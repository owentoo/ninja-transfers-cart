{%- liquid
  assign isgloablenable = false
  case request.page_type
    when 'page'
      assign isgloablenable = page.metafields.custom.disable_global_title
  endcase

  assign urlParts = request.path | split: "/"
  assign urlPartsLastIndex = urlParts.size | minus: 1
  assign targetCollectionName = urlParts[urlPartsLastIndex]
  assign targetCollection = collections[targetCollectionName]

  if targetCollection == blank
    assign targetCollection = collection
  endif

  assign pageDescription = page_description
  if isgloablenable == false
    if targetCollection
      assign pageDescription = targetCollection.metafields.global.description_tag
    endif
  endif

  assign pageTitle = page_title
  if isgloablenable == false
    if targetCollection
      assign pageTitle = targetCollection.metafields.global.title_tag
    endif
  endif
-%}
