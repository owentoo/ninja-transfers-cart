    <script>
      $(function () {

        function getHeaderH(){
          return $('.shopify-section-header').outerHeight() || 0;
        }

        function getY($el){
          return $el[0].getBoundingClientRect().top + window.pageYOffset;
        }

        function scrollToYotpo(){
          var $target = $('#yotpo-app');
          if(!$target.length) return;
          // Pass 1: go near target quickly (triggers lazy-render without needing exact)
          var firstY = getY($target) - getHeaderH() - 120; // a bit above
          $('html, body').stop(true).animate({ scrollTop: Math.max(0, firstY) }, 350);
          // Pass 2: after layout changes settle, go exact
          setTimeout(function(){
            var finalY = getY($target) - getHeaderH();
            $('html, body').stop(true).animate({ scrollTop: Math.max(0, finalY) }, 500);
          }, 450);
        }
        $(document).on("click", ".yotpo-reviews-star-ratings-widget button", function(e){
          e.preventDefault();
          scrollToYotpo();
        });
      });
    </script>

