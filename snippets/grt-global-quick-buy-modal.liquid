{%- assign modal_currency = localization.country.currency.iso_code | default: shop.currency -%}
<div
  class="grt-global-quick-buy-modal"
  data-grt-global-quick-buy-modal
  data-grt-global-quick-buy-currency="{{ modal_currency }}"
>
  <dialog class="grt-global-quick-buy-modal__dialog" data-grt-global-quick-buy-dialog>
    <div class="grt-global-quick-buy-modal__container">
      <div class="grt-global-quick-buy-modal__loading" data-grt-modal-loading aria-hidden="true">
        <div class="grt-global-quick-buy-modal__spinner" aria-hidden="true"></div>
        <div class="grt-global-quick-buy-modal__loading-text" data-grt-modal-loading-text>Loading product...</div>
      </div>
      <div class="grt-global-quick-buy-modal__content">
        <div class="grt-global-quick-buy-modal__layout">

          <div class="grt-global-quick-buy-modal__media" data-grt-modal-image>
            <figure class="grt-global-quick-buy-modal__image-figure">
              <img
                src="{{ 'transparent.png' | asset_url }}"
                alt=""
                data-grt-modal-image-preview
              />
            </figure>
          </div>

          <div class="grt-global-quick-buy-modal__details" data-grt-modal-details>
            <button
              type="button"
              class="grt-global-quick-buy-modal__close"
              data-grt-global-quick-buy-close
              aria-label="Close quick buy"
            >
              ×
            </button>

            <div class="grt-global-quick-buy-modal__header">
              <div class="grt-global-quick-buy-modal__rating" data-grt-modal-rating></div>
              <template data-grt-modal-rating-template>
                <div id="yotpoProductReviews">
                  <div class="grt-global-quick-buy-modal__yotpo-shell" data-grt-modal-yotpo-shell>
                    <div
                      class="yotpo-widget-instance"
                      id="quick-buy-yotpo"
                      data-yotpo-instance-id="447610"
                      data-yotpo-product-id=""
                      data-yotpo-section-id="quick-buy-modal"
                      data-yotpo-preloaded-data=""
                    ></div>
                  </div>
                </div>
              </template>
              <div class="grt-global-quick-buy-modal__title-wrapper">
                <h2 class="grt-global-quick-buy-modal__title" data-grt-modal-title>Product Title</h2>
                <div class="grt-global-quick-buy-modal__full-details">
                  <a href="#" target="_blank" rel="noopener noreferrer" data-grt-modal-product-link>View Full Details</a>
                </div>
              </div>
              <div class="grt-global-quick-buy-modal__price-container">
                <span class="grt-global-quick-buy-modal__price" data-grt-modal-price>---</span>
                <span class="grt-global-quick-buy-modal__compare-price" data-grt-modal-compare-price></span>
              </div>
            </div>

            <p class="grt-global-quick-buy-modal__description" data-grt-modal-description></p>

            <div class="grt-global-quick-buy-modal__variant-options" data-grt-modal-variant-options></div>
            <div class="grt-global-quick-buy-modal__label grt-global-quick-buy-modal__size-label-heading" data-grt-modal-size-label style="display:none;">Variant</div>
            <div class="grt-global-quick-buy-modal__size-grid" data-grt-modal-size-grid data-size-qty-grid></div>

            <form
              class="grt-global-quick-buy-modal__form"
              method="post"
              action="/cart/add"
              data-grt-modal-form
              novalidate
            >
              <template data-grt-modal-form-template>
                <input type="hidden" name="id" value="">
              </template>

              <div class="grt-global-quick-buy-modal__qty" data-qty-wrap>
                <label class="grt-global-quick-buy-modal__label">Quantity</label>
                <div class="grt-global-quick-buy-modal__qty-control">
                  <button type="button" class="grt-global-quick-buy-modal__qty-btn" data-grt-qty-minus aria-label="Decrease quantity">
                    -
                  </button>
                  <input
                    type="number"
                    class="grt-global-quick-buy-modal__qty-input"
                    name="quantity"
                    value="1"
                    min="1"
                    step="1"
                    inputmode="numeric"
                    pattern="[0-9]*"
                    data-grt-qty-input
                  />
                  <button type="button" class="grt-global-quick-buy-modal__qty-btn" data-grt-qty-plus aria-label="Increase quantity">
                    +
                  </button>
                </div>
              </div>

              <div class="grt-global-quick-buy-modal__buttons">
                <button
                  type="submit"
                  class="grt-global-quick-buy-modal__add-button button"
                  data-grt-modal-submit
                >
                  Add to cart
                </button>
              </div>
            </form>

          </div>
        </div>
      </div>
    </div>
  </dialog>
</div>
