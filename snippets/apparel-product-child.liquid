{% if showJSData != false %}
<script>
  let lastAddToCartTime = 0;
  function addToCart () {
    const curTime = new Date().getTime();
    if (lastAddToCartTime > 0 && (curTime - lastAddToCartTime) <= 3000) {
      return; // prevent multiple AddToCarts from being called within x ms
    }
    lastAddToCartTime = curTime;

    console.log("addToCart called")
    $(".errorMessages").hide();
    const itemsToAdd = [];
    const errorMessages = [];
    $(".itemQuantity").each(function () {
      var id = $(this).attr("data-id");
      var label = $(this).attr("data-label");
      var quantity = parseInt($(this).val());
      var quantityMax = parseInt($(this).attr("data-max"));
      var tp = atob($(this).attr("data-tp"));
      const properties = {
        {% if product.options.size < 2 %}
        'Color': $("#hf_productColor").val(),
        {% endif %}
        '_tp': tp
      }
      console.log("Adding line item properties");
      console.log(JSON.stringify(properties,null,2))
      $(this).css("border","1px solid #e0e0e0")
      if (quantity > 0) {
        if (quantity > quantityMax) {
          errorMessages.push(`Size ${label} only has ${quantityMax} items in stock.`)
          $(this).css("border","2px solid #ff0000")
        }
        else {
          itemsToAdd.push({ id, quantity, properties });
        }
      }
    });

    if (errorMessages.length == 0 && itemsToAdd.length == 0) {
      errorMessages.push("No quantities chosen")
    }

    if (errorMessages.length) {
      $(".errorMessages").show();
      $(".errorMessages .errorList").html("<li>"+errorMessages.join("</li><li>")+"</li>");
    }
    else if (itemsToAdd.length) {
      console.log("Adding items to cart: " + JSON.stringify(itemsToAdd))
      $(".addToCartSection button").addClass("working");

      function showCartDrawer (jsonResponse) {
        $.get('/?section_id=helper-cart', function ( r ) {
          const sectionInnerHTML = new DOMParser().parseFromString(r, 'text/html');
          const cartFormInnerHTML = sectionInnerHTML.getElementById('AjaxCartForm').innerHTML;
          const cartSubtotalInnerHTML = sectionInnerHTML.getElementById('AjaxCartSubtotal').innerHTML;

          const cartItems = document.getElementById('AjaxCartForm');
          cartItems.innerHTML = cartFormInnerHTML;
          cartItems.ajaxifyCartItems();

          document.getElementById('AjaxCartSubtotal').innerHTML = cartSubtotalInnerHTML;

          document.querySelectorAll('[data-header-cart-count]').forEach(elm=>{
            //elm.textContent = document.querySelector('#AjaxCartForm [data-cart-count]').textContent;
            let _cartno = document.querySelector('#AjaxCartForm [data-cart-count]').textContent;
            elm.textContent = _cartno;
            elm.setAttribute("data-count",_cartno);
          });
          document.querySelectorAll('[data-header-cart-total').forEach(elm=>{
            elm.textContent = document.querySelector('#AjaxCartForm [data-cart-total]').textContent;
          });

          //dispatchEvent(new Event('add-to-cart'))

          $('#site-cart-sidebar')[0].show();


          $(".addToCartSection button").removeClass("working");
          $(".itemQuantity").val("");
          resetPrices();
          _saving_update();
        });
      }

      $.ajax({
        type: "POST",
        url: '/cart/add.js',
        data: { items: itemsToAdd },
        dataType: 'json',
        success: function (response) {
          showCartDrawer(response);
        },
        error: function (response) {
          console.log("Could not add items: " + response);
          $(".errorMessages").show();
          $(".errorMessages .errorList").html("<li>An error has occurred.  Please try again.</li>");
        }
      });
    }
  }

  function initColors () {
    {% comment %}
    // {{ style_category }}
  {%  for collection in selectedProduct.collections %}
    // {{ collection.title }}
  {%  endfor %}

    var colors = [];
  {% for style_product in sortedColors %}
    // shirt_prim_hex: {{ style_product.metafields.specs.shirt_prim_hex }}
    {% assign inventoryTotal=0 %}
    {% for variant in style_product.variants %}
    {% assign inventoryTotal = inventoryTotal | plus:variant.inventory_quantity %}
    {% endfor %}

    {% if style_product.metafields.specs.shirt_prim_hex %}
      {% assign colorUrl = "/products/" | append: product.handle | append: "?variant=" | append: style_product.metafields.specs.shirt_color %}
      {% if inventoryTotal > 0  %}
        colors.push({ hex: '#{{ style_product.metafields.specs.shirt_prim_hex }}', name: '{{style_product.metafields.specs.shirt_color}}', out: '', url: '{{ colorUrl }}' })
      {% else %}
        colors.push({ hex: '#{{ style_product.metafields.specs.shirt_prim_hex }}', name: '{{style_product.metafields.specs.shirt_color}}', out: '(OUT)', url: '{{ colorUrl }}' })
      {% endif %}
    {% endif %}
  {% endfor %}

    new Vue({
      el: '#color-picker',
      data: {
        active: false,
        selectedColor: '#{{ selectedProduct.metafields.specs.shirt_prim_hex }}',
        selectedColorName: '{{ selectedProduct.metafields.specs.shirt_color }}',
        colors: colors
      },
      computed: {
        selector: function() {
          if(!this.selectedColor) {
            return 'Color';
          }
          else {
            return '<span class="swatchItem" style="background: ' + this.selectedColor + '"></span> ' + this.selectedColorName;
          }
        }
      },
      methods: {
        setColor: function(color, colorName, url) {
          this.selectedColor = color;
          this.selectedColorName = colorName;
          this.active = false;
                //window.history.replaceState(null, null, url + "/" + document.location.search);
                document.location = url;
        },
        toggleDropdown: function() {
          this.active = !this.active;
        },
      }
    });
    {% endcomment %}
  }

  function refreshItemPrices() {
    getCartTotalOriginalPrice(function(cartTotal) {
        $(".tierPricingBulkGridTable .tierRow").removeClass("active");
        
        let formTotalOriginal = 0;
        $(".itemQuantity").each(function () {
            const $itemQuantity = $(this);
            const quantity = parseInt($itemQuantity.val());
            if (!isNaN(quantity)) {
                const originalPrice = parseInt($itemQuantity.attr("data-price"));
                formTotalOriginal += originalPrice * quantity;
            }
        });

        const virtualTotal = (cartTotal + formTotalOriginal) / 100;
        let tierLevel = 0;
        if (virtualTotal >= 3800) tierLevel = 7;
        else if (virtualTotal >= 1750) tierLevel = 6;
        else if (virtualTotal >= 1000) tierLevel = 5;
        else if (virtualTotal >= 500) tierLevel = 4;
        else if (virtualTotal >= 250) tierLevel = 3;
        else if (virtualTotal >= 150) tierLevel = 2;
        else if (virtualTotal >= 99) tierLevel = 1;

        if (tierLevel > 0) $(".tierPricingBulkGridTable .tier" + tierLevel).addClass("active");

        $(".itemQuantity").each(function () {
            const $itemQuantity = $(this);
            let itemPrice = parseInt($itemQuantity.attr("data-price"));
            if (tierLevel > 0) {
                const itemTierLevels = $itemQuantity.attr("data-tiers").split(',');
                if (itemTierLevels.length == 7) itemPrice = parseInt(itemTierLevels[tierLevel - 1]);
            }
            $(".label-price", $itemQuantity.parent()).html("$" + (parseFloat(itemPrice) / 100.0).toFixed(2));
        });
    });
  }

  function getCartTotalOriginalPrice(callback) {
      fetch('/cart.js')
          .then(response => response.json())
          .then(data => {
              const totalOriginalPrice = data.total_price;
              callback(totalOriginalPrice);
          })
          .catch(error => console.error('Error fetching cart data:', error));
  }

  initColors()

  let estimateDeliveryDateRefreshPending = false;
  function checkEstimateDeliveryDateRefreshPending () {
    if (estimateDeliveryDateRefreshPending) {
      estimateDeliveryDateRefreshPending = false;
      estimateDeliveryDate();
    }
    setTimeout(checkEstimateDeliveryDateRefreshPending, 1000);
  }

  $(".itemQuantity").on("keyup", function () {
    refreshItemPrices();
    // estimateDeliveryDateRefreshPending = true;
  })
  refreshItemPrices();
  checkEstimateDeliveryDateRefreshPending();
  function updatePrices() {
    const inputs = document.querySelectorAll('input.itemQuantity');

    inputs.forEach(input => {
        input.addEventListener('input', () => {
            function getCartTotalOriginalPrice(callback) {
                fetch('/cart.js')
                    .then(response => response.json())
                    .then(data => {
                        const totalOriginalPrice = data.total_price;
                        callback(totalOriginalPrice);
                    })
                    .catch(error => console.error('Error fetching cart data:', error));
            }

            getCartTotalOriginalPrice(function(cartTotalActual) {
                const cartTotal = cartTotalActual;
                const enteredQuantity = parseFloat(input.value) || 0;
                let variantPrice = parseFloat(input.getAttribute('data-price'));
                let actualPrice = parseFloat(input.getAttribute('data-variant-price'));

                const newPrice = (enteredQuantity * variantPrice);
                const virtualTotal = (cartTotal + newPrice) / 100;
                let tierLevel = 0;

                if (virtualTotal >= 3800) tierLevel = 7;
                else if (virtualTotal >= 1750) tierLevel = 6;
                else if (virtualTotal >= 1000) tierLevel = 5;
                else if (virtualTotal >= 500) tierLevel = 4;
                else if (virtualTotal >= 250) tierLevel = 3;
                else if (virtualTotal >= 150) tierLevel = 2;
                else if (virtualTotal >= 99) tierLevel = 1;

                if (tierLevel > 0) {
                    const itemTierLevels = input.getAttribute("data-tiers").split(',');
                    if (itemTierLevels.length === 7) variantPrice = parseInt(itemTierLevels[tierLevel - 1], 10);
                }

                const currentPriceSpan = input.nextElementSibling.querySelector('span.money');
                if (currentPriceSpan) {
                    if (enteredQuantity <= 0 && cartTotal <= 0) {
                        currentPriceSpan.textContent = `$${actualPrice}`;
                    } else if (cartTotal > 0 && enteredQuantity <= 0){
                      const newCartTotal = cartTotal / 100
                      let newTierLevel = 0;
                      if (newCartTotal >= 3800) newTierLevel = 7;
                      else if (newCartTotal >= 1750) newTierLevel = 6;
                      else if (newCartTotal >= 1000) newTierLevel = 5;
                      else if (newCartTotal >= 500) newTierLevel = 4;
                      else if (newCartTotal >= 250) newTierLevel = 3;
                      else if (newCartTotal >= 150) newTierLevel = 2;
                      else if (newCartTotal >= 99) newTierLevel = 1;
                      if (newTierLevel > 0) {
                          const itemTierLevels = input.getAttribute("data-tiers").split(',');
                          if (itemTierLevels.length === 7) variantPrice = parseInt(itemTierLevels[newTierLevel - 1], 10);                        
                      }
                      const formattedPrice = (variantPrice / 100).toFixed(2);
                      currentPriceSpan.textContent = `$${formattedPrice}`;
                    } else {
                        const formattedPrice = (variantPrice / 100).toFixed(2);
                        currentPriceSpan.textContent = `$${formattedPrice}`;
                    }
                }

                inputs.forEach(otherInput => {
                    if (otherInput !== input) {
                        let otherVariantPrice = parseFloat(otherInput.getAttribute('data-price'));
                        let otherVariantActualPrice = parseFloat(otherInput.getAttribute('data-variant-price'));
                        const otherNewPrice = (enteredQuantity * otherVariantPrice);
                        const virtualTotal = (cartTotal + otherNewPrice) / 100;
                        let tierLevel = 0;

                        if (virtualTotal >= 3800) tierLevel = 7;
                        else if (virtualTotal >= 1750) tierLevel = 6;
                        else if (virtualTotal >= 1000) tierLevel = 5;
                        else if (virtualTotal >= 500) tierLevel = 4;
                        else if (virtualTotal >= 250) tierLevel = 3;
                        else if (virtualTotal >= 150) tierLevel = 2;
                        else if (virtualTotal >= 99) tierLevel = 1;

                        if (tierLevel > 0) {
                            const itemTierLevels = otherInput.getAttribute("data-tiers").split(',');
                            if (itemTierLevels.length === 7) otherVariantPrice = parseInt(itemTierLevels[tierLevel - 1], 10);
                        }

                        const otherPriceSpan = otherInput.nextElementSibling.querySelector('span.money');
                        if (otherPriceSpan) {
                            if (enteredQuantity <= 0 && cartTotal <= 0) {
                                otherPriceSpan.textContent = `$${otherVariantActualPrice}`;
                            } else if (cartTotal > 0 && enteredQuantity <= 0) {
                              const newCartTotal = cartTotal / 100
                              let newTierLevel = 0;
                              if (newCartTotal >= 3800) newTierLevel = 7;
                              else if (newCartTotal >= 1750) newTierLevel = 6;
                              else if (newCartTotal >= 1000) newTierLevel = 5;
                              else if (newCartTotal >= 500) newTierLevel = 4;
                              else if (newCartTotal >= 250) newTierLevel = 3;
                              else if (newCartTotal >= 150) newTierLevel = 2;
                              else if (newCartTotal >= 99) newTierLevel = 1;
                              if (newTierLevel > 0) {
                                  const itemTierLevels = otherInput.getAttribute("data-tiers").split(',');
                                  if (itemTierLevels.length === 7) otherVariantPrice = parseInt(itemTierLevels[newTierLevel - 1], 10);                        
                              }
                              const formattedPrice = (otherVariantPrice / 100).toFixed(2);
                              otherPriceSpan.textContent = `$${formattedPrice}`;
                            } else {
                                const formattedPrice = (otherVariantPrice / 100).toFixed(2);
                                otherPriceSpan.textContent = `$${formattedPrice}`;
                            }
                        }
                    }
                });
            });
        });
    });
  }

  updatePrices(); 
  resetPrices();
  {% if template.suffix == "blanks" %}
    collectionItemsLoaded();
  {% endif %}
  function resetPrices() {
    document.querySelectorAll('.itemQuantity').forEach(input => {

      function getCartTotalOriginalPrice(callback) {
          fetch('/cart.js')
              .then(response => response.json())
              .then(data => {
                  const totalOriginalPrice = data.total_price;
                  callback(totalOriginalPrice);
              })
              .catch(error => console.error('Error fetching cart data:', error));
          }

          getCartTotalOriginalPrice(function(cartTotalActual) {
            const cartTotal = cartTotalActual;
            let variantPrice = parseFloat(input.getAttribute('data-price'));
            const nextLabel = input.nextElementSibling;

            const newCartTotal = cartTotal / 100;
            let newTierLevel = 0;
            if (newCartTotal >= 3800) newTierLevel = 7;
            else if (newCartTotal >= 1750) newTierLevel = 6;
            else if (newCartTotal >= 1000) newTierLevel = 5;
            else if (newCartTotal >= 500) newTierLevel = 4;
            else if (newCartTotal >= 250) newTierLevel = 3;
            else if (newCartTotal >= 150) newTierLevel = 2;
            else if (newCartTotal >= 99) newTierLevel = 1;
            if (newTierLevel > 0) {
                const itemTierLevels = input.getAttribute("data-tiers").split(',');
                if (itemTierLevels.length === 7) variantPrice = parseInt(itemTierLevels[newTierLevel - 1], 10);                        
            }
          if (cartTotal <= 0 ){
            const pricePerUnit = parseFloat(input.getAttribute('data-variant-price'));
            if (nextLabel && nextLabel.tagName === 'LABEL') {
                const priceSpan = nextLabel.querySelector('.money');
                if (priceSpan) {
                    priceSpan.textContent = `$${pricePerUnit}`;
                }
            }                
          } else {
            if (nextLabel && nextLabel.tagName === 'LABEL') {
                const priceSpan = nextLabel.querySelector('.money');
                const formattedPrice = (variantPrice / 100).toFixed(2);
                if (priceSpan) {
                    priceSpan.textContent = `$${formattedPrice}`;
                }
            }
          }
        })
    });
  }  
</script>
