{% assign stylesToForceChildModel = '' | split:","  %}
{% assign useVariantRender = false %}

{% if product.variants.first.options.size == 2 %}
  {% unless stylesToForceChildModel contains product.metafields.specs.shirt_style %}
    {% assign useVariantRender = true %}
  {% endunless %}  
{% endif %}

{% if useVariantRender %}
  {% if product.variants.first.options.size == 2 %}
    {% assign colorlist_string = '' %}
    {% paginate product.variants by 2049 %}
      {% for variant in product.variants %}
        {% assign color = variant.option1 %}
        {% assign colorlist_string = colorlist_string | append: color | append: ',' %}
      {% endfor %}
    {% endpaginate %}
    
    {% assign colorlist = colorlist_string | split: ',' %}
    {% assign sortedColors = colorlist | uniq %}
  {% endif %}
  {% render "apparel-variant", colorlist: sortedColors %}
{% else %}

  <!-- MASTER PRODUCT RENDER -->
{%- assign page_url = content_for_header
  | split: '"pageurl":"'
  | last
  | split: '"'
  | first
  | split: request.host
  | last
  | replace: '\/', '/'
  | replace: '%20', ' '
  | replace: '\u0026', '&'
-%}
{% assign param_color = null %}
{% assign param_variant_id = null %}

{%- for i in (1..1) -%}
  {%- unless page_url contains '?' -%}{% break %}{%- endunless -%}
  {%- assign query_string = page_url | split: '?' | last -%}
  {%- assign qry_parts = query_string | split: '&' -%}

  {%- for part in qry_parts -%}
    {%- assign key_and_value = part | split: '=' -%}
    {%- if key_and_value.size > 1 -%}
      {% if key_and_value[0] == 'variant' %}
        {% assign param_arr = key_and_value[1] | split: '_' %}
        {% assign param_color = param_arr[0] | upcase | url_decode %}
        {% assign param_variant_id = param_arr[1] %}
      {% endif %}
    {%- endif -%}
  {%- endfor -%}
{%- endfor -%}

{% assign style_category = 'style-' | append: product.metafields.specs.shirt_style %}
{% assign style_collection = product.collections | where: 'handle', style_category | first %}

{% paginate style_collection.products by 1000 %}
  {% assign sortedColors = style_collection.products | sort: 'url' %}
{% endpaginate %}

{% assign defaultProduct = blank %}
{% assign selectedProduct = blank %}
{% for style_product in sortedColors %}
  {% assign shirt_color = style_product.metafields.specs.shirt_color | upcase %}
  {% if style_product.metafields.specs.shirt_color == product.metafields.specs.default_child_color %}
    {% assign defaultProduct = style_product %}
  {% endif %}
  {% if param_color and shirt_color == param_color %}
    {% assign selectedProduct = style_product %}
  {% endif %}
{% endfor %}

{% if selectedProduct == blank %}
  {% assign selectedProduct = defaultProduct %}
{% endif %}

{% assign style_category = 'style-' | append: selectedProduct.metafields.specs.shirt_style %}
{% assign collection = selectedProduct.collections | where: 'handle', style_category | first %}

{% paginate collection.products by 1000 %}
  {% assign sortedColors = collection.products | sort: 'url' %}
{% endpaginate %}

{% assign selectedColor = blank %}
{% assign selectedColorHex = blank %}
{% assign selectedColorSecHex = blank %}
{% assign selectedColorAlt = blank %}
{% assign selectedColorAltHex = blank %}
{% assign selectedColorAltSecHex = blank %}
{% assign selectedProductAlt = blank %}

{% for style_product in sortedColors %}
  {% assign inventoryTotal = 0 %}
  {% for variant in style_product.variants %}
    {% assign inventoryTotal = inventoryTotal | plus: variant.inventory_quantity %}
  {% endfor %}

  {% if inventoryTotal > 0 %}
    {% if selectedColorAlt == blank %}
      {% assign selectedColorAlt = style_product.metafields.specs.shirt_color %}
      {% assign selectedColorAltHex = style_product.metafields.specs.shirt_prim_hex %}
      {% assign selectedColorAltSecHex = style_product.metafields.specs.shirt_sec_hex %}
      {% assign selectedProductAlt = style_product %}
    {% endif %}

    {% if style_product.metafields.specs.shirt_color == selectedProduct.metafields.specs.shirt_color %}
      {% assign selectedColor = style_product.metafields.specs.shirt_color %}
      {% assign selectedColorHex = style_product.metafields.specs.shirt_prim_hex %}
      {% assign selectedColorSecHex = style_product.metafields.specs.shirt_sec_hex %}
    {% endif %}
  {% endif %}
{% endfor %}

{% if selectedColor == blank %}
  {% assign selectedColor = selectedColorAlt %}
  {% assign selectedColorHex = selectedColorAltHex %}
  {% assign selectedColorSecHex = selectedColorAltSecHex %}
  {% assign selectedProduct = selectedProductAlt %}
{% endif %}

<input type="hidden" id="hf_productRenderModel" value="masterChild">
<input type="hidden" id="hf_productStyle" value="{{ selectedProduct.metafields.specs.shirt_style }}">
<input type="hidden" id="hf_productColor" value="{{ selectedProduct.metafields.specs.shirt_color }}">
<input type="hidden" id="hf_variantId" value="{{ param_variant_id }}">

{% render 'apparel-product-color-picker-dev',
  product: product,
  isPopUp: isPopUp,
  handleIncludes: selectedProduct.metafields.specs.shirt_style,
  colors: sortedColors,
  selectedColor: selectedColor,
  selectedColorHex: selectedColorHex,
  selectedColorSecHex: selectedColorSecHex,
  showJSData: showJSData
%}

<div
  class="apparel-product-child-wrapper"
  style="padding:20px;padding-left:20px;background-color:#f6f6f6;padding-right:20px;border-top-left-radius:8px;border-top-right-radius:8px;border-bottom-left-radius:8px;border-bottom-right-radius:8px;"
>
  <h5 style="font-size:1em;font-weight:700;margin-bottom:15px;" class="">Choose Size</h5>
  {% if product.options.size > 1 %}
    <div class="flex-bar variantsData variant2020">
    {% assign color_variants = '' | split: ',' %}
    {% paginate product.variants by 2049 %}
      {% for variant in product.variants %}
        {% assign color = variant.option1 %}
        {% if color == selectedColor %}
          {% render 'blank-variant-list', variant:variant %}
        {% endif %}
      {% endfor %}
    {% endpaginate %}
    </div>
  {% else %}
  <div class="flex-bar variantsData">
    {% paginate product.variants by 2049 %}
    {% for variant in selectedProduct.variants %}
      {% if variant.price == 0 or variant.sku contains '-T' %}
        {% continue %}
      {% endif %}
      {% render 'blank-variant-list', variant:variant %}
    {% endfor %}
    {% endpaginate %}
  </div>
  {% endif %}

  {% if isPopUp != true %}
    <div style="margin-top:20px;">
     {% render "apparel-product-delivery-estimate" %}
    </div>
  {% endif %}

  <div class="errorMessages" style="display:none;color:#ff0000;">
    <div style="font-weight:700;">Unable to add items to cart:</div>
    <ul class="errorList" style="margin-top:0px;"></ul>
  </div>

  <div class="product__cart-functions" another-transfer="" style="margin-top:0px;">
    <div class="addToCartSection flex-buttons">
      {% if isPopUp != true %}
        <button
          type="submit"
          onclick="addToCart();"
          name="add"
          class="add-to-cart button button--solid button--product button--loader button--move"
        >
          <span class="button__text"> Add To Cart </span>
          <span class="button__preloader">
            <svg class="button__preloader-element" viewBox="25 25 50 50">
              <circle cx="50" cy="50" r="20" fill="none" stroke-width="4"></circle>
            </svg>
          </span>
        </button>
      {% else %}
        {% if isUpsellPopup %}
          <span onclick="addToCartPopup_upsell();" class="button button--solid button--product button--loader button--move">
            <span class="button__text"> Add To Cart </span>
            <span class="button__preloader">
              <svg class="button__preloader-element" viewBox="25 25 50 50">
                <circle cx="50" cy="50" r="20" fill="none" stroke-width="4"></circle>
              </svg>
            </span>
          </span>
        {% else %}
          <span onclick="addToCartPopup();" class="button button--solid button--product button--loader button--move">
            <span class="button__text"> Add To Cart </span>
            <span class="button__preloader">
              <svg class="button__preloader-element" viewBox="25 25 50 50">
                <circle cx="50" cy="50" r="20" fill="none" stroke-width="4"></circle>
              </svg>
            </span>
          </span>
        {% endif %}
      {% endif %}
    </div>
    {% if isUpsellPopup %}
      <div class="flex-buttons">
        <a href="javascript://" class="button button--solid button--product button--loader button--move addToCartThenCheckout">
          <span class="button__text">Checkout</span>
        </a>
      </div>
    {% endif %}
  </div>

  {% if isPopUp != true %}
    <div class="product-actions" {{ block.shopify_attributes }}>
      {%- if block.settings.show_price -%}
        <div
          class="sidebar-widget sidebar-widget--{{ block.settings.style }} {% unless default_to_first_variant %} hide {% endunless %}"
          data-js-product-price-extended
        >
          {%- if block.settings.style == 'outline' -%}
            <span class="sidebar-widget__title">{{ 'products.page.price' | t }}</span>
          {%- endif -%}
          <div class="sidebar-widget__content">
            <div>
              {%- render 'product-price', variant: current_variant, target: current_variant, show_saving: true -%}
            </div>
          </div>
        </div>
      {%- endif -%}

      <product-form
        id="add-to-cart-{{ section.id }}"
        class="product-form"
        {% if settings.cart_action == 'overlay' %}
          data-ajax-cart data-js-product-form
        {% endif %}
      >
        {%- form 'product',
          product,
          id: product_form_id,
          class: 'form',
          novalidate: 'novalidate',
          data-type: 'add-to-cart-form'
        -%}
          <div class="form__properties"></div>

          <template>
            <input type="hidden" name="id" value="{{ current_variant.id }}">
          </template>
          <script>
            document.getElementById('add-to-cart-{{ section.id }}').querySelector('form').append(document.getElementById('add-to-cart-{{ section.id }}').querySelector('template').content.cloneNode(true));
            {% if b.afterAddtoCart_goCart %}
              const afterAddtoCart_goCart_redirect = true;
            {% endif %}
          </script>

          {%- liquid
            if product.gift_card? and block.settings.show_gift_card_recipient
              render 'gift-card-recipent-form', product: product
            endif
          -%}

          {% if isPopUp != true %}
            <div class="product__cart-functions">
              <div class="flex-buttons">
                {% if b.allowAnotherTransfer and b.anotherTransferPosition == 'above' %}
                  <span
                    class="anotherTransfer above{% if b.fillAnotherTransferBtn %} button button--solid button--product{% endif %}{% if b.fullWidthButtons %} btnFullWidth{% endif %}"
                  >
                    <span class="anotherTransfer__btnText">
                      {{ b.allowAnotherTransfer__label }}
                    </span>
                  </span>
                {% endif %}

                {%- if block.settings.show_quantity_selector -%}
                  <product-quantity
                    class="
                      product-quantity quantity-selector-holder
                      {% if default_to_first_variant %} hide {% endif %}
                    "
                  >
                    <button
                      class="qty-button qty-minus no-js-hidden"
                      aria-label="{{ 'general.accessibility_labels.decrease_quantity' | t }}"
                      role="button"
                      controls="qty-{{ section.id }}"
                    >
                      {%- render 'theme-symbols', icon: 'minus' -%}
                    </button>
                    <label for="qty-{{ section.id }}" class="visually-hidden">
                      {{- 'general.accessibility_labels.quantity' | t -}}
                    </label>
                    <input
                      type="number"
                      name="quantity"
                      value="1"
                      min="1"
                      max="999"
                      class="qty qty-selector product__quantity"
                      id="qty-{{ section.id }}"
                    >
                    <button
                      class="qty-button qty-plus no-js-hidden"
                      aria-label="{{ 'general.accessibility_labels.increase_quantity' | t }}"
                      role="button"
                      controls="qty-{{ section.id }}"
                    >
                      {%- render 'theme-symbols', icon: 'plus' -%}
                    </button>
                  </product-quantity>
                {%- endif -%}

                <button
                  type="submit"
                  name="add"
                  class="
                    add-to-cart button button--solid button--product button--loader button--move
                    {% unless current_variant.available %} disabled {% endunless %}
                    {% unless default_to_first_variant %} disabled {% endunless %}
                  "
                  data-js-product-add-to-cart
                  data-main-product-add-to-cart
                >
                  <span class="button__text" data-js-product-add-to-cart-text>
                    {%- liquid
                      unless default_to_first_variant
                        if product.available
                          if b.buttonText != blank
                            echo b.buttonText
                          else
                            echo 'products.grid.choose_variant_first' | t
                          endif
                        else
                          echo 'products.page.inventory.sold_out_variant' | t
                        endif
                      else
                        if current_variant.available
                          if b.buttonText != blank
                            echo b.buttonText
                          else
                            echo 'products.page.add_to_cart_button' | t
                          endif
                        else
                          echo 'products.page.inventory.sold_out_variant' | t
                        endif
                      endunless
                    -%}
                  </span>
                  <span class="button__preloader">
                    <svg class="button__preloader-element" viewBox="25 25 50 50">
                      <circle cx="50" cy="50" r="20" fill="none" stroke-width="4"/>
                    </svg>
                  </span>
                </button>

                {%- liquid
                  if block.settings.show_dynamic_checkout and block.settings.show_gift_card_recipient == false
                    echo form | payment_button
                  endif
                -%}

                {% if b.allowAnotherTransfer and b.anotherTransferPosition == 'below' %}
                  <span
                    class="anotherTransfer above{% if b.fillAnotherTransferBtn %} button button--solid button--product{% endif %}{% if b.fullWidthButtons %} btnFullWidth{% endif %}"
                  >
                    <span class="anotherTransfer__btnText">
                      {{ b.allowAnotherTransfer__label }}
                    </span>
                  </span>
                {% endif %}
              </div>
            </div>
          {% endif %}

          {% for item in customTabelItems %}
            {%- assign tItems = item.settings -%}
            {%- capture minMax -%}
                {%- if tItems.title contains '-' -%}
                  {%- assign min = tItems.title | split: '-' | first | strip -%}
                  {%- assign max = tItems.title | split: '-' | last | strip -%}
                {%- elsif tItems.title contains '+' -%}
                  {%- assign min = tItems.title | split: '+' | first | strip -%}
                  {%- assign max = 1000000 -%}
                {%- endif -%}
              {%- endcapture -%}
            {%- capture percentages -%}
                {%- if tItems.title_2 contains '%' -%}
                  {%- assign offPercentage = tItems.title_2 | split: '%' | first | strip -%}
                {%- endif -%}
              {%- endcapture -%}
            {% if forloop.first %}
              {%- assign getUnitPrice_1st = tItems.title_3 | default: '&nbsp;' -%}
            {% endif %}
            {% assign _dis = _dis | append: 'min_' %}
            {% assign _dis = _dis | append: min %}
            {% assign _dis = _dis | append: '-off_' %}
            {% assign _dis = _dis | append: offPercentage %}
            {% assign _dis = _dis | append: '#' %}

            {% assign _dis_title = _dis_title
              | append: offPercentage
              | append: '%25_off_for_'
              | append: min
              | append: '+_transfers#'
            %}
            {% assign _dis_title = _dis_title | split: '+' | join: '' %}
            {% if forloop.last %}
              <input type="hidden" id="discount_input" name="properties[_discount_input]" value="{{ _dis }}">
              <input type="hidden" id="discount_input" name="properties[_discount_name]" value="{{ _dis_title }}">
            {% endif %}
          {% endfor %}
        {%- endform -%}
      </product-form>

      {% if isPopUp != true %}
        {%- form 'product', product, id: 'product-form-installment' -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}">
          {{ form | payment_terms }}

          {% render 'custom-payment-terms' %}
        {%- endform -%}
      {% endif %}

      {% if block.settings.enable_payment_terms %}
        {% render 'custom-payment-terms' %}
      {% endif %}

      <script>
        document
          .querySelector('shopify-payment-terms')
          .shadowRoot.querySelector('*')
          .setAttribute('style', 'text-align: center;');
      </script>
    </div>
  {% endif %}

  <script>
    if ( typeof loaderGif == 'undefined' ) {
      loaderGif = `{{ 'loader.gif' | asset_url }}`;
    }
    anotherTransfer = false;
    $( document )
    .ready(function() {
      {% if b.buttonText != blank %}
        KROWN.settings.locales.products_add_to_cart_button = '{{ b.buttonText }}';
      {% endif %}
    })
    .on(`click`, `.anotherTransfer`,async function( e ) {
      try {
        e.stopImmediatePropagation();
        anotherTransfer = true;
        $( this )
          .closest( `form` )
          .find( `.add-to-cart[data-main-product-add-to-cart]` )
          .click();

        if ( typeof ElementAvailibility === 'function' ) {
          ElementAvailibility ( `#site-cart-sidebar.sidebar.sidebar--opened`, 'refreshAll__child', 30 );
        }
      } catch ( err ) {
        console.log( `ERROR .anotherTransfer`, err.message );
      }
    })
    ;

    function refreshAll__child() {
      try {
        console.log ( 'refreshAll done' );
        anotherTransfer = false;
        // location.href = "?";
        $( `#site-cart-sidebar.sidebar.sidebar--opened` )
          .find( `.sidebar__close` )
          .click();
        $( `.css-slider-dot-navigation .css-slider-dot[data-index="0"]` ).click();
        $( `button.filepond--file-action-button.filepond--action-revert-item-processing` ).click();
        $( `.cl-upload--errors.open` ).remove();

        $( `html, body` ).animate({
          scrollTop: $( `#site-header` ).offset().top
        }, 300);
        $( `.loadingScreen__` ).remove();
      } catch ( err ) {
        console.log( `ERROR `, err.message );
      }
    }

    function closeDrawerAfterProductAdded() {
      $( `#CartDrawer .drawer__close` ).click();
      $( `html, body` ).animate({ scrollTop: 0 }, `fast`);
    }
  </script>
</div>

{% if isPopUp != true %}
  <div style="text-align:center;margin-top:20px;font-weight:bold;color:#3E6166;">
    <div style="display:inline-block;">
      <span class="material-symbols-outlined" style="vertical-align: bottom; line-height: 50px;">local_shipping</span>
      <span style="margin-right:30px;vertical-align: bottom; line-height: 50px;">Free Shipping on $50+</span>
    </div>
    <div style="display:inline-block;">
      <span class="material-symbols-outlined" style="vertical-align: bottom; line-height: 50px;">check_circle</span>
      <span style="margin-right:30px;vertical-align: bottom; line-height: 50px;">No Minimums</span>
    </div>
    <div style="display:inline-block;">
      <span class="material-symbols-outlined" style="vertical-align: bottom; line-height: 50px;">replay</span>
      <span style="vertical-align: bottom; line-height: 50px;">Free 45-Day Returns</span>
    </div>
  </div>
{% endif %}

<style type="text/css">
   .metafield-rich_text_field ul {
     padding-left:40px;
   }

   .product-custom-liquid {
     margin-top:2rem !important;
   }

