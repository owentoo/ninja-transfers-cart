<script>
  function loadColor(url,colorName) {
    console.log("loadColor: " + url + ", colorName: " + colorName)

    const yotpoHtml = $("#shopify-block-yotpo_product_photo_reviews_star_rating_eKME9B").html();

    /*
    $(".colorOption svg").hide();
    $(".colorOption .colorButton").removeClass("outline-rush-blue-500");
    $(".colorOption button").removeClass("outline-transparent");
    $(".colorOption button").addClass("outline-transparent");
    
    const $el = $(".colorOption[data-colorname='" + colorName + "']");    
    $(".colorButton",$el).addClass("outline-rush-blue-500")
    $(".colorButton",$el).removeClass("outline-transparent")    
    $(".colorButton",$el).hide();
    setTimeout(function () {
      $(".colorButton",$el).show();
    },1)
    $("svg",$el).show();
    */
    
    const helperUrl = `/pages/blanks-pdp-helper?variant=${encodeURIComponent(colorName)}_0_{{ product.handle }}`
    console.log("Loading helper URL " + helperUrl)
    
    window.history.replaceState(null, null, url);
    //$('#hf_productStyle').parent().load(helperUrl + ' .main-content', function() { 
    $('.mount-product-page').load(url + ' .mount-product-page', function() { 
      $("#shopify-block-yotpo_product_photo_reviews_star_rating_eKME9B").html(yotpoHtml);
      sortColors();
      refreshItemPrices();
      const popupOverlay = document.querySelector(".popup-overlay");
      const closeButton = document.querySelector(".close-button");
      if (closeButton) {
        closeButton.addEventListener("click", function () {
          popupOverlay.classList.add("popup-overlay-hidden");
        });
      }
      
      const savedZipCode = window.localStorage.getItem("deliveryPostalCode");
      if (savedZipCode) {
        $(".deliveryEstimateZip").val(savedZipCode);
        estimateDeliveryDate();
      }
      else {
        $.ajax({
          type: "GET",
          //url: 'http://ipwho.is',
          url: 'http://ipwhois.pro/?key=YGjaRyEWIW8Y8MLO',
          contentType: "application/json; charset=utf-8",
          dataType: 'json',
          success: function (response) {
            console.log("ipwho response: " + JSON.stringify(response,null,2))
            try {
              if (response.success && response.country_code == "US") {
                console.log("Retrieved geolocation postal code " + response.postal)
                $(".deliveryEstimateZip").val(response.postal);
                estimateDeliveryDate();
              } else {
                 $(".deliveryEstimateZip").val('78701');
                 estimateDeliveryDate();
              }
            }
            catch (error) {
              console.log("Could not determine geolocation (error: " + error + "): " + response);  
            }
          },
          error: function (response) {
            console.log("Could not determine geolocation: " + response);
          }
        });
      }
      $(".itemQuantity").on("keyup", function () {
        refreshItemPrices();
        updatePrices();
        estimateDeliveryDateRefreshPending = true;
      })
            const directionWrapper = document.querySelector(".getDirectionWrapperInner");
      if (directionWrapper) {
        directionWrapper.addEventListener("click", () => {
          const locationPermissionDenied = window.localStorage.getItem("locationPermissionDenied");
          if (locationPermissionDenied === "true") {
            showError("Location services are required to get your current zip code. Please enable location services in your browser.");
          } else {
            requestLocationAccess();
          }
        });
      }

      collectionItemsLoaded();
      resetPrices();
      $(function(){
        setupThumbnailNavigation();
      });
    });
  }
</script>

