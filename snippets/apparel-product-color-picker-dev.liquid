{% if showJSData != false and isPopUp != true %}
<script>
    if ( typeof colors == 'undefined' ) {
      var colors = [];
    }
    {% for style_product in colors %}
      {% if style_product.metafields.specs.shirt_color != blank %}
        {% assign primHex = style_product.metafields.specs.shirt_prim_hex  %}
        {% if primHex == "0" %}
          {% assign primHex = "000000" %}
        {% endif %}
        colors.push({hex:'{{ primHex }}'});
      {% endif %}
    {% endfor %}

    if ( typeof saturationThreshold == 'undefined' ) {
      var saturationThreshold = 0.2; // 20% saturation
    }

  const hueRanges = new Map([
    [[330, 360], "red"],
    [[0, 16], "red"],
    [[16, 42], "orange"],
    [[42, 65], "yellow"],
    [[65, 165], "green"],
    [[165, 190], "cyan"],
    [[190, 255], "blue"],
    [[255, 295], "violet"],
    [[295, 330], "magenta"],
  ]);

  function isGrayscale(saturation) {
    return saturation < saturationThreshold;
  }

  function findColorRange(hue) {
    for (let [[bottomHue, topHue], color] of hueRanges.entries()) {
      if (hue >= bottomHue && hue <= topHue) {
        return color;
      }
    }
    return "other";
  }

  function hsl (hex) {
    try {
      var result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);

      var r = parseInt(result[1], 16);
      var g = parseInt(result[2], 16);
      var b = parseInt(result[3], 16);

      r /= 255, g /= 255, b /= 255;
      var max = Math.max(r, g, b), min = Math.min(r, g, b);
      var h, s, l = (max + min) / 2;

      if(max == min){
          h = s = 0; // achromatic
      } else {
          var d = max - min;
          s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
          switch(max) {
              case r: h = (g - b) / d + (g < b ? 6 : 0); break;
              case g: h = (b - r) / d + 2; break;
              case b: h = (r - g) / d + 4; break;
          }
          h /= 6;
      }

      s = s*100;
      s = Math.round(s);
      l = l*100;
      l = Math.round(l);
      h = Math.round(360*h);
      return [h,s,l];
    }
    catch {
      return [0,0,0];
    }
  }

  function getSortedColors() {
    let colorGroups = {
      grayscale: [],
      red: [],
      orange: [],
      yellow: [],
      green: [],
      cyan: [],
      blue: [],
      violet: [],
      magenta: [],
      other: [],
    };

    colors.forEach((color) => {
      const [hue, saturation] = hsl(color.hex);

      let colorCategory = findColorRange(hue);

      if (isGrayscale(saturation)) {
        colorCategory = "grayscale";
      }

      colorGroups[colorCategory].push(color);
    });

    return Object.values(colorGroups).flatMap((colorGroup) => {
      // Sort colors by lightness - lightest first, darkest last
      return colorGroup.sort((a, b) => {
        const [_aHue, _aSaturation, aLightness] = hsl(a.hex);
        const [_bHue, _bSaturation, bLightness] = hsl(b.hex);

        return bLightness - aLightness;
      });
    });
  }

  function sortColors () {
    const colorOptionElements = {};
    $(".colorOptions .colorOption").each(function () {
      const $el = $(this);
      const colorHex = $el.attr("data-color");
      let elArr = colorOptionElements[colorHex];
      if (elArr == null) {
        elArr = [];
        colorOptionElements[colorHex] = elArr;
      }
      elArr.push($el.detach());
    })

    const sortedColors = getSortedColors();
    sortedColors.forEach((color) => {
      const elArr = colorOptionElements[color.hex];
      if (elArr) {
        elArr.forEach(($el) => {
          $(".colorOptions").append($el);
        })
      }
    })

    $(".colorOptions").show();
  }

  $( document ).ready(function() {
    sortColors();
  });
</script>
