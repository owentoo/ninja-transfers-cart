{%- assign dtfBYSize = all_products['dtf-transfers'] -%}
{%- capture bySizeVariants -%}
  {% for variant in dtfBYSize.variants %}
    {
      "id": {{ variant.id | json }},
      "title": {{ variant.title | json }},
      {% if variant.featured_image != blank %}
        "thumb": {{ variant.featured_image | image_url: width: 100 | json }},
        "large": {{ variant.featured_image | image_url: width: 1000 | json }},
      {% elsif variant.image != blank %}
        "thumb": {{ variant.image | image_url: width: 100 | json }},
        "large": {{ variant.image | image_url: width: 1000 | json }},
      {% else %}
        "thumb": null,
        "large": null,
      {% endif %}
      {% if variant.option1 != blank %}
        "option1": {{ variant.option1 | json }},
        "option1_converted": {{ variant.option1 | replace: '"', '^' | json }},
        {% if variant.option1 contains 'Style #' %}
          "isCustom": true,
          {%-liquid
            assign getSize = variant.option1 | split: 'Style #' | remove: ' ' | remove: '[' | remove: ']' | remove: '"' | remove: ','
            assign minInches = getSize | split: '-' | first | strip | times: 1
            assign maxInches = getSize | split: '-' | last | strip | times: 1
          -%}
          "minInches": {{ minInches | json }},
          "maxInches": {{ maxInches | json }},
        {% else %}
          "isPopular": true,
        {% endif %}
      {% endif %}
      {% if variant.option2 != blank %}
        "option2": {{ variant.option2 | json }},
      {% endif %}
      {% if variant.option3 != blank %}
        "option3": {{ variant.option3 | json }},
      {% endif %}
      "media_id": {{ variant.featured_media.id | json }},
      "price": {{ variant.price | money_without_currency | json }}
    }
    {%- unless forloop.last -%}
      ,
    {%- endunless -%}
  {% endfor %}
{%- endcapture -%}
<div class="uploadBox">
  <link rel="stylesheet" href="{{ '__blanksUploadHelper.css' | asset_url }}">
  {% if block.settings.box_heading != blank %}
    <h3 class="uploadBox__title">{{ block.settings.box_heading }}</h3>
  {% endif %}
  {% if block.settings.box_subHeading != blank %}
    <p class="uploadBox__subTitle">{{ block.settings.box_subHeading }}</p>
  {% endif %}

  <div class="uploadBox__layout">
    <div class="uploadBox__content">
      <div class="uploadBox__icon">
        <img src="https://cdn.shopify.com/s/files/1/0558/0265/8899/files/image_9_89553aea-5c53-4c9d-be87-f468e46ee459.png?auto=format,compress&amp;auto=format,compress&amp;v=1757090125" style="max-width: 72px;">
      </div>
      {% if block.settings.boxTitle != blank %}
        <h4 class="uploadBox__contentTitle">{{ block.settings.boxTitle }}</h4>
      {% endif %}
      {% if block.settings.boxText != blank %}
        <p class="uploadBox__contentText">{{ block.settings.boxText }}</p>
      {% endif %}

      {% if block.settings.btn_label != blank %}
        <div class="uploadBox__contentButton">{{ block.settings.btn_label }}</div>
      {% endif %}
    </div>
    {% if block.settings.image != blank %}
      <img src="{{ block.settings.image | image_url }}" alt="Upload Files" class="uploadBox__image uploadBox__image--desktop" width="" height="" />
    {% endif %}
    {% if block.settings.imageMobile != blank %}
      <img src="{{ block.settings.imageMobile | image_url }}" alt="Upload Files" class="uploadBox__image uploadBox__image--mobile" width="" height="" />
    {% endif %}

    <input
      type="file"
      id="fileInput"
      class="drop-zoon__file-input hidden"
      {% if block.settings.multiUploadOption %}
        multiple
      {% endif %}
      accept="image/png,image/jpg,image/jpeg,application/postscript,.eps,application/pdf,image/tiff,image/svg+xml"
    >
  </div>
  {%- comment -%}
  {% if renderThisFile == 'pdp-image-with-text-block' %}
    {% render 'pdp-image-with-text-block', block: block, makeLinkJs: true %}
  {% endif %}
  {%- endcomment -%}

  <script>
    const bySizeVariants = [{{ bySizeVariants }}];

    const imagesTypesNew = ["image/png", "image/jpg", "image/jpeg", "application/postscript", ".eps", "application/pdf", "image/tiff", "image/svg+xml"];
    const definedMinWidth = {{ block.settings.minWidth | times: 1 | json }};
    const definedMaxWidth = {{ block.settings.maxWidth | times: 1 | json }};

    const definedMinHeight = {{ block.settings.minHight | times: 1 | json }};
    const definedMaxHeight = {{ block.settings.maxHeight | times: 1 | json }};

    const definedMinQty = {{ block.settings.minQty | times: 1 | json }};
    const isEnabledPixelsValidation = {{ block.settings.enablePixleValidation | json }};
    const definedMaxPixelsForSuperRes = {{ block.settings.maxPixelsForSuperRes | times: 1 | json }};
    const smartSizing = {{ block.settings.enableSmartSizing | json }};

    const newCartMsgs = {
      "emptyCart": `{{ block.settings.forEmptyCartMsg }}`,
      "itemsAvailableInCart": `{{ block.settings.forItemsInCartMsg }}`,
      "maxDiscount": `{{ block.settings.forMaxDiscountMsg }}`
    }
  </script>
  {{ '__blanksUploadHelper.js' | asset_url | script_tag }}
</div>
<style>
  multi-upload-wrapper * {
    font-family: "inter" !important;
  }
</style>

<div id="multiUploadTemplates" class="hidden">
  <template data-multi-id="main">
    <multi-upload-wrapper class="multiUpload active">
      <multi-upload>
        <span class="multiUpload__close">&nbsp;</span>
        <upload-area>
          <file-blocks-area total-qty="1"></file-blocks-area>

          <another-upload-multi class="anotherUpload" tabindex="1" newdesign>
            <div class="secondDropZone" for="secondFile_">
              <div class="secondDropZone__title">Add another design</div>
              <div class="secondDropZone__inner">
                <b>Browse</b>
                <div class="secondDropZone__text">
                  Drag and drop file(s)
                </div>
              </div>
              {% if customer %}
                <p class="access_old_data">
                  <a href="#" class="purchase_from_previous" data-type="first_upload">
                    Choose a previous design
                  </a>
                </p>
              {% else %}
                <p class="access_old_data">
                  <a data-link="" href="/customer_authentication/login?return_to={{ dtfBYSize.url | url_encode }}" class="basic__link first__upload">
                    Login
                  </a>
                  to see previous designs
                </p>
              {% endif %}
            </div>
          </another-upload-multi>
          <input
            type="file"
            id="anotherFileMultiple"
            class="hidden"
            {% if block.settings.multiUploadOption %}
              multiple
            {% endif %}
            accept="image/png,image/jpg,image/jpeg,application/postscript,.eps,application/pdf,image/tiff,image/svg+xml"
          >
        </upload-area>

        <other-options>
          <div class="otherOptions__top">
            <multi-shipping-bar>
              {%-liquid
                assign localzone = localization.country.iso_code
                case localzone
                  when "CA"
                    assign bySize_freeShipping_amount = settings.bySize_freeShipping_amount_ca
                    assign nwprice = bySize_freeShipping_amount | prepend : "$"
                    assign nwprice = nwprice | append : " CAD"
                  else
                    assign bySize_freeShipping_amount = settings.bySize_freeShipping_amount
                    assign nwprice = bySize_freeShipping_amount | prepend : "$"
                endcase

                assign bySizeTotal = 0
                assign blanksTotal = 0
                assign isBySizeAvailable = false
                assign isBlankAvailable = false
                for item in cart.items
                  if item.product.type == 'custom transfers' or item.product.type == 'spangles' or item.product.type == 'UV DTF' or item.product.type == 'UV DTF gang' or item.product.type == 'puff transfers' or item.product.tags contains 'supplies'
                    assign isBySizeAvailable = true
                    assign bySizeTotal = bySizeTotal | plus: item.final_line_price
                  endif

                  assign taglist = item.product.tags | join : " " | downcase
                  if taglist contains 'blank'
                    assign isBlankAvailable = true
                    assign blanksTotal = blanksTotal | plus: item.final_line_price
                  endif
                endfor
                capture eligibilityBySize
                  assign a__ = bySize_freeShipping_amount | times: 100
                  if a__ > bySizeTotal
                    assign awayFrom_bysize = a__ | minus: bySizeTotal
                    assign awayFrom_bysize = awayFrom_bysize | divided_by: 100.00 | round: 2
                    assign awayFrom_bysize_0 = awayFrom_bysize | split: '.' | first
                    assign awayFrom_bysize_1 = awayFrom_bysize | split: '.' | last
                    if awayFrom_bysize_1.size == 1
                      assign awayFrom_bysize_1 = awayFrom_bysize_1 | append: '0'
                    endif
                    assign awayFrom_bysize = awayFrom_bysize_0 | append: '.' | append: awayFrom_bysize_1 | prepend: '$'
                    echo settings.bySize_freeShipping_text | replace: '[AMOUNT]', awayFrom_bysize
                  else
                    echo "Congrats! <strong>Free Shipping</strong> Unlocked on <strong>Transfers & Supplies</strong>"
                  endif
                endcapture

                capture eligibilityBlanks
                  assign b___ = settings.blanks_freeShipping_amount | times: 100
                  if b___ > blanksTotal
                    assign awayFrom_blanks = b___ | minus: blanksTotal
                    assign awayFrom_blanks = awayFrom_blanks | divided_by: 100.00 | round: 2
                    assign awayFrom_blanks_0 = awayFrom_blanks | split: '.' | first
                    assign awayFrom_blanks_1 = awayFrom_blanks | split: '.' | last
                    if awayFrom_blanks_1.size == 1
                      assign awayFrom_blanks_1 = awayFrom_blanks_1 | append: '0'
                    endif
                    assign awayFrom_blanks = awayFrom_blanks_0 | append: '.' | append: awayFrom_blanks_1 | prepend: '$'
                    echo settings.blanks_freeShipping_text | replace: '[AMOUNT]', awayFrom_blanks
                  else
                    echo "Congrats! <strong>Free Shipping</strong> Unlocked on <strong>Blanks</strong>"
                  endif
                endcapture
              -%}

              {%- if settings.cartFreeShippingBySize or settings.cartFreeShippingBlanks -%}
                {% if isBySizeAvailable or isBlankAvailable %}
                  <div class="cart-notice text-size--small hide-if-empty-cart">
                    {%- if settings.cartFreeShippingBySize and isBySizeAvailable -%}
                      <free-shipping-bysize class="sidebar-widget__contentItem freeship_zone{{ localzone | downcase }}"
                        free-shipping-amount="{{ bySize_freeShipping_amount | times: 100 }}"
                        data-cart-total="{{ bySizeTotal }}"
                      >
                        {%- assign bySizeToolTip = '<picture class="tooltip"><img src="//ninja-transfers-cdn.imgix.net/info_da70c6e6-1e86-41d3-9035-2bf57d01d406_medium.svg?auto=format,compress&amp;v=1678797665" class="infoIcon infoModal grt-infoicon"><span class="tooltiptext">' | append: settings.bySize_freeShipping_tooltipContent | replace: '[AMOUNT]', nwprice | append: '</span></picture>' -%}
                        <div class="freeShipping__title">
                          <div>
                            <span class="freeShipping__content">{{ eligibilityBySize }}</span>
                            <span>{{ settings.bySize_freeShipping_title | replace: '[TOOLTIP]', bySizeToolTip }}</span>
                          </div>
                          <strong class="nowrap">{{ nwprice }}</strong>
                        </div>
                        <span class="cart-notice__slider">
                          <span class="cart-notice__slider-bar" style="background-color: #3eaeff; width: 0;"></span>
                        </span>
                      </free-shipping-bysize>
                    {%- endif -%}

                    {%- if settings.cartFreeShippingBlanks and isBlankAvailable -%}
                      <free-shipping-blanks class="sidebar-widget__contentItem freeshipzone{{ localzone | downcase }}"
                        free-shipping-amount="{{ settings.blanks_freeShipping_amount | times: 100 }}"
                        data-cart-total="{{ blanksTotal }}"
                      >
                        {%- assign blanksToolTip = '<picture class="tooltip"><img src="//ninja-transfers-cdn.imgix.net/info_da70c6e6-1e86-41d3-9035-2bf57d01d406_medium.svg?auto=format,compress&amp;v=1678797665" class="infoIcon infoModal grt-infoicon"><span class="tooltiptext">' | append: settings.blanks_freeShipping_tooltipContent | append: '</span></picture>' -%}
                        <div class="freeShipping__title">
                          <div>
                            <span class="freeShipping__content">{{ eligibilityBlanks }}</span>
                            <span>{{ settings.blanks_freeShipping_title | replace: '[TOOLTIP]', blanksToolTip }}</span>
                          </div>
                          <strong class="nowrap">{{ settings.blanks_freeShipping_amount | prepend : "$" }}</strong>
                        </div>
                        <span class="cart-notice__slider">
                          <span class="cart-notice__slider-bar" style="background-color: #fba500; width: 0;"></span>
                        </span>
                      </free-shipping-blanks>
                    {%- endif -%}
                  </div>
                {% endif %}
              {%- endif -%}
            </multi-shipping-bar>

            <delivery-block>
              <div class="delivery-block">
                <div class="del-sh-text">Fastest Delivery <strong>Sat, <date>Jun. 14th</date></strong> if ordered in <strong><time>04h 45m 51s</time></strong></div>
                <span class="textinfodel" style="display:none">Fastest Delivery <strong>Sat, <date>Jun. 14th</date></strong> if ordered in <strong><time>04h 45m 50s</time></strong></span>
              </div>
            </delivery-block>

            {%-liquid
              capture alreadyCartQty
                render '__alreadyItemsInCart', product: dtfBYSize
              endcapture
            -%}
            <prices-table class="pricesTable" already-in-cart="{{ alreadyCartQty }}" current-qty-plus-cart-qty="{{ alreadyCartQty | plus: 1 }}" empty-cart-msg="{{ block.settings.forEmptyCartMsg | escape }}" items-msg="{{ block.settings.forItemsInCartMsg | escape }}" max-qty-msg="{{ block.settings.forMaxDiscountMsg | escape }}">
              <div class="pricesTable__title">
                {% if block.settings.title != blank %}
                  {{ block.settings.title }}
                {% endif %}
                {% if block.settings.enableTooltip and block.settings.toolTipContent != blank %}
                  <div class="pricesTable__detail" style="display: inline;">
                    <picture class="tooltip">
                      <img src="//ninja-transfers-cdn.imgix.net/info_da70c6e6-1e86-41d3-9035-2bf57d01d406_medium.svg?auto=format,compress&amp;v=1678797665" class="infoIcon infoModal grt-infoicon" width="" height="">
                      <span class="tooltiptext" style="text-align: left; background-color: #000; color: #fff; height: auto; max-height: 112px; padding: 5px; margin-right: 0; right: 0; left: unset; width: 220px; white-space: wrap; line-height: 130%; min-height: auto;">
                        {{ block.settings.toolTipContent }}
                      </span>
                    </picture>
                  </div>
                {% endif %}
              </div>
              {% if block.settings.subText != blank %}
                <div class="pricesTable__subText">
                  {{ block.settings.subText }}
                </div>
              {% endif %}

              <div class="pricesTable__table">
                <div class="pricesTable__tableHeading">
                  <div class="pricesTable__tableHeading_1">
                    {{ block.settings.firstColTitle }}
                  </div>
                  <div class="pricesTable__tableHeading_2">
                    {{ block.settings.secondColTitle }}
                  </div>
                  <div class="pricesTable__tableHeading_3">
                    {{ block.settings.thirdColTitle }}
                  </div>
                </div>

                <div class="pricesTable__items">
                  <div class="pricesTable__table_viewAll view" view-all="view all" view-hide="hide">
                    <svg width="16px" height="16px" style="enable-background:new 0 0 512 512;" viewBox="0 0 512 512" xml:space="preserve" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"><path d="M184.7,413.1l2.1-1.8l156.5-136c5.3-4.6,8.6-11.5,8.6-19.2c0-7.7-3.4-14.6-8.6-19.2L187.1,101l-2.6-2.3  C182,97,179,96,175.8,96c-8.7,0-15.8,7.4-15.8,16.6h0v286.8h0c0,9.2,7.1,16.6,15.8,16.6C179.1,416,182.2,414.9,184.7,413.1z"></path></svg>
                  </div>
                  {% for i in (1..6) %}
                    {%-liquid
                      assign qtyKey = 'qty_' | append: i
                      assign priceKey = 'price_' | append: i
                      assign percentKey = 'percent_' | append: i
                      assign preCutPriceKey = 'preCutPrice_' | append: i

                      assign j = i | plus: 1
                      assign nextOffKey = 'percent_' | append: j

                      assign qtyVal = block.settings[qtyKey]
                      assign priceVal = block.settings[priceKey]
                      assign percentVal = block.settings[percentKey]
                      assign preCutVal = block.settings[preCutPriceKey]

                      assign nextOffVal = block.settings[nextOffKey]

                      assign textContent = qtyVal | remove: ' pcs' | remove: ' '
                      assign minQty = textContent | split: '-' | first
                      assign maxQty = textContent | split: '-' | last

                      if minQty contains '+'
                        assign minQty = textContent | split: '+' | first
                        assign maxQty = 1000000
                      endif

                      assign off = percentVal | remove: ' ' | remove: '%' | remove: 'off'
                      assign nextOff = nextOffVal | remove: ' ' | remove: '%' | remove: 'off'
                      if nextOff contains '+'
                        assign nextOff = 1000000
                      endif
                    -%}

                    {% if qtyVal != blank and priceVal != blank %}
                      {%- capture minMax -%}
                        {%- if qtyVal contains '-' -%}
                          {%- assign min = qtyVal | split: '-' | first | strip -%}
                          {%- assign max = qtyVal | split: '-' | last | strip -%}
                        {%- elsif qtyVal contains '+' -%}
                          {%- assign min = qtyVal | split: '+' | first | strip -%}
                          {%- assign max = 1000000 -%}
                        {%- endif -%}
                      {%- endcapture -%}
                      {%- capture percentages -%}
                        {% if percentVal == '0% off' %}
                          {%- if percentVal contains '%' -%}
                            {%- assign offPercentage = '50' -%}
                          {%- endif -%}
                        {% else %}
                          {%- if percentVal contains '%' -%}
                            {%- assign offPercentage = percentVal | split: '%' | first | strip -%}
                          {%- endif -%}
                        {% endif %}
                      {%- endcapture -%}
                      {% if forloop.first %}
                        {%- assign getUnitPrice_1st = percentVal | default: '&nbsp;' -%}
                      {% endif %}
                      {% assign _dis = _dis | append :  "min_" %}
                      {% assign _dis = _dis | append :  min %}
                      {% assign _dis = _dis | append : "-off_" %}
                      {% assign _dis = _dis | append : offPercentage %}
                      {% assign _dis = _dis | append : "#" %}

                      {% assign _dis_title = _dis_title | append : offPercentage | append : "%25_off_for_" | append : min | append : "+_transfers#" %}
                      {% assign _dis_title = _dis_title | split : "+" | join : "" %}

                      <div class="pricesTable__item{% if i == 1 %} selected{% endif %}" index="{{ i }}" min="{{ minQty }}" max="{{ maxQty }}" off="{{ off }}" next-off="{{ nextOff }}" pre-cut="{{ preCutVal }}">
                        <div class="pricesTable__item_1">
                          <dynamic-qty>
                            {{ qtyVal }}
                          </dynamic-qty>
                        </div>
                        <div class="pricesTable__item_2">
                          {{ priceVal }}
                        </div>
                        <div class="pricesTable__item_3" aa="{{ percentVal }}">
                          {% if percentVal == '0% off' %}
                            &nbsp;
                          {% else %}
                            {{ percentVal | default: '&nbsp;' }}
                          {% endif %}
                        </div>
                        <div class="pricesTable__item__msg"></div>
                      </div>
                    {% endif %}
                  {% endfor %}

                  <div class="pricesTable__selectedBar"></div>
                </div>
              </div>

              <div class="print_perfect" style="display: flex; align-items: center; gap: 1rem; background-color: #4ab543; height: auto; border-radius: 4px; padding: 10px 15px;">
                <img src="{{ 'print_perfect.svg' | asset_url }}" style="width: 30px;" width="" height="">
                <p style="font-size: 14px; color: #fff; margin: 0; font-weight: 300;">
                  <strong>Ninja Guarantee:</strong>&nbsp;<em>Perfect Prints. Free Art Review. No Extra Fees!</em>
                </p>
              </div>
              <discount-properties discount-input="{{ _dis }}" discount-name="{{ _dis_title }}"></discount-properties>
            </prices-table>
          </div>

          <footer-block>
            {% if block.settings.enablePrecut %}
              <precut>
                <div class="preCut__text">
                  <span>Want to save time?</span>
                  <a class="openmodalbox" href="javascript://" onclick="$('.precut-popup').show();">
                    <img src="//ninja-transfers-cdn.imgix.net/info_da70c6e6-1e86-41d3-9035-2bf57d01d406_medium.svg?auto=format,compress&amp;v=1678797665" class="infoIcon infoModal grt-infoicon" width="" height="">
                  </a>
                </div>
                <label for="preCutOption_multi">
                  <input type="checkbox" id="preCutOption_multi">
                  Yes, Pre-cut transfers <strong class="nodisplay precut-cost">$0.19 each</strong>
                </label>
              </precut>
            {% endif %}

            <proceed-to-checkout>
              <span class="button button--solid button--product button--loader button--move addToCartGroupItemsMultiple">
                <span class="button__text" data-js-product-add-to-cart-text="">Add to Cart</span>
                <span class="button__preloader">
                  <svg class="button__preloader-element" viewBox="25 25 50 50"><circle cx="50" cy="50" r="20" fill="none" stroke-width="4"></circle></svg>
                </span>
              </span>
            </proceed-to-checkout>
          </footer-block>
        </other-options>

      </multi-upload>
    </multi-upload-wrapper>
  </template>

  <template data-multi-id="fileBlock">
    <uploaded-files-block tabindex="1">
      {% if block.settings.showFileProgressBar %}
        <file-progress class="fileProgress">
          <img src="https://cdn.shopify.com/s/files/1/0558/0265/8899/files/Ninja_96x.png" class="fileProgress__ninjaImg" width="" height="">
          <div class="fileProgress__msg">
            <svg clip-rule="evenodd" fill-rule="evenodd" stroke-linejoin="round" stroke-miterlimit="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="m12.002 2.005c5.518 0 9.998 4.48 9.998 9.997 0 5.518-4.48 9.998-9.998 9.998-5.517 0-9.997-4.48-9.997-9.998 0-5.517 4.48-9.997 9.997-9.997zm0 8c-.414 0-.75.336-.75.75v5.5c0 .414.336.75.75.75s.75-.336.75-.75v-5.5c0-.414-.336-.75-.75-.75zm-.002-3c-.552 0-1 .448-1 1s.448 1 1 1 1-.448 1-1-.448-1-1-1z" fill-rule="nonzero"></path></svg>
            <p>We're making sure your upload is perfect for printing. This may take a few seconds.</p>
          </div>
          <div class="fileProgress__loadingPercent">
            <a href="javascript://" style="color: #03a3f7; cursor:pointer" onclick="resetLoading()">Cancel</a>
            <span class="loadingPercent__counter">0%</span>
          </div>

          <div class="fileProgress__barWrap">
            <span class="fileProgress__bar" style="width: 0%;">
              <img src="https://cdn.shopify.com/s/files/1/0558/0265/8899/files/New_Ball.png?auto=format,compress&amp;v=1734081591" width="" height="">
            </span>
          </div>
        </file-progress>
      {% endif %}
      <item-no>
        <div class="itemNo__name">Upload 1</div>
        <div class="itemNo__action">
          <a href="javascript://">Delete</a>
        </div>
      </item-no>

      <div class="previewBlock_and_lineItems">
        <preview-box>
          <span class="zoom-text">Hover to Zoom | <a href="javascript://" style="color:#03a3f7" class="zoom_image">Click</a> to enlarge</span>
          <div class="previewText">
            <span class="fw-600">Preview:</span> The image will print as shown above.
          </div>
          <file-preview
            id="filePreview"
            show-dimensions
          >
            <preview-block class="easyzoom zoom-box">
              <div class="upload_tools">
                <a href="javascript://" removefile>
                  <svg style="pointer-events:none" clip-rule="evenodd" fill-rule="evenodd" stroke-linejoin="round" stroke-miterlimit="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="m4.015 5.494h-.253c-.413 0-.747-.335-.747-.747s.334-.747.747-.747h5.253v-1c0-.535.474-1 1-1h4c.526 0 1 .465 1 1v1h5.254c.412 0 .746.335.746.747s-.334.747-.746.747h-.254v15.435c0 .591-.448 1.071-1 1.071-2.873 0-11.127 0-14 0-.552 0-1-.48-1-1.071zm14.5 0h-13v15.006h13zm-4.25 2.506c-.414 0-.75.336-.75.75v8.5c0 .414.336.75.75.75s.75-.336.75-.75v-8.5c0-.414-.336-.75-.75-.75zm-4.5 0c-.414 0-.75.336-.75.75v8.5c0 .414.336.75.75.75s.75-.336.75-.75v-8.5c0-.414-.336-.75-.75-.75zm3.75-4v-.5h-3v.5z" fill-rule="nonzero"/></svg>
                </a>
              </div>
              <div class="horizontal_direction" x-is="0">&nbsp;</div>
              <div class="verticle_direction" y-is="0">&nbsp;</div>
              <img class="xzoom fileupload_hero" src="https://cdn.shopify.com/s/files/1/0558/0265/8899/files/transparent.png?v=1728297951" width="" height="">
              {% if dtfBYSize.template_suffix == "multiupload_bysizepopular" or dtfBYSize.template_suffix == "multiupload_vividpopular" or dtfBYSize.template_suffix == "uv-dtf-by-size" %}
                <button class="edit-with-ai">
                  <span class="edit-with-aiFlex" onclick="document.querySelector('.customTabelPopup__overlay-ai').style.display = 'grid'">
                    <span>Edit with</span>
                    <img src="https://cdn.shopify.com/s/files/1/0558/0265/8899/files/editWithAI_c3302daf-3fd0-4731-a169-d7e8f7e5eee7.png?auto=format,compress&amp;v=1766579573" width="" height="" style="height: 28px;">
                  </span>
                  <div class="delIcon" onclick="$(this).closest(`.edit-with-ai`).hide();">✕</div>
                </button>
              {% endif %}
            </preview-block>
            <file-details class="hidden"></file-details>
          </file-preview>

          <toggle-options show-bg-option="false" show-superres-option="false">
            <label class="switch bgRemover" for="bgRemover_">
              <img src="https://cdn.shopify.com/s/files/1/0558/0265/8899/files/editWithAI_c3302daf-3fd0-4731-a169-d7e8f7e5eee7.png?auto=format,compress&amp;v=1766579573" width="" height="" style="height: 28px;">
              Remove Background
              <input type="checkbox" class="toggleOption hidden" id="bgRemover_">
              <div class="slider round"></div>
            </label>

            <label class="switch superRes" for="superRes_">
              <img src="https://cdn.shopify.com/s/files/1/0558/0265/8899/files/editWithAI_c3302daf-3fd0-4731-a169-d7e8f7e5eee7.png?auto=format,compress&amp;v=1766579573" width="" height="" style="height: 28px;">
              Super Resolution
              <input type="checkbox" class="toggleOption hidden" id="superRes_">
              <div class="slider round"></div>
            </label>
          </toggle-options>
        </preview-box>

        <line-items>
          <tab-controls>
            <input type="radio" name="tabOptionName_" id="tabOptionCustom_" class="hidden tabOptionName" value="custom" checked>
            <label class="tabLink" for="tabOptionCustom_" tabindex="1">
              Custom Size
            </label>

            <input type="radio" name="tabOptionName_" id="tabOptionPopular_" class="hidden tabOptionName" value="popular">
            <label class="tabLink" for="tabOptionPopular_">
              Popular Size
            </label>
          </tab-controls>

          <sizes-blocks total-items="1" total-qty="1">
            <line-items-custom></line-items-custom>
            <line-items-popular></line-items-popular>

            {% render '__multipleSnippets' product: product, section: section, block: block, contentFor: 'addMoreSize' %}
          </sizes-blocks>

          <designer-notes>
            <input type="checkbox" class="popupinput checkbox-field hidden" id="designerNotes_1">
            <label class="lblctrl" for="designerNotes_1">
              <i></i> Add Free Design Notes (Optional)
            </label>
            <textarea class="designNotes" maxlength="300" placeholder="i.e. Keep the white inside of the text. Change the border of the logo to blue."></textarea>
          </designer-notes>
        </line-items>
      </div>
    </uploaded-files-block>
  </template>

  <template data-multi-id="custom">
    <div class="widthHeight__custom" item="1-1" option-selected="custom" dpi-warning="" discount="" qty="{{ block.settings.minQty }}" precut="">
      <div class="widthHeight__item" by="width" title="">
        <div class="widthHeight__item_inputWrapper">
          <button class="widthHeight__value-minus">&minus;</button>
          <input type="number" name="width__value" class="widthHeight__value" value="0.00" min="{{ block.settings.minWidth }}" max="{{ block.settings.maxWidth }}" step="0.5">
          <button class="widthHeight__value-plus">&plus;</button>
        </div>

        <div class="widthHeight__item_err hidden">
          <svg width="16" height="16" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48"><path d="M0 0h48v48h-48z" fill="none"/><path d="M24 4c-11.05 0-20 8.95-20 20s8.95 20 20 20 20-8.95 20-20-8.95-20-20-20zm2 30h-4v-12h4v12zm0-16h-4v-4h4v4z"/></svg>
          <span>{{ block.settings.maxWidthErr | replace: '[MAXWIDTH]', block.settings.maxWidth }}</span>
        </div>
        <div class="widthHeight__item_minErr hidden">
          <span>{{ block.settings.minWidthErr | replace: '[MINWIDTH]', block.settings.minWidth }}</span>
        </div>
      </div>

      <div class="widthHeight__item" by="height" title="">
        <div class="widthHeight__item_inputWrapper">
          <button class="widthHeight__value-minus">&minus;</button>
          <input type="number" name="height__value" class="widthHeight__value" value="0.00" min="{{ block.settings.minHight }}" max="{{ block.settings.maxHeight }}" step="0.5">
          <button class="widthHeight__value-plus">&plus;</button>
        </div>

        <div class="widthHeight__item_err hidden">
          <svg width="16" height="16" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48"><path d="M0 0h48v48h-48z" fill="none"/><path d="M24 4c-11.05 0-20 8.95-20 20s8.95 20 20 20 20-8.95 20-20-8.95-20-20-20zm2 30h-4v-12h4v12zm0-16h-4v-4h4v4z"/></svg>
          <span>{{ block.settings.maxHeightErr | replace: '[MAXHEIGHT]', block.settings.maxHeight }}</span>
        </div>
        <div class="widthHeight__item_minErr hidden">
          <span>{{ block.settings.minHeightErr | replace: '[MINHEIGHT]', block.settings.minHight }}</span>
        </div>
      </div>

      <precut-unit-logic title="">
        <div class="precut-unit-logic__grid">
          <div class="precut-unit-logic__qty">
            <div>
              <input type="text" name="quantity" class="customQtyFile__qty" value="1" min="{{ block.settings.minQty }}" autocomplete="off">
            </div>
            <qty-error>{{ block.settings.minQtyErr | replace: '[MINQTY]', block.settings.minQty }}</qty-error>
          </div>

          <div class="precut-unit-logic__price">
            <div class="__originalPrice">$0.00</div>
            <div class="__discountedPrice">$0.00<span>ea</span></div>
          </div>

          <div class="precut-unit-logic__total">
            <div class="__originalPrice">$0.00</div>
            <div class="__discountedPrice">$0.00</div>
          </div>

          <div class="precut-unit-logic__discount">
            <span></span>
            <div class="del_item">
              <a class="del_item_cta" href="javascript:void(0)">
                <svg width="20px" height="20px" enable-background="new 0 0 24 24" viewBox="0 0 24 24" xml:space="preserve" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"><g><path d="M12,2C6.5,2,2,6.5,2,12c0,5.5,4.5,10,10,10s10-4.5,10-10C22,6.5,17.5,2,12,2z M16.9,15.5l-1.4,1.4L12,13.4l-3.5,3.5 l-1.4-1.4l3.5-3.5L7.1,8.5l1.4-1.4l3.5,3.5l3.5-3.5l1.4,1.4L13.4,12L16.9,15.5z"></path></g></svg>
              </a>
            </div>
          </div>
        </div>
      </precut-unit-logic>
      <dpi-warning title="">At this size, artwork clarity may be compromised. Opt for a smaller size or enhance quality with our Super Resolution feature for best results.</dpi-warning>
    </div>
  </template>

  <template data-multi-id="popular">
    <div class="widthHeight__custom" item="1-2" option-selected="popular" dpi-warning="" discount="" qty="{{ block.settings.minQty }}" precut="">
      <div class="widthHeight__item__popular" title="">
        <div>
          {% if dtfBYSize.template_suffix == "multiupload_bysizepopular" or dtfBYSize.template_suffix == "multiupload_vividpopular" %}
            <select class="popularSizes">
              <option value="" selected disabled>Select a popular size</option>
              {% for variant in dtfBYSize.variants %}
                {% if variant.option1 contains 'Style #' %}
                {% else %}
                  {% assign desc = '' %}

                  {% case variant.option1 %}
                    {% when '2" x 2"' %}
                      {% assign desc = 'Tag Print / Neck Label' %}
                    {% when '3" x 3"' %}
                      {% assign desc = 'Small Tag/Sleeve Icon' %}
                    {% when '4" x 2"' %}
                      {% assign desc = 'Name Label/Small Chest Text' %}
                    {% when '4" x 4"' %}
                      {% assign desc = 'Left-Chest Logo' %}
                    {% when '5" x 3"' %}
                      {% assign desc = 'Small Badge Logo' %}
                    {% when '5" x 5"' %}
                      {% assign desc = 'Small Chest/Youth Print' %}
                    {% when '6" x 6"' %}
                      {% assign desc = 'Std Left-Chest/Youth' %}
                    {% when '7" x 7"' %}
                      {% assign desc = 'Small Front (Adult)' %}
                    {% when '8" x 8"' %}
                      {% assign desc = 'Medium Front Print' %}
                    {% when '9" x 9"' %}
                      {% assign desc = 'Large Chest/Med Front' %}
                    {% when '9" x 11"' %}
                      {% assign desc = 'Vertical Front/Youth' %}
                    {% when '10" x 10"' %}
                      {% assign desc = 'Standard Adult Front' %}
                    {% when '11" x 5"' %}
                      {% assign desc = 'Chest Banner/Sleeve' %}
                    {% when '11" x 11"' %}
                      {% assign desc = 'Adult Full Front' %}
                    {% when '11" x 14"' %}
                      {% assign desc = 'Tall Front/Jersey' %}
                    {% when '12" x 17"' %}
                      {% assign desc = 'Oversized Front/Hoodie' %}
                  {% endcase %}

                  <option
                    value="{{ variant.option1 | replace: '"', '^' }}"
                    vid="{{ variant.id }}"
                  >
                    {{ variant.option1 | replace: '"', '″' }}{% if desc != '' %} - {{ desc }}{% endif %}
                  </option>
                {% endif %}
              {% endfor %}
            </select>
          {% elsif dtfBYSize.template_suffix == "uv-dtf-by-size" %}
            <select class="popularSizes">
              <option value="" selected disabled>Select a popular size</option>
              {% for variant in dtfBYSize.variants %}
                {% if variant.option1 contains 'Style #' %}
                {% else %}
                  {% assign desc = '' %}
                  {% case variant.option1 %}
                    {% when '1" x 1"' %}
                      {% assign desc = 'Micro Logo / Icon Decal' %}
                    {% when '2" x 2"' %}
                      {% assign desc = 'Small Logo / Product Mark' %}
                    {% when '3" x 3"' %}
                      {% assign desc = 'Small Decal / Brand Icon' %}
                    {% when '4" x 4"' %}
                      {% assign desc = 'Standard Logo Decal' %}
                    {% when '5" x 5"' %}
                      {% assign desc = 'Medium Decal / Tumbler Front' %}
                    {% when '6" x 6"' %}
                      {% assign desc = 'Large Logo / Cup Front' %}
                    {% when '7" x 7"' %}
                      {% assign desc = 'XL Decal / Tumbler Wrap Area' %}
                    {% when '8" x 8"' %}
                      {% assign desc = 'Small Sign / Laptop Decal' %}
                    {% when '9" x 9"' %}
                      {% assign desc = 'Medium Sign / Door Decal' %}
                    {% when '10" x 10"' %}
                      {% assign desc = 'Large Decal / Statement Graphic' %}
                    {% when '11" x 11"' %}
                      {% assign desc = 'XL Statement Decal' %}
                    {% when '22" x 24"' %}
                      {% assign desc = 'Oversized Sign / Window Decal' %}
                  {% endcase %}

                  <option
                    value="{{ variant.option1 | replace: '"', '^' }}"
                    vid="{{ variant.id }}"
                  >
                    {{ variant.option1 | replace: '"', '″' }}{% if desc != '' %} - {{ desc }}{% endif %}
                  </option>
                {% endif %}
              {% endfor %}
            </select>
          {% else %}
            <select class="popularSizes">
              {% for variant in dtfBYSize.variants %}
                {% if variant.option1 contains 'Style #' %}
                {% else %}
                  <option value="{{ variant.option1 | replace: '"', '^' }}" vid="{{ variant.id }}">{{ variant.option1 | replace: '"', '″' }}</option>
                {% endif %}
              {% endfor %}
            </select>
          {% endif %}
        </div>
        <div class="smart-sizing">
          <span>Smart Sizing Applied</span>
          <span class="widthHeight__option-toolTip">
            <img src="//ninja-transfers-cdn.imgix.net/info_da70c6e6-1e86-41d3-9035-2bf57d01d406_medium.svg?auto=format,compress&amp;auto=format,compress&amp;v=1678797665" width="" height="">
            <div class="widthHeight__option-toolTip__content">
              <div>
                We automatically scale your design to the largest dimension of the popular size you choose, ensuring you only pay for the space you need. For example, a 4”×8” upload becomes 1”×2” when you select a 2”×2” size.
              </div>
            </div>
          </span>
        </div>
      </div>

      <precut-unit-logic title="">
        <div class="precut-unit-logic__grid">
          <div class="precut-unit-logic__qty">
            <div>
              <input type="text" name="quantity" class="customQtyFile__qty" value="1" min="{{ block.settings.minQty }}" autocomplete="off">
            </div>
            <qty-error>{{ block.settings.minQtyErr | replace: '[MINQTY]', block.settings.minQty }}</qty-error>
          </div>

          <div class="precut-unit-logic__price">
            <div class="__originalPrice">$0.00</div>
            <div class="__discountedPrice">$0.00<span>ea</span></div>
          </div>

          <div class="precut-unit-logic__total">
            <div class="__originalPrice">$0.00</div>
            <div class="__discountedPrice">$0.00</div>
          </div>

          <div class="precut-unit-logic__discount">
            <span></span>
            <div class="del_item">
              <a class="del_item_cta" href="javascript:void(0)">
                <svg width="20px" height="20px" enable-background="new 0 0 24 24" viewBox="0 0 24 24" xml:space="preserve" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"><g><path d="M12,2C6.5,2,2,6.5,2,12c0,5.5,4.5,10,10,10s10-4.5,10-10C22,6.5,17.5,2,12,2z M16.9,15.5l-1.4,1.4L12,13.4l-3.5,3.5 l-1.4-1.4l3.5-3.5L7.1,8.5l1.4-1.4l3.5,3.5l3.5-3.5l1.4,1.4L13.4,12L16.9,15.5z"></path></g></svg>
              </a>
            </div>
          </div>
        </div>
      </precut-unit-logic>
      <dpi-warning title="">At this size, artwork clarity may be compromised. Opt for a smaller size or enhance quality with our Super Resolution feature for best results.</dpi-warning>
    </div>
  </template>

  <template data-multi-id="fileRemove">
    <file-remove-wrapper-multi>
      <file-remove-block class="fileRemoveBlock">
        <svg class="fileRemoveBlock__close" width="24px" height="24px" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6 6L18 18" stroke="#000" stroke-linecap="round"></path><path d="M18 6L6.00001 18" stroke="#000" stroke-linecap="round"></path></svg>
        <div class="fileRemoveBlock__msg">
          Are you sure you would like to remove this file?
        </div>
        <div class="fileRemoveBlock__action">
          <button type="button" class="button button--solid fileRemoveBlock__removeFile">Remove File</button>
          <button type="button" class="close button button--solid fileRemoveBlock__cancle" style="background: #999 !important;">Cancel</button>
        </div>
      </file-remove-block>
    </file-remove-wrapper-multi>
  </template>

