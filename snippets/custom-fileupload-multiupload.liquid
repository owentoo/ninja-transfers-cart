  /*Style 3*/
  .fileupload_custom .switch {
    display: flex;
    height: 20px;
    position: relative;
    padding-left: 45px;
    align-items: center;
    font-weight: 600;
    font-size: 11px;
        white-space: nowrap;
  }
 /* .multiupload-popup .fileupload_custom .switch{
     height: 14px;
       padding-left: 30px;
  } */
  .fileupload_custom .switch input {
    display: none;
  }
  .fileupload_custom .slider {
    background-color: #ccc;
    bottom: 0;
    cursor: pointer;
    left: 0;
    position: absolute;
    right: unset;
    top: 0;
    transition: 0.4s;
    width: 43px;
  }
/*  .multiupload-popup .fileupload_custom .slider{
     background-color: #000000;
    width: 28px;
  } */
  .fileupload_custom .slider:before {
    background-color: #fff;
    bottom: 3px;
    content: "";
    height: 14px;
    left: 4px;
    position: absolute;
    transition: 0.4s;
    width: 14px;
  }
/*  .multiupload-popup .fileupload_custom .slider:before {
     bottom: 2px;
      height: 10px;
  left: 2px;
     width: 10px;
   } */
  .fileupload_custom input:checked + .slider {
    background-color: #03a3f7;
  }
  .fileupload_custom .switch:hover input:not(:checked) + .slider {
    background-color: rgba(3, 163, 247, 0.5);
  }
  .fileupload_custom input:checked + .slider:before {
    transform: translateX(19px);
  }
  /*
 .multiupload-popup .fileupload_custom input:checked + .slider:before {
    transform: translateX(14px);
  } */
  .fileupload_custom .slider.round {
    border-radius: 34px;
  }
  .fileupload_custom .slider.round:before {
    border-radius: 50%;
  }
