<!-- VARIANT RENDER : -->

{%- assign page_url = content_for_header
  | split: '"pageurl":"'
  | last
  | split: '"'
  | first
  | split: request.host
  | last
  | replace: '\/', '/'
  | replace: '%20', ' '
  | replace: '\u0026', '&'
-%}
{% assign param_color = null %}
{% assign param_variant_id = null %}

{%- for i in (1..1) -%}
  {%- unless page_url contains '?' -%}{% break %}{%- endunless -%}
  {%- assign query_string = page_url | split: '?' | last -%}
  {%- assign qry_parts = query_string | split: '&' -%}

  {%- for part in qry_parts -%}
    {%- assign key_and_value = part | split: '=' -%}
    {%- if key_and_value.size > 1 -%}
      {% if key_and_value[0] == 'variant' %}
        {% assign param_arr = key_and_value[1] | split: '_' %}
        {% assign param_color = param_arr[0] | upcase | url_decode %}
      {% endif %}
    {%- endif -%}
  {%- endfor -%}
{%- endfor -%}
{% assign param_variant_id = param_color | plus: 0 %}
{% assign defaultVariant = blank %}
{% assign selectedVariant = blank %}
{% paginate product.variants by 2049 %}
{% for variant in product.variants %}
  {% assign inventory = variant.inventory_quantity %}
  {% if localization.country.iso_code == "CA" %}
  {% assign inventory = variant.metafields.custom.ss_ca_inventory %}
  {% endif %}
  {% if inventory > 0 %}
    {% assign shirt_color = variant.metafields.specs.shirt_color | upcase %}
    {% if variant.metafields.specs.shirt_color == product.metafields.specs.default_child_color %}
      {% assign defaultVariant = variant %}
    {% endif %}
    {% if param_color and shirt_color == param_color %}
      {% assign selectedVariant = variant %}
    {% elsif param_color and variant.id == param_color %}
      {% assign selectedVariant = variant %}
    {% elsif param_color and variant.id == param_variant_id %}    
      {% assign selectedVariant = variant %}
    {% endif %}

    {% if defaultVariant != blank and selectedVariant != blank %}
      {% break %}
    {% endif %}
  {% endif %}
{% endfor %}
{% endpaginate %}
{% if selectedVariant == blank %}
  {% assign selectedVariant = defaultVariant %}
{% endif %}

{% assign selectedVariant = product.selected_or_first_available_variant %}

{% assign selectedColor = blank %}
{% assign selectedColorHex = blank %}
{% assign selectedColorSecHex = blank %}
{% assign selectedColorAlt = blank %}
{% assign selectedColorAltHex = blank %}
{% assign selectedColorAltSecHex = blank %}
{% assign selectedVariantAlt = blank %}
{% assign hasInventory = false %}

{% for product_option in product.options_with_values %}
    {% for product_option_value in product_option.values %}
      {% assign variant = product_option_value.variant %}
      {% assign inventory = variant.inventory_quantity %}
      {% if localization.country.iso_code == "CA" %}
      {% assign inventory = variant.metafields.custom.ss_ca_inventory %}
      {% endif %}
      {% if inventory > 0 %}
        {% assign hasInventory = true %}
        {% if selectedColorAlt == blank %}
          {% assign selectedColorAlt = variant.metafields.specs.shirt_color %}
          {% assign selectedColorAltHex = variant.metafields.specs.shirt_prim_hex %}
          {% assign selectedColorAltSecHex = variant.metafields.specs.shirt_sec_hex %}
          {% assign selectedVariantAlt = variant %}
        {% endif %}

        {% if variant.metafields.specs.shirt_color == selectedVariant.metafields.specs.shirt_color %}
          {% assign selectedColor = variant.metafields.specs.shirt_color %}
          {% assign selectedColorHex = variant.metafields.specs.shirt_prim_hex %}
          {% assign selectedColorSecHex = variant.metafields.specs.shirt_sec_hex %}
        {% endif %}

        {% if selectedColor != blank and selectedColorAlt != blank %}
          {% break %}
        {% endif %}
      {% endif %}
    {% endfor %}
{% endfor %}

{% if selectedColor == blank %}
  {% assign selectedColor = selectedColorAlt %}
  {% assign selectedColorHex = selectedColorAltHex %}
  {% assign selectedColorSecHex = selectedColorAltSecHex %}
  {% assign selectedVariant = selectedVariantAlt %}
{% endif %}

{% assign shirt_style = selectedVariant.metafields.specs.shirt_style %}
{% assign shirt_color = selectedVariant.metafields.specs.shirt_color %}
{% if selectedColor == blank %}
  {% assign selectedVariant = product.selected_or_first_available_variant %}
  {% assign shirt_style = selectedVariant.option2 %}
  {% assign shirt_color = selectedVariant.option1 %}
  {% assign selectedColor = selectedVariant.option1 %}
{% endif %}

<input type="hidden" id="hf_productRenderModel" value="consolidatedVariant">
<input type="hidden" id="hf_productStyle" value="{{ shirt_style }}">
<input type="hidden" id="hf_productColor" value="{{ shirt_color }}">
<input type="hidden" id="hf_variantId" value="{{ param_variant_id }}">

{% if hasInventory %}
{% render 'apparel-variant-color-picker',
  product: product,
  isPopUp: isPopUp,
  handleIncludes: shirt_style,
  selectedColor: selectedColor,
  selectedColorHex: selectedColorHex,
  selectedColorSecHex: selectedColorSecHex,
  showJSData: showJSData
%}
{%else %}
  <div class="" style="color:#ff0000;">
    <div style="font-weight:700;">Out Of Stock</div>
  </div>
{%endif %}
<div
  class="apparel-product-child-wrapper"
  style="padding:20px;padding-left:20px;background-color:#f6f6f6;padding-right:20px;border-top-left-radius:8px;border-top-right-radius:8px;border-bottom-left-radius:8px;border-bottom-right-radius:8px;"
>
  {% if hasInventory %} 
  <h5 style="font-size:1em;font-weight:700;margin-bottom:15px;" class="">Choose Size</h5>
  {%endif %}
  <div class="flex-bar variantsData">
    {% assign addedSizes = '' | split: '' %}
    {% for product_option in product.options_with_values %}
    {% for product_option_value in product_option.values %}
      {% assign variant = product_option_value.variant %}
      {% assign sizeName = variant.options[1].name %}

      
      
      {% if variant.price == 0 or variant.sku contains '-T' %}
        {% continue %}
      {% endif %}
      {%liquid
        if variant.metafields.specs.shirt_color == blank 
          unless variant.option1 == selectedColor
            continue
          endunless
        else
          unless variant.metafields.specs.shirt_color == selectedColor
            continue
          endunless
        endif
      %}
    
      {% unless variant.metafields.specs.shirt_color == selectedColor %}
        {% continue %}
      {% endunless %}

      {% unless addedSizes contains sizeName %}

      {% assign tmpSizeArr = sizeName | split: '~' %}
      {% assign addedSizes = addedSizes | concat: tmpSizeArr %}

      {% assign tierPricing = variant.metafields.custom.tier_pricing %}
      {% assign inventory = variant.inventory_quantity %}
      {% if localization.country.iso_code == "CA" %}
      {% assign tierPricing = variant.metafields.custom.tier_pricing_ca %}
      {% assign inventory = variant.metafields.custom.ss_ca_inventory %}
      {% endif %}
        
      <div class="flex-item text-center">
        <div class="variant-price-2" style="display:block;width:65px;">
          <label
            class="font-size--down-2 line-height--up-1 large--line-height--down-1 large--font-size--down-1 padding-top--down-3 large--padding-top--down-1 padding-bottom--down-3 font-bold"
            style="font-weight: 700;"
          >
            {{- variant.options[1].name -}}
          </label>
          {% if inventory <= 0 %}
            <!-- inventory: {{ inventory }} -->
            <div style="border-radius: 4px;display:block;border: 1px solid #e0e0e0;width:100%;color: #000000;padding-top:4px;padding-bottom:4px;background-color: #e1e1e1;height:55px;line-height:45px;">
              <label>OUT</label>
            </div>
          {% else %}
            <!--
            inventory_item
            {{ variant.inventory_item  }}
          -->
            <input
              class="text-center itemQuantity"
              type="number"
              min="0"
              data-id="{{ variant.id }}"
              data-price="{{ variant.price }}"
              data-variant-price="{{ variant.price | money_without_currency }}"
              data-tiers="{{ tierPricing }}"
              data-tp="{{ tierPricing | base64_encode }}"
              data-label="{{ variant.options[1].name }}"
              data-gtin="{{ variant.sku | split:"-" | first }}"
              data-max="{{ inventory }}"
              placeholder=""
              value=""
              style="border-radius: 4px;display:block;padding-top: 1rem;padding-bottom: 1rem; border: 1px solid #e0e0e0;width:100%;margin-bottom:10px;"
            >
            <label class="font-size--down-2 line-height--up-1 large--line-height--down-1 large--font-size--down-1 padding-top--down-5 large--padding-top--down-0 font-bold">
              <small
                data-variant-id="32449812529212"
                class="font-size--down-3 large--font-size--down-2 font-bold text-primary variant-price-2 padding-bottom--down-1 label-price"
                style="color: #03406C;font-size:1.1em;font-weight:700;"
              >
                {{- variant.price | money -}}
              </small>
            </label>
            <div style="font-size:0.8em;">
              {% if inventory >= 999 %}
                <div>999+</div>
              {% else %}
                <div>{{ inventory }}</div>
              {% endif %}
              <div>In Stock</div>
            </div>
          {% endif %}
        </div>
      </div>
        {% endunless %}
    {% endfor %}
    {% endfor %}
  
  </div>

  {% if isPopUp != true %}
    <div style="margin-top:20px;">
     {% render "apparel-product-delivery-estimate" %}
    </div>
  {% endif %}

  <div class="errorMessages" style="display:none;color:#ff0000;">
    <div style="font-weight:700;">Unable to add items to cart:</div>
    <ul class="errorList" style="margin-top:0px;"></ul>
  </div>

  {% if hasInventory %}
  <div class="product__cart-functions" another-transfer="" style="margin-top:0px;">
    <div class="addToCartSection flex-buttons">
      {% if isPopUp != true %}
        <button
          type="submit"
          onclick="addToCart();"
          name="add"
          class="add-to-cart button button--solid button--product button--loader button--move"
        >
          <span class="button__text"> Add To Cart </span>
          <span class="button__preloader">
            <svg class="button__preloader-element" viewBox="25 25 50 50">
              <circle cx="50" cy="50" r="20" fill="none" stroke-width="4"></circle>
            </svg>
          </span>
        </button>
      {% else %}
        {% if isUpsellPopup %}
          <span onclick="addToCartPopup_upsell();" class="button button--solid button--product button--loader button--move">
            <span class="button__text"> Add To Cart </span>
            <span class="button__preloader">
              <svg class="button__preloader-element" viewBox="25 25 50 50">
                <circle cx="50" cy="50" r="20" fill="none" stroke-width="4"></circle>
              </svg>
            </span>
          </span>
        {% else %}
          <span onclick="addToCartPopup();" class="button button--solid button--product button--loader button--move">
            <span class="button__text"> Add To Cart </span>
            <span class="button__preloader">
              <svg class="button__preloader-element" viewBox="25 25 50 50">
                <circle cx="50" cy="50" r="20" fill="none" stroke-width="4"></circle>
              </svg>
            </span>
          </span>
        {% endif %}
      {% endif %}
    </div>
    {% if isUpsellPopup %}
      <div class="flex-buttons">
        <a href="javascript://" class="button button--solid button--product button--loader button--move addToCartThenCheckout">
          <span class="button__text">Checkout</span>
        </a>
      </div>
    {% endif %}
  </div>
  {%endif %}

  {% if isPopUp != true %}
    <div class="product-actions" {{ block.shopify_attributes }}>
      {%- if block.settings.show_price -%}
        <div
          class="sidebar-widget sidebar-widget--{{ block.settings.style }} {% unless default_to_first_variant %} hide {% endunless %}"
          data-js-product-price-extended
        >
          {%- if block.settings.style == 'outline' -%}
            <span class="sidebar-widget__title">{{ 'products.page.price' | t }}</span>
          {%- endif -%}
          <div class="sidebar-widget__content">
            <div>
              {%- render 'product-price', variant: current_variant, target: current_variant, show_saving: true -%}
            </div>
          </div>
        </div>
      {%- endif -%}

      <product-form
        id="add-to-cart-{{ section.id }}"
        class="product-form"
        {% if settings.cart_action == 'overlay' %}
          data-ajax-cart data-js-product-form
        {% endif %}
      >
        {%- form 'product',
          product,
          id: product_form_id,
          class: 'form',
          novalidate: 'novalidate',
          data-type: 'add-to-cart-form'
        -%}
          <div class="form__properties"></div>

          <template>
            <input type="hidden" name="id" value="{{ current_variant.id }}">
          </template>
          <script>
            document.getElementById('add-to-cart-{{ section.id }}').querySelector('form').append(document.getElementById('add-to-cart-{{ section.id }}').querySelector('template').content.cloneNode(true));
            {% if b.afterAddtoCart_goCart %}
              const afterAddtoCart_goCart_redirect = true;
            {% endif %}
          </script>

          {%- liquid
            if product.gift_card? and block.settings.show_gift_card_recipient
              render 'gift-card-recipent-form', product: product
            endif
          -%}

          {% if isPopUp != true %}
            <div class="product__cart-functions">
              <div class="flex-buttons">
                {% if b.allowAnotherTransfer and b.anotherTransferPosition == 'above' %}
                  <span
                    class="anotherTransfer above{% if b.fillAnotherTransferBtn %} button button--solid button--product{% endif %}{% if b.fullWidthButtons %} btnFullWidth{% endif %}"
                  >
                    <span class="anotherTransfer__btnText">
                      {{ b.allowAnotherTransfer__label }}
                    </span>
                  </span>
                {% endif %}

                {%- if block.settings.show_quantity_selector -%}
                  <product-quantity
                    class="
                      product-quantity quantity-selector-holder
                      {% if default_to_first_variant %} hide {% endif %}
                    "
                  >
                    <button
                      class="qty-button qty-minus no-js-hidden"
                      aria-label="{{ 'general.accessibility_labels.decrease_quantity' | t }}"
                      role="button"
                      controls="qty-{{ section.id }}"
                    >
                      {%- render 'theme-symbols', icon: 'minus' -%}
                    </button>
                    <label for="qty-{{ section.id }}" class="visually-hidden">
                      {{- 'general.accessibility_labels.quantity' | t -}}
                    </label>
                    <input
                      type="number"
                      name="quantity"
                      value="1"
                      min="1"
                      max="999"
                      class="qty qty-selector product__quantity"
                      id="qty-{{ section.id }}"
                    >
                    <button
                      class="qty-button qty-plus no-js-hidden"
                      aria-label="{{ 'general.accessibility_labels.increase_quantity' | t }}"
                      role="button"
                      controls="qty-{{ section.id }}"
                    >
                      {%- render 'theme-symbols', icon: 'plus' -%}
                    </button>
                  </product-quantity>
                {%- endif -%}

                <button
                  type="submit"
                  name="add"
                  class="
                    add-to-cart button button--solid button--product button--loader button--move
                    {% unless current_variant.available %} disabled {% endunless %}
                    {% unless default_to_first_variant %} disabled {% endunless %}
                  "
                  data-js-product-add-to-cart
                  data-main-product-add-to-cart
                >
                  <span class="button__text" data-js-product-add-to-cart-text>
                    {%- liquid
                      unless default_to_first_variant
                        if product.available
                          if b.buttonText != blank
                            echo b.buttonText
                          else
                            echo 'products.grid.choose_variant_first' | t
                          endif
                        else
                          echo 'products.page.inventory.sold_out_variant' | t
                        endif
                      else
                        if current_variant.available
                          if b.buttonText != blank
                            echo b.buttonText
                          else
                            echo 'products.page.add_to_cart_button' | t
                          endif
                        else
                          echo 'products.page.inventory.sold_out_variant' | t
                        endif
                      endunless
                    -%}
                  </span>
                  <span class="button__preloader">
                    <svg class="button__preloader-element" viewBox="25 25 50 50">
                      <circle cx="50" cy="50" r="20" fill="none" stroke-width="4"/>
                    </svg>
                  </span>
                </button>

                {%- liquid
                  if block.settings.show_dynamic_checkout and block.settings.show_gift_card_recipient == false
                    echo form | payment_button
                  endif
                -%}

                {% if b.allowAnotherTransfer and b.anotherTransferPosition == 'below' %}
                  <span
                    class="anotherTransfer above{% if b.fillAnotherTransferBtn %} button button--solid button--product{% endif %}{% if b.fullWidthButtons %} btnFullWidth{% endif %}"
                  >
                    <span class="anotherTransfer__btnText">
                      {{ b.allowAnotherTransfer__label }}
                    </span>
                  </span>
                {% endif %}
              </div>
            </div>
          {% endif %}

          {% for item in customTabelItems %}
            {%- assign tItems = item.settings -%}
            {%- capture minMax -%}
                {%- if tItems.title contains '-' -%}
                  {%- assign min = tItems.title | split: '-' | first | strip -%}
                  {%- assign max = tItems.title | split: '-' | last | strip -%}
                {%- elsif tItems.title contains '+' -%}
                  {%- assign min = tItems.title | split: '+' | first | strip -%}
                  {%- assign max = 1000000 -%}
                {%- endif -%}
              {%- endcapture -%}
            {%- capture percentages -%}
                {%- if tItems.title_2 contains '%' -%}
                  {%- assign offPercentage = tItems.title_2 | split: '%' | first | strip -%}
                {%- endif -%}
              {%- endcapture -%}
            {% if forloop.first %}
              {%- assign getUnitPrice_1st = tItems.title_3 | default: '&nbsp;' -%}
            {% endif %}
            {% assign _dis = _dis | append: 'min_' %}
            {% assign _dis = _dis | append: min %}
            {% assign _dis = _dis | append: '-off_' %}
            {% assign _dis = _dis | append: offPercentage %}
            {% assign _dis = _dis | append: '#' %}

            {% assign _dis_title = _dis_title
              | append: offPercentage
              | append: '%25_off_for_'
              | append: min
              | append: '+_transfers#'
            %}
            {% assign _dis_title = _dis_title | split: '+' | join: '' %}
            {% if forloop.last %}
              <input type="hidden" id="discount_input" name="properties[_discount_input]" value="{{ _dis }}">
              <input type="hidden" id="discount_input" name="properties[_discount_name]" value="{{ _dis_title }}">
            {% endif %}
          {% endfor %}
        {%- endform -%}
      </product-form>

      {% if isPopUp != true %}
        {%- form 'product', product, id: 'product-form-installment' -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}">
          {{ form | payment_terms }}

          {% render 'custom-payment-terms' %}
        {%- endform -%}
      {% endif %}

      {% if block.settings.enable_payment_terms %}
        {% render 'custom-payment-terms' %}
      {% endif %}

      <script>
        document
          .querySelector('shopify-payment-terms')
          .shadowRoot.querySelector('*')
          .setAttribute('style', 'text-align: center;');
      </script>
    </div>
  {% endif %}

  <script>
    if ( typeof loaderGif == 'undefined' ) {
      loaderGif = `{{ 'loader.gif' | asset_url }}`;
    }
    anotherTransfer = false;
    $( document )
    .ready(function() {
      {% if b.buttonText != blank %}
        KROWN.settings.locales.products_add_to_cart_button = '{{ b.buttonText }}';
      {% endif %}
    })
    .on(`click`, `.anotherTransfer`,async function( e ) {
      try {
        e.stopImmediatePropagation();
        anotherTransfer = true;
        $( this )
          .closest( `form` )
          .find( `.add-to-cart[data-main-product-add-to-cart]` )
          .click();

        if ( typeof ElementAvailibility === 'function' ) {
          ElementAvailibility ( `#site-cart-sidebar.sidebar.sidebar--opened`, 'refreshAll__child', 30 );
        }
      } catch ( err ) {
        console.log( `ERROR .anotherTransfer`, err.message );
      }
    })
    ;

    function refreshAll__child() {
      try {
        console.log ( 'refreshAll done' );
        anotherTransfer = false;
        // location.href = "?";
        $( `#site-cart-sidebar.sidebar.sidebar--opened` )
          .find( `.sidebar__close` )
          .click();
        $( `.css-slider-dot-navigation .css-slider-dot[data-index="0"]` ).click();
        $( `button.filepond--file-action-button.filepond--action-revert-item-processing` ).click();
        $( `.cl-upload--errors.open` ).remove();

        $( `html, body` ).animate({
          scrollTop: $( `#site-header` ).offset().top
        }, 300);
        $( `.loadingScreen__` ).remove();
      } catch ( err ) {
        console.log( `ERROR `, err.message );
      }
    }

    function closeDrawerAfterProductAdded() {
      $( `#CartDrawer .drawer__close` ).click();
      $( `html, body` ).animate({ scrollTop: 0 }, `fast`);
    }
  </script>
</div>

{% if isPopUp != true %}
  {%liquid 
  assign localzone = localization.country.iso_code
  case localzone
      when "CA"
        assign b___ship = settings.blanks_freeShipping_amount_CA
        assign b___nwprice = b___ship | prepend : "$"
      else
       assign b___ship = settings.blanks_freeShipping_amount
       assign b___nwprice = b___ship | prepend : "$"
    endcase
  %}
  <div style="text-align:center;margin-top:20px;font-weight:bold;color:#3E6166;">
    <div style="display:inline-block;">
      <span class="material-symbols-outlined" style="vertical-align: bottom; line-height: 50px;">local_shipping</span>
      <span style="margin-right:30px;vertical-align: bottom; line-height: 50px;">Free Shipping on {{ b___nwprice }}+</span>
    </div>
    <div style="display:inline-block;">
      <span class="material-symbols-outlined" style="vertical-align: bottom; line-height: 50px;">check_circle</span>
      <span style="margin-right:30px;vertical-align: bottom; line-height: 50px;">No Minimums</span>
    </div>
    <div style="display:inline-block;">
      <span class="material-symbols-outlined" style="vertical-align: bottom; line-height: 50px;">replay</span>
      <span style="vertical-align: bottom; line-height: 50px;">Free 45-Day Returns</span>
    </div>
  </div>
{% endif %}

<style type="text/css">
   .metafield-rich_text_field ul {
     padding-left:40px;
   }

   .product-custom-liquid {
     margin-top:2rem !important;
   }

   .flex-bar {
     display: -webkit-box;
     display: -webkit-flex;
     display: -moz-flex;
     display: -ms-flexbox;
     display: flex;
     -webkit-box-align: center;
     -ms-flex-align: center;
     -webkit-align-items: center;
     -moz-align-items: center;
     align-items: flex-start;
     margin-left: -0.75019rem;
     flex-wrap: wrap;
   }

   .flex-item {
     margin:5px;
   }

   .text-center {
     text-align:center;
   }

   * {
  box-sizing: border-box;
  font-family: "Arial";
   }
   .wrapper-dropdown {
       position: relative;
       width: 300px;
       background: #FFF;
       color: #2e2e2e;
       outline: none;
       cursor: pointer;
   }
   .wrapper-dropdown > span {
     width: 100%;
     display: block;
     border: 1px solid #ababab;
     padding: 5px;
   }
   .wrapper-dropdown > span > span {
     padding: 0 12px;
     margin-right: 5px;
   }
   .wrapper-dropdown > span:after {
     content: "";
     width: 0;
     height: 0;
     position: absolute;
     right: 16px;
     top: calc(50% + 4px);
     margin-top: -6px;
     border-width: 6px 6px 0 6px;
     border-style: solid;
     border-color: #2e2e2e transparent;
   }

   .wrapper-dropdown .dropdown {
     position: absolute;
     z-index: 10;
     top: 100%;
     left: 0;
     right: 0;
     background: #fff;
     font-weight: normal;
     list-style-type: none;
     padding-left: 0;
     margin: 0;
     border: 1px solid #ababab;
     border-top: 0;
     max-height:300px;
     overflow-y:auto;
   }

   .wrapper-dropdown .dropdown li {
     display: block;
     text-decoration: none;
     color: #2e2e2e;
     padding: 5px;
     cursor: pointer;
   }

   .wrapper-dropdown .dropdown li > span {
     padding: 0 12px;
     margin-right: 5px;
   }

   .wrapper-dropdown .dropdown li:hover {
     background: #eee;
     cursor: pointer;
   }

   .swatchItem {
     border:1px solid #000;
   }

   input::-webkit-outer-spin-button, input::-webkit-inner-spin-button {
     -webkit-appearance: none;
     margin: 0;
   }

   input[type=number] {
     -moz-appearance: textfield;
   }
</style>

{% if showJSData != false %}
<script>
  let lastAddToCartTime = 0;
  function addToCart () {
    const curTime = new Date().getTime();
    console.log("AddToCartDetails: lastAddToCartTime=" + lastAddToCartTime + ", curTime=" + curTime + ", diff=" + (curTime - lastAddToCartTime))
    if (lastAddToCartTime > 0 && (curTime - lastAddToCartTime) <= 3000) {
      console.log("addtoCart DISALLOWED")
      return; // prevent multiple AddToCarts from being called within x ms
    }
    lastAddToCartTime = curTime;

    console.log("addToCart called")
    $(".errorMessages").hide();
    const itemsToAdd = [];
    const errorMessages = [];
    $(".itemQuantity").each(function () {
      var id = $(this).attr("data-id");
      var label = $(this).attr("data-label");
      var quantity = parseInt($(this).val());
      var quantityMax = parseInt($(this).attr("data-max"));
      var tp = atob($(this).attr("data-tp"));
      const properties = {
        //'Color': $("#hf_productColor").val(),
        {% if localization.country.iso_code == "CA" %}
        '_caInventory': quantityMax,
        {% endif %}
        '_tp': tp
      }
      console.log("Adding line item properties");
      console.log(JSON.stringify(properties,null,2))
      $(this).css("border","1px solid #e0e0e0")
      if (quantity > 0) {
        if (quantity > quantityMax) {
          errorMessages.push(`Size ${label} only has ${quantityMax} items in stock.`)
          $(this).css("border","2px solid #ff0000")
        }
        else {
          itemsToAdd.push({ id, quantity, properties });
        }
      }
    });

    if (errorMessages.length == 0 && itemsToAdd.length == 0) {
      errorMessages.push("No quantities chosen")
    }

    if (errorMessages.length) {
      $(".errorMessages").show();
      $(".errorMessages .errorList").html("<li>"+errorMessages.join("</li><li>")+"</li>");
    }
    else if (itemsToAdd.length) {
      console.log("Adding items to cart: " + JSON.stringify(itemsToAdd))
      $(".addToCartSection button").addClass("working");

      $.ajax({
        type: "POST",
        url: '/cart/add.js',
        data: { items: itemsToAdd },
        dataType: 'json',
        success: function (response) {
          if (typeof window.refreshCart === 'function') {
            window.refreshCart();
          } else {
            var sidebarEl = document.querySelector('[data-js-site-cart-sidebar]');
            if (sidebarEl) sidebarEl.show();
          }
          $(".addToCartSection button").removeClass("working");
          $(".itemQuantity").val("");
          var _btnEl = document.querySelector('.addToCartSection button .button__text');
          if (_btnEl) _btnEl.textContent = ' Add To Cart ';
          resetPrices();
        },
        error: function (response) {
          console.log("Could not add items: " + response);
          $(".errorMessages").show();
          $(".errorMessages .errorList").html("<li>An error has occurred.  Please try again.</li>");
        }
      });
    }
  }

  function initColors () {
    
  }

  function refreshItemPrices() {
    getCartTotalOriginalPrice(function(cartTotal) {
        $(".tierPricingBulkGridTable .tierRow").removeClass("active");
        
        let formTotalOriginal = 0;
        $(".itemQuantity").each(function () {
            const $itemQuantity = $(this);
            const quantity = parseInt($itemQuantity.val());
            if (!isNaN(quantity)) {
                const originalPrice = parseInt($itemQuantity.attr("data-price"));
                formTotalOriginal += originalPrice * quantity;
            }
        });

        const virtualTotal = (cartTotal + formTotalOriginal) / 100;
        let tierLevel = 0;
        if (virtualTotal >= 3800) tierLevel = 7;
        else if (virtualTotal >= 1750) tierLevel = 6;
        else if (virtualTotal >= 1000) tierLevel = 5;
        else if (virtualTotal >= 500) tierLevel = 4;
        else if (virtualTotal >= 250) tierLevel = 3;
        else if (virtualTotal >= 150) tierLevel = 2;
        else if (virtualTotal >= 99) tierLevel = 1;

        if (tierLevel > 0) $(".tierPricingBulkGridTable .tier" + tierLevel).addClass("active");

        $(".itemQuantity").each(function () {
            const $itemQuantity = $(this);
            let itemPrice = parseInt($itemQuantity.attr("data-price"));
            if (tierLevel > 0) {
                const itemTierLevels = $itemQuantity.attr("data-tiers").split(',');
                if (itemTierLevels.length == 7) itemPrice = parseInt(itemTierLevels[tierLevel - 1]);
            }
            $(".label-price", $itemQuantity.parent()).html("$" + (parseFloat(itemPrice) / 100.0).toFixed(2));
        });
    });
  }

  function getCartTotalOriginalPrice(callback) {
      fetch('/cart.js')
          .then(response => response.json())
          .then(data => {
              const totalOriginalPrice = data.total_price;
              callback(totalOriginalPrice);
          })
          .catch(error => console.error('Error fetching cart data:', error));
  }

  initColors()

  let estimateDeliveryDateRefreshPending = false;
  function checkEstimateDeliveryDateRefreshPending () {
    if (estimateDeliveryDateRefreshPending) {
      estimateDeliveryDateRefreshPending = false;
      estimateDeliveryDate();
    }
    setTimeout(checkEstimateDeliveryDateRefreshPending, 1000);
  }

  function updateButtonTotal() {
    var totalQty = 0;
    var formTotalOriginal = 0;
    $(".itemQuantity").each(function() {
      var qty = parseInt($(this).val()) || 0;
      if (qty > 0) {
        totalQty += qty;
        formTotalOriginal += parseInt($(this).attr("data-price")) * qty;
      }
    });
    var btnText = document.querySelector('.addToCartSection button .button__text');
    if (!btnText) return;
    if (totalQty === 0) {
      btnText.textContent = ' Add To Cart ';
      return;
    }
    getCartTotalOriginalPrice(function(cartTotal) {
      var virtualTotal = (cartTotal + formTotalOriginal) / 100;
      var tierLevel = 0;
      if (virtualTotal >= 3800) tierLevel = 7;
      else if (virtualTotal >= 1750) tierLevel = 6;
      else if (virtualTotal >= 1000) tierLevel = 5;
      else if (virtualTotal >= 500) tierLevel = 4;
      else if (virtualTotal >= 250) tierLevel = 3;
      else if (virtualTotal >= 150) tierLevel = 2;
      else if (virtualTotal >= 99) tierLevel = 1;
      var totalPrice = 0;
      $(".itemQuantity").each(function() {
        var qty = parseInt($(this).val()) || 0;
        if (qty > 0) {
          var itemPrice = parseInt($(this).attr("data-price"));
          if (tierLevel > 0) {
            var tiers = $(this).attr("data-tiers").split(',');
            if (tiers.length === 7) itemPrice = parseInt(tiers[tierLevel - 1]);
          }
          totalPrice += qty * itemPrice;
        }
      });
      var totalDollars = (totalPrice / 100).toFixed(2);
      btnText.textContent = 'Add ' + totalQty + ' item' + (totalQty !== 1 ? 's' : '') + ' \u2014 $' + totalDollars;
    });
  }

  $(".itemQuantity").on("keyup", function () {
    refreshItemPrices();
    updateButtonTotal();
    // estimateDeliveryDateRefreshPending = true;
  })
  refreshItemPrices();
  checkEstimateDeliveryDateRefreshPending();
  function updatePrices() {
    const inputs = document.querySelectorAll('input.itemQuantity');

    inputs.forEach(input => {
        input.addEventListener('input', () => {
            function getCartTotalOriginalPrice(callback) {
                fetch('/cart.js')
                    .then(response => response.json())
                    .then(data => {
                        const totalOriginalPrice = data.total_price;
                        callback(totalOriginalPrice);
                    })
                    .catch(error => console.error('Error fetching cart data:', error));
            }

            getCartTotalOriginalPrice(function(cartTotalActual) {
                const cartTotal = cartTotalActual;
                const enteredQuantity = parseFloat(input.value) || 0;
                let variantPrice = parseFloat(input.getAttribute('data-price'));
                let actualPrice = parseFloat(input.getAttribute('data-variant-price'));

                const newPrice = (enteredQuantity * variantPrice);
                const virtualTotal = (cartTotal + newPrice) / 100;
                let tierLevel = 0;

                if (virtualTotal >= 3800) tierLevel = 7;
                else if (virtualTotal >= 1750) tierLevel = 6;
                else if (virtualTotal >= 1000) tierLevel = 5;
                else if (virtualTotal >= 500) tierLevel = 4;
                else if (virtualTotal >= 250) tierLevel = 3;
                else if (virtualTotal >= 150) tierLevel = 2;
                else if (virtualTotal >= 99) tierLevel = 1;

                if (tierLevel > 0) {
                    const itemTierLevels = input.getAttribute("data-tiers").split(',');
                    if (itemTierLevels.length === 7) variantPrice = parseInt(itemTierLevels[tierLevel - 1], 10);
                }

                const currentPriceSpan = input.nextElementSibling.querySelector('span.money');
                if (currentPriceSpan) {
                    if (enteredQuantity <= 0 && cartTotal <= 0) {
                        currentPriceSpan.textContent = `$${actualPrice}`;
                    } else if (cartTotal > 0 && enteredQuantity <= 0){
                      const newCartTotal = cartTotal / 100
                      let newTierLevel = 0;
                      if (newCartTotal >= 3800) newTierLevel = 7;
                      else if (newCartTotal >= 1750) newTierLevel = 6;
                      else if (newCartTotal >= 1000) newTierLevel = 5;
                      else if (newCartTotal >= 500) newTierLevel = 4;
                      else if (newCartTotal >= 250) newTierLevel = 3;
                      else if (newCartTotal >= 150) newTierLevel = 2;
                      else if (newCartTotal >= 99) newTierLevel = 1;
                      if (newTierLevel > 0) {
                          const itemTierLevels = input.getAttribute("data-tiers").split(',');
                          if (itemTierLevels.length === 7) variantPrice = parseInt(itemTierLevels[newTierLevel - 1], 10);                        
                      }
                      const formattedPrice = (variantPrice / 100).toFixed(2);
                      currentPriceSpan.textContent = `$${formattedPrice}`;
                    } else {
                        const formattedPrice = (variantPrice / 100).toFixed(2);
                        currentPriceSpan.textContent = `$${formattedPrice}`;
                    }
                }

                inputs.forEach(otherInput => {
                    if (otherInput !== input) {
                        let otherVariantPrice = parseFloat(otherInput.getAttribute('data-price'));
                        let otherVariantActualPrice = parseFloat(otherInput.getAttribute('data-variant-price'));
                        const otherNewPrice = (enteredQuantity * otherVariantPrice);
                        const virtualTotal = (cartTotal + otherNewPrice) / 100;
                        let tierLevel = 0;

                        if (virtualTotal >= 3800) tierLevel = 7;
                        else if (virtualTotal >= 1750) tierLevel = 6;
                        else if (virtualTotal >= 1000) tierLevel = 5;
                        else if (virtualTotal >= 500) tierLevel = 4;
                        else if (virtualTotal >= 250) tierLevel = 3;
                        else if (virtualTotal >= 150) tierLevel = 2;
                        else if (virtualTotal >= 99) tierLevel = 1;

                        if (tierLevel > 0) {
                            const itemTierLevels = otherInput.getAttribute("data-tiers").split(',');
                            if (itemTierLevels.length === 7) otherVariantPrice = parseInt(itemTierLevels[tierLevel - 1], 10);
                        }

                        const otherPriceSpan = otherInput.nextElementSibling.querySelector('span.money');
                        if (otherPriceSpan) {
                            if (enteredQuantity <= 0 && cartTotal <= 0) {
                                otherPriceSpan.textContent = `$${otherVariantActualPrice}`;
                            } else if (cartTotal > 0 && enteredQuantity <= 0) {
                              const newCartTotal = cartTotal / 100
                              let newTierLevel = 0;
                              if (newCartTotal >= 3800) newTierLevel = 7;
                              else if (newCartTotal >= 1750) newTierLevel = 6;
                              else if (newCartTotal >= 1000) newTierLevel = 5;
                              else if (newCartTotal >= 500) newTierLevel = 4;
                              else if (newCartTotal >= 250) newTierLevel = 3;
                              else if (newCartTotal >= 150) newTierLevel = 2;
                              else if (newCartTotal >= 99) newTierLevel = 1;
                              if (newTierLevel > 0) {
                                  const itemTierLevels = otherInput.getAttribute("data-tiers").split(',');
                                  if (itemTierLevels.length === 7) otherVariantPrice = parseInt(itemTierLevels[newTierLevel - 1], 10);                        
                              }
                              const formattedPrice = (otherVariantPrice / 100).toFixed(2);
                              otherPriceSpan.textContent = `$${formattedPrice}`;
                            } else {
                                const formattedPrice = (otherVariantPrice / 100).toFixed(2);
                                otherPriceSpan.textContent = `$${formattedPrice}`;
                            }
                        }
                    }
                });
            });
        });
    });
  }

  updatePrices(); 
  resetPrices();
  {% if template.suffix == "blanks" %}
    collectionItemsLoaded();
  {% endif %}
  function resetPrices() {
    document.querySelectorAll('.itemQuantity').forEach(input => {

      function getCartTotalOriginalPrice(callback) {
          fetch('/cart.js')
              .then(response => response.json())
              .then(data => {
                  const totalOriginalPrice = data.total_price;
                  callback(totalOriginalPrice);
              })
              .catch(error => console.error('Error fetching cart data:', error));
          }

          getCartTotalOriginalPrice(function(cartTotalActual) {
            const cartTotal = cartTotalActual;
            let variantPrice = parseFloat(input.getAttribute('data-price'));
            const nextLabel = input.nextElementSibling;

            const newCartTotal = cartTotal / 100;
            let newTierLevel = 0;
            if (newCartTotal >= 3800) newTierLevel = 7;
            else if (newCartTotal >= 1750) newTierLevel = 6;
            else if (newCartTotal >= 1000) newTierLevel = 5;
            else if (newCartTotal >= 500) newTierLevel = 4;
            else if (newCartTotal >= 250) newTierLevel = 3;
            else if (newCartTotal >= 150) newTierLevel = 2;
            else if (newCartTotal >= 99) newTierLevel = 1;
            if (newTierLevel > 0) {
                const itemTierLevels = input.getAttribute("data-tiers").split(',');
                if (itemTierLevels.length === 7) variantPrice = parseInt(itemTierLevels[newTierLevel - 1], 10);                        
            }
          if (cartTotal <= 0 ){
            const pricePerUnit = parseFloat(input.getAttribute('data-variant-price'));
            if (nextLabel && nextLabel.tagName === 'LABEL') {
                const priceSpan = nextLabel.querySelector('.money');
                if (priceSpan) {
                    priceSpan.textContent = `$${pricePerUnit}`;
                }
            }                
          } else {
            if (nextLabel && nextLabel.tagName === 'LABEL') {
                const priceSpan = nextLabel.querySelector('.money');
                const formattedPrice = (variantPrice / 100).toFixed(2);
                if (priceSpan) {
                    priceSpan.textContent = `$${formattedPrice}`;
                }
            }
          }
        })
    });
  }  
</script>
{% endif %}