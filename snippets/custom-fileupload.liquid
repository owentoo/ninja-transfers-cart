  .toast {
    position: fixed;
    top: 150px;
    right: 30px;
    border-radius: 8px;
    background: #cffca6;
    padding: 10px 35px 10px 15px;
    box-shadow: 0 6px 20px -5px rgba(0, 0, 0, 0.1);
    overflow: hidden;
    transform: translateX(calc(100% + 30px));
    transition: all 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.35);
    z-index: 99999999999999;
  }

  .toast.active {
    transform: translateX(0%);
  }

  .toast .toast-content {
    display: flex;
    align-items: center;
  }

  .toast-content .check {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 18px;
    min-width: 18px;
    color: #fff;
    font-size: 20px;
    border-radius: 50%;
  }
  .toast-content .check path {
