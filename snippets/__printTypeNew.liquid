          {% endif %}
          
        </figure>
        <div class="vivid-details">
          <h4>{{ pt.popup_heading }}</h4>
          {% if pt.popup_feature != blank %}
            <div>{{ pt.popup_feature }}</div>
          {% endif %}
          {% if pt.popup_feature_1 != blank %}
            <div>{{ pt.popup_feature_1 }}</div>
          {% endif %}
          {% if pt.popup_feature_2 != blank %}
            <div>{{ pt.popup_feature_2 }}</div>
          {% endif %}
          {% if pt.popup_feature_3 != blank %}
