  </div>
</div>
<!-- ./Modal content -->
<style>
  body.noscroll {overflow: hidden; height: 100%; touch-action: none; overscroll-behavior: none;}
  .customTabelPopup__overlay.vivid-info-block{height: 100%;}
  .vivid-info-block{display:none;}
