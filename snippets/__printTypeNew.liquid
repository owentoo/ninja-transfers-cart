          {% endif %}
      </div>
      <div class="vivid-information pad24">
        <div class="vivid-card">
          <h5 class="head">What's New</h5>
          <div>
            {{ pt.popup_whatsnew }}
          </div>
        </div>
        <div class="vivid-card whatssame">
          <h5 class="head">What's the Same</h5>
          <div>
            {{ pt.popup_whatssame }}
          </div>
        </div>
      </div>
      </main>
