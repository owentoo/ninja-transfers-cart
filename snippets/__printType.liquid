{%- assign printTypeArr = section.blocks | where: 'type', 'printType' -%}
{% comment %} placeInGangSheetVariant {% endcomment %}
{% for item in printTypeArr %}
  {% assign pt = item.settings %}
  <div class="printType{% if pt.placeInGangSheetVariant %} hidden{% endif %}">
    {% if pt.mainTitle != blank %}
      <div class="printType__title">{{ pt.mainTitle }}</div>
    {% endif %}

    <div class="printType__items">
      {% if pt.enableOption_1 %}
        <input type="radio" name="printType" id="printType__1" class="printType__input" checked>
        <label for="printType__1" class="printType__{{ pt.contentSource_1 }} printType__first">
          {% if pt.contentSource_1 == 'text' %}
            {% if pt.optionText_1 != blank %}
              <div class="printType__opTitle">
                {{ pt.optionText_1 }}
              </div>
            {% endif %}
            {% if pt.optionSubText_1 != blank %}
              <div class="printType__opSubTitle">
                {{ pt.optionSubText_1 }}
              </div>
            {% endif %}
          {% elsif pt.contentSource_1 == 'img' %}
            <div class="printType__flex">
              
              <div class="printType__leftImg">
                {% if pt.optionImg_1 != blank %}
                  <img src="{{ pt.optionImg_1 | image_url: width: 200 }}">
                {% endif %}
                <div><strong>SOLD OUT</strong></div>
              </div>
              
              {% if pt.optionRightText_1 != blank %}
                <div class="printType__rightContent">
                  {% comment %} {{ pt.optionRightText_1 }} <span class="printType__icon">!</span> {% endcomment %}

                </div>
              {% endif %}
            </div>
            <div class="printType__hoverImg">
              <img src="{{ pt.optionLarge_1 | image_url: width: 450 }}">
            </div>
          {% endif %}
        </label>
      {% endif %}

      {% if pt.enableOption_1 %}
        {%- comment -%}
        <input type="radio" name="printType" id="printType__2" class="printType__input">
        {%- endcomment -%}
        {%- capture modalContent -%}
          {% if pt.optionLarge_2 != blank %}
            <img src="{{ pt.optionLarge_2 | image_url: width: 1440 }}" class="printTypeImg">
            <style>
              .printTypeImg {
                max-height: calc(90vh - 1.5rem - 22px);
              }
            </style>
          {% endif %}
        {%- endcapture -%}
        <script>
          const modalContent__ = `{{ modalContent }}`;
        </script>
        {%- capture secondOptionHTML -%}
          {% if pt.placeInGangSheetVariant %}<div class="dyn-flex">{% endif %}
          <label
            for="printType__2"
            class="printType__{{ pt.contentSource_2 }}"
            {% if modalContent != blank %}
              onclick="modalWrapper(this, modalContent__, 800);"
            {% endif %}
          >
            {% if pt.contentSource_2 == 'text' %}
              {% if pt.optionText_2 != blank %}
                <div class="printType__opTitle">
                  {{ pt.optionText_2 }}
                </div>
              {% endif %}
              {% if pt.optionSubText_2 != blank %}
                <div class="printType__opSubTitle">
                  {{ pt.optionSubText_2 }}
                </div>
              {% endif %}
            {% elsif pt.contentSource_2 == 'img' %}
              <div class="printType__flex">
                <div class="printType__leftImg print-custom-change">
                  {% if pt.optionImg_2 != blank %}
                    <img src="{{ pt.optionImg_2 | image_url: width: 200 }}">
                  {% endif %}
                </div>
                {% if pt.optionRightText_2 != blank %}
                  <div class="printType__rightContent {% if pt.enable_soldout == true %}pprice{% endif %} {{ pt.seprator_class }}">
                    {% if pt.enable_soldout == true %}
                    <div class="vividstatus">SOLD OUT</div>
                    {% endif %}
                    <span class="vividprice {{ pt.enable_soldout }}">{{ pt.optionRightText_2 }}</span>
                    {% if pt.enable_soldout == false %}
                      <span class="printType__icon">!</span>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
              <div class="printType__hoverImg">
                {% if pt.optionLarge_2 != blank %}
                  <img src="{{ pt.optionLarge_2 | image_url: width: 450 }}">
                {% endif %}
              </div>
            {% endif %}
          </label>
          {% if pt.placeInGangSheetVariant %}
          <div class="printType__items">
            <div class="printType__rightContent learn-moremsg navigatevivid {{ pt.placeInGangSheetVariant }}"><span class="printType__icon">!</span> Learn More About Vivid AF</div>
          </div>
          </div>
        {% endif %}
        {%- endcapture -%}
        {% if pt.placeInGangSheetVariant == false %}
          {{ secondOptionHTML }}
        {% endif %}
      {% endif %}
    </div>
    <div class="printType__items">
      <div class="empty-div"></div>
      <div class="printType__rightContent learn-moremsg navigatevivid {{ pt.placeInGangSheetVariant }}"><span class="printType__icon">!</span> Learn More About Vivid AF</div>
      </div>
  </div>

  <script>
    function modalWrapper(e, content, width) {
      try {
        const screenWidth = $(window).width();
        if ( screenWidth > 767 ) {
          globalModal(content, width);
        } else {
          const isActive = $( e ).find( `.printType__hoverImg` ).hasClass( `active` );
          if ( isActive ) {
            $( e ).find( `.printType__hoverImg` ).removeClass( `active` );
          } else {
            $( e ).find( `.printType__hoverImg` ).addClass( `active` );
          }
        }
      } catch ( err ) {
        console.log( `ERROR modalWrapper(content, width)`, err.message );
      }
    }
    {% if pt.placeInGangSheetVariant %}
      $(document).ready(function () {
        const collectHTML = ``;
        $( `product-variants .product-variant__container[option="2"]` ).last().after( `{{ secondOptionHTML }}` );
      });
    {% endif %}
  </script>

  <style>
    .printType {
      {% if removeBottomMarginPadding != true %}
        border-bottom: 1px solid #b9b9b9;
        padding-bottom: 12px;
        margin-bottom: 12px;
        margin-top: -5px;
      {% endif %}
    }
    .printType__input {
      display: none;
    }
    .printType__title {
      font-size: 15px;
      font-weight: 700;
      margin-bottom: 6px;
    }
    .printType__items {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }
    .printType__text,
    .printType__img {
      background-color: whitesmoke;
      border: 2px solid #ddd;
      padding: 8px;
      border-radius: 8px;
      position: relative;
      cursor: pointer;
      transition: 0.2s all ease-in-out;
      padding-left: 34px; min-height:50px;
      display: flex;
      flex-flow: column wrap;
      justify-content: center;
    }
    .printType__text::before,
    .printType__img::before {
      content: '';
      position: absolute;
      top: 12px;
      left: 12px;
      width: 16px;
      height: 16px;
      border: 2px solid #ddd;
      border-radius: 999px;
      transition: 0.2s all ease-in-out;
    }
    .printType__text:hover,
    .printType__img:hover {
      border-color: #9ac8da;
      background-color: #e9f4fa;
    }
    .printType__opTitle {
      font-size: 14px;
      font-weight: 600;
    }
    .printType__opSubTitle {
      font-size: 12px;
      font-weight: bold;
      color: #000;
    }

    .printType__input:checked + .printType__text,
    .printType__input:checked + .printType__img {
      border: 2px solid #449fc4;
      background-color: #fff;
    }
    .printType__input:checked + .printType__text::before {
      border: 3px solid #449fc4;
    }
    .printType__text.printType__first{flex-flow: row; justify-content: space-between; align-items: center;}
    .printType__img::before,.printType__text.printType__first::before{top: 50%; margin-top: -8px;}
    @media ( min-width: 767px ) {
      .printType__img:hover .printType__hoverImg {
        animation: animate-in 0.5s ease-out forwards;
      }
    }
    @media (max-width: 768px) {
      .printType__items {
        grid-template-columns: auto;
      }
    }
    .printType__flex {
      display: flex;
      align-items: center;
      gap: 8px;
      justify-content: space-between;
    }
    .printType__hoverImg {
      position: absolute;
      left: 0;
      bottom: 100%;
      width: 100%;
      height: auto;
      border-radius: 6px;
      overflow: hidden;
      padding: 8px;
      background-color: #fff;
      box-shadow: 0 0 6px #bdbdbd;
      z-index: 2;
      opacity: 0;
      visibility: hidden;
    }
    .printType__hoverImg.active {
      animation: animate-in 0.5s ease-out forwards;
    }
    .printType img,.printType__hoverImg img {
      max-width: 100%;
    }
    .printType__rightContent {
      font-size: 12px;
      color: #27aefd;
    }
    .printType__rightContent.learn-moremsg{font-size:13px; padding: 8px 0; font-weight: bold; cursor:pointer;}
    .printType__rightContent.pprice{color: #000000; font-size:12px; font-weight:600; display: flex; gap: 14px; align-items:center;}
    .printType__rightContent.pprice .vividstatus,.vpink_price{color:#F72582; font-size:14px; font-weight:bolder;}
    span.vividprice {text-align: right;color: #000000; font-size:14px; font-weight:600;}
    span.vividprice > span{display:block;}
    .printType__icon {
      display: inline-flex;
      width: 16px;
      height: 16px;
      border-radius: 999px;
      /* margin-left: 3px; */
      align-items: center;
      justify-content: center;
      background-color: #27aefd;
      color: #fff;
      font-weight: 700;
      font-style: normal;
    }
    .printType__leftImg img {
      max-width: 100px;
    }
    {% if pt.placeInGangSheetVariant %}
      product-variants .product-variant__container .printType__img {
        padding: 6px 4px;
        display: grid;
        align-items: center;
      }
      product-variants .product-variant__container .printType__leftImg {
        line-height: 0;
      }
      product-variants .product-variant__container .printType__img::before {
        display: none;
      }
      product-variants .product-variant__container .printType__hoverImg {
        width: unset;
        overflow: unset;
        max-width: unset;
      }
      product-variants .product-variant__container .printType__hoverImg img {
        max-width: 350px;
      }
      product-variants .product-variant__container .printType__leftImg img {
        max-width: 80px;
        line-height: 0;
      }
      product-variants .product-variant__container .printType__rightContent {
        font-size: 9px;
      }
      product-variants .product-variant__container .printType__icon {
        width: 12px;
        height: 12px;
      }
      product-variants .product-variant__container[option="2"] .product-variant__item--radio:last-child {
        padding-inline-end: 0;
      }
      .template-product-dtf-gang-sheet .product-variant__item--radio label,
      .template-product-build-a-gang-sheet .product-variant__item--radio label {
        padding: 10px 6px;
      }
      .product-variant__item--radio label {
        gap: 2px;
      }
      @media ( max-width: 768px ) {
        .empty-div{display:none;}
        product-variants .product-variant__container .printType__hoverImg {
          right: 0;
          padding: 0;
          background-color: #fff;
          box-shadow: none;
        }
        product-variants .product-variant__container .printType__hoverImg img {
          padding: 8px;
          background-color: #fff;
          box-shadow: 0 0 6px #bdbdbd;
          border-radius: 6px;
          max-width: 300px;
          position: relative;
          left: 50%;
          transform: translateX(-50%);
        }
        product-variants .product-variant__container .printType__img {
          padding: 3px 4px;
        }
      }
    {% endif %}
    .printType__leftImg.print-custom-change{display: flex; align-items: center; gap: 8px; color:#F6157E; font-weight:bolder;}
    .printType__leftImg.print-custom-change strong{font-weight:bolder;}
    .dyn-flex{display:flex; gap:12px; align-items: center; padding-top:8px;}
    @media ( max-width: 768px ) {
      .dyn-flex{display:block; gap:4px; flex-flow:row wrap;}
    }
  </style>
{% endfor %}
<script>
  var __printType = 0
  var vivid_parent_seprator = '{{- pt.seprator_class -}}';
  var vivid_live_price = '{{- pt.enable_live -}}';
  $(function(){
    $(".navigatevivid").click(function(){
      const $target = $(".vividbox-node");
      if ($target.length) {
          $('html, body').animate({
            scrollTop: $target.offset().top - 0
          }, 800);
      }
    })

    document.addEventListener('click', function (e) {
      const insidePrintTypeImg = e.target.closest('.printType__img');
      if (!insidePrintTypeImg) {
          document.querySelectorAll('.printType__hoverImg.active')
              .forEach(function (el) {
                  el.classList.remove('active');
              });
      }
    });


  })
  
</script>