            </upload-area>

            <other-options>
              <div class="otherOptions__top">
                <multi-shipping-bar>
                  {%-liquid
                    assign localzone = localization.country.iso_code
                    case localzone
                      when "CA"
                        assign bySize_freeShipping_amount = settings.bySize_freeShipping_amount_ca
                        assign nwprice = bySize_freeShipping_amount | prepend : "$"
                        assign nwprice = nwprice | append : " CAD"
                      else
                        assign bySize_freeShipping_amount = settings.bySize_freeShipping_amount
                        assign nwprice = bySize_freeShipping_amount | prepend : "$"
                    endcase

                    assign bySizeTotal = 0
                    assign blanksTotal = 0
                    assign isBySizeAvailable = false
                    assign isBlankAvailable = false
                    for item in cart.items
                      if item.product.type == 'custom transfers' or item.product.type == 'spangles' or item.product.type == 'UV DTF' or item.product.type == 'UV DTF gang' or item.product.type == 'puff transfers' or item.product.tags contains 'supplies'
                        assign isBySizeAvailable = true
                        assign bySizeTotal = bySizeTotal | plus: item.final_line_price
                      endif

                      assign taglist = item.product.tags | join : " " | downcase
                      if taglist contains 'blank'
                        assign isBlankAvailable = true
                        assign blanksTotal = blanksTotal | plus: item.final_line_price
                      endif
                    endfor
                    capture eligibilityBySize
                      assign a__ = bySize_freeShipping_amount | times: 100
                      if a__ > bySizeTotal
                        assign awayFrom_bysize = a__ | minus: bySizeTotal
                        assign awayFrom_bysize = awayFrom_bysize | divided_by: 100.00 | round: 2
                        assign awayFrom_bysize_0 = awayFrom_bysize | split: '.' | first
                        assign awayFrom_bysize_1 = awayFrom_bysize | split: '.' | last
                        if awayFrom_bysize_1.size == 1
                          assign awayFrom_bysize_1 = awayFrom_bysize_1 | append: '0'
                        endif
                        assign awayFrom_bysize = awayFrom_bysize_0 | append: '.' | append: awayFrom_bysize_1 | prepend: '$'
                        echo settings.bySize_freeShipping_text | replace: '[AMOUNT]', awayFrom_bysize
                      else
                        echo "Congrats! <strong>Free Shipping</strong> Unlocked on <strong>Transfers & Supplies</strong>"
                      endif
                    endcapture

                    capture eligibilityBlanks
                      assign b___ = settings.blanks_freeShipping_amount | times: 100
                      if b___ > blanksTotal
                        assign awayFrom_blanks = b___ | minus: blanksTotal
                        assign awayFrom_blanks = awayFrom_blanks | divided_by: 100.00 | round: 2
                        assign awayFrom_blanks_0 = awayFrom_blanks | split: '.' | first
                        assign awayFrom_blanks_1 = awayFrom_blanks | split: '.' | last
                        if awayFrom_blanks_1.size == 1
                          assign awayFrom_blanks_1 = awayFrom_blanks_1 | append: '0'
                        endif
                        assign awayFrom_blanks = awayFrom_blanks_0 | append: '.' | append: awayFrom_blanks_1 | prepend: '$'
                        echo settings.blanks_freeShipping_text | replace: '[AMOUNT]', awayFrom_blanks
                      else
                        echo "Congrats! <strong>Free Shipping</strong> Unlocked on <strong>Blanks</strong>"
                      endif
                    endcapture
                  -%}

                  {%- if settings.cartFreeShippingBySize or settings.cartFreeShippingBlanks -%}
                    {% if isBySizeAvailable or isBlankAvailable %}
                      <div class="cart-notice text-size--small hide-if-empty-cart">
                        {%- if settings.cartFreeShippingBySize and isBySizeAvailable -%}
                          <free-shipping-bysize class="sidebar-widget__contentItem freeship_zone{{ localzone | downcase }}"
                            free-shipping-amount="{{ bySize_freeShipping_amount | times: 100 }}"
                            data-cart-total="{{ bySizeTotal }}"
                          >
                            {%- assign bySizeToolTip = '<picture class="tooltip"><img src="//ninja-transfers-cdn.imgix.net/info_da70c6e6-1e86-41d3-9035-2bf57d01d406_medium.svg?auto=format,compress&amp;v=1678797665" class="infoIcon infoModal grt-infoicon"><span class="tooltiptext">' | append: settings.bySize_freeShipping_tooltipContent | replace: '[AMOUNT]', nwprice | append: '</span></picture>' -%}
                            <div class="freeShipping__title">
                              <div>
                                <span class="freeShipping__content">{{ eligibilityBySize }}</span>
                                <span>{{ settings.bySize_freeShipping_title | replace: '[TOOLTIP]', bySizeToolTip }}</span>
                              </div>
                              <strong class="nowrap">{{ nwprice }}</strong>
                            </div>
                            <span class="cart-notice__slider">
                              <span class="cart-notice__slider-bar" style="background-color: #3eaeff; width: 0;"></span>
                            </span>
                          </free-shipping-bysize>
                        {%- endif -%}

                        {%- if settings.cartFreeShippingBlanks and isBlankAvailable -%}
                          <free-shipping-blanks class="sidebar-widget__contentItem freeshipzone{{ localzone | downcase }}"
                            free-shipping-amount="{{ settings.blanks_freeShipping_amount | times: 100 }}"
                            data-cart-total="{{ blanksTotal }}"
                          >
                            {%- assign blanksToolTip = '<picture class="tooltip"><img src="//ninja-transfers-cdn.imgix.net/info_da70c6e6-1e86-41d3-9035-2bf57d01d406_medium.svg?auto=format,compress&amp;v=1678797665" class="infoIcon infoModal grt-infoicon"><span class="tooltiptext">' | append: settings.blanks_freeShipping_tooltipContent | append: '</span></picture>' -%}
                            <div class="freeShipping__title">
                              <div>
                                <span class="freeShipping__content">{{ eligibilityBlanks }}</span>
                                <span>{{ settings.blanks_freeShipping_title | replace: '[TOOLTIP]', blanksToolTip }}</span>
                              </div>
                              <strong class="nowrap">{{ settings.blanks_freeShipping_amount | prepend : "$" }}</strong>
                            </div>
                            <span class="cart-notice__slider">
                              <span class="cart-notice__slider-bar" style="background-color: #fba500; width: 0;"></span>
                            </span>
                          </free-shipping-blanks>
                        {%- endif -%}
                      </div>
                    {% endif %}
                  {%- endif -%}
                </multi-shipping-bar>

                <delivery-block>
                  <div class="delivery-block">
                    <div class="del-sh-text">Fastest Delivery <strong>Sat, <date>Jun. 14th</date></strong> if ordered in <strong><time>04h 45m 51s</time></strong></div>
                    <span class="textinfodel" style="display:none">Fastest Delivery <strong>Sat, <date>Jun. 14th</date></strong> if ordered in <strong><time>04h 45m 50s</time></strong></span>
                  </div>
                </delivery-block>
                {%- assign pricesTableBlock = section.blocks | where: 'type', 'pricesTable' -%}
                {% if pricesTableBlock.size > 0 %}
                  {% for block in pricesTableBlock %}
                    {%- assign pb = block.settings -%}
                    {%-liquid
                      capture alreadyCartQty
                        render '__alreadyItemsInCart', product: product
                      endcapture
                    -%}
                    <prices-table class="pricesTable" already-in-cart="{{ alreadyCartQty }}" current-qty-plus-cart-qty="{{ alreadyCartQty | plus: 1 }}" empty-cart-msg="{{ pb.forEmptyCartMsg | escape }}" items-msg="{{ pb.forItemsInCartMsg | escape }}" max-qty-msg="{{ pb.forMaxDiscountMsg | escape }}">
                      <div class="pricesTable__title">
                        {% if pb.title != blank %}
                          {{ pb.title }}
                        {% endif %}
                        {% if pb.enableTooltip and pb.toolTipContent != blank %}
                          <div class="pricesTable__detail" style="display: inline;">
                            <picture class="tooltip">
                              <img src="//ninja-transfers-cdn.imgix.net/info_da70c6e6-1e86-41d3-9035-2bf57d01d406_medium.svg?auto=format,compress&amp;v=1678797665" class="infoIcon infoModal grt-infoicon">
                              <span class="tooltiptext" style="text-align: left; background-color: #000; color: #fff; height: auto; max-height: 112px; padding: 5px;">
                                {{ pb.toolTipContent }}
                              </span>
                            </picture>
                          </div>
                        {% endif %}
                      </div>
                      {% if pb.subText != blank %}
                        <div class="pricesTable__subText">
                          {{ pb.subText }}
                        </div>
                      {% endif %}

                      <div class="pricesTable__table">
                        <div class="pricesTable__tableHeading">
                          <div class="pricesTable__tableHeading_1">
                            {{ pb.firstColTitle }}
                          </div>
                          <div class="pricesTable__tableHeading_2">
                            {{ pb.secondColTitle }}
                          </div>
                          <div class="pricesTable__tableHeading_3">
                            {{ pb.thirdColTitle }}
                          </div>
                        </div>

                        <div class="pricesTable__items">
                          <div class="pricesTable__table_viewAll view" view-all="view all" view-hide="hide">
                            <svg width="16px" height="16px" style="enable-background:new 0 0 512 512;" viewBox="0 0 512 512" xml:space="preserve" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"><path d="M184.7,413.1l2.1-1.8l156.5-136c5.3-4.6,8.6-11.5,8.6-19.2c0-7.7-3.4-14.6-8.6-19.2L187.1,101l-2.6-2.3  C182,97,179,96,175.8,96c-8.7,0-15.8,7.4-15.8,16.6h0v286.8h0c0,9.2,7.1,16.6,15.8,16.6C179.1,416,182.2,414.9,184.7,413.1z"></path></svg>
                          </div>
                          {% for i in (1..6) %}
                            {%-liquid
                              assign qtyKey = 'qty_' | append: i
                              assign priceKey = 'price_' | append: i
                              assign percentKey = 'percent_' | append: i
                              assign preCutPriceKey = 'preCutPrice_' | append: i

                              assign j = i | plus: 1
                              assign nextOffKey = 'percent_' | append: j

                              assign qtyVal = pb[qtyKey]
                              assign priceVal = pb[priceKey]
                              assign percentVal = pb[percentKey]
                              assign preCutVal = pb[preCutPriceKey]

                              assign nextOffVal = pb[nextOffKey]

                              assign textContent = qtyVal | remove: ' pcs' | remove: ' '
                              assign minQty = textContent | split: '-' | first
                              assign maxQty = textContent | split: '-' | last

                              if minQty contains '+'
                                assign minQty = textContent | split: '+' | first
                                assign maxQty = 1000000
                              endif

                              assign off = percentVal | remove: ' ' | remove: '%' | remove: 'off'
                              assign nextOff = nextOffVal | remove: ' ' | remove: '%' | remove: 'off'
                              if nextOff contains '+'
                                assign nextOff = 1000000
                              endif
                            -%}

                            {% if qtyVal != blank and priceVal != blank %}
                              {%- capture minMax -%}
                                {%- if qtyVal contains '-' -%}
                                  {%- assign min = qtyVal | split: '-' | first | strip -%}
                                  {%- assign max = qtyVal | split: '-' | last | strip -%}
                                {%- elsif qtyVal contains '+' -%}
                                  {%- assign min = qtyVal | split: '+' | first | strip -%}
                                  {%- assign max = 1000000 -%}
                                {%- endif -%}
                              {%- endcapture -%}
                              {%- capture percentages -%}
                                {% if percentVal == '0% off' %}
                                  {%- if percentVal contains '%' -%}
                                    {%- assign offPercentage = '50' -%}
                                  {%- endif -%}
                                {% else %}
                                  {%- if percentVal contains '%' -%}
                                    {%- assign offPercentage = percentVal | split: '%' | first | strip -%}
                                  {%- endif -%}
                                {% endif %}
                              {%- endcapture -%}
                              {% if forloop.first %}
                                {%- assign getUnitPrice_1st = percentVal | default: '&nbsp;' -%}
                              {% endif %}
                              {% assign _dis = _dis | append :  "min_" %}
                              {% assign _dis = _dis | append :  min %}
                              {% assign _dis = _dis | append : "-off_" %}
                              {% assign _dis = _dis | append : offPercentage %}
                              {% assign _dis = _dis | append : "#" %}

                              {% assign _dis_title = _dis_title | append : offPercentage | append : "%25_off_for_" | append : min | append : "+_transfers#" %}
                              {% assign _dis_title = _dis_title | split : "+" | join : "" %}

                              <div class="pricesTable__item" index="{{ i }}" min="{{ minQty }}" max="{{ maxQty }}" off="{{ off }}" next-off="{{ nextOff }}" pre-cut="{{ preCutVal }}">
