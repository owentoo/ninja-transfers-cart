          "byDefaultSuperRes": {{ b.pngSuperResByDefault | json }}
        }
      {%- endcapture -%}
    {%- endif -%}
    {%- capture collectParamsForPrevious -%}
      {{- collectParamsForPrevious -}}
      {%- if collectParamsForPrevious != blank -%},{%- endif -%}
