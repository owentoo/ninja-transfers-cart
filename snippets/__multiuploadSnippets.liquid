
{%- case newContentFor -%}
  {%- when 'bySize__tabs' -%}
    {%- assign blockArr = section.blocks | where: 'type', 'mainTabs' -%}
    {%- assign collectCSS = '' -%}
    {% for block in blockArr %}
      {%- assign tabBlock = block.settings -%}
      <div class="customTabs">
        {% if tabBlock.mainTitle != blank %}
          <div class="customTabs__mainTitle">{{ tabBlock.mainTitle }}</div>
        {% endif %}

        <div class="customTabs__wrapper">
          {%- assign enableTabsCount = 0 -%}
          {% for i in (1..3) %}
            {%-liquid
              assign enableTab_key = 'enableTab_' | append: i
              assign tabTitle_key = 'tabTitle_' | append: i
              assign tabSubTitle_key = 'tabSubTitle_' | append: i
              assign tabColor_key = 'tabColor_' | append: i
              assign image_key = 'image_' | append: i
              assign contentTitle_key = 'contentTitle_' | append: i
              assign content_key = 'content_' | append: i
              assign btnLabel_key = 'btnLabel_' | append: i
              assign btnLink_key = 'btnLink_' | append: i
              assign btnBg_key = 'btnBg_' | append: i

              assign enableTab = tabBlock[enableTab_key]
              assign tabTitle = tabBlock[tabTitle_key]
              assign tabSubTitle = tabBlock[tabSubTitle_key]
              assign tabColor = tabBlock[tabColor_key]
              assign image = tabBlock[image_key]
              assign contentTitle = tabBlock[contentTitle_key]
              assign content = tabBlock[content_key]
              assign btnLabel = tabBlock[btnLabel_key]
              assign btnLink = tabBlock[btnLink_key]
              assign btnBg = tabBlock[btnBg_key]
            -%}
            {% if enableTab %}
              {%- assign enableTabsCount = enableTabsCount | plus: 1 -%}
              <div class="customTabs__item{% if forloop.first %} active{% endif %}" item-no="{{ i }}">
                <div class="customTabs__itemTitle">{{ tabTitle }}</div>
                <div class="customTabs__itemSubTitle">{{ tabSubTitle }}</div>
              </div>
              {%- capture collectCSS -%}
                {{ collectCSS }}
                .customTabs__item.active[item-no="{{ i }}"]::before {
                  background-color: {{ tabColor }};
                }
                .customTabs__item[item-no="{{ i }}"] .customTabs__itemTitle {
                  color: {{ tabColor }};
                }
              {%- endcapture -%}
            {% endif %}
          {% endfor %}
        </div>

        <div class="customTabs__contentWrapper">
          {% for i in (1..3) %}
            {%-liquid
              assign enableTab_key = 'enableTab_' | append: i
              assign tabTitle_key = 'tabTitle_' | append: i
              assign tabSubTitle_key = 'tabSubTitle_' | append: i
              assign tabColor_key = 'tabColor_' | append: i
              assign image_key = 'image_' | append: i
              assign contentTitle_key = 'contentTitle_' | append: i
              assign content_key = 'content_' | append: i
              assign btnLabel_key = 'btnLabel_' | append: i
              assign btnLink_key = 'btnLink_' | append: i
              assign btnBg_key = 'btnBg_' | append: i

              assign enableTab = tabBlock[enableTab_key]
              assign tabTitle = tabBlock[tabTitle_key]
              assign tabSubTitle = tabBlock[tabSubTitle_key]
              assign tabColor = tabBlock[tabColor_key]
              assign image = tabBlock[image_key]
              assign contentTitle = tabBlock[contentTitle_key]
              assign content = tabBlock[content_key]
              assign btnLabel = tabBlock[btnLabel_key]
              assign btnLink = tabBlock[btnLink_key]
              assign btnBg = tabBlock[btnBg_key]
            -%}
            {% if enableTab and contentTitle != blank and content != blank %}
              <div class="customTabs__content{% if forloop.first %} active{% endif %}" item-no="{{ i }}">
                <div class="customTabs__imgArea">
                  <img src="{{ image | image_url: width: 400 }}" alt="{{ contentTitle | escape }}">
                </div>
                <div class="customTabs__contentArea">
                  <h3 class="customTabs__contentTitle">{{ contentTitle }}</h3>
                  <div class="customTabs__contentText">{{ content }}</div>
                  {% if btnLabel != blank %}
                    <div class="customTabs__contentBtn {% if i == 2 %} ai__btn {% endif %}"
                      {% if btnLink != blank %}
                        onclick="$( `{{ btnLink }}` ).click()"
                      {% endif %}
                    >
                      
                      {{ btnLabel }}
                      {% if i == 2 %}
                      <svg width="108px" height="108px" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px" viewBox="0 0 108 108" enable-background="new 0 0 108 108" xml:space="preserve"><g><path fill-rule="evenodd" clip-rule="evenodd" fill="#FFFFFF" d="M16.84,57.274c2.74,1.481,4.071,2.358,5.518,2.954 c4.911,2.021,9.829,4.039,14.809,5.882c8.329,3.083,13.899,8.814,17.017,17.074c1.991,5.274,4.021,10.537,6.202,15.734 c0.451,1.074,1.644,1.837,2.495,2.744c0.833-0.928,1.987-1.72,2.446-2.807c2.387-5.65,4.586-11.379,6.87-17.073 c2.872-7.161,7.855-12.219,15.053-15.068c5.401-2.139,10.828-4.218,16.17-6.497c1.396-0.596,2.519-1.837,3.766-2.781 c-1.192-0.971-2.244-2.268-3.603-2.856c-5.329-2.31-10.737-4.44-16.147-6.555c-7.397-2.891-12.461-8.058-15.348-15.419 c-2.06-5.25-4.074-10.518-6.241-15.722c-0.635-1.524-1.726-2.858-3.179-5.2c-1.385,2.619-2.336,4.115-2.999,5.729 c-2.141,5.215-4.151,10.482-6.256,15.712C50.525,40.3,45.424,45.234,38.23,48.059c-5.098,2.002-10.183,4.039-15.244,6.131 C21.371,54.857,19.85,55.752,16.84,57.274z M18.3,5.473C14.839,14.063,8.464,18.958,0.815,23.2 c8.38,3.494,13.688,9.276,17.596,17.31c3.737-8.237,9.608-13.614,17.649-17.795C27.471,19.45,22.415,13.425,18.3,5.473z M2.283,90.626c3.949,3.917,8.151,8.085,11.999,11.901c3.999-3.926,8.307-8.156,12.086-11.865 c-4.045-4.024-8.243-8.202-12.072-12.01C10.455,82.48,6.263,86.66,2.283,90.626z"></path><path fill-rule="evenodd" clip-rule="evenodd" d="M16.84,57.274c3.01-1.521,4.531-2.417,6.146-3.084 c5.062-2.092,10.146-4.129,15.244-6.131c7.193-2.825,12.295-7.758,15.182-14.934c2.104-5.23,4.115-10.498,6.256-15.712 c0.663-1.614,1.614-3.109,2.999-5.729c1.453,2.342,2.544,3.676,3.179,5.2c2.167,5.204,4.182,10.472,6.241,15.722 c2.887,7.361,7.95,12.528,15.348,15.419c5.41,2.115,10.818,4.245,16.147,6.555c1.358,0.589,2.41,1.885,3.603,2.856 c-1.247,0.944-2.369,2.186-3.766,2.781c-5.342,2.279-10.769,4.358-16.17,6.497c-7.197,2.85-12.181,7.908-15.053,15.068 c-2.284,5.694-4.483,11.423-6.87,17.073c-0.459,1.086-1.613,1.879-2.446,2.807c-0.852-0.906-2.044-1.669-2.495-2.744 c-2.181-5.197-4.211-10.46-6.202-15.734c-3.117-8.26-8.688-13.991-17.017-17.074c-4.979-1.844-9.897-3.861-14.809-5.882 C20.911,59.632,19.58,58.755,16.84,57.274z"></path><path fill-rule="evenodd" clip-rule="evenodd" d="M18.3,5.473c4.115,7.952,9.171,13.977,17.761,17.241 c-8.041,4.182-13.912,9.558-17.649,17.795C14.503,32.476,9.195,26.694,0.815,23.2C8.464,18.958,14.839,14.063,18.3,5.473z"></path><path fill-rule="evenodd" clip-rule="evenodd" d="M2.283,90.626c3.979-3.966,8.172-8.146,12.013-11.975 c3.829,3.809,8.027,7.986,12.072,12.01c-3.779,3.709-8.087,7.939-12.086,11.865C10.435,98.711,6.232,94.542,2.283,90.626z"></path></g></svg>
                      {% endif %}
                    </div>
                  {% endif %}
                </div>
                {%- comment -%}
                  contentTitle: {{ contentTitle | json }} - content: {{ content | json }} - btnLabel: {{ btnLabel | json }} - btnLink: {{ btnLink | json }} - btnBg: {{ btnBg | json }}
                {%- endcomment -%}
              </div>
              {%- capture collectCSS -%}
                {{ collectCSS }}
                {% if enableTabsCount == 1 %}
                  .customTabs__wrapper {
                    grid-template-columns: auto;
                  }
                {% endif %}
                {% if enableTabsCount == 2 %}
                  .customTabs__wrapper {
                    grid-template-columns: auto auto;
                  }
                {% endif %}
                {% if enableTabsCount == 3 %}
                  .customTabs__wrapper {
                    grid-template-columns: auto auto auto;
                  }
                {% endif %}
                .customTabs__content[item-no="{{ i }}"] .customTabs__contentBtn {
                  background-color: {{ btnBg }};
                }
              {%- endcapture -%}
            {% endif %}
          {% endfor %}
        </div>
      </div>
      {%- capture collectCSS -%}
        {{ collectCSS }}
        {% if tabBlock.aiUnderUploadBox %}
          .customTabs__wrapper {
            grid-template-columns: auto auto;
          }
          .customTabs__wrapper .customTabs__item[item-no="2"] {
            display: none;
          }
          product-page:has(.customTabs__item.active[item-no="3"]) .generative-ai-area {
            display: none !important;
          }
        {% else %}
          @media(min-width: 768px) {
            .generative-ai-area {
              display: none !important;
            }
          }
        {% endif %}
      {%- endcapture -%}
      <script>
        $( document )
        .on(`click`, `.customTabs__item:not(.active)`, function( e ) {
          try {
            e.stopImmediatePropagation();
            const tabNo = $( this ).attr( `item-no` );
            $( `.customTabs__item, .customTabs__content` ).removeClass( `active` );
            $( `.customTabs__item[item-no="${ tabNo }"], .customTabs__content[item-no="${ tabNo }"]` ).addClass( `active` );
            if ( tabNo == 1 ) {
              $( `master-upload` ).show();
            } else {
              $( `master-upload` ).hide();
            }
          } catch ( err ) {
            console.log( `ERROR .customTabs__item`, err.message );
          }
        })
        ;
      </script>
    {% endfor %}
    <style>
      {% if collectCSS != blank %}
        {{ collectCSS }}
      {% endif %}
    </style>

  {%- when 'masterUploader' -%}
    {%-liquid
      assign allowFormats = ''
      assign contentMsg = ''
      assign collectParams = ''
      assign collectParamsForPrevious = ''
      if b.enablePNG
        assign allowFormats = allowFormats | append: '"image/png"'
        assign contentMsg = contentMsg | append: 'PNG'
      endif
      if b.enableJPG
        if allowFormats != blank
          assign allowFormats = allowFormats | append: ',"image/jpg","image/jpeg"'
          assign contentMsg = contentMsg | append: ', JPG / JPEG'
        else
          assign allowFormats = allowFormats | append: '"image/jpg","image/jpeg"'
          assign contentMsg = contentMsg | append: 'JPG / JPEG'
        endif
      endif
      if b.enableAI
        if allowFormats != blank
          assign allowFormats = allowFormats | append: ',"application/postscript"'
          assign contentMsg = contentMsg | append: ', AI'
        else
          assign allowFormats = allowFormats | append: '"application/postscript"'
          assign contentMsg = contentMsg | append: 'AI'
        endif
      endif
      if b.enableEPS
        if allowFormats != blank
          assign allowFormats = allowFormats | append: ',".eps"'
          assign contentMsg = contentMsg | append: ', EPS'
        else
          assign allowFormats = allowFormats | append: '".eps"'
          assign contentMsg = contentMsg | append: 'EPS'
        endif
      endif
      if b.enablePDF
        if allowFormats != blank
          assign allowFormats = allowFormats | append: ',"application/pdf"'
          assign contentMsg = contentMsg | append: ', PDF'
        else
          assign allowFormats = allowFormats | append: '"application/pdf"'
          assign contentMsg = contentMsg | append: 'PDF'
        endif
      endif
      if b.enableTIF
        if allowFormats != blank
          assign allowFormats = allowFormats | append: ',"image/tiff"'
          assign contentMsg = contentMsg | append: ', TIF / TIFF'
        else
          assign allowFormats = allowFormats | append: '"image/tiff"'
          assign contentMsg = contentMsg | append: 'TIF / TIFF'
        endif
      endif
      if b.enableSVG
        if allowFormats != blank
          assign allowFormats = allowFormats | append: ',"image/svg+xml"'
          assign contentMsg = contentMsg | append: ', SVG'
        else
          assign allowFormats = allowFormats | append: '"image/svg+xml"'
          assign contentMsg = contentMsg | append: 'SVG'
        endif
      endif
      assign contentMsg = contentMsg | replace_last: ',', ' and '
      assign contentMsg = 'We accept the following file types: ' | append: contentMsg
    -%}
    {%- if b.enablePNG -%}
      {%- capture collectParams -%}
        {{- collectParams -}}
        {%- if collectParams != blank -%},{%- endif -%}
        {
          "fileType": "png",
