                        {% assign _dis_title = _dis_title | split : "+" | join : "" %}

                        <div class="pricesTable__item" index="{{ i }}" min="{{ minQty }}" max="{{ maxQty }}" off="{{ off }}" next-off="{{ nextOff }}" pre-cut="{{ preCutVal }}">
