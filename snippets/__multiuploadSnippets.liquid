    <style>
      #uploadArea.drop-disabled-type::after {
        content: "{{ contentMsg }}";
      }
    </style>

    <script>
      const productURL = `{{ product.url }}`;
      const imagesTypesNew = [{{ allowFormats }}];
      const imgParamsSettings = [{{ collectParams }}];
      const fileParamsAccount = [{{ collectParamsForPrevious }}];
      const definedMinWidth = {{ b.minWidth | times: 1 | json }};
      const definedMaxWidth = {{ b.maxWidth | times: 1 | json }};

      const definedMinHeight = {{ b.minHight | times: 1 | json }};
      const definedMaxHeight = {{ b.maxHeight | times: 1 | json }};

      const definedMinQty = {{ b.minQty | times: 1 | json }};
      const isEnabledPixelsValidation = {{ b.enablePixleValidation | json }};
      const definedMaxPixelsForSuperRes = {{ b.maxPixelsForSuperRes | times: 1 | json }};
    </script>
    <upload-controls current="upload">
      <master-upload{% if b.applyNewDesign %} newdesign=""{% endif %} err-type-msg="{{ contentMsg }}" err-size-msg="Please Your File Should be 5 GB or Less">
        {% if b.applyNewDesign %}
          <div class="upload__icon">
            <img src="https://cdn.shopify.com/s/files/1/0558/0265/8899/files/image_9_89553aea-5c53-4c9d-be87-f468e46ee459.png?auto=format,compress&amp;v=1757090125">
          </div>
        {% else %}
          <div class="upload__info">
            <h3><span>NEW</span> Upload all your files at once!</h3>
            <p>Checkout faster then ever with smooth, simultaneous multiupload file uploads.</p>
          </div>
        {% endif %}
        <!-- Header -->
        <div class="upload-area__header" style="display:none;">
          <h4 class="upload-area__title" >Upload your file</h4>
          <p class="upload-area__paragraph" style="display:none;">
            File should be an image
            <strong class="upload-area__tooltip">
              Like
              <span class="upload-area__tooltip-data"></span> <!-- Data Will be Comes From Js -->
            </strong>
          </p>
        </div>
        <!-- End Header -->
        <div id="dropZoon" class="upload-area__drop-zoon drop-zoon">
          {% if b.applyNewDesign %}
            <p class="drop-zoon__paragraph">
              <strong>Upload your file(s)</strong>
            </p>
            <span class="_or">Drag and drop file(s) here or click to browse</span>
            <button type="button">Browse</button>
          {% else %}
            <p class="drop-zoon__paragraph">
              <strong>Drop your file(s) here</strong>
            </p>
            <span class="_or">or</span>
            <button type="button">Upload File(s)</button>
          {% endif %}
          <span class="drop-zoon__icon" style="display:none;">
            <i class='bx bxs-file-image'></i>
          </span>
          {% if customer %}
            <p class="access_old_data">
              <a href="#" class="purchase_from_previous" data-type="first_upload">
                Choose a previous design
              </a>
            </p>
          {% else %}
            <p class="access_old_data">
              <a data-link="" href="/customer_authentication/login?return_to={{ product.url | url_encode }}">
                Login
              </a>
              {% if b.applyNewDesign %}
                to see your designs
              {% else %}
                to see previous designs
              {% endif %}
            </p>
          {% endif %}
          <span id="loadingText" class="drop-zoon__loading-text" style="display:none;">Please Wait</span>
