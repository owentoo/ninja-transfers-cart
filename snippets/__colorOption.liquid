{%- liquid
  assign color_swatch_name = value | handle | append: '.png'
  assign color_swatch_image = images[color_swatch_name]
  assign color_swatch_background = value | downcase | escape | replace: ' ', ''
-%}
{%- if color_swatch_image != blank and value != 'Gold' -%}
  <img src="{{ color_swatch_image | image_url: width: 24, height: 24, crop: 'center' }}">
{%- else -%}
  {%-liquid
    case color_swatch_background
      when 'mint'
        assign __colorcode = "#caf7e5"
      when 'denim'
        assign __colorcode = "#5e87a3"
      when 'glowinthedark'
        assign __colorcode = "rgb(242, 253, 158)"
      when 'glowinthedark'
        assign __colorcode = "rgb(242, 253, 158)"
      when 'green'
        assign __colorcode = "#82d145"
      when 'pink'
        assign __colorcode = "#f77ff0"
      when 'orange'
        assign __colorcode = '#FF3900'
      when 'gold'
        assign __colorcode = '#f1a70f'
      when 'yellow'
        assign __colorcode = '#ffe500'
      when 'yellow'
        assign __colorcode = '#ffe500'
      when 'teal'
        assign __colorcode = '#66c9c4'
      when 'teal'
        assign __colorcode = '#66c9c4'
      when 'blue'
        assign __colorcode = '#005bd3'
      when 'purple'
        assign __colorcode = '#a54dcf'
      when 'lavender'
        assign __colorcode = '#d9b7ea'
      when 'tan'
        assign __colorcode = '#e9b396'
      when 'red'
        assign __colorcode = '#c40000'
      when 'skyblue'
        assign __colorcode = '#88d4f7'
      else
        assign __colorcode = color_swatch_background
    endcase
  -%}
  <selected-color style="background-color: {{ __colorcode }};">&nbsp;</selected-color>
{%- endif -%}