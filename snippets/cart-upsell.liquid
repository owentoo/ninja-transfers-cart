{%liquid
  assign cart_isupsell = false
  for item in cart.items
    assign pType = item.product.type | escape | downcase
    assign beatles = pType | split: " " | join : "_"
    assign type_list = 'custom_transfers,uv_dtf' | split : ","
    if type_list contains beatles
      assign cart_isupsell = true
    endif
  endfor
%}
{% if cart_isupsell %}
<div class="customTabelPopup__overlay uv-cart-upsell" style="display:none">
   <div class="customTabelPopup">
      <span class="customTabelPopup__close_uv">
         <svg width="24px" height="24px" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M6 6L18 18" stroke="#000" stroke-linecap="round"></path> 
            <path d="M18 6L6.00001 18" stroke="#000" stroke-linecap="round"></path>
         </svg>
      </span>
     <div class="upsell-wrapper main">
        <div class="upsell-product-list-container">
           {% for metaobject_data in shop.metaobjects.cart_upsell_popup.values %}
           <div class="cart-upsell-header">
              <h2>{{ metaobject_data.heading }}</h2>
              <div>{{ metaobject_data.subheading }}</div>
              <div class="value-props">
                 <div class="value-prop">✓ Next day rush delivery</div>
                 <div class="value-prop">✓ No minimums</div>
                 <div class="value-prop">✓ Competitive pricing <span class="tooltip"><span class="info-circle">i</span>
                    <span class="tooltiptext">Get pricing that protects your profit margin. Our blank product pricing rivals direct wholesalers and is as low or lower than most secondary market suppliers.</span></span>
                 </div>
              </div>
           </div>
           <div class="cart-upsell-product-list">
              <div class="upsell-slider">
                 {% for ppp in metaobject_data.product_list.value %}
                  {% if ppp.available %} 
                    <div>
                      <!-- Product block -->
                      <div class="pdpRelatedProducts__pItem" pid="{{ ppp.id }}" handle="{{ ppp.url }}">
                        <div class="pdpRelatedProducts__pItem__img __selectproduct lblctrl">
                          <img src="{{ ppp.featured_image | image_url: width: 300 }}" alt="{{ ppp.title | escape }}" class="pdpRelatedProducts__pItem__triggerAction_1" />
                        </div>
                        <div class="pdpRelatedProducts__pItem__content">
                          <span class="pdpRelatedProducts__pItem__startFrom">starting at</span>
                          <div class="pdpRelatedProducts__pItem__price">
                            {{ ppp.price_min | money_without_currency | prepend: '$' }}
                          </div>
                          <div class="pdpRelatedProducts__pItem__yotpo">
                            <div class="yotpo-widget-instance" data-yotpo-instance-id="447610" data-yotpo-product-id="{{ ppp.id }}" data-yotpo-section-id="{{ section.id }}" data-yotpo-preloaded-data=""></div>
                          </div>
                          <h4 class="pdpRelatedProducts__pItem__title">{{ ppp.title }}</h4>
                        </div>
                        <div class="pdpRelatedProducts__pItem__atc">
                          <a class="lnkcolor button __selectproduct" href="javascript:void(0)"><strong>+ Select Quantity</strong></a>
                        </div>
                        <div class="pdpRelatedProducts__popUp hidden">
                          {% render 'upsell_product_info', prod_: ppp %}
                        </div>
                      </div>
                      <!-- Product block -->
                    </div>
                  {% endif %}
                {% endfor %}

              </div>
           </div>
           <div class="mrg32 text-center">
              <div class="shopall">
                 <a class="lnkcolor" href="{{ metaobject_data.link.value.url }}">
                    <span>{{ metaobject_data.link.value.text }}</span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                       <path d="M13.3333 5L20 12M20 12L13.3333 19M20 12L4 12" stroke="#46aae3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                 </a>
              </div>
              <div class="upsell__popUp__checkout">
                 <a class="" href="{{ metaobject_data.checkout_text.value.url }}">
                 <span>{{ metaobject_data.checkout_text.value.text }}</span>
                 </a>
              </div>
           </div>
           {%- endfor -%}
        </div>
        <div class="upsell-product-container">
          
        </div>
      </div>
   </div>
</div>

  <style>
    body.noscroll{overflow:hidden;}
    .upsell-product-list-container .tooltip .tooltiptext{top: calc(100% + 6px); left: 50%; margin-left: -150px;}
.uv-cart-upsell .customTabelPopup::-webkit-scrollbar {width: 8px;}
.uv-cart-upsell .customTabelPopup::-webkit-scrollbar-track {background-color: #ddd;}
.uv-cart-upsell .customTabelPopup::-webkit-scrollbar-thumb {background-color: #666;}
    .upsell-wrapper{display: flex; flex-wrap: nowrap; align-items: flex-start; width: 100%; overflow: hidden;}
    .upsell-wrapper .upsell-product-list-container, .upsell-wrapper .upsell-product-container {min-width: calc(100% + -0px); transition: .3s all ease-in-out;}
    .upsell-wrapper.prod .upsell-product-list-container, .upsell-wrapper.prod .upsell-product-container{transform: translate(-100%);}
    .upsell-wrapper.main .upsell-product-list-container, .upsell-wrapper.main .upsell-product-container{transform: translate(0);}
    
    .upsell-slider{display:none;}
    .uv-cart-upsell .customTabelPopup{max-width:1100px; padding:10px; max-height:85vh; overflow:hidden; overflow-y:auto;}
    .cart-upsell-header{text-align:center;}
    .uv-cart-upsell{height:100%; z-index:100001;}
    .uv-cart-upsell .value-props{margin-top: 14px; margin-bottom: 14px;}
    
    .cart-upsell-product-list .slick-arrow {position: absolute; top: 50%; width: 30px; height: 30px; z-index: 10; background-color: #fff; border-radius: 999px; transform: translateY(-50%); cursor: pointer; display: grid; align-items: center; box-shadow: 0 0 3px #999;}
    .cart-upsell-product-list .slick-arrow.slick-disabled {cursor: default; opacity: 0;}
    .cart-upsell-product-list .slick-arrow svg {margin: auto;}
    .cart-upsell-product-list .slick-prev {left: 10px;}
    .cart-upsell-product-list .slick-next {right: 10px;}
    .cart-upsell-product-list .yotpo-sr-bottom-line-right-panel{display:none !important}
    .cart-upsell-product-list .pdpRelatedProducts__pItem {margin-right: 10px;}
    .cart-upsell-product-list .pdpRelatedProducts__pItem__img{/*height:216px;*/}
    .cart-upsell-product-list .pdpRelatedProducts__pItem__img img{max-height:100%; width: 100%; max-width:100%;}
    .cart-upsell-product-list .pdpRelatedProducts__pItem{background-color: white !important; padding: 6px; border: 1px solid #e0dfdf; border-radius: 4px; display: grid; gap: 8px; max-width: calc(100% - 10px);}
    .cart-upsell-product-list .pdpRelatedProducts__pItem__startFrom{color: #2b2b2b; font-size: small;}
    .cart-upsell-product-list .pdpRelatedProducts__pItem__price{color: #000; font-weight: 600; font-size: large;}
    .cart-upsell-product-list .pdpRelatedProducts__pItem__title{font-size: small; margin-bottom: 4px; line-height: 1.1; height:29px;}
    .cart-upsell-product-list .pdpRelatedProducts__pItem__atc .button{cursor: pointer; border-color: transparent; text-align: left; padding-left: 0; color: #46aae3; font-weight: 600;}
    .uv-cart-upsell .shopall > a{display: flex; align-items: center; gap: 4px; justify-content: center; margin-top: 20px; color: #46aae3; font-weight: 600; max-width: -moz-max-content; max-width: max-content;
    margin-left: auto; margin-right: auto;}
    .uv-cart-upsell .upsell__popUp__checkout {display: grid; margin-top: 20px; margin-bottom: 14px;}
    .uv-cart-upsell .upsell__popUp__checkout a {color: #fff; background-color: #46aae3; display: inline-block; padding: 14px 26px; border-radius: 6px; border: 2px solid #46aae3; margin-left: auto; margin-right: auto; transition: 0.2s all ease-in-out; font-weight: 600;}
    .uv-cart-upsell .upsell__popUp__checkout a:hover {background-color: #fff; color: #46aae3;}


    
      .uv-cart-upsell .value-props .value-prop{font-size:16px;}
    .uv-cart-upsell .product-image img {max-width: 100%; height: auto; border-radius: 10px; margin-bottom: 15px;}
    .uv-cart-upsell .variant-option{padding-top:16px; padding-bottom:16px;}
    .uv-cart-upsell .color-swatch-group,.uv-cart-upsell .variant-pill-group {display: flex; gap: 10px; justify-content: flex-start; margin-top: 10px;}
  .uv-cart-upsell .color-swatch {width: 30px; height: 30px; border-radius: 50%; border: 2px solid rgba(0,0,0,0.2); cursor: pointer; outline: none;}
  .uv-cart-upsell .color-swatch.active {border: 2px solid black;}
    .uv-cart-upsell .variant-pills {display: flex; gap: 10px; margin: 20px 0; margin-top:8px; flex-wrap: wrap; justify-content: flex-start;}
  .uv-cart-upsell .variant-pill {text-align: center; display: inline-block; border-style: solid; border-width: 1px; border-radius: var(--border-radius-buttons);
    border-color: var(--color-borders-forms-primary); color: var(--color-text-main); padding: var(--input-padding) calc(var(--input-padding)* .9); transition: all .1s linear;
    line-height: 1; width: max-content; min-width: 2.5rem; cursor: pointer;}
  .uv-cart-upsell .variant-pill:hover,.uv-cart-upsell .variant-pill.active {border-color: var(--color-text-main) !important; box-shadow: 0 0 0 1px var(--color-text-main);}
  .uv-cart-upsell .product-description ul{list-style-type:disc; margin-left:23px;}
  .uv-cart-upsell .product-description ul li:not(:first-child) {margin-top: .75rem;}
  .uv-cart-upsell .add-to-cart:hover,.uv-cart-upsell  .buy-now:hover,.uv-cart-upsell .add-to-cart,.uv-cart-upsell  .buy-now {display: block; text-transform:uppercase; font-weight:bold; width: 100%; margin: 10px 0; padding: 10px; border: none; background: #3eaeff; line-height:45px; border-radius:var(--border-radius-buttons); color: white; cursor: pointer; font-size: 16px; height:auto;}
  .uv-cart-upsell .quantity-selector {display: inline-flex; justify-content: flex-start; align-items: center; gap: 10px; margin: 15px 0; margin-top:8px; border:1px solid #1d1d1d; border-radius:var(--border-radius-forms);}
  .uv-cart-upsell .quantity-input,.uv-cart-upsell .quantity-input:hover {background:none; height:41px; outline:none; width: 50px; text-align: center; font-size: 16px; border-radius: 5px; padding: 5px; border:none;}
  .uv-cart-upsell .qty-btn {background: none; border: none; padding: 15px; font-size: 16px; cursor: pointer; border-radius: 5px; display:inline-flex;}
  .uv-cart-upsell .desc-wrapper .relatedPopup__content__fullDetail{text-align:left;}
  .uv-cart-upsell .product-description{padding-top:8px;}
  .uv-cart-upsell .qty-with-price {width: 100%; border-bottom: 1px solid #9a9a9a; padding-bottom: 10px; padding-top: 10px; margin-bottom: 6px; display: flex; align-items: center; justify-content: space-between;}
  .uv-cart-upsell .relatedPopup__offers{flex-flow:column wrap}
  .uv-cart-upsell go-back-btn{display: inline-flex; align-items: center; color: #3eaeff; font-weight: bold; margin-bottom: 12px; cursor:pointer;}
  .uv-cart-upsell go-back-btn span{margin-left:8px;}
  .uv-cart-upsell .relatedPopup__content__title{font-size:24px;}
  .uv-cart-upsell .price_node{margin-top:22px;}
  .uv-cart-upsell .relatedPopup__media img{margin:auto;}

  .uv-cart-upsell .yotpo-sr-bottom-line-right-panel{height:18px; align-items: center; line-height: 0;}
  .uv-cart-upsell .pdp-productprice{font-size:20px;}
  .relatedPopup__content__fullDetail a{color: #42a9de; font-weight: 600;}
  .uv-cart-upsell .relatedPopup__offers {flex-flow: column wrap; display: flex; align-items: center; gap: 8px;}
    .relatedPopup__offers__item{display:flex; align-items:center; color: #3e6166; font-weight:700;}
    .relatedPopup__offers__item > span{margin-left:4px; margin-right:4px;}
   .uv-cart-upsell .swiper-button-next::after,.uv-cart-upsell .swiper-button-prev::after{content:none;}
    
.uv-cart-upsell .swiper-button-prev,.uv-cart-upsell .swiper-button-next {width: 36px; height: 36px; border-radius: 9999px; box-shadow: 0 0 3px #000; background-color: #fff;
  position: absolute; top: calc(50% + 18px);}
    .uv-cart-upsell .swiper-button-prev{ transform:rotate(180deg);}
.uv-cart-upsell .swiper-button-prev svg,.uv-cart-upsell .swiper-button-next svg {width: 12px; height: 12px;}
    @media(min-width:768px){
      .uv-cart-upsell .relatedPopup {display: grid; grid-template-columns: 40% auto; gap: 16px;}
      .uv-cart-upsell .value-props .value-prop{margin:0; font-size:16px;}
    }
    @media screen and (max-width: 767px) {
      .value-prop{width:auto; margin-bottom:2px;}
    }
</style>
<script>
  function showUvPopup(){
    setCookie("uv_upsell", "true", "session");
    $("body").addClass("noscroll");
    $(".uv-cart-upsell").show();
    if(!$(".upsell-slider").hasClass(".slick-initialized")){
      $(".upsell-slider").show().slick({
          dots: false,
          arrows: true,
          prevArrow: '<button type="button" class="slick-prev pull-left"><svg width="7px" height="9px" viewBox="0 0 7 9" version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"><g id="Page-1" stroke="none" stroke-width="1" fill="none" fill-rule="evenodd"><polygon id="Triangle" fill="#000000" transform="translate(3.5, 4.5) rotate(-90) translate(-3.5, -4.5)" points="3.5 1 8 8 -1 8"></polygon></g></svg></button>',
          nextArrow: '<button type="button" class="slick-next pull-right"><svg width="7px" height="9px" viewBox="0 0 7 9" version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"><g id="Page-1" stroke="none" stroke-width="1" fill="none" fill-rule="evenodd"><polygon id="Triangle" fill="#000000" transform="translate(3.5, 4.5) rotate(90) translate(-3.5, -4.5)" points="3.5 1 8 8 -1 8"></polygon></g></svg></button>',
          infinite: false,
          slidesToShow: 5.5,
          slidesToScroll: 3,
          adaptiveHeight:false,
          autoplay: false,
          autoplaySpeed: 10000,
          responsive: [
            {
              breakpoint: 1200,
              settings: {
                slidesToShow: 3.5
              }
            },
            {
              breakpoint: 1000,
              settings: {
                slidesToShow: 2.75,
                slidesToScroll: 2
              }
            },
            {
              breakpoint: 815,
              settings: {
                slidesToShow: 1.75,
                slidesToScroll: 1
              }
            },
            {
              breakpoint: 768,
              settings: {
                slidesToShow: 2.5,
                slidesToScroll: 3
              }
            },
            {
              breakpoint: 600,
              settings: {
                slidesToShow: 2.2,
                slidesToScroll: 1
              }
            },
            {
              breakpoint: 450,
              settings: {
                slidesToShow: 1.85,
                slidesToScroll: 1
              }
            },
            {
              breakpoint: 360,
              settings: {
                slidesToShow: 1.5,
                slidesToScroll: 1
              }
            }
          ]
        })
    }else{
      $(".upsell-slider").unslick();
    }
  }
  
  
  var _slickObj = "";
  $(function(){
    
    $(".__selectproduct").click(function(){
      var cardData = $(this).parents(".pdpRelatedProducts__pItem");
      var _productData = cardData.find(".pdpRelatedProducts__popUp").html();
      $(".upsell-wrapper").removeClass("main").addClass("prod");
      $(".upsell-product-container").html(_productData);
      var _cv = $('.uv-cart-upsell .upsell-product-container .variant-image').index();
      setTimeout(function(){
        _slickObj = $('.uv-cart-upsell .upsell-product-container .swiper-wrapper').slick({
          prevArrow : $('.uv-cart-upsell .main-slider').find(".swiper-button-prev"),
          nextArrow : $('.uv-cart-upsell .main-slider').find(".swiper-button-next")
        });
      
        _slickObj.slick('slickGoTo', _cv);
      },200)
    })
  })
  .on(`click`, `.uv-cart-upsell`, function(event) {
      console.log("close uv-cart-upsell")
      if (!$(event.target).closest(".customTabelPopup").length) {
        $(".uv-cart-upsell .customTabelPopup__close").trigger("click");
        $("body").removeClass("noscroll setOverlay");
      } else {
      }
  })
  .on(`click`, `.uv-cart-upsell .customTabelPopup__close_uv`, function( e ) {
    try {
      e.stopImmediatePropagation();
      console.log("close trigger")
      $( `.customTabelPopup__overlay` ).fadeOut();
      $(".upsell-wrapper").removeClass("prod").addClass("main");
      $( `.product.container.container--large` ).css( `z-index`, `unset` );
      $( `body` ).removeAttr( `style` );
      $("body").removeClass("noscroll setOverlay");
    } catch ( err ) {
      console.log( `ERROR .customTabelPopup__close`, err.message );
    }
  })
</script>


<!-- JavaScript -->
<script>
  $(document).ready(function() {
    
    var $popup = $('body');
    $popup.on('click', '.p_bck', function(event) {
      $(".upsell-wrapper").removeClass("prod").addClass("main");
    })
    $popup.on('click', '._tdesc', function(event) {
      var pNode = $(this).parents(".desc-wrapper");
      $(this).hide();
      pNode.find(".second").show();
      pNode.find(".product-description").removeClass("hidden");
    })
    $popup.on('click', '._tndesc', function(event) {
      var pNode = $(this).parents(".desc-wrapper");
      $(this).hide();
      pNode.find(".first").show();
      pNode.find(".product-description").addClass("hidden");
    })

    var currencySymbol = "{{ cart.currency.symbol }}"; 
    
    function updateVariant() {
        var selectedValues = {};
    
        $('.uv-cart-upsell .upsell-product-container .variant-pill.active, .uv-cart-upsell .upsell-product-container .color-swatch.active').each(function() {
            var optionName = $(this).closest('[data-option-name]').data('option-name');
            selectedValues['options[' + optionName + ']'] = $(this).data('value');
        });
    
        var optionNames = ["option1", "option2", "option3"];
    
        var selectedVariant = null;
        
        variants.forEach(function(variant) {
            var isMatch = variant.options.every(function(value, index) {
                return selectedValues['options[' + optionNames[index] + ']'] === value;
            });
    
            if (isMatch) {
                selectedVariant = variant;
            }
        });
    
        if (selectedVariant) {
            console.log(selectedVariant, "Selected Variant ID:", selectedVariant.id);
    
            $('.uv-cart-upsell .upsell-product-container .add-to-cart, .uv-cart-upsell .upsell-product-container .buy-now')
                .attr('data-variantid', selectedVariant.id);
    
            var imageSrc = selectedVariant.featured_image ? selectedVariant.featured_image.src : '';
            $('.uv-cart-upsell .upsell-product-container .price-value').html(currencySymbol + '' + selectedVariant.price / 100);
          
          if(imageSrc != ""){
            $('.uv-cart-upsell .upsell-product-container .main-slider .variant-image img').attr('src', imageSrc);
            console.log(selectedVariant, "Selected Variant ID:", selectedVariant.id,imageSrc);
            var _kv = $('.uv-cart-upsell .upsell-product-container .main-slider .variant-image:not(.slick-cloned)').index() - 1;
            _slickObj.slick('slickGoTo', _kv);  
          }
    
            var _kv = $('.uv-cart-upsell .variant-image:not(.slick-cloned)').index() - 1;
            console.log(_kv, $(this));
            _slickObj.slick('slickGoTo', _kv);
            $('.uv-cart-upsell .upsell-product-container .out-of-stock-message').remove();
            if (selectedVariant.available) {
                $('.uv-cart-upsell .upsell-product-container .add-to-cart, .uv-cart-upsell .upsell-product-container .buy-now')
                    .prop('disabled', false)
                    .removeClass('disabled');
            } else {
                $('.uv-cart-upsell .upsell-product-container .add-to-cart, .uv-cart-upsell .upsell-product-container .buy-now')
                    .prop('disabled', true)
                    .addClass('disabled');
    
                if ($('.uv-cart-upsell .upsell-product-container .out-of-stock-message').length === 0) {
                    $('.uv-cart-upsell .upsell-product-container').append('<p class="out-of-stock-message" style="color:red; font-weight:bold;">This variant is currently out of stock!</p>');
                }
            }
        }
    }




     $popup.on('click', '.uv-cart-upsell .upsell-product-container .color-swatch', function() {
      var $this = $(this);

      $this.closest('.color-swatch-group').find('.color-swatch').removeClass('active');
      $this.addClass('active');

      updateVariant();
    });

    
    $popup.on('click', '.variant-pill', function(event) {
      event.preventDefault();
      var variantId = $(this).data('variantid');
      var price = $(this).data('price');
      var imageSrc = $(this).data('image');
      // Update price and image
      
      var _kv = $('.uv-cart-upsell .upsell-product-container .variant-image:not(.slick-cloned)').index() - 1;
      // Update buttons
      $('.uv-cart-upsell .upsell-product-container .add-to-cart,.uv-cart-upsell .upsell-product-container .buy-now').attr('data-variantid', variantId);

      // Update active class
      var $this = $(this);
      $this.closest('.variant-pill-group').find('.variant-pill').removeClass('active');
      $this.addClass('active');
      
      _slickObj.slick('slickGoTo', _kv);
      updateVariant();
    });

    $popup.on('click', '.qty-btn', function() {
      var $input = $popup.find('.quantity-input');
      var currentVal = parseInt($input.val(), 10);

      if ($(this).hasClass('increase')) {
        $input.val(currentVal + 1);
      } else if ($(this).hasClass('decrease') && currentVal > 1) {
        $input.val(currentVal - 1);
      }
    });
    
    // Add to Cart function
    var _cartCTA = 0;
    $popup.on('click', '.uv-cart-upsell .add-to-cart', function() {
      $(this).addClass("working");
      upsell_addtocart($popup,$(this));
    });

    // Buy Now function
    $popup.on('click', '.uv-cart-upsell .buy-now', function() {
      $(this).addClass("working");
      upsell_addtocart($popup,$(this),"1");
    });
  });

  function upsell_addtocart($popup,obj,actionType){
    var action = actionType || 0;
    var variantId = $(obj).attr('data-variantid');
      var quantity = parseInt($popup.find('.upsell-product-container .quantity-input').val(), 10);

      $.ajax({
        type: 'POST',
        url: '/cart/add.js',
        data: { id: variantId, quantity: quantity },
        dataType: 'json',
        success: function() {
          if(action == "1"){
            location.href = "/checkout";
          }
          $('.product-buynow .button').removeClass("working");
            refreshCart( `notOpen` );
          
            //$(".uv-cart-upsell .pdpRelatedProducts__popUp__close").trigger("click");  
            setTimeout(() => {
              const isToast = $( `body .toast` ).length;
              if ( isToast > 0 ) {
                $( `body .toast` ).addClass( `active` );
      
                setTimeout(() => {
                  $( `body .toast` ).removeClass( `active` );
                }, 5000);
              } else {
                $( `body` )
                  .append( `
                    <div class="toast active">
                      <div class="toast-content">
                        <svg  class="fas fa-solid fa-check check" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path d="M9 22l-10-10.598 2.798-2.859 7.149 7.473 13.144-14.016 2.909 2.806z"/></svg>
                          <div class="message">
                          <span class="text text-1">Added</span>
                          <span class="text text-2">Product successfully added to your cart</span>
                        </div>
                      </div>
                      <svg class="fa-solid fa-xmark close" width="24px" height="24px" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6 6L18 18" stroke="#000" stroke-linecap="round"></path><path d="M18 6L6.00001 18" stroke="#000" stroke-linecap="round"></path></svg>
      
                      <!-- Remove 'active' class, this is just to show in Codepen thumbnail -->
                      <div class="progress active"></div>
                    </div>
                    ` );
      
                    setTimeout(() => {
                      $( `body .toast` ).addClass( `active` );
                    }, 50);
      
                setTimeout(() => {
                  $( `body .toast` ).removeClass( `active` );
                  setTimeout(() => {
                    $( `body .toast` ).remove();
                  }, 100);
                }, 5000);
              }
            }, 300);
          
          //$(".uv-cart-upsell .customTabelPopup__close").trigger("click");
        },
        error: function(err) {
          console.error('Error adding to cart:', err);
        }
      });
  }
</script>
{% endif %}