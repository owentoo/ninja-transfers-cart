{%-liquid
  assign productVideoData_arr = product.metafields.custom.product_video.value
  for item in productVideoData_arr
    if forloop.index == 1
      assign videoText = item
    endif
    if forloop.index == 2
      assign videoURL = item
     if videoURL contains 'youtube'
        assign getVideoID = videoURL | split: 'watch?v=' | last
        assign isYouTube = true
        assign videoURL = 'iframe src="https://www.youtube.com/embed/' | append: getVideoID | append: '?autoplay=1" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen'
      endif
    endif
    if forloop.index == 3
      assign videoIcon = item
    endif
  endfor
-%}

{%- if videoText != blank and videoURL != blank and template.suffix != 'blanks' -%}
  <style>
    .productVideo {
      display: flex;
      align-items: center;
      gap: 6px;
      margin-top: 18px;
      max-width: max-content;
      cursor: pointer;
    }
    .productVideo:hover .productVideo__text {
      color: #03a3f7;
    }
    .productVideoModal {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100vh;
      z-index: 99999999;
      display: grid;
      align-items: center;
      justify-content: center;
      background: #00000071;
    }
    .productVideoModal__wrap {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 100%;
      max-width: 650px;
      padding: 56px 30px 26px;
      background-color: #fff;
      border-radius: 10px;
      transform: translate(-50%, -50%);
    }
    .productVideoModal__wrap iframe {
      width: 100%;
      aspect-ratio: 6/4;
    }
    .productVideoModal__video {
      width: 100%;
      max-width: 650px;
    }
    .productVideoModal__close {
      position: absolute;
      top: 12px;
      right: 24px;
      width: 24px;
      height: 24px;
      z-index: 1;
      cursor: pointer;
    }
  </style>
  <div class="productVideo">
    <img src="{{ 'watch_video.svg' | asset_url }}" width="22px">

    <div class="productVideo__text">
      {{ videoText }}
    </div>
  </div>

  <script>
    const productVideoEle = `
      <div class="productVideoModal">
        <div class="productVideoModal__wrap">
          <div class="productVideoModal__close">
            <svg width="24px" height="24px" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6 6L18 18" stroke="#000" stroke-linecap="round"></path><path d="M18 6L6.00001 18" stroke="#000" stroke-linecap="round"></path></svg>
          </div>
          {% if isYouTube %}
            <{{ videoURL }}></iframe>
          {% else %}
            <video autoplay="" loop="" controls="true" playsinline="" class="productVideoModal__video"><source data-src="{{ videoURL }}" type="video/mp4" src="{{ videoURL }}"></video>
          {% endif %}
        </div>
      </div>
    `;
    $( document )
    .on(`click`, `.productVideo`, function( e ) {
      try {
        e.stopImmediatePropagation();
        $( `body` )
          .css( `overflow`, `hidden` )
          .prepend( productVideoEle );

      } catch ( err ) {
        console.log( `ERROR .productVideo`, err.message );
      }
    })
    .on(`click`, `.productVideoModal__close, .productVideoModal`, function( e ) {
      try {
        e.stopImmediatePropagation();
        $( `body` )
          .css( `overflow`, '' )
          .find( `.productVideoModal` )
          .remove();
      } catch ( err ) {
        console.log( `ERROR .productVideoModal__close`, err.message );
      }
    })
    ;
  </script>
{%- endif -%}

<script>
  $(function(){
    $(".product-gallery__thumbnails .thumbnail").click(function(){
      var _type = $(this).attr("data-media-type");
      if(_type == "video"){
        setTimeout(function(){
          $(".product-gallery-item.css-slide-active").find(".video-popup__play").trigger("click");
        },1000)
      }
    })
  })
</script>
