    <style>
      .video-box {position: relative; width: 100%; margin: 0 auto; margin-top:16px;}
      .video-wrapper.visible video{opacity:1;border-radius:9px;}
      .video-wrapper.visible .img-container,.video-wrapper video{max-width:100%;opacity:0;}
      .video-wrapper .img-container{position:absolute; top:0; bottom:0; right:0; left:0; display: flex; align-items: center; justify-content: center; z-index:1; background-size: contain; background-position: center; background-repeat: no-repeat; cursor:pointer; border-radius:9px; background-size:cover;}
