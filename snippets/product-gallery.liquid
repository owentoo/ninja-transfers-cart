{% assign hoverimg = product.metafields.custom.animated_image | default : "" %}
{% if section.settings.gallery_position_vertical %}
<style>
  .grt-image-gallery .lazy-image.lazy-image--fit.lazy-image--small img{padding:0;}
  .grt-image-gallery .product-gallery__thumbnails .thumbnail.active{border-width:0px;}
  .grt-image-gallery .product-gallery__thumbnails .thumbnail{width:60px; height:60px; border-radius:9px;}
  .grt-thumbnails.product-gallery__thumbnails .grt-video-thumb{top: 50%; right: 50% !important; display: flex; align-items: center; justify-content: center; margin-right: -10px; margin-top: -10px;}
  .grt-image-gallery .product-gallery__thumbnails .grt-video-thumb svg .path{fill:#fff;}
  .grt-image-gallery .product-gallery__thumbnails .active .thumbnail__image,.grt-image-gallery .product-gallery__thumbnails .thumbnail__image:hover{opacity:1}
  .grt-image-gallery .product-gallery__thumbnails .thumbnail__image{opacity:0.4;}
@media(min-width:768px){
  .grt-image-gallery .grt-main-image{position:relative; width:auto; max-width:100%; }
  .grt-image-gallery .grt-main-image .product-gallery-item{border-radius:9px;}
  .grt-image-gallery{display:grid;flex-direction:column;align-items:flex-start;grid-template-columns:72px auto;}
  .grt-image-gallery .grt-thumbnails{display:flex;flex-direction:row;gap:8px;flex-wrap:wrap;order: -1;padding-top:0;height: 455px;overflow: auto;scroll-behavior: smooth;}
  .grt-image-gallery img{max-width:100%;height:auto;object-fit:contain;}
  .grt-image-gallery .product-gallery__thumbnails-holder{display:grid; gap:12px;}
  .grt-image-gallery .product-gallery__thumbnails .thumbnail:not(:last-child){margin-inline-end:0;}
  .grt-image-gallery .grt-thumbnails{-ms-overflow-style:none;scrollbar-width:none;}
  .grt-image-gallery .grt-thumbnails::-webkit-scrollbar{display:none;}
}
</style>
{% endif %}
<div
    class="posrel
    gallery_position
    product-gallery
    product-gallery--{% if section.settings.gallery_layout contains 'scroll' %}scroll{% else %}slider{% endif %}
    lap--grid--slider-container
    {% if section.settings.gallery_layout contains 'scroll' and section.settings.show_thumbnails and product.media.size > 1 %} product-gallery--has-thumbnails {% endif %}
  "
  data-js-product-gallery
  style="--border-radius: {{ section.settings.border_radius }}px"
>
  <article class="grt-image-gallery">
    <div class="grt-main-image">
  {% style %}
    #product-{{ section.id }} .product-gallery-item .lazy-image img {
      padding: {{ section.settings.gallery_padding }}% !important;
    }
    {%- if section.settings.gallery_background != 'rgba(0,0,0,0)' -%}
      #product-{{ section.id }} .product-gallery-item .lazy-image--fit {
        background-color: {{ section.settings.gallery_background }};
      }
    {%- endif -%}
    {%- if section.settings.gallery_border != 'rgba(0,0,0,0)' -%}
      #product-{{ section.id }} .product-gallery-item img,
      #product-{{ section.id }} .product-gallery-item iframe,
      #product-{{ section.id }} .product-gallery-item video {
        border: 1px solid {{ section.settings.gallery_border }};
      }
    {%- endif -%}

    .thumbnail-bg-color {
      background-color: #f6f6f6;
      position: absolute;
      top: 0;
      height: 100%;
      width: 100%;
      border-radius: 8px;
    }
    .no-touchevents .product-gallery-item__zoom:hover,
    .product-gallery-item__zoom{
      background-color: #f6f6f6 !important
    }
    .thumbnail-image {
      mix-blend-mode: darken;
    }
    .product-gallery__thumbnails .thumbnail.active,
    .no-touchevents .product-gallery__thumbnails .thumbnail:hover{
      border-radius: 9px;
    }
  {% endstyle %}

  <!-- Gallery image hari -->
  {%- if product.media.size > 1 -%}
    <style>
      @media(max-width:768px){
        .gallery_position{position:relative;}
      }
      .arrow-key{
        display: flex; width: 32px; height: 32px; align-items: center; justify-content: center; position: absolute; top: 50%; margin-top:-16px;
        z-index: 3; background: #fff; border-radius: 50%; box-shadow:0 0.0625rem 0.125rem 0.0625rem #00000026; cursor:pointer;
      }
      .arrow-key.disable{opacity:0.5; pointer-events:none;}
      .arrow-key.next{right:12px;}
      .arrow-key.prev{left:12px; transform:rotate(180deg)}
      .css-slider-navigation-container {
        display: none !important;
      }
    </style>

    <a class="arrow-key prev">
      {% render 'product-gallery-arrow' %}
    </a>
    <a class="arrow-key next">
      {% render 'product-gallery-arrow' %}
    </a>

    <script>
      function setupThumbnailNavigation() {
        var _thumb = $(".product-gallery__thumbnails-holder").find(".thumbnail");
        var _thumbLength = _thumb.length;

        function updateButtons() {
          var _activeIndex = $(".product-gallery__thumbnails-holder").find(".thumbnail.active").index();

          if (_activeIndex === 0) {
            $(".arrow-key.prev").addClass("disable");
          } else {
            $(".arrow-key.prev").removeClass("disable");
          }

          if (_activeIndex === (_thumbLength - 1)) {
            $(".arrow-key.next").addClass("disable");
          } else {
            $(".arrow-key.next").removeClass("disable");
          }
        }

        function moveToNextSlide() {
          var _active = $(".product-gallery__thumbnails-holder").find(".thumbnail.active");
          var _next = _active.next(".thumbnail");

          if (_next.length) {
            _active.removeClass("active");
            _next.addClass("active");
            _next.trigger("click");
          }

          updateButtons();
        }

        function moveToPrevSlide() {
          var _active = $(".product-gallery__thumbnails-holder").find(".thumbnail.active");
          var _prev = _active.prev(".thumbnail");

          if (_prev.length) {
            _active.removeClass("active");
            _prev.addClass("active");
            _prev.trigger("click");
          }

          updateButtons();
        }
        updateButtons();

        {% if product.template_suffix contains 'multiupload' %}
        {% else %}
          $(".arrow-key.next").off("click").on("click", function () {
            moveToNextSlide();
          });

          $(".arrow-key.prev").off("click").on("click", function () {
            moveToPrevSlide();
          });
        {% endif %}
      }
      $(function(){
        setupThumbnailNavigation();
      });
      {%  if product.template_suffix == "multiupload_bysizepopular" or  product.template_suffix == "multiupload_vividpopular" %}
            $( document )
        .on(`click`, `.product-gallery.product-gallery--slider .arrow-key.prev`, function( e ) {
          try {
            e.stopImmediatePropagation();
            $( `.css-slider-navigation-container .css-slider-button.css-slider-prev` ).click();
            setTimeout(() => {
              const activeSlideNo = $( `css-slider .css-slider-container .product-gallery-item.css-slide.css-slide-active` ).attr( `data-index` );
              console.log ( 'activeSlideNo', activeSlideNo );
            }, 500);
          } catch ( err ) {
            console.log( `ERROR .product-gallery.product-gallery--slider .arrow-key.prev`, err.message );
          }
        })
        .on(`click`, `.product-gallery.product-gallery--slider .arrow-key.next`, function( e ) {
          try {
            e.stopImmediatePropagation();
            $( `.css-slider-navigation-container .css-slider-button.css-slider-next` ).click();
            setTimeout(() => {
              const activeSlideNo = $( `css-slider .css-slider-container .product-gallery-item.css-slide.css-slide-active` ).attr( `data-index` );
              console.log ( 'activeSlideNo', activeSlideNo );
              $( `.product-gallery.product-gallery--slider .product-gallery__thumbnails .thumbnail[data-index]` ).removeClass( `active` );
              $( `.product-gallery.product-gallery--slider .product-gallery__thumbnails .thumbnail[data-index="${ activeSlideNo }"]` )
                .addClass( `active` )
                .focus()
                .find( `img` )
                .focus();
            }, 500);
          } catch ( err ) {
            console.log( `ERROR .product-gallery.product-gallery--slider .arrow-key.next`, err.message );
          }
        })
         .on(`click`, `.product-gallery.product-gallery--slider .product-gallery__thumbnails .thumbnail[data-index]`, function( e ) {
    try {
      // If this click came from our script (tab switch), skip our custom logic
      if ( suppressThumbClickHandler ) {
        suppressThumbClickHandler = false;
        return;
      }

      e.stopImmediatePropagation();

      const slideNo = $( this ).attr( `data-index` );
      console.log ( 'slideNo', slideNo );

      $( `.css-slider-dot-navigation .css-slider-dot[data-index="${ slideNo }"]` ).click();

      $( `.product-gallery.product-gallery--slider .product-gallery__thumbnails .thumbnail[data-index]` ).removeClass( `active` );
      $( this ).addClass( `active` );
    } catch ( err ) {
      console.log( `ERROR .product-gallery.product-gallery--slider .product-gallery__thumbnails .thumbnail[data-index]`, err.message );
    }
  })
        ;
      {% elsif product.template_suffix contains 'multiupload' %}
        $( document )
        .on(`click`, `.product-gallery.product-gallery--slider .arrow-key.prev`, function( e ) {
          try {
            e.stopImmediatePropagation();
            $( `.css-slider-navigation-container .css-slider-button.css-slider-prev` ).click();
            setTimeout(() => {
              $(`.product-gallery.product-gallery--slider .arrow-key.next`).removeClass("disable");
              const activeSlideNo = $( `css-slider .css-slider-container .product-gallery-item.css-slide.css-slide-active` ).attr( `data-index` );
              console.log ( 'activeSlideNo', activeSlideNo );
              if(activeSlideNo > 0){
                $(`.product-gallery.product-gallery--slider .arrow-key.prev`).removeClass("disable");
              }else{
                $(`.product-gallery.product-gallery--slider .arrow-key.prev`).addClass("disable");
              }
            }, 500);
          } catch ( err ) {
            console.log( `ERROR .product-gallery.product-gallery--slider .arrow-key.prev`, err.message );
          }
        })
        .on(`click`, `.product-gallery.product-gallery--slider .arrow-key.next`, function( e ) {
          try {
            e.stopImmediatePropagation();
            $( `.css-slider-navigation-container .css-slider-button.css-slider-next` ).click();
            setTimeout(() => {
              const activeSlideNo = $( `css-slider .css-slider-container .product-gallery-item.css-slide.css-slide-active` ).attr( `data-index` );
              console.log ( 'activeSlideNo', activeSlideNo );
              if(activeSlideNo > 0){
                $(`.product-gallery.product-gallery--slider .arrow-key.prev`).removeClass("disable");
              }
              $( `.product-gallery.product-gallery--slider .product-gallery__thumbnails .thumbnail[data-index]` ).removeClass( `active` );
              $( `.product-gallery.product-gallery--slider .product-gallery__thumbnails .thumbnail[data-index="${ activeSlideNo }"]` )
                .addClass( `active` )
                .focus()
                .find( `img` )
                .focus();
            }, 500);
          } catch ( err ) {
            console.log( `ERROR .product-gallery.product-gallery--slider .arrow-key.next`, err.message );
          }
        })
        .on(`click`, `.product-gallery.product-gallery--slider .product-gallery__thumbnails .thumbnail[data-index]`, function( e ) {
          try {
            e.stopImmediatePropagation();
            const slideNo = $( this ).attr( `data-index` );
            console.log ( 'slideNo', slideNo );
            $( `.css-slider-dot-navigation .css-slider-dot[data-index="${ slideNo }"]` ).click();
            $( `.product-gallery.product-gallery--slider .product-gallery__thumbnails .thumbnail[data-index]` ).removeClass( `active` );
            $( this ).addClass( `active` );
          } catch ( err ) {
            console.log( `ERROR .product-gallery.product-gallery--slider .product-gallery__thumbnails .thumbnail[data-index]`, err.message );
          }
        })
        ;
      {% endif %}
    </script>
  {% endif %}
  <!-- ./Gallery image hari -->
  {%- if product.media.size > 1 -%}
    <css-slider
      data-options='
        {
          "selector": ".product-gallery-item",
          "autoHeight": false,
          {%- if section.settings.gallery_layout contains 'scroll' -%}
            "watchCSS": true,
          {%- endif -%}
          {%- if section.settings.show_thumbnails -%}
            {% if product.template_suffix contains 'multiupload' %}
              "thumbnails": true,
              "navigation": true,
            {% else %}
              "thumbnails": false,
              "navigation": false,
            {% endif %}
          {%- else -%}
            "navigationDOM": "<span class=\"css-slider-button css-slider-prev\" style=\"display:none\"><svg fill=\"none\" height=\"11\" viewBox=\"0 0 6 11\" width=\"6\" xmlns=\"http://www.w3.org/2000/svg\"><path clip-rule=\"evenodd\" d=\"m4.32845 10.0708-4.18198-4.18194c-.195261-.19526-.195261-.51185 0-.70711l4.18198-4.181979c.19527-.195262.51185-.195262.70711 0 .19526.195259.19526.511849 0 .707109l-3.32843 3.32842s-.70713.4647-.00002 1l3.32845 3.32843c.19526.19526.19526.51185 0 .70707-.19526.1953-.51185.1953-.70711 0z\" fill=\"#000\" fill-rule=\"evenodd\"/></svg></span><span class=\"css-slider-button css-slider-next\" style=\"display:none\"><svg fill=\"none\" height=\"11\" viewBox=\"0 0 6 11\" width=\"6\" xmlns=\"http://www.w3.org/2000/svg\"><path clip-rule=\"evenodd\" d=\"m.853555.999962 4.181985 4.181978c.19526.19526.19526.51185 0 .70711l-4.181983 4.18195c-.195263.1953-.511845.1953-.707108 0-.1952631-.19523-.1952632-.51181 0-.70708l3.328431-3.32842s.70713-.4647.00002-1l-3.328453-3.32843c-.1952626-.19526-.1952627-.51185 0-.707108.195263-.195262.511845-.195262.707108 0z\" fill=\"#000\" fill-rule=\"evenodd\"/></svg></span>",
            "thumbnailsDOM": "<div class=\"css-slider-dot-navigation\" style=\"display:none;--size:{{ product.media.size }}\"></div>",
          {%- endif -%}
          "listenScroll": false
        }
      '
      class="css-slider--bottom-navigation element--border-radius"
    >
  {%- endif -%}

  <div
    class="grid {% if section.settings.gallery_layout contains 'slider' %} grid--slider {% else %} grid--layout {% endif %} {{ gallery_class }} lap--grid--slider grid--gap-small"
    style="--mobile-media-width: {{ section.settings.gallery_mobile_width }}%"
  >
    {%- if product.media.size == 0 -%}
      <div class="product-gallery-item" style="padding-top: 100%">
        {%- render 'lazy-svg',
          image: 'product-1',
          ratio: section.settings.gallery_aspect_ratio,
          class: 'svg-placeholder svg-placeholder--background'
        %}
      </div>
    {%- else -%}
      {%- liquid
        assign product_media = product.media
        assign variant_media = product.variants | map: 'featured_media'
        if hideVariantImages
          for media in product.media
            assign is_variant_media = variant_media | has: 'id', media.id
            if is_variant_media
              assign product_media = product_media | reject: 'id', media.id
            endif
          endfor
        endif

        assign forLoopIndex_main = 0
        for media in product_media
          render 'product-media', hoverimg:hoverimg, media: media, enable_zoom: section.settings.enable_zoom, loop: section.settings.enable_video_looping, index: forLoopIndex_main, aspect_ratio: section.settings.gallery_aspect_ratio, fit: section.settings.gallery_fit, layout: section.settings.gallery_layout, desktop_width: section.settings.gallery_desktop_width, mobile_width: section.settings.gallery_mobile_width
          assign forLoopIndex_main = forLoopIndex_main | plus: 1
          if media.media_type == 'external_video' or media.media_type == 'video'
            assign video_script = true
            echo 'component-video.css' | asset_url | stylesheet_tag
          endif
        endfor

        if hideVariantImages
          assign forLoopRest = forLoopIndex_main
          for media in variant_media
            render 'product-media', act: 'hidden prodMainMedia', media: media, enable_zoom: section.settings.enable_zoom, loop: section.settings.enable_video_looping, index: forLoopRest, aspect_ratio: section.settings.gallery_aspect_ratio, fit: section.settings.gallery_fit, layout: section.settings.gallery_layout, desktop_width: section.settings.gallery_desktop_width, mobile_width: section.settings.gallery_mobile_width
            assign forLoopRest = forLoopRest | plus: 1
            if media.media_type == 'external_video' or media.media_type == 'video'
              assign video_script = true
              echo 'component-video.css' | asset_url | stylesheet_tag
            endif
          endfor
        endif
      -%}
    {%- endif -%}
  </div>

  {%- if product.media.size > 1 -%}</css-slider>{%- endif -%}
</div>  
  {%- if section.settings.show_thumbnails and product.media.size > 1 -%}
    <div
      class="grt-thumbnails product-gallery__thumbnails {% if section.settings.gallery_style contains 'scroll' %} hide portable-show {% endif %}"
      aria-hidden="true"
      style="--border-radius: {{ section.settings.border_radius | at_most: 5 }}px"
    >
      <div class="product-gallery__thumbnails-holder">
        {%- assign forloopThumb = 0 -%}
        {%- for media in product_media -%}
          <button
            data-media-type="{{ media.media_type }}"
            class="thumbnail element--border-radius"
            data-index="{{ forloopThumb }}"
            {% if section.settings.show_thumbnails %}
              tabindex="0"
            {% endif %}
            data-thumb-id="{{ media.id }}"
          >
            {%- render 'lazy-image-small',
              image: media.preview_image,
              aspect_ratio: settings.cart_image_ratio,
              fit: settings.cart_image_fit,
              class: 'thumbnail__image'
            -%}
            {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
              <span class="thumbnail__badge grt-video-thumb">
                <img src="//ninja-transfers-cdn.imgix.net/play_button.png?auto=format,compress&amp;v=1745436450" class="video-play-icon" alt="video play">
                {% comment %} {%- render 'theme-symbols', icon: 'badge-video-thumbnail' -%} {% endcomment %}
              </span>
            {%- elsif media.media_type == 'model' -%}
              <span class="thumbnail__badge">{%- render 'theme-symbols', icon: 'badge-model-thumbnail' -%}</span>
            {%- endif -%}
          </button>
          {%- assign forloopThumb = forloopThumb | plus: 1 -%}
        {%- endfor -%}

        {% if hideVariantImages %}
          {%- assign forloopRestThumb = forloopThumb -%}
          {%- for media in variant_media -%}
            <button
              class="thumbnail element--border-radius {% if showThumbImg == false %} hidden prodThumbMedia {% endif %}"
              data-index="{{ forloopRestThumb }}"
              {% if section.settings.show_thumbnails %}
                tabindex="0"
              {% endif %}
              data-thumb-id="{{ media.id }}"
            >
              {%- render 'lazy-image-small',
                image: media.preview_image,
                aspect_ratio: settings.cart_image_ratio,
                fit: settings.cart_image_fit,
                class: 'thumbnail__image'
              -%}
              {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
                <span class="thumbnail__badge">{%- render 'theme-symbols', icon: 'badge-video-thumbnail' -%}</span>
              {%- elsif media.media_type == 'model' -%}
                <span class="thumbnail__badge">{%- render 'theme-symbols', icon: 'badge-model-thumbnail' -%}</span>
              {%- endif -%}
            </button>
            {%- assign forloopRestThumb = forloopRestThumb | plus: 1 -%}
          {%- endfor -%}
        {% endif %}
      </div>
    </div>
  {%- endif -%}

  {%- assign first_3d_model = product.media | where: 'media_type', 'model' | first -%}

  {%- if first_3d_model -%}
    <div class="fullwidth text-align--center">
      <button
        title="{{ 'products.page.view_in_space_label' | t }}"
        class="button button--small button--icon button--outline product-gallery__view-in-space"
        data-shopify-xr
        data-shopify-first-model3d-id="{{ first_3d_model.id }}"
        data-shopify-model3d-id="{{ first_3d_model.id }}"
        data-shopify-title="{{ product.title | escape }}"
        data-shopify-xr-hidden
      >
        <span aria-hidden="true" class="button__icon">{%- render 'theme-symbols', icon: 'model-button' -%}</span>
        <span class="product-gallery__view-in-space-text">{{ 'products.page.view_in_space' | t }}</span>
      </button>

      <link
        id="ModelViewerStyle"
        rel="stylesheet"
        href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css"
        media="print"
        onload="this.media='all'"
      >
      <script src="{{ 'component-product-model.js' | asset_url }}" defer></script>
    </div>
  {%- endif -%}
  </article>

</div>
{% if product.template_suffix contains "dtf-by-size" or product.template_suffix contains 'by-size-2' or product.template_suffix contains 'by-size-test' or section.settings.enableUploadedImgPreview %}
  <script>document.body.classList.add( `is-dtf-page` );</script>
  <style>
    .dtf_imgix_images{
      display:none;
    }
    .dtf_imgix_images img{
      max-width:100%;
      margin-bottom: -6px;
    }
    .dtf_body_image{
      display:flex;
      flex-wrap:wrap;
      position: relative;
    }
    .dtf_body_image::after {
      position: absolute;
      content: "";
      top: 0;
      right: 0;
      width: 1px;
      height: 100%;
      background-color: #efefef;
    }
    .dtf_body_image > *{
      flex:0 0 33.33%;
      position:relative;
    }
    .watermark_image{
      position: absolute;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      z-index:1;
      opacity:0;
    }
    {% if product.template_suffix == "dtf-by-size" %}
      ._first .watermark_image {
        top: 69px;
      }
      ._fifth .watermark_image{
        top: 72px;
      }
      ._first .watermark_image img,
      ._fifth .watermark_image img{
        max-width: 55px;
        max-height: 100px;
      }
      ._fifth .watermark_image img{
        max-height: 60px;
      }

      ._second .watermark_image{
        top: 69px;
        height: 61px;
        padding-left: 6px;
      }
      ._second .watermark_image img{
        max-height: 30px;
        max-width: 30px;
      }

      ._third .watermark_image{
        top: 76px;
      }
      ._third .watermark_image img{
        max-width: 17.5px;
        margin-left: 41px;
        max-height:30px;
      }

      ._forth .watermark_image{
        top: 89px;
      }
      ._forth .watermark_image img{
        max-width: 55px;
        max-height:65px;
      }

      ._sixth .watermark_image{
        top: 94px;
      }
      ._sixth .watermark_image img{
        max-width: 35px;
        max-height: 50px;
      }

      @media (max-width:1280px){
        ._first .watermark_image{
          top: 72px;
        }
        ._second .watermark_image{
          top: 75px;
        }
        ._third .watermark_image{
          top: 80px;
        }
        ._forth .watermark_image{
          top: 81px;
        }
      }
      @media (max-width:1210px){
        ._first .watermark_image img, ._fifth .watermark_image img{
          max-width:44px;
        }
        ._second .watermark_image img{
          max-height: 24px;
        }
        ._second .watermark_image{
          top: 68px;
        }
        ._third .watermark_image{
          top: 78px;
        }
        ._third .watermark_image img{
          margin-left: 46px;
          max-width: 13.5px;
        }
        ._forth .watermark_image{
          top: 93px;
        }
        ._forth .watermark_image img{
          max-width: 37px;
        }
        ._sixth .watermark_image{
          top: 94px;
        }
        ._sixth .watermark_image img{
          max-width: 30px;
        }
      }
      @media (max-width:1080px){
        ._first .watermark_image{
          top: 64px;
