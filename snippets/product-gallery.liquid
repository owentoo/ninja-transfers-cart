    <div class="video-box video-wrapper" data-v="{{ videoFile }}">
      <div class="img-container image-with-text-{{ section.id }}-videobtnelement" style="background-image:url('{{ section.settings.poster_image | image_url }}')">
        {% if section.settings.video_play_icon %}
          <a href="javascript:void(0)" class=""><img src="{{ section.settings.video_play_icon | image_url }}" class="video-play-icon" alt="video play" /></a>
        {% endif %}
      </div>
