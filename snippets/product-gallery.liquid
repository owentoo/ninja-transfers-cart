        Your browser does not support the video tag.
      </video>
    </div>
      <script>
          
        function ImageWithTextInit() {
            let btn = document.querySelector('.image-with-text-{{ section.id }}-videobtnelement');
            if(btn) {
              btn.addEventListener('click', () => {
                btn.closest(".video-wrapper")?.classList.add("visible");
                document.querySelector(".image-with-text-{{ section.id }}-videoelement").play()
              });
            }
        }
      
        document.addEventListener('DOMContentLoaded', ImageWithTextInit);
        
        if (Shopify.designMode) {
           document.addEventListener('shopify:section:unload', ImageWithTextInit);
           document.addEventListener('shopify:section:load', ImageWithTextInit);
        }
      </script>
  {%- endif -%}    
{%- endif -%}
<script>
  $(function(){
    if($(window).outerWidth() > 768){
      var videoURL = '{{videoURL}}</iframe>';
      $(".videoURL").append(videoURL);
      console.log(videoURL, "videoURL")
    }

    $(".product-gallery__thumbnails .thumbnail").click(function(){
      var _type = $(this).attr("data-media-type");
      if(_type == "video"){
        setTimeout(function(){
          $(".product-gallery-item.css-slide-active").find(".video-popup__play").trigger("click");
        },1000)
      }
    })
  })
  $( document )
  .on(`click`, `video-popup .video-popup__container .video-popup__play`, function( e ) {
    try {
      e.stopImmediatePropagation();
      const getVideoHTML = $( this ).closest( `video-popup` ).find( `template` ).html();
      const isIframeAvailable = $( this ).closest( `video-popup` ).find( `iframe` ).length;

      if ( isIframeAvailable == 0 ) {
        $( this ).closest( `video-popup` )
          .find( `.video-popup__container` )
          .append( `${ getVideoHTML }` );
      }
    } catch ( err ) {
      console.log( `ERROR video-popup .video-popup__container .video-popup__play`, err.message );
    }
  })
  ;
</script>
{% if section.settings.gallery_position_vertical %}
<script>
document.addEventListener("DOMContentLoaded", function () {
  if (!window.matchMedia("(min-width: 768px)").matches) return;
  var mainWrap = document.querySelector(".grt-main-image");
  var thumbs = document.querySelector(".grt-thumbnails");
  if (!mainWrap || !thumbs) return;

  function setThumbHeight() {
    var h = Math.round(mainWrap.getBoundingClientRect().height || 0);
    if (h > 0) thumbs.style.height = h + "px";
  }

  setThumbHeight();
  window.addEventListener("load", setThumbHeight);

  if ("ResizeObserver" in window) {
    var ro = new ResizeObserver(function () { setThumbHeight(); });
    ro.observe(mainWrap);
  }

  var t;
  window.addEventListener("resize", function () {
    clearTimeout(t);
    t = setTimeout(setThumbHeight, 80);
  });

  var img = mainWrap.querySelector("img");
  if (img) {
    if (!img.complete) img.addEventListener("load", setThumbHeight, { once: true });
  }
});
</script>
{% endif %}