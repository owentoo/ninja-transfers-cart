        } catch ( err ) {
          console.log( `ERROR placeSpangleData()`, err.message );
        }
      }

      function getRemainingColors(allColors, selectedColors) {
        return allColors.filter(color => !selectedColors.includes(color.colorName));
      }
      function removeColorsItem( selectedColorItem ) {
        try {
          const selectedColorsArr = [];
          $( `spangle-colors .spangle__colorOption` ).each(function(i) {
            let color_ = $( this ).find( `.spangle__dropdown .spangle__dropbtn > span` ).text();
            if ( typeof color_ !== 'undefined' && color_ ) {
