    <script>
      const downloadTemplateHTML = `{{ downloadTemplateHTML }}`;
      let keyUpTimeOutGangsheet = null;
      $( document )
      .ready(function() {
        setTimeout(() => {
          updatedGangSheetPrice();
        }, 1000);
      })
      .on(`click`, `customoptions-gangsheet .gangSheet__item:not(.autoSizeSelected) .gangSheet__dropdown`, function( e ) {
        try {
          e.stopImmediatePropagation();
          $( `customoptions-gangsheet .gangSheet__item` ).removeClass( `selectedTier` );
          $( this ).closest( `.gangSheet__item` ).addClass( `selectedTier` );
          $( this ).addClass( `open` );
        } catch ( err ) {
          console.log( `ERROR customoptions-gangsheet .gangSheet__item .gangSheet__dropdown`, err.message );
        }
      })
      .on(`mouseleave`, `customoptions-gangsheet .gangSheet__item:not(.autoSizeSelected) .gangSheet__dropdown`, function( e ) {
        try {
          e.stopImmediatePropagation();
          $( this ).removeClass( `open` );
        } catch ( err ) {
          console.log( `ERROR customoptions-gangsheet .gangSheet__item .gangSheet__dropdown`, err.message );
        }
      })
      .on(`click`, `customoptions-gangsheet .gangSheet__item:not(.autoSizeSelected) .gangSheet__dropdown .gangSheet__dropdown-content span`, function( e ) {
        try {
          e.stopImmediatePropagation();
          $( `customoptions-gangsheet .gangSheet__item` ).removeClass( `selectedTier` );
          $( this ).closest( `.gangSheet__item` ).addClass( `selectedTier` );
          const getVal = $( this ).attr( `val` );

          if ( typeof getVal !== 'undefined' && getVal ) {
            $( this ).closest( `.gangSheet__dropdown-content` ).find( `span` ).removeClass( `selected` );
            $( this ).closest( `.gangSheet__dropdown` ).removeClass( `open` ).find( `.gangSheet__dropbtn span` ).text( getVal );
            $( this ).addClass( `selected` );
            $( `product-variants .product-variant[op="1"] .product-variant__input[value="${ getVal }"]` ).click();
          }
        } catch ( err ) {
          console.log( `ERROR spangle-colors .gangSheet__dropdown .gangSheet__dropdown-content span`, err.message );
        }
      })
      .on(`keyup`, `customoptions-gangsheet .gangSheet__item__qty [name="quantity"]`, function( e ) {
        try {
          e.stopImmediatePropagation();
          clearTimeout( keyUpTimeOutGangsheet );
          keyUpTimeOutGangsheet = setTimeout(() => {
            $( `customoptions-gangsheet .gangSheet__item` ).removeClass( `selectedTier` );
            $( this ).closest( `.gangSheet__item` ).addClass( `selectedTier` );
            const getVal = $( this ).val() * 1;
            const minQty = $( this ).attr( `min` ) * 1;
            var pattern = /^[0-9]+$/; // Pattern: only numbers
            if ( pattern.test( getVal ) ) {
              if ( getVal < minQty ) {
                $( this ).val( minQty ).addClass( `minErr` );
                updatedGangSheetPrice();
              } else {
                updatedGangSheetPrice();
              }
            }
            setTimeout(() => {
              $( this ).removeClass( `minErr` );
            }, 1500);
          }, 500);
        } catch ( err ) {
          console.log( `ERROR customoptions-gangsheet .gangSheet__item__qty [name="quantity"]`, err.message );
        }
      })
      .on(`focus`, `customoptions-gangsheet .gangSheet__item__qty [name="quantity"]`, function( e ) {
        try {
          e.stopImmediatePropagation();
          $( this ).select();
        } catch ( err ) {
          console.log( `ERROR customoptions-gangsheet .gangSheet__item__qty [name="quantity"]`, err.message );
        }
      })
      .on(`change`, `product-variants .product-variant .product-variant__input`, function( e ) {
        try {
          e.stopImmediatePropagation();
          setTimeout(() => {
            updatedGangSheetPrice();
          }, 200);
        } catch ( err ) {
          console.log( `ERROR product-variants .product-variant .product-variant__input`, err.message );
        }
      })
      .on(`click`, `a[download-template]`, function( e ) {
        try {
          e.stopImmediatePropagation();
          $( `body` ).append( downloadTemplateHTML );
        } catch ( err ) {
          console.log( `ERROR a[download-template]`, err.message );
        }
      })
      .on(`click`, `download-template-popup .closePopup`, function( e ) {
        try {
          e.stopImmediatePropagation();
          $( `download-template-popup` ).detach();
        } catch ( err ) {
          console.log( `ERROR download-template-popup .closePopup`, err.message );
        }
      })

      function updatedGangSheetPrice() {
        try {
          const selectedRow = $( `customoptions-gangsheet .gangSheet__item.selectedTier` );
          let makeTitle = $( `product-variants .product-variant[op="1"] .product-variant__input:checked` ).val();
          const is2ndOption = $( `product-variants .product-variant[op="2"]` );
          const is3rdOption = $( `product-variants .product-variant[op="3"]` );
          if ( is2ndOption.length > 0 ) {
            const optionSelected = is2ndOption.find( `.product-variant__input:checked` ).val();
            if ( typeof optionSelected !== 'undefined' && optionSelected ) {
              makeTitle = `${ makeTitle } / ${ optionSelected }`;
            }
          }
          if ( is3rdOption.length > 0 ) {
            const optionSelected = is3rdOption.find( `.product-variant__input:checked` ).val();
            if ( typeof optionSelected !== 'undefined' && optionSelected ) {
              makeTitle = `${ makeTitle } / ${ optionSelected }`;
            }
          }

          const currentObject = findObjectByKey( allVariants, `title`, makeTitle );
          // console.clear();
          if ( typeof currentObject !== 'undefined' && currentObject ) {
            if ( typeof currentObject.compare_price !== 'undefined' && currentObject.compare_price ) {
              selectedRow.attr( `compare-price`, currentObject.compare_price );
            }else{
              selectedRow.attr( `compare-price`, currentObject.price );
            }
            if ( typeof currentObject.price !== 'undefined' && currentObject.price ) {
              selectedRow.attr( `price`, currentObject.price );
            }
          }

          let getDiscountPercent = $( `product-variants .product-variant[op="1"] .product-variant__input:checked` ).closest( `.product-variant__item` ).find( `.saving-info` ).text();
          if ( typeof getDiscountPercent !== 'undefined' && getDiscountPercent ) {
            getDiscountPercent = getDiscountPercent.trim();
            selectedRow.attr( `off`, getDiscountPercent );
          } else {
            selectedRow.attr( `off`, '0%' );
          }

          calculateSelectedRow( selectedRow );
          console.log ( 'currentObject', currentObject ,typeof vivid_price_gangsheet);
          if(typeof vivid_price_gangsheet == "function"){
            vivid_price_gangsheet(currentObject);
          }

        } catch ( err ) {
          console.log( `ERROR updatedGangSheetPrice()`, err.message );
        }
      }

      function calculateSelectedRow( selectedRow ) {
        try {
          let selectedValue = $( `product-variants .product-variant[op="1"] .product-variant__input:checked` ).val();
          const price = selectedRow.attr( `price` ) * 1;
          let compare_price = selectedRow.attr( `compare-price` );
          if ( typeof compare_price !== 'undefined' && compare_price ) {
            compare_price = compare_price * 1;
          } else {
            compare_price = 0;
          }
          let offPercentage = selectedRow.attr( `off` );
          const qty = selectedRow.find( `.gangSheet__item__qty input[name="quantity"]` ).val() * 1;
          if ( typeof offPercentage !== 'undefined' && offPercentage && offPercentage.includes( `%` ) ){
            let getPercent = offPercentage.split( `%` )[0];
            offPercentage = getPercent * 1;
          } else {
            offPercentage = 0;
          }
          console.log ( 'price', price );
          if ( offPercentage == 0 ) {
            selectedRow.find( `.gangSheet__item__action .gangSheet__item__action_discounted` ).text( `` );
            selectedRow.find( `.gangSheet__item__price .gangSheet__item__price_original, .gangSheet__item__total .gangSheet__item__total_original` ).addClass( `hidden` );
          } else {
            selectedRow.find( `.gangSheet__item__action .gangSheet__item__action_discounted` ).text( `${ offPercentage }% off` );
            selectedRow.find( `.gangSheet__item__price .gangSheet__item__price_original, .gangSheet__item__total .gangSheet__item__total_original` ).removeClass( `hidden` );
          }

          selectedRow.find( `.gangSheet__item__price .gangSheet__item__price_original` ).text( `$${ price.toFixed( 2 ) }` );
          selectedRow.find( `.gangSheet__item__total .gangSheet__item__total_original` ).text( `$${ ( price * qty ).toFixed( 2 ) }` );

          let unitDiscountedPrice;
          if ( typeof compare_price !== 'undefined' && compare_price ) {
            unitDiscountedPrice = compare_price;

            selectedRow.find( `.gangSheet__item__price .gangSheet__item__price_discounted` ).html( `$${ price.toFixed( 2 ) }<span>ea.</span>` );
            selectedRow.find( `.gangSheet__item__total .gangSheet__item__total_discounted` ).text( `$${ ( price * qty ).toFixed( 2 ) }` );

            selectedRow.find( `.gangSheet__item__price .gangSheet__item__price_original` ).text( `$${ unitDiscountedPrice.toFixed( 2 ) }` );
            selectedRow.find( `.gangSheet__item__total .gangSheet__item__total_original` ).text( `$${ ( unitDiscountedPrice * qty ).toFixed( 2 ) }` );
          }

          console.log ( 'offPercentage', offPercentage );
          $( `product-form form .product__cart-functions product-quantity .product__quantity` ).val( qty );
          const isQtyEle = $( `product-form form .form__properties [name="quantity"]` );
          if ( isQtyEle.length > 0 ) {
            isQtyEle.val( qty );
          } else {
            isQtyEle.closest( `.form__properties` ).append( `<input type="hidden" name="quantity" value="${ qty }">` );
          }
          console.log ( 'selectedValue', selectedValue );
        } catch ( err ) {
          console.log( `ERROR calculateSelectedRow( selectedRow )`, err.message );
        }
      }
    </script>
{%- endcase -%}

