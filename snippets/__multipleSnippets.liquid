    <script>
      window.productVariants = {{ product.variants | json }};
      function getVariantCost(allVariants, cVariant) {
        // Ensure allVariants is an array
        if (!Array.isArray(allVariants)) {
          throw new Error("allVariants must be an array.");
        }

        // Find the matching variant
        const matchedVariant = allVariants.find(variant => variant.id === cVariant);

        // Check if a matching variant was found
        if (!matchedVariant) {
          throw new Error(`Variant with ID ${cVariant} not found.`);
        }

        // Return the matched variant object
        return matchedVariant;
      }

      function _getPrecutVariant(vrntID,HTMLnode){
        try{
          const variantId = vrntID; // Replace with your specific variant ID
          const productVariants = window.productVariants;

          // Find the target variant
          const targetVariant = productVariants.find(variant => variant.id === parseInt(variantId));

          if (targetVariant) {
            // Get the desired option value (e.g., color)
            const targetColor = targetVariant.option1; // Assuming "option1" is color

            // Find all related variants with the same color
            const relatedVariants = productVariants.filter(variant => variant.option1 === targetColor);

            // Log or display related variants
            console.log("Related Variants:", relatedVariants);

              // Example: Display the related variant IDs on the page
            relatedVariants.forEach(variant => {
              if(vrntID != variant.id){
                $(HTMLnode).val(variant.id);
                $(".widthHeight__block").removeClass("loading");
              }
            });
          } else {
            console.error("Variant not found");
          }
        }catch(err){
          console.log("_getPrecutVariant: ",vrntID,err)
        }
      };

      function _precutPriceUpdate(){
        var _c = $('.widthHeight__block').length - 1;
        _update(_c);
      }

      function _update(no){
        $('.widthHeight__block').removeClass("selected");
        obj = $('.widthHeight__block').eq(no);
        $(obj).addClass("selected");
        const $block = $(obj);
        const $checkbox = $('#precutselected');
        const $hiddenInput = $('form.custom-transfer-form input[name="id"]');
        const variantValue = $checkbox.is(':checked')  ? $block.find('.nodevariant_precut').val()  : $block.find('.nodevariant').val();

        $hiddenInput.val(variantValue);
        setTimeout(function(){
          manageQuantities();
          no--;
          setTimeout(function(){
            if(no >= 0){
              _update(no);
            }
          },200)
        })
      }
    </script>
