 {% if product.template_suffix contains "multiupload" %}
   {%- case contentFor -%}
  {%- when 'toast' -%}
    <!-- {{ contentFor }} START -->
    <div class="toast">
      <div class="toast-content">
        <svg class="fas fa-solid fa-check check" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path d="M9 22l-10-10.598 2.798-2.859 7.149 7.473 13.144-14.016 2.909 2.806z"/></svg>
        <div class="message">
          <span class="text text-1">Added</span>
          <span class="text text-2">Product successfully added to your cart</span>
        </div>
      </div>
      <svg class="fa-solid fa-xmark close" width="24px" height="24px" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6 6L18 18" stroke="#000" stroke-linecap="round"></path><path d="M18 6L6.00001 18" stroke="#000" stroke-linecap="round"></path></svg>
    </div>
    <!-- {{ contentFor }} END -->

  {%- when 'customTabs' -%}
    {% render '__multiuploadSnippets' product: product, section: section, newContentFor: 'bySize__tabs' %}

  {%- when 'uploadArea' -%}
    <!-- {{ contentFor }} START -->
    {%- assign b = block.settings -%}
    {% if b.enableSettings %}
      {% render '__multiuploadSnippets' product: product, section: section, block: block, b: b, newContentFor: 'masterUploader' %}
    {% else %}
            <style>
       
      .upload__info{
        display:flex;
        border-radius:15px;
        align-self:center; 
        margin-bottom:20px; 
        background:#f8fcff;
         width: 95%;
      }
      .upload__info span{
        display:inline-block;
		margin-right:5px;
        color:#479e30; 
        font-weight:800;
      }
      .upload__info {
       padding: 20px 15px; 
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        
      }
      .upload__info  h3{
        color:#000000;
        margin:0 0 8px 0;
        font-weight:700;
        font-size:15px;
      }
      .upload__info  p{
        font-size:14px;
        font-weight:300;
        margin:0;
      }
     </style>    
     
    <!-- {{ contentFor }} START -->
    <div class="file-upload-overlay-1 master-upload">
      <div id="uploadArea" class="upload-area" item-show-on="beforeUpload">
        <div class="upload__info"  >  
           <h3><span>NEW</span> Upload all your files at once!</h3>
           <p>Checkout faster then ever with smooth, simultaneous multiupload file uploads.</p>  
     </div>
        <!-- Header -->
        <div class="upload-area__header" style="display:none;">
          <h4 class="upload-area__title" >Upload your file</h4>
          <p class="upload-area__paragraph" style="display:none;">
            File should be an image
            <strong class="upload-area__tooltip">
              Like
              <span class="upload-area__tooltip-data"></span> <!-- Data Will be Comes From Js -->
            </strong>
          </p>
        </div>
        <!-- End Header -->

        <!-- Drop Zoon -->
        <div id="dropZoon" class="upload-area__drop-zoon drop-zoon">
          <p class="drop-zoon__paragraph"><strong>Drop your file(s) here</strong></p>
           <span class="_or">or</span>
          <button type="button">Upload File(s)</button>
          <span class="drop-zoon__icon" style="display:none;">
            <i class='bx bxs-file-image'></i>
          </span>
          
          {% if customer %}
            <p class="access_old_data"><a href="#" class="purchase_from_previous" data-type="first_upload" >Choose a previous design</a></p>
          {% else %}
            <p class="access_old_data"><a data-link="" href="/customer_authentication/login?return_to={{ product.url | url_encode }}&force=upload" class="basic_link first__upload">Login</a> to see previous designs</p>
          {% endif %}
          <span id="loadingText" class="drop-zoon__loading-text" style="display:none;">Please Wait</span>
          <img src="" alt="Preview Image" data-id="previewImage"  style="display:none;" class="previewImage drop-zoon__preview-image" draggable="false">
          <input type="file" id="fileInput" multiple class="drop-zoon__file-input" multiple accept=".eps,application/postscript,image/png,image/jpeg,image/tiff,application/pdf,image/svg+xml" >
        </div>
      </div>
      <!-- End Upload Area -->
    </div>
    {% endif %}
    <!-- {{ contentFor }} END -->

  {%- when 'aiImageGenerator' -%}
