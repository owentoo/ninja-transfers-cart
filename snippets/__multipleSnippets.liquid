          // console.log ( 'selectedColorsArr', selectedColorsArr );
          const remainingColors = getRemainingColors( allSpangleColors, selectedColorsArr );

          // console.log ( 'remainingColors', remainingColors );

          const selectedValue = $( `spangle-colors .spangle__colorOption[item="${ selectedColorItem }"] .spangle__dropdown-content span.selected` ).attr( `val` );
          $( `spangle-colors .spangle__colorOption[item="${ selectedColorItem }"] .spangle__dropdown-content` ).text( `` );
          remainingColors.forEach((el, i) => {
