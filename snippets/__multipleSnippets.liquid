          console.log( `ERROR spangle-colors .spangle__dropdown`, err.message );
        }
      })
      .on(`click`, `spangle-colors .spangle__dropdown .spangle__dropdown-content span`, function( e ) {
        try {
          e.stopImmediatePropagation();
          const getVal = $( this ).attr( `val` );
          let getColorVal = $( this ).find( `selected-color` ).length;
          let colorVal, imgVal;

          if ( getColorVal > 0 ) {
            colorVal = $( this ).find( `selected-color` ).attr( `style` );
          } else {
            imgVal = $( this ).find( `img` ).attr( `src` );
          }
          if ( typeof getVal !== 'undefined' && getVal ) {
            $( this ).closest( `.spangle__dropdown-content` ).find( `span` ).removeClass( `selected` );
            $( this ).addClass( `selected` );
            if ( typeof imgVal !== 'undefined' && imgVal ) {
              // console.log ( 'imgVal', imgVal );
              $( this ).closest( `.spangle__dropdown` ).find( `.spangle__dropbtn selected-color, .spangle__dropbtn img` ).remove();
              $( this ).closest( `.spangle__dropdown` ).find( `.spangle__dropbtn` ).prepend( `<img src="${ imgVal }">` );
            } else if ( typeof colorVal !== 'undefined' && colorVal ) {
              // console.log ( 'colorVal', colorVal );
              $( this ).closest( `.spangle__dropdown` ).find( `.spangle__dropbtn selected-color, .spangle__dropbtn img` ).remove();
              $( this ).closest( `.spangle__dropdown` ).find( `.spangle__dropbtn` ).prepend( `<selected-color style="${ colorVal }"></selected-color>` );
            }
            $( this ).closest( `.spangle__dropdown` ).removeClass( `open` ).find( `.spangle__dropbtn span` ).text( getVal );
          }
          $( this ).closest( `.spangle__dropdown` ).removeClass( `error pickColor` );
          $( this ).closest( `.spangle__dropdown` ).find( `.spangle__dropbtn > span` ).removeAttr( `pick-color style` );
        } catch ( err ) {
          console.log( `ERROR spangle-colors .spangle__dropdown .spangle__dropdown-content span`, err.message );
        }
      })
      .on(`click`, `.spangle__addAnother .addMoreColor`, function( e ) {
        try {
          e.stopImmediatePropagation();
          const isError = $( `spangle-colors .spangle__colorOption[item="1"] .spangle__dropdown` ).hasClass( `pickColor` );
          if ( isError ) {
            $( `html, body` ).animate({
              scrollTop: $( `spangle-colors .spangle__colorOption[item="1"]` ).offset().top - 100
            }, 1000);
            $( `spangle-colors .spangle__colorOption[item="1"] .spangle__dropdown` ).addClass( `error` );
            return;
          }
          const getHTML = $( this ).closest( `spangle-colors` ).find( `.spangle__colorOption` ).last().clone();
          $( this ).closest( `spangle-colors` ).find( `.spangle__colorOption` ).last().after( getHTML );
          // $( this ).closest( `.spangle__addAnother[a-item="2"]` ).before( getHTML );
          const getItems = $( `spangle-colors .spangle__colorOption` ).length;
          if ( getItems == 3 ) {
            $( this ).closest( `spangle-colors` ).find( `.spangle__addAnother` ).addClass( `hidden` );
          } else if ( getItems == 2 ) {
            $( this ).closest( `spangle-colors` ).find( `.spangle__addAnother[a-item="3"]` ).addClass( `hidden` );
          } else {
            $( this ).closest( `spangle-colors` ).find( `.spangle__addAnother` ).removeClass( `hidden` );
          }
          if ( getItems > 1 ) {
            $( `spangle-colors .spangle__colorOption .spangle__dropdown .optionDel` ).removeClass( `hidden` );
          }

          $( `spangle-colors .spangle__numberOfColors select` ).val( getItems );
          const selectedColorsArr = [];
          $( `spangle-colors .spangle__colorOption` ).each(function(i) {
            $( this ).attr( `item`, `${ i + 1 }` );
            let color_ = $( this ).find( `.spangle__dropdown .spangle__dropbtn > span` ).text();
            if ( typeof color_ !== 'undefined' && color_ ) {
              color_ = color_.trim();
              selectedColorsArr.push( color_ );
            }
          })
          const remainingColors = getRemainingColors( allSpangleColors, selectedColorsArr );

          $( `spangle-colors .spangle__colorOption[item="${ getItems }"] .spangle__dropdown-content` ).text( `` );
          $( `
            spangle-colors .spangle__colorOption[item="${ getItems }"] .spangle__dropbtn > selected-color,
            spangle-colors .spangle__colorOption[item="${ getItems }"] .spangle__dropbtn > img,
            spangle-colors .spangle__colorOption[item="${ getItems }"] .spangle__dropbtn > span
          ` ).remove();
          remainingColors.forEach((el, i) => {
            if ( i == 0 ) {
              if ( el.colorCode_or_img.includes( `#` ) ) {
                $( `spangle-colors .spangle__colorOption[item="${ getItems }"] .spangle__dropbtn` ).prepend( `<selected-color style="background-color: ${ el.colorCode_or_img };"></selected-color><span></span>` );
              } else {
                $( `spangle-colors .spangle__colorOption[item="${ getItems }"] .spangle__dropbtn` ).prepend( `<img src="${ el.colorCode_or_img }"><span></span>` );
              }
              $( `spangle-colors .spangle__colorOption[item="${ getItems }"] .spangle__dropbtn > span` ).text( el.colorName );
              $( `spangle-colors .spangle__colorOption[item="${ getItems }"] .spangle__dropdown-content` ).append( `
                <span class="selected" val="${ el.colorName }">
                  ${ el.colorCode_or_img.includes( `#` ) ? `<selected-color style="background-color: ${ el.colorCode_or_img };">&nbsp;</selected-color>` : `<img src="${ el.colorCode_or_img }">` }
                  ${ el.colorName }
                </span>
              ` );
            } else {
              $( `spangle-colors .spangle__colorOption[item="${ getItems }"] .spangle__dropdown-content` ).append( `
                <span val="${ el.colorName }">
                  ${ el.colorCode_or_img.includes( `#` ) ? `<selected-color style="background-color: ${ el.colorCode_or_img };">&nbsp;</selected-color>` : `<img src="${ el.colorCode_or_img }">` }
                  ${ el.colorName }
                </span>
              ` );
            }
          });
          $( `spangle-colors .spangle__colorOption[item="${ getItems }"] .spangle__dropdown` ).addClass( `open` );
        } catch ( err ) {
          console.log( `ERROR .spangle__addAnother .addMoreColor`, err.message );
        }
      })
      .on(`click`, `spangle-colors .optionDel`, function( e ) {
        try {
          e.stopImmediatePropagation();
          $( this ).closest( `.spangle__colorOption` ).remove();

          $( `spangle-colors .spangle__colorOption` ).each(function(i) {
            $( this ).attr( `item`, `${ i + 1 }` );
          })
          const getItems = $( `spangle-colors .spangle__colorOption` ).length;
          console.log ( 'getItems', getItems );
          if ( getItems == 3 ) {
            $( this ).closest( `spangle-colors` ).find( `.spangle__addAnother` ).addClass( `hidden` );
          } else if ( getItems == 2 ) {
            $( `spangle-colors .spangle__addAnother[a-item="3"]` ).removeClass( `hidden` );
          } else {
            $( `spangle-colors .spangle__addAnother` ).removeClass( `hidden` );
          }

          $( `spangle-colors .spangle__numberOfColors select` ).val( getItems );
          if ( getItems == 1 ) {
            $( `spangle-colors .spangle__colorOption .spangle__dropdown .optionDel` ).addClass( `hidden` );
          }
        } catch ( err ) {
          console.log( `ERROR .optionDel`, err.message );
        }
      })
      ;

