    <script>
      $( document )
      .on(`change`, `.customStickerOption__optionInput`, function( e ) {
        try {
          e.stopImmediatePropagation();
          const getVal = $( this ).val();
          const itemNo = $( this ).closest( `.customStickerOption` ).attr( `item` ) * 1;
          $( this ).closest( `.customStickerOption` ).find( `.customStickerOption__title option-value` ).text( getVal );
          if ( itemNo == 3 ) {
            let getMsg = $( this ).attr( `msg` );
            const borderData = $( this ).closest( `.customStickerOption__option` ).attr( `data-border` );
            if ( typeof borderData !== 'undefined' && borderData && borderData == 'true' ) {
              $( `.customStickerOption[item="4"]` ).removeClass( `hidden` );
            } else if ( typeof borderData !== 'undefined' && borderData && borderData == 'false' ) {
              $( `.customStickerOption[item="4"]` ).addClass( `hidden` );
            }
            if ( typeof getMsg !== 'undefined' && getMsg ) {
              getMsg = `<img src="//ninja-transfers-cdn.imgix.net/info_da70c6e6-1e86-41d3-9035-2bf57d01d406_medium.svg?auto=format,compress&amp;v=1678797665" class="infoIcon infoModal grt-infoicon"> ${ getMsg }`;
            }
            $( this ).closest( `.customStickerOption` ).find( `.customStickerOption__msg` ).html( getMsg );
          } else if ( itemNo == 5 ) {
            const secondOption_of_fifth = $( `#option_5_2` ).val();
            if ( getVal == secondOption_of_fifth ) {
              $( `.customStickerOption[item="3"], .customStickerOption[item="4"]` ).addClass( `hidden` );
              if ( typeof hideFinishOptions !== 'undefined' && hideFinishOptions ) {
                $( `.customStickerOption[item="2"]` ).addClass( `hidden` );
              }
            } else {
              $( `.customStickerOption[item="3"]` ).removeClass( `hidden` );
              const checkBorderStatus = $( `.customStickerOption[item="3"] .customStickerOption__optionInput:checked` ).closest( `.customStickerOption__option` ).attr( `data-border` );
              if ( typeof checkBorderStatus !== 'undefined' && checkBorderStatus == 'true' ) {
                $( `.customStickerOption[item="4"]` ).removeClass( `hidden` );
              } else {
                $( `.customStickerOption[item="4"]` ).addClass( `hidden` );
                if ( typeof hideFinishOptions !== 'undefined' && hideFinishOptions ) {
                  $( `.customStickerOption[item="2"]` ).removeClass( `hidden` );
                }
              }
            }
          }
        } catch ( err ) {
          console.log( `ERROR .customStickerOption__optionInput`, err.message );
        }
      })
      .on(`mouseover`, `.customStickerOption__optionImg`, function( e ) {
        try {
          e.stopImmediatePropagation();
          const getVal = $( this ).closest( `.customStickerOption__option` ).find( `.customStickerOption__optionInput` ).val();
          $( this ).closest( `.customStickerOption` ).find( `.customStickerOption__title option-value` ).text( getVal );
        } catch ( err ) {
          console.log( `ERROR .customStickerOption__optionImg`, err.message );
        }
      })
      .on(`mouseout`, `.customStickerOption__optionImg`, function(e) {
        try {
          e.stopImmediatePropagation();
          const isChecked = $( this ).closest( `.customStickerOption` ).find( `.customStickerOption__optionInput` ).is( `:checked` );
          if ( isChecked ) {
            const selectedVal = $( this ).closest( `.customStickerOption` ).find( `.customStickerOption__optionInput:checked` ).val();
            $( this ).closest(`.customStickerOption`).find(`.customStickerOption__title option-value`).text( selectedVal );
          }
        } catch (err) {
          console.log(`ERROR .customStickerOption__optionImg (mouseout)`, err.message);
        }
      })
      ;
    </script>

