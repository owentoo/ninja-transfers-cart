    // ---------------------------
    // Width calc (scoped)
    // ---------------------------
    {% if request.page_type == 'cart' %}
      var __cartUpsellServerVisible = {{ show_cart_upsell | json }};

      function shouldShowCartUpsell() {
        var cartHolderEl = document.querySelector("#AjaxCartForm .cart-holder");
        if (cartHolderEl) {
          var cartItemsCount = parseInt(cartHolderEl.getAttribute("data-items"), 10);
          if (!isNaN(cartItemsCount)) return cartItemsCount > 0;
        }
        return __cartUpsellServerVisible;
      }

      function syncCartUpsellVisibility() {
        var $root = $("#grt-upsell-{{ uid }}");
        if (!$root.length) return false;
        var $box = $root.find(".grt-product-upsell").first();
        if (!$box.length) return false;

        var shouldShow = shouldShowCartUpsell();
        console.log("shouldShowCartUpsell: ", shouldShow);
        if (shouldShow) {
          $box.addClass("active_productupsell")//.css("display", "block");
        } else {
          $box.removeClass("active_productupsell").css("display", "none");
        }
        return shouldShow;
      }
    {% else %}
      function syncCartUpsellVisibility() {
        return true;
      }
    {% endif %}

    function setWidth() {
      var $root = $("#grt-upsell-{{ uid }}");
      if (!$root.length || !$root[0]) return;
      if (!syncCartUpsellVisibility()) return;
      var rootEl = $root[0];
      // 1) pick the "real" container (best → fallback)
      var parent =
      rootEl.closest(".product-text") ||
      rootEl.parentElement;

      var $box = $root.find(".grt-product-upsell").first();
      if (!parent) return;
      var containerWidth = parent.getBoundingClientRect().width;
      console.log(parent," =================parent: ",containerWidth,$box.css("display"));
      if ($box.length) $box.css("display", "block");
      $root[0].style.setProperty("--grt-container-w", containerWidth + "px");
      
      enable_swiper("#grt-upsell-{{ uid }} .grt-swiper");
      grt____upsell();
      // Center arrows on image height, not full card height
      setTimeout(function() {
        var imgH = $root.find(".grt-product-card__main-image").first().outerHeight();
        if (imgH) {
          $root.find(".grt-upsell-prev, .grt-upsell-next").css("top", Math.round(imgH / 2) + "px");
        }
      }, 100);
    }

    function refreshCurrentGRTUpsellBlock() {
      var $root = $("#grt-upsell-{{ uid }}");
      if (!$root.length) return;

      if ($root.attr("data-grt-upsell-resize") !== "1") {
        $root.attr("data-grt-upsell-resize", "1");
        $(window).on("resize", function () {
          setWidth();
        });
      }

      {% if request.page_type == 'cart' %}
        if ($root.attr("data-grt-upsell-cart-watch") !== "1") {
          $root.attr("data-grt-upsell-cart-watch", "1");

          document.addEventListener("cart:updated", function () {
            setTimeout(setWidth, 0);
            setTimeout(setWidth, 200);
