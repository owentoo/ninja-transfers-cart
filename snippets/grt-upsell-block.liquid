          if (cardColorKey) $variantBlock.attr("data-pdp-selected-color-key", cardColorKey);
          finalizeUpsellModalOpen($dlg, $btn, { deferParentChildInit: true, keepOpeningState: true });
          $btn.prop("disabled", true).attr("is-loading", "true");
          initPdpColorFlow($variantBlock)
            .then(function () {
              buildSizeQtyGrid($dlg);
              schedulePdpColorRowsLimit($variantBlock);
              $dlg.removeClass("is-opening");
            })
            .catch(function () {
              $dlg.removeClass("is-opening");
              var dlgNode = $dlg[0];
              if (dlgNode && dlgNode.close) dlgNode.close();
              syncPageScrollLock();
              showUpsellToast("Unable to load options", true);
            })
            .finally(function () {
              $btn.prop("disabled", false).attr("is-loading", "false");
            });
          return;
        }
      }

      finalizeUpsellModalOpen($dlg, $btn);
