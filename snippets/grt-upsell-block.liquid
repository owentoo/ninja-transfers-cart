{%- liquid
  assign uid = section.id | append: '-' | append: block.id
  assign upsell_products = block.settings.upsell_products
  assign has_upsell_products = false
  assign limit = block.settings.cards_limit | default: 6
  assign show_slider = false
  if upsell_products != blank and upsell_products.count > 0
    assign has_upsell_products = true
  endif
  if has_upsell_products and upsell_products.count > limit
    assign show_slider = true
  endif
-%}
{%- if has_upsell_products -%}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
<style>
  #grt-upsell-{{ uid }} .swiper-slide{text-align: left;}
</style>

{%- liquid
  assign swatch_option_name = block.settings.swatch_option_name | default: 'Color'
  assign show_upsell_head = false
  assign show_cart_upsell = true

  if request.page_type == 'cart'
    if cart.item_count == 0
      assign show_cart_upsell = false
    endif
  endif

  if block.settings.heading != blank
    assign show_upsell_head = true
  endif
  if block.settings.subheading != blank
    assign show_upsell_head = true
  endif
  if block.settings.upsell_info_icon_1 != blank or block.settings.upsell_info_text_1 != blank
    assign show_upsell_head = true
  endif
  if block.settings.upsell_info_icon_2 != blank or block.settings.upsell_info_text_2 != blank
    assign show_upsell_head = true
  endif
-%}

<div class="grt-upsell" id="grt-upsell-{{ uid }}" {{ block.shopify_attributes }}>
  <div class="grt-product-upsell">
    {%- if show_upsell_head -%}
      <div class="grt-upsell__head">
        {%- if block.settings.heading != blank -%}
          <h2 class="grt-upsell__title">{{ block.settings.heading }}</h2>
        {%- endif -%}
        {%- if block.settings.subheading != blank -%}
          <p class="grt-upsell__sub">{{ block.settings.subheading }}</p>
        {%- endif -%}
        {%- if block.settings.upsell_info_icon_1 != blank or block.settings.upsell_info_text_1 != blank or block.settings.upsell_info_icon_2 != blank or block.settings.upsell_info_text_2 != blank -%}
          <div class="grt-upsell__meta">
            {%- if block.settings.upsell_info_icon_1 != blank or block.settings.upsell_info_text_1 != blank -%}
              <div class="grt-upsell__meta-item">
                {%- if block.settings.upsell_info_icon_1 != blank -%}
                  <img
                    class="grt-upsell__meta-icon"
                    src="{{ block.settings.upsell_info_icon_1 | image_url }}"
                    width="20"
                    height="20"
                    loading="lazy"
                    alt="{{ block.settings.upsell_info_text_1 | escape }}"
                  >
                {%- endif -%}
                {%- if block.settings.upsell_info_text_1 != blank -%}
                  <span class="grt-upsell__meta-text">{{ block.settings.upsell_info_text_1 | escape }}</span>
                {%- endif -%}
              </div>
            {%- endif -%}
            {%- if block.settings.upsell_info_icon_2 != blank or block.settings.upsell_info_text_2 != blank -%}
              <div class="grt-upsell__meta-item">
                {%- if block.settings.upsell_info_icon_2 != blank -%}
                  <img
                    class="grt-upsell__meta-icon"
                    src="{{ block.settings.upsell_info_icon_2 | image_url }}"
                    width="20"
                    height="20"
                    loading="lazy"
                    alt="{{ block.settings.upsell_info_text_2 | escape }}"
                  >
                {%- endif -%}
                {%- if block.settings.upsell_info_text_2 != blank -%}
                  <span class="grt-upsell__meta-text">{{ block.settings.upsell_info_text_2 | escape }}</span>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

      <div class="grt-upsell__wrap swiper grt-swiper">
        <div class="grt-upsell__track_ swiper-wrapper" data-upsell-track data-slider-enabled="{{ show_slider }}">
          {%- for p in upsell_products -%}
            {%- liquid
              assign v = p.selected_or_first_available_variant
              assign modal_id = 'grt-product-modal-' | append: uid | append: '-' | append: forloop.index
              assign upsell_shirt_style = p.metafields.specs.shirt_style | strip
              assign upsell_use_parent_child_flow = false
              if upsell_shirt_style != blank
                assign upsell_use_parent_child_flow = true
              endif
              assign upsell_product_heading = p.metafields.blanks.second_title_for_blanks | default: p.title
              unless upsell_use_parent_child_flow
                assign upsell_product_heading = p.title
              endunless
              assign upsell_pdp_handle = p.handle
              if upsell_use_parent_child_flow
                assign _uph_style_slug = upsell_shirt_style | downcase
                if _uph_style_slug != blank and p.handle contains _uph_style_slug
                  assign _uph_parts = p.handle | split: _uph_style_slug
                  assign upsell_pdp_handle = _uph_parts | first | append: _uph_style_slug
                endif
              endif
            -%}
            <div class="swiper-slide">
            <div class="grt-upsell__item" data-upsell-item{%- if upsell_use_parent_child_flow %} data-card-pdp-handle="{{ upsell_pdp_handle | escape }}"{%- endif -%}>
              <div class="grt-product-layout">

                <!-- Whole card navigates to product -->
                  <div class="grt-product-card grt-qv-btn"
                    data-open-modal="{{ modal_id }}"
                    data-vid="{{ v.id }}"
                    data-style="{{ p.metafields.specs.shirt_style | downcase }}"
                    data-handle="{{ p.url }}"
                    aria-label="Quick view">
                    <div class="grt-product-card__container">

                      <div class="grt-product-card__media grtproductcard">
                        <div class="grt-product-card__main-image">
                          {% comment %} <a href="{{ p.url }}"  aria-label="{{ p.title | escape }}" class="grt-card-overlay"></a> {% endcomment %}
                          {%- if p.featured_image != blank -%}
                            <img
                              src="{{ p.featured_image | image_url: width: 560 }}"
                              srcset="{{ p.featured_image | image_url: width: 280 }} 280w, {{ p.featured_image | image_url: width: 560 }} 560w"
                              sizes="(max-width: 749px) 50vw, 280px"
                              width="280"
                              height="280"
                              loading="lazy"
                              alt="{{ p.featured_image.alt | default: p.title | escape }}"
                            >
                          {%- elsif v.image != blank -%}
                            <img
                              src="{{ v.image | image_url: width: 560 }}"
                              srcset="{{ v.image | image_url: width: 280 }} 280w, {{ v.image | image_url: width: 560 }} 560w"
                              sizes="(max-width: 749px) 50vw, 280px"
                              width="280"
                              height="280"
                              loading="lazy"
                              alt="{{ v.image.alt | default: p.title | escape }}"
                            >
                          {%- else -%}
                            <div class="grt-product-card__img-placeholder"></div>
                          {%- endif -%}
                        </div>

                          <!-- Hidden by default, visible on hover -->
                          <div class="grt-qv-wrap" id="product-card-quick-view-btn-{{ v.id }}">
                            <button class="grtqvbtn"
                              type="button"
                              data-open-modal="{{ modal_id }}" data-vid="{{ v.id }}"
                              aria-label="Quick buy">
                              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                              QUICK BUY
                            </button>
                          </div>
                          <!-- ./quick view -->
                      </div>

                      {%- comment -%}Card color swatch strip — right below product image. Hidden for Supplies products.{%- endcomment -%}
                      {%- assign _ptype_lc = p.type | downcase -%}
                      {%- unless _ptype_lc == 'supplies' -%}
                      <div class="grt-card-swatches" data-card-swatches style="display:none;"></div>
                      {%- if upsell_use_parent_child_flow -%}
                        {%- assign _pp = all_products[upsell_pdp_handle] -%}
                        {%- if _pp != blank -%}
                          {%- comment -%}Only show color swatches if the product actually has a Color option or shirt_color metafield{%- endcomment -%}
                          {%- assign _has_color_opt = false -%}
                          {%- for _opt in _pp.options_with_values -%}
                            {%- assign _opt_name_lc = _opt.name | downcase -%}
                            {%- if _opt_name_lc == 'color' or _opt_name_lc == swatch_option_name -%}
                              {%- assign _has_color_opt = true -%}{%- break -%}
                            {%- endif -%}
                          {%- endfor -%}
                          {%- if _has_color_opt == false -%}
                            {%- for _pv in _pp.variants -%}
                              {%- if _pv.metafields.specs.shirt_color != blank -%}
                                {%- assign _has_color_opt = true -%}{%- break -%}
                              {%- endif -%}
                            {%- endfor -%}
                          {%- endif -%}
                          {%- if _has_color_opt -%}
                            {%- comment -%}Use options_with_values for accurate total — not capped like variants (100 limit){%- endcomment -%}
                            {%- assign _total_colors = 0 -%}{%- for _opt in _pp.options_with_values -%}{%- assign _opt_name_lc = _opt.name | downcase -%}{%- if _opt_name_lc == 'color' or _opt_name_lc == swatch_option_name -%}{%- assign _total_colors = _opt.values.size -%}{%- break -%}{%- endif -%}{%- endfor -%}{%- if _total_colors == 0 -%}{%- assign _tc_seen = '|' -%}{%- for _pv in _pp.variants -%}{%- assign _pck = _pv.metafields.specs.shirt_color | strip | downcase -%}{%- if _pck != blank -%}{%- assign _pct = '|' | append: _pck | append: '|' -%}{%- unless _tc_seen contains _pct -%}{%- assign _tc_seen = _tc_seen | append: _pck | append: '|' -%}{%- assign _total_colors = _total_colors | plus: 1 -%}{%- endunless -%}{%- endif -%}{%- endfor -%}{%- endif -%}
                            <script type="application/json" data-card-color-json data-card-color-total="{{ _total_colors }}">[{%- assign _ck_seen = '|' -%}{%- assign _ck_first = true -%}{%- for _pv in _pp.variants -%}{%- assign _pcn = _pv.metafields.specs.shirt_color | default: _pv.option1 | strip -%}{%- assign _pck = _pcn | downcase -%}{%- assign _pci = _pv.inventory_quantity -%}{%- if localization.country.iso_code == 'CA' -%}{%- assign _pci = _pv.metafields.custom.ss_ca_inventory | default: _pv.inventory_quantity -%}{%- endif -%}{%- if _pck != blank and _pci > 0 -%}{%- assign _pct = '|' | append: _pck | append: '|' -%}{%- unless _ck_seen contains _pct -%}{%- assign _ck_seen = _ck_seen | append: _pck | append: '|' -%}{%- assign _pch = _pv.metafields.specs.shirt_prim_hex | strip -%}{%- if _pch == blank or _pch == '0' -%}{%- assign _pch = '888888' -%}{%- endif -%}{%- unless _pch contains '#' -%}{%- assign _pch = '#' | append: _pch -%}{%- endunless -%}{%- unless _ck_first -%},{%- endunless -%}{%- assign _ck_first = false -%}{"key":{{ _pck | json }},"name":{{ _pcn | json }},"hex":{{ _pch | json }},"vid":{{ _pv.id | json }},"img":{%- if _pv.image != blank -%}{{ _pv.image | image_url: width: 560 | json }}{%- else -%}null{%- endif -%},"price":{{ _pv.price | json }},"compare":{{ _pv.compare_at_price | json }}}{%- endunless -%}{%- endif -%}{%- endfor -%}]</script>
                          {%- endif -%}
                        {%- endif -%}
                      {%- endif -%}
                      {%- endunless -%}

                      <div class="grt-product-card__details grtproductcard">
                        <div class="grt-product-card__info">
                          <div class="grt-product-card__yotpo">
                            <div class="yotpo-widget-instance" data-yotpo-instance-id="447610" data-yotpo-product-id="{{ p.id }}" data-yotpo-section-id="{{ section.id }}" data-yotpo-preloaded-data=""></div>
                          </div>
                          <h3 class="grt-product-card__title">{{ upsell_product_heading }}</h3>
                          <div class="grt-product-card__price-row">
                            <span class="grt-product-card__starting">Starting at</span>
                            <div class="grt-product-card__price">
                              <span class="grt-product-card__price-now">{{ v.price | money }}</span>
                              {%- if v.compare_at_price and v.compare_at_price > v.price -%}
                                <span class="grt-product-card__price-compare">{{ v.compare_at_price | money }}</span>
                              {%- endif -%}
                            </div>
                          </div>

                        </div>
                      </div>

                    </div>
                  </div>
              </div>

              <!-- Modal -->
              <dialog id="{{ modal_id }}" class="grt-product-modal" data-default-vid="{{ v.id }}">
                <div class="grt-product-modal__container">
                  <div class="grt-product-modal__loading" aria-hidden="true">
                    <div class="grt-product-modal__loading-spinner"></div>
                    <div class="grt-product-modal__loading-text">Loading options...</div>
                  </div>

                  <div class="grt-product-modal__content">
                    <div class="grt-product-modal__layout">
                      <div class="grt-product-modal__media">
                        {%- if v.image != blank -%}
                          <img data-modal-image src="{{ v.image | image_url: width: 832 }}" width="416" height="416" alt="{{ v.image.alt | default: p.title | escape }}">
                        {%- elsif p.featured_image != blank -%}
                          <img data-modal-image src="{{ p.featured_image | image_url: width: 832 }}" width="416" height="416" alt="{{ p.featured_image.alt | default: p.title | escape }}">
                        {%- endif -%}
                      </div>

                      <div class="grt-product-modal__details">
                        
                        <button class="grt-product-modal__close grt-modal__close" type="button" data-close-modal="{{ modal_id }}">
                          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M1.6 16L0 14.4L6.4 8L0 1.6L1.6 0L8 6.4L14.4 0L16 1.6L9.6 8L16 14.4L14.4 16L8 9.6L1.6 16Z" fill="black"/>
                          </svg>
                        </button>

                        <div class="grt-product-modal__header">
                          <div class="grt-product-card__yotpo grt-modal__star">
                              <div class="yotpo-widget-instance" data-yotpo-instance-id="447610" data-yotpo-product-id="{{ p.id }}" data-yotpo-section-id="{{ section.id }}" data-yotpo-preloaded-data=""></div>
                          </div>
                          <h2 class="grt-product-modal__title">{{ upsell_product_heading }}</h2>
                          {% if upsell_use_parent_child_flow %}
                            <div class="grt-product-modal__full-details">
                              <a href="{{ p.url }}" target="_blank" rel="noopener noreferrer">View Full Details</a>
                            </div>
                          {% endif %}
                          <div class="grt-product-modal__price-container">
                            {% if upsell_use_parent_child_flow %}
                            <div class="grt-product-modal__starting-at">Starting at</div>
                            {% endif %}
                            <span class="grt-product-modal__price">{{ v.price | money }}</span>
                            {%- if v.compare_at_price and v.compare_at_price > v.price -%}
                              <span class="grt-product-modal__compare-price">{{ v.compare_at_price | money }}</span>
                            {%- endif -%}
                          </div>
                          
                        </div>

                        <form class="grt-product-modal__form" novalidate method="post" action="/cart/add" data-initial-variant="{{ v.id }}">
                          <input type="hidden" name="id" value="{{ v.id }}" data-variant-input />

                          {%- if p.variants.size > 1 -%}
                            {%- render 'grt-upsell-variant-options',
                              block: block,
                              p: p,
                              v: v,
                              swatch_option_name: swatch_option_name
                            -%}
                          {%- endif -%}

                          <div class="grt-product-modal__label grt-size-qty-parent-label" data-size-qty-parent-label style="display:none;">Variant</div>
                          <div class="grt-pdp-size-grid" data-pdp-size-grid style="display:none;"></div>
                          <div class="grt-size-qty-grid" data-size-qty-grid style="display:none;"></div>

                          <div class="grt-product-modal__qty" data-qty-wrap>
                            <label class="grt-product-modal__label" for="grt-qty-{{ modal_id }}">Quantity</label>
                            <div class="grt-qty">
                              <div class="grt-qty-box-wrapper">
                                <button type="button" class="grt-qty__btn" data-qty-minus aria-label="Decrease quantity">-</button>
                                <input id="grt-qty-{{ modal_id }}" class="grt-qty__input" type="number" name="quantity" value="1" min="1" step="1" inputmode="numeric" pattern="[0-9]*" data-qty-input>
                                <button type="button" class="grt-qty__btn" data-qty-plus aria-label="Increase quantity">+</button>
                              </div>
                            </div>
                          </div>

                          {% unless upsell_use_parent_child_flow %}
                          <div class="grt-product-modal__description grt-modal__description-wrapper">
                            <div class="grt-product-modal__description-text half__description">
                              {{ p.description | strip_html | truncate: 220 }}
                              <div class="grt-product-modal__more">
                                <a href="javascript:void(0);" class="showfullcta">See More</a>
                              </div>
                            </div>

                            <div class="grt-product-modal__description-text full__description">
                              {{ p.description | strip_html }}
                              <div class="grt-product-modal__more">
                                <a href="javascript:void(0);" class="hidefullcta">See Less</a>
                              </div>
                            </div>
                          </div>
                          {% endunless %}

                        </form>

                        <div class="grt-product-modal__buttons">
                          <button class="grt-product-modal__add-button button" type="button" {% unless v.available %}disabled{% endunless %}>
                            Add to cart
                          </button>
                        </div>

                      </div>
                    </div>
                  </div>
                </div>
              </dialog>
            </div>
          </div>
          {%- endfor -%}
        </div>
        
        <div class="swiper-button-prev grt-upsell-prev"></div>
        <div class="swiper-button-next grt-upsell-next"></div>
      </div>
  </div>
</div>

<script>

  var SHOP_MONEY_FORMAT = {{ shop.money_format | json }};
  function grt____upsell(){
    var $root = $("#grt-upsell-{{ uid }}");
    if (!$root.length) return;
    if ($root.attr("data-grt-upsell-bound") === "1") return;
    $root.attr("data-grt-upsell-bound", "1");
    var pdpColorDataRequests = {};
    var cardImageCache = {}; // keyed by "pdpHandle::colorName"

    // ---------------------------
    // Helpers
    // ---------------------------
    function formatMoney(cents, format) {
      if (typeof cents === "string") cents = cents.replace(".", "");
      var value = "";
      var placeholderRegex = /\{\{\s*(\w+)\s*\}\}/;
      var formatString = format || SHOP_MONEY_FORMAT;

      function formatWithDelimiters(number, precision, thousands, decimal) {
        precision = precision || 2;
        thousands = thousands || ",";
        decimal = decimal || ".";
        number = (number / 100).toFixed(precision);
        var parts = number.split(".");
        var dollars = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, thousands);
        var centsPart = parts[1] ? decimal + parts[1] : "";
        return dollars + centsPart;
      }

      var match = formatString.match(placeholderRegex);
      var token = match ? match[1] : "amount";

      switch (token) {
        case "amount": value = formatWithDelimiters(cents, 2); break;
        case "amount_no_decimals": value = formatWithDelimiters(cents, 0); break;
        case "amount_with_comma_separator": value = formatWithDelimiters(cents, 2, ".", ","); break;
        case "amount_no_decimals_with_comma_separator": value = formatWithDelimiters(cents, 0, ".", ","); break;
        default: value = formatWithDelimiters(cents, 2); break;
      }
      return formatString.replace(placeholderRegex, value);
    }

    function getVariantsFromBlock($block) {
      var $jsonEl = $block.find("[data-variants-json]").first();
      if (!$jsonEl.length) return [];
      try { return JSON.parse($jsonEl.text() || "[]"); } catch (e) { return []; }
    }

    function findVariantById(variants, id) {
      var sid = String(id || "").trim();
      if (!sid) return null;
      for (var i = 0; i < variants.length; i++) {
        if (String(variants[i].id) === sid) return variants[i];
      }
      return null;
    }

    function getSelectedOptions($block) {
      var count = parseInt($block.attr("data-option-count") || "0", 10);
      var selected = new Array(count);
      for (var i = 0; i < count; i++) selected[i] = null;

      $block.find(".grt-variant-pill.is-active").each(function () {
        var idx = parseInt($(this).attr("data-option-index"), 10);
        var val = $(this).attr("data-option-value");
        if (!isNaN(idx)) selected[idx] = val;
      });
      return selected;
    }

    function findMatchingVariant(variants, selected) {
      for (var i = 0; i < variants.length; i++) {
        var vr = variants[i];
        var ok = true;
        for (var j = 0; j < selected.length; j++) {
          if (selected[j] == null) { ok = false; break; }
          var key = "option" + (j + 1);
          if ((vr[key] || "") !== selected[j]) { ok = false; break; }
        }
        if (ok) return vr;
      }
      return null;
    }

    function setActivePill($block, optionIndex, optionValue) {
      var $scope = $block.find('.grt-opt__pills[data-option-index="' + optionIndex + '"]').first();
      if (!$scope.length) return;
      $scope.find(".grt-variant-pill").removeClass("is-active");
      var $found = $scope.find('.grt-variant-pill[data-option-value="' + cssEscape(optionValue) + '"]').first();
      if ($found.length) $found.addClass("is-active");
    }

    function updateButtonsAndPrice($form, variant) {
      var $addBtn = $form.find(".grt-product-modal__add-button").first();
      var $details = $form.closest(".grt-product-modal__details");
      var $priceEl = $details.find(".grt-product-modal__price").first();
      var $compareEl = $details.find(".grt-product-modal__compare-price").first();

      var available = !!(variant && variant.available);
      if ($addBtn.length) $addBtn.prop("disabled", !available);

      if (variant && $priceEl.length) $priceEl.html(formatMoney(variant.price));

      if ($compareEl.length) {
        var c = variant ? variant.compare_at_price : null;
        if (c && Number(c) > Number(variant.price)) {
          $compareEl.css("display", "").html(formatMoney(c));
        } else {
          $compareEl.css("display", "none");
        }
      }
    }

    function updateModalHeadlinePrice($dlg, priceCents, compareCents) {
      if (!$dlg.length) return;
      var $details = $dlg.find(".grt-product-modal__details").first();
      if (!$details.length) return;

      var $priceEl = $details.find(".grt-product-modal__price").first();
      var $compareEl = $details.find(".grt-product-modal__compare-price").first();

      var priceValue = parseInt(priceCents || "0", 10);
      if (!isNaN(priceValue) && priceValue > 0 && $priceEl.length) {
        $priceEl.html(formatMoney(priceValue));
      }

      var compareValue = parseInt(compareCents || "0", 10);
      if ($compareEl.length) {
        if (!isNaN(compareValue) && compareValue > priceValue) {
          $compareEl.css("display", "").html(formatMoney(compareValue));
        } else {
          $compareEl.css("display", "none");
        }
      }
    }

    function updateModalImage($form, variant) {
      if (!variant || !variant.image) return;
      var $dlg = $form.closest("dialog.grt-product-modal");
      if (!$dlg.length) return;
      var $img = $dlg.find("[data-modal-image]").first();
      if ($img.length) $img.attr("src", variant.image);
    }

    function setVariantOnForm($form, variant) {
      if (!$form.length || !variant) return;

      // source of truth for our code
      $form.attr("data-variant-id", String(variant.id));

      // keep hidden input aligned
      var $hidden = $form.find("[data-variant-input],[name='id']").first();
      if ($hidden.length) $hidden.val(variant.id);

      updateButtonsAndPrice($form, variant);
      updateModalImage($form, variant);
    }

    function isValuePossible(variants, selected, optionIndex, testValue) {
      for (var i = 0; i < variants.length; i++) {
        var vr = variants[i];
        if (!vr.available) continue;

        var ok = true;
        for (var j = 0; j < selected.length; j++) {
          var key = "option" + (j + 1);
          if (j === optionIndex) {
            if ((vr[key] || "") !== testValue) { ok = false; break; }
          } else {
            if (selected[j] == null) continue;
            if ((vr[key] || "") !== selected[j]) { ok = false; break; }
          }
        }
        if (ok) return true;
      }
      return false;
    }

    function refreshDisabledStates($block) {
      var variantFlow = String($block.attr("data-variant-flow") || "").trim();
      var variants = getVariantsFromBlock($block);
      var selected = getSelectedOptions($block);
      var optionCount = parseInt($block.attr("data-option-count") || "0", 10);
      var lastOptionIndex = optionCount > 0 ? optionCount - 1 : -1;

      $block.find(".grt-variant-pill").each(function () {
        var $btn = $(this);
        var idx = parseInt($btn.attr("data-option-index"), 10);
        if (isNaN(idx)) return;

        if (variantFlow === "normal" && idx !== lastOptionIndex) {
          $btn.prop("disabled", false);
          $btn.removeClass("is-disabled");
          return;
        }

        var val = $btn.attr("data-option-value");
        var possible = isValuePossible(variants, selected, idx, val);
        $btn.prop("disabled", !possible);
        $btn.toggleClass("is-disabled", !possible);
      });
      scheduleColorRowsLimit($block);
      schedulePdpColorRowsLimit($block);
    }

    function ensureDefaults($block) {
      $block.find(".grt-opt__pills").each(function () {
        var $wrap = $(this);
        if ($wrap.find(".grt-variant-pill.is-active:not(:disabled)").length) return;
        $wrap.find(".grt-variant-pill.is-active").removeClass("is-active");
        var $first = $wrap.find(".grt-variant-pill:not(:disabled)").first();
        if (!$first.length) $first = $wrap.find(".grt-variant-pill").first();
        if ($first.length) $first.addClass("is-active");
      });
    }

    function syncVariantFromSelection($block) {
      var variants = getVariantsFromBlock($block);
      var selected = getSelectedOptions($block);
      var $form = $block.closest("form.grt-product-modal__form");
      if (!$form.length) return;

      if (selected.some(function (v) { return v == null; })) {
        ensureDefaults($block);
        selected = getSelectedOptions($block);
      }

      refreshDisabledStates($block);
      ensureDefaults($block);
      selected = getSelectedOptions($block);

      var match = findMatchingVariant(variants, selected);
      if (!match) {
        updateButtonsAndPrice($form, null);
        var $dlgNoMatch = $block.closest("dialog.grt-product-modal");
        if ($dlgNoMatch.length) buildSizeQtyGrid($dlgNoMatch);
        return;
      }
      setVariantOnForm($form, match);
      var $dlg = $block.closest("dialog.grt-product-modal");
      if ($dlg.length) buildSizeQtyGrid($dlg);
    }

    function applyVariantIdToModal($dlg, variantId) {
      var $block = $dlg.find("[data-variant-options]").first();
      var $form = $dlg.find("form.grt-product-modal__form").first();
      if (!$block.length || !$form.length) return;

      var variants = getVariantsFromBlock($block);
      var vr = findVariantById(variants, variantId);
      if (!vr) { syncVariantFromSelection($block); return; }

      var count = parseInt($block.attr("data-option-count") || "0", 10);
      for (var i = 0; i < count; i++) {
        var key = "option" + (i + 1);
        if (vr[key] != null) setActivePill($block, i, vr[key]);
      }

      refreshDisabledStates($block);
      setVariantOnForm($form, vr);
      buildSizeQtyGrid($dlg);
    }

    // CSS.escape fallback for attribute selector safety
    function cssEscape(val) {
      val = String(val == null ? "" : val);
      // minimal escape for quotes and backslashes (enough for your values)
      return val.replace(/\\/g, "\\\\").replace(/"/g, '\\"');
    }

    function normalizeSwatchHex(hex) {
      var value = String(hex || "").trim();
      if (!value || value === "0") return "";
      if (value.charAt(0) !== "#") value = "#" + value;
      return value;
    }

    function getColorMapFromBlock($block) {
      var $jsonEl = $block.find("[data-color-map-json]").first();
      if (!$jsonEl.length) return {};
      try {
        var parsed = JSON.parse($jsonEl.text() || "{}");
        return parsed && typeof parsed === "object" ? parsed : {};
      } catch (e) {
        return {};
      }
    }

    // ---------------------------
    // Swatch mask helpers (hard-cut edges, dynamic per scroll position)
    // ---------------------------
    var MASK_SIZE = 20; // px — roughly half a 36px swatch
    function updateSwatchMask(el) {
      var atStart = el.scrollLeft <= 1;
      var atEnd   = el.scrollLeft >= el.scrollWidth - el.clientWidth - 1;
      var noScroll = el.scrollWidth <= el.clientWidth + 2;
      var mask;
      if (noScroll) {
        mask = 'none';
      } else if (atStart) {
        // Only right hard-cut — show half of next swatch
        mask = 'linear-gradient(to right, black calc(100% - ' + MASK_SIZE + 'px), transparent calc(100% - ' + MASK_SIZE + 'px))';
      } else if (atEnd) {
        // Only left hard-cut — last swatch fully visible on right
        mask = 'linear-gradient(to right, transparent ' + MASK_SIZE + 'px, black ' + MASK_SIZE + 'px)';
      } else {
        // Both edges — cut on left and right
        mask = 'linear-gradient(to right, transparent ' + MASK_SIZE + 'px, black ' + MASK_SIZE + 'px, black calc(100% - ' + MASK_SIZE + 'px), transparent calc(100% - ' + MASK_SIZE + 'px))';
      }
      el.style.webkitMaskImage = mask;
      el.style.maskImage = mask;
    }

    function initSwatchMask(el) {
      if (!el || el.__grtMaskBound) return;
      el.__grtMaskBound = true;
      updateSwatchMask(el);
      el.addEventListener('scroll', function () { updateSwatchMask(el); }, { passive: true });
    }

    function applyColorSwatches($block) {
      if (!$block.length) return;
      var swatchIndex = parseInt($block.attr("data-swatch-option-index") || "", 10);
      if (isNaN(swatchIndex) || swatchIndex < 0) return;

      var colorMap = getColorMapFromBlock($block);
      if (!colorMap || typeof colorMap !== "object") return;

      var $pills = $block.find('.grt-variant-pill[data-option-index="' + swatchIndex + '"]');
      if (!$pills.length) return;

      $pills.each(function () {
        var $pill = $(this);
        var optionValue = ($pill.attr("data-option-value") || "").toString().trim();
        var optionKey = optionValue.toLowerCase();
        var swatchHex = normalizeSwatchHex(colorMap[optionKey]);
        if (!swatchHex) return;

        $pill.addClass("is-swatch");
        $pill.attr("data-swatch", swatchHex);
        $pill.css("--swatch", swatchHex);
        $pill.attr("aria-label", optionValue);

        if (!$pill.find(".grt-swatch").length) {
          $pill.empty().append('<span class="grt-swatch"></span>');
        }
      });

      $block.find('.grt-opt__pills[data-option-index="' + swatchIndex + '"]').addClass("grt-swatch-pills");
      updateSelectedColorName($block);
