    function getPdpColorMaxRows() {
      var maxRows = 2;
      if (window.matchMedia && window.matchMedia("(max-width: 749px)").matches) {
        maxRows = 4;
      }
      return maxRows;
    }

    function isPdpColorBeyondRowLimit($block, $pill) {
      if (!$block.length || !$pill.length) return false;
      var $wrap = $block.find("[data-pdp-color-options]").first();
      if (!$wrap.length) return false;

      var maxRows = getPdpColorMaxRows();
      var rowTops = [];
      var selectedRow = -1;
      var $pills = $wrap.find(".grt-pdp-color-pill:visible");

      $pills.each(function () {
        var top = Math.round($(this).position().top || 0);
        var rowIndex = -1;
        for (var i = 0; i < rowTops.length; i++) {
          if (Math.abs(rowTops[i] - top) <= 2) {
            rowIndex = i;
            break;
          }
        }
        if (rowIndex === -1) {
          rowTops.push(top);
          rowIndex = rowTops.length - 1;
        }
        if (this === $pill[0]) {
          selectedRow = rowIndex + 1;
        }
      });

      if (selectedRow < 0) return false;
      return selectedRow > maxRows;
    }

