      }
    }

    function getRequest(url) {
      return fetch(url, { credentials: "same-origin" }).then(function (response) {
        if (!response.ok) {
          throw new Error("Request failed: " + response.status);
        }
        return response.json();
      });
    }

    function getPdpColorRequestKey(handle, colorValue, colorOptionValueId) {
      return (
        String(handle || "").trim() +
        "::" +
        String(colorValue || "").trim() +
        "::" +
        String(colorOptionValueId || "").trim()
      );
    }

    function requestPdpColorData(handle, colorValue, options) {
      options = options || {};
      var colorOptionValueId = String(options.colorOptionValueId || "").trim();
      var key = getPdpColorRequestKey(handle, colorValue, colorOptionValueId);
      if (!key || key === "::") {
        return Promise.reject(new Error("Missing parent-child request key"));
      }

      if (pdpColorDataRequests[key]) {
        return pdpColorDataRequests[key];
      }

      var url =
        "/products/" +
        handle +
        "?view=get_handle__modal&_ts=" +
        Date.now() +
        "&variant=" +
        encodeURIComponent(colorValue);
      if (colorOptionValueId) {
        url += "&option_values=" + encodeURIComponent(colorOptionValueId);
      }
      pdpColorDataRequests[key] = getRequest(url)
        .then(function (data) {
          delete pdpColorDataRequests[key];
          return data || {};
        })
        .catch(function (error) {
          delete pdpColorDataRequests[key];
          throw error;
        });

      return pdpColorDataRequests[key];
    }

    function normalizePdpHex(hex) {
      var value = String(hex || "").trim();
      if (!value) return "";
      if (value.charAt(0) !== "#") value = "#" + value;
      return value;
    }

    function pdpHsl(hex) {
      try {
        var clean = normalizePdpHex(hex);
        var result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(clean);
        if (!result) return [0, 0, 0];

        var r = parseInt(result[1], 16) / 255;
        var g = parseInt(result[2], 16) / 255;
        var b = parseInt(result[3], 16) / 255;
        var max = Math.max(r, g, b);
        var min = Math.min(r, g, b);
        var h = 0;
        var s = 0;
        var l = (max + min) / 2;

        if (max !== min) {
          var d = max - min;
          s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
          switch (max) {
            case r: h = (g - b) / d + (g < b ? 6 : 0); break;
            case g: h = (b - r) / d + 2; break;
            default: h = (r - g) / d + 4; break;
          }
          h /= 6;
        }

        return [Math.round(h * 360), Math.round(s * 100), Math.round(l * 100)];
      } catch (e) {
        return [0, 0, 0];
      }
    }

    function getPdpColorCategory(hue, saturation) {
      // Match apparel-variant-color-picker behavior (threshold is 0.2 on a 0-100 saturation scale).
      if (saturation < 0.2) return "grayscale";
      if ((hue >= 330 && hue <= 360) || (hue >= 0 && hue <= 16)) return "red";
      if (hue > 16 && hue <= 42) return "orange";
      if (hue > 42 && hue <= 65) return "yellow";
      if (hue > 65 && hue <= 165) return "green";
      if (hue > 165 && hue <= 190) return "cyan";
      if (hue > 190 && hue <= 255) return "blue";
      if (hue > 255 && hue <= 295) return "violet";
      if (hue > 295 && hue < 330) return "magenta";
      return "other";
    }

    function sortPdpColorPills($block) {
      if (!$block.length) return;
      var $wrap = $block.find("[data-pdp-color-options]").first();
      if (!$wrap.length) return;

      var colors = [];

      $wrap.find("[data-pdp-color-key]").each(function () {
        var $el = $(this);
        var hex = normalizePdpHex($el.attr("data-pdp-color-hex"));
        var hsl = pdpHsl(hex);

        colors.push({
          $el: $el.detach(),
          hex: hex,
          h: hsl[0],
          s: hsl[1] / 100,
          l: hsl[2]
        });
      });

      colors.sort(function (a, b) {
        var colA = a.s < 0.15 ? 0 : Math.floor(a.h / 24) + 1;
        var colB = b.s < 0.15 ? 0 : Math.floor(b.h / 24) + 1;

        if (colA !== colB) return colA - colB;
        return b.l - a.l;
      });

      colors.forEach(function (color) {
        $wrap.append(color.$el);
      });
    }

    function buildMobileColorDropdown($block) {
      var $list = $block.find("[data-mobile-cp-list]").first();
      if (!$list.length) return;

      // Collect colors from pills (already hue-sorted by sortPdpColorPills)
      var colors = [];
      $block.find(".grt-pdp-color-pill").each(function () {
        var $p = $(this);
        var chipStyle = $p[0].style.getPropertyValue("--grt-pdp-color-chip") || "";
        colors.push({
          key: String($p.attr("data-pdp-color-key") || ""),
          name: String($p.attr("data-pdp-color-name") || ""),
          chipStyle: chipStyle
        });
      });

      // Sort alphabetically by color name
      colors.sort(function (a, b) { return a.name.localeCompare(b.name); });

      // Update count badge
      var count = colors.length;
      $block.find("[data-color-count-badge]").text(count + " colors");

      // Active key
      var activeKey = String($block.attr("data-pdp-selected-color-key") || "").toLowerCase();

      // Build full-screen overlay HTML: header + scrollable list
      var itemsHtml = "";
      for (var i = 0; i < colors.length; i++) {
        var c = colors[i];
        var isActive = (c.key === activeKey);
        itemsHtml += '<button type="button" class="grt-mobile-cp-item' + (isActive ? " is-active" : "") + '"'
          + ' data-mobile-cp-item-key="' + htmlEscape(c.key) + '">'
          + '<span class="grt-mobile-cp-item__chip" style="--grt-mobile-cp-item-chip:' + c.chipStyle + '"></span>'
          + '<span>' + htmlEscape(c.name) + '</span>'
          + '</button>';
      }
      var html = '<div class="grt-mobile-cp-list__header">'
        + '<span>Select Color</span>'
        + '<button type="button" class="grt-mobile-cp-list__close" data-mobile-cp-close aria-label="Close">'
        + '<svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 1l12 12M13 1L1 13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>'
        + '</button>'
        + '</div>'
        + '<div class="grt-mobile-cp-list__scroll">' + itemsHtml + '</div>';
      $list.html(html);
    }

    function updateMobileColorTrigger($block, colorName, chipValue) {
      var $trigger = $block.find("[data-mobile-cp-trigger]").first();
      if (!$trigger.length) return;
      var $chip = $trigger.find("[data-mobile-cp-chip]").first();
      var $name = $trigger.find("[data-mobile-cp-name]").first();
      if ($name.length) $name.text(String(colorName || "").toLowerCase() || "select color");
      if ($chip.length && chipValue) {
        $chip[0].style.setProperty("--grt-mobile-cp-chip", chipValue);
      }
      // Sync active state in the dropdown list
      var activeKey = String(colorName || "").toLowerCase();
      $block.find(".grt-mobile-cp-item").each(function () {
        var $item = $(this);
        $item.toggleClass("is-active", $item.attr("data-mobile-cp-item-key") === activeKey);
      });
    }

    function sortPdpColorPills__old($block) {
      if (!$block.length) return;
      var $wrap = $block.find("[data-pdp-color-options]").first();
      if (!$wrap.length) return;

      var groups = {
        grayscale: [],
        red: [],
        orange: [],
        yellow: [],
        green: [],
        cyan: [],
        blue: [],
        violet: [],
        magenta: [],
        other: []
      };

      $wrap.find("[data-pdp-color-key]").each(function () {
        var $el = $(this);
        var hex = normalizePdpHex($el.attr("data-pdp-color-hex"));
        var hsl = pdpHsl(hex);
        var category = getPdpColorCategory(hsl[0], hsl[1]);
        groups[category].push({
          $el: $el.detach(),
          lightness: hsl[2]
        });
      });

      Object.keys(groups).forEach(function (key) {
        groups[key].sort(function (a, b) {
          return b.lightness - a.lightness;
        });
      });

      console.log("Grouped color pills by category and sorted by lightness within each category");
      console.log(groups);
      var order = ["grayscale", "red", "orange", "yellow", "green", "cyan", "blue", "violet", "magenta", "other"];
      order.forEach(function (key) {
        groups[key].forEach(function (row) {
          $wrap.append(row.$el);
        });
      });

      console.log("Sorted color pills in category order with lightness sorting within each category");
      console.log(groups);
    }

    function setPdpColorButtonState($block, $pill) {
      $block
        .find("[data-pdp-color-key]")
        .removeClass("is-active")
        .attr("aria-pressed", "false");
      $pill.addClass("is-active").attr("aria-pressed", "true");
