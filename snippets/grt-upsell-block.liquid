    // ---------------------------
    // Swatch carousel: horizontal touch-scroll with momentum on mobile.
    // We use {passive:false} on touchmove so we can preventDefault() for
    // horizontal swipes (stops the parent modal from stealing the gesture).
    // On touchend we apply velocity-based deceleration via rAF so the
    // scroll coasts naturally like native inertia scrolling.
    // ---------------------------
    (function () {
      var rootEl = $root[0];
      if (!rootEl) return;

      rootEl.addEventListener("touchstart", function (e) {
        var target = e.target;
        var pills = target.closest
          ? target.closest(".grt-swatch-pills, .grt-opt__pills--pdp-colors")
          : null;
        if (!pills) return;

        // Ensure mask is initialised (lazy safety-net for dynamic pill builds)
        initSwatchMask(pills);

        // Cancel any in-progress momentum animation on this element
        if (pills.__grtRaf) {
          cancelAnimationFrame(pills.__grtRaf);
          pills.__grtRaf = null;
        }

        var startX      = e.touches[0].clientX;
        var startY      = e.touches[0].clientY;
        var startScroll = pills.scrollLeft;
        var direction   = null;
        var prevX       = startX;
        var prevTime    = Date.now();
        var velX        = 0; // px / ms at last tracked frame

        function onMove(e2) {
          var cx = e2.touches[0].clientX;
          var cy = e2.touches[0].clientY;
          var dx = cx - startX;
          var dy = cy - startY;

          // Determine scroll direction once we have enough movement
          if (!direction && (Math.abs(dx) > 4 || Math.abs(dy) > 4)) {
            direction = Math.abs(dx) >= Math.abs(dy) ? "h" : "v";
          }

          if (direction === "h") {
            e2.preventDefault();

            // Clamp to valid scroll range
            var maxScroll = pills.scrollWidth - pills.clientWidth;
            pills.scrollLeft = Math.max(0, Math.min(maxScroll, startScroll - dx));

            // Track instantaneous velocity (px/ms, positive = scrolling right)
            var now = Date.now();
            var dt  = now - prevTime;
            if (dt > 0) velX = (prevX - cx) / dt;
            prevX    = cx;
            prevTime = now;
          }
        }

        function onEnd() {
          pills.removeEventListener("touchmove",   onMove);
          pills.removeEventListener("touchend",    onEnd);
          pills.removeEventListener("touchcancel", onEnd);

          if (direction !== "h") return;

          // Convert px/ms velocity → px/frame (~60fps) and apply friction
          var v        = velX * 16;
          var friction = 0.92; // ~92% retained per frame → natural coast

          function step() {
            v *= friction;
            if (Math.abs(v) < 0.5) { pills.__grtRaf = null; return; }
            var maxScroll = pills.scrollWidth - pills.clientWidth;
            var next = pills.scrollLeft + v;
            if (next <= 0 || next >= maxScroll) { pills.scrollLeft = Math.max(0, Math.min(maxScroll, next)); pills.__grtRaf = null; return; }
            pills.scrollLeft = next;
            pills.__grtRaf = requestAnimationFrame(step);
          }

          if (Math.abs(v) > 1) {
            pills.__grtRaf = requestAnimationFrame(step);
          }
        }

        pills.addEventListener("touchmove",   onMove, { passive: false });
        pills.addEventListener("touchend",    onEnd,  { passive: true });
        pills.addEventListener("touchcancel", onEnd,  { passive: true });
      }, { passive: true });
    }());

    $root.find("[data-variant-options][data-use-pdp-color-flow='1']").each(function (index) {
