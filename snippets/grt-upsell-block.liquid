    // ---------------------------
    $root.on("click", ".grt-product-modal__add-button", function (e) {
      var $btn = $(this);
      var $dlg = $btn.closest("dialog.grt-product-modal");
      if (!$dlg.length) return;

      var $form = $dlg.find("form.grt-product-modal__form").first();
      if (!$form.length) return;

      e.preventDefault();
      e.stopPropagation();

      if ($btn.prop("disabled")) return;

      var originalHtml = $btn.html();
      var $sizeGrid = $form.find("[data-size-qty-grid]:visible").first();
      var $variantBlock = $form.find("[data-variant-options]").first();
      var isPdpServerFlow = $variantBlock.length && $variantBlock.attr("data-use-pdp-color-flow") === "1";
      var $pdpSizeGrid = $form.find("[data-pdp-size-grid]:visible").first();
      var itemsToAdd = [];
      var selectedColor = "";

      if ($variantBlock.length) {
        var colorOptionIndex = parseInt(
          ($variantBlock.attr("data-color-option-index") ||
            $variantBlock.attr("data-swatch-option-index") ||
            ""),
          10
        );
        if (!isNaN(colorOptionIndex) && colorOptionIndex >= 0) {
          selectedColor = getSelectedOptionValue($variantBlock, colorOptionIndex);
        }
        if (!selectedColor) {
          selectedColor = String($variantBlock.attr("data-selected-pdp-color") || "").trim();
        }
      }
      if (!selectedColor) {
        selectedColor = String($form.attr("data-selected-color") || "").trim();
      }

      if (isPdpServerFlow) {
        if (!$pdpSizeGrid.length) {
          $btn.html("Choose color");
          setTimeout(function () { $btn.html(originalHtml); }, 1200);
          return;
        }

        var $pdpInputs = $pdpSizeGrid.find("[data-pdp-size-qty-input]");
        if ($pdpInputs.length) {
          $pdpInputs.each(function () {
            var $inp = $(this);
            var qty = parseInt($inp.val() || "0", 10);
            if (isNaN(qty) || qty < 1) return;

            var max = parseInt($inp.attr("data-max") || "0", 10);
            if (!isNaN(max) && max > 0 && qty > max) {
              qty = max;
              $inp.val(max);
            }

            var itemId = String($inp.attr("data-id") || "").trim();
            if (!itemId) return;

            var item = { id: itemId, quantity: qty };
            var properties = {};
            if (selectedColor) properties.Color = selectedColor;
            if (Object.keys(properties).length) item.properties = properties;
            itemsToAdd.push(item);
          });
        } else {
          $pdpSizeGrid.find(".itemQuantity").each(function () {
            var $inp = $(this);
            var qty = parseInt($inp.val() || "0", 10);
            if (isNaN(qty) || qty < 1) return;

            var max = parseInt($inp.attr("data-max") || "0", 10);
            if (!isNaN(max) && max > 0 && qty > max) {
              qty = max;
              $inp.val(max);
            }

            var itemId = String($inp.attr("data-id") || "").trim();
            if (!itemId) return;

            var item = { id: itemId, quantity: qty };
            var properties = {};
            if (selectedColor) properties.Color = selectedColor;
            if (Object.keys(properties).length) item.properties = properties;
            itemsToAdd.push(item);
          });
        }

        if (!itemsToAdd.length) {
          $btn.html("Choose qty");
          setTimeout(function () { $btn.html(originalHtml); }, 1200);
          return;
        }
      } else if ($sizeGrid.length) {

        $sizeGrid.find("[data-size-qty-input]").each(function () {
          var $inp = $(this);
          var qty = parseInt($inp.val() || "0", 10);
          if (isNaN(qty) || qty < 1) return;

          var max = parseInt($inp.attr("data-max") || "0", 10);
          if (!isNaN(max) && max > 0 && qty > max) {
            qty = max;
            $inp.val(max);
          }

          var itemId = String($inp.attr("data-id") || "").trim();
          if (!itemId) return;

          var item = { id: itemId, quantity: qty };
          var properties = {};
          if (selectedColor) properties.Color = selectedColor;
          if (Object.keys(properties).length) item.properties = properties;
          itemsToAdd.push(item);
        });

        if (!itemsToAdd.length) {
          $btn.html("Choose qty");
          setTimeout(function () { $btn.html(originalHtml); }, 1200);
          return;
        }
      } else {
        var $qtyEl = $form.find('[name="quantity"],[data-qty-input]').first();
        var qty = $qtyEl.length ? parseInt($qtyEl.val() || "1", 10) : 1;
        if (isNaN(qty) || qty < 1) qty = 1;

        var variantId = ($form.attr("data-variant-id") || "").trim();
        if (!variantId) {
          var $idEl = $form.find('[data-variant-input],[name="id"]').first();
          variantId = ($idEl.val() || "").toString().trim();
        }
        if (!variantId) return;

        itemsToAdd.push({ id: variantId, quantity: qty });
      }

      // Tally total quantity being added
      var totalQtyAdded = 0;
      for (var _ai = 0; _ai < itemsToAdd.length; _ai++) { totalQtyAdded += (itemsToAdd[_ai].quantity || 0); }
      if (totalQtyAdded < 1) totalQtyAdded = 1;

      // Show spinner while request is in flight
      $btn.prop("disabled", true).html('<span class="grt-btn-spinner"></span>');

      $.ajax({
        url: "/cart/add.js",
        method: "POST",
        dataType: "json",
        contentType: "application/json; charset=utf-8",
        data: JSON.stringify({ items: itemsToAdd })
      }).done(function () {
        // Green success state with item count
        var successLabel = totalQtyAdded + (totalQtyAdded === 1 ? " Item Added to Cart!" : " Items Added to Cart!");
        $btn.addClass("grt-btn--success").html(successLabel);

        if (isPdpServerFlow && $pdpSizeGrid.length) {
          if ($pdpSizeGrid.find("[data-pdp-size-qty-input]").length) {
            $pdpSizeGrid.find("[data-pdp-size-qty-input]").val("");
            schedulePdpSizeGridPriceRefresh($dlg);
          } else {
            $pdpSizeGrid.find(".itemQuantity").val("");
          }
        } else if ($sizeGrid.length) {
          $sizeGrid.find("[data-size-qty-input]").val("");
          scheduleSizeGridPriceRefresh($dlg);
        } else {
          var $qtyInput = $form.find("[data-qty-input]").first();
          if ($qtyInput.length) $qtyInput.val(1);
        }
        showUpsellToast("Product successfully added to your cart");
        if (typeof window.refreshCart === "function") {
          window.refreshCart("notOpen");
        } else {
          document.dispatchEvent(new Event("cart:updated"));
        }
        document.dispatchEvent(new CustomEvent("grt-upsell:added", { detail: { source: "grt-upsell" } }));

        setTimeout(function () {
          $btn.prop("disabled", false).removeClass("grt-btn--success").html("Add to cart");
        }, 3000);
      }).fail(function (xhr) {
        console.error("[GRT Upsell] add error:", xhr);
        showUpsellToast("Unable to add to cart", true);
        $btn.prop("disabled", false).html(originalHtml);
        setTimeout(function () { $btn.html(originalHtml); }, 2000);
      });
    });

