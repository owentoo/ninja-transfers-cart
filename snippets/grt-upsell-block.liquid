    function updateSelectedColorName($block) {
      if (!$block.length) return;
      var colorName = "";

      if ($block.attr("data-use-pdp-color-flow") === "1") {
        // Parent-child flow: read from the label element or block attribute
        colorName = String($block.find("[data-pdp-selected-color-text]").first().text() || "").trim();
        if (!colorName) colorName = String($block.attr("data-pdp-selected-color-key") || "").trim();
        // Show the built-in text element
        $block.find("[data-pdp-selected-color-text]").show();
      } else {
        // Normal flow: read from the active swatch pill
        var $activePill = $block.find(".grt-variant-pill.is-swatch.is-active").first();
        if (!$activePill.length) $activePill = $block.find(".grt-variant-pill.is-swatch").first();
        colorName = String($activePill.attr("data-option-value") || $activePill.attr("aria-label") || "").trim();
        // Update or create the inline color name span in the label
        var $opt = $activePill.closest(".grt-opt");
        var $label = $opt.find(".grt-product-modal__label").first();
        if ($label.length) {
          var $nameSpan = $label.find(".grt-selected-color-name");
          if (!$nameSpan.length) {
            $nameSpan = $('<span class="grt-selected-color-name"></span>');
            $label.append($nameSpan);
          }
          $nameSpan.text(colorName);
