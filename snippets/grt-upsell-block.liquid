<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>


<script>
  function enable_swiper(root){
    var el = document.querySelector(root);
    if(!el) return;

    // must be the container that has .swiper class
    if(el.swiper){ el.swiper.update(); return; }

    var nextBtn = el.querySelector('.swiper-button-next');
    var prevBtn = el.querySelector('.swiper-button-prev');

    var sw = new Swiper(el, {
      slidesPerView: 'auto',
      spaceBetween: 16,
      speed: 250,
      watchOverflow: true,
      navigation: { nextEl: nextBtn, prevEl: prevBtn },
      observer: true,
      observeParents: true
    });

    // webview/font/image safety updates
    setTimeout(function(){ sw.update(); }, 0);
    setTimeout(function(){ sw.update(); }, 300);
  }
</script>
