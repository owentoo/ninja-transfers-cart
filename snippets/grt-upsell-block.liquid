    // ---------------------------
    // Build card swatch strip from modal's pre-rendered color data
    // ---------------------------
    function buildCardSwatchesFromModal($item) {
      var $dlg = $item.find("dialog.grt-product-modal").first();
      // Dialog may not be rendered yet (lazy) — that's fine; embedded JSON doesn't need it
      var $variantBlock = $dlg.length ? $dlg.find("[data-variant-options]").first() : $();
      var isPdpFlow = $variantBlock.length && $variantBlock.attr("data-use-pdp-color-flow") === "1";
      var colors = [];

      // First try: embedded color JSON (reliable for parent-child flow products)
      var $cardColorJson = $item.find("[data-card-color-json]").first();
      if ($cardColorJson.length) {
        try {
          var parsedColors = JSON.parse($cardColorJson.text() || "[]");
          if (Array.isArray(parsedColors)) {
            var seenCardKeys = {};
            parsedColors.forEach(function (c) {
              var key  = String(c.key  || "").toLowerCase().trim();
              var name = String(c.name || "").trim();
              var hex  = String(c.hex  || "").trim();
              if (!key || !name || seenCardKeys[key]) return;
              seenCardKeys[key] = true;
              if (!hex || hex === "0") hex = "#888888";
              if (hex.charAt(0) !== "#") hex = "#" + hex;
              colors.push({ key: key, name: name, hex: hex,
                vid: String(c.vid || ""),
                img: c.img ? String(c.img) : "",
                price: c.price || 0,
                compare: c.compare || 0 });
            });
          }
        } catch (e) {}
      }

      // Second try: for pdp flow, read pre-rendered [data-pdp-color-key] pills
      if (colors.length < 2 && isPdpFlow) {
        $dlg.find("[data-pdp-color-key]").each(function () {
          var $pill = $(this);
          var key  = ($pill.attr("data-pdp-color-key") || "").toLowerCase().trim();
          var name = ($pill.attr("data-pdp-color-name") || "").trim();
          var hex  = ($pill.attr("data-pdp-color-hex") || "").trim();
          var vid  = ($pill.attr("data-pdp-color-variant-id") || "").trim();
          if (!key || !name) return;
          if (!hex || hex === "0") hex = "#888888";
          if (hex.charAt(0) !== "#") hex = "#" + hex;
          colors.push({ key: key, name: name, hex: hex, vid: vid, img: "", price: 0, compare: 0 });
        });
      }

      // Third try: normal flow — read from [data-variants-json] + [data-color-map-json]
      // Only runs when a swatch option index is explicitly set (prevents size-only products from showing fake swatches)
      if (colors.length < 2 && !isPdpFlow && $variantBlock.length) {
        var swatchIdx = parseInt($variantBlock.attr("data-swatch-option-index") || "-1", 10);
        if (swatchIdx < 0) { /* no designated color option — skip card swatch rendering */ }
        else {
        var variantsData = [];
        var $varJson = $dlg.find("[data-variants-json]").first();
        if ($varJson.length) { try { variantsData = JSON.parse($varJson.text()); } catch (e) {} }
        var optKey = "option" + (swatchIdx + 1);
        // Read hex directly from color-map-json (available at page load without applyColorSwatches)
        var colorMap = getColorMapFromBlock($variantBlock);
        var seenKeys = {};
        variantsData.forEach(function (vr) {
          var name = String(vr[optKey] || "").trim();
          var key  = name.toLowerCase();
          if (!key || seenKeys[key]) return;
          seenKeys[key] = true;
          var hex = String(colorMap[key] || "").trim();
          if (!hex || hex === "0") hex = "#888888";
          if (hex.charAt(0) !== "#") hex = "#" + hex;
          colors.push({ key: key, name: name, hex: hex, vid: String(vr.id || ""), img: String(vr.image || ""), price: vr.price || 0, compare: vr.compare_at_price || 0 });
        });
        } // end else (swatchIdx >= 0)
      }

      if (colors.length < 2) return;

      // Sort in the same HSL hue order as the modal's sortPdpColorPills
      colors.forEach(function (c) {
        var hsl = pdpHsl(c.hex || "#888888");
        c._h = hsl[0]; c._s = hsl[1] / 100; c._l = hsl[2];
      });
      colors.sort(function (a, b) {
        var gA = a._s < 0.15 ? 0 : Math.floor(a._h / 24) + 1;
        var gB = b._s < 0.15 ? 0 : Math.floor(b._h / 24) + 1;
        if (gA !== gB) return gA - gB;
        return b._l - a._l;
      });

      var $wrap = $item.find("[data-card-swatches]").first();
      $wrap.empty();

      var MAX = 8;
      var shown = Math.min(colors.length, MAX);
      // Use the server-side total (all colors incl. out-of-stock) for accurate +X count
      var totalColors = parseInt($cardColorJson.attr("data-card-color-total") || "0", 10) || colors.length;
      var remaining = totalColors - shown;

      for (var i = 0; i < shown; i++) {
        var c = colors[i];
        var $btn = $('<button class="grt-card-swatch" type="button"></button>');
        if (i === 0) $btn.addClass("is-active");
        $btn.attr({ "data-swatch-key": c.key, "data-swatch-name": c.name, "data-swatch-hex": c.hex,
          "data-swatch-vid": c.vid, "data-swatch-price": String(c.price), "data-swatch-compare": String(c.compare),
          "data-swatch-img": c.img, "title": c.name });
        $btn[0].style.setProperty("--swatch-color", c.hex);
        $wrap.append($btn);
      }
      if (remaining > 0) {
        $wrap.append($('<span class="grt-card-swatch-more">+' + remaining + '</span>'));
      }
      $wrap.show();
    }

    // Build swatches for all cards on init
    $root.find("[data-upsell-item]").each(function () {
      buildCardSwatchesFromModal($(this));
    });

    // Wrap Yotpo review count in parens and strip "Reviews" word — e.g. "1089 Reviews" → "(1089)"
    function stripYotpoReviewsWord() {
      $root.find(".yotpo-sr-bottom-line-text--right-panel").each(function () {
        var $el = $(this);
        var txt = $el.text().trim();
        if (!txt) return; // not rendered yet
        // Strip existing parens and "Reviews" word to get the raw number
        var num = txt.replace(/[()]/g, "").replace(/\s*[Rr]eview[s]?/g, "").trim();
        if (!num) return;
        var target = "(" + num + ")";
        if (txt !== target) {
          $el.text(target);
        }
      });
    }
    // Poll for up to 8s to catch async Yotpo rendering and re-renders
    var _yotpoStripTimer = setInterval(stripYotpoReviewsWord, 400);
    setTimeout(function() { clearInterval(_yotpoStripTimer); }, 8000);

    // ---------------------------
    // Card color swatch strip
    // ---------------------------
    $root.on("click", ".grt-card-swatch", function (e) {
      e.preventDefault();
      e.stopPropagation(); // prevent card click from opening modal

      var $swatch = $(this);
      var $item   = $swatch.closest("[data-upsell-item]");
      if (!$item.length) return;

      // Mark active
      $item.find(".grt-card-swatch").removeClass("is-active");
      $swatch.addClass("is-active");

      var vid     = $swatch.attr("data-swatch-vid");
      var img     = $swatch.attr("data-swatch-img");
      var price   = parseInt($swatch.attr("data-swatch-price")   || "0", 10);
      var compare = parseInt($swatch.attr("data-swatch-compare") || "0", 10);
      var colorKey  = $swatch.attr("data-swatch-key");
      var colorName = $swatch.attr("data-swatch-name");

      // Update preview image on card
      var $cardImg = $item.find(".grt-product-card__main-image img");
      if (img && $cardImg.length) {
        // Image URL baked into swatch data — clear srcset so browser actually uses new src
        $cardImg.removeAttr("srcset").removeAttr("sizes").attr("src", img);
      } else if ($cardImg.length) {
        // No baked image — fetch via the same API the modal uses
        var pdpHandle = ($item.attr("data-card-pdp-handle") || "").trim();
        var cacheKey  = pdpHandle + "::" + colorName;
        if (cardImageCache[cacheKey]) {
          $cardImg.removeAttr("srcset").removeAttr("sizes").attr("src", cardImageCache[cacheKey]);
        } else if (pdpHandle && colorName) {
          var $imgTarget = $cardImg;
          requestPdpColorData(pdpHandle, colorName)
            .then(function (payload) {
              if (!payload) return;
              var src = "";
              // Try mainImgs (same as modal image update path)
              if (payload.mainImgs && payload.mainImgs.length) {
                try {
                  var slideHtml = (payload.mainImgs[0].slide || "");
                  var $si = $("<div>" + slideHtml + "</div>").find("img").first();
                  src = $si.attr("src") || "";
                } catch (e) {}
              }
              if (src) {
                cardImageCache[cacheKey] = src;
                $imgTarget.removeAttr("srcset").removeAttr("sizes").attr("src", src);
              }
            })
            .catch(function () {});
        }
      }

      // Update price on card — use .html() because formatMoney may return HTML (e.g. <span class=money>)
      $item.find(".grt-product-card__price-now").html(formatMoney(price));
      var $cmp = $item.find(".grt-product-card__price-compare");
      if (compare && compare > price) {
        if ($cmp.length) $cmp.html(formatMoney(compare)).show();
        else $item.find(".grt-product-card__price-now").after('<span class="grt-product-card__price-compare">' + formatMoney(compare) + '</span>');
      } else {
        $cmp.hide();
      }

      // Store selected variant + color so modal opens to correct color
      $item.find("[data-open-modal]").attr("data-vid", vid);
      $item.attr("data-selected-card-color-key", colorKey);
      $item.attr("data-selected-card-color-name", colorName);
    });

