          if (!itemId || seenRowKeys["id:" + itemId]) return;
          seenRowKeys["id:" + itemId] = true;

          var max = parseInt($inp.attr("data-max") || "0", 10);
          if (isNaN(max)) max = 0;

          var basePrice = parseInt($inp.attr("data-price") || "0", 10);
          if (isNaN(basePrice) || basePrice < 0) basePrice = 0;

          var tierPricing = String($inp.attr("data-tiers") || "").trim();
          var sizeLabel = $.trim($inp.closest(".variant-price-2").find("label").first().text());
          if (!sizeLabel) sizeLabel = "Size";

          rows.push({
            id: itemId,
            size: sizeLabel,
            basePrice: basePrice,
            tierPricing: tierPricing,
            max: max,
            isOut: false
          });
        });
      }

      var html = "";
      var hasPurchasableRows = false;
      var lowestBasePrice = 0;
      for (var i = 0; i < rows.length; i++) {
        var row = rows[i];
        var hasInput = !row.isOut && !!row.id;
        var retailPrice = Math.round(row.basePrice * RETAIL_PRICE_MULTIPLIER);
        if (hasInput && row.basePrice > 0 && (!lowestBasePrice || row.basePrice < lowestBasePrice)) {
          lowestBasePrice = row.basePrice;
        }
        html += '<div class="grt-size-qty-row grt-size-qty-row--pdp' + (hasInput ? "" : " is-out") + '" data-size-row data-base-price="' + row.basePrice + '" data-tier-pricing="' + htmlEscape(row.tierPricing) + '">';
        html += '<div class="grt-size-qty-row__size"><span class="grt-size-qty-row__v">' + htmlEscape(row.size) + '</span></div>';
        html += '<div class="grt-size-qty-row__qty">';
        if (hasInput) {
          html += '<div class="grt-size-qty-wrap"><input class="grt-size-qty-input grt-pdp-size-qty-input" data-pdp-size-qty-input type="number" min="0" max="' + row.max + '" value="" data-id="' + row.id + '" data-base-price="' + row.basePrice + '" data-tier-pricing="' + htmlEscape(row.tierPricing) + '" data-max="' + row.max + '" aria-label="Quantity for size ' + htmlEscape(row.size) + '"><div class="grt-size-qty-spinners"><button type="button" class="grt-size-qty-spin grt-size-qty-spin--up" tabindex="-1" aria-label="Increase quantity">&#9650;</button><button type="button" class="grt-size-qty-spin grt-size-qty-spin--dn" tabindex="-1" aria-label="Decrease quantity">&#9660;</button></div></div>';
          hasPurchasableRows = true;
        } else {
          html += '<div class="grt-size-qty-row__out">OUT</div>';
        }
        html += '</div>';
        if (hasInput) {
          html += '<div class="grt-size-qty-row__price-wrap"><div class="grt-size-qty-row__compare" data-size-compare-price>' + formatMoney(retailPrice) + '</div><div class="grt-size-qty-row__price" data-size-unit-price>' + formatMoney(row.basePrice) + '</div></div>';
        } else {
          html += '<div class="grt-size-qty-row__price-wrap"></div>';
        }
        html += "</div>";
      }

      $pdpGrid.css("min-height", ""); // Release height lock now that real content is ready
      $pdpGrid.html(html);
      var hasRows = rows.length > 0;
      if (hasRows) {
        $pdpGrid.show();
        if (lowestBasePrice > 0) {
          updateModalHeadlinePrice($dlg, lowestBasePrice, Math.round(lowestBasePrice * RETAIL_PRICE_MULTIPLIER));
        }
        schedulePdpSizeGridPriceRefresh($dlg);
      } else {
        $pdpGrid.hide();
      }

      if ($form.length) {
        var $addBtn = $form.find(".grt-product-modal__add-button").first();
        if ($addBtn.length) $addBtn.prop("disabled", !hasPurchasableRows);
      }

      var selectedVariantId = String($block.attr("data-selected-pdp-color-variant-id") || "").trim();
      if (selectedVariantId) {
        fetchPdpVariantImage($block, selectedVariantId);
      } else if (payload && payload.mainImgs && payload.mainImgs.length) {
        try {
          var firstSlide = payload.mainImgs[0];
          var slideHtml = firstSlide && firstSlide.slide ? String(firstSlide.slide) : "";
          var $imgEl = $("<div>" + slideHtml + "</div>").find("img").first();
          var src = $imgEl.attr("src");
          if (src) {
            $dlg.find("[data-modal-image]").first().attr("src", src);
          }
        } catch (e) {}
      }
    }

    function fetchPdpColorData($block, colorValue) {
      if (!$block.length || !colorValue) return Promise.resolve(null);
      var handle = String($block.attr("data-pdp-product-handle") || "").trim();
      if (!handle) return Promise.resolve(null);

      var requestId = String(Date.now()) + "-" + Math.random().toString(36).slice(2);
      $block.attr("data-pdp-request-id", requestId);

      var $dlg = $block.closest("dialog.grt-product-modal");
      var $form = $block.closest("form.grt-product-modal__form");
      var $pdpGrid = $dlg.find("[data-pdp-size-grid]").first();
      if ($pdpGrid.length) {
        // Lock current height before skeleton swap so modal doesn't reflow/flicker
        if ($pdpGrid.is(":visible")) {
          $pdpGrid.css("min-height", $pdpGrid.outerHeight() + "px");
        }
        $pdpGrid.html(buildPdpSizeSkeletonHtml()).show();
      }
      if ($form.length) {
        var $addBtn = $form.find(".grt-product-modal__add-button").first();
        if ($addBtn.length) $addBtn.prop("disabled", true);
      }

      var colorOptionValueId = String($block.attr("data-selected-pdp-color-option-value-id") || "").trim();
      return requestPdpColorData(handle, colorValue, { colorOptionValueId: colorOptionValueId })
        .then(function (data) {
          if ($block.attr("data-pdp-request-id") !== requestId) return;
          renderPdpColorSizes($block, data || {});
          return data || {};
        })
        .catch(function (error) {
          if ($block.attr("data-pdp-request-id") !== requestId) return;
          var $sizeGrid = $dlg.find("[data-pdp-size-grid]").first();
          if ($sizeGrid.length) $sizeGrid.hide().empty();
          if ($form.length) {
            var $addBtn = $form.find(".grt-product-modal__add-button").first();
            if ($addBtn.length) $addBtn.prop("disabled", true);
          }
          throw error;
        });
    }

    function getInitialPdpColorPill($block) {
      if (!$block.length) return $();
      var selectedKey = String($block.attr("data-pdp-selected-color-key") || "").trim().toLowerCase();
      var $selected = $();
      if (selectedKey) {
        $selected = $block.find('[data-pdp-color-key="' + cssEscape(selectedKey) + '"]').first();
      }
      if (!$selected.length) {
        $selected = $block.find("[data-pdp-color-key]").first();
      }
      return $selected;
    }

    function getPdpColorFetchValue($pill) {
      if (!$pill || !$pill.length) return "";
      var colorName = String($pill.attr("data-pdp-color-name") || "").trim();
      var colorQuery = String($pill.attr("data-pdp-color-query") || "").trim();
      var colorVariantId = String($pill.attr("data-pdp-color-variant-id") || "").trim();
      if (!colorQuery) colorQuery = colorName;
      if (!colorQuery) return "";
      if (colorVariantId) return colorQuery + "_" + colorVariantId;
      return colorQuery;
    }

    function prefetchInitialPdpColorData($block) {
      return;
    }

    function fetchPdpVariantImage($block, variantId) {
      if (!$block.length || !variantId) return;
      var cleanVariantId = String(variantId || "").trim();
      if (!cleanVariantId) return;

      var imageRequestId = String(Date.now()) + "-" + Math.random().toString(36).slice(2);
      $block.attr("data-pdp-image-request-id", imageRequestId);

      var imageUrl = "/variants/" + encodeURIComponent(cleanVariantId) + ".js";
      getRequest(imageUrl)
        .then(function (data) {
          if ($block.attr("data-pdp-image-request-id") !== imageRequestId) return;
          if (!data) return;

          var src = "";
          if (data.featured_image && data.featured_image.src) {
            src = String(data.featured_image.src);
          } else if (
            data.featured_media &&
            data.featured_media.preview_image &&
            data.featured_media.preview_image.src
          ) {
            src = String(data.featured_media.preview_image.src);
          }
          if (!src) return;

          var $dlg = $block.closest("dialog.grt-product-modal");
          if (!$dlg.length) return;
          var $img = $dlg.find("[data-modal-image]").first();
          if ($img.length) {
            $img.attr("src", src);
          }
        })
        .catch(function () {});
    }

    function setPdpSelectedColorLabel($block, colorName, chipValue) {
      if (!$block.length) return;
      var $selectedColorLabel = $block.find("[data-pdp-selected-color-label]").first();
      if (!$selectedColorLabel.length) return;
      var displayColor = String(colorName || "").trim();
      var $selectedColorChip = $selectedColorLabel.find("[data-pdp-selected-color-chip]").first();
      if ($selectedColorChip.length) {
        var resolvedChipValue = String(chipValue || "").trim();
        if (resolvedChipValue) {
          $selectedColorChip.css("--grt-pdp-selected-color-chip", resolvedChipValue).addClass("is-visible");
        } else {
          $selectedColorChip.css("--grt-pdp-selected-color-chip", "").removeClass("is-visible");
        }
      }
      var labelText = displayColor ? displayColor.toLowerCase() : "-";
      var $selectedColorText = $selectedColorLabel.find("[data-pdp-selected-color-text]").first();
      if ($selectedColorText.length) {
        $selectedColorText.text(labelText);
      } else {
        $selectedColorLabel.append(document.createTextNode(labelText));
      }
      // Keep mobile trigger in sync
      updateMobileColorTrigger($block, displayColor, String(chipValue || "").trim());
    }

    function restorePdpSelectedColorLabel($block) {
      if (!$block.length) return;
      var selectedColor = String($block.attr("data-selected-pdp-color") || "").trim();
      var $selectedPill = getInitialPdpColorPill($block);
      var selectedChipValue = "";
      if ($selectedPill.length) {
        selectedChipValue = String($selectedPill[0].style.getPropertyValue("--grt-pdp-color-chip") || "").trim();
      }
      setPdpSelectedColorLabel($block, selectedColor, selectedChipValue);
    }

    function applyPdpColorSelection($block, $pill) {
      if (!$block.length || !$pill.length) return;
      if ($block.attr("data-use-pdp-color-flow") !== "1") return;

      var colorKey = String($pill.attr("data-pdp-color-key") || "").trim().toLowerCase();
      var colorName = String($pill.attr("data-pdp-color-name") || "").trim();
      var colorQuery = String($pill.attr("data-pdp-color-query") || "").trim();
      var colorOptionValueId = String($pill.attr("data-pdp-color-option-value-id") || "").trim();
      var colorVariantId = String($pill.attr("data-pdp-color-variant-id") || "").trim();
      if (!colorQuery) colorQuery = colorName;
      if (!colorKey || !colorName) return;

      $block.attr("data-pdp-selected-color-key", colorKey);
      $block.attr("data-selected-pdp-color", colorName);
      $block.attr("data-selected-pdp-color-query", colorQuery);
      if (colorOptionValueId) {
        $block.attr("data-selected-pdp-color-option-value-id", colorOptionValueId);
      } else {
        $block.removeAttr("data-selected-pdp-color-option-value-id");
      }
      if (colorVariantId) {
        $block.attr("data-selected-pdp-color-variant-id", colorVariantId);
      } else {
        $block.removeAttr("data-selected-pdp-color-variant-id");
      }
      var selectedChipValue = String($pill[0].style.getPropertyValue("--grt-pdp-color-chip") || "").trim();
      setPdpSelectedColorLabel($block, colorName, selectedChipValue);
      var $form = $block.closest("form.grt-product-modal__form");
      if ($form.length) {
        $form.attr("data-selected-color", colorName);
      }

      setPdpColorButtonState($block, $pill);
      var fetchColorValue = colorQuery;
      if (colorVariantId) {
        fetchColorValue = colorQuery + "_" + colorVariantId;
        fetchPdpVariantImage($block, colorVariantId);
      }
      var fetchPromise = fetchPdpColorData($block, fetchColorValue);
      schedulePdpColorRowsLimit($block);
      return fetchPromise;
    }

    function initPdpColorFlow($block) {
      if (!$block.length) return Promise.resolve(null);
      if ($block.attr("data-use-pdp-color-flow") !== "1") return Promise.resolve(null);

      sortPdpColorPills($block);
      buildMobileColorDropdown($block);

      var $selected = getInitialPdpColorPill($block);
      if (!$selected.length) return Promise.resolve(null);

      return applyPdpColorSelection($block, $selected);
    }

    function resetInitialPdpColorSelection($block) {
      if (!$block.length) return;
      var initialColorKey = String($block.attr("data-pdp-initial-color-key") || "").trim();
      var initialColorName = String($block.attr("data-pdp-initial-color-name") || "").trim();
      if (initialColorKey) $block.attr("data-pdp-selected-color-key", initialColorKey);
      if (initialColorName) {
        $block.attr("data-selected-pdp-color", initialColorName);
      } else {
        $block.removeAttr("data-selected-pdp-color");
      }
    }

    function finalizeUpsellModalOpen($dlg, $btn, options) {
      var dlg = $dlg[0];
      if (!dlg || !dlg.showModal) return;
      options = options || {};

      lockPageScroll();
      dlg.showModal();
      if (!options.keepOpeningState) {
        $dlg.removeClass("is-opening");
      }

      var $qty = $dlg.find("[data-qty-input]").first();
      if ($qty.length) $qty.val(1);

      var $variantBlock = $dlg.find("[data-variant-options]").first();
      if ($variantBlock.length) {
        if ($variantBlock.attr("data-use-pdp-color-flow") === "1") {
          if (!options.parentChildReady && !options.deferParentChildInit) {
            resetInitialPdpColorSelection($variantBlock);
            initPdpColorFlow($variantBlock).then(function () {
              updateSelectedColorName($variantBlock);
              setTimeout(function () {
                $dlg.find(".grt-swatch-pills, .grt-opt__pills--pdp-colors").each(function () { initSwatchMask(this); });
              }, 60);
            });
          }
          if (!options.deferParentChildInit) {
            buildSizeQtyGrid($dlg);
            schedulePdpColorRowsLimit($variantBlock);
          }
        } else {
          applyColorSwatches($variantBlock);
          scheduleColorRowsLimit($variantBlock);
          buildSizeQtyGrid($dlg);
          setTimeout(function () {
            $dlg.find(".grt-swatch-pills, .grt-opt__pills--pdp-colors").each(function () { initSwatchMask(this); });
          }, 60);
        }
      }

      setTimeout(function () {
        var $f = $dlg.find(".grt-product-modal__form");
        if ($f.find("#bcpo").length) $f.find("#bcpo").remove();
      }, 250);

      setTimeout(function () {
        var $form = $dlg.find("form.grt-product-modal__form").first();
        var startVid =
          ($btn.attr("data-vid") || "").trim() ||
          ($dlg.attr("data-default-vid") || "").trim() ||
          ($form.attr("data-initial-variant") || "").trim();

        var $block = $dlg.find("[data-variant-options]").first();
        if (!$block.length) return;
        if ($block.attr("data-use-pdp-color-flow") === "1") {
          if ($form.length) $form.removeAttr("data-variant-id");
        } else {
          if ($form.length && startVid) $form.attr("data-variant-id", String(startVid));
          if (startVid) applyVariantIdToModal($dlg, startVid);
          else syncVariantFromSelection($block);
        }
      }, 0);
    }

    function applyPdpColorRowsLimit($block) {
      if (!$block.length) return;
      if ($block.attr("data-use-pdp-color-flow") !== "1") return;

      var $wrap = $block.find("[data-pdp-color-options]").first();
      if (!$wrap.length) return;

      var $opt = $wrap.closest(".grt-opt");
      $opt.find("[data-grt-pdp-color-toggle]").remove();
      $opt.removeClass("is-color-expanded");
      $wrap.find(".grt-pdp-color-pill-hidden").removeClass("grt-pdp-color-pill-hidden");
    }

    function schedulePdpColorRowsLimit($block) {
      if (!$block || !$block.length) return;
      setTimeout(function () {
        applyPdpColorRowsLimit($block);
      }, 0);
    }

    function getColorOptionIndex($block) {
      var idx = parseInt(
        $block.attr("data-color-option-index") ||
        $block.attr("data-swatch-option-index") ||
        "",
        10
      );
      return isNaN(idx) ? -1 : idx;
    }

    function applyColorRowsLimit($block) {
      if (!$block.length) return;
      var colorOptionIndex = getColorOptionIndex($block);
      if (colorOptionIndex < 0) return;

      var $wrap = $block.find('.grt-opt__pills[data-option-index="' + colorOptionIndex + '"]').first();
      if (!$wrap.length) return;

      var $opt = $wrap.closest(".grt-opt");
      $opt.find("[data-grt-color-toggle]").remove();
      $opt.removeClass("is-color-expanded");
      $wrap.find(".grt-color-pill-hidden").removeClass("grt-color-pill-hidden");

      var $pills = $wrap.find(".grt-variant-pill:visible");
      var totalColors = $pills.length;
      if (!totalColors) return;

      var maxRows = 2;
      if (window.matchMedia && window.matchMedia("(max-width: 749px)").matches) {
        maxRows = 4;
      }

      var rowTops = [];
      var hiddenStartTop = null;

      $pills.each(function () {
        var top = Math.round($(this).position().top || 0);
        var exists = false;
        for (var i = 0; i < rowTops.length; i++) {
          if (Math.abs(rowTops[i] - top) <= 2) {
            exists = true;
            break;
          }
        }
        if (!exists) {
          rowTops.push(top);
          if (rowTops.length === (maxRows + 1)) {
            hiddenStartTop = top;
            return false;
          }
        }
      });

      if (hiddenStartTop == null) return;

      var hiddenCount = 0;
      $pills.each(function () {
        var top = Math.round($(this).position().top || 0);
        if (top >= hiddenStartTop - 1) {
          $(this).addClass("grt-color-pill-hidden");
          hiddenCount++;
        }
      });

      if (hiddenCount > 0) {
        $opt.append(
          '<button type="button" class="grt-color-see-all button" data-grt-color-toggle data-total-colors="' + totalColors + '">' +
            'See all ' + totalColors + ' colors' +
          '</button>'
        );
      }
    }

    function scheduleColorRowsLimit($block) {
      if (!$block || !$block.length) return;
      setTimeout(function () {
        //applyColorRowsLimit($block);
      }, 0);
    }

    var RETAIL_PRICE_MULTIPLIER = 1.96;
    var FIXED_SAVE_PERCENT = 49;
    var sizeGridRefreshTimer = null;
    var toastTimer = null;

    function htmlEscape(str) {
      return String(str == null ? "" : str)
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    function getOptionKeyFromIndex(optionIndex) {
      return "option" + (optionIndex + 1);
    }

    function getSelectedOptionValue($block, optionIndex) {
      var $pill = $block.find('.grt-variant-pill.is-active[data-option-index="' + optionIndex + '"]').first();
      if (!$pill.length) return "";
      return ($pill.attr("data-option-value") || "").toString().trim();
    }

    function getTierLevel(virtualTotal) {
      if (virtualTotal >= 3800) return 7;
      if (virtualTotal >= 1750) return 6;
      if (virtualTotal >= 1000) return 5;
      if (virtualTotal >= 500) return 4;
      if (virtualTotal >= 250) return 3;
      if (virtualTotal >= 150) return 2;
      if (virtualTotal >= 99) return 1;
      return 0;
    }

    function parseTierPricing(tierPricingRaw) {
      if (!tierPricingRaw) return [];
      var tierBreaks = [99, 150, 250, 500, 1000, 1750, 3800];

      function normalize(values) {
        if (!values || !values.length) return [];
        return values
          .map(function (v) { return parseInt(String(v).trim(), 10); })
          .filter(function (n) { return !isNaN(n) && n > 0; });
      }

      if (Array.isArray(tierPricingRaw)) {
        return normalize(tierPricingRaw);
      }

      if (typeof tierPricingRaw === "object") {
        var objectTiers = [];
        for (var i = 0; i < tierBreaks.length; i++) {
          var key = String(tierBreaks[i]);
          if (tierPricingRaw[key] != null) objectTiers.push(tierPricingRaw[key]);
        }
        if (objectTiers.length) return normalize(objectTiers);
        return normalize(Object.keys(tierPricingRaw).map(function (k) { return tierPricingRaw[k]; }));
      }

      var raw = String(tierPricingRaw).trim();
      if (!raw) return [];

      try {
        var parsed = JSON.parse(raw);
        if (Array.isArray(parsed)) return normalize(parsed);
        if (parsed && typeof parsed === "object") {
          var parsedTiers = [];
          for (var j = 0; j < tierBreaks.length; j++) {
            var parsedKey = String(tierBreaks[j]);
            if (parsed[parsedKey] != null) parsedTiers.push(parsed[parsedKey]);
          }
          if (parsedTiers.length) return normalize(parsedTiers);
          return normalize(Object.keys(parsed).map(function (k) { return parsed[k]; }));
        }
      } catch (e) {}

      if (raw.indexOf(":") > -1) {
        var valueMatches = raw.match(/:\s*"?([0-9]+)"?/g) || [];
        if (valueMatches.length) {
          return normalize(
            valueMatches.map(function (chunk) {
              var parts = chunk.split(":");
              return parts.length > 1 ? parts[1].replace(/"/g, "").trim() : "";
            })
          );
        }
      }

      return normalize(raw.split(","));
    }

    function getTierPrice(basePrice, tierPricingRaw, tierLevel) {
      var tiers = parseTierPricing(tierPricingRaw);
      if (tierLevel > 0 && tiers.length >= tierLevel) return tiers[tierLevel - 1];
      return basePrice;
    }

    function getCartTotalPrice() {
      return fetch("/cart.js")
        .then(function (response) { return response.json(); })
        .then(function (data) {
          var total = parseInt((data && data.total_price) || 0, 10);
          return isNaN(total) ? 0 : total;
        })
        .catch(function () { return 0; });
    }

    function buildSizeQtyGrid($dlg) {
      if (!$dlg.length) return;

      var $variantBlock = $dlg.find("[data-variant-options]").first();
      var $sizeParentLabel = $dlg.find("[data-size-qty-parent-label]").first();
      var $pdpSizeGrid = $dlg.find("[data-pdp-size-grid]").first();
      var $sizeGrid = $dlg.find("[data-size-qty-grid]").first();
      var $qtyWrap = $dlg.find("[data-qty-wrap]").first();
      if (!$variantBlock.length || !$sizeGrid.length) return;

      var variantFlow = String($variantBlock.attr("data-variant-flow") || "").trim();
      var sizeOptionIndex = parseInt($variantBlock.attr("data-size-option-index") || "", 10);
      var $sizeOpt = $();
      if (!isNaN(sizeOptionIndex) && sizeOptionIndex >= 0) {
        $sizeOpt = $variantBlock.find('.grt-opt__pills[data-option-index="' + sizeOptionIndex + '"]').closest(".grt-opt");
      }

      if (variantFlow === "normal") {
        if ($pdpSizeGrid.length) $pdpSizeGrid.hide().empty();
        if ($sizeGrid.length) $sizeGrid.empty().hide();
        if ($sizeOpt.length) $sizeOpt.show();
        if ($sizeParentLabel.length) $sizeParentLabel.hide();
        if ($qtyWrap.length) $qtyWrap.show();
        return;
      }

      if ($variantBlock.attr("data-use-pdp-color-flow") === "1") {
        if (!isNaN(sizeOptionIndex) && sizeOptionIndex >= 0) {
          $variantBlock
            .find('.grt-opt__pills[data-option-index="' + sizeOptionIndex + '"]')
            .closest(".grt-opt")
            .hide();
        }
        if ($sizeGrid.length) $sizeGrid.empty().hide();
        if ($qtyWrap.length) $qtyWrap.hide();
        if ($sizeParentLabel.length) $sizeParentLabel.text("Choose Size(s)").show();
        if (
          $pdpSizeGrid.length &&
          (
            $pdpSizeGrid.find("[data-pdp-size-qty-input]").length ||
            $pdpSizeGrid.find("[data-size-row]").length ||
            $pdpSizeGrid.find(".itemQuantity").length
          )
        ) {
          $pdpSizeGrid.show();
        }
        return;
      }

      if ($pdpSizeGrid.length) {
        $pdpSizeGrid.hide().empty();
      }

      if (isNaN(sizeOptionIndex) || sizeOptionIndex < 0) {
        if ($sizeOpt.length) $sizeOpt.show();
        if ($sizeParentLabel.length) $sizeParentLabel.hide();
        $sizeGrid.empty().hide();
        if ($qtyWrap.length) $qtyWrap.show();
        return;
      }

      var colorOptionIndex = parseInt($variantBlock.attr("data-color-option-index") || "", 10);
      var selectedColor = "";
      if (!isNaN(colorOptionIndex) && colorOptionIndex >= 0) {
        selectedColor = getSelectedOptionValue($variantBlock, colorOptionIndex);
      }
      if (!selectedColor) {
        selectedColor = String($variantBlock.attr("data-selected-pdp-color") || "").trim();
      }

      var variants = getVariantsFromBlock($variantBlock);
      var sizeKey = getOptionKeyFromIndex(sizeOptionIndex);
      var colorKey = getOptionKeyFromIndex(colorOptionIndex);
      var seenSizes = {};
      var rows = [];

      for (var i = 0; i < variants.length; i++) {
        var vr = variants[i];
        if (!vr || !vr.available) continue;

        if (selectedColor && !isNaN(colorOptionIndex) && colorOptionIndex >= 0) {
          if (String(vr[colorKey] || "") !== selectedColor) continue;
        }

        var sizeLabel = String(vr[sizeKey] || "").trim();
        if (!sizeLabel || seenSizes[sizeLabel]) continue;
        seenSizes[sizeLabel] = true;

        var inventory = parseInt(vr.inventory || "0", 10);
        if (isNaN(inventory)) inventory = 0;

        rows.push({
          id: String(vr.id),
          size: sizeLabel,
          basePrice: parseInt(vr.price || "0", 10) || 0,
          tierPricing: String(vr.tier_pricing || ""),
          inventory: inventory
        });
      }

      if (!rows.length) {
        if ($sizeOpt.length) $sizeOpt.show();
        if ($sizeParentLabel.length) $sizeParentLabel.hide();
        $sizeGrid.empty().hide();
        if ($qtyWrap.length) $qtyWrap.show();
        return;
      }

      if ($sizeOpt.length) $sizeOpt.hide();
      if ($sizeParentLabel.length) {
        var parentLabelText = $.trim($sizeOpt.find(".grt-product-modal__label").first().text()) || "Variant";
        $sizeParentLabel.text(parentLabelText).show();
      }

      var html = '';
      var lowestBasePrice = 0;

      for (var r = 0; r < rows.length; r++) {
        var row = rows[r];
        var retailPrice = Math.round(row.basePrice * RETAIL_PRICE_MULTIPLIER);
        if (row.basePrice > 0 && (!lowestBasePrice || row.basePrice < lowestBasePrice)) {
          lowestBasePrice = row.basePrice;
        }
        html += '<div class="grt-size-qty-row" data-size-row data-base-price="' + row.basePrice + '" data-tier-pricing="' + htmlEscape(row.tierPricing) + '">';
        html += '<div class="grt-size-qty-row__size"><span class="grt-size-qty-row__v">' + htmlEscape(row.size) + '</span></div>';
        html += '<div class="grt-size-qty-row__qty">';
        html += '<div class="grt-size-qty-wrap"><input class="grt-size-qty-input" data-size-qty-input type="number" min="0" max="' + row.inventory + '" value="" data-id="' + row.id + '" data-base-price="' + row.basePrice + '" data-tier-pricing="' + htmlEscape(row.tierPricing) + '" data-max="' + row.inventory + '" aria-label="Quantity for size ' + htmlEscape(row.size) + '"><div class="grt-size-qty-spinners"><button type="button" class="grt-size-qty-spin grt-size-qty-spin--up" tabindex="-1" aria-label="Increase quantity">&#9650;</button><button type="button" class="grt-size-qty-spin grt-size-qty-spin--dn" tabindex="-1" aria-label="Decrease quantity">&#9660;</button></div></div>';
        html += '</div>';
        html += '<div class="grt-size-qty-row__price-wrap"><div class="grt-size-qty-row__compare" data-size-compare-price>' + formatMoney(retailPrice) + '</div><div class="grt-size-qty-row__price" data-size-unit-price>' + formatMoney(row.basePrice) + '</div></div>';
        //html += '<div class="grt-size-qty-row__save-wrap"><div class="grt-size-qty-row__save" data-size-save>' + FIXED_SAVE_PERCENT + '% off</div></div>';
        html += '</div>';
      }

      $sizeGrid.html(html).show();
      if ($qtyWrap.length) $qtyWrap.hide();
      if (lowestBasePrice > 0) {
        updateModalHeadlinePrice($dlg, lowestBasePrice, Math.round(lowestBasePrice * RETAIL_PRICE_MULTIPLIER));
      }
      updateAddButtonLabel($dlg, 0, 0);
      scheduleSizeGridPriceRefresh($dlg);
    }

    function refreshSizeGridPrices($dlg) {
