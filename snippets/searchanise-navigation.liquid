              class="toggle__title"
              data-js-title=""
              tabindex="0"
              aria-expanded="false"
              role="button"
              aria-controls="toggle-sizechart"
            >
              {{ faqTextArr2[0] }}
              {% assign isHeading = false %}
        {% else %}
