<script>
    const colorData = {};
    {% paginate collection.products by 1000 %}
  {% for product in collection.products %}
    {% if product.metafields.specs.color_data != blank %}
    colorData["{{ product.metafields.specs.shirt_style | downcase }}"] = {{ product.metafields.specs.color_data }};
    {% endif %}
    {% endfor %}
  {% endpaginate %}

    let selectedColor = null;
    function refreshSelectedColor () {
      const urlParts = document.location.pathname.split('/');
      const urlParams = new URLSearchParams(window.location.search);
      const colorParam = urlParams.get('rb_filter_ptag_01afa331fa9ab7fb404d2f26720ea67c');
      if (colorParam) selectedColor = colorParam;
      else selectedColor = urlParts[urlParts.length-1]
    }

    function applySelectedColor () {
      if (selectedColor) {
        $(".snize-view-link").each(function () {
          var $el = $(this);
          const urlParts = $el.attr("href").split("-");
          const style = urlParts[urlParts.length-1];
          const colorStyleData = colorData[style];
          if (colorStyleData) {
            const _colorData = colorStyleData[selectedColor.toLowerCase()];
            if (_colorData) {
              $(".snize-item-image",$el).attr("src","https://cdn.shopify.com/s/files/1/0558/0265/8899/products/" + _colorData.img);
              $el.attr("href","/products/"+_colorData.link);
            }
          }
        })
      }
    }
    refreshSelectedColor();



    let lastUrl = document.location.toString();
    setInterval(function () {
      const currentUrl = document.location.toString();
      if (currentUrl != lastUrl) {
        console.log("URL CHANGED TO " + currentUrl)
        lastUrl = currentUrl;
        refreshSelectedColor();
        applySelectedColor();
      }
    },50)

    ;
</script>
