>
// <![CDATA[
(function(window, undefined) {
  console.log("SEARCHANIZE LOADING")
  
  
    var snize_results = document.getElementById('snize_results');
    if (snize_results != null && snize_results != undefined && snize_results.innerHTML != '') {
        return;
    }
  
    sInterval = setInterval(function() {
      /*
        $("#snize_results .snize-price").each(function () {
          if (!$(this).html().includes("starting at")) $(this).html("starting at " + $(this).html())
        });
      */
      
        var snize_results = document.getElementById('snize_results');
        if (snize_results != null && snize_results != undefined && snize_results.innerHTML != '') {
            clearInterval(sInterval);
            var skeleton_results = document.getElementById('snize_skeleton_results');
            skeleton_results.parentNode.removeChild(skeleton_results);
            var deliveryEstimateContainer = document.querySelector('.deliveryEstimateContainer');            
            if (deliveryEstimateContainer) {
                      deliveryEstimateContainer.style.marginTop = '0';
                      deliveryEstimateContainer.style.marginBottom = '0';
                  if (window.innerWidth <= 992) {
                      // Select the existing containers
                      var deliveryEstimateContainer = document.querySelector('.deliveryEstimateContainer');
                      var mobileFilters = document.querySelector('.snize-main-panel .snize-main-panel-mobile-filters');
                  
                      // Create the new wrapper div
                      var estimateFilterWrap = document.createElement('div');
                      estimateFilterWrap.className = 'estimate__filter--wrap';
                  
                      // Move the deliveryEstimateContainer and mobileFilters into the new wrapper
                      if (deliveryEstimateContainer) {
                          estimateFilterWrap.appendChild(deliveryEstimateContainer);
                      }
                      if (mobileFilters) {
                          estimateFilterWrap.appendChild(mobileFilters);
                      }
                  
                      // Append the new wrapper to the element with class 'snize-main-panel'
                      var snizeMainPanel = document.querySelector('.snize-main-panel');
                      if (snizeMainPanel) {
                          snizeMainPanel.appendChild(estimateFilterWrap);
                      }
                  } else {
                      var snizeCollectionMode = document.querySelector('.snize-collection-mode .snize-horizontal-wrapper');
                      if (snizeCollectionMode) {
                          snizeCollectionMode.insertBefore(deliveryEstimateContainer, snizeCollectionMode.firstChild);
                      }
                  }
            }
    
            var snizeHorizontalLeft = document.querySelector('.snize-horizontal-wrapper .snize-horizontal-left');
            var snizeFiltersSidebar = document.querySelector('.snize-filters-sidebar');

            if (snizeHorizontalLeft && snizeFiltersSidebar) {
                var resultsFound = snizeHorizontalLeft.querySelector('.snize-main-panel-collection-results-found');
                if (resultsFound) {
                    var text = resultsFound.textContent;
                    var index = text.indexOf('for');
                    if (index !== -1) {
                        resultsFound.textContent = text.substring(0, index).trim();
                        snizeFiltersSidebar.insertBefore(snizeHorizontalLeft, snizeFiltersSidebar.firstChild);
                    }
                }
            } 

            function removeAllEventListeners(element) {
              const newElement = element.cloneNode(true);
              element.parentNode.replaceChild(newElement, element);
              return newElement;
            }
            
            document.querySelectorAll(".snize-product-filters-title").forEach((title) => {
              const cleanTitle = removeAllEventListeners(title);
              const nextElement = cleanTitle.nextElementSibling;
              if (nextElement) {
                nextElement.removeAttribute('style');
                nextElement.classList.add('hidden');
              }
            
              cleanTitle.addEventListener("click", () => {
                const targetList = cleanTitle.nextElementSibling;
            
                document.querySelectorAll(".snize-product-filters-title").forEach((otherTitle) => {
                  const otherList = otherTitle.nextElementSibling;
            
                  // Reset other titles
                  if (otherTitle !== cleanTitle) {
                    otherTitle.classList.remove("open"); 
                    if (otherList) {
                      otherList.classList.remove("visible");
                      otherList.classList.add("hidden"); 
                    }
                  }
                });
            
                if (targetList.classList.contains("visible")) {
                  targetList.classList.remove("visible");
                  targetList.classList.add("hidden");
                  cleanTitle.classList.remove("open");
                } else {
                  targetList.classList.remove("hidden");
                  targetList.classList.add("visible");
                  cleanTitle.classList.add("open");
                }
              });
            });
          
          
            return;
        }
        var grid_wrapper = document.getElementById('snize-search-results-wrapper');
        if (grid_wrapper.offsetWidth >= 1055) {
            grid_wrapper.className = grid_wrapper.className.replace(/(?:^|\s)snize-three-columns(?!\S)/g , '').replace(/(?:^|\s)snize-four-columns(?!\S)/g , '');
            if (!grid_wrapper.className.match(/(?:^|\s)snize-five-columns(?!\S)/)) {
                grid_wrapper.className += ' snize-five-columns';
            }
        } else if (grid_wrapper.offsetWidth >= 915) {
            grid_wrapper.className = grid_wrapper.className.replace(/(?:^|\s)snize-three-columns(?!\S)/g , '').replace(/(?:^|\s)snize-five-columns(?!\S)/g , '');
            if (!grid_wrapper.className.match(/(?:^|\s)snize-four-columns(?!\S)/)) {
                grid_wrapper.className += ' snize-four-columns';
            }
        } else {
            grid_wrapper.className = grid_wrapper.className.replace(/(?:^|\s)snize-four-columns(?!\S)/g , '').replace(/(?:^|\s)snize-five-columns(?!\S)/g , '');
            if (!grid_wrapper.className.match(/(?:^|\s)snize-three-columns(?!\S)/)) {
                grid_wrapper.className += ' snize-three-columns';
            }
        }        
    }, 30);
    setInterval(function () {
        let foundProductCardToUpdate = false;
        $("#snize_results .snize-view-link").each(function () {
            const $productCard = $(this);
            if (!$productCard.hasClass("view-altered")) {
                $productCard.addClass("view-altered");
                foundProductCardToUpdate = true;
                const title = $(".snize-title", $productCard).text();
                const price = $(".snize-price", $productCard).text();
                const hrefArr = $productCard.attr("href").split("-");
                const style = hrefArr[hrefArr.length - 1];
    
                let $offsetParent = $($productCard[0].offsetParent);
                let snizeItemData;
                let vendorImageHtml = '';
                let vendorImageExists = false;
                for (let prop in $offsetParent[0]) {
                    if ($offsetParent[0].hasOwnProperty(prop) && $offsetParent[0][prop] && $offsetParent[0][prop].snize_item_data) {
                        snizeItemData = $offsetParent[0][prop].snize_item_data;
                        break;
                    }
                }
    
                function imageExists(url, callback) {
                    const img = new Image();
                    img.onload = () => callback(true);
                    img.onerror = () => callback(false);
                    img.src = url;
                }
    
                function formatVendorName(vendor) {
                    let formattedVendor = vendor.toLowerCase();
                    formattedVendor = formattedVendor.replace(/[\s+]+/g, '_');
                    formattedVendor = formattedVendor.replace(/^_+|_+$/g, '');
                    return formattedVendor;
                }
    
                if (snizeItemData) {
                    const vendor = snizeItemData.vendor || "Unknown Vendor";
                    const formattedVendor = formatVendorName(vendor);
                    const imageUrl = `//ninjatransfers.com/cdn/shop/t/551/assets/${formattedVendor}.png`;
    
                    imageExists(imageUrl, (exists) => {
                        vendorImageExists = exists;
                        if (vendorImageExists) {
                            vendorImageHtml = `<span class="vendor__image-wrap"><img src="${imageUrl}" alt="${vendor}"></span>`;
                            $(`.starting-at__wrap`, $productCard).html(`starting at ${vendorImageHtml}`);
                        }
                    });
                }

                var _style = style
                if(_style.indexOf("?") > 0){
                  _style = _style.split("?");
                  _style = _style[0];
                }else{
                  _style = _style;
                }
                let $starRatings = $($("#yotpoProductReviews .style-" + _style).html());
                const $el = $(".yotpo-sr-bottom-line-right-panel", $starRatings);
                if ($el.length) {
                    const ratingCount = $el[0].innerText.trim();
                    $el.siblings().first().append(`<div style="margin-left:5px;font-size:14px;">${ratingCount}</div>`);
                    $el.hide();
                }
    
                if ($(".yotpo-sr-star-full", $starRatings).length == 0) $starRatings = null;
                $(".snize-overhidden", $productCard).empty();
                $(".snize-overhidden", $productCard).append(`<div class="starting-at__wrap" style="font-size:0.9em;color: #5e5e5e;">starting at</div> {% if template.suffix == "makerflo" %}<span class="vendor__image-wrap makerflo_vendor__image-wrap"><img src="https://cdn.shopify.com/s/files/1/0558/0265/8899/files/makerflo-crafts.png" alt="MakerFlo Crafts"></span>{% endif %}`);
                $(".snize-overhidden", $productCard).append(`<div style="color:#4572bb;font-weight:bold;font-size:1.4em;padding-top:5px;padding-bottom:5px;">${price}</div>`);
                if ($starRatings) $(".snize-overhidden", $productCard).append($starRatings);
                {% unless template.suffix == "makerflo" %} $(".snize-overhidden", $productCard).append(`<div class="estimatedDeliveryDate" style="display:none;"><div style="color:#000;font-size:0.9em;padding-top:5px;">Earliest Delivery</div><div class="estimatedDeliveryDateText" style="color:#52af61;font-weight:bold;font-size:1.2em;padding-bottom:10px;padding-top:5px;"></div></div>`); {% endunless %}
                {% if template.suffix == "makerflo" %} $(".snize-overhidden", $productCard).append(`<div class="estimatedDelivery-makerflo" style="color:#52af61;font-weight:bold;font-size:1.2em;padding-bottom:10px;padding-top:5px;"> Next day rush delivery </div>`);{% endif %}
                $(".snize-overhidden", $productCard).append(`<div style="color:#000;">${title}</div>`);
            }
        });
        if (foundProductCardToUpdate) collectionItemsLoaded();
    }, 30);
    if (window.location.href.indexOf('collection=') != -1) {
        var elements = document.getElementsByClassName('snize-search-results-page-title');
        for (var i = 0; i < elements.length; i++) {
            elements[i].style.display = 'none';
        }
    }
})(window);
// ]]>
</script>

