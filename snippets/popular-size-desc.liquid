{%- comment -%}
  Shared popular-size descriptions — single source of truth.
  Usage: {% render 'popular-size-desc', size: variant.option1, is_uv: _is_uv %}
{%- endcomment -%}

{%- if is_uv -%}
  {%- case size -%}
    {%- when '1" x 1"' -%}Micro Logo / Icon Decal
    {%- when '2" x 2"' -%}Small Logo / Product Mark
    {%- when '3" x 3"' -%}Small Decal / Brand Icon
    {%- when '4" x 4"' -%}Standard Logo Decal
    {%- when '5" x 5"' -%}Medium Decal / Tumbler Front
    {%- when '6" x 6"' -%}Large Logo / Cup Front
    {%- when '7" x 7"' -%}XL Decal / Tumbler Wrap Area
    {%- when '8" x 8"' -%}Small Sign / Laptop Decal
    {%- when '9" x 9"' -%}Medium Sign / Door Decal
    {%- when '10" x 10"' -%}Large Decal / Statement Graphic
    {%- when '11" x 11"' -%}XL Statement Decal
    {%- when '22" x 24"' -%}Oversized Sign / Window Decal
  {%- endcase -%}
{%- else -%}
  {%- case size -%}
    {%- when '2" x 2"' -%}Tag Print / Neck Label
    {%- when '3" x 3"' -%}Small Tag/Sleeve Icon
    {%- when '4" x 2"' -%}Name Label/Small Chest Text
    {%- when '4" x 4"' -%}Left-Chest Logo
    {%- when '5" x 3"' -%}Small Badge Logo
    {%- when '5" x 5"' -%}Small Chest/Youth Print
    {%- when '6" x 6"' -%}Std Left-Chest/Youth
    {%- when '7" x 7"' -%}Small Front (Adult)
    {%- when '8" x 8"' -%}Medium Front Print
    {%- when '9" x 9"' -%}Large Chest/Med Front
    {%- when '9" x 11"' -%}Vertical Front/Youth
    {%- when '10" x 10"' -%}Standard Adult Front
    {%- when '11" x 5"' -%}Chest Banner/Sleeve
    {%- when '11" x 11"' -%}Adult Full Front
    {%- when '11" x 14"' -%}Tall Front/Jersey
    {%- when '12" x 17"' -%}Oversized Front/Hoodie
  {%- endcase -%}
{%- endif -%}
