{%-liquid
  case colorName
    when 'black'
      echo '#000000'

    when 'dark red'
      echo '#700404'

    when 'silver'
      echo '#D3D3D3'

    when 'gold'
      echo '#FFC121'

    when 'fuchsia'
      echo 'https://cdn.shopify.com/s/files/1/0558/0265/8899/files/Black_0014_Fuchsia_200x200.png?v=1740691930'

    when 'red'
      echo '#C40000'

    when 'royal'
      echo 'https://cdn.shopify.com/s/files/1/0558/0265/8899/files/Black_0004_Royal_200x200.png?v=1740691930'

    when 'emerald'
      echo 'https://cdn.shopify.com/s/files/1/0558/0265/8899/files/Black_0015_Emerald_200x200.png?v=1740691930'

    when 'purple'
      echo '#A54DCF'

    when 'pale yellow'
      echo '#FFE500'

    when 'light pink'
      echo '#FFC0CB'

    when 'light blue'
      echo '#005BD3'

    when 'sea blue'
      echo '#005BD3'

    when 'orange'
      echo '#FF3900'

    when 'white'
      echo '#ffffff'

    when 'platinum'
      echo 'https://cdn.shopify.com/s/files/1/0558/0265/8899/files/Black_0007_Platinum_200x200.png?v=1740691930'

    when 'turquoise'
      echo 'https://cdn.shopify.com/s/files/1/0558/0265/8899/files/Black_0001_Turquoise_200x200.png?v=1740691930'

    when 'navy blue'
      echo '#005BD3'

    else
      echo ''
  endcase
-%}