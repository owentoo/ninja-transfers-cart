{%- case contentIs -%}
  {%- when 'fileUploadNote' -%}
    <!-- {{ contentIs }} START -->
    <style>
      .fileupload_notes_for_designer textarea {width: 100%;}
      .fileupload_notes_for_designer ._lbcactivelabel label{color:var(--color-text-main)}
      .upload_tools {
        position: absolute;
        top: 4px;
        right: 4px;
        width: 24px;
        height: 24px;
        z-index: 1;
      }
      .uploaderOverlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: #222222d8;
        z-index: 9999;
        display: none;
      }
      .uploaderOverlay.active {
        display: block;
      }
      .uploaderOverlay::after {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: calc(100% - 30px);
        height: calc(100% - 30px);
        border: 2px dashed #fff;
        transform: translate(-50%,-50%);
        border-radius: 8px;
      }
      .uploaderOverlay__wrap {
        display: grid;
        align-items: center;
        justify-content: center;
        position: absolute;
        top: 50%;
        left: 50%;
        width: 300px;
        height: auto;
        transform: translate(-50%,-50%);
        color: #fff;
        text-align: center;
      }
      .uploaderOverlay_svg {
        margin: auto;
      }
      .uploaderOverlay__dropFile {
        margin-top: 15px;
        font-size: xx-large;
        font-weight: 600;
      }
      .uploaderOverlay__text {
      }
    </style>
    <!-- {{ contentIs }} END -->

  {%- when 'customUploaderView' -%}
    <!-- {{ contentIs }} START -->
    <style>
      .customUploaderView {
        display: flex;
        gap: 20px;
        visibility: hidden;
        position: absolute;
        margin-bottom: 10px;
      }
      .changeLayout .customUploaderView {
        visibility: visible;
        position: relative;
      }
      .customUploaderView_detail {
        width: 50%;
        background-color: #eeeeee;
        border-radius: 7px;
        padding: 10px;
        overflow: hidden;
      }
      .customUploaderView_detail.imgAvailable .customUploaderView__info {
        background-image: linear-gradient(#369763, #36976312);
        background-color: transparent;
      }
      .customUploaderView__info {
        display: grid;
        grid-template-columns: 50% calc(50% - 30px);
        position: absolute;
        background-color: #369763;
        color: #fff;
        padding: 10px;
        border-radius: 4px;
        z-index: 1;
        width: calc(50% - 30px);
      }
      .customUploaderView__info_right {
        text-align: right;
      }
      .customUploaderView__removeFile {
        position: absolute;
        z-index: 1;
        top: 7px;
        right: 7px;
        width: 26px;
        height: 26px;
        background-color: #1a4930;
        border-radius: 999px;
        cursor: pointer;
        border: 2px solid transparent;
        transition: 0.2s all ease-in-out;
      }
      .customUploaderView__removeFile:hover {
        border-color: #fff;
      }
      .customUploaderView__removeFile svg {
        position: relative;
        transform: translate(-50%, -50%);
        top: 50%;
        left: 50%;
      }
      .customUploaderView__info_fileName,
      .customUploaderView__info_status {
        text-overflow: ellipsis;
        white-space: nowrap;
        width: 100%;
        font-size: .75em;
        line-height: 1.2;
        overflow: hidden;
      }
      .customUploaderView__info_fileSize,
      .customUploaderView__info_status2nd {
        opacity: .5;
        white-space: nowrap;
        font-size: .625em;
        transition: opacity .25s ease-in-out;
      }
      .customUploaderView_preview {
        position: relative;
        border-radius: 4px;
        overflow: hidden;
      }
      .customUploaderView_preview canvas {
        width: 100%;
      }
      .customUploaderView__inputFeild {
        width: 50%;
      }
      .customUploaderView__inputFeild_label {
        font-weight: 700;
        color: #555;
      }
      .customUploaderView__inputFeild_textarea {
        width: 100%;
      }
    </style>
    <!-- {{ contentIs }} END -->
{%- endcase -%}

