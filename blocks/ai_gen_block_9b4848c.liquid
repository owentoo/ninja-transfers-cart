{% doc %}
  @prompt
    create a section with one line of text, with vertical padding. the text should not go past the themes max width (include themes horizontal padding and margin) there should be one line of text for desk top and another for mobile. entire section should have a bg color or gradient , top and bottom padding should be one setting text should aligns be aligned between them, when desktop text in active mobile text should not take up any space and the other way around, text is not being center aligned vertically , all padding should to in multiples of 2, vertical content max width and padding should match the section above, content padding does not match section above on desktop and mobile , content max width and horizontal padding and margin needs to match section above on desktop and mobile , add option for Text alignment on desktop and mobile. give content max width and inner padding in multiples of 2, make text fields accept inline css 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-banner-{{ ai_gen_id }} {
    width: 100%;
    display: block;
    {% if block.settings.use_gradient %}
      background: linear-gradient({{ block.settings.gradient_angle }}deg, {{ block.settings.gradient_color_1 }}, {{ block.settings.gradient_color_2 }});
    {% else %}
      background-color: {{ block.settings.background_color }};
    {% endif %}
    padding-top: {{ block.settings.padding_vertical }}px;
    padding-bottom: {{ block.settings.padding_vertical }}px;
  }

  .ai-text-banner-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
    padding-left: {{ block.settings.content_padding_horizontal }}px;
    padding-right: {{ block.settings.content_padding_horizontal }}px;
  }

  .ai-text-banner-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    text-align: {{ block.settings.text_align_desktop }};
    margin: 0;
    line-height: 1.4;
  }

  .ai-text-banner-text-{{ ai_gen_id }} p {
    margin: 0;
  }

  .ai-text-banner-text-mobile-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-text-banner-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_vertical_mobile }}px;
      padding-bottom: {{ block.settings.padding_vertical_mobile }}px;
    }

    .ai-text-banner-container-{{ ai_gen_id }} {
      padding-left: {{ block.settings.content_padding_horizontal_mobile }}px;
      padding-right: {{ block.settings.content_padding_horizontal_mobile }}px;
    }

    .ai-text-banner-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size_mobile }}px;
      text-align: {{ block.settings.text_align_mobile }};
    }

    .ai-text-banner-text-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-text-banner-text-mobile-{{ ai_gen_id }} {
      display: block;
    }
  }
{% endstyle %}

<div class="ai-text-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-banner-container-{{ ai_gen_id }}">
    <div class="ai-text-banner-text-{{ ai_gen_id }}">
      <div class="ai-text-banner-text-desktop-{{ ai_gen_id }}">
        {{ block.settings.text_desktop }}
      </div>
      <div class="ai-text-banner-text-mobile-{{ ai_gen_id }}">
        {{ block.settings.text_mobile }}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Text banner",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "html",
      "id": "text_desktop",
      "label": "Desktop text",
      "default": "<p>Free shipping on orders over $75</p>"
    },
    {
      "type": "html",
      "id": "text_mobile",
      "label": "Mobile text",
      "default": "<p>Free shipping over $75</p>"
    },
    {
      "type": "header",
      "content": "Desktop style"
    },
    {
      "type": "select",
      "id": "text_align_desktop",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Mobile style"
    },
    {
      "type": "select",
      "id": "text_align_mobile",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "padding_vertical_mobile",
      "label": "Vertical padding",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 600,
      "max": 2000,
      "step": 20,
      "unit": "px",
      "default": 1400
    },
    {
      "type": "range",
      "id": "content_padding_horizontal",
      "label": "Desktop horizontal padding",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "content_padding_horizontal_mobile",
      "label": "Mobile horizontal padding",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "checkbox",
      "id": "use_gradient",
      "label": "Use gradient background",
      "default": false
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "gradient_color_1",
      "label": "Gradient start color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "gradient_color_2",
      "label": "Gradient end color",
      "default": "#019aff"
    },
    {
      "type": "range",
      "id": "gradient_angle",
      "label": "Gradient angle",
      "min": 0,
      "max": 360,
      "step": 15,
      "unit": "deg",
      "default": 90
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Text banner"
    }
  ]
}
{% endschema %}
