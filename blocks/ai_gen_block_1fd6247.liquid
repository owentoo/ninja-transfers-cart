{% doc %}
  @prompt
    need a section with eight blocks with text below them, need space btween and text size for desktop and mobile. on mobile give me the option to go 2 by 2 or hide overflow with scroll , desktop need to be in 1 or 2 rows , Section needs max width option with horizontal padding for desktop and mobile. text needs weight option, horizontal padding should be inside max width, go from 8 to 6 blocks, for horizontal scroll on mobile make sure you can see 30 px of 3rd block, add text alignment option for mobile 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-image-grid-wrapper-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.padding_desktop }}px;
  }

  .ai-image-grid-container-{{ ai_gen_id }} {
    display: grid;
    {% if block.settings.desktop_rows == '1' %}
      grid-template-columns: repeat(6, 1fr);
    {% else %}
      grid-template-columns: repeat(3, 1fr);
    {% endif %}
    gap: {{ block.settings.spacing_desktop }}px;
    width: 100%;
  }

  .ai-image-grid-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.text_spacing }}px;
  }

  .ai-image-grid-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-image-grid-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-image-grid-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-image-grid-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-image-grid-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size_desktop }}px;
    font-weight: {{ block.settings.text_weight }};
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_alignment }};
    line-height: 1.4;
  }

  @media screen and (max-width: 749px) {
    .ai-image-grid-wrapper-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.padding_mobile }}px;
    }

    .ai-image-grid-container-{{ ai_gen_id }} {
      {% if block.settings.mobile_layout == 'grid' %}
        grid-template-columns: repeat(2, 1fr);
        gap: {{ block.settings.spacing_mobile }}px;
      {% elsif block.settings.mobile_layout == 'scroll' %}
        display: flex;
        overflow-x: auto;
        gap: {{ block.settings.spacing_mobile }}px;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
        padding-right: calc(100vw - {{ block.settings.padding_mobile }}px - {{ block.settings.padding_mobile }}px - (2 * ((100vw - {{ block.settings.padding_mobile }}px - {{ block.settings.padding_mobile }}px - {{ block.settings.spacing_mobile }}px) / 2)) - {{ block.settings.spacing_mobile }}px - 30px);
      {% endif %}
    }

    .ai-image-grid-container-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    {% if block.settings.mobile_layout == 'scroll' %}
      .ai-image-grid-item-{{ ai_gen_id }} {
        flex: 0 0 calc((100vw - {{ block.settings.padding_mobile }}px - {{ block.settings.padding_mobile }}px - {{ block.settings.spacing_mobile }}px) / 2);
        scroll-snap-align: start;
      }
    {% endif %}

    .ai-image-grid-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
      text-align: {{ block.settings.text_alignment_mobile }};
    }
  }
{% endstyle %}

<image-grid-{{ ai_gen_id }} class="ai-image-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-grid-wrapper-{{ ai_gen_id }}">
    <div class="ai-image-grid-container-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign text_key = 'text_' | append: i
          assign image = block.settings[image_key]
          assign text = block.settings[text_key]
        %}
        
        <div class="ai-image-grid-item-{{ ai_gen_id }}">
          <div class="ai-image-grid-image-wrapper-{{ ai_gen_id }}">
            {% if image %}
              <img
                src="{{ image | image_url: width: 600 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="600"
                height="600"
                class="ai-image-grid-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-image-grid-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          
          {% if text != blank %}
            <div class="ai-image-grid-text-{{ ai_gen_id }}">
              {{ text }}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</image-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.container = this.querySelector('.ai-image-grid-container-{{ ai_gen_id }}');
        
        if (window.innerWidth <= 749 && this.container.style.display === 'flex') {
          this.setupScrollBehavior();
        }
      }

      setupScrollBehavior() {
        let isDown = false;
        let startX;
        let scrollLeft;

        this.container.addEventListener('mousedown', (e) => {
          isDown = true;
          startX = e.pageX - this.container.offsetLeft;
          scrollLeft = this.container.scrollLeft;
        });

        this.container.addEventListener('mouseleave', () => {
          isDown = false;
        });

        this.container.addEventListener('mouseup', () => {
          isDown = false;
        });

        this.container.addEventListener('mousemove', (e) => {
          if (!isDown) return;
          e.preventDefault();
          const x = e.pageX - this.container.offsetLeft;
          const walk = (x - startX) * 2;
          this.container.scrollLeft = scrollLeft - walk;
        });
      }
    }

    customElements.define('image-grid-{{ ai_gen_id }}', ImageGrid{{ ai_gen_id }});
  })();
</script>

