{% doc %}
  @prompt
    Create a customizable Shopify section that displays 5 category cards in a grid on desktop, 2–3 on tablet, and 1 on mobile. The section must be fully responsive.
    
    Section Controls
    
    Editable heading and subheading
    
    Optional “Shop All Blanks” button (text, link, alignment)
    
    Control section padding, max-width, background color
    
    Control grid column count, row/column gaps, and card spacing
    
    Card Requirements (each card)
    
    Each card must include the following editable fields, in this order:
    
    Image (upload per card; adjustable ratio)
    
    Category title (text)
    
    Optional benefit line (toggle on/off)
    
    Price + delivery row
    
    Field 1: “From $X.XX”
    
    Field 2: “Ships in X–Y days”
    
    Option: inline or stacked
    
    CTA button
    
    Editable text + URL
    
    Uniform width across all cards
    
    Toggle on/off
    
    Entire card must also be clickable, linking to the collection or custom URL.
    
    Card Styling Controls
    
    Card padding, background color, corner radius
    
    Border on/off, shadow on/off, hover state
    
    Text alignment (global or per card)
    
    Behavior
    
    Clean, simple, scannable layout
    
    Images always on top
    
    Uniform CTA width
    
    Works with any number of cards (minimum 5)
    
    Generate this as a Shopify section with full theme-editor controls., Move the ‘Shop All’ CTA to appear directly below the category grid, and add global controls to set the CTA style (button, outline, text link, or text link with arrow). Apply these CTA style options to every CTA in the section., update the layout to display 6 cards across on desktop, Make sure it's 2 columns across on mobile, Shop all button should just be a button, cta style should not affect shop all cta, only product card ctas
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-category-cards-{{ ai_gen_id }} {
    background-color: {{ block.settings.section_bg_color }};
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-category-cards-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.section_max_width }}px;
    margin: 0 auto;
  }

  .ai-category-cards-header-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }
  .ai-category-cards-header-text-{{ ai_gen_id }} {
    text-align: {{ block.settings.header_alignment }};
    flex: 1;
  }
  .ai-category-cards-shop-all-{{ ai_gen_id }} {
    font-size: 13px;
    font-weight: 600;
    color: {{ block.settings.shop_all_color }};
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    padding-top: 4px;
  }
  .ai-category-cards-shop-all-{{ ai_gen_id }}:hover {
    text-decoration: underline;
  }

  .ai-category-cards-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.subheading_spacing }}px;
    font-weight: 600;
  }

  .ai-category-cards-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
  }

  .ai-category-cards-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.grid_columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_row_gap }}px {{ block.settings.grid_column_gap }}px;
    margin-top: {{ block.settings.grid_spacing }}px;
  }

  .ai-category-card-{{ ai_gen_id }} {
    position: relative;
    background-color: {{ block.settings.card_bg_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    text-decoration: none;
    display: block;
    transition: all 0.3s ease;
    {% if block.settings.card_border_enabled %}
      border: 1px solid {{ block.settings.card_border_color }};
    {% endif %}
    {% if block.settings.card_shadow_enabled %}
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    {% endif %}
  }

  {% if block.settings.card_hover_enabled %}
    .ai-category-card-{{ ai_gen_id }}:hover {
      transform: translateY(-4px);
      {% if block.settings.card_shadow_enabled %}
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
      {% endif %}
    }
  {% endif %}

  .ai-category-card-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio | times: 100 }}%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    margin-bottom: {{ block.settings.image_spacing }}px;
    background-color: #f4f4f4;
  }

  .ai-category-card-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-category-card-image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-category-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-category-card-content-{{ ai_gen_id }} {
    text-align: {{ block.settings.card_text_alignment }};
  }

  .ai-category-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 {{ block.settings.card_title_spacing }}px;
    font-weight: 600;
  }

  .ai-category-card-benefit-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_benefit_size }}px;
    color: {{ block.settings.card_benefit_color }};
    margin: 0 0 {{ block.settings.card_benefit_spacing }}px;
  }

  .ai-category-card-price-delivery-{{ ai_gen_id }} {
    {% if block.settings.price_delivery_layout == 'inline' %}
      display: flex;
      align-items: center;
      gap: 12px;
      {% if block.settings.card_text_alignment == 'center' %}
        justify-content: center;
      {% elsif block.settings.card_text_alignment == 'right' %}
        justify-content: flex-end;
      {% endif %}
    {% else %}
      display: flex;
      flex-direction: column;
      gap: 4px;
    {% endif %}
    margin-bottom: {{ block.settings.price_delivery_spacing }}px;
  }

  .ai-category-card-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_price_size }}px;
    color: {{ block.settings.card_price_color }};
    font-weight: 600;
  }

  .ai-category-card-delivery-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_delivery_size }}px;
    color: {{ block.settings.card_delivery_color }};
  }

  .ai-cta-base-{{ ai_gen_id }} {
    font-size: {{ block.settings.cta_font_size }}px;
    font-weight: 500;
    text-align: center;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  {% if block.settings.cta_style == 'button' %}
    .ai-cta-base-{{ ai_gen_id }} {
      padding: 12px 32px;
      background-color: {{ block.settings.cta_bg_color }};
      color: {{ block.settings.cta_text_color }};
      border-radius: {{ block.settings.cta_border_radius }}px;
    }

    .ai-cta-base-{{ ai_gen_id }}:hover {
      background-color: {{ block.settings.cta_hover_bg_color }};
      color: {{ block.settings.cta_hover_text_color }};
    }

    .ai-category-card-cta-{{ ai_gen_id }} {
      width: {{ block.settings.cta_width }}%;
      padding: 10px 20px;
      justify-content: center;
    }
  {% elsif block.settings.cta_style == 'outline' %}
    .ai-cta-base-{{ ai_gen_id }} {
      padding: 12px 32px;
      background-color: transparent;
      color: {{ block.settings.cta_bg_color }};
      border: 2px solid {{ block.settings.cta_bg_color }};
      border-radius: {{ block.settings.cta_border_radius }}px;
    }

    .ai-cta-base-{{ ai_gen_id }}:hover {
      background-color: {{ block.settings.cta_bg_color }};
      color: {{ block.settings.cta_text_color }};
      border-color: {{ block.settings.cta_bg_color }};
    }

    .ai-category-card-cta-{{ ai_gen_id }} {
      width: {{ block.settings.cta_width }}%;
      padding: 10px 20px;
      justify-content: center;
    }
  {% elsif block.settings.cta_style == 'text_link' %}
    .ai-cta-base-{{ ai_gen_id }} {
      padding: 0;
      background-color: transparent;
      color: {{ block.settings.cta_bg_color }};
      border: none;
    }

    .ai-cta-base-{{ ai_gen_id }}:hover {
      color: {{ block.settings.cta_hover_bg_color }};
      text-decoration: underline;
    }

    .ai-category-card-cta-{{ ai_gen_id }} {
      width: auto;
    }
  {% elsif block.settings.cta_style == 'text_link_arrow' %}
    .ai-cta-base-{{ ai_gen_id }} {
      padding: 0;
      background-color: transparent;
      color: {{ block.settings.cta_bg_color }};
      border: none;
    }

    .ai-cta-base-{{ ai_gen_id }}:hover {
      color: {{ block.settings.cta_hover_bg_color }};
    }

    .ai-cta-base-{{ ai_gen_id }}:hover .ai-cta-arrow-{{ ai_gen_id }} {
      transform: translateX(4px);
    }

    .ai-category-card-cta-{{ ai_gen_id }} {
      width: auto;
    }

    .ai-cta-arrow-{{ ai_gen_id }} {
      transition: transform 0.3s ease;
    }
  {% endif %}

  .ai-category-cards-button-wrapper-{{ ai_gen_id }} {
    margin-top: {{ block.settings.button_spacing }}px;
    text-align: {{ block.settings.button_alignment }};
  }

  .ai-shop-all-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 32px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 500;
    transition: all 0.3s ease;
  }

  .ai-shop-all-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-category-cards-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.grid_columns_tablet }}, 1fr);
    }

    .ai-category-cards-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-category-cards-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }

    .ai-category-cards-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.7 }}px {{ block.settings.section_padding_horizontal | times: 0.7 }}px {{ block.settings.section_padding_bottom | times: 0.7 }}px;
    }

    .ai-category-cards-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-category-card-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.card_title_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-category-cards-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-category-cards-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-category-cards-header-{{ ai_gen_id }}">
        <div class="ai-category-cards-header-text-{{ ai_gen_id }}">
          {% if block.settings.heading != blank %}
            <h2 class="ai-category-cards-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
          {% endif %}
          {% if block.settings.subheading != blank %}
            <p class="ai-category-cards-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
          {% endif %}
        </div>
        {% if block.settings.shop_all_link != blank %}
          <a href="{{ block.settings.shop_all_link }}" class="ai-category-cards-shop-all-{{ ai_gen_id }}">{{ block.settings.shop_all_text }}</a>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-category-cards-grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign card_image_key = 'card_' | append: i | append: '_image'
          assign card_title_key = 'card_' | append: i | append: '_title'
          assign card_benefit_key = 'card_' | append: i | append: '_benefit'
          assign card_show_benefit_key = 'card_' | append: i | append: '_show_benefit'
          assign card_price_key = 'card_' | append: i | append: '_price'
          assign card_delivery_key = 'card_' | append: i | append: '_delivery'
          assign card_cta_text_key = 'card_' | append: i | append: '_cta_text'
          assign card_show_cta_key = 'card_' | append: i | append: '_show_cta'
          assign card_link_key = 'card_' | append: i | append: '_link'

          assign card_image = block.settings[card_image_key]
          assign card_title = block.settings[card_title_key]
          assign card_benefit = block.settings[card_benefit_key]
          assign card_show_benefit = block.settings[card_show_benefit_key]
          assign card_price = block.settings[card_price_key]
          assign card_delivery = block.settings[card_delivery_key]
          assign card_cta_text = block.settings[card_cta_text_key]
          assign card_show_cta = block.settings[card_show_cta_key]
          assign card_link = block.settings[card_link_key]
        %}

        <a href="{{ card_link }}" class="ai-category-card-{{ ai_gen_id }}">
          <div class="ai-category-card-image-wrapper-{{ ai_gen_id }}">
            {% if card_image %}
              <img
                src="{{ card_image | image_url: width: 800 }}"
                alt="{{ card_image.alt | escape }}"
                loading="lazy"
                width="800"
                height="{{ 800 | times: block.settings.image_aspect_ratio }}"
                class="ai-category-card-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-category-card-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <div class="ai-category-card-content-{{ ai_gen_id }}">
            {% if card_title != blank %}
              <h3 class="ai-category-card-title-{{ ai_gen_id }}">{{ card_title }}</h3>
            {% endif %}

            {% if card_show_benefit and card_benefit != blank %}
              <p class="ai-category-card-benefit-{{ ai_gen_id }}">{{ card_benefit }}</p>
            {% endif %}

            {% if card_price != blank or card_delivery != blank %}
              <div class="ai-category-card-price-delivery-{{ ai_gen_id }}">
                {% if card_price != blank %}
                  <span class="ai-category-card-price-{{ ai_gen_id }}">{{ card_price }}</span>
                {% endif %}
                {% if card_delivery != blank %}
                  <span class="ai-category-card-delivery-{{ ai_gen_id }}">{{ card_delivery }}</span>
                {% endif %}
              </div>
            {% endif %}

            {% if card_show_cta and card_cta_text != blank %}
              <span class="ai-cta-base-{{ ai_gen_id }} ai-category-card-cta-{{ ai_gen_id }}">
                {{ card_cta_text }}
                {% if block.settings.cta_style == 'text_link_arrow' %}
                  <svg class="ai-cta-arrow-{{ ai_gen_id }}" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                {% endif %}
              </span>
            {% endif %}
          </div>
        </a>
      {% endfor %}
    </div>

    {% if block.settings.show_button and block.settings.button_text != blank %}
      <div class="ai-category-cards-button-wrapper-{{ ai_gen_id }}">
        <a href="{{ block.settings.button_link }}" class="ai-shop-all-button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </a>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Category cards",
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by category"
    },
    {
      "type": "url",
      "id": "shop_all_link",
      "label": "\"Shop all\" link URL"
    },
    {
      "type": "text",
      "id": "shop_all_text",
      "label": "\"Shop all\" link text",
      "default": "Shop all"
    },
    {
      "type": "color",
      "id": "shop_all_color",
      "label": "\"Shop all\" link color",
      "default": "#019aff"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Explore our collection"
    },
    {
      "type": "select",
      "id": "header_alignment",
      "label": "Header alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "subheading_spacing",
      "label": "Subheading spacing",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "header_spacing",
      "label": "Header bottom spacing",
      "min": 20,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Section layout"
    },
    {
      "type": "range",
      "id": "section_max_width",
      "label": "Maximum width",
      "min": 1000,
      "max": 2000,
      "step": 50,
      "unit": "px",
      "default": 1400
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 150,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 150,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_horizontal",
      "label": "Padding horizontal",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Grid layout"
    },
    {
      "type": "range",
      "id": "grid_columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 6
    },
    {
      "type": "range",
      "id": "grid_columns_tablet",
      "label": "Columns on tablet",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "grid_row_gap",
      "label": "Row gap",
      "min": 10,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "grid_column_gap",
      "label": "Column gap",
      "min": 10,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "grid_spacing",
      "label": "Grid top spacing",
      "min": 20,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Padding",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "checkbox",
      "id": "card_border_enabled",
      "label": "Show border",
      "default": false
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Border color",
      "default": "#e0e0e0"
    },
    {
      "type": "checkbox",
      "id": "card_shadow_enabled",
      "label": "Show shadow",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "card_hover_enabled",
      "label": "Enable hover effect",
      "default": true
    },
    {
      "type": "select",
      "id": "card_text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Card image"
    },
    {
      "type": "range",
      "id": "image_aspect_ratio",
      "label": "Aspect ratio",
      "min": 0.5,
      "max": 1.5,
      "step": 0.1,
      "default": 1
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
