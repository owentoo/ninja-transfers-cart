{% doc %}
  @prompt
    need a collection of link blocks up to 30 each with an image and text below, 2-3 per row. whole section needs horizontal padding and spacing options. Ned text size, weight, color, and alignment options. images need ration and radius options , space between and padding needs to be in increments of 2, Columns should be the same on desktop and mobile 1-3, need space between rows setting 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-link-collection-{{ ai_gen_id }} {
    padding-left: {{ block.settings.horizontal_padding }}px;
    padding-right: {{ block.settings.horizontal_padding }}px;
  }

  .ai-link-collection-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    column-gap: {{ block.settings.spacing }}px;
    row-gap: {{ block.settings.row_spacing }}px;
  }

  .ai-link-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    text-decoration: none;
  }

  .ai-link-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: calc(100% / {{ block.settings.image_ratio }});
    overflow: hidden;
    border-radius: {{ block.settings.image_radius }}px;
    background-color: #f4f4f4;
  }

  .ai-link-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-link-image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-link-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-link-text-{{ ai_gen_id }} {
    margin-top: 12px;
    font-size: {{ block.settings.text_size }}px;
    font-weight: {{ block.settings.text_weight }};
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  @media screen and (max-width: 749px) {
    .ai-link-collection-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
  }
{% endstyle %}

<div class="ai-link-collection-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-link-collection-grid-{{ ai_gen_id }}">
    {% for i in (1..30) %}
      {% liquid
        assign link_enabled_key = 'link_' | append: i | append: '_enabled'
        assign link_url_key = 'link_' | append: i | append: '_url'
        assign link_image_key = 'link_' | append: i | append: '_image'
        assign link_text_key = 'link_' | append: i | append: '_text'

        assign link_enabled = block.settings[link_enabled_key]
        assign link_url = block.settings[link_url_key]
        assign link_image = block.settings[link_image_key]
        assign link_text = block.settings[link_text_key]
      %}

      {% if link_enabled %}
        <a
          href="{{ link_url }}"
          class="ai-link-item-{{ ai_gen_id }}"
        >
          <div class="ai-link-image-wrapper-{{ ai_gen_id }}">
            {% if link_image %}
              <img
                src="{{ link_image | image_url: width: 800 }}"
                alt="{{ link_image.alt | escape }}"
                loading="lazy"
                width="{{ link_image.width }}"
                height="{{ link_image.height }}"
                class="ai-link-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-link-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          {% if link_text != blank %}
            <div class="ai-link-text-{{ ai_gen_id }}">{{ link_text }}</div>
          {% endif %}
        </a>
      {% endif %}
    {% endfor %}
  </div>
</div>

