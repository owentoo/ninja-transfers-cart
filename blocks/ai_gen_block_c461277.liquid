      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Button hover background",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Button hover text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Hover Effects"
    },
    {
      "type": "checkbox",
      "id": "hover_effect",
      "label": "Enable hover effect",
      "default": false
    },
    {
      "type": "range",
      "id": "hover_overlay_opacity",
      "label": "Hover overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.8
    },
    {
      "type": "header",
      "content": "Custom Content Column"
    },
    {
      "type": "html",
      "id": "custom_content",
      "label": "Custom HTML/CSS/Liquid content"
    },
    {
      "type": "color",
      "id": "content_background",
      "label": "Content background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "content_padding",
      "label": "Content padding",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "content_border_radius",
      "label": "Content border radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "content_border_width",
      "label": "Content border width",
      "min": 0,
      "max": 5,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "content_border_color",
      "label": "Content border color",
      "default": "#e0e0e0"
    },
    {
      "type": "header",
      "content": "Mobile Settings"
