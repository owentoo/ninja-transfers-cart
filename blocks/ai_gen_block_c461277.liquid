{% doc %}
  @prompt
    Create a flexible theme section with a two-column layout where the left column (1/3 width) contains a video player with a comprehensive text overlay including title header, subtext, and customizable button, plus adjustable video size controls, and the right column (2/3 width) provides a custom HTML/CSS/Liquid area for embedding forms or custom content. Include section settings for video upload, video size/dimensions control, overlay title text, overlay subtext, button text and link, and a rich text area for custom code input.

{% enddoc %}
{% assign ai_gen_id = section.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-content-section-{{ ai_gen_id }} {
    padding: {{ section.settings.section_padding }}px 0;
    background-color: {{ section.settings.section_background }};
  }

  .ai-video-content-container-{{ ai_gen_id }} {
    max-width: {{ settings.theme_max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-video-content-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: {{ section.settings.column_gap }}px;
    align-items: {{ section.settings.vertical_alignment }};
  }

  .ai-video-column-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    max-width: {{ section.settings.video_max_width }}px;
    border-radius: {{ section.settings.video_border_radius }}px;
    overflow: hidden;
    box-shadow: {{ section.settings.video_shadow }};
  }

  .ai-video-player-{{ ai_gen_id }} {
    width: 100%;
    height: {{ section.settings.video_height }}px;
    object-fit: cover;
    display: block;
  }

  .ai-video-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ section.settings.video_height }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ section.settings.video_border_radius }}px;
  }

  .ai-video-placeholder-{{ ai_gen_id }} svg {
    width: 80px;
    height: 80px;
    opacity: 0.5;
  }

  .ai-video-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: {{ section.settings.overlay_background }};
    display: flex;
    flex-direction: column;
    justify-content: {{ section.settings.overlay_vertical_position }};
    align-items: {{ section.settings.overlay_horizontal_position }};
    padding: 30px;
    text-align: {{ section.settings.overlay_text_alignment }};
    opacity: {{ section.settings.overlay_opacity }};
    transition: opacity 0.3s ease;
  }

  .ai-video-overlay-title-{{ ai_gen_id }} {
    color: {{ section.settings.overlay_title_color }};
    font-size: {{ section.settings.overlay_title_size }}px;
    font-weight: 600;
    margin: 0 0 15px;
    line-height: 1.2;
  }

  .ai-video-overlay-subtext-{{ ai_gen_id }} {
    color: {{ section.settings.overlay_subtext_color }};
    font-size: {{ section.settings.overlay_subtext_size }}px;
    margin: 0 0 20px;
    line-height: 1.4;
  }

  .ai-video-overlay-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 24px;
    background-color: {{ section.settings.button_background }};
    color: {{ section.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ section.settings.button_border_radius }}px;
    font-size: {{ section.settings.button_font_size }}px;
    font-weight: 500;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-video-overlay-button-{{ ai_gen_id }}:hover {
    background-color: {{ section.settings.button_hover_background }};color: {{ section.settings.button_hover_text_color }};
    transform: translateY(-2px);
  }

  .ai-content-column-{{ ai_gen_id }} {
    background-color: {{ section.settings.content_background }};
    padding: {{ section.settings.content_padding }}px;
    border-radius: {{ section.settings.content_border_radius }}px;
    border: {{ section.settings.content_border_width }}px solid {{ section.settings.content_border_color }};
  }

  .ai-custom-content-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
  }

  @media screen and (max-width: 768px) {
    .ai-video-content-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ section.settings.mobile_gap }}px;
    }

    .ai-video-column-{{ ai_gen_id }} {
      order: {{ section.settings.mobile_video_order }};
    }

    .ai-content-column-{{ ai_gen_id }} {
      order: {{ section.settings.mobile_content_order }};
    }

    .ai-video-player-{{ ai_gen_id }},
    .ai-video-placeholder-{{ ai_gen_id }} {
      height: {{ section.settings.mobile_video_height }}px;
    }

    .ai-video-overlay-{{ ai_gen_id }} {
      padding: 20px;
    }

    .ai-video-overlay-title-{{ ai_gen_id }} {
      font-size: {{ section.settings.overlay_title_size | times: 0.8 }}px;
    }

    .ai-video-overlay-subtext-{{ ai_gen_id }} {
      font-size: {{ section.settings.overlay_subtext_size | times: 0.9 }}px;
    }
  }

  {% if section.settings.hover_effect %}
    .ai-video-wrapper-{{ ai_gen_id }}:hover .ai-video-overlay-{{ ai_gen_id }} {
      opacity: {{ section.settings.hover_overlay_opacity }};
    }
  {% endif %}
{% endstyle %}

<section class="ai-video-content-section-{{ ai_gen_id }}" {{ section.shopify_attributes }}>
  <div class="ai-video-content-container-{{ ai_gen_id }}">
    <div class="ai-video-content-grid-{{ ai_gen_id }}">
      <div class="ai-video-column-{{ ai_gen_id }}">
        <div class="ai-video-wrapper-{{ ai_gen_id }}">
          {% if section.settings.video %}
            <video
              class="ai-video-player-{{ ai_gen_id }}"
              {% if section.settings.video_autoplay %}autoplay{% endif %}
              {% if section.settings.video_loop %}loop{% endif %}
              {% if section.settings.video_muted %}muted{% endif %}
              {% if section.settings.video_controls %}controls{% endif %}
              playsinline
              preload="metadata"
            >
              <source src="{{ section.settings.video }}" type="video/mp4">
              Your browser does not support the video tag.
            </video>
          {% else %}
            <div class="ai-video-placeholder-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="5,3 19,12 5,21"></polygon>
              </svg>
            </div>
          {% endif %}

          {% if section.settings.show_overlay %}
            <div class="ai-video-overlay-{{ ai_gen_id }}">
              {% if section.settings.overlay_title != blank %}
                <h2 class="ai-video-overlay-title-{{ ai_gen_id }}">{{ section.settings.overlay_title }}</h2>
              {% endif %}
              
              {% if section.settings.overlay_subtext != blank %}
                <p class="ai-video-overlay-subtext-{{ ai_gen_id }}">{{ section.settings.overlay_subtext }}</p>
              {% endif %}
              
              {% if section.settings.button_text != blank and section.settings.button_link != blank %}
                <a href="{{ section.settings.button_link }}" class="ai-video-overlay-button-{{ ai_gen_id }}">
                  {{ section.settings.button_text }}
                </a>
              {% endif %}
            </div>
          {% endif %}
        </div>
      </div>

      <div class="ai-content-column-{{ ai_gen_id }}">
        <div class="ai-custom-content-{{ ai_gen_id }}">
          {{ section.settings.custom_content }}
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Video Content Section",
  "settings": [
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Column gap",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Vertical alignment",
      "options": [
        {
          "value": "start",
          "label": "Top"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "end",
          "label": "Bottom"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Video Settings"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video file"
    },
    {
      "type": "range",
      "id": "video_max_width",
      "label": "Video max width",
      "min": 200,
      "max": 800,
      "step": 10,
      "unit": "px",
      "default": 500
    },
    {
      "type": "range",
      "id": "video_height",
      "label": "Video height",
      "min": 200,
      "max": 600,
      "step": 10,
      "unit": "px",
      "default": 350
    },
    {
      "type": "range",
      "id": "video_border_radius",
      "label": "Video border radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "select",
      "id": "video_shadow",
      "label": "Video shadow",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "0 4px 8px rgba(0,0,0,0.1)",
          "label": "Light"
        },
        {
          "value": "0 8px 16px rgba(0,0,0,0.15)",
          "label": "Medium"
        },
        {
          "value": "0 12px 24px rgba(0,0,0,0.2)",
          "label": "Strong"
        }
      ],
      "default": "0 8px 16px rgba(0,0,0,0.15)"
    },
    {
      "type": "checkbox",
      "id": "video_autoplay",
      "label": "Autoplay video",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_loop",
      "label": "Loop video",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_muted",
      "label": "Mute video",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_controls",
      "label": "Show video controls",
      "default": false
    },
    {
      "type": "header",
      "content": "Video Overlay"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show overlay",
      "default": true
    },
    {
      "type": "color",
      "id": "overlay_background",
      "label": "Overlay background",
      "default": "rgba(0,0,0,0.4)"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 1
    },
    {
      "type": "select",
      "id": "overlay_vertical_position",
      "label": "Overlay vertical position",
      "options": [
        {
          "value": "flex-start",
          "label": "Top"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Bottom"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "overlay_horizontal_position",
      "label": "Overlay horizontal position",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "overlay_text_alignment",
      "label": "Overlay text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "text",
      "id": "overlay_title",
      "label": "Overlay title",
      "default": "Your Video Title"
    },
    {
      "type": "range",
      "id": "overlay_title_size",
      "label": "Title font size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "color",
      "id": "overlay_title_color",
      "label": "Title color",
      "default": "#ffffff"
    },
    {
      "type": "textarea",
      "id": "overlay_subtext",
      "label": "Overlay subtext",
      "default": "Add your compelling description here to engage your audience."
    },
    {
      "type": "range",
      "id": "overlay_subtext_size",
      "label": "Subtext font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "overlay_subtext_color",
      "label": "Subtext color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Overlay Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Button font size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 6
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
