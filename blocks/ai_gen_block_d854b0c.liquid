{% doc %}
  @prompt
    Design a modern “Featured Products” section in a 4-column grid layout, inspired by Apple's product showcase.

Style & Layout

Clean, premium Apple-like aesthetic with minimal distraction.

Responsive 4-column grid on desktop, 2-column on tablet, 1-column on mobile.

Each card has:

Rounded corners (12 px)

Light gradient background (#eef7ff → #ffffff)

Soft drop shadow (rgba(0, 0, 0, 0.08) 0px 8px 24px)

Hover animation: card lifts (translateY(-4px)), shadow deepens slightly.

Top section header

Title: “The latest.” (bold, large font)

Subtitle: “Take a look at what's new, right now.” (regular weight)

Center-aligned text with subtle fade-in animation on scroll.

Card Content (identical across all cards)

Product name in bold (e.g., “iPhone 16 Pro”)

Subtitle or tag in gradient text: “Apple Intelligence” style (use gradient: #0062ff → #d100ff)

Price line below (smaller font): e.g., “From $999 or $41.62/mo. for 24 mo.”

Centered high-quality product image with slight shadow

Vertical spacing between elements should be even and elegant (16–24 px)

Section behavior

Clean padding: 32 px around grid, 24 px gutters between cards

All text and buttons pass WCAG AA contrast

Placeholder content is okay, but structure should be easily swappable with real DTF product info (titles, prices, images)

Extras

Enable easy editing of product title, tag, price line, and image

Entire section should animate in on scroll (soft fade-in from bottom)

Purpose
Display 4 featured DTF-print products with a premium, consistent layout.

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-featured-products-{{ ai_gen_id }} {
    padding: 32px;
    overflow: hidden;
  }

  .ai-featured-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 48px;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .ai-featured-header-{{ ai_gen_id }}.animate {
    opacity: 1;
    transform: translateY(0);
  }

  .ai-featured-title-{{ ai_gen_id }} {
    font-size: 48px;
    font-weight: 700;
    margin-bottom: 16px;
    color: {{ block.settings.title_color }};
  }

  .ai-featured-subtitle-{{ ai_gen_id }} {
    font-size: 20px;
    font-weight: 400;
    color: {{ block.settings.subtitle_color }};
  }

  .ai-featured-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .ai-featured-card-{{ ai_gen_id }} {
    background: linear-gradient(to bottom, {{ block.settings.card_gradient_start }}, {{ block.settings.card_gradient_end }});
    border-radius: 12px;
    box-shadow: rgba(0, 0, 0, 0.08) 0px 8px 24px;
    padding: 24px;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    opacity: 0;
    transform: translateY(20px);
  }

  .ai-featured-card-{{ ai_gen_id }}.animate {
    opacity: 1;
    transform: translateY(0);
  }

  .ai-featured-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: rgba(0, 0, 0, 0.12) 0px 12px 28px;
  }

  .ai-featured-product-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    margin: 24px 0;
    filter: drop-shadow(0px 4px 8px rgba(0, 0, 0, 0.1));
    transition: transform 0.3s ease;
  }

  .ai-featured-card-{{ ai_gen_id }}:hover .ai-featured-product-image-{{ ai_gen_id }} {
    transform: scale(1.03);
  }

  .ai-featured-image-wrapper-{{ ai_gen_id }} {
    margin: 24px 0;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 200px;
  }

  .ai-featured-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-featured-image-placeholder-{{ ai_gen_id }} svg {
    width: 80%;
    height: 80%;
    object-fit: contain;
  }

  .ai-featured-product-name-{{ ai_gen_id }} {
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 8px;
    color: {{ block.settings.product_name_color }};
  }

  .ai-featured-product-tag-{{ ai_gen_id }} {
    display: inline-block;
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 16px;
    background: linear-gradient(to right, {{ block.settings.tag_gradient_start }}, {{ block.settings.tag_gradient_end }});
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .ai-featured-product-price-{{ ai_gen_id }} {
    font-size: 16px;
    color: {{ block.settings.price_color }};
  }

  @media screen and (max-width: 990px) {
    .ai-featured-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
    
    .ai-featured-title-{{ ai_gen_id }} {
      font-size: 36px;
    }
    
    .ai-featured-subtitle-{{ ai_gen_id }} {
      font-size: 18px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-featured-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
    
    .ai-featured-title-{{ ai_gen_id }} {
      font-size: 32px;
    }
    
    .ai-featured-subtitle-{{ ai_gen_id }} {
      font-size: 16px;
    }
  }
{% endstyle %}

<div class="ai-featured-products-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-featured-header-{{ ai_gen_id }}">
    <h2 class="ai-featured-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    <p class="ai-featured-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
  </div>
  
  <div class="ai-featured-grid-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% liquid
        assign product_key = 'product_' | append: i
        assign tag_key = 'product_tag_' | append: i
        assign price_key = 'product_price_' | append: i
        
        assign product = block.settings[product_key]
        assign tag = block.settings[tag_key]
        assign price = block.settings[price_key]
        
        assign delay = forloop.index | times: 0.15
      %}
      
      <div class="ai-featured-card-{{ ai_gen_id }}" style="transition-delay: {{ delay }}s;">
        {% if product != blank %}
          <h3 class="ai-featured-product-name-{{ ai_gen_id }}">{{ product.title }}</h3>
          <div class="ai-featured-product-tag-{{ ai_gen_id }}">{{ tag }}</div>
          <div class="ai-featured-image-wrapper-{{ ai_gen_id }}">
            {% if product.featured_image != blank %}
              <img 
                src="{{ product.featured_image | image_url: width: 300 }}" 
                alt="{{ product.title }}" 
                class="ai-featured-product-image-{{ ai_gen_id }}"
                width="{{ product.featured_image.width }}"
                height="{{ product.featured_image.height }}"
                loading="lazy"
              >
            {% else %}
              <div class="ai-featured-image-placeholder-{{ ai_gen_id }}">
                {{ 'product-apparel-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          <div class="ai-featured-product-price-{{ ai_gen_id }}">{{ price }}</div>
        {% else %}
          <h3 class="ai-featured-product-name-{{ ai_gen_id }}">Product {{ i }}</h3>
          <div class="ai-featured-product-tag-{{ ai_gen_id }}">{{ tag | default: "Featured" }}</div>
          <div class="ai-featured-image-wrapper-{{ ai_gen_id }}">
            <div class="ai-featured-image-placeholder-{{ ai_gen_id }}">
              {{ 'product-apparel-1' | placeholder_svg_tag }}
            </div>
          </div>
          <div class="ai-featured-product-price-{{ ai_gen_id }}">{{ price | default: "From $99.99" }}</div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

<script>
  (function() {
    class FeaturedProducts extends HTMLElement {
      constructor() {
        super();
        this.header = this.querySelector('.ai-featured-header-{{ ai_gen_id }}');
        this.cards = this.querySelectorAll('.ai-featured-card-{{ ai_gen_id }}');
        this.observer = new IntersectionObserver(this.handleIntersection.bind(this), {
          root: null,
          rootMargin: '0px',
          threshold: 0.1
        });
      }

      connectedCallback() {
        this.observer.observe(this);
      }

      disconnectedCallback() {
        this.observer.unobserve(this);
      }

      handleIntersection(entries) {
        if (entries[0].isIntersecting) {
          this.header.classList.add('animate');
          
          this.cards.forEach((card, index) => {
            setTimeout(() => {
              card.classList.add('animate');
            }, 150 * index);
          });
          
          this.observer.unobserve(this);
        }
      }
    }

    customElements.define('featured-products-{{ ai_gen_id }}', FeaturedProducts);
    
    document.querySelectorAll('.ai-featured-products-{{ ai_gen_id }}').forEach(container => {
      if (!customElements.get('featured-products-{{ ai_gen_id }}')) return;
      
      const featuredProducts = document.createElement('featured-products-{{ ai_gen_id }}');
      
      // Move all children from container to featuredProducts
      while (container.firstChild) {
        featuredProducts.appendChild(container.firstChild);
      }
      
      // Replace container with featuredProducts
      container.parentNode.replaceChild(featuredProducts, container);
    });
  })();
</script>

