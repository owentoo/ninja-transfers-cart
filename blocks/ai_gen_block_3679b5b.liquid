{% doc %}
  @prompt
    make me a two column layout on onde side i want an h1, para, and two cta's, that adhere to section width on the other side i want a collection of stacked photos that move with parallax on scroll. all text needs size and weight options, i can't see the images, and i need atleast eight of them, give me placeholder images, and text and cta needs to be contained in a max width

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .two-column-parallax-{{ ai_gen_id }} {
    display: flex;
    flex-direction: row;
    gap: {{ block.settings.column_gap }}px;
    padding: {{ block.settings.padding_y }}px {{ block.settings.padding_x }}px;
    max-width: 100%;
    margin: 0 auto;
  }

  .text-column-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 20px 0;
    width: 100%;
  }

  .text-content-wrapper-{{ ai_gen_id }} {
    max-width: {{ block.settings.text_max_width }}px;
    margin: 0 auto;
  }

  .heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    margin-bottom: 20px;
    color: {{ block.settings.heading_color }};
    line-height: 1.2;
  }

  .paragraph-{{ ai_gen_id }} {
    font-size: {{ block.settings.paragraph_size }}px;
    font-weight: {{ block.settings.paragraph_weight }};
    margin-bottom: 30px;
    color: {{ block.settings.paragraph_color }};
    line-height: 1.5;
  }

  .buttons-container-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
    margin-top: 10px;
  }

  .primary-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.primary_button_bg }};
    color: {{ block.settings.primary_button_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_radius }}px;
    font-size: {{ block.settings.button_size }}px;
    font-weight: {{ block.settings.button_weight }};
    transition: background-color 0.3s, transform 0.2s;
  }

  .primary-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.primary_button_bg_hover }};
    transform: translateY(-2px);
  }

  .secondary-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.secondary_button_bg }};
    color: {{ block.settings.secondary_button_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_radius }}px;
    font-size: {{ block.settings.button_size }}px;
    font-weight: {{ block.settings.button_weight }};
    transition: background-color 0.3s, transform 0.2s;
  }

  .secondary-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.secondary_button_bg_hover }};
    transform: translateY(-2px);
  }

  .image-column-{{ ai_gen_id }} {
    flex: 1;
    position: relative;
    overflow: hidden;
    min-height: 800px;
  }

  .parallax-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .parallax-image-{{ ai_gen_id }} {
    position: absolute;
    width: {{ block.settings.image_width }}%;
    height: auto;
    border-radius: {{ block.settings.image_radius }}px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    transition: transform 0.2s ease-out;
  }

  .parallax-image-1-{{ ai_gen_id }} {
    top: 0%;
    left: 5%;
    z-index: 8;
  }

  .parallax-image-2-{{ ai_gen_id }} {
    top: 10%;
    right: 5%;
    z-index: 7;
  }

  .parallax-image-3-{{ ai_gen_id }} {
    top: 22%;
    left: 15%;
    z-index: 6;
  }

  .parallax-image-4-{{ ai_gen_id }} {
    top: 32%;
    right: 15%;
    z-index: 5;
  }

  .parallax-image-5-{{ ai_gen_id }} {
    top: 44%;
    left: 5%;
    z-index: 4;
  }

  .parallax-image-6-{{ ai_gen_id }} {
    top: 54%;
    right: 5%;
    z-index: 3;
  }

  .parallax-image-7-{{ ai_gen_id }} {
    top: 66%;
    left: 15%;
    z-index: 2;
  }

  .parallax-image-8-{{ ai_gen_id }} {
    top: 76%;
    right: 15%;
    z-index: 1;
  }

  .parallax-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_radius }}px;
    aspect-ratio: 3/4;
  }

  .parallax-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.5;
  }

  @media screen and (max-width: 768px) {
    .two-column-parallax-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 40px;
    }

    .image-column-{{ ai_gen_id }} {
      min-height: 1200px;
    }
  }
{% endstyle %}

<div class="two-column-parallax-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.reverse_layout %}
    <div class="image-column-{{ ai_gen_id }}">
      <parallax-images-{{ ai_gen_id }} class="parallax-container-{{ ai_gen_id }}">
        {% for i in (1..8) %}
          {% assign image_key = 'image_' | append: i %}
          {% assign image = block.settings[image_key] %}
          
          <div class="parallax-image-{{ ai_gen_id }} parallax-image-{{ i }}-{{ ai_gen_id }} parallax-placeholder-{{ ai_gen_id }}">
            {% if image %}
              <img 
                src="{{ image | image_url: width: 600 }}" 
                alt="{{ image.alt | escape }}" 
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
                style="width: 100%; height: 100%; object-fit: cover; border-radius: {{ block.settings.image_radius }}px;"
              >
            {% else %}
              {{ 'image' | placeholder_svg_tag }}
            {% endif %}
          </div>
        {% endfor %}
      </parallax-images-{{ ai_gen_id }}>
    </div>
    <div class="text-column-{{ ai_gen_id }}">
      <div class="text-content-wrapper-{{ ai_gen_id }}">
        <h1 class="heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h1>
        <p class="paragraph-{{ ai_gen_id }}">{{ block.settings.paragraph }}</p>
        <div class="buttons-container-{{ ai_gen_id }}">
          {% if block.settings.primary_button_label != blank and block.settings.primary_button_url != blank %}
            <a href="{{ block.settings.primary_button_url }}" class="primary-button-{{ ai_gen_id }}">
              {{ block.settings.primary_button_label }}
            </a>
          {% endif %}
          {% if block.settings.secondary_button_label != blank and block.settings.secondary_button_url != blank %}
            <a href="{{ block.settings.secondary_button_url }}" class="secondary-button-{{ ai_gen_id }}">
              {{ block.settings.secondary_button_label }}
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  {% else %}
    <div class="text-column-{{ ai_gen_id }}">
      <div class="text-content-wrapper-{{ ai_gen_id }}">
        <h1 class="heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h1>
        <p class="paragraph-{{ ai_gen_id }}">{{ block.settings.paragraph }}</p>
        <div class="buttons-container-{{ ai_gen_id }}">
          {% if block.settings.primary_button_label != blank and block.settings.primary_button_url != blank %}
            <a href="{{ block.settings.primary_button_url }}" class="primary-button-{{ ai_gen_id }}">
              {{ block.settings.primary_button_label }}
            </a>
          {% endif %}
          {% if block.settings.secondary_button_label != blank and block.settings.secondary_button_url != blank %}
            <a href="{{ block.settings.secondary_button_url }}" class="secondary-button-{{ ai_gen_id }}">
              {{ block.settings.secondary_button_label }}
            </a>
          {% endif %}
        </div>
      </div>
    </div>
    <div class="image-column-{{ ai_gen_id }}">
      <parallax-images-{{ ai_gen_id }} class="parallax-container-{{ ai_gen_id }}">
        {% for i in (1..8) %}
          {% assign image_key = 'image_' | append: i %}
          {% assign image = block.settings[image_key] %}
          
          <div class="parallax-image-{{ ai_gen_id }} parallax-image-{{ i }}-{{ ai_gen_id }} parallax-placeholder-{{ ai_gen_id }}">
            {% if image %}
              <img 
                src="{{ image | image_url: width: 600 }}" 
                alt="{{ image.alt | escape }}" 
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
                style="width: 100%; height: 100%; object-fit: cover; border-radius: {{ block.settings.image_radius }}px;"
              >
            {% else %}
              {{ 'image' | placeholder_svg_tag }}
            {% endif %}
          </div>
        {% endfor %}
      </parallax-images-{{ ai_gen_id }}>
    </div>
  {% endif %}
</div>

<script>
  (function() {
    class ParallaxImages extends HTMLElement {
      constructor() {
        super();
        this.images = this.querySelectorAll('.parallax-image-{{ ai_gen_id }}');
        this.handleScroll = this.handleScroll.bind(this);
      }

      connectedCallback() {
        window.addEventListener('scroll', this.handleScroll);
        this.handleScroll();
      }

      disconnectedCallback() {
        window.removeEventListener('scroll', this.handleScroll);
      }

      handleScroll() {
        const rect = this.getBoundingClientRect();
        const windowHeight = window.innerHeight;
        
        // Check if element is in viewport
        if (rect.top < windowHeight && rect.bottom > 0) {
          const scrollPercentage = (windowHeight - rect.top) / (windowHeight + rect.height);
          
          this.images.forEach((image, index) => {
            const speed = 0.1 + (index * 0.02);
            const yOffset = (scrollPercentage * 100 * speed) - 20;
            image.style.transform = `translateY(${yOffset}px)`;
          });
        }
      }
    }

    customElements.define('parallax-images-{{ ai_gen_id }}', ParallaxImages);
  })();
</script>

