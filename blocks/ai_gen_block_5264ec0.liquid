{% doc %}
  @prompt
    Create a fully customizable Shopify section with a responsive product grid: 3 columns desktop, 2 tablet, 1 mobile. Each product card must be fully clickable and include its own editable CTA button.
    
    Product card structure (in order):
    
    Optional top-left pill (editable text, color, size, shape, visibility per breakpoint)
    
    Product image (uploadable)
    
    Custom title
    
    Custom price text
    
    Custom sub-text
    
    CTA button (editable text, link, color, hover color, size, padding, visibility per breakpoint)
    
    Section requirements:
    
    Editable section heading with full control over alignment, size, spacing, and visibility on desktop/mobile.
    
    Full per-card controls: image, title, price, sub-text, pill settings, CTA settings, and individual link (entire card clickable).
    
    Layout controls: grid spacing, card padding/margins, card size, border radius, shadows, text alignment, image aspect ratio, and max-width.
    
    Separate desktop and mobile controls for spacing, alignment, and visibility.
    
    Fully responsive and visually balanced by default.
    
    The section must allow complete customization through the theme editor without modifying code., Give me control over the padding of the pills on each product card, Pill padding should effect the outside padding, not the inside of the pill
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-grid-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.section_max_width }}px;
    margin: 0 auto;
    padding: {{ block.settings.section_padding_desktop }}px {{ block.settings.section_horizontal_padding }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-product-grid-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_mobile }}px {{ block.settings.section_horizontal_padding_mobile }}px;
    }
  }

  .ai-product-grid-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size_desktop }}px;
    text-align: {{ block.settings.heading_alignment_desktop }};
    margin-bottom: {{ block.settings.heading_spacing_desktop }}px;
    color: {{ block.settings.heading_color }};
    font-weight: 600;
  }

  @media screen and (max-width: 749px) {
    .ai-product-grid-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
      text-align: {{ block.settings.heading_alignment_mobile }};
      margin-bottom: {{ block.settings.heading_spacing_mobile }}px;
      {% if block.settings.heading_hide_mobile %}
        display: none;
      {% endif %}
    }
  }

  {% if block.settings.heading_hide_desktop %}
    @media screen and (min-width: 750px) {
      .ai-product-grid-heading-{{ ai_gen_id }} {
        display: none;
      }
    }
  {% endif %}

  .ai-product-grid-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap_desktop }}px;
  }

  @media screen and (max-width: 989px) {
    .ai-product-grid-container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
      gap: {{ block.settings.grid_gap_tablet }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-product-grid-container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.grid_gap_mobile }}px;
    }
  }

  .ai-product-card-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    flex-direction: column;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    cursor: pointer;
    {% if block.settings.card_shadow %}
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    {% endif %}
  }

  .ai-product-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    {% if block.settings.card_shadow %}
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
    {% endif %}
  }

  .ai-product-card-pill-{{ ai_gen_id }} {
    position: absolute;
    z-index: 2;
    padding: {{ block.settings.pill_padding_vertical }}px {{ block.settings.pill_padding_horizontal }}px;
    font-size: {{ block.settings.pill_font_size }}px;
    font-weight: 600;
    border-radius: {{ block.settings.pill_border_radius }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-product-card-pill-{{ ai_gen_id }} {
      {% if block.settings.pill_hide_mobile %}
        display: none;
      {% endif %}
    }
  }

  {% if block.settings.pill_hide_desktop %}
    @media screen and (min-width: 750px) {
      .ai-product-card-pill-{{ ai_gen_id }} {
        display: none;
      }
    }
  {% endif %}

  .ai-product-card-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    margin-bottom: {{ block.settings.image_spacing }}px;
  }

  .ai-product-card-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-card-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-card-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-product-card-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-product-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    margin-bottom: {{ block.settings.title_spacing }}px;
    line-height: 1.3;
  }

  .ai-product-card-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_font_size }}px;
    font-weight: 700;
    color: {{ block.settings.price_color }};
    margin-bottom: {{ block.settings.price_spacing }}px;
  }

  .ai-product-card-subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_font_size }}px;
    color: {{ block.settings.subtext_color }};
    margin-bottom: {{ block.settings.subtext_spacing }}px;
    line-height: 1.5;
  }

  .ai-product-card-cta-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.cta_padding_vertical }}px {{ block.settings.cta_padding_horizontal }}px;
    background-color: {{ block.settings.cta_background }};
    color: {{ block.settings.cta_text_color }};
    font-size: {{ block.settings.cta_font_size }}px;
    font-weight: 600;
    border-radius: {{ block.settings.cta_border_radius }}px;
    text-decoration: none;
    transition: background-color 0.3s ease, color 0.3s ease;
    margin-top: auto;
    {% if block.settings.text_alignment == 'center' %}
      align-self: center;
    {% elsif block.settings.text_alignment == 'right' %}
      align-self: flex-end;
    {% else %}
      align-self: flex-start;
    {% endif %}
  }

  .ai-product-card-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_hover_background }};
    color: {{ block.settings.cta_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-product-card-cta-{{ ai_gen_id }} {
      {% if block.settings.cta_hide_mobile %}
        display: none;
      {% endif %}
    }
  }

  {% if block.settings.cta_hide_desktop %}
    @media screen and (min-width: 750px) {
      .ai-product-card-cta-{{ ai_gen_id }} {
        display: none;
      }
    }
  {% endif %}
{% endstyle %}

<div class="ai-product-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.section_heading != blank %}
    <h2 class="ai-product-grid-heading-{{ ai_gen_id }}">{{ block.settings.section_heading }}</h2>
  {% endif %}

  <div class="ai-product-grid-container-{{ ai_gen_id }}">
    {% for i in (1..12) %}
      {% liquid
        assign card_enabled_key = 'card_' | append: i | append: '_enabled'
        assign card_link_key = 'card_' | append: i | append: '_link'
        assign card_image_key = 'card_' | append: i | append: '_image'
        assign card_title_key = 'card_' | append: i | append: '_title'
        assign card_price_key = 'card_' | append: i | append: '_price'
        assign card_subtext_key = 'card_' | append: i | append: '_subtext'
        assign card_pill_text_key = 'card_' | append: i | append: '_pill_text'
        assign card_pill_bg_key = 'card_' | append: i | append: '_pill_bg'
        assign card_pill_text_color_key = 'card_' | append: i | append: '_pill_text_color'
        assign card_pill_offset_top_key = 'card_' | append: i | append: '_pill_offset_top'
        assign card_pill_offset_left_key = 'card_' | append: i | append: '_pill_offset_left'
        assign card_cta_text_key = 'card_' | append: i | append: '_cta_text'
        assign card_cta_link_key = 'card_' | append: i | append: '_cta_link'

        assign card_enabled = block.settings[card_enabled_key]
        assign card_link = block.settings[card_link_key]
        assign card_image = block.settings[card_image_key]
        assign card_title = block.settings[card_title_key]
        assign card_price = block.settings[card_price_key]
        assign card_subtext = block.settings[card_subtext_key]
        assign card_pill_text = block.settings[card_pill_text_key]
        assign card_pill_bg = block.settings[card_pill_bg_key]
        assign card_pill_text_color = block.settings[card_pill_text_color_key]
        assign card_pill_offset_top = block.settings[card_pill_offset_top_key]
        assign card_pill_offset_left = block.settings[card_pill_offset_left_key]
        assign card_cta_text = block.settings[card_cta_text_key]
        assign card_cta_link = block.settings[card_cta_link_key]
      %}

      {% if card_enabled %}
        <a
          href="{{ card_link }}"
          class="ai-product-card-{{ ai_gen_id }}"
          {% if card_link == blank %}onclick="return false;"{% endif %}
        >
          {% if card_pill_text != blank %}
            <span
              class="ai-product-card-pill-{{ ai_gen_id }}"
              style="background-color: {{ card_pill_bg }}; color: {{ card_pill_text_color }}; top: {{ card_pill_offset_top }}px; left: {{ card_pill_offset_left }}px;"
            >
              {{ card_pill_text }}
            </span>
          {% endif %}

          <div class="ai-product-card-image-wrapper-{{ ai_gen_id }}">
            {% if card_image %}
              <img
                src="{{ card_image | image_url: width: 800 }}"
                alt="{{ card_title | escape }}"
                class="ai-product-card-image-{{ ai_gen_id }}"
                loading="lazy"
                width="800"
                height="{{ 800 | times: block.settings.image_aspect_ratio | divided_by: 100 }}"
              >
            {% else %}
              <div class="ai-product-card-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <div class="ai-product-card-content-{{ ai_gen_id }}">
            {% if card_title != blank %}
              <h3 class="ai-product-card-title-{{ ai_gen_id }}">{{ card_title }}</h3>
            {% endif %}

            {% if card_price != blank %}
              <div class="ai-product-card-price-{{ ai_gen_id }}">{{ card_price }}</div>
            {% endif %}

            {% if card_subtext != blank %}
              <div class="ai-product-card-subtext-{{ ai_gen_id }}">{{ card_subtext }}</div>
            {% endif %}

            {% if card_cta_text != blank %}
              <span class="ai-product-card-cta-{{ ai_gen_id }}">
                {{ card_cta_text }}
              </span>
            {% endif %}
          </div>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Custom product grid",
  "settings": [
    {
      "type": "header",
      "content": "Section heading"
    },
    {
      "type": "text",
      "id": "section_heading",
      "label": "Heading"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "min": 16,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Size (desktop)",
      "default": 36
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Size (mobile)",
      "default": 28
    },
    {
      "type": "select",
      "id": "heading_alignment_desktop",
      "label": "Alignment (desktop)",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "heading_alignment_mobile",
      "label": "Alignment (mobile)",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "heading_spacing_desktop",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Bottom spacing (desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "heading_spacing_mobile",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Bottom spacing (mobile)",
      "default": 24
    },
    {
      "type": "checkbox",
      "id": "heading_hide_desktop",
      "label": "Hide on desktop",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "heading_hide_mobile",
      "label": "Hide on mobile",
      "default": false
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "label": "Columns (desktop)",
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Columns (tablet)",
      "default": 2
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns (mobile)",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "1"
    },
    {
      "type": "range",
      "id": "grid_gap_desktop",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Grid gap (desktop)",
      "default": 32
    },
    {
      "type": "range",
      "id": "grid_gap_tablet",
      "min": 0,
      "max": 48,
      "step": 4,
      "unit": "px",
      "label": "Grid gap (tablet)",
      "default": 24
    },
    {
      "type": "range",
      "id": "grid_gap_mobile",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Grid gap (mobile)",
      "default": 20
    },
    {
      "type": "range",
      "id": "section_max_width",
      "min": 1000,
      "max": 2000,
      "step": 50,
      "unit": "px",
      "label": "Max width",
