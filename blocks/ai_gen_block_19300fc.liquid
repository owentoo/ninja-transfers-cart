{% doc %}
  @prompt
    i need a section with a text section thats can take html with a max width
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-html-text-container-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    justify-content: center;
    padding: {{ block.settings.vertical_padding }}px 20px;
  }

  .ai-html-text-content-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.max_width }}px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    line-height: {{ block.settings.line_height }};
  }

  .ai-html-text-content-{{ ai_gen_id }} h1,
  .ai-html-text-content-{{ ai_gen_id }} h2,
  .ai-html-text-content-{{ ai_gen_id }} h3,
  .ai-html-text-content-{{ ai_gen_id }} h4,
  .ai-html-text-content-{{ ai_gen_id }} h5,
  .ai-html-text-content-{{ ai_gen_id }} h6 {
    margin-top: 0;
    margin-bottom: 16px;
    color: {{ block.settings.heading_color }};
  }

  .ai-html-text-content-{{ ai_gen_id }} p {
    margin-top: 0;
    margin-bottom: 16px;
  }

  .ai-html-text-content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-html-text-content-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: underline;
  }

  .ai-html-text-content-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-html-text-content-{{ ai_gen_id }} ul,
  .ai-html-text-content-{{ ai_gen_id }} ol {
    margin-top: 0;
    margin-bottom: 16px;
    padding-left: 24px;
  }

  .ai-html-text-content-{{ ai_gen_id }} li {
    margin-bottom: 8px;
  }

  .ai-html-text-content-{{ ai_gen_id }} img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  .ai-html-text-content-{{ ai_gen_id }} blockquote {
    margin: 20px 0;
    padding-left: 20px;
    border-left: 4px solid {{ block.settings.text_color }};
    font-style: italic;
  }

  .ai-html-text-content-{{ ai_gen_id }} table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 16px;
  }

  .ai-html-text-content-{{ ai_gen_id }} th,
  .ai-html-text-content-{{ ai_gen_id }} td {
    padding: 12px;
    border: 1px solid {{ block.settings.text_color }};
    text-align: left;
  }

  .ai-html-text-content-{{ ai_gen_id }} th {
    font-weight: 600;
    background-color: {{ block.settings.table_header_bg }};
  }

  @media screen and (max-width: 749px) {
    .ai-html-text-content-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-html-text-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-html-text-content-{{ ai_gen_id }}">
    {% if block.settings.html_content != blank %}
      {{ block.settings.html_content }}
    {% else %}
      <p style="color: #999; text-align: center; font-style: italic;">Add your HTML content in the block settings</p>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "HTML text section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "html",
      "id": "html_content",
      "label": "HTML content"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 400,
      "max": 1400,
      "step": 50,
      "unit": "px",
      "label": "Maximum width",
      "default": 800
    },
    {
      "type": "range",
      "id": "vertical_padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Vertical padding",
      "default": 40
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 16
    },
    {
      "type": "range",
      "id": "line_height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "label": "Line height",
      "default": 1.6
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#019aff"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link hover color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "table_header_bg",
      "label": "Table header background",
      "default": "#f2f2f2"
    }
  ],
  "presets": [
    {
      "name": "HTML text section"
    }
  ]
}
{% endschema %}