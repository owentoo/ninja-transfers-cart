{% doc %}
  @prompt
    i need a three coulm layout with two line of text above an image in each coolumn , section needs max width with horizontal padding that matches the themes , each line of text needs a weight and size option 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-three-column-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 0;
  }

  .ai-three-column-wrapper-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .ai-three-column-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.column_gap }}px;
  }

  .ai-three-column-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.text_spacing }}px;
  }

  .ai-three-column-text-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.text_spacing }}px;
  }

  .ai-three-column-text-line-1-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_line_1_size }}px;
    font-weight: {{ block.settings.text_line_1_weight }};
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_alignment }};
    margin: 0;
  }

  .ai-three-column-text-line-2-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_line_2_size }}px;
    font-weight: {{ block.settings.text_line_2_weight }};
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_alignment }};
    margin: 0;
  }

  .ai-three-column-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-three-column-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
  }

  .ai-three-column-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-three-column-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media screen and (max-width: 989px) {
    .ai-three-column-container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-three-column-wrapper-{{ ai_gen_id }} {
      padding: 0 20px;
    }

    .ai-three-column-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.column_gap | times: 0.75 }}px;
    }

    .ai-three-column-text-line-1-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_line_1_size | times: 0.9 }}px;
    }

    .ai-three-column-text-line-2-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_line_2_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-three-column-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-three-column-wrapper-{{ ai_gen_id }}">
    <div class="ai-three-column-container-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign text_line_1_key = 'column_' | append: i | append: '_text_line_1'
          assign text_line_2_key = 'column_' | append: i | append: '_text_line_2'
          assign image_key = 'column_' | append: i | append: '_image'
          
          assign text_line_1 = block.settings[text_line_1_key]
          assign text_line_2 = block.settings[text_line_2_key]
          assign image = block.settings[image_key]
        %}
        
        <div class="ai-three-column-item-{{ ai_gen_id }}">
          <div class="ai-three-column-text-wrapper-{{ ai_gen_id }}">
            {% if text_line_1 != blank %}
              <p class="ai-three-column-text-line-1-{{ ai_gen_id }}">{{ text_line_1 }}</p>
            {% endif %}
            {% if text_line_2 != blank %}
              <p class="ai-three-column-text-line-2-{{ ai_gen_id }}">{{ text_line_2 }}</p>
            {% endif %}
          </div>
          
          <div class="ai-three-column-image-wrapper-{{ ai_gen_id }}">
            {% if image %}
              <img
                src="{{ image | image_url: width: 800 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
                class="ai-three-column-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-three-column-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

