{% doc %}
  @prompt
    i need link blocks with an image heading and two separate lines of text underneath on desktop they display 2-6 per row and on mobile 1-2 , give the section a max width with horizontal padding and margin rules that match the themes, need top and bottom padding options , i need spacing and size for all text on desktop and mobile , and weight a color options for the first and second line of text, don't need Letter spacing, and heading needs weight option, give me a shadow option for all link blocks and give me horizontal padding options that apply outside the max width for desktop and mobile in increments of 2 , give me a section max width , Horizontal padding is not working it needs to apply outside the content , i need up to 16 links 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-link-wrapper-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.horizontal_padding_desktop }}px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-link-section-{{ ai_gen_id }} {
    max-width: {{ block.settings.section_max_width }}px;
    margin: 0 auto;
  }

  .ai-link-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-link-card-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
    color: inherit;
    background-color: {{ block.settings.card_background_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    {% if block.settings.card_shadow_blur > 0 %}
      box-shadow: 0 {{ block.settings.card_shadow_vertical }}px {{ block.settings.card_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity | divided_by: 100.0 }});
    {% endif %}
  }

  .ai-link-card-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
    box-shadow: 0 {{ block.settings.hover_shadow }}px {{ block.settings.hover_shadow | times: 2 }}px rgba(0, 0, 0, 0.1);
  }

  .ai-link-card-image-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    overflow: hidden;
    position: relative;
  }

  .ai-link-card-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-link-card-{{ ai_gen_id }}:hover .ai-link-card-image-{{ ai_gen_id }} img {
    transform: scale({{ block.settings.image_hover_scale }});
  }

  .ai-link-card-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-link-card-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-link-card-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding_top }}px {{ block.settings.card_padding_horizontal }}px {{ block.settings.card_padding_bottom }}px;
  }

  .ai-link-card-heading-{{ ai_gen_id }} {
    font-family: {{ settings.headings_font_primary.family }}, {{ settings.headings_font_primary.fallback_families }};
    font-weight: {{ block.settings.heading_weight }};
    font-size: {{ block.settings.heading_size_desktop }}px;
    line-height: {{ block.settings.heading_line_height }};
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px 0;
  }

  .ai-link-card-text-1-{{ ai_gen_id }} {
    font-family: {{ settings.body_font_primary.family }}, {{ settings.body_font_primary.fallback_families }};
    font-weight: {{ block.settings.text_1_weight }};
    font-size: {{ block.settings.text_size_desktop }}px;
    line-height: {{ block.settings.text_line_height }};
    color: {{ block.settings.text_1_color }};
    margin: 0 0 {{ block.settings.text_margin_bottom }}px 0;
  }

  .ai-link-card-text-2-{{ ai_gen_id }} {
    font-family: {{ settings.body_font_primary.family }}, {{ settings.body_font_primary.fallback_families }};
    font-weight: {{ block.settings.text_2_weight }};
    font-size: {{ block.settings.text_size_desktop }}px;
    line-height: {{ block.settings.text_line_height }};
    color: {{ block.settings.text_2_color }};
    margin: 0 0 {{ block.settings.text_margin_bottom }}px 0;
  }

  .ai-link-card-text-2-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-link-wrapper-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top_mobile }}px {{ block.settings.horizontal_padding_mobile }}px {{ block.settings.section_padding_bottom_mobile }}px;
    }

    .ai-link-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.grid_gap_mobile }}px;
    }

    .ai-link-card-content-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding_top_mobile }}px {{ block.settings.card_padding_horizontal_mobile }}px {{ block.settings.card_padding_bottom_mobile }}px;
    }

    .ai-link-card-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
      line-height: {{ block.settings.heading_line_height_mobile }};
      margin-bottom: {{ block.settings.heading_margin_bottom_mobile }}px;
    }

    .ai-link-card-text-1-{{ ai_gen_id }},
    .ai-link-card-text-2-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
      line-height: {{ block.settings.text_line_height_mobile }};
      margin-bottom: {{ block.settings.text_margin_bottom_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-link-wrapper-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-link-section-{{ ai_gen_id }}">
    <div class="ai-link-grid-{{ ai_gen_id }}">
      {% for i in (1..16) %}
        {% liquid
          assign link_key = 'link_' | append: i
          assign image_key = 'image_' | append: i
          assign heading_key = 'heading_' | append: i
          assign text_1_key = 'text_1_' | append: i
          assign text_2_key = 'text_2_' | append: i

          assign link_url = block.settings[link_key]
          assign image = block.settings[image_key]
          assign heading = block.settings[heading_key]
          assign text_1 = block.settings[text_1_key]
          assign text_2 = block.settings[text_2_key]
        %}

        {% if heading != blank or text_1 != blank or text_2 != blank or image != blank %}
          <a
            href="{{ link_url | default: '#' }}"
            class="ai-link-card-{{ ai_gen_id }}"
            {% if link_url == blank %}onclick="return false;"{% endif %}
          >
            <div class="ai-link-card-image-{{ ai_gen_id }}">
              {% if image %}
                <img
                  src="{{ image | image_url: width: 600 }}"
                  alt="{{ image.alt | escape }}"
                  loading="lazy"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                >
              {% else %}
                <div class="ai-link-card-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <div class="ai-link-card-content-{{ ai_gen_id }}">
              {% if heading != blank %}
                <h3 class="ai-link-card-heading-{{ ai_gen_id }}">{{ heading }}</h3>
              {% endif %}

              {% if text_1 != blank %}
                <p class="ai-link-card-text-1-{{ ai_gen_id }}">{{ text_1 }}</p>
              {% endif %}

              {% if text_2 != blank %}
                <p class="ai-link-card-text-2-{{ ai_gen_id }}">{{ text_2 }}</p>
              {% endif %}
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

