{% doc %}
  @prompt
    create me a four column grid with an mage and a heading and para text in each. images should have all setting like ratio and radius, all text should have weight and size option. section should hve a bg color and max width, as well as padding and margins, bg color needs to go full width, and add a gradient bg option. and a h2 and para above it all with alignment options, all text needs alignment option, everything needs mobile and desktop rules, i don't need tablet rules.

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
.four-column-section-{{ ai_gen_id }} {
  background-color: {{ block.settings.background_color }};
  {% if block.settings.enable_gradient %}
    background-image: linear-gradient({{ block.settings.gradient_direction }}deg, {{ block.settings.gradient_color_1 }}, {{ block.settings.gradient_color_2 }});
  {% endif %}
  padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
  margin: {{ block.settings.margin_top }}px 0 {{ block.settings.margin_bottom }}px;
  width: 100%;
}

.four-column-section__inner-{{ ai_gen_id }} {
  max-width: {{ block.settings.max_width }}px;
  margin: 0 auto;
  padding: 0 {{ block.settings.padding_horizontal }}px;
}

.four-column-section__header-{{ ai_gen_id }} {
  text-align: {{ block.settings.header_alignment }};
  margin-bottom: {{ block.settings.header_bottom_margin }}px;
}

.four-column-section__title-{{ ai_gen_id }} {
  font-size: {{ block.settings.title_size }}px;
  font-weight: {{ block.settings.title_weight }};
  color: {{ block.settings.title_color }};
  margin-top: 0;
  margin-bottom: {{ block.settings.title_bottom_margin }}px;
}

.four-column-section__subtitle-{{ ai_gen_id }} {
  font-size: {{ block.settings.subtitle_size }}px;
  font-weight: {{ block.settings.subtitle_weight }};
  color: {{ block.settings.subtitle_color }};
  line-height: 1.5;
  margin: 0;
}

.four-column-grid__container-{{ ai_gen_id }} {
  display: grid;
  grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
  gap: {{ block.settings.column_gap }}px;
}

.four-column-grid__column-{{ ai_gen_id }} {
  display: flex;
  flex-direction: column;
}

.four-column-grid__image-wrapper-{{ ai_gen_id }} {
  position: relative;
  width: 100%;
  overflow: hidden;
  border-radius: {{ block.settings.image_border_radius }}px;
  margin-bottom: {{ block.settings.image_bottom_margin }}px;
}

.four-column-grid__image-wrapper-{{ ai_gen_id }}::before {
  content: "";
  display: block;
  padding-bottom: calc(100% / ({{ block.settings.image_aspect_ratio }}));
}

.four-column-grid__image-{{ ai_gen_id }} {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: {{ block.settings.image_fit }};
  object-position: center;
}

.four-column-grid__image-placeholder-{{ ai_gen_id }} {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f4f4f4;
}

.four-column-grid__image-placeholder-{{ ai_gen_id }} svg {
  width: 50%;
  height: 50%;
}

.four-column-grid__heading-{{ ai_gen_id }} {
  font-size: {{ block.settings.heading_size }}px;
  font-weight: {{ block.settings.heading_weight }};
  margin-top: 0;
  margin-bottom: {{ block.settings.heading_bottom_margin }}px;
  color: {{ block.settings.heading_color }};
  text-align: {{ block.settings.column_text_alignment }};
}

.four-column-grid__text-{{ ai_gen_id }} {
  font-size: {{ block.settings.text_size }}px;
  font-weight: {{ block.settings.text_weight }};
  line-height: 1.5;
  color: {{ block.settings.text_color }};
  text-align: {{ block.settings.column_text_alignment }};
}

@media screen and (max-width: 749px) {
  .four-column-section__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size_mobile }}px;
    text-align: {{ block.settings.header_alignment_mobile }};
  }
  
  .four-column-section__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size_mobile }}px;
    text-align: {{ block.settings.header_alignment_mobile }};
  }
  
  .four-column-section__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.header_alignment_mobile }};
  }
  
  .four-column-grid__container-{{ ai_gen_id }} {
    grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    gap: {{ block.settings.column_gap_mobile }}px;
  }
  
  .four-column-grid__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size_mobile }}px;
    text-align: {{ block.settings.column_text_alignment_mobile }};
  }
  
  .four-column-grid__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size_mobile }}px;
    text-align: {{ block.settings.column_text_alignment_mobile }};
  }
  
  .four-column-section-{{ ai_gen_id }} {
    padding: {{ block.settings.padding_top_mobile }}px 0 {{ block.settings.padding_bottom_mobile }}px;
  }
  
  .four-column-section__inner-{{ ai_gen_id }} {
    padding: 0 {{ block.settings.padding_horizontal_mobile }}px;
  }
}
{% endstyle %}

<div class="four-column-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="four-column-section__inner-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.subtitle != blank %}
      <div class="four-column-section__header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="four-column-section__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        
        {% if block.settings.subtitle != blank %}
          <div class="four-column-section__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
        {% endif %}
      </div>
    {% endif %}
    
    <div class="four-column-grid__container-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign heading_key = 'heading_' | append: i
          assign text_key = 'text_' | append: i
          
          assign image = block.settings[image_key]
          assign heading = block.settings[heading_key]
          assign text = block.settings[text_key]
        %}
        
        <div class="four-column-grid__column-{{ ai_gen_id }}">
          <div class="four-column-grid__image-wrapper-{{ ai_gen_id }}">
            {% if image != blank %}
              <img
                src="{{ image | image_url: width: 600 }}"
                alt="{{ image.alt | escape }}"
                width="{{ image.width }}"
                height="{{ image.height }}"
                loading="lazy"
                class="four-column-grid__image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="four-column-grid__image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          
          {% if heading != blank %}
            <h3 class="four-column-grid__heading-{{ ai_gen_id }}">{{ heading }}</h3>
          {% endif %}
          
          {% if text != blank %}
            <div class="four-column-grid__text-{{ ai_gen_id }}">{{ text }}</div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

