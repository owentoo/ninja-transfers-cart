{% doc %}
  @prompt
    i need a section with a make width and a flex container with a embeded youtube video on the right that's width can be controlled by a width pertentage on the left i need a container with a h1 papa text, and cta in it, i need a bg color option and all text needs mobile and desktop options for size and weight, the video needs an autoplay option and radius i need section padding and margin top and bottom for desktop and mobile. and an optional video placeholder image, bg color should take up the while section, section need top bottom left and right margin and padding options for desktop and mobile. cta needs padding and text weight options, simlify the layout options and add an option to swap the video and text position, i need section padding options for all sides and max width of content is not being followed, section padding needs to apply to the content within it, add line height option to h1 and text section alignment for dektop and mobile, and a space between the video and text for desktop and an option for the video to be above the text on mobile

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-text-section-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    margin-top: {{ block.settings.margin_top_desktop }}px;
    margin-bottom: {{ block.settings.margin_bottom_desktop }}px;
  }

  .ai-video-text-section-inner-{{ ai_gen_id }} {
    padding-top: {{ block.settings.padding_top_desktop }}px;
    padding-bottom: {{ block.settings.padding_bottom_desktop }}px;padding-left: {{ block.settings.padding_left_desktop }}px;
    padding-right: {{ block.settings.padding_right_desktop }}px;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    width: 100%;
  }

  .ai-video-text-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: {% if block.settings.swap_position %}row-reverse{% else %}row{% endif %};
    gap: {{ block.settings.gap_desktop }}px;
    width: 100%;align-items: center;
  }

  .ai-video-text-content-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: {{ block.settings.content_gap }}px;text-align: {{ block.settings.text_alignment_desktop }};
  }

  .ai-video-text-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size_desktop }}px;
    font-weight: {{ block.settings.heading_weight_desktop }};
    line-height: {{ block.settings.heading_line_height }};
    color: {{ block.settings.heading_color }};
    margin:0;
  }

  .ai-video-text-paragraph-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size_desktop }}px;
    font-weight: {{ block.settings.text_weight_desktop }};
    line-height: {{ block.settings.text_line_height }};
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-video-text-cta-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 2 }}px;
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size_desktop }}px;
    font-weight: {{ block.settings.button_weight_desktop }};
    transition: background-color 0.3s;margin-top: 10px;
    {% if block.settings.text_alignment_desktop == 'center' %}
      align-self: center;
    {% elsif block.settings.text_alignment_desktop == 'right' %}
      align-self: flex-end;
    {% else %}
      align-self: flex-start;
    {% endif %}
  }

  .ai-video-text-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-video-container-{{ ai_gen_id }} {
    width: {{ block.settings.video_width }}%;
    position: relative;
  }

  .ai-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
  }

  .ai-video-wrapper-{{ ai_gen_id }} iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: {{ block.settings.video_border_radius }}px;}

  .ai-video-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: {{ block.settings.video_border_radius }}px;
  }

  .youtube-video-picture{z-index:1; cursor:pointer;}
  .ai-video-text-section-{{ ai_gen_id }} .play-icon{z-index:2; pointer-events:none; margin: auto; width:{{ block.settings.play_icon_image_width }}px; height:{{ block.settings.play_icon_image_width }}px; left: 50%; margin-left: -{{ block.settings.play_icon_image_width | divided_by : 2 }}px; top: 50%; margin-top: -{{ block.settings.play_icon_image_width | divided_by : 2 }}px;}
  
  @media screen and (max-width: 768px) {
    .ai-video-text-section-{{ ai_gen_id }} .play-icon{width:{{ block.settings.play_icon_image_mobile }}px; height:{{ block.settings.play_icon_image_mobile }}px; left: 50%; margin-left: -{{ block.settings.play_icon_image_mobile | divided_by : 2 }}px; top: 50%; margin-top: -{{ block.settings.play_icon_image_mobile | divided_by : 2 }}px;}
    .ai-video-text-section-{{ ai_gen_id }} {
      margin-top: {{ block.settings.margin_top_mobile }}px;
      margin-bottom: {{ block.settings.margin_bottom_mobile }}px;
    }

    .ai-video-text-section-inner-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top_mobile }}px;
      padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
      padding-left: {{ block.settings.padding_left_mobile }}px;
      padding-right: {{ block.settings.padding_right_mobile }}px;
    }

    .ai-video-text-container-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.gap_mobile }}px;
    }

    .ai-video-container-{{ ai_gen_id }} {
      width: 100%;
      {% if block.settings.video_above_text_mobile %}
        order: 1;
      {% else %}
        order: {% if block.settings.swap_position %}1{% else %}2{% endif %};
      {% endif %}
    }

    .ai-video-text-content-{{ ai_gen_id }} {
      {% if block.settings.video_above_text_mobile %}
        order: 2;
      {% else %}
        order: {% if block.settings.swap_position %}2{% else %}1{% endif %};
      {% endif %}text-align: {{ block.settings.text_alignment_mobile }};
    }

    .ai-video-text-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
      font-weight: {{ block.settings.heading_weight_mobile }};}

    .ai-video-text-paragraph-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
      font-weight: {{ block.settings.text_weight_mobile }};
    }

    .ai-video-text-cta-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_text_size_mobile }}px;
      font-weight: {{ block.settings.button_weight_mobile }};
      {% if block.settings.text_alignment_mobile == 'center' %}
        align-self: center;
      {% elsif block.settings.text_alignment_mobile == 'right' %}
        align-self: flex-end;
      {% else %}
        align-self: flex-start;
      {% endif %}
    }
  }
{% endstyle %}

<div class="ai-video-text-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-video-text-section-inner-{{ ai_gen_id }}">
    <div class="ai-video-text-container-{{ ai_gen_id }}">
      <div class="ai-video-text-content-{{ ai_gen_id }}">
        <h1 class="ai-video-text-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h1>
        <div class="ai-video-text-paragraph-{{ ai_gen_id }}">{{ block.settings.paragraph }}</div>
        {% if block.settings.button_text != blank and block.settings.button_link != blank %}
          <a href="{{ block.settings.button_link }}" class="ai-video-text-cta-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </a>
        {% endif %}
      </div><div class="ai-video-container-{{ ai_gen_id }}">
        <div class="ai-video-wrapper-{{ ai_gen_id }}">
          <div class="video-container" {% if block.settings.placeholder_image %}onclick="playVideo(this)"{% endif %}>
          {% if block.settings.youtube_url != blank %}
            {% assign youtube_id = block.settings.youtube_url | split: "v=" | last | split: "&" | first %}
            {% if block.settings.placeholder_image %}
              {% if block.settings.play_icon_image %}
                <img src="{{ block.settings.play_icon_image | image_url: width: block.settings.play_icon_image_width }}"  alt="{{ block.settings.placeholder_image.alt | escape }}" class="play-icon ai-video-placeholder-{{ ai_gen_id }}"loading="lazy"
                    width="{{ block.settings.play_icon_image_width }}" />
              {% endif %}
            <img 
              src="{{ block.settings.placeholder_image | image_url: width: 1200}}" 
              alt="{{ block.settings.placeholder_image.alt | escape }}"
              class="youtube-video-picture ai-video-placeholder-{{ ai_gen_id }}"loading="lazy"
              width="{{ block.settings.placeholder_image.width }}"
              height="{{ block.settings.placeholder_image.height }}"
            >
            {% endif %}
            <iframe 
              src="https://www.youtube.com/embed/{{ youtube_id }}{% if block.settings.autoplay %}?autoplay=1&mute=1{% endif %}" 
              frameborder="0" 
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
              allowfullscreen>
            </iframe>
            </div>
{% if block.settings.placeholder_image %}
          <script>
              function playVideo(container) {
                const videoId = "{{ youtube_id }}"; // Your YouTube video ID
                const iframe = document.createElement('iframe');
                iframe.setAttribute('src', `https://www.youtube.com/embed/${videoId}?autoplay=1`);
                iframe.setAttribute('frameborder', '0');
                iframe.setAttribute('allow', 'autoplay; encrypted-media; fullscreen');
                iframe.setAttribute('allowfullscreen', '1');
                iframe.style.width = '100%';
                iframe.style.height = '100%';
                container.innerHTML = ''; // Remove thumbnail and play button
                container.appendChild(iframe);
              }
            </script>
  {% endif %}
          {% elsif block.settings.placeholder_image %}
            <img 
              src="{{ block.settings.placeholder_image | image_url: width: 1200}}" 
              alt="{{ block.settings.placeholder_image.alt | escape }}"
              class="ai-video-placeholder-{{ ai_gen_id }}"loading="lazy"
              width="{{ block.settings.placeholder_image.width }}"
              height="{{ block.settings.placeholder_image.height }}"
            >
          {% else %}
            <div style="background-color: #f4f4f4; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; position: absolute; border-radius: {{ block.settings.video_border_radius }}px;">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M19 4H5C3.89543 4 3 4.89543 3 6V18C3 19.1046 3.89543 20 5 20H19C20.1046 20 21 19.1046 21 18V6C21 4.89543 20.1046 4 19 4Z" stroke="#888888" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M10 8L16 12L10 16V8Z" stroke="#888888" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

