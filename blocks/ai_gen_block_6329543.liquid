{% doc %}
  @prompt
    Create a homepage hero section with a background video and dynamic headline. Include a background video with fallback image, overlay options, and responsive padding. Add a main heading with highlighted words that can be customized, a subheading, feature badges, call-to-action buttons, and a stats display. Make everything responsive with text alignment and sizing controls for different devices.

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .hero-section-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  @media screen and (max-width: 749px) {
    .hero-section-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top_mobile }}px;
      padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
    }
  }

  .hero-section__background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .hero-section__video-wrapper-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .hero-section__video-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    min-width: 100%;
    min-height: 100%;
    width: auto;
    height: auto;
    transform: translate(-50%, -50%);
    object-fit: cover;
  }

  .hero-section__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-section__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-section__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
    object-fit: cover;
  }

  .hero-section__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 2;
  }

  .hero-section__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    max-width: {{ block.settings.content_width }}px;
    width: 100%;
    padding: 0 20px;
    margin: 0 auto;
  }

  .hero-section__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
    margin-bottom: 20px;
    color: {{ block.settings.heading_color }};
  }

  .hero-section__heading-highlight-{{ ai_gen_id }} {
    color: {{ block.settings.highlight_color }};
    background: {{ block.settings.highlight_background }};
    padding: 0 8px;
    border-radius: 4px;
    display: inline;
  }

  .hero-section__subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    line-height: 1.4;
    margin-bottom: 30px;
    color: {{ block.settings.subheading_color }};
  }

  .hero-section__badges-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
    margin-bottom: 30px;
    justify-content: {{ block.settings.text_alignment }};
  }

  .hero-section__badge-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    background-color: {{ block.settings.badge_background }};
    padding: 8px 15px;
    border-radius: 50px;
  }

  .hero-section__badge-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    margin-right: 8px;
    color: {{ block.settings.badge_color }};
  }

  .hero-section__badge-text-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 500;
    color: {{ block.settings.badge_color }};
  }

  .hero-section__buttons-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
    margin-bottom: 30px;
    justify-content: {{ block.settings.text_alignment }};
  }

  .hero-section__button-primary-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.button_primary_background }};
    color: {{ block.settings.button_primary_color }};
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
    transition: background-color 0.3s;
  }

  .hero-section__button-primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_primary_hover_background }};
  }

  .hero-section__button-secondary-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.button_secondary_background }};
    color: {{ block.settings.button_secondary_color }};
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
    transition: background-color 0.3s;
  }

  .hero-section__button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_secondary_hover_background }};
  }

  .hero-section__stats-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 30px;
    justify-content: {{ block.settings.text_alignment }};
  }

  .hero-section__stat-{{ ai_gen_id }} {
    text-align: center;
  }

  .hero-section__stat-number-{{ ai_gen_id }} {
    font-size: 36px;
    font-weight: 700;
    color: {{ block.settings.stats_number_color }};
    margin-bottom: 5px;
  }

  .hero-section__stat-label-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.stats_label_color }};
  }

  @media screen and (max-width: 749px) {
    .hero-section__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .hero-section__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size_mobile }}px;
    }

    .hero-section__badges-{{ ai_gen_id }},
    .hero-section__buttons-{{ ai_gen_id }},
    .hero-section__stats-{{ ai_gen_id }} {
      justify-content: center;
    }
  }
{% endstyle %}

<div class="hero-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="hero-section__background-{{ ai_gen_id }}">
    {% if block.settings.video_url != blank %}
      <div class="hero-section__video-wrapper-{{ ai_gen_id }}">
        <video 
          class="hero-section__video-{{ ai_gen_id }}" 
          autoplay 
          muted 
          loop 
          playsinline
          {% if block.settings.video_load_priority == 'lazy' %}loading="lazy"{% endif %}
        >
          <source src="{{ block.settings.video_url }}" type="video/mp4">
        </video>
      </div>
    {% elsif block.settings.background_image %}
      <img 
        src="{{ block.settings.background_image | image_url: width: 2000 }}" 
        alt="{{ block.settings.background_image.alt | escape }}" 
        class="hero-section__image-{{ ai_gen_id }}" 
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="hero-section__image-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  {% if block.settings.show_overlay %}
    <div class="hero-section__overlay-{{ ai_gen_id }}"></div>
  {% endif %}

  <div class="hero-section__content-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h1 class="hero-section__heading-{{ ai_gen_id }}">
        {% assign heading_parts = block.settings.heading | split: block.settings.highlight_text %}
        {{ heading_parts[0] }}
        {% if block.settings.highlight_text != blank and heading_parts.size > 1 %}
          <span class="hero-section__heading-highlight-{{ ai_gen_id }}">{{ block.settings.highlight_text }}</span>
          {{ heading_parts[1] }}
        {% endif %}
      </h1>
    {% endif %}

    {% if block.settings.subheading != blank %}
      <div class="hero-section__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
    {% endif %}

    {% if block.settings.show_badges %}
      <div class="hero-section__badges-{{ ai_gen_id }}">
        {% for i in (1..3) %}
          {% assign badge_text_key = 'badge_' | append: i | append: '_text' %}
          {% assign badge_text = block.settings[badge_text_key] %}
          
          {% if badge_text != blank %}
            <div class="hero-section__badge-{{ ai_gen_id }}">
              <div class="hero-section__badge-icon-{{ ai_gen_id }}">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </div>
              <div class="hero-section__badge-text-{{ ai_gen_id }}">{{ badge_text }}</div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    <div class="hero-section__buttons-{{ ai_gen_id }}">
      {% if block.settings.button_primary_text != blank and block.settings.button_primary_link != blank %}
        <a href="{{ block.settings.button_primary_link }}" class="hero-section__button-primary-{{ ai_gen_id }}">
          {{ block.settings.button_primary_text }}
        </a>
      {% endif %}

      {% if block.settings.button_secondary_text != blank and block.settings.button_secondary_link != blank %}
        <a href="{{ block.settings.button_secondary_link }}" class="hero-section__button-secondary-{{ ai_gen_id }}">
          {{ block.settings.button_secondary_text }}
        </a>
      {% endif %}
    </div>

    {% if block.settings.show_stats %}
      <div class="hero-section__stats-{{ ai_gen_id }}">
        {% for i in (1..3) %}
          {% assign stat_number_key = 'stat_' | append: i | append: '_number' %}
          {% assign stat_label_key = 'stat_' | append: i | append: '_label' %}
          {% assign stat_number = block.settings[stat_number_key] %}
          {% assign stat_label = block.settings[stat_label_key] %}
          
          {% if stat_number != blank and stat_label != blank %}
            <div class="hero-section__stat-{{ ai_gen_id }}">
              <div class="hero-section__stat-number-{{ ai_gen_id }}">{{ stat_number }}</div>
              <div class="hero-section__stat-label-{{ ai_gen_id }}">{{ stat_label }}</div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "header",
      "content": "Background Media"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Background video URL",
      "info": "MP4 format recommended. Will take priority over background image."
    },
    {
      "type": "select",
      "id": "video_load_priority",
      "label": "Video load priority",
      "options": [
        {
          "value": "eager",
          "label": "Eager (load immediately)"
        },
        {
          "value": "lazy",
          "label": "Lazy (load when visible)"
        }
      ],
      "default": "lazy"
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show overlay",
      "default": true
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 50
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "range",
      "id": "content_width",
      "min": 500,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Content width",
      "default": 1000
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Discover our amazing products"
    },
    {
      "type": "text",
