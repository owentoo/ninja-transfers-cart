{% doc %}
  @prompt
    Create a flexible theme section with a two-column layout where the left column (1/3 width) contains a video player with a comprehensive text overlay including title header, subtext, and customizable button, plus adjustable video size controls, and the right column (2/3 width) provides a custom HTML/CSS/Liquid area for embedding forms or custom content. Include section settings for video upload, video size/dimensions control, overlay title text, overlay subtext, button text and link, and a rich text area for custom code input., the video isnt loading, Nothing is working or updating

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-content-block-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-video-content-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-video-content-layout-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: {{ block.settings.column_gap }}px;align-items: {{ block.settings.vertical_alignment }};
  }

  .ai-video-column-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-video-player-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    max-width: {{ block.settings.video_max_width }}px;
    aspect-ratio: {{ block.settings.video_aspect_ratio }};
    border-radius: {{ block.settings.video_border_radius }}px;
    overflow: hidden;
    background-color: #000;
  }

  .ai-video-player-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-video-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #666;
    flex-direction: column;gap: 10px;
  }

  .ai-video-placeholder-{{ ai_gen_id }} svg {
    width: 80px;
    height: 80px;opacity: 0.5;
  }

  .ai-video-placeholder-text-{{ ai_gen_id }} {
    font-size: 14px;
    text-align: center;}

  .ai-video-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
      {{ block.settings.overlay_direction }},
      {{ block.settings.overlay_color | color_modify: 'alpha', block.settings.overlay_opacity }}
    );
    display: flex;
    flex-direction: column;
    justify-content: {{ block.settings.overlay_vertical_position }};
    align-items: {{ block.settings.overlay_horizontal_position }};
    padding: {{ block.settings.overlay_padding }}px;
    text-align: {{ block.settings.text_alignment }};}

  .ai-video-overlay-title-{{ ai_gen_id }} {
    color: {{ block.settings.overlay_title_color }};
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: 600;
    margin: 0 0 {{ block.settings.title_margin_bottom }}px;
    line-height: 1.2;
  }

  .ai-video-overlay-subtext-{{ ai_gen_id }} {
    color: {{ block.settings.overlay_text_color }};
    font-size: {{ block.settings.subtext_font_size }}px;
    margin: 0 0 {{ block.settings.subtext_margin_bottom }}px;
    line-height: 1.4;
  }

  .ai-video-overlay-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 500;
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
  }

  .ai-video-overlay-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};transform: translateY(-2px);
  }

  .ai-content-column-{{ ai_gen_id }} {
    background-color: {{ block.settings.content_background_color }};
    padding: {{ block.settings.content_padding }}px;
    border-radius: {{ block.settings.content_border_radius }}px;
    border: {{ block.settings.content_border_width }}px solid {{ block.settings.content_border_color }};
  }

  .ai-custom-content-{{ ai_gen_id }} {
    width: 100%;
    color: {{ block.settings.content_text_color }};
  }

  @media screen and (max-width: 768px) {
    .ai-video-content-layout-{{ ai_gen_id }} {
      grid-template-columns: 1fr;gap: {{ block.settings.mobile_gap }}px;
    }

    .ai-video-player-wrapper-{{ ai_gen_id }} {
      max-width: 100%;
    }

    .ai-video-overlay-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size | times: 0.8 }}px;
    }

    .ai-video-overlay-subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_font_size | times: 0.9 }}px;
    }

    .ai-content-column-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding | times: 0.7 }}px;
    }
  }
{% endstyle %}

<div class="ai-video-content-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-video-content-container-{{ ai_gen_id }}">
    <div class="ai-video-content-layout-{{ ai_gen_id }}">
      <div class="ai-video-column-{{ ai_gen_id }}">
        <div class="ai-video-player-wrapper-{{ ai_gen_id }}">
          {% if block.settings.video %}
            {{ block.settings.video | video_tag: 
              class: 'ai-video-player-' | append: ai_gen_id,
              autoplay: block.settings.video_autoplay,
              muted: block.settings.video_muted,
              loop: block.settings.video_loop,
              controls: block.settings.video_controls,
              playsinline: true
            }}
          {% else %}
            <div class="ai-video-placeholder-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="5,3 19,12 5,21"></polygon>
              </svg>
              <div class="ai-video-placeholder-text-{{ ai_gen_id }}">Upload a video in block settings</div>
            </div>
          {% endif %}

          {% if block.settings.show_overlay and block.settings.video %}
            <div class="ai-video-overlay-{{ ai_gen_id }}">
              {% if block.settings.overlay_title != blank %}
                <h2 class="ai-video-overlay-title-{{ ai_gen_id }}">{{ block.settings.overlay_title }}</h2>
              {% endif %}

              {% if block.settings.overlay_subtext != blank %}
                <div class="ai-video-overlay-subtext-{{ ai_gen_id }}">{{ block.settings.overlay_subtext }}</div>
              {% endif %}

              {% if block.settings.button_text != blank and block.settings.button_link != blank %}
                <a href="{{ block.settings.button_link }}" class="ai-video-overlay-button-{{ ai_gen_id }}">
                  {{ block.settings.button_text }}
                </a>
              {% endif %}
            </div>
          {% endif %}
        </div>
      </div>

      <div class="ai-content-column-{{ ai_gen_id }}">
        <div class="ai-custom-content-{{ ai_gen_id }}">
          {% if block.settings.custom_content != blank %}
            {{ block.settings.custom_content }}
          {% else %}
            <p>Add your custom HTML, CSS, or Liquid code in the block settings.</p>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

