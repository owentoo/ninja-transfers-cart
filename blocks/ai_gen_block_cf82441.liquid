{% doc %}
  @prompt
    Need a section thats an image with an h1, text and ct inside , need max width in px , and content needs alignment options both for contnetn and content within section , get rid Section alignment, give section a max height. and add horizontal padding for section on mobile and desktop. all text needs mobile and desktop rules 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    display: block;
    padding: 0 {{ block.settings.padding_horizontal_desktop }}px;
  }

  .ai-hero-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    max-height: {{ block.settings.max_height }}px;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-hero-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    max-height: {{ block.settings.max_height }}px;
    object-fit: cover;
    display: block;
  }

  .ai-hero-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.max_height }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-hero-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-hero-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-hero-content-{{ ai_gen_id }} {
    position: absolute;
    z-index: 2;
    width: 90%;
    max-width: {{ block.settings.content_max_width }}px;
  }

  {% if block.settings.content_position == 'top-left' %}
    .ai-hero-content-{{ ai_gen_id }} {
      top: 40px;
      left: 40px;
      transform: none;
    }
  {% elsif block.settings.content_position == 'top-center' %}
    .ai-hero-content-{{ ai_gen_id }} {
      top: 40px;
      left: 50%;
      transform: translateX(-50%);
    }
  {% elsif block.settings.content_position == 'top-right' %}
    .ai-hero-content-{{ ai_gen_id }} {
      top: 40px;
      right: 40px;
      transform: none;
    }
  {% elsif block.settings.content_position == 'center-left' %}
    .ai-hero-content-{{ ai_gen_id }} {
      top: 50%;
      left: 40px;
      transform: translateY(-50%);
    }
  {% elsif block.settings.content_position == 'center-center' %}
    .ai-hero-content-{{ ai_gen_id }} {
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
    }
  {% elsif block.settings.content_position == 'center-right' %}
    .ai-hero-content-{{ ai_gen_id }} {
      top: 50%;
      right: 40px;
      transform: translateY(-50%);
    }
  {% elsif block.settings.content_position == 'bottom-left' %}
    .ai-hero-content-{{ ai_gen_id }} {
      bottom: 40px;
      left: 40px;
      transform: none;
    }
  {% elsif block.settings.content_position == 'bottom-center' %}
    .ai-hero-content-{{ ai_gen_id }} {
      bottom: 40px;
      left: 50%;
      transform: translateX(-50%);
    }
  {% elsif block.settings.content_position == 'bottom-right' %}
    .ai-hero-content-{{ ai_gen_id }} {
      bottom: 40px;
      right: 40px;
      transform: none;
    }
  {% endif %}

  .ai-hero-content-inner-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-hero-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 1;
  }

  .ai-hero-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size_desktop }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.spacing_between_elements }}px;
    line-height: 1.2;
  }

  .ai-hero-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size_desktop }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.spacing_between_elements }}px;
    line-height: 1.5;
  }

  .ai-hero-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size_desktop }}px;
    font-weight: 600;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-hero-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_bg_hover_color }};
    color: {{ block.settings.button_text_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-hero-container-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.padding_horizontal_mobile }}px;
    }

    .ai-hero-content-{{ ai_gen_id }} {
      width: 85%;
      max-width: none;
    }

    .ai-hero-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-hero-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
    }

    .ai-hero-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_text_size_mobile }}px;
    }
  }
{% endstyle %}

<div
  class="ai-hero-container-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-hero-wrapper-{{ ai_gen_id }}">
    {% if block.settings.image %}
      <img
        src="{{ block.settings.image | image_url: width: 2000 }}"
        alt="{{ block.settings.image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.image.width }}"
        height="{{ block.settings.image.height }}"
        class="ai-hero-image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-hero-image-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-hero-empty-state-{{ ai_gen_id }}">
          Next, add a hero image
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_overlay %}
      <div class="ai-hero-overlay-{{ ai_gen_id }}"></div>
    {% endif %}

    <div class="ai-hero-content-{{ ai_gen_id }}">
      <div class="ai-hero-content-inner-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h1 class="ai-hero-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h1>
        {% endif %}

        {% if block.settings.text != blank %}
          <div class="ai-hero-text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
        {% endif %}

        {% if block.settings.button_text != blank %}
          <a
            href="{{ block.settings.button_link }}"
            class="ai-hero-button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

