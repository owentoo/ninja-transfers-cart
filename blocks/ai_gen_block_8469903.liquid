{% doc %}
  @prompt
    Create a full-width section with a background image and text overlay that can be customized with heading, subheading, and button, make the text container have a width option


{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .hero-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: {{ block.settings.content_position }};
    min-height: {{ block.settings.section_height }}px;}

  .hero-banner__background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .hero-banner__background-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ block.settings.image_position }};
  }

  .hero-banner__background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.placeholder_color }};
  }

  .hero-banner__background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .hero-banner__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 2;
  }

  .hero-banner__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    text-align: {{ block.settings.text_alignment }};
    padding: 40px;
    width: {{ block.settings.content_width }}%;
    max-width: {{ block.settings.content_max_width }}px;
    {% if block.settings.content_position == 'center' %}margin: 0 auto;
    {% elsif block.settings.content_position == 'flex-end' %}
    margin-right: {{ block.settings.content_margin }}px;
    {% else %}
    margin-left: {{ block.settings.content_margin }}px;
    {% endif %}
  }

  .hero-banner__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    margin-top: 0;
    margin-bottom: {{ block.settings.space_between_elements }}px;
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;}

  .hero-banner__subheading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    margin-bottom: {{ block.settings.space_between_elements }}px;
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.5;}

  .hero-banner__button-{{ ai_gen_id }} {
    display: inline-block;
    padding:12px 24px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    transition: background-color 0.3s;}

  .hero-banner__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .hero-banner-{{ ai_gen_id }} {
      min-height: {{ block.settings.section_height_mobile }}px;
    }

    .hero-banner__content-{{ ai_gen_id }} {
      padding: 20px;
      width: 90%;
      margin: 0 auto;
    }

    .hero-banner__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .hero-banner__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="hero-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="hero-banner__background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        class="hero-banner__background-image-{{ ai_gen_id }}"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="hero-banner__background-placeholder-{{ ai_gen_id }}">
        {{'image' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="hero-banner__overlay-{{ ai_gen_id }}"></div>

  <div class="hero-banner__content-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="hero-banner__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.subheading != blank %}
      <div class="hero-banner__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
    {% endif %}

    {% if block.settings.button_label != blank and block.settings.button_link != blank %}
      <a href="{{ block.settings.button_link }}" class="hero-banner__button-{{ ai_gen_id }}">
        {{ block.settings.button_label }}
      </a>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Hero Banner",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "section_height",
      "min": 200,
      "max": 800,
      "step": 20,
      "unit": "px",
      "label": "Section height",
      "default": 500
    },
    {
      "type": "range",
      "id": "section_height_mobile",
      "min": 100,
      "max": 600,
      "step": 20,
      "unit": "px",
      "label": "Section height on mobile",
      "default": 400
    },
    {
      "type": "header",
      "content": "Content Container"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content position",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "content_width",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Content width",
      "default": 80
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 400,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Content maximum width",
      "default": 800
    },
    {
      "type": "range",
      "id": "content_margin",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Content margin",
      "default": 40,
      "info": "Margin from left or right edge when positioned to side"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "space_between_elements",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Space between elements",
      "default": 20
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        {
          "value": "center center",
          "label": "Center"
        },
        {
          "value": "center top",
          "label": "Top"
        },
        {
          "value": "center bottom",
          "label": "Bottom"
        }
      ],
      "default": "center center"
    },
    {
      "type": "color",
      "id": "placeholder_color",
      "label": "Placeholder color",
      "default": "#f4f4f4"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 30
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Headline Here"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 42
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Use this section to welcome customers to your store, highlight products, or share announcements."
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 18
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "button_text_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Button text size",
      "default": 16
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button color",
      "default": "#000f9f"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Button border radius",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}