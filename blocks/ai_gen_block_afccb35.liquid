{% doc %}
  @prompt
    i need a section with 3-5 icons with 2 lines of text below them, i need text size option for desktop and mobile, and the ability to have the icon above or to the left , section needs a max width with horizontal padding with for desktop and mobile. whole section needs bg color. option , each icon section needs a max width, need gap between for desktop and mobile, on mobile give me the option to put icons to the left of text, and left align text. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-icon-features-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.section_background }};
    padding: {{ block.settings.section_padding_desktop }}px {{ block.settings.section_horizontal_padding_desktop }}px;
  }

  .ai-icon-features-inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    width: 100%;
  }

  .ai-icon-features-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.gap_desktop }}px;
    width: 100%;
  }

  .ai-icon-feature-item-{{ ai_gen_id }} {
    display: flex;
    {% if block.settings.icon_position == 'top' %}
      flex-direction: column;
    {% else %}
      flex-direction: row;
    {% endif %}
    align-items: {{ block.settings.alignment }};
    {% if block.settings.icon_position == 'top' %}
      text-align: {{ block.settings.alignment }};
    {% else %}
      text-align: left;
    {% endif %}
    gap: {{ block.settings.item_gap }}px;
    max-width: {{ block.settings.item_max_width }}px;
    {% if block.settings.alignment == 'center' %}
      margin: 0 auto;
    {% endif %}
  }

  .ai-icon-feature-icon-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.icon_background }};
    border-radius: {{ block.settings.icon_border_radius }}px;
    flex-shrink: 0;
  }

  .ai-icon-feature-icon-wrapper-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.icon_size }}px * 0.6);
    height: calc({{ block.settings.icon_size }}px * 0.6);
    color: {{ block.settings.icon_color }};
  }

  .ai-icon-feature-icon-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-icon-feature-text-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 4px;
    {% if block.settings.icon_position == 'left' %}
      flex: 1;
    {% endif %}
  }

  .ai-icon-feature-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-size: {{ block.settings.title_size_desktop }}px;
    color: {{ block.settings.title_color }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-icon-feature-description-{{ ai_gen_id }} {
    font-family: {{ block.settings.description_font.family }}, {{ block.settings.description_font.fallback_families }};
    font-weight: {{ block.settings.description_font.weight }};
    font-size: {{ block.settings.description_size_desktop }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-icon-features-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_mobile }}px {{ block.settings.section_horizontal_padding_mobile }}px;
    }

    .ai-icon-features-container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.gap_mobile }}px;
    }

    .ai-icon-feature-item-{{ ai_gen_id }} {
      {% if block.settings.icon_position_mobile == 'top' %}
        flex-direction: column;
        text-align: {{ block.settings.alignment_mobile }};
      {% else %}
        flex-direction: row;
        text-align: {{ block.settings.alignment_mobile }};
      {% endif %}
      {% if block.settings.alignment_mobile == 'center' %}
        margin: 0 auto;
      {% else %}
        margin: 0;
      {% endif %}
    }

    .ai-icon-feature-text-{{ ai_gen_id }} {
      {% if block.settings.icon_position_mobile == 'left' %}
        flex: 1;
      {% endif %}
    }

    .ai-icon-feature-icon-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size_mobile }}px;
      height: {{ block.settings.icon_size_mobile }}px;
    }

    .ai-icon-feature-icon-wrapper-{{ ai_gen_id }} svg {
      width: calc({{ block.settings.icon_size_mobile }}px * 0.6);
      height: calc({{ block.settings.icon_size_mobile }}px * 0.6);
    }

    .ai-icon-feature-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_mobile }}px;
    }

    .ai-icon-feature-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-icon-features-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-icon-features-inner-{{ ai_gen_id }}">
    <div class="ai-icon-features-container-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign enabled_key = 'feature_' | append: i | append: '_enabled'
          assign icon_key = 'feature_' | append: i | append: '_icon'
          assign title_key = 'feature_' | append: i | append: '_title'
          assign description_key = 'feature_' | append: i | append: '_description'

          assign enabled = block.settings[enabled_key]
          assign icon = block.settings[icon_key]
          assign title = block.settings[title_key]
          assign description = block.settings[description_key]
        %}

        {% if enabled %}
          <div class="ai-icon-feature-item-{{ ai_gen_id }}">
            <div class="ai-icon-feature-icon-wrapper-{{ ai_gen_id }}">
              {% if icon != blank %}
                <img
                  src="{{ icon | image_url: width: 200 }}"
                  alt="{{ title | escape }}"
                  loading="lazy"
                  width="200"
                  height="200"
                >
              {% else %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"></circle>
                  <path d="M12 16v-4"></path>
                  <path d="M12 8h.01"></path>
                </svg>
              {% endif %}
            </div>

            <div class="ai-icon-feature-text-{{ ai_gen_id }}">
              {% if title != blank %}
                <h3 class="ai-icon-feature-title-{{ ai_gen_id }}">{{ title }}</h3>
              {% endif %}

              {% if description != blank %}
                <p class="ai-icon-feature-description-{{ ai_gen_id }}">{{ description }}</p>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

