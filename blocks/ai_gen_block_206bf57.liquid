{% doc %}
  @prompt
    i need a section with a max width and the option to 3 three or four blocks in a row. each block has an image with ratio options, a text wrapper with a heading and para text with side padding. all text needs desktop and mobil options for size and weight and padding from one another and from the image, section needs padding and margin options for all sides, and a bg color with a gradient option that takes up whole section, images need radius, text needs alignment options

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .feature-section-{{ ai_gen_id }} {
    padding-top: {{ block.settings.padding_top }}px;
    padding-right: {{ block.settings.padding_right }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_left }}px;
    margin-top: {{ block.settings.margin_top }}px;
    margin-right: {{ block.settings.margin_right }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
    margin-left: {{ block.settings.margin_left }}px;
    {% if block.settings.enable_gradient %}
      background: linear-gradient(to {{ block.settings.gradient_direction }}, {{ block.settings.background_color }}, {{ block.settings.gradient_end_color }});
    {% else %}
      background-color: {{ block.settings.background_color }};
    {% endif %}
  }

  .feature-block-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.side_padding }}px;
  }

  .feature-block__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .feature-block__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    margin-bottom: {{ block.settings.image_text_spacing }}px;
    border-radius: {{ block.settings.image_radius }}px;
  }

  .feature-block__image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.image_fit }};
    display: block;
    border-radius: {{ block.settings.image_radius }}px;
  }

  .feature-block__image-placeholder-{{ ai_gen_id }} {
    position: relative;
    padding-bottom: {{ block.settings.image_ratio }}%;
    background-color: #f4f4f4;
    overflow: hidden;
    border-radius: {{ block.settings.image_radius }}px;
  }

  .feature-block__image-placeholder-{{ ai_gen_id }} svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .feature-block__content-{{ ai_gen_id }} {
    padding: 0 {{ block.settings.text_side_padding }}px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    text-align: {{ block.settings.text_alignment }};
  }

  .feature-block__title-{{ ai_gen_id }} {
    margin-top: 0;
    margin-bottom: {{ block.settings.heading_text_spacing }}px;
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    line-height: 1.2;
  }

  .feature-block__text-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.text_size }}px;
    font-weight: {{ block.settings.text_weight }};
    line-height: 1.5;
  }

  .feature-block__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  @media screen and (max-width: 749px) {
    .feature-section-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top_mobile }}px;
      padding-right: {{ block.settings.padding_right_mobile }}px;
      padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
      padding-left: {{ block.settings.padding_left_mobile }}px;
      margin-top: {{ block.settings.margin_top_mobile }}px;
      margin-right: {{ block.settings.margin_right_mobile }}px;
      margin-bottom: {{ block.settings.margin_bottom_mobile }}px;
      margin-left: {{ block.settings.margin_left_mobile }}px;
    }

    .feature-block__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.grid_gap_mobile }}px;
    }

    .feature-block__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
      font-weight: {{ block.settings.heading_weight_mobile }};
      margin-bottom: {{ block.settings.heading_text_spacing_mobile }}px;
    }

    .feature-block__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
      font-weight: {{ block.settings.text_weight_mobile }};
    }

    .feature-block__content-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.text_side_padding_mobile }}px;
      text-align: {{ block.settings.text_alignment_mobile }};
    }

    .feature-block__image-wrapper-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.image_text_spacing_mobile }}px;
    }

    .feature-block-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.side_padding_mobile }}px;
    }
  }
{% endstyle %}

<div class="feature-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="feature-block-{{ ai_gen_id }}">
    <div class="feature-block__grid-{{ ai_gen_id }}">
      {% for i in (1..block.settings.columns) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign heading_key = 'heading_' | append: i
          assign text_key = 'text_' | append: i
          
          assign image = block.settings[image_key]
          assign heading = block.settings[heading_key]
          assign text = block.settings[text_key]
        %}

        <div class="feature-block__item-{{ ai_gen_id }}">
          <div class="feature-block__image-wrapper-{{ ai_gen_id }}">
            {% if image != blank %}
              <img 
                src="{{ image | image_url: width: 800 }}"
                alt="{{ image.alt | escape }}"
                width="{{ image.width }}"
                height="{{ image.height }}"
                loading="lazy"
              >
            {% else %}
              <div class="feature-block__image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          <div class="feature-block__content-{{ ai_gen_id }}">
            {% if heading != blank %}
              <h3 class="feature-block__title-{{ ai_gen_id }}">{{ heading }}</h3>
            {% endif %}
            {% if text != blank %}
              <div class="feature-block__text-{{ ai_gen_id }}">{{ text }}</div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

