{% doc %}
  @prompt
    Create a section that displays exactly eight content cards in a responsive grid layout. Arrange them four cards across on each row (two rows on desktop).
    
    Above the section, include an H2 heading and a subheading.
    
    Each content card should include:
    
    A background image or solid color.
    
    A heading text aligned left at the bottom of the image.
    
    A subheading text below the image, aligned left.
    
    An overlay that starts at the bottom of the image and can be customized (color, opacity, and gradient settings). Ensure overlay customization is accessible in the theme editor.
    
    Include:
    
    Multiple animation styles for hover effects (zoom in, fade in, subtle movement), selectable in the theme editor.
    
    Controls for image proportions (cover, contain, crop).
    
    Controls for padding and margin of the section and cards.
    
    Controls for section and card widths on desktop, tablet, and mobile.
    
    

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .content-grid-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding }}px;
    margin: {{ block.settings.section_margin }}px;
    max-width: {{ block.settings.section_width }}px;margin-left: auto;
    margin-right: auto;
  }

  .content-grid__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.header_alignment }};
    margin-bottom: {{ block.settings.header_bottom_margin }}px;
  }

  .content-grid__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    margin-bottom: {{ block.settings.heading_bottom_margin }}px;
    color: {{ block.settings.heading_color }};
  }

  .content-grid__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};}

  .content-grid__cards-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.card_gap }}px;
  }

  .content-grid__card-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.card_border_radius }}px;
    box-shadow: {{ block.settings.card_shadow_h_offset }}px {{ block.settings.card_shadow_v_offset }}px {{ block.settings.card_shadow_blur }}px {{ block.settings.card_shadow_color }};
    height: 100%;
  }

  .content-grid__card-image-container-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    padding-top: {{ block.settings.image_aspect_ratio }}%;}

  .content-grid__card-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.image_fit }};
    transition: transform 0.5s ease;
  }

  .content-grid__card-image-container-{{ ai_gen_id }} svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.placeholder_color }};}

  .content-grid__card-overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: {{ block.settings.overlay_height }}%;
    background: {% if block.settings.overlay_gradient %}linear-gradient(to top, {{ block.settings.overlay_color }} {{ block.settings.overlay_opacity }}%, transparent){% else %}{{ block.settings.overlay_color | color_modify: 'alpha', block.settings.overlay_opacity | divided_by: 100.0 }}{% endif %};
  }

  .content-grid__card-title-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 20px;
    color: {{ block.settings.card_title_color }};
    font-size: {{ block.settings.card_title_size }}px;
    margin: 0;
    z-index: 2;
    max-width: calc(100% - 40px);
  }

  .content-grid__card-subtitle-{{ ai_gen_id }} {
    padding: 20px;
    color: {{ block.settings.card_subtitle_color }};
    font-size: {{ block.settings.card_subtitle_size }}px;
    background-color: {{ block.settings.card_content_bg }};
  }

  {% if block.settings.hover_animation == 'zoom' %}
    .content-grid__card-{{ ai_gen_id }}:hover .content-grid__card-image-{{ ai_gen_id }} {
      transform: scale(1.1);
    }
  {% elsif block.settings.hover_animation == 'fade' %}
    .content-grid__card-overlay-{{ ai_gen_id }} {
      opacity: 0.7;
      transition: opacity 0.3s ease;
    }
    .content-grid__card-{{ ai_gen_id }}:hover .content-grid__card-overlay-{{ ai_gen_id }} {
      opacity: 1;
    }
  {% elsif block.settings.hover_animation == 'move' %}
    .content-grid__card-title-{{ ai_gen_id }} {
      transform: translateY(10px);
      transition: transform 0.3s ease;
    }
    .content-grid__card-{{ ai_gen_id }}:hover .content-grid__card-title-{{ ai_gen_id }} {
      transform: translateY(0);
    }
  {% endif %}

  @media screen and (max-width: 990px) {
    .content-grid__cards-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }.content-grid-{{ ai_gen_id }} {
      max-width: {{ block.settings.section_width_tablet }}px;
      padding: {{ block.settings.section_padding_tablet }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .content-grid__cards-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
    .content-grid-{{ ai_gen_id }} {
      max-width: {{ block.settings.section_width_mobile }}px;
      padding: {{ block.settings.section_padding_mobile }}px;
    }
  }
{% endstyle %}

<div class="content-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="content-grid__header-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="content-grid__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}
    {% if block.settings.subheading != blank %}
      <div class="content-grid__subtitle-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
    {% endif %}
  </div>

  <div class="content-grid__cards-{{ ai_gen_id }}">
    {% for i in (1..8) %}
      {% assign card_image_key = 'card_' | append: i | append: '_image' %}
      {% assign card_title_key = 'card_' | append: i | append: '_title' %}
      {% assign card_subtitle_key = 'card_' | append: i | append: '_subtitle' %}
      {% assign card_bg_key = 'card_' | append: i | append: '_bg_color' %}
      
      {% assign card_image = block.settings[card_image_key] %}
      {% assign card_title = block.settings[card_title_key] %}
      {% assign card_subtitle = block.settings[card_subtitle_key] %}
      {% assign card_bg_color = block.settings[card_bg_key] %}

      <div class="content-grid__card-{{ ai_gen_id }}">
        <div class="content-grid__card-image-container-{{ ai_gen_id }}" style="background-color: {{ card_bg_color }};">
          {% if card_image != blank %}
            <img 
              src="{{ card_image | image_url: width: 800 }}"
              alt="{{ card_image.alt | escape }}"
              width="{{ card_image.width }}"
              height="{{ card_image.height }}"
              loading="lazy"
              class="content-grid__card-image-{{ ai_gen_id }}"
            >
          {% else %}
            {{ 'image' | placeholder_svg_tag }}
          {% endif %}<div class="content-grid__card-overlay-{{ ai_gen_id }}"></div>
          {% if card_title != blank %}
            <h3 class="content-grid__card-title-{{ ai_gen_id }}">{{ card_title }}</h3>
          {% endif %}</div>
        {% if card_subtitle != blank %}
          <div class="content-grid__card-subtitle-{{ ai_gen_id }}">{{ card_subtitle }}</div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

