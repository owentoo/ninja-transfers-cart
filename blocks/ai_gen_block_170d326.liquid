{% doc %}
  @prompt
    Create a responsive section that displays six product cards in a grid layout, followed by a seventh block that acts as a “View All” call-to-action linking to the full collection. Each product card should include the following content elements:

Product image

Brand logo

Product title

“Starting at” price

Earliest delivery date

Each card should be styled uniformly with equal padding and spacing. The “View All” block should have the same styling as the product cards but should contain centered text saying “View All T-Shirts” and a button or icon. It should not include pricing or delivery information.

The section should be fully responsive, stacking the product cards vertically on smaller screens to maintain a clean and organized appearance.

Include editable settings in the theme editor for:

Uploading product images and brand logos

Editing product titles, prices, and delivery dates

Adding or changing the link for the “View All” button

Adjusting spacing and padding around the cards, Each product card should be clickable, add a section to allow me to add a link for each card. All 6 product cards should be on one row, give me ability to edit section width
, Put the view all button on the same row as the product cards and give it the same styling as product cards


{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .product-grid-container-{{ ai_gen_id }} {
    width: {{ block.settings.section_width }}%;
    margin: 0 auto;
  }

  .product-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    width: 100%;
    max-width: 100%;
  }

  @media screen and (max-width: 1200px) {
    .product-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(4, 1fr);
    }
    
    .view-all-card-{{ ai_gen_id }} {
      grid-column: span 1;
    }
  }

  @media screen and (max-width: 990px) {
    .product-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
    }
    
    .view-all-card-{{ ai_gen_id }} {
      grid-column: span 1;
    }
  }

  @media screen and (max-width: 749px) {
    .product-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
    
    .view-all-card-{{ ai_gen_id }} {
      grid-column: span 1;
    }
  }

  .product-card-{{ ai_gen_id }},
  .view-all-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    background-color: {{ block.settings.card_background_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    height: 100%;
    text-decoration: none;
  }

  .product-card-{{ ai_gen_id }}:hover,
  .view-all-card-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 15px rgba(0, 0, 0, 0.1);
  }

  .product-image-container-{{ ai_gen_id }},
  .view-all-image-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
  }

  .product-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-image-container-{{ ai_gen_id }} svg,
  .view-all-image-container-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.view_all_bg_color }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .view-all-icon-{{ ai_gen_id }} {
    font-size: 48px;
    color: {{ block.settings.view_all_icon_color }};
  }

  .brand-logo-container-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.logo_padding }}px;
    left: {{ block.settings.logo_padding }}px;
    width: {{ block.settings.logo_width }}px;
    height: {{ block.settings.logo_height }}px;
    background-color: white;
    border-radius: 4px;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .brand-logo-{{ ai_gen_id }} {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .product-info-{{ ai_gen_id }},
  .view-all-info-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .product-title-{{ ai_gen_id }},
  .view-all-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: 600;
    margin-bottom: 8px;
    color: {{ block.settings.title_color }};
    text-align: center;
  }

  .product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_font_size }}px;
    color: {{ block.settings.price_color }};
    margin-bottom: 8px;
  }

  .product-delivery-{{ ai_gen_id }} {
    font-size: {{ block.settings.delivery_font_size }}px;
    color: {{ block.settings.delivery_color }};
    margin-top: auto;
  }

  .view-all-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    font-weight: 600;
    transition: background-color 0.3s ease;
    margin: auto auto 0;
    text-align: center;
  }

  .view-all-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }
{% endstyle %}

<div class="product-grid-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="product-grid-{{ ai_gen_id }}">
    {% for i in (1..6) %}
      {% liquid
        assign product_image_key = 'product_image_' | append: i
        assign brand_logo_key = 'brand_logo_' | append: i
        assign product_title_key = 'product_title_' | append: i
        assign product_price_key = 'product_price_' | append: i
        assign delivery_date_key = 'delivery_date_' | append: i
        assign product_link_key = 'product_link_' | append: i
        
        assign product_image = block.settings[product_image_key]
        assign brand_logo = block.settings[brand_logo_key]
        assign product_title = block.settings[product_title_key]
        assign product_price = block.settings[product_price_key]
        assign delivery_date = block.settings[delivery_date_key]
        assign product_link = block.settings[product_link_key]
      %}
      <a href="{{ product_link }}" class="product-card-{{ ai_gen_id }}">
        <div class="product-image-container-{{ ai_gen_id }}">
          {% if product_image %}
            <img 
              src="{{ product_image | image_url: width: 600 }}" 
              alt="{{ product_title }}" 
              class="product-image-{{ ai_gen_id }}"
              width="600"
              height="600"
              loading="lazy"
            >
          {% else %}
            {{ 'product-apparel-1' | placeholder_svg_tag }}
          {% endif %}<div class="brand-logo-container-{{ ai_gen_id }}">
            {% if brand_logo %}
              <img 
                src="{{ brand_logo | image_url: width: 100 }}" 
                alt="Brand logo" 
                class="brand-logo-{{ ai_gen_id }}"
                width="100"
                height="50"
                loading="lazy"
              >
            {% endif %}
          </div>
        </div>
        
        <div class="product-info-{{ ai_gen_id }}">
          <h3 class="product-title-{{ ai_gen_id }}">{{ product_title }}</h3>
          <div class="product-price-{{ ai_gen_id }}">Starting at {{ product_price }}</div>
          <div class="product-delivery-{{ ai_gen_id }}">Earliest delivery: {{ delivery_date }}</div>
        </div>
      </a>
    {% endfor %}<a href="{{ block.settings.view_all_link }}" class="view-all-card-{{ ai_gen_id }}">
      <div class="view-all-image-container-{{ ai_gen_id }}">
        <div class="view-all-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="8" x2="12" y2="16"></line>
            <line x1="8" y1="12" x2="16" y2="12"></line>
          </svg>
        </div>
      </div>
      
      <div class="view-all-info-{{ ai_gen_id }}">
        <h3 class="view-all-title-{{ ai_gen_id }}">{{ block.settings.view_all_text }}</h3>
        <span class="view-all-button-{{ ai_gen_id }}">
          {{ block.settings.view_all_button_text }}
        </span>
      </div>
    </a>
  </div>
</div>

