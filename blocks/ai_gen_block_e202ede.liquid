{% doc %}
  @prompt
    Section: Mobile-Only Product Grid (2 Across)
    
    Goal: Show product cards in a 2-column grid on mobile only.
    
    Behavior:
    
    Show only on mobile (<750px).
    
    Two cards per row, adjustable spacing.
    
    Each card links to a product.
    
    No slider or scrolling.
    
    Section Settings:
    
    Background color, padding, grid gap, card border radius, text alignment.
    
    Control colors, fonts, and text sizes.
    
    Block (Product Card) Settings:
    
    Product picker or manual link.
    
    Image + alt text (show/hide).
    
    Brand logo or text (show/hide).
    
    “Starting at” label (editable, show/hide).
    
    Price (show/hide).
    
    Star rating + review count (editable, show/hide).
    
    “Earliest delivery” text (editable, show/hide).
    
    Product title (editable, show/hide).
    
    Short description (editable, show/hide).
    
    CTA button (text, link, style: solid/outline, show/hide).
    
    Optional tag/badge (text + color controls, show/hide).
    
    Defaults:
    
    4 cards preloaded with placeholder content.
    
    Two across on mobile, hidden on tablet and desktop., The entire product card should be clickable and go to link, No CTA, just make product card the link
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-mobile-grid-{{ ai_gen_id }} {
    display: none;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-mobile-grid-{{ ai_gen_id }} {
      display: block;
    }
  }

  .ai-mobile-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-mobile-grid__card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    position: relative;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-mobile-grid__card-link-{{ ai_gen_id }} {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .ai-mobile-grid__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-mobile-grid__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-mobile-grid__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-mobile-grid__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-mobile-grid__badge-{{ ai_gen_id }} {
    position: absolute;
    top: 8px;
    right: 8px;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .ai-mobile-grid__content-{{ ai_gen_id }} {
    padding: 12px;
  }

  .ai-mobile-grid__brand-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: {{ block.settings.text_alignment }};
    margin-bottom: 8px;
    gap: 8px;
  }

  .ai-mobile-grid__brand-logo-{{ ai_gen_id }} {
    max-width: 60px;
    height: auto;
  }

  .ai-mobile-grid__brand-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.brand_font_size }}px;
    color: {{ block.settings.brand_color }};
    font-weight: 600;
  }

  .ai-mobile-grid__starting-{{ ai_gen_id }} {
    font-size: {{ block.settings.starting_font_size }}px;
    color: {{ block.settings.starting_color }};
    margin-bottom: 4px;
  }

  .ai-mobile-grid__price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_font_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 700;
    margin-bottom: 8px;
  }

  .ai-mobile-grid__rating-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: {{ block.settings.text_alignment }};
    gap: 4px;
    margin-bottom: 8px;
    font-size: {{ block.settings.rating_font_size }}px;
  }

  .ai-mobile-grid__stars-{{ ai_gen_id }} {
    color: {{ block.settings.star_color }};
  }

  .ai-mobile-grid__review-count-{{ ai_gen_id }} {
    color: {{ block.settings.review_count_color }};
  }

  .ai-mobile-grid__delivery-{{ ai_gen_id }} {
    font-size: {{ block.settings.delivery_font_size }}px;
    color: {{ block.settings.delivery_color }};
    margin-bottom: 8px;
  }

  .ai-mobile-grid__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    font-weight: 600;
    margin-bottom: 8px;
    line-height: 1.3;
  }

  .ai-mobile-grid__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.4;
  }
{% endstyle %}

<div class="ai-mobile-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-mobile-grid__container-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% liquid
        assign show_image_key = 'card_' | append: i | append: '_show_image'
        assign product_key = 'card_' | append: i | append: '_product'
        assign product_link_key = 'card_' | append: i | append: '_product_link'
        assign product_image_key = 'card_' | append: i | append: '_product_image'
        assign image_alt_key = 'card_' | append: i | append: '_image_alt'
        assign show_badge_key = 'card_' | append: i | append: '_show_badge'
        assign badge_text_key = 'card_' | append: i | append: '_badge_text'
        assign show_brand_key = 'card_' | append: i | append: '_show_brand'
        assign brand_logo_key = 'card_' | append: i | append: '_brand_logo'
        assign brand_text_key = 'card_' | append: i | append: '_brand_text'
        assign show_starting_key = 'card_' | append: i | append: '_show_starting'
        assign starting_text_key = 'card_' | append: i | append: '_starting_text'
        assign show_price_key = 'card_' | append: i | append: '_show_price'
        assign price_text_key = 'card_' | append: i | append: '_price_text'
        assign show_rating_key = 'card_' | append: i | append: '_show_rating'
        assign star_rating_key = 'card_' | append: i | append: '_star_rating'
        assign review_count_key = 'card_' | append: i | append: '_review_count'
        assign show_delivery_key = 'card_' | append: i | append: '_show_delivery'
        assign delivery_text_key = 'card_' | append: i | append: '_delivery_text'
        assign show_title_key = 'card_' | append: i | append: '_show_title'
        assign product_title_key = 'card_' | append: i | append: '_product_title'
        assign show_description_key = 'card_' | append: i | append: '_show_description'
        assign product_description_key = 'card_' | append: i | append: '_product_description'

        assign show_image = block.settings[show_image_key]
        assign product = block.settings[product_key]
        assign product_link = block.settings[product_link_key]
        assign product_image = block.settings[product_image_key]
        assign image_alt = block.settings[image_alt_key]
        assign show_badge = block.settings[show_badge_key]
        assign badge_text = block.settings[badge_text_key]
        assign show_brand = block.settings[show_brand_key]
        assign brand_logo = block.settings[brand_logo_key]
        assign brand_text = block.settings[brand_text_key]
        assign show_starting = block.settings[show_starting_key]
        assign starting_text = block.settings[starting_text_key]
        assign show_price = block.settings[show_price_key]
        assign price_text = block.settings[price_text_key]
        assign show_rating = block.settings[show_rating_key]
        assign star_rating = block.settings[star_rating_key]
        assign review_count = block.settings[review_count_key]
        assign show_delivery = block.settings[show_delivery_key]
        assign delivery_text = block.settings[delivery_text_key]
        assign show_title = block.settings[show_title_key]
        assign product_title = block.settings[product_title_key]
        assign show_description = block.settings[show_description_key]
        assign product_description = block.settings[product_description_key]

        if product_link != blank
          assign card_url = product_link
        elsif product != blank
          assign card_url = product.url
        else
          assign card_url = ''
        endif
      %}

      {% if card_url != blank %}
        <a href="{{ card_url }}" class="ai-mobile-grid__card-{{ ai_gen_id }} ai-mobile-grid__card-link-{{ ai_gen_id }}">
      {% else %}
        <div class="ai-mobile-grid__card-{{ ai_gen_id }}">
      {% endif %}

        <div class="ai-mobile-grid__image-wrapper-{{ ai_gen_id }}">
          {% if show_image %}
            {% if product_image != blank %}
              <img
                src="{{ product_image | image_url: width: 600 }}"
                alt="{{ image_alt | escape }}"
                class="ai-mobile-grid__image-{{ ai_gen_id }}"
                loading="lazy"
                width="600"
                height="600"
              >
            {% elsif product != blank and product.featured_image %}
              <img
                src="{{ product.featured_image | image_url: width: 600 }}"
                alt="{{ product.featured_image.alt | escape }}"
                class="ai-mobile-grid__image-{{ ai_gen_id }}"
                loading="lazy"
                width="600"
                height="600"
              >
            {% else %}
              <div class="ai-mobile-grid__image-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          {% endif %}

          {% if show_badge and badge_text != blank %}
            <div class="ai-mobile-grid__badge-{{ ai_gen_id }}">
              {{ badge_text }}
            </div>
          {% endif %}
        </div>

        <div class="ai-mobile-grid__content-{{ ai_gen_id }}">
          {% if show_brand %}
            <div class="ai-mobile-grid__brand-{{ ai_gen_id }}">
              {% if brand_logo != blank %}
                <img
                  src="{{ brand_logo | image_url: width: 120 }}"
                  alt="{{ brand_text | escape }}"
                  class="ai-mobile-grid__brand-logo-{{ ai_gen_id }}"
                  loading="lazy"
                >
              {% elsif brand_text != blank %}
                <div class="ai-mobile-grid__brand-text-{{ ai_gen_id }}">
                  {{ brand_text }}
                </div>
              {% endif %}
            </div>
          {% endif %}

          {% if show_starting and starting_text != blank %}
            <div class="ai-mobile-grid__starting-{{ ai_gen_id }}">
              {{ starting_text }}
            </div>
          {% endif %}

          {% if show_price %}
            <div class="ai-mobile-grid__price-{{ ai_gen_id }}">
              {% if price_text != blank %}
                {{ price_text }}
              {% elsif product != blank %}
                {{ product.price | money }}
              {% else %}
                $0.00
              {% endif %}
            </div>
          {% endif %}

          {% if show_rating %}
            <div class="ai-mobile-grid__rating-{{ ai_gen_id }}">
              <span class="ai-mobile-grid__stars-{{ ai_gen_id }}">
                {% if star_rating != blank %}
                  {{ star_rating }}
                {% else %}
                  ★★★★★
                {% endif %}
              </span>
              {% if review_count != blank %}
                <span class="ai-mobile-grid__review-count-{{ ai_gen_id }}">
                  ({{ review_count }})
                </span>
              {% endif %}
            </div>
          {% endif %}

          {% if show_delivery and delivery_text != blank %}
            <div class="ai-mobile-grid__delivery-{{ ai_gen_id }}">
              {{ delivery_text }}
            </div>
          {% endif %}

          {% if show_title %}
            <div class="ai-mobile-grid__title-{{ ai_gen_id }}">
              {% if product_title != blank %}
                {{ product_title }}
              {% elsif product != blank %}
                {{ product.title }}
              {% else %}
                Product Title
              {% endif %}
            </div>
          {% endif %}

          {% if show_description and product_description != blank %}
            <div class="ai-mobile-grid__description-{{ ai_gen_id }}">
              {{ product_description }}
            </div>
          {% endif %}
        </div>

      {% if card_url != blank %}
        </a>
      {% else %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

