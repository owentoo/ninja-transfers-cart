{% doc %}
  @prompt
    i need up to 8-10 images 3-5 a row with text under each, section needs max width with horizontal padding within from desktop and mobile , need grid gap for desktop and mobile, text size for desktop and mobile. text weight and alignment, need top and bottom padding for desktop and mobile , need space between rows for desktop and mobile. and horizontal padding for desktop and mobile. padding between should go in multiples of 2 and 5 , horizontal padding needs to apply within the section max width. add bg color option to entire section , text needs horizontal padding on desktop and mobile , text padding needs to work in multiples of 2
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top_desktop }}px 0 {{ block.settings.padding_bottom_desktop }}px 0;
  }

  .ai-image-grid-wrapper-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.horizontal_padding_desktop }}px;
  }

  .ai-image-grid-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    column-gap: {{ block.settings.column_gap_desktop }}px;
    row-gap: {{ block.settings.row_gap_desktop }}px;
    width: 100%;
  }

  .ai-image-grid-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.text_spacing }}px;
  }

  .ai-image-grid-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    background-color: {{ block.settings.image_background }};
  }

  .ai-image-grid-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: {% if block.settings.image_fit %}contain{% else %}cover{% endif %};
    display: block;
  }

  .ai-image-grid-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-image-grid-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-image-grid-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size_desktop }}px;
    font-weight: {{ block.settings.text_weight }};
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_alignment }};
    line-height: 1.4;
    padding: 0 {{ block.settings.text_padding_desktop }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-image-grid-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px 0 {{ block.settings.padding_bottom_mobile }}px 0;
    }

    .ai-image-grid-wrapper-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.horizontal_padding_mobile }}px;
    }

    .ai-image-grid-container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      column-gap: {{ block.settings.column_gap_mobile }}px;
      row-gap: {{ block.settings.row_gap_mobile }}px;
    }

    .ai-image-grid-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
      padding: 0 {{ block.settings.text_padding_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-image-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-grid-wrapper-{{ ai_gen_id }}">
    <div class="ai-image-grid-container-{{ ai_gen_id }}">
      {% for i in (1..10) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign text_key = 'text_' | append: i
          assign image = block.settings[image_key]
          assign text = block.settings[text_key]
        %}

        {% if image != blank or text != blank %}
          <div class="ai-image-grid-item-{{ ai_gen_id }}">
            <div class="ai-image-grid-image-wrapper-{{ ai_gen_id }}">
              {% if image != blank %}
                <img
                  src="{{ image | image_url: width: 800 }}"
                  alt="{{ image.alt | escape }}"
                  loading="lazy"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                  class="ai-image-grid-image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-image-grid-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            {% if text != blank %}
              <div class="ai-image-grid-text-{{ ai_gen_id }}">
                {{ text }}
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

