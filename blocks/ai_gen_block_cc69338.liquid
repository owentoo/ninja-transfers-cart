      "default": "#e0e0e0"
    },
    {
      "type": "checkbox",
      "id": "image_shadow",
      "label": "Show image shadow",
      "default": true
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
