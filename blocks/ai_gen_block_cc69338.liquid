        {
          "value": "1",
          "label": "Square (1:1)"
        },
        {
          "value": "1.33333",
          "label": "Landscape (4:3)"
        },
        {
          "value": "1.777778",
          "label": "Wide (16:9)"
        },
        {
          "value": "0.75",
          "label": "Portrait (3:4)"
        },
        {
          "value": "0.666667",
