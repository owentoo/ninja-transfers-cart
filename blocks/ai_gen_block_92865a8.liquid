{% doc %}
  @prompt
    make me s section with mobile a desktop rules for a fiver column grid with ten blocks each block has an image with ratio options and a text link below it, with text size and roll over options, add options for a max width with padding and margin, and a bg color that can be a solid or gradient that isn;t effected by the max with, and give me an option to link blocks to collections, on hover the text color needs to chnage

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .five-column-grid-wrapper-{{ ai_gen_id }} {
    width: 100%;
    background: {% if block.settings.use_gradient %}
      linear-gradient(to {{ block.settings.gradient_direction }}, {{ block.settings.background_color }} 0%, {{ block.settings.gradient_end_color }} 100%)
    {% else %}
      {{ block.settings.background_color }}
    {% endif %};
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px;
  }

  .five-column-grid-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.max_width }}px;
    margin: {{ block.settings.section_margin_top }}px auto {{ block.settings.section_margin_bottom }}px;
    padding: 0 {{ block.settings.content_padding }}px;
  }

  .grid-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  @media screen and (max-width: 990px) {
    .grid-container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .grid-container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
  }

  .grid-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: transform {{ block.settings.hover_transition_speed }}s ease;
  }

  {% if block.settings.enable_hover_effect %}
    .grid-item-{{ ai_gen_id }}:hover {
      transform: {{ block.settings.hover_effect }};
    }
  {% endif %}

  .image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
    overflow: hidden;
    {% if block.settings.image_border_radius > 0 %}
      border-radius: {{ block.settings.image_border_radius }}px;
    {% endif %}
  }

  .image-wrapper-{{ ai_gen_id }}::before {
    content: "";
    display: block;
    padding-top: {{ block.settings.image_ratio }};
  }

  .image-wrapper-{{ ai_gen_id }} img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.image_fit }};
  }

  .image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.placeholder_color }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .image-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
  }

  .grid-item-link-{{ ai_gen_id }} {
    margin-top: {{ block.settings.text_margin }}px;
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    text-decoration: none;
    transition: color {{ block.settings.hover_transition_speed }}s ease;
  }

  .grid-item-{{ ai_gen_id }}:hover .grid-item-link-{{ ai_gen_id }} {
    color: {{ block.settings.text_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .grid-item-link-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="five-column-grid-wrapper-{{ ai_gen_id }}">
  <div class="five-column-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
    <div class="grid-container-{{ ai_gen_id }}">
      {% for i in (1..10) %}
        {% assign image_field = 'image_' | append: i %}
        {% assign link_text_field = 'link_text_' | append: i %}
        {% assign link_url_field = 'link_url_' | append: i %}
        {% assign collection_field = 'collection_' | append: i %}
        <div class="grid-item-{{ ai_gen_id }}">
          <div class="image-wrapper-{{ ai_gen_id }}">
            {% if block.settings[image_field] != blank %}
              <img 
                src="{{ block.settings[image_field] | image_url: width: 500 }}"
                alt="{{ block.settings[link_text_field] | escape }}"
                loading="lazy"
                width="{{ block.settings[image_field].width }}"
                height="{{ block.settings[image_field].height }}"
              >
            {% else %}
              <div class="image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          
          {% if block.settings[link_text_field] != blank %}
            {% assign link_url = block.settings[link_url_field] %}
            {% if block.settings[collection_field] != blank %}
              {% assign link_url = block.settings[collection_field].url %}
            {% endif %}
            
            <a 
              href="{{ link_url | default: '#' }}" 
              class="grid-item-link-{{ ai_gen_id }}">
              {{ block.settings[link_text_field] }}
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

