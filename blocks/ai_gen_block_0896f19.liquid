{% doc %}
  @prompt
    Create a fully customizable Shopify section that displays a grid of product cards.
    Layout: 6 columns on desktop, 2–3 on tablet (editable), 1 on mobile, with full control over spacing, padding, and max-width.
    
    Card Structure (top to bottom):
    
    Image (upload per card; adjustable ratio)
    
    Title (editable text)
    
    Optional 1-line benefit (toggle on/off per card)
    
    Price + Delivery row
    
    Field 1: starting price
    
    Field 2: delivery time
    
    Option to show on one line or stacked
    
    CTA button (editable text, link, style, hide/show)
    
    Entire card must also be clickable separately from the CTA.
    
    Section Controls:
    
    Edit heading + subheading
    
    Adjust column count per breakpoint
    
    Adjust card padding, background, border, radius, shadow, hover state
    
    Control text alignment
    
    Control row/column gaps + section padding
    
    Control CTA styles
    
    Set section or card max-width
    
    Card Controls:
    
    Upload image
    
    Edit title
    
    Edit benefit text
    
    Edit starting price
    
    Edit delivery time
    
    Edit CTA text + link
    
    Toggle visibility for benefit, price, delivery, CTA
    
    Behavior Requirements:
    
    Fully responsive
    
    Image always on top
    
    Cards remain simple, clean, and easy to scan
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-grid-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.section_background }};
  }

  .ai-product-grid-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.section_max_width }}px;
    margin: 0 auto;
  }

  .ai-product-grid-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-product-grid-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.subheading_spacing }}px;
    font-weight: 600;
  }

  .ai-product-grid-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
  }

  .ai-product-grid-wrapper-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.row_gap }}px {{ block.settings.column_gap }}px;
  }

  .ai-product-card-{{ ai_gen_id }} {
    position: relative;
    background-color: {{ block.settings.card_background }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    transition: all 0.3s ease;
    cursor: pointer;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    {% if block.settings.card_max_width > 0 %}
      max-width: {{ block.settings.card_max_width }}px;
      margin: 0 auto;
      width: 100%;
    {% endif %}
    {% if block.settings.card_shadow %}
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    {% endif %}
  }

  .ai-product-card-{{ ai_gen_id }}:hover {
    {% if block.settings.card_hover_shadow %}
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
    {% endif %}
    {% if block.settings.card_hover_transform %}
      transform: translateY(-4px);
    {% endif %}
    border-color: {{ block.settings.card_hover_border_color }};
  }

  .ai-product-card-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio | times: 100 }}%;
    margin-bottom: {{ block.settings.image_spacing }}px;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    background-color: {{ block.settings.image_background }};
  }

  .ai-product-card-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-card-image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-product-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-product-card-content-{{ ai_gen_id }} {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-product-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    font-weight: 600;
    line-height: 1.3;
  }

  .ai-product-card-benefit-{{ ai_gen_id }} {
    font-size: {{ block.settings.benefit_size }}px;
    color: {{ block.settings.benefit_color }};
    margin: 0 0 {{ block.settings.benefit_spacing }}px;
    line-height: 1.4;
  }

  .ai-product-card-pricing-{{ ai_gen_id }} {
    {% if block.settings.pricing_layout == 'stacked' %}
      display: flex;
      flex-direction: column;
      gap: {{ block.settings.pricing_gap }}px;
    {% else %}
      display: flex;
      align-items: center;
      gap: {{ block.settings.pricing_gap }}px;
      flex-wrap: wrap;
    {% endif %}
    margin-bottom: {{ block.settings.pricing_spacing }}px;
  }

  .ai-product-card-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 600;
  }

  .ai-product-card-delivery-{{ ai_gen_id }} {
    font-size: {{ block.settings.delivery_size }}px;
    color: {{ block.settings.delivery_color }};
  }

  .ai-product-card-cta-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.cta_padding_vertical }}px {{ block.settings.cta_padding_horizontal }}px;
    background-color: {{ block.settings.cta_background }};
    color: {{ block.settings.cta_text_color }};
    border: {{ block.settings.cta_border_width }}px solid {{ block.settings.cta_border_color }};
    border-radius: {{ block.settings.cta_border_radius }}px;
    font-size: {{ block.settings.cta_font_size }}px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
    margin-top: auto;
    {% if block.settings.text_alignment == 'center' %}
      align-self: center;
    {% elsif block.settings.text_alignment == 'right' %}
      align-self: flex-end;
    {% else %}
      align-self: flex-start;
    {% endif %}
  }

  .ai-product-card-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_hover_background }};
    color: {{ block.settings.cta_hover_text_color }};
    border-color: {{ block.settings.cta_hover_border_color }};
  }

  @media screen and (max-width: 989px) and (min-width: 750px) {
    .ai-product-grid-wrapper-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-product-grid-wrapper-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-product-grid-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.6 }}px {{ block.settings.section_padding_horizontal | times: 0.6 }}px {{ block.settings.section_padding_bottom | times: 0.6 }}px;
    }

    .ai-product-grid-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-product-grid-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<div class="ai-product-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-grid-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-product-grid-header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-product-grid-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-product-grid-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-product-grid-wrapper-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign card_image_key = 'card_' | append: i | append: '_image'
          assign card_title_key = 'card_' | append: i | append: '_title'
          assign card_benefit_key = 'card_' | append: i | append: '_benefit'
          assign card_benefit_show_key = 'card_' | append: i | append: '_show_benefit'
          assign card_price_key = 'card_' | append: i | append: '_price'
          assign card_price_show_key = 'card_' | append: i | append: '_show_price'
          assign card_delivery_key = 'card_' | append: i | append: '_delivery'
          assign card_delivery_show_key = 'card_' | append: i | append: '_show_delivery'
          assign card_cta_text_key = 'card_' | append: i | append: '_cta_text'
          assign card_cta_link_key = 'card_' | append: i | append: '_cta_link'
          assign card_cta_show_key = 'card_' | append: i | append: '_show_cta'
          assign card_link_key = 'card_' | append: i | append: '_link'

          assign card_image = block.settings[card_image_key]
          assign card_title = block.settings[card_title_key]
          assign card_benefit = block.settings[card_benefit_key]
          assign card_benefit_show = block.settings[card_benefit_show_key]
          assign card_price = block.settings[card_price_key]
          assign card_price_show = block.settings[card_price_show_key]
          assign card_delivery = block.settings[card_delivery_key]
          assign card_delivery_show = block.settings[card_delivery_show_key]
          assign card_cta_text = block.settings[card_cta_text_key]
          assign card_cta_link = block.settings[card_cta_link_key]
          assign card_cta_show = block.settings[card_cta_show_key]
          assign card_link = block.settings[card_link_key]
        %}

        <a
          href="{{ card_link }}"
          class="ai-product-card-{{ ai_gen_id }}"
          {% if card_link == blank %}onclick="return false;" style="cursor: default;"{% endif %}
        >
          <div class="ai-product-card-image-wrapper-{{ ai_gen_id }}">
            {% if card_image %}
              <img
                src="{{ card_image | image_url: width: 800 }}"
                alt="{{ card_image.alt | escape }}"
                loading="lazy"
                width="800"
                height="{{ 800 | times: block.settings.image_aspect_ratio }}"
                class="ai-product-card-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-product-card-image-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <div class="ai-product-card-content-{{ ai_gen_id }}">
            {% if card_title != blank %}
              <h3 class="ai-product-card-title-{{ ai_gen_id }}">{{ card_title }}</h3>
            {% endif %}

            {% if card_benefit_show and card_benefit != blank %}
              <p class="ai-product-card-benefit-{{ ai_gen_id }}">{{ card_benefit }}</p>
            {% endif %}

            {% if card_price_show or card_delivery_show %}
              <div class="ai-product-card-pricing-{{ ai_gen_id }}">
                {% if card_price_show and card_price != blank %}
                  <div class="ai-product-card-price-{{ ai_gen_id }}">{{ card_price }}</div>
                {% endif %}
                {% if card_delivery_show and card_delivery != blank %}
                  <div class="ai-product-card-delivery-{{ ai_gen_id }}">{{ card_delivery }}</div>
                {% endif %}
              </div>
            {% endif %}

            {% if card_cta_show and card_cta_text != blank %}
              <span
                class="ai-product-card-cta-{{ ai_gen_id }}"
                {% if card_cta_link != blank %}
                  onclick="event.stopPropagation(); window.location.href='{{ card_cta_link }}';"
                {% else %}
                  onclick="event.stopPropagation();"
                {% endif %}
              >
                {{ card_cta_text }}
              </span>
            {% endif %}
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product grid",
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 16,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 36
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover our best-selling items"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Subheading size",
      "default": 16
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "subheading_spacing",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Subheading spacing",
      "default": 8
    },
    {
      "type": "range",
      "id": "header_spacing",
      "min": 20,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Header bottom spacing",
      "default": 40
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Columns on desktop",
      "default": 6
    },
    {
      "type": "select",
      "id": "columns_tablet",
      "label": "Columns on tablet",
      "options": [
        {
          "value": "2",
          "label": "2"
        },
        {
          "value": "3",
          "label": "3"
        }
      ],
      "default": "3"
    },
    {
      "type": "range",
      "id": "column_gap",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Column gap",
      "default": 24
    },
    {
      "type": "range",
      "id": "row_gap",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Row gap",
      "default": 24
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Section style"
    },
    {
      "type": "range",
      "id": "section_max_width",
      "min": 1000,
      "max": 2000,
      "step": 50,
      "unit": "px",
      "label": "Max width",
      "default": 1400
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_horizontal",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding horizontal",
      "default": 20
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "range",
      "id": "card_max_width",
      "min": 0,
      "max": 600,
      "step": 20,
      "unit": "px",
      "label": "Max width",
      "default": 0,
      "info": "Set to 0 for no limit"
    },
    {
      "type": "range",
      "id": "card_padding",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Padding",
      "default": 16
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "card_border_width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "label": "Border width",
      "default": 1
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Border color",
      "default": "#e5e5e5"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "card_shadow",
      "label": "Show shadow",
      "default": false
    },
    {
      "type": "header",
      "content": "Card hover state"
    },
    {
      "type": "checkbox",
      "id": "card_hover_shadow",
      "label": "Show hover shadow",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "card_hover_transform",
      "label": "Lift on hover",
      "default": true
    },
    {
      "type": "color",
      "id": "card_hover_border_color",
      "label": "Hover border color",
      "default": "#cccccc"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "range",
      "id": "image_aspect_ratio",
      "min": 0.5,
      "max": 1.5,
      "step": 0.1,
      "label": "Aspect ratio",
      "default": 1,
      "info": "1 = square, 0.75 = portrait, 1.33 = landscape"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 4
    },
    {
      "type": "color",
      "id": "image_background",
      "label": "Background",
      "default": "#f4f4f4"
    },
    {
      "type": "range",
      "id": "image_spacing",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Bottom spacing",
      "default": 16
    },
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Size",
      "default": 18
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "title_spacing",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Bottom spacing",
      "default": 8
    },
    {
      "type": "header",
      "content": "Benefit"
    },
    {
      "type": "range",
      "id": "benefit_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Size",
      "default": 14
    },
    {
      "type": "color",
      "id": "benefit_color",
      "label": "Color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "benefit_spacing",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Bottom spacing",
      "default": 12
    },
    {
      "type": "header",
      "content": "Pricing"
    },
    {
      "type": "select",
      "id": "pricing_layout",
      "label": "Layout",
      "options": [
        {
          "value": "inline",
          "label": "One line"
        },
        {
          "value": "stacked",
          "label": "Stacked"
        }
      ],
      "default": "inline"
    },
    {
      "type": "range",
      "id": "pricing_gap",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Gap",
      "default": 8
    },
    {
      "type": "range",
      "id": "pricing_spacing",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Bottom spacing",
      "default": 16
    },
    {
      "type": "range",
      "id": "price_size",
      "min": 14,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Price size",
      "default": 18
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "delivery_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Delivery size",
      "default": 14
    },
    {
      "type": "color",
      "id": "delivery_color",
      "label": "Delivery color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "CTA button"
    },
    {
      "type": "range",
      "id": "cta_padding_vertical",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Padding vertical",
      "default": 12
    },
    {
      "type": "range",
      "id": "cta_padding_horizontal",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Padding horizontal",
      "default": 24
    },
    {
      "type": "range",
      "id": "cta_font_size",
      "min": 12,
      "max": 20,
      "step": 1,
