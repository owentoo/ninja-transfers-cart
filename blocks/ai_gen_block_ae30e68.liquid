{% doc %}
  @prompt
    Create a full-width section with:
    
    🧱 Content Elements:
    An H2 heading (editable)
    A paragraph text block (editable)
    A 4-column grid layout:
    The first grid cell should be a static image that spans 2 columns and 2 rows
    The remaining 8 grid cells each contain:
    An image (1:1 ratio)
    A text label below the image
    Each box should be individually editable
    A button (with editable label and link)
    🎨 Layout:
    Desktop: 4 columns
    Mobile: stack in a single column with the large static image on top
    Use CSS grid for layout with named areas
    Text content should be centered on mobile and left-aligned on desktop
    Add top and bottom padding options
    Add padding/margin controls for all sides
    Add max-width setting for the container
    ⚙️ Customization Settings:
    Editable H2 text, font size, font weight (desktop & mobile)
    Editable paragraph text, font size, font weight (desktop & mobile)
    Upload field for static image (with desktop and mobile size controls)
    Upload fields for each of the 8 grid images (with desktop and mobile size controls)
    Editable text labels for each grid box
    Button label, link, and alignment (centered by default)
    Optional background color and spacing control (padding/margin per element), every grid item needs to be a link, i need alignment options for the heading and description, button and text links need roll over color option

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .grid-section-{{ ai_gen_id }} {
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_left }}px;
    padding-right: {{ block.settings.padding_right }}px;
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
    margin-left: {{ block.settings.margin_left }}px;
    margin-right: {{ block.settings.margin_right }}px;
    background-color: {{ block.settings.background_color }};
  }

  .grid-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
  }

  .grid-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment_mobile }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  @media screen and (min-width: 750px) {
    .grid-header-{{ ai_gen_id }} {
      text-align: {{ block.settings.text_alignment }};
    }
  }

  .grid-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size_mobile }}px;
    font-weight: {{ block.settings.heading_weight }};
    margin-bottom: {{ block.settings.title_spacing }}px;
  }

  .grid-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.paragraph_size_mobile }}px;
    font-weight: {{ block.settings.paragraph_weight }};
    margin-bottom: {{ block.settings.description_spacing }}px;
  }

  @media screen and (min-width: 750px) {
    .grid-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size }}px;
    }

    .grid-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.paragraph_size }}px;
    }
  }

  .grid-layout-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ block.settings.grid_gap }}px;margin-bottom: {{ block.settings.grid_spacing }}px;
  }

  .grid-main-image-{{ ai_gen_id }} {
    width: 100%;
    margin-bottom: {{ block.settings.grid_gap }}px;
  }

  .grid-main-image-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .grid-items-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.grid_gap }}px;
  }

  .grid-item-link-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: {{ block.settings.link_text_color }};
    transition: transform 0.3s ease, color 0.3s ease;
  }

  .grid-item-link-{{ ai_gen_id }}:hover {
    transform: translateY(-2px);
    color: {{ block.settings.link_hover_color }};
  }

  .grid-item-image-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1/1;
    margin-bottom: {{ block.settings.image_text_spacing }}px;
  }

  .grid-item-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .grid-item-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .grid-item-placeholder-{{ ai_gen_id }} svg {
    width:100%;
    height: 100%;
    object-fit: cover;
  }

  .grid-item-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size_mobile }}px;
    font-weight: {{ block.settings.label_weight }};
    text-align: center;
  }

  .grid-button-wrapper-{{ ai_gen_id }} {
    margin-top: {{ block.settings.button_spacing }}px;text-align: {{ block.settings.button_alignment }};
  }

  .grid-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 2 }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-weight: {{ block.settings.button_weight }};
    font-size: {{ block.settings.button_size_mobile }}px;
    transition: background-color 0.3s, color 0.3s;
  }

  .grid-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    color: {{ block.settings.button_text_hover_color }};
  }

  @media screen and (min-width: 750px) {
    .grid-layout-{{ ai_gen_id }} {
      grid-template-columns: repeat(4, 1fr);grid-template-rows: repeat(3, auto);
      grid-template-areas:
        "main main item1 item2"
        "main main item3 item4"
        "item5 item6 item7 item8";
    }

    .grid-main-image-{{ ai_gen_id }} {
      grid-area: main;
      margin-bottom: 0;
    }

    .grid-items-{{ ai_gen_id }} {
      display: contents;
    }

    .grid-item-link-{{ ai_gen_id }}:nth-child(1) {
      grid-area: item1;
    }

    .grid-item-link-{{ ai_gen_id }}:nth-child(2) {
      grid-area: item2;
    }

    .grid-item-link-{{ ai_gen_id }}:nth-child(3) {
      grid-area: item3;
    }

    .grid-item-link-{{ ai_gen_id }}:nth-child(4) {
      grid-area: item4;
    }

    .grid-item-link-{{ ai_gen_id }}:nth-child(5) {
      grid-area: item5;
    }

    .grid-item-link-{{ ai_gen_id }}:nth-child(6) {
      grid-area: item6;
    }

    .grid-item-link-{{ ai_gen_id }}:nth-child(7) {
      grid-area: item7;
    }

    .grid-item-link-{{ ai_gen_id }}:nth-child(8) {
      grid-area: item8;
    }

    .grid-item-label-{{ ai_gen_id }} {
      font-size: {{ block.settings.label_size }}px;}

    .grid-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_size }}px;
    }
  }
{% endstyle %}

<div class="grid-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="grid-container-{{ ai_gen_id }}">
    <div class="grid-header-{{ ai_gen_id }}">
      <h2 class="grid-title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      <div class="grid-description-{{ ai_gen_id }}">{{ block.settings.paragraph }}</div>
    </div>

    <div class="grid-layout-{{ ai_gen_id }}">
      <div class="grid-main-image-{{ ai_gen_id }}">
        {% if block.settings.main_image %}
          <img
            src="{{ block.settings.main_image | image_url: width: 1000}}"
            alt="{{ block.settings.main_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.main_image.width }}"
            height="{{ block.settings.main_image.height }}"
          >
        {% else %}
          <div class="grid-item-placeholder-{{ ai_gen_id }}">
            {{'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      <div class="grid-items-{{ ai_gen_id }}">
        {% for i in (1..8) %}
          {% assign image_key = 'image_' | append: i %}
          {% assign label_key = 'label_' | append: i %}
          {% assign link_key = 'link_' | append: i %}
          <a href="{{ block.settings[link_key] }}" class="grid-item-link-{{ ai_gen_id }}">
            <div class="grid-item-image-{{ ai_gen_id }}">
              {% if block.settings[image_key] %}
                <img
                  src="{{ block.settings[image_key] | image_url: width: 500 }}"
                  alt="{{ block.settings[image_key].alt | escape }}"
                  loading="lazy"
                  width="{{ block.settings[image_key].width }}"
                  height="{{ block.settings[image_key].height }}"
                >
              {% else %}
                <div class="grid-item-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            <div class="grid-item-label-{{ ai_gen_id }}">{{ block.settings[label_key] }}</div>
          </a>
        {% endfor %}
      </div>
    </div>

    <div class="grid-button-wrapper-{{ ai_gen_id }}">
      <a href="{{ block.settings.button_link }}" class="grid-button-{{ ai_gen_id }}">
        {{ block.settings.button_label }}
      </a>
    </div>
  </div>
</div>

