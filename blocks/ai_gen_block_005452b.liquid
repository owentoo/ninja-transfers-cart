{% doc %}
  @prompt
    Create a fully customizable Shopify section featuring a product card grid with 3 columns on desktop, 2 on tablet, and 1 on mobile. Each card must be fully clickable and link to any product or custom URL.
    
    Each product card should include (in order):
    
    Optional top-left pill (editable text, color, size, visibility)
    
    Product image (uploadable per card)
    
    Custom title
    
    Custom price text
    
    Custom sub-text description
    
    All elements on every card must be fully editable in the theme editor.
    
    Above the grid, include an editable section heading.
    
    Required customization controls:
    
    Edit section heading text
    
    Upload image per card
    
    Edit title, price, and sub-text per card
    
    Add/remove/edit the top-left pill per card (text, color, shape, size)
    
    Link each card individually
    
    Adjust card size, spacing, and alignment
    
    Adjust section padding, margin, and max-width
    
    Control text alignment for all text fields
    
    Fully responsive behavior across breakpoints
    
    Ensure the layout is visually balanced, with centered content under images, and all styling options are adjustable in the theme editor.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-grid-section-{{ ai_gen_id }} {
    padding-top: {{ block.settings.section_padding_top }}px;
    padding-bottom: {{ block.settings.section_padding_bottom }}px;
    margin-top: {{ block.settings.section_margin_top }}px;
    margin-bottom: {{ block.settings.section_margin_bottom }}px;
  }

  .ai-product-grid-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.section_max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-product-grid-heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    font-weight: 600;
  }

  .ai-product-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.card_gap }}px;
  }

  .ai-product-card-{{ ai_gen_id }} {
    position: relative;
    display: block;
    text-decoration: none;
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    background-color: {{ block.settings.card_background }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
  }

  .ai-product-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
  }

  .ai-product-card-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
    background-color: {{ block.settings.image_background }};
  }

  .ai-product-card-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-card-image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-product-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-product-card-pill-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.pill_position_top }}px;
    left: {{ block.settings.pill_position_left }}px;
    padding: {{ block.settings.pill_padding_vertical }}px {{ block.settings.pill_padding_horizontal }}px;
    font-size: {{ block.settings.pill_font_size }}px;
    font-weight: 600;
    z-index: 2;
    border-radius: {{ block.settings.pill_border_radius }}px;
  }

  .ai-product-card-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_content_padding }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-product-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    line-height: 1.3;
  }

  .ai-product-card-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_font_size }}px;
    font-weight: 700;
    color: {{ block.settings.price_color }};
    margin: 0 0 {{ block.settings.price_spacing }}px;
  }

  .ai-product-card-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.5;
  }

  @media screen and (max-width: 989px) {
    .ai-product-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-product-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-product-grid-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-product-card-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_font_size }}px * 0.9);
    }

    .ai-product-card-price-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.price_font_size }}px * 0.9);
    }
  }
{% endstyle %}

<div class="ai-product-grid-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-grid-container-{{ ai_gen_id }}">
    {% if block.settings.section_heading != blank %}
      <h2 class="ai-product-grid-heading-{{ ai_gen_id }}">{{ block.settings.section_heading }}</h2>
    {% endif %}

    <div class="ai-product-grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign card_enabled_key = 'card_' | append: i | append: '_enabled'
          assign card_link_key = 'card_' | append: i | append: '_link'
          assign card_image_key = 'card_' | append: i | append: '_image'
          assign card_title_key = 'card_' | append: i | append: '_title'
          assign card_price_key = 'card_' | append: i | append: '_price'
          assign card_description_key = 'card_' | append: i | append: '_description'
          assign pill_enabled_key = 'card_' | append: i | append: '_pill_enabled'
          assign pill_text_key = 'card_' | append: i | append: '_pill_text'
          assign pill_bg_key = 'card_' | append: i | append: '_pill_bg_color'
          assign pill_text_color_key = 'card_' | append: i | append: '_pill_text_color'

          assign card_enabled = block.settings[card_enabled_key]
          assign card_link = block.settings[card_link_key]
          assign card_image = block.settings[card_image_key]
          assign card_title = block.settings[card_title_key]
          assign card_price = block.settings[card_price_key]
          assign card_description = block.settings[card_description_key]
          assign pill_enabled = block.settings[pill_enabled_key]
          assign pill_text = block.settings[pill_text_key]
          assign pill_bg = block.settings[pill_bg_key]
          assign pill_text_color = block.settings[pill_text_color_key]
        %}

        {% if card_enabled %}
          <a
            href="{% if card_link != blank %}{{ card_link }}{% else %}#{% endif %}"
            class="ai-product-card-{{ ai_gen_id }}"
          >
            <div class="ai-product-card-image-wrapper-{{ ai_gen_id }}">
              {% if card_image %}
                <img
                  src="{{ card_image | image_url: width: 800 }}"
                  alt="{{ card_title | escape }}"
                  class="ai-product-card-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="{{ card_image.width }}"
                  height="{{ card_image.height }}"
                >
              {% else %}
                <div class="ai-product-card-image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}

              {% if pill_enabled and pill_text != blank %}
                <div
                  class="ai-product-card-pill-{{ ai_gen_id }}"
                  style="background-color: {{ pill_bg }}; color: {{ pill_text_color }};"
                >
                  {{ pill_text }}
                </div>
              {% endif %}
            </div>

            <div class="ai-product-card-content-{{ ai_gen_id }}">
              {% if card_title != blank %}
                <h3 class="ai-product-card-title-{{ ai_gen_id }}">{{ card_title }}</h3>
              {% endif %}

              {% if card_price != blank %}
                <div class="ai-product-card-price-{{ ai_gen_id }}">{{ card_price }}</div>
              {% endif %}

              {% if card_description != blank %}
                <div class="ai-product-card-description-{{ ai_gen_id }}">{{ card_description }}</div>
              {% endif %}
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

