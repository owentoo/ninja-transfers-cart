{% doc %}
  @prompt
    i need a section with 2 columns in one container with a heading, para, and an optional cta. in the other container a embeded youtube video. All text should have size and weight options. and both containers should have alignment optins, section needs a max width and padding and margin options, padding and margin for the section need top, bottom, left, and right options and the video needs a radius, wrapper of the video and the wrapper of the text needs a max width option with alignments options. cta needs size options and roll over options, make the containers max width larger and let one take over the other if it goes past 50%, give me an option of the split % between the two columns so i can do something like a 20/80 split for content, add autoplay option to video and give me options for spacing between the text and cta, add an option for a bg color or gradient that doesn't effect max width, bg color should go full width and height, bg color should take up the whole section, all fonts need desktop and mobile options, ignore columns and use flex and deign the video wrapper with a percent width and let the text wrapper take up remaining space, on mobile the section is not taking up full width, i need options for the top and bottom margin for desktop and mobile

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .dual-content-section-{{ ai_gen_id }} {
    width: 100%;
    {% if block.settings.background_type == 'color' %}
      background-color: {{ block.settings.background_color }};
    {% elsif block.settings.background_type == 'gradient' %}
      background: linear-gradient({{ block.settings.gradient_direction }}deg, {{ block.settings.gradient_color_1 }}, {{ block.settings.gradient_color_2 }});
    {% endif %}
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;padding-left: {{ block.settings.padding_left }}px;
    padding-right: {{ block.settings.padding_right }}px;
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
    margin-left: {{ block.settings.margin_left }}px;
    margin-right: {{ block.settings.margin_right }}px;
    box-sizing: border-box;
  }

  .dual-content-wrapper-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin-left: auto;
    margin-right: auto;
    width: 100%;box-sizing: border-box;
  }

  .dual-content-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.gap }}px;
    align-items: {{ block.settings.vertical_alignment }};
    width: 100%;box-sizing: border-box;
  }

  .dual-content-text-wrapper-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
    box-sizing: border-box;
  }

  .dual-content-video-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.video_width }}%;
    box-sizing: border-box;
  }

  .dual-content-text-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.text_container_width }}px;
    width: 100%;
    text-align: {{ block.settings.text_alignment }};
    box-sizing: border-box;
    {% case block.settings.text_container_alignment %}
      {% when 'left' %}
        margin-left: 0;
        margin-right: auto;
      {% when 'center' %}
        margin-left: auto;
        margin-right: auto;
      {% when 'right' %}
        margin-left: auto;
        margin-right: 0;
    {% endcase %}
  }

  .dual-content-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    margin-top: 0;
    margin-bottom: {{ block.settings.heading_bottom_spacing }}px;
  }

  .dual-content-paragraph-{{ ai_gen_id }} {
    font-size: {{ block.settings.paragraph_size }}px;
    font-weight: {{ block.settings.paragraph_weight }};
    line-height: 1.5;
    margin-bottom: {{ block.settings.paragraph_bottom_spacing }}px;
  }

  .dual-content-button-{{ ai_gen_id }} {
    display: inline-block;
    font-size: {{ block.settings.button_size }}px;
    font-weight: {{ block.settings.button_weight }};
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    text-decoration: none;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border-radius: {{ block.settings.button_radius }}px;
    transition: all 0.3s ease;
  }

  .dual-content-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_background_hover }};
    color: {{ block.settings.button_text_color_hover }};
    transform: {{ block.settings.button_hover_effect }};
  }

  .dual-content-video-container-{{ ai_gen_id }} {
    width:100%;
    box-sizing: border-box;
    {% case block.settings.video_container_alignment %}
      {% when 'left' %}
        margin-left: 0;
        margin-right: auto;
      {% when 'center' %}
        margin-left: auto;
        margin-right: auto;
      {% when 'right' %}
        margin-left: auto;
        margin-right: 0;
    {% endcase %}
  }

  .dual-content-video-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: {{ block.settings.video_radius }}px;
  }

  .dual-content-video-{{ ai_gen_id }} iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
    border-radius: {{ block.settings.video_radius }}px;}

  .dual-content-video-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.video_radius }}px;}

  .dual-content-video-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
  }

  @media screen and (max-width: 749px) {
    .dual-content-section-{{ ai_gen_id }} {
      width: 100vw;
      margin-left: calc(-50vw + 50%);
      margin-right: calc(-50vw + 50%);padding-left: 20px;
      padding-right: 20px;
      margin-top: {{ block.settings.margin_top_mobile }}px;
      margin-bottom: {{ block.settings.margin_bottom_mobile }}px;
    }
    .dual-content-wrapper-{{ ai_gen_id }} {
      width: 100%;
      padding-left: 0;
      padding-right: 0;
    }
    
    .dual-content-{{ ai_gen_id }} {
      flex-direction: {{ block.settings.mobile_layout }};
      gap:24px;
    }
    
    .dual-content-video-wrapper-{{ ai_gen_id }},
    .dual-content-text-wrapper-{{ ai_gen_id }} {
      width: 100%;
      flex: none;
    }
    
    .dual-content-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
      font-weight: {{ block.settings.heading_weight_mobile }};}
    
    .dual-content-paragraph-{{ ai_gen_id }} {
      font-size: {{ block.settings.paragraph_size_mobile }}px;
      font-weight: {{ block.settings.paragraph_weight_mobile }};
    }

    .dual-content-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_size_mobile }}px;
      font-weight: {{ block.settings.button_weight_mobile }};
    }
    
    .dual-content-text-container-{{ ai_gen_id }},
    .dual-content-video-container-{{ ai_gen_id }} {
      max-width: 100%;
    }
  }
{% endstyle %}<div class="dual-content-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="dual-content-wrapper-{{ ai_gen_id }}">
    <div class="dual-content-{{ ai_gen_id }}">
      {% if block.settings.layout == 'text_video' %}
        <div class="dual-content-text-wrapper-{{ ai_gen_id }}">
          <div class="dual-content-text-container-{{ ai_gen_id }}">
            {% if block.settings.heading != blank %}
              <h2 class="dual-content-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
            {% endif %}
            
            {% if block.settings.paragraph != blank %}
              <div class="dual-content-paragraph-{{ ai_gen_id }}">{{ block.settings.paragraph }}</div>
            {% endif %}
            
            {% if block.settings.button_text != blank and block.settings.button_link != blank %}
              <a href="{{ block.settings.button_link }}" class="dual-content-button-{{ ai_gen_id }}">
                {{ block.settings.button_text }}
              </a>
            {% endif %}
          </div>
        </div>
        <div class="dual-content-video-wrapper-{{ ai_gen_id }}"><div class="dual-content-video-container-{{ ai_gen_id }}">
            {% if block.settings.youtube_url != blank %}
              <div class="dual-content-video-{{ ai_gen_id }}">
                {% assign video_id = block.settings.youtube_url | split: 'v=' | last | split: '&' | first %}
                {% assign autoplay_param = '' %}
                {% if block.settings.video_autoplay %}
                  {% assign autoplay_param = '&autoplay=1&mute=1' %}
                {% endif %}
                <iframe
                  src="https://www.youtube.com/embed/{{ video_id }}?rel=0{{ autoplay_param }}"
                  title="YouTube video"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                ></iframe>
              </div>
            {% else %}
              <div class="dual-content-video-{{ ai_gen_id }}">
                <div class="dual-content-video-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              </div>
            {% endif %}
          </div>
        </div>
      {% else %}
        <div class="dual-content-video-wrapper-{{ ai_gen_id }}">
          <div class="dual-content-video-container-{{ ai_gen_id }}">
            {% if block.settings.youtube_url != blank %}
              <div class="dual-content-video-{{ ai_gen_id }}">
                {% assign video_id = block.settings.youtube_url | split: 'v=' | last | split: '&' | first %}
                {% assign autoplay_param = '' %}
                {% if block.settings.video_autoplay %}
                  {% assign autoplay_param = '&autoplay=1&mute=1' %}
                {% endif %}
                <iframe
                  src="https://www.youtube.com/embed/{{ video_id }}?rel=0{{ autoplay_param }}"
                  title="YouTube video"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                ></iframe>
              </div>
            {% else %}
              <div class="dual-content-video-{{ ai_gen_id }}">
                <div class="dual-content-video-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              </div>
            {% endif %}
          </div>
        </div>
        
        <div class="dual-content-text-wrapper-{{ ai_gen_id }}">
          <div class="dual-content-text-container-{{ ai_gen_id }}">
            {% if block.settings.heading != blank %}
              <h2 class="dual-content-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
            {% endif %}
            
            {% if block.settings.paragraph != blank %}
              <div class="dual-content-paragraph-{{ ai_gen_id }}">{{ block.settings.paragraph }}</div>
            {% endif %}
            
            {% if block.settings.button_text != blank and block.settings.button_link != blank %}
              <a href="{{ block.settings.button_link }}" class="dual-content-button-{{ ai_gen_id }}">
                {{ block.settings.button_text }}
              </a>
            {% endif %}
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

