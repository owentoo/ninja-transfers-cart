{% doc %}
  @prompt
    make me a hero section with a min and max height for desktop and mobile. section should have a bg image that shrinks and grows with section. inside a max width container that is center aligned create a wrapper with an h1, para, and two options ctas. wrapper should have a percent based width, and alignment options for where is sits in container , section should always atempt to be 21:9, Container news outside padding and margins that match to the themes , on mobile Content wrapper
    should be full width, and section height should be based upon content plus top and bottom padding , on mobile use photos set focal point. and ad seperate overlay opcaity for mobile 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 21 / 9;
    min-height: {{ block.settings.min_height_desktop }}px;
    max-height: {{ block.settings.max_height_desktop }}px;
    display: flex;
    align-items: {{ block.settings.content_vertical_alignment }};
    justify-content: {{ block.settings.content_horizontal_alignment }};
    overflow: hidden;
  }

  .ai-hero-bg-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .ai-hero-bg-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.placeholder_bg_color }};
    z-index: 0;
  }

  .ai-hero-bg-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 1;
  }

  .ai-hero-container-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: {{ settings.theme_max_width }}px;
    margin: 0 auto;
    padding: 0 {{ settings.grid_gap }}px;
    display: flex;
    align-items: {{ block.settings.content_vertical_alignment }};
    justify-content: {{ block.settings.content_horizontal_alignment }};
  }

  .ai-hero-content-{{ ai_gen_id }} {
    width: {{ block.settings.content_width }}%;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-hero-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size_desktop }}px;
    line-height: 1.2;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
  }

  .ai-hero-text-{{ ai_gen_id }} {
    font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
    font-weight: {{ block.settings.text_font.weight }};
    font-size: {{ block.settings.text_size_desktop }}px;
    line-height: 1.5;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.text_spacing }}px 0;
  }

  .ai-hero-buttons-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.button_gap }}px;
    flex-wrap: wrap;
    {% if block.settings.text_alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.text_alignment == 'right' %}
      justify-content: flex-end;
    {% else %}
      justify-content: flex-start;
    {% endif %}
  }

  .ai-hero-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    text-decoration: none;
    border-radius: {{ settings.border_radius_buttons }}px;
    transition: all 0.3s ease;
    cursor: pointer;
    border: none;
  }

  .ai-hero-button-primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_primary_bg }};
    color: {{ block.settings.button_primary_color }};
  }

  .ai-hero-button-primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_primary_bg_hover }};
    color: {{ block.settings.button_primary_color_hover }};
  }

  .ai-hero-button-secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_secondary_bg }};
    color: {{ block.settings.button_secondary_color }};
    border: 2px solid {{ block.settings.button_secondary_border }};
  }

  .ai-hero-button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_secondary_bg_hover }};
    color: {{ block.settings.button_secondary_color_hover }};
    border-color: {{ block.settings.button_secondary_border_hover }};
  }

  @media screen and (max-width: 749px) {
    .ai-hero-{{ ai_gen_id }} {
      aspect-ratio: auto;
      min-height: auto;
      max-height: none;
      padding: {{ block.settings.mobile_padding_top }}px 0 {{ block.settings.mobile_padding_bottom }}px 0;
    }

    .ai-hero-bg-{{ ai_gen_id }} {
      object-position: {{ block.settings.background_image.presentation.focal_point }};
    }

    .ai-hero-overlay-{{ ai_gen_id }} {
      opacity: {{ block.settings.overlay_opacity_mobile }};
    }

    .ai-hero-container-{{ ai_gen_id }} {
      padding: 0 20px;
    }

    .ai-hero-content-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-hero-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-hero-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
    }

    .ai-hero-buttons-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: stretch;
    }

    .ai-hero-button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.background_image %}
    <img
      src="{{ block.settings.background_image | image_url: width: 2000 }}"
      srcset="{{ block.settings.background_image | image_url: width: 750 }} 750w,
              {{ block.settings.background_image | image_url: width: 1500 }} 1500w,
              {{ block.settings.background_image | image_url: width: 2000 }} 2000w"
      sizes="100vw"
      alt="{{ block.settings.background_image.alt | escape }}"
      loading="lazy"
      width="{{ block.settings.background_image.width }}"
      height="{{ block.settings.background_image.height }}"
      class="ai-hero-bg-{{ ai_gen_id }}"
    >
  {% else %}
    <div class="ai-hero-bg-placeholder-{{ ai_gen_id }}">
      {{ 'hero-apparel-1' | placeholder_svg_tag }}
    </div>
  {% endif %}

  {% if block.settings.show_overlay %}
    <div class="ai-hero-overlay-{{ ai_gen_id }}"></div>
  {% endif %}

  <div class="ai-hero-container-{{ ai_gen_id }}">
    <div class="ai-hero-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h1 class="ai-hero-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h1>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-hero-text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
      {% endif %}

      {% if block.settings.button_primary_label != blank or block.settings.button_secondary_label != blank %}
        <div class="ai-hero-buttons-{{ ai_gen_id }}">
          {% if block.settings.button_primary_label != blank %}
            <a
              href="{{ block.settings.button_primary_link }}"
              class="ai-hero-button-{{ ai_gen_id }} ai-hero-button-primary-{{ ai_gen_id }}"
            >
              {{ block.settings.button_primary_label }}
            </a>
          {% endif %}

          {% if block.settings.button_secondary_label != blank %}
            <a
              href="{{ block.settings.button_secondary_link }}"
              class="ai-hero-button-{{ ai_gen_id }} ai-hero-button-secondary-{{ ai_gen_id }}"
            >
              {{ block.settings.button_secondary_label }}
            </a>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

