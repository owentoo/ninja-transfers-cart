      "type": "range",
      "id": "play_icon_size",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Play icon size",
      "default": 60
    },
    {
      "type": "checkbox",
      "id": "hide_play_icon_mobile",
      "label": "Hide play icon on mobile",
      "default": false
    },
    {
      "type": "range",
      "id": "arrow_size",
      "min": 40,
      "max": 90,
      "step": 5,
      "unit": "%",
      "label": "Arrow size (% of icon)",
      "default": 60
    },
    {
