{% doc %}
  @prompt
    make me a section that follows the themes horizontal max width padding and margin. inside that i need the option to display 2-4 blocks, and the option for desktop and mobile to show 1-4 per row. Each block contains an image and below it a heading and para text, each block image needs the option to have a rollover image or video. all text needs color, weight, and sizes options for desktop and mobile, blocks need the option to display a play icon when  rover over media is present. Give Text opacity options, Text opacity should 0%-100%. in layout give me the option to display 1- 4 blocks. Play icon should be on image and disappear on hover, give me options for play icons size and position, center and corners, with padding options. I also need horizontal padding options for text, give me option for padding between the text and page for desktop and mobile. and options for the play icon including arrow size, arrow style, arrow color, arrow background color, arrow hover color, and the option for a custom icon., i need more image rations, and the option for image fit with contain or cover. and top and bottom padding and margin options for desktop and mobile, Horizontal padding (mobile) needs to move in increments of 2. i need a bg color option that fills the whole section. And text alignment options for desktop and mobile. Also spacing options for between image and heading and heading text. for desktop and mobile, Horizontal padding needs to move in increments of 2. Section background color needs to fill entire width of screen, need "Gap between blocks" for desktop and mobile. add option to hide play icon on mobile

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-feature-blocks-section-{{ ai_gen_id }} {
    background-color: {{ block.settings.section_background_color }};
    width: 100%;
  }

  .ai-feature-blocks-{{ ai_gen_id }} {
    margin: 0 auto;
    max-width: {{ settings.theme_max_width }}px;
    padding: {{ block.settings.container_padding_top_desktop }}px {{ block.settings.container_padding_desktop }}px {{ block.settings.container_padding_bottom_desktop }}px;
    margin-top: {{ block.settings.container_margin_top_desktop }}px;
    margin-bottom: {{ block.settings.container_margin_bottom_desktop }}px;
  }

  .ai-feature-blocks__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.gap_desktop }}px;
  }

  .ai-feature-blocks__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    text-align: {{ block.settings.text_alignment_desktop }};
  }

  .ai-feature-blocks__image-wrapper-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.image_to_heading_spacing_desktop }}px;width: 100%;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
  }

  .ai-feature-blocks__image-{{ ai_gen_id }},
  .ai-feature-blocks__hover-image-{{ ai_gen_id }},
  .ai-feature-blocks__video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: block;
    transition: opacity 0.3s ease;
    object-fit: {{ block.settings.image_fit }};
  }

  .ai-feature-blocks__hover-image-{{ ai_gen_id }},
  .ai-feature-blocks__video-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    width: 100%;
    height: 100%;
  }

  .ai-feature-blocks__item-{{ ai_gen_id }}:hover .ai-feature-blocks__hover-image-{{ ai_gen_id }},
  .ai-feature-blocks__item-{{ ai_gen_id }}:hover .ai-feature-blocks__video-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-feature-blocks__item-{{ ai_gen_id }}:not(.notransition):hover .ai-feature-blocks__image-{{ ai_gen_id }} {
    opacity: 0;
  }

  .ai-feature-blocks__play-icon-{{ ai_gen_id }} {
    position: absolute;
    width: {{ block.settings.play_icon_size }}px;
    height: {{ block.settings.play_icon_size }}px;
    background-color: {{ block.settings.play_icon_bg_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    z-index: 2;
    
    {% case block.settings.play_icon_position %}
      {% when 'center' %}
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
      {% when 'top-left' %}
        top: {{ block.settings.play_icon_padding }}px;
        left: {{ block.settings.play_icon_padding }}px;
      {% when 'top-right' %}
        top: {{ block.settings.play_icon_padding }}px;
        right: {{ block.settings.play_icon_padding }}px;
      {% when 'bottom-left' %}
        bottom: {{ block.settings.play_icon_padding }}px;
        left: {{ block.settings.play_icon_padding }}px;
      {% when 'bottom-right' %}
        bottom: {{ block.settings.play_icon_padding }}px;
        right: {{ block.settings.play_icon_padding }}px;
    {% endcase %}
  }

  .ai-feature-blocks__play-icon-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.play_icon_hover_bg_color }};}

  .ai-feature-blocks__play-icon-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.play_icon_size }}px * {{ block.settings.arrow_size | divided_by: 100.0 }});
    height: calc({{ block.settings.play_icon_size }}px * {{ block.settings.arrow_size | divided_by: 100.0 }});
    fill: {{ block.settings.play_icon_color }};
  }

  .ai-feature-blocks__item-{{ ai_gen_id }}:hover .ai-feature-blocks__play-icon-{{ ai_gen_id }} {
    opacity: 0;
  }

  .ai-feature-blocks__image-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-feature-blocks__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-feature-blocks__content-{{ ai_gen_id }} {
    padding: 0 {{ block.settings.text_horizontal_padding }}px;
  }

  .ai-feature-blocks__heading-{{ ai_gen_id }} {
    margin-top: 0;
    margin-bottom: {{ block.settings.heading_to_text_spacing_desktop }}px;
    font-size: {{ block.settings.heading_size_desktop }}px;
    color: {{ block.settings.heading_color }};
    font-weight: {{ block.settings.heading_weight }};
    line-height: 1.2;
    opacity: {{ block.settings.heading_opacity | divided_by: 100.0 }};
  }

  .ai-feature-blocks__text-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.text_size_desktop }}px;
    color: {{ block.settings.text_color }};
    font-weight: {{ block.settings.text_weight }};
    line-height: 1.5;
    opacity: {{ block.settings.text_opacity | divided_by: 100.0 }};
  }

  @media screen and (max-width: 749px) {
    .ai-feature-blocks-{{ ai_gen_id }} {
      padding: {{ block.settings.container_padding_top_mobile }}px {{ block.settings.container_padding_mobile }}px {{ block.settings.container_padding_bottom_mobile }}px;
      margin-top: {{ block.settings.container_margin_top_mobile }}px;
      margin-bottom: {{ block.settings.container_margin_bottom_mobile }}px;
    }
    
    .ai-feature-blocks__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.gap_mobile }}px;
    }

    .ai-feature-blocks__item-{{ ai_gen_id }} {
      text-align: {{ block.settings.text_alignment_mobile }};
    }

    .ai-feature-blocks__image-wrapper-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.image_to_heading_spacing_mobile }}px;
    }
    
    .ai-feature-blocks__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
      margin-bottom: {{ block.settings.heading_to_text_spacing_mobile }}px;
    }
    
    .ai-feature-blocks__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
    }

    .ai-feature-blocks__play-icon-{{ ai_gen_id }} {
      width: {{ block.settings.play_icon_size | times: 0.8 }}px;
      height: {{ block.settings.play_icon_size | times: 0.8 }}px;
      {% if block.settings.hide_play_icon_mobile %}
        display: none;
      {% endif %}
    }

    .ai-feature-blocks__play-icon-{{ ai_gen_id }} svg {
      width: calc({{ block.settings.play_icon_size | times: 0.8 }}px * {{ block.settings.arrow_size | divided_by: 100.0 }});
      height: calc({{ block.settings.play_icon_size | times: 0.8 }}px * {{ block.settings.arrow_size | divided_by: 100.0 }});
    }

    .ai-feature-blocks__content-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.text_horizontal_padding_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-feature-blocks-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-feature-blocks-{{ ai_gen_id }}">
    <div class="ai-feature-blocks__grid-{{ ai_gen_id }}">
      {% for i in (1..block.settings.number_of_blocks) %}
        {% assign image_key = 'image_' | append: i %}
        {% assign hover_image_key = 'hover_image_' | append: i %}
        {% assign video_key = 'video_' | append: i %}
        {% assign heading_key = 'heading_' | append: i %}
        {% assign text_key = 'text_' | append: i %}
        {% assign show_play_key = 'show_play_icon_' | append: i %}
        {% if block.settings[heading_key] != blank or block.settings[text_key] != blank %}
          <div class="ai-feature-blocks__item-{{ ai_gen_id }} {% if block.settings[hover_image_key] == blank and block.settings[video_key] == blank %}notransition{% endif %}">
            <div class="ai-feature-blocks__image-wrapper-{{ ai_gen_id }}">
              {% if block.settings[image_key] != blank %}
                <img
                  src="{{ block.settings[image_key] | image_url: width: 800 }}"
                  alt="{{ block.settings[image_key].alt | escape }}"
                  loading="lazy"
                  width="{{ block.settings[image_key].width }}"
                  height="{{ block.settings[image_key].height }}"
                  class="ai-feature-blocks__image-{{ ai_gen_id }}"
                >
                {% if block.settings[hover_image_key] != blank %}
                  <img
                    src="{{ block.settings[hover_image_key] | image_url: width: 800 }}"
                    alt="{{ block.settings[hover_image_key].alt | escape }}"
                    loading="lazy"
                    width="{{ block.settings[hover_image_key].width }}"
                    height="{{ block.settings[hover_image_key].height }}"
                    class="ai-feature-blocks__hover-image-{{ ai_gen_id }}"
                  >
                  {% if block.settings[show_play_key] %}
                    <div class="ai-feature-blocks__play-icon-{{ ai_gen_id }}">
                      {% if block.settings.custom_play_icon != blank %}
                        <img
                          src="{{ block.settings.custom_play_icon | image_url: width: 100 }}"
                          alt="Play"
                          loading="lazy"
                          width="{{ block.settings.custom_play_icon.width }}"
                          height="{{ block.settings.custom_play_icon.height }}"
                        >
                      {% else %}
                        {% case block.settings.arrow_style %}
                          {% when 'triangle' %}
                            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                              <polygon points="5,3 19,12 5,21"></polygon>
                            </svg>
                          {% when 'double-arrow' %}
                            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                              <path d="M11.5,5.5L17,12l-5.5,6.5M5.5,5.5L11,12l-5.5,6.5"></path>
                            </svg>
                          {% when 'circle-arrow' %}
                            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                              <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="1"></circle>
                              <polygon points="10,7 16,12 10,17"></polygon>
                            </svg>{% endcase %}
                      {% endif %}
                    </div>
                  {% endif %}
                {% elsif block.settings[video_key] != blank %}
                  <video
                    class="ai-feature-blocks__video-{{ ai_gen_id }}" 
                    autoplay 
                    muted 
                    loop 
                    playsinline
                  >
                    <source src="{{ block.settings[video_key] }}" type="video/mp4">
                  </video>{% if block.settings[show_play_key] %}
                    <div class="ai-feature-blocks__play-icon-{{ ai_gen_id }}">
                      {% if block.settings.custom_play_icon != blank %}
                        <img 
                          src="{{ block.settings.custom_play_icon | image_url: width: 100 }}"
                          alt="Play"
                          loading="lazy"
                          width="{{ block.settings.custom_play_icon.width }}"
                          height="{{ block.settings.custom_play_icon.height }}"
                        >
                      {% else %}
                        {% case block.settings.arrow_style %}
                          {% when 'triangle' %}
                            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                              <polygon points="5,3 19,12 5,21"></polygon>
                            </svg>
                          {% when 'double-arrow' %}
                            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                              <path d="M11.5,5.5L17,12l-5.5,6.5M5.5,5.5L11,12l-5.5,6.5"></path>
                            </svg>
                          {% when 'circle-arrow' %}
                            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                              <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="1"></circle>
                              <polygon points="10,7 16,12 10,17"></polygon>
                            </svg>
                        {% endcase %}
                      {% endif %}
                    </div>
                  {% endif %}
                {% endif %}
              {% else %}
                <div class="ai-feature-blocks__image-placeholder-{{ ai_gen_id }}">
                  {{'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            <div class="ai-feature-blocks__content-{{ ai_gen_id }}">
              {% if block.settings[heading_key] != blank %}
                <h3 class="ai-feature-blocks__heading-{{ ai_gen_id }}">{{ block.settings[heading_key] }}</h3>
              {% endif %}
              
              {% if block.settings[text_key] != blank %}
                <div class="ai-feature-blocks__text-{{ ai_gen_id }}">{{ block.settings[text_key] }}</div>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Feature Blocks",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color",
      "id": "section_background_color",
      "label": "Section background color",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "range",
      "id": "container_padding_desktop",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Horizontal padding (desktop)",
      "default": 20
    },
    {
      "type": "range",
      "id": "container_padding_top_desktop",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Top padding (desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "container_padding_bottom_desktop",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding (desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "container_margin_top_desktop",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Top margin (desktop)",
      "default": 0
    },
    {
      "type": "range",
      "id": "container_margin_bottom_desktop",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Bottom margin (desktop)",
      "default": 0
    },
    {
      "type": "range",
      "id": "container_padding_mobile",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Horizontal padding (mobile)",
      "default": 16
    },
    {
      "type": "range",
      "id": "container_padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top padding (mobile)",
      "default": 30
    },
    {
      "type": "range",
      "id": "container_padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding (mobile)",
      "default": 30
    },
    {
      "type": "range",
      "id": "container_margin_top_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top margin (mobile)",
      "default": 0
    },
    {
      "type": "range",
      "id": "container_margin_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom margin (mobile)",
      "default": 0
    },
    {
      "type": "range",
      "id": "number_of_blocks",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Number of blocks to display",
      "default": 3
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        },
        {
          "value": "3",
          "label": "3"
        },
        {
          "value": "4",
          "label": "4"
        }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "1"
    },
    {
      "type": "range",
