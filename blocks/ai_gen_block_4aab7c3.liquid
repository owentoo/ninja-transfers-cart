    {
      "type": "select",
      "id": "play_icon_position",
      "label": "Play icon position",
      "options": [
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "top-left",
          "label": "Top left"
        },
        {
          "value": "top-right",
          "label": "Top right"
        },
        {
          "value": "bottom-left",
          "label": "Bottom left"
        },
        {
          "value": "bottom-right",
          "label": "Bottom right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "play_icon_padding",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Play icon padding from edges",
      "default": 20
    },
    {
      "type": "header",
      "content": "Text Spacing"
    },
    {
      "type": "range",
      "id": "text_horizontal_padding",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Text horizontal padding (desktop)",
      "default": 0
    },
    {
      "type": "range",
      "id": "text_horizontal_padding_mobile",
      "min": 0,
      "max": 40,
      "step": 2,
