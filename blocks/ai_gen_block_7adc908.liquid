{% doc %}
  @prompt
    Section Name:
    Feature Grid with Full-Width Header
    
    Description:
    Create a section with one full-width top block and a customizable grid of feature blocks below. Each block includes a heading, subheading, icon, image, and link. The section should be fully responsive with layout, width, and visibility controls.
    
    Requirements:
    
    Top Full-Width Block:
    
    Heading (text)
    
    Subheading (text)
    
    Button text (text)
    
    Button link (URL)
    
    Icon upload (image)
    
    Image upload (image)
    
    Background color
    
    Option to hide on desktop or mobile
    
    Feature Blocks (repeatable):
    
    Heading (text)
    
    Subheading (text)
    
    Link (URL) — entire block clickable
    
    Icon upload (image) — top left of block
    
    Image upload (image) — under text
    
    Background color
    
    Option to hide on desktop or mobile
    
    Layout Options:
    
    Choose 2 or 3 blocks per row on desktop
    
    Adjustable section width (full / wide / normal)
    
    Adjustable padding and spacing
    
    Section Heading:
    
    Optional heading displayed above all blocks, The icon should appear to the left of each heading , Top Section Layout:
    The top block should be a two-column layout (50/50 split) — the left side contains the heading, subheading, and link/button, while the right side displays an image. The entire block should be clickable, using the link provided in the settings., Image Controls:
    Each block image (including the top section) should have adjustable image size controls — for example, width, height, or scale percentage.
    By default, the entire image should be displayed (no cropping) and automatically scaled to fit within its container while maintaining aspect ratio., Layout Controls:
    
    Add a setting to adjust the overall section width (options like Full width, Wide, or Standard).
    
    Include controls for padding inside each block (top, bottom, left, and right).
    
    Padding values should be adjustable in pixels or use range sliders for easier customization., Advanced Layout Controls:
    
    The section width should be adjustable using a range slider (e.g. 800px–2000px or 50%–100%), allowing full control instead of fixed options like “Normal” or “Wide.”
    
    Padding controls should be separate for desktop and mobile, with individual inputs for top, bottom, left, and right.
    
    Each padding value should be adjustable in pixels (or with range sliders) to fine-tune spacing per device.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-feature-grid-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.section_max_width }}px;
    margin: 0 auto;
    padding-top: {{ block.settings.section_padding_top_desktop }}px;
    padding-bottom: {{ block.settings.section_padding_bottom_desktop }}px;
    padding-left: {{ block.settings.section_padding_left_desktop }}px;
    padding-right: {{ block.settings.section_padding_right_desktop }}px;
  }

  .ai-feature-grid-section-heading-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.section_spacing }}px;
  }

  .ai-feature-grid-section-heading-{{ ai_gen_id }} h2 {
    font-family: {{ settings.headings_font_primary.family }}, {{ settings.headings_font_primary.fallback_families }};
    font-weight: {{ settings.headings_font_primary.weight }};
    font-size: {{ block.settings.section_heading_size }}px;
    color: {{ block.settings.section_heading_color }};
    margin: 0;
  }

  .ai-feature-grid-header-block-{{ ai_gen_id }} {
    width: 100%;
    background-color: {{ block.settings.header_bg_color }};
    border-radius: {{ settings.widgets_border_radius }}px;
    padding-top: {{ block.settings.header_padding_top_desktop }}px;
    padding-bottom: {{ block.settings.header_padding_bottom_desktop }}px;
    padding-left: {{ block.settings.header_padding_left_desktop }}px;
    padding-right: {{ block.settings.header_padding_right_desktop }}px;
    margin-bottom: {{ block.settings.section_spacing }}px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
    text-decoration: none;
    color: inherit;
    transition: all 0.3s ease;
    cursor: pointer;
    {% if block.settings.hide_header_desktop %}
      display: none;
    {% endif %}
  }

  .ai-feature-grid-header-block-{{ ai_gen_id }}:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
  }

  .ai-feature-grid-header-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .ai-feature-grid-header-heading-{{ ai_gen_id }} {
    font-family: {{ settings.headings_font_primary.family }}, {{ settings.headings_font_primary.fallback_families }};
    font-weight: {{ settings.headings_font_primary.weight }};
    font-size: {{ block.settings.header_heading_size }}px;
    color: {{ block.settings.header_text_color }};
    margin: 0;
  }

  .ai-feature-grid-header-subheading-{{ ai_gen_id }} {
    font-family: {{ settings.body_font_primary.family }}, {{ settings.body_font_primary.fallback_families }};
    font-size: {{ block.settings.header_subheading_size }}px;
    color: {{ block.settings.header_text_color }};
    margin: 0;
    opacity: 0.8;
    line-height: 1.5;
  }

  .ai-feature-grid-header-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    padding: 12px 24px;
    background-color: {{ block.settings.header_button_bg }};
    color: {{ block.settings.header_button_text }};
    text-decoration: none;
    border-radius: {{ settings.border_radius_buttons }}px;
    font-family: {{ settings.body_font_primary.family }}, {{ settings.body_font_primary.fallback_families }};
    font-weight: 500;
    transition: all 0.3s ease;
    align-self: flex-start;
    pointer-events: none;
  }

  .ai-feature-grid-header-image-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.header_image_width }}%;
    height: {{ block.settings.header_image_height }}px;
    border-radius: {{ settings.widgets_border_radius }}px;
    overflow: hidden;
    position: relative;
    margin: 0 auto;
  }

  .ai-feature-grid-header-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transform: scale({{ block.settings.header_image_scale | divided_by: 100.0 }});
  }

  .ai-feature-grid-header-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ settings.widgets_border_radius }}px;
  }

  .ai-feature-grid-header-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-feature-grid-blocks-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.blocks_per_row }}, 1fr);
    gap: {{ block.settings.blocks_spacing }}px;
  }

  .ai-feature-block-{{ ai_gen_id }} {
    background-color: {{ block.settings.default_block_bg }};
    border-radius: {{ settings.widgets_border_radius }}px;
    padding-top: {{ block.settings.block_padding_top_desktop }}px;
    padding-bottom: {{ block.settings.block_padding_bottom_desktop }}px;
    padding-left: {{ block.settings.block_padding_left_desktop }}px;
    padding-right: {{ block.settings.block_padding_right_desktop }}px;
    text-decoration: none;
    color: inherit;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .ai-feature-block-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .ai-feature-block-content-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-feature-block-header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 15px;
  }

  .ai-feature-block-icon-{{ ai_gen_id }} {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
  }

  .ai-feature-block-icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-feature-block-heading-{{ ai_gen_id }} {
    font-family: {{ settings.headings_font_primary.family }}, {{ settings.headings_font_primary.fallback_families }};
    font-weight: {{ settings.headings_font_primary.weight }};
    font-size: {{ block.settings.block_heading_size }}px;
    color: {{ block.settings.block_text_color }};
    margin: 0;
    flex: 1;
  }

  .ai-feature-block-subheading-{{ ai_gen_id }} {
    font-family: {{ settings.body_font_primary.family }}, {{ settings.body_font_primary.fallback_families }};
    font-size: {{ block.settings.block_subheading_size }}px;
    color: {{ block.settings.block_text_color }};
    margin: 0 0 20px 0;
    opacity: 0.8;
    line-height: 1.4;
  }

  .ai-feature-block-image-{{ ai_gen_id }} {
    width: {{ block.settings.block_image_width }}%;
    height: {{ block.settings.block_image_height }}px;
    border-radius: {{ settings.widgets_border_radius }}px;
    overflow: hidden;
    margin: 15px auto 0;
    position: relative;
  }

  .ai-feature-block-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transform: scale({{ block.settings.block_image_scale | divided_by: 100.0 }});
  }

  .ai-feature-block-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ settings.widgets_border_radius }}px;
  }

  .ai-feature-block-image-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  @media screen and (max-width: 768px) {
    .ai-feature-grid-{{ ai_gen_id }} {
      padding-top: {{ block.settings.section_padding_top_mobile }}px;
      padding-bottom: {{ block.settings.section_padding_bottom_mobile }}px;
      padding-left: {{ block.settings.section_padding_left_mobile }}px;
      padding-right: {{ block.settings.section_padding_right_mobile }}px;
    }

    .ai-feature-grid-header-block-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 25px;
      text-align: center;
      padding-top: {{ block.settings.header_padding_top_mobile }}px;
      padding-bottom: {{ block.settings.header_padding_bottom_mobile }}px;
      padding-left: {{ block.settings.header_padding_left_mobile }}px;
      padding-right: {{ block.settings.header_padding_right_mobile }}px;
      {% if block.settings.hide_header_mobile %}
        display: none;
      {% endif %}
    }

    .ai-feature-grid-header-content-{{ ai_gen_id }} {
      order: 2;
    }

    .ai-feature-grid-header-image-wrapper-{{ ai_gen_id }} {
      order: 1;
      height: {{ block.settings.header_image_height | times: 0.8 }}px;
    }

    .ai-feature-grid-header-button-{{ ai_gen_id }} {
      align-self: center;
    }

    .ai-feature-grid-blocks-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.blocks_per_row_mobile }}, 1fr);
      gap: {{ block.settings.blocks_spacing | times: 0.75 }}px;
    }

    .ai-feature-block-{{ ai_gen_id }} {
      padding-top: {{ block.settings.block_padding_top_mobile }}px;
      padding-bottom: {{ block.settings.block_padding_bottom_mobile }}px;
      padding-left: {{ block.settings.block_padding_left_mobile }}px;
      padding-right: {{ block.settings.block_padding_right_mobile }}px;
    }

    .ai-feature-block-icon-{{ ai_gen_id }} {
      width: 28px;
      height: 28px;
    }

    .ai-feature-block-header-{{ ai_gen_id }} {
      gap: 10px;
    }

    .ai-feature-block-image-{{ ai_gen_id }} {
      height: {{ block.settings.block_image_height | times: 0.8 }}px;
    }
  }

  @media screen and (max-width: 480px) {
    .ai-feature-grid-blocks-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<div class="ai-feature-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.section_heading != blank %}
    <div class="ai-feature-grid-section-heading-{{ ai_gen_id }}">
      <h2>{{ block.settings.section_heading }}</h2>
    </div>
  {% endif %}

  {% if block.settings.show_header_block %}
    <a 
      href="{{ block.settings.header_btn_link | default: '#' }}" 
      class="ai-feature-grid-header-block-{{ ai_gen_id }}"
    >
      <div class="ai-feature-grid-header-content-{{ ai_gen_id }}">
        {% if block.settings.header_heading != blank %}
          <h3 class="ai-feature-grid-header-heading-{{ ai_gen_id }}">{{ block.settings.header_heading }}</h3>
        {% endif %}
        
        {% if block.settings.header_subheading != blank %}
          <p class="ai-feature-grid-header-subheading-{{ ai_gen_id }}">{{ block.settings.header_subheading }}</p>
        {% endif %}
        
        {% if block.settings.header_btn_text != blank %}
          <span class="ai-feature-grid-header-button-{{ ai_gen_id }}">
            {{ block.settings.header_btn_text }}
          </span>
        {% endif %}
      </div>
      
      <div class="ai-feature-grid-header-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.header_image %}
          <img 
            src="{{ block.settings.header_image | image_url: width: 800 }}" 
            alt="{{ block.settings.header_image.alt | escape }}" 
            loading="lazy"
            class="ai-feature-grid-header-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-feature-grid-header-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    </a>
  {% endif %}

  <div class="ai-feature-grid-blocks-{{ ai_gen_id }}">
    {% for i in (1..6) %}
      {% liquid
        assign block_enabled_key = 'block_' | append: i | append: '_enabled'
        assign block_heading_key = 'block_' | append: i | append: '_heading'
        assign block_subheading_key = 'block_' | append: i | append: '_subheading'
        assign block_link_key = 'block_' | append: i | append: '_link'
        assign block_icon_key = 'block_' | append: i | append: '_icon'
        assign block_image_key = 'block_' | append: i | append: '_image'
        assign block_bg_key = 'block_' | append: i | append: '_bg_color'
        assign hide_desktop_key = 'block_' | append: i | append: '_hide_desktop'
        assign hide_mobile_key = 'block_' | append: i | append: '_hide_mobile'

        assign block_enabled = block.settings[block_enabled_key]
        assign block_heading = block.settings[block_heading_key]
        assign block_subheading = block.settings[block_subheading_key]
        assign block_link = block.settings[block_link_key]
        assign block_icon = block.settings[block_icon_key]
        assign block_image = block.settings[block_image_key]
        assign block_bg = block.settings[block_bg_key]
        assign hide_desktop = block.settings[hide_desktop_key]
        assign hide_mobile = block.settings[hide_mobile_key]
      %}

      {% if block_enabled %}
        <a 
          href="{{ block_link | default: '#' }}" 
          class="ai-feature-block-{{ ai_gen_id }} ai-feature-block-{{ ai_gen_id }}-{{ i }}"
          style="
            background-color: {{ block_bg | default: block.settings.default_block_bg }};
            {% if hide_desktop %}display: none;{% endif %}
          "
          {% if hide_mobile %}data-hide-mobile="true"{% endif %}
        >
          <div class="ai-feature-block-content-{{ ai_gen_id }}">
            <div class="ai-feature-block-header-{{ ai_gen_id }}">
              {% if block_icon %}
                <div class="ai-feature-block-icon-{{ ai_gen_id }}">
                  <img src="{{ block_icon | image_url: width: 64 }}" alt="{{ block_icon.alt | escape }}" loading="lazy">
                </div>
              {% endif %}
              
              {% if block_heading != blank %}
                <h4 class="ai-feature-block-heading-{{ ai_gen_id }}">{{ block_heading }}</h4>
              {% endif %}
            </div>
            
            {% if block_subheading != blank %}
              <p class="ai-feature-block-subheading-{{ ai_gen_id }}">{{ block_subheading }}</p>
            {% endif %}
            
            <div class="ai-feature-block-image-{{ ai_gen_id }}">
              {% if block_image %}
                <img src="{{ block_image | image_url: width: 400 }}" alt="{{ block_image.alt | escape }}" loading="lazy">
              {% else %}
                <div class="ai-feature-block-image-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
          </div>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</div>

<script>
  (function() {
    function handleMobileVisibility() {
      const blocks = document.querySelectorAll('.ai-feature-block-{{ ai_gen_id }}[data-hide-mobile="true"]');
      const isMobile = window.innerWidth <= 768;
      
      blocks.forEach(block => {
        if (isMobile) {
          block.style.display = 'none';
        } else {
          block.style.display = 'block';
        }
      });
    }

    handleMobileVisibility();
    window.addEventListener('resize', handleMobileVisibility);
  })();
</script>

