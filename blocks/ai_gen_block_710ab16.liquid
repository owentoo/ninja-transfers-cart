<script>
  (function() {
    class ScrollingGallery{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.wrapper = this.querySelector('.ai-scrolling-gallery__wrapper-{{ ai_gen_id }}');
        this.setupScrollBehavior();
      }

      setupScrollBehavior() {
        if (!this.wrapper) return;

        this.wrapper.style.scrollBehavior = 'smooth';
      }
    }

    customElements.define('scrolling-gallery-{{ ai_gen_id }}', ScrollingGallery{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Scrolling image gallery",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Container"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 1000,
      "max": 2000,
      "step": 100,
      "unit": "px",
      "default": 1400
    },
    {
      "type": "range",
      "id": "horizontal_padding",
      "label": "Horizontal padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "aspect_ratio_type",
      "label": "Aspect ratio",
      "options": [
        {
          "value": "natural",
          "label": "Natural (from images)"
        },
        {
          "value": "fixed",
          "label": "Fixed"
        }
      ],
      "default": "natural"
    },
    {
      "type": "range",
      "id": "aspect_ratio",
