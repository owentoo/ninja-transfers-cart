{% doc %}
  @prompt
    i need a section with up to eight blocks each block is made of an image with a text box over laid with two lines of text in it. on desktop you should see 3.5 block and 1.5 on mobile with schroll over lay , section needs max width and hoizontal padding. overlay needs gradiant , all blocks need padding inside that effect the text, and all text needs desktop and mobile size options , need weight option for both pieces of text. , scroll bar should display below all elements, give me an option for aspect ratio to come from images , i need an option for gradient height 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-scrolling-gallery-{{ ai_gen_id }} {
    width: 100%;
    display: block;
    overflow: hidden;
    position: relative;
  }

  .ai-scrolling-gallery__inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.horizontal_padding }}px;
  }

  .ai-scrolling-gallery__wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: {{ block.settings.scrollbar_color }} transparent;
    margin: 0 -{{ block.settings.horizontal_padding }}px;
    padding: 0 {{ block.settings.horizontal_padding }}px {{ block.settings.scrollbar_spacing }}px;
  }

  .ai-scrolling-gallery__wrapper-{{ ai_gen_id }}::-webkit-scrollbar {
    height: 8px;
  }

  .ai-scrolling-gallery__wrapper-{{ ai_gen_id }}::-webkit-scrollbar-track {
    background: transparent;
  }

  .ai-scrolling-gallery__wrapper-{{ ai_gen_id }}::-webkit-scrollbar-thumb {
    background-color: {{ block.settings.scrollbar_color }};
    border-radius: 4px;
  }

  .ai-scrolling-gallery__container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    padding: {{ block.settings.vertical_padding }}px 0 0;
  }

  .ai-scrolling-gallery__item-{{ ai_gen_id }} {
    position: relative;
    flex-shrink: 0;
    width: calc((100% - (2.5 * {{ block.settings.gap }}px)) / 3.5);
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-scrolling-gallery__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    {% if block.settings.aspect_ratio_type == 'fixed' %}
      padding-bottom: {{ block.settings.aspect_ratio }}%;
    {% endif %}
    background-color: {{ block.settings.placeholder_bg }};
  }

  {% if block.settings.aspect_ratio_type == 'natural' %}
    .ai-scrolling-gallery__image-wrapper-{{ ai_gen_id }} {
      height: auto;
    }
  {% endif %}

  .ai-scrolling-gallery__image-{{ ai_gen_id }} {
    {% if block.settings.aspect_ratio_type == 'fixed' %}
      position: absolute;
      top: 0;
      left: 0;
    {% endif %}
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-scrolling-gallery__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-scrolling-gallery__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-scrolling-gallery__text-overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: {{ block.settings.gradient_height }}%;
    padding: {{ block.settings.overlay_padding_desktop }}px;
    background: linear-gradient(to top, {{ block.settings.overlay_gradient_start }}, {{ block.settings.overlay_gradient_end }});
    backdrop-filter: blur({{ block.settings.overlay_blur }}px);
    -webkit-backdrop-filter: blur({{ block.settings.overlay_blur }}px);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .ai-scrolling-gallery__text-line-1-{{ ai_gen_id }} {
    font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
    font-weight: {{ block.settings.text_weight_line_1 }};
    font-size: {{ block.settings.text_size_line_1_desktop }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.line_spacing }}px 0;
    line-height: 1.2;
  }

  .ai-scrolling-gallery__text-line-2-{{ ai_gen_id }} {
    font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
    font-weight: {{ block.settings.text_weight_line_2 }};
    font-size: {{ block.settings.text_size_line_2_desktop }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.2;
  }

  @media screen and (max-width: 749px) {
    .ai-scrolling-gallery__inner-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.horizontal_padding | times: 0.5 }}px;
    }

    .ai-scrolling-gallery__wrapper-{{ ai_gen_id }} {
      margin: 0 -{{ block.settings.horizontal_padding | times: 0.5 }}px;
      padding: 0 {{ block.settings.horizontal_padding | times: 0.5 }}px {{ block.settings.scrollbar_spacing }}px;
    }

    .ai-scrolling-gallery__item-{{ ai_gen_id }} {
      width: calc((100% - (0.5 * {{ block.settings.gap }}px)) / 1.5);
    }

    .ai-scrolling-gallery__text-overlay-{{ ai_gen_id }} {
      padding: {{ block.settings.overlay_padding_mobile }}px;
    }

    .ai-scrolling-gallery__text-line-1-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_line_1_mobile }}px;
    }

    .ai-scrolling-gallery__text-line-2-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_line_2_mobile }}px;
    }
  }
{% endstyle %}

