{% doc %}
  @prompt
    create a section with horizontal max width and margin and padding that matches the current themes. inside i need an h1, on the next line five small icons with text next to it, on the next line para text, on the next line two buttons, on the next line small text.  bg that is either a looping video or image, with overlay option. , 5 icons should be next to one another with one line of text after them all. all text needs weight, and color options that include opacity, and size for desktop and mobile   , get rid of text next to icons 1-4., icon section should just be five small images with text next to it , get rid of Icon text, and add one line of text to the right of the icons , add desktop and mobile padding options below heading, icons, paragraph, and buttons. gap between icons should go as low as 2. all padding should be in multiples of 2., save entries as defaults. add top and bottom padding for desktop and mobile around content, section height should be based on this. bg image or video should fill all available space , section height should be determined by content and top and bottom padding 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-section-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-hero-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .ai-hero-video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 800px;
    max-height: 600px;
  }

  .ai-hero-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 1;
  }

  .ai-hero-container-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    max-width: {{ settings.theme_max_width }}px;
    margin: 0 auto;
    padding: {{ block.settings.section_padding_top_desktop }}px {{ settings.grid_gap }}px {{ block.settings.section_padding_bottom_desktop }}px;
  }

  .ai-hero-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_spacing }}px;
    max-width: {{ block.settings.content_max_width }}px;
    text-align: {{ block.settings.text_alignment }};
    width: 100%;
    {% if block.settings.text_alignment == 'center' %}
      margin-left: auto;
      margin-right: auto;
    {% elsif block.settings.text_alignment == 'right' %}
      margin-left: auto;
    {% endif %}
  }

  .ai-hero-heading-{{ ai_gen_id }} {
    font-family: {{ settings.headings_font_primary.family }}, {{ settings.headings_font_primary.fallback_families }};
    font-weight: {{ block.settings.heading_weight }};
    font-size: {{ block.settings.heading_size_desktop }}px;
    line-height: {{ settings.headings_line }};
    letter-spacing: {{ settings.headings_spacing }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    padding-bottom: {{ block.settings.heading_padding_bottom_desktop }}px;
  }

  .ai-hero-icons-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.icons_text_gap }}px;
    flex-wrap: wrap;
    padding-bottom: {{ block.settings.icons_padding_bottom_desktop }}px;
    {% if block.settings.text_alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.text_alignment == 'right' %}
      justify-content: flex-end;
    {% else %}
      justify-content: flex-start;
    {% endif %}
  }

  .ai-hero-icons-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.icons_gap }}px;
  }

  .ai-hero-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
  }

  .ai-hero-icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: {{ block.settings.icon_opacity }};
  }

  .ai-hero-icons-text-{{ ai_gen_id }} {
    font-family: {{ settings.body_font_primary.family }}, {{ settings.body_font_primary.fallback_families }};
    font-weight: {{ block.settings.icons_text_weight }};
    font-size: {{ block.settings.icons_text_size_desktop }}px;
    line-height: {{ settings.body_line }};
    color: {{ block.settings.icons_text_color }};
    opacity: {{ block.settings.icons_text_opacity }};
  }

  .ai-hero-paragraph-{{ ai_gen_id }} {
    font-family: {{ settings.body_font_primary.family }}, {{ settings.body_font_primary.fallback_families }};
    font-weight: {{ block.settings.paragraph_weight }};
    font-size: {{ block.settings.paragraph_size_desktop }}px;
    line-height: {{ settings.body_line }};
    color: {{ block.settings.paragraph_color }};
    opacity: {{ block.settings.paragraph_opacity }};
    margin: 0;
    padding-bottom: {{ block.settings.paragraph_padding_bottom_desktop }}px;
  }

  .ai-hero-buttons-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.buttons_gap }}px;
    padding-bottom: {{ block.settings.buttons_padding_bottom_desktop }}px;
    {% if block.settings.text_alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.text_alignment == 'right' %}
      justify-content: flex-end;
    {% else %}
      justify-content: flex-start;
    {% endif %}
  }

  .ai-hero-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    font-family: {{ settings.body_font_primary.family }}, {{ settings.body_font_primary.fallback_families }};
    font-weight: {{ block.settings.button_text_weight }};
    font-size: {{ block.settings.button_text_size_desktop }}px;
    text-decoration: none;
    border-radius: {{ settings.border_radius_buttons }}px;
    border-width: {{ settings.border_width_buttons }}px;
    border-style: solid;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-hero-button-primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_primary_bg }};
    color: {{ block.settings.button_primary_color }};
    border-color: {{ block.settings.button_primary_border }};
    opacity: {{ block.settings.button_primary_opacity }};
  }

  .ai-hero-button-primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_primary_bg_hover }};
    color: {{ block.settings.button_primary_color_hover }};
    border-color: {{ block.settings.button_primary_border_hover }};
  }

  .ai-hero-button-secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_secondary_bg }};
    color: {{ block.settings.button_secondary_color }};
    border-color: {{ block.settings.button_secondary_border }};
    opacity: {{ block.settings.button_secondary_opacity }};
  }

  .ai-hero-button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_secondary_bg_hover }};
    color: {{ block.settings.button_secondary_color_hover }};
    border-color: {{ block.settings.button_secondary_border_hover }};
  }

  .ai-hero-small-text-{{ ai_gen_id }} {
    font-family: {{ settings.body_font_primary.family }}, {{ settings.body_font_primary.fallback_families }};
    font-weight: {{ block.settings.small_text_weight }};
    font-size: {{ block.settings.small_text_size_desktop }}px;
    line-height: {{ settings.body_line }};
    color: {{ block.settings.small_text_color }};
    opacity: {{ block.settings.small_text_opacity }};
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-container-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top_mobile }}px {{ settings.grid_gap | times: 0.5 }}px {{ block.settings.section_padding_bottom_mobile }}px;
    }

    .ai-hero-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
      padding-bottom: {{ block.settings.heading_padding_bottom_mobile }}px;
    }

    .ai-hero-icons-wrapper-{{ ai_gen_id }} {
      padding-bottom: {{ block.settings.icons_padding_bottom_mobile }}px;
    }

    .ai-hero-icons-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.icons_text_size_mobile }}px;
    }

    .ai-hero-paragraph-{{ ai_gen_id }} {
      font-size: {{ block.settings.paragraph_size_mobile }}px;
      padding-bottom: {{ block.settings.paragraph_padding_bottom_mobile }}px;
    }

    .ai-hero-buttons-{{ ai_gen_id }} {
      padding-bottom: {{ block.settings.buttons_padding_bottom_mobile }}px;
    }

    .ai-hero-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_text_size_mobile }}px;
    }

    .ai-hero-small-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.small_text_size_mobile }}px;
    }

    .ai-hero-content-{{ ai_gen_id }} {
      gap: {{ block.settings.content_spacing | times: 0.7 }}px;
    }

    .ai-hero-buttons-{{ ai_gen_id }} {
      flex-direction: column;
      width: 100%;
    }

    .ai-hero-button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<hero-section-{{ ai_gen_id }} class="ai-hero-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-background-{{ ai_gen_id }}">
    {% if block.settings.background_type == 'video' and block.settings.background_video != blank %}
      <video
        class="ai-hero-video-{{ ai_gen_id }}"
        autoplay
        muted
        loop
        playsinline
        {% if block.settings.background_image != blank %}
          poster="{{ block.settings.background_image | image_url: width: 2000 }}"
        {% endif %}
      >
        <source src="{{ block.settings.background_video }}" type="video/mp4">
      </video>
    {% elsif block.settings.background_image != blank %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
        class="ai-hero-image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-hero-image-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  {% if block.settings.enable_overlay %}
    <div class="ai-hero-overlay-{{ ai_gen_id }}"></div>
  {% endif %}

  <div class="ai-hero-container-{{ ai_gen_id }}">
    <div class="ai-hero-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h1 class="ai-hero-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h1>
      {% endif %}

      <div class="ai-hero-icons-wrapper-{{ ai_gen_id }}">
        <div class="ai-hero-icons-{{ ai_gen_id }}">
          {% for i in (1..5) %}
            {% liquid
              assign icon_image_key = 'icon_' | append: i | append: '_image'
              assign icon_image = block.settings[icon_image_key]
            %}
            {% if icon_image != blank %}
              <div class="ai-hero-icon-{{ ai_gen_id }}">
                <img
                  src="{{ icon_image | image_url: width: 100 }}"
                  alt="{{ icon_image.alt | escape }}"
                  loading="lazy"
                  width="100"
                  height="100"
                >
              </div>
            {% endif %}
          {% endfor %}
        </div>

        {% if block.settings.icons_text != blank %}
          <span class="ai-hero-icons-text-{{ ai_gen_id }}">{{ block.settings.icons_text }}</span>
        {% endif %}
      </div>

      {% if block.settings.paragraph != blank %}
        <div class="ai-hero-paragraph-{{ ai_gen_id }}">{{ block.settings.paragraph }}</div>
      {% endif %}

      <div class="ai-hero-buttons-{{ ai_gen_id }}">
        {% if block.settings.button_primary_label != blank %}
          <a
            href="{{ block.settings.button_primary_link }}"
            class="ai-hero-button-{{ ai_gen_id }} ai-hero-button-primary-{{ ai_gen_id }}"
          >
            {{ block.settings.button_primary_label }}
          </a>
        {% endif %}

        {% if block.settings.button_secondary_label != blank %}
          <a
            href="{{ block.settings.button_secondary_link }}"
            class="ai-hero-button-{{ ai_gen_id }} ai-hero-button-secondary-{{ ai_gen_id }}"
          >
            {{ block.settings.button_secondary_label }}
          </a>
        {% endif %}
      </div>

      {% if block.settings.small_text != blank %}
        <div class="ai-hero-small-text-{{ ai_gen_id }}">{{ block.settings.small_text }}</div>
      {% endif %}
    </div>
  </div>
</hero-section-{{ ai_gen_id }}>

<script>
  (function() {
    class HeroSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const video = this.querySelector('.ai-hero-video-{{ ai_gen_id }}');
        if (video) {
          video.play().catch(() => {});
        }
      }
    }

    customElements.define('hero-section-{{ ai_gen_id }}', HeroSection{{ ai_gen_id }});
  })();
</script>

