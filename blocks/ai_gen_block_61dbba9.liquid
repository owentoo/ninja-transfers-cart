{% doc %}
  @prompt
    make me a section that follows the themes horizontal max width padding and margin. I need a collection on link blocks each with a picture and text, these should have the option to link to a collection and pull the image and collection title from the cms, give me the option to show 20 blocks with the options to show 1-6 blocks per row. all blocks should be aligned center, give me an option on how many link blocks to show, link blocks should have the ability to have the text and image overridden. any row that is not completely filled should have blocks centered, I don't need a heading. i need Text Settings for desktop and mobile. Rollover option for text color. don't need tablet rules. if number of blocks shown is not a multiple of the column number center blocks, i need desktop and mobile option for top and bottom padding and margin. space between rows desktop and mobile. and image should not grow on roll over. the whole block should only move up slightly., section needs a bg color option, need a space between blocks for desktop and mobile, bg color needs to fill entire section, the full width. and add Horizontal padding option for desktop and mobile, all Horizontal padding needs to work in increments of 1 from 0 to 100

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .collection-links-wrapper-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding-top: {{ block.settings.padding_top_desktop }}px;
    padding-bottom: {{ block.settings.padding_bottom_desktop }}px;
    margin-top: {{ block.settings.margin_top_desktop }}px;
    margin-bottom: {{ block.settings.margin_bottom_desktop }}px;
  }

  .collection-links-{{ ai_gen_id }} {
    max-width: {{ settings.theme_max_width }}px;
    margin: 0 auto;
    padding-left: {{ block.settings.padding_horizontal_desktop }}px;
    padding-right: {{ block.settings.padding_horizontal_desktop }}px;
  }

  .collection-links__grid-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.row_spacing_desktop }}px {{ block.settings.column_spacing_desktop }}px;
    justify-content: center;
    align-items: stretch;
  }

  .collection-links__item-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.columns_desktop }} - 1) * {{ block.settings.column_spacing_desktop }}px) / {{ block.settings.columns_desktop }});
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    color: {{ block.settings.text_color }};
    transition: transform 0.3s ease, color 0.3s ease;
    max-width: calc((100% - ({{ block.settings.columns_desktop }} - 1) * {{ block.settings.column_spacing_desktop }}px) / {{ block.settings.columns_desktop }});
    height: 100%;
  }

  .collection-links__item-{{ ai_gen_id }}:hover {
    transform: translateY(-3px);
    color: {{ block.settings.text_hover_color }};
  }

  .collection-links__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    margin-bottom: 15px;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    position: relative;
    padding-bottom: {{ block.settings.image_ratio }}%;
  }

  .collection-links__image-{{ ai_gen_id }} {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    object-fit: {{ block.settings.image_fit }};
  }

  .collection-links__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.placeholder_color }};
  }

  .collection-links__image-placeholder-{{ ai_gen_id }} svg {
    width: 40%;
    height: 40%;
    opacity: 0.5;
  }

  .collection-links__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size_desktop }}px;
    font-weight: {{ block.settings.title_weight }};
    margin: 0;
    color: currentColor;
  }

  @media screen and (max-width: 749px) {
    .collection-links-wrapper-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top_mobile }}px;
      padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
      margin-top: {{ block.settings.margin_top_mobile }}px;
      margin-bottom: {{ block.settings.margin_bottom_mobile }}px;
    }
    
    .collection-links-{{ ai_gen_id }} {
      padding-left: {{ block.settings.padding_horizontal_mobile }}px;
      padding-right: {{ block.settings.padding_horizontal_mobile }}px;
    }
    
    .collection-links__grid-{{ ai_gen_id }} {
      gap: {{ block.settings.row_spacing_mobile }}px {{ block.settings.column_spacing_mobile }}px;
    }
    
    .collection-links__item-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.columns_mobile }} - 1) * {{ block.settings.column_spacing_mobile }}px) / {{ block.settings.columns_mobile }});
      max-width: calc((100% - ({{ block.settings.columns_mobile }} - 1) * {{ block.settings.column_spacing_mobile }}px) / {{ block.settings.columns_mobile }});
    }
    
    .collection-links__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="collection-links-wrapper-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="collection-links-{{ ai_gen_id }}">
    <div class="collection-links__grid-{{ ai_gen_id }}">
      {% for i in (1..20) %}
        {% assign collection_setting = 'collection_' | append: i %}
        {% assign collection = block.settings[collection_setting] %}
        {% assign custom_title_setting = 'custom_title_' | append: i %}
        {% assign custom_title = block.settings[custom_title_setting] %}
        {% assign custom_image_setting = 'custom_image_' | append: i %}
        {% assign custom_image = block.settings[custom_image_setting] %}
        
        {% if collection != blank and forloop.index <= block.settings.number_of_blocks %}
          <a href="{{ collection.url }}" class="collection-links__item-{{ ai_gen_id }}">
            <div class="collection-links__image-wrapper-{{ ai_gen_id }}">
              {% if custom_image != blank %}
                <img
                  src="{{ custom_image | image_url: width: 500 }}"
                  alt="{{ custom_title | default: collection.title | escape }}"
                  loading="lazy"
                  class="collection-links__image-{{ ai_gen_id }}"
                  width="500"
                  height="{{ 500 | divided_by: custom_image.aspect_ratio | round }}"
                >
              {% elsif collection.image %}
                <img
                  src="{{ collection.image | image_url: width: 500 }}"
                  alt="{{ collection.title | escape }}"
                  loading="lazy"
                  class="collection-links__image-{{ ai_gen_id }}"
                  width="500"
                  height="{{ 500 | divided_by: collection.image.aspect_ratio | round }}"
                >
              {% else %}
                <div class="collection-links__image-placeholder-{{ ai_gen_id }}">
                  {{ 'collection-apparel-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            <h3 class="collection-links__title-{{ ai_gen_id }}">{{ custom_title | default: collection.title }}</h3>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

