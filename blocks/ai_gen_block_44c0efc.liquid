{% doc %}
  @prompt
    I would like to create a section that is meant for mobile. It will have 2 entries per row and I can add on as many rows as I need. Each image displayed in each entry will be a square section with round edges (that can be controlled with a slider). In the square will be a circle where the uploaded image will display, the circle will act as a mask, so that the image will only display where the circle opens up. Underneath each circle but still in the square will be a place for text. Clicking anywhere in the square will take user to the URL provided for that entry. This whole section needs an H1 and subtext underneath

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-mobile-grid-{{ ai_gen_id }} {
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-mobile-grid__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 32px;
  }

  .ai-mobile-grid__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
    font-weight: 600;
  }

  .ai-mobile-grid__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_size }}px;
    color: {{ block.settings.subtext_color }};
    margin: 0;
    line-height: 1.4;
  }

  .ai-mobile-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.grid_gap }}px;
    max-width: 600px;
    margin: 0 auto;
  }

  .ai-mobile-grid__item-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease;
  }

  .ai-mobile-grid__item-{{ ai_gen_id }}:hover {
    transform: translateY(-2px);
  }

  .ai-mobile-grid__card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    height: 100%;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-mobile-grid__image-container-{{ ai_gen_id }} {
    width: {{ block.settings.circle_size }}px;
    height: {{ block.settings.circle_size }}px;
    border-radius: 50%;
    overflow: hidden;
    margin-bottom: 16px;
    background-color: {{ block.settings.circle_background }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-mobile-grid__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-mobile-grid__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;}

  .ai-mobile-grid__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-mobile-grid__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.item_text_size }}px;
    color: {{ block.settings.item_text_color }};
    margin: 0;
    line-height: 1.3;
    font-weight: 500;
  }

  @media screen and (max-width: 480px) {
    .ai-mobile-grid-{{ ai_gen_id }} {
      padding: 30px 16px;
    }

    .ai-mobile-grid__container-{{ ai_gen_id }} {
      gap: {{ block.settings.grid_gap | times: 0.8 }}px;
    }

    .ai-mobile-grid__image-container-{{ ai_gen_id }} {
      width: {{ block.settings.circle_size | times: 0.9 }}px;
      height: {{ block.settings.circle_size | times: 0.9 }}px;
    }

    .ai-mobile-grid__card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.8 }}px;
    }
  }
{% endstyle %}

<mobile-grid-{{ ai_gen_id }} class="ai-mobile-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-mobile-grid__header-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h1 class="ai-mobile-grid__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h1>
    {% endif %}
    {% if block.settings.subtext != blank %}
      <div class="ai-mobile-grid__subtitle-{{ ai_gen_id }}">{{ block.settings.subtext }}</div>
    {% endif %}
  </div>

  <div class="ai-mobile-grid__container-{{ ai_gen_id }}">
    {% for i in (1..20) %}
      {% liquid
        assign image_key = 'item_' | append: i | append: '_image'
        assign text_key = 'item_' | append: i | append: '_text'
        assign url_key = 'item_' | append: i | append: '_url'
        
        assign item_image = block.settings[image_key]
        assign item_text = block.settings[text_key]
        assign item_url = block.settings[url_key]%}

      {% if item_text != blank or item_image != blank %}
        <a 
          href="{{ item_url | default: '#' }}" 
          class="ai-mobile-grid__item-{{ ai_gen_id }}"
          {% if item_url == blank %}onclick="return false;"{% endif %}
        >
          <div class="ai-mobile-grid__card-{{ ai_gen_id }}"><div class="ai-mobile-grid__image-container-{{ ai_gen_id }}">
              {% if item_image != blank %}
                <img
                  src="{{ item_image | image_url: width: 200 }}"
                  alt="{{ item_image.alt | escape }}"
                  class="ai-mobile-grid__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="200"
                  height="200"
                >
              {% else %}
                <div class="ai-mobile-grid__placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            {% if item_text != blank %}
              <p class="ai-mobile-grid__text-{{ ai_gen_id }}">{{ item_text }}</p>
            {% endif %}
          </div>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</mobile-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class MobileGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const items = this.querySelectorAll('.ai-mobile-grid__item-{{ ai_gen_id }}');
        items.forEach((item) => {
          if (item.getAttribute('href') === '#') {
            item.setAttribute('role', 'button');
            item.setAttribute('tabindex', '0');
            item.setAttribute('aria-disabled', 'true');
          }
        });
      }
    }

    customElements.define('mobile-grid-{{ ai_gen_id }}', MobileGrid{{ ai_gen_id }});
  })();
</script>

