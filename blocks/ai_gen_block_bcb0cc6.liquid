{% doc %}
  @prompt
    Create a responsive content blocks section with customizable icons that can be uploaded by the merchant. Design the layout with each icon and block title appearing on the same horizontal line, followed by a description below. Include 3-4 feature blocks in a clean grid layout. Add subtle hover animations that highlight each block when users interact with them. Make the section width controllable through settings (full-width, contained, or custom width with pixel/percentage options). Ensure the design is minimalist with consistent spacing and a cohesive color scheme that can be customized to match brand colors. Include settings to adjust spacing between blocks, icon size, and text alignment.

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-feature-blocks-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.gap }}px;
    width: 100%;
    max-width: {% if block.settings.width_type == 'full' %}100%{% elsif block.settings.width_type == 'contained' %}{{ block.settings.container_width }}px{% else %}{{ block.settings.width_value }}{{ block.settings.width_unit }}{% endif %};
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 0;
  }

  @media screen and (max-width: 749px) {
    .ai-feature-blocks-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
  }

  .ai-feature-block-{{ ai_gen_id }} {
    padding: {{ block.settings.block_padding }}px;
    background-color: {{ block.settings.block_background }};
    border-radius: {{ block.settings.block_border_radius }}px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    text-align: {{ block.settings.text_alignment }};}

  .ai-feature-block-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
  }

  .ai-feature-block-header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    margin-bottom: {{ block.settings.spacing_after_title }}px;
    gap: 15px;
  }

  .ai-feature-block-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;}

  .ai-feature-block-icon-{{ ai_gen_id }} img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .ai-feature-block-icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.icon_background }};
    border-radius: 50%;
  }

  .ai-feature-block-icon-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    fill: {{ block.settings.icon_color }};
  }

  .ai-feature-block-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    margin: 0;
    color: {{ block.settings.title_color }};
  }

  .ai-feature-block-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.5;
    color: {{ block.settings.text_color }};
  }
{% endstyle %}

<div class="ai-feature-blocks-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.block_1_title != blank %}
    <div class="ai-feature-block-{{ ai_gen_id }}">
      <div class="ai-feature-block-header-{{ ai_gen_id }}">
        <div class="ai-feature-block-icon-{{ ai_gen_id }}">
          {% if block.settings.block_1_icon %}
            <img
              src="{{ block.settings.block_1_icon | img_url: '100x' }}" 
              alt="{{ block.settings.block_1_title }}" 
              loading="lazy"
              width="{{ block.settings.icon_size }}"
              height="{{ block.settings.icon_size }}"
            >
          {% else %}
            <div class="ai-feature-block-icon-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
        <h3 class="ai-feature-block-title-{{ ai_gen_id }}">{{ block.settings.block_1_title }}</h3>
      </div>
      <div class="ai-feature-block-description-{{ ai_gen_id }}">{{ block.settings.block_1_description }}</div>
    </div>
  {% endif %}

  {% if block.settings.block_2_title != blank %}
    <div class="ai-feature-block-{{ ai_gen_id }}">
      <div class="ai-feature-block-header-{{ ai_gen_id }}">
        <div class="ai-feature-block-icon-{{ ai_gen_id }}">
          {% if block.settings.block_2_icon %}
            <img 
              src="{{ block.settings.block_2_icon | img_url: '100x' }}" 
              alt="{{ block.settings.block_2_title }}" 
              loading="lazy"
              width="{{ block.settings.icon_size }}"
              height="{{ block.settings.icon_size }}"
            >
          {% else %}
            <div class="ai-feature-block-icon-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
        <h3 class="ai-feature-block-title-{{ ai_gen_id }}">{{ block.settings.block_2_title }}</h3>
      </div>
      <div class="ai-feature-block-description-{{ ai_gen_id }}">{{ block.settings.block_2_description }}</div>
    </div>
  {% endif %}

  {% if block.settings.block_3_title != blank %}
    <div class="ai-feature-block-{{ ai_gen_id }}">
      <div class="ai-feature-block-header-{{ ai_gen_id }}">
        <div class="ai-feature-block-icon-{{ ai_gen_id }}">
          {% if block.settings.block_3_icon %}
            <img 
              src="{{ block.settings.block_3_icon | img_url: '100x' }}" 
              alt="{{ block.settings.block_3_title }}" 
              loading="lazy"
              width="{{ block.settings.icon_size }}"
              height="{{ block.settings.icon_size }}"
            >
          {% else %}
            <div class="ai-feature-block-icon-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
        <h3 class="ai-feature-block-title-{{ ai_gen_id }}">{{ block.settings.block_3_title }}</h3>
      </div>
      <div class="ai-feature-block-description-{{ ai_gen_id }}">{{ block.settings.block_3_description }}</div>
    </div>
  {% endif %}

  {% if block.settings.block_4_title != blank %}
    <div class="ai-feature-block-{{ ai_gen_id }}">
      <div class="ai-feature-block-header-{{ ai_gen_id }}">
        <div class="ai-feature-block-icon-{{ ai_gen_id }}">
          {% if block.settings.block_4_icon %}
            <img 
              src="{{ block.settings.block_4_icon | img_url: '100x' }}" 
              alt="{{ block.settings.block_4_title }}" 
              loading="lazy"
              width="{{ block.settings.icon_size }}"
              height="{{ block.settings.icon_size }}"
            >
          {% else %}
            <div class="ai-feature-block-icon-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
        <h3 class="ai-feature-block-title-{{ ai_gen_id }}">{{ block.settings.block_4_title }}</h3>
      </div>
      <div class="ai-feature-block-description-{{ ai_gen_id }}">{{ block.settings.block_4_description }}</div>
    </div>
  {% endif %}
</div>

