{% doc %}
  @prompt
    i want a section with row text on one side and an image on the other. each piece of text is a link that changes the image , section needs a max width with horizontal padding, need upto 8 links, all text needs mobile and desktop options, images need ratio options, Horizontal padding should be inside of max width. on mobile links should be all on one roll and be scrollable  , no bubble arpound links just an underline under the active one 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-switcher-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-image-switcher-wrapper-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.horizontal_padding_desktop }}px;
  }

  .ai-image-switcher-container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    align-items: flex-start;
  }

  .ai-image-switcher-links-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.text_column_width }}%;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.link_spacing }}px;
  }

  .ai-image-switcher-link-{{ ai_gen_id }} {
    display: block;
    padding: {{ block.settings.link_padding }}px 0;
    background-color: transparent;
    color: {{ block.settings.link_text_color }};
    text-decoration: none;
    font-size: {{ block.settings.link_font_size_desktop }}px;
    transition: all 0.3s ease;
    cursor: pointer;
    border-bottom: {{ block.settings.underline_thickness }}px solid transparent;
    white-space: nowrap;
  }

  .ai-image-switcher-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_text_color }};
  }

  .ai-image-switcher-link-{{ ai_gen_id }}.active {
    color: {{ block.settings.link_active_text_color }};
    border-bottom-color: {{ block.settings.underline_color }};
  }

  .ai-image-switcher-images-{{ ai_gen_id }} {
    flex: 1;
    position: relative;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
  }

  .ai-image-switcher-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio_desktop }};
  }

  .ai-image-switcher-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .ai-image-switcher-image-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-image-switcher-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-image-switcher-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  @media screen and (max-width: 749px) {
    .ai-image-switcher-wrapper-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.horizontal_padding_mobile }}px;
    }

    .ai-image-switcher-container-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-image-switcher-links-{{ ai_gen_id }} {
      flex: 0 0 auto;
      width: 100%;
      flex-direction: row;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    .ai-image-switcher-links-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    .ai-image-switcher-images-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-image-switcher-image-wrapper-{{ ai_gen_id }} {
      aspect-ratio: {{ block.settings.image_aspect_ratio_mobile }};
    }

    .ai-image-switcher-link-{{ ai_gen_id }} {
      font-size: {{ block.settings.link_font_size_mobile }}px;
      flex-shrink: 0;
    }
  }
{% endstyle %}

<image-switcher-{{ ai_gen_id }}
  class="ai-image-switcher-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-image-switcher-wrapper-{{ ai_gen_id }}">
    <div class="ai-image-switcher-container-{{ ai_gen_id }}">
      <div class="ai-image-switcher-links-{{ ai_gen_id }}">
        {% for i in (1..8) %}
          {% liquid
            assign link_text_key = 'link_' | append: i | append: '_text'
            assign link_url_key = 'link_' | append: i | append: '_url'
            assign image_key = 'image_' | append: i
            assign enabled_key = 'link_' | append: i | append: '_enabled'

            assign link_text = block.settings[link_text_key]
            assign link_url = block.settings[link_url_key]
            assign image = block.settings[image_key]
            assign enabled = block.settings[enabled_key]
          %}

          {% if enabled and link_text != blank %}
            <a
              href="{{ link_url }}"
              class="ai-image-switcher-link-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
              data-image-index="{{ i }}"
            >
              {{ link_text }}
            </a>
          {% endif %}
        {% endfor %}
      </div>

      <div class="ai-image-switcher-images-{{ ai_gen_id }}">
        <div class="ai-image-switcher-image-wrapper-{{ ai_gen_id }}">
          {% assign has_images = false %}
          {% for i in (1..8) %}
            {% liquid
              assign image_key = 'image_' | append: i
              assign enabled_key = 'link_' | append: i | append: '_enabled'
              assign image = block.settings[image_key]
              assign enabled = block.settings[enabled_key]
            %}

            {% if enabled and image != blank %}
              {% assign has_images = true %}
              <img
                src="{{ image | image_url: width: 1200 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
                class="ai-image-switcher-image-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
                data-image-index="{{ i }}"
              >
            {% endif %}
          {% endfor %}

          {% unless has_images %}
            <div class="ai-image-switcher-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endunless %}
        </div>
      </div>
    </div>
  </div>
</image-switcher-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageSwitcher{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.links = this.querySelectorAll('.ai-image-switcher-link-{{ ai_gen_id }}');
        this.images = this.querySelectorAll('.ai-image-switcher-image-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.links.forEach((link) => {
          link.addEventListener('click', (event) => {
            event.preventDefault();
            const imageIndex = link.getAttribute('data-image-index');
            this.switchImage(imageIndex);
            this.setActiveLink(link);
          });
        });
      }

      switchImage(index) {
        this.images.forEach((image) => {
          if (image.getAttribute('data-image-index') === index) {
            image.classList.add('active');
          } else {
            image.classList.remove('active');
          }
        });
      }

      setActiveLink(activeLink) {
        this.links.forEach((link) => {
          link.classList.remove('active');
        });
        activeLink.classList.add('active');
      }
    }

    customElements.define('image-switcher-{{ ai_gen_id }}', ImageSwitcher{{ ai_gen_id }});
  })();
</script>

