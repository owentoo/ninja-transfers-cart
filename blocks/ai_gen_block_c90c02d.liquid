{% doc %}
  @prompt
    Top Content Block
    
    H1 heading
    Paragraph text
    Alignment setting: left / center / right
    Max-width setting for the text container
    Padding and margin controls (top, bottom, sides)
    Below: 4 Responsive Media Blocks
    
    Grid Layout:
    
    4 columns on desktop
    2 columns on tablet and mobile
    Max-width container with padding/margin controls
    Overflow hidden on section and block containers to prevent layout breaking
    Each Block Includes:
    
    Background image (editable)
    Customizable gradient overlay:
    Enable/disable toggle
    Direction: top, bottom, left, right, diagonal
    Start color & end color
    Opacity slider (0–100%)
    H3 heading only, placed over the gradient
    Text alignment control inside the block: top-left, top-center, center, bottom-right, etc.
    On Hover Effects
    
    The entire block scales up by 10% (transform: scale(1.1))
    A background video fades in and plays (autoplay, muted, looped)
    Replaces or overlays the background image
    Keeps image aspect ratio and fills the block
    Text color changes on hover (customizable via setting)
    Text shadow appears on hover (adjustable opacity and blur)
    Optional blur effect on image/video background under text (toggle in settings)
    Smooth transitions for all effects (transition: all 0.3s ease-in-out)
    Theme Editor Customization Settings
    Per Block (x4):
    
    Background image upload
    Video upload or video URL (MP4 or external)
    H3 heading text
    Text alignment dropdown
    Gradient overlay settings:
    Enable/disable
    Direction
    Start color / End color
    Opacity
    Hover text color picker
    Hover text shadow toggle
    Background blur toggle (beneath text only)
    Global Layout Controls:
    
    Section width: full-width or contained
    Responsive grid: 4/2/1 layout
    Padding and margin for section and blocks
    Grid gap spacing (row/column), try again and the blocks can grow outside the max width, also gradiants can be controlled universally, make the videos able to be pulled from cms and give each block a height option. and a section bg color option, on hover add para text in blocks, heading in block goes away on hover, hide headings on block on hover and give the para text alignment options

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-content-media-block-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: {{ block.settings.margin_top }}px auto {{ block.settings.margin_bottom }}px;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_sides }}px {{ block.settings.padding_bottom }}px;
    overflow: hidden;
    background-color: {{ block.settings.section_bg_color }};
  }

  .ai-content-media-block__top-{{ ai_gen_id }} {
    max-width: {{ block.settings.text_max_width }}px;
    margin: 0 auto;
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.grid_gap }}px;
  }

  .ai-content-media-block__heading-{{ ai_gen_id }} {
    margin-top: 0;
    margin-bottom: 20px;
    font-size: 2.5rem;
  }

  .ai-content-media-block__paragraph-{{ ai_gen_id }} {
    font-size: 1.1rem;
    line-height: 1.6;
  }

  .ai-content-media-block__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    width: 100%;
    {% if block.settings.allow_overflow %}
      max-width: 100vw;
      margin-left: calc((100vw - 100%) / -2);
      margin-right: calc((100vw - 100%) / -2);
      padding-left: calc((100vw - 100%) / 2);
      padding-right: calc((100vw - 100%) / 2);
    {% endif %}
  }

  .ai-content-media-block__item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    transition: transform 0.3s ease-in-out;
  }

  .ai-content-media-block__item-{{ ai_gen_id }}:hover {
    transform: scale(1.1);
    z-index: 1;
  }

  .ai-content-media-block__bg-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: filter 0.3s ease-in-out;
  }

  .ai-content-media-block__bg-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
  }

  .ai-content-media-block__bg-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-content-media-block__video-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.3s ease-in-out;
  }

  .ai-content-media-block__item-{{ ai_gen_id }}:hover .ai-content-media-block__video-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-content-media-block__gradient-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    transition: opacity 0.3s ease-in-out;
  }

  .ai-content-media-block__content-{{ ai_gen_id }} {
    position: absolute;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    padding: 20px;
    box-sizing: border-box;
    transition: color 0.3s ease-in-out, text-shadow 0.3s ease-in-out;
  }

  .ai-content-media-block__title-{{ ai_gen_id }} {
    margin: 0 0 10px 0;
    font-size: 1.5rem;
    z-index: 2;
    transition: all 0.3s ease-in-out;
    opacity: 1;
  }

  .ai-content-media-block__item-{{ ai_gen_id }}:hover .ai-content-media-block__title-{{ ai_gen_id }} {
    opacity: 0;
    transform: translateY(-10px);
  }

  .ai-content-media-block__description-{{ ai_gen_id }} {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.4;
    z-index: 2;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.3s ease-in-out;
    max-height: 0;
    overflow: hidden;
  }

  .ai-content-media-block__item-{{ ai_gen_id }}:hover .ai-content-media-block__description-{{ ai_gen_id }} {
    opacity: 1;
    transform: translateY(0);
    max-height: 200px;
  }

  @media screen and (max-width: 990px) {
    .ai-content-media-block__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-content-media-block__heading-{{ ai_gen_id }} {
      font-size: 2rem;
    }
    .ai-content-media-block__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
    .ai-content-media-block__title-{{ ai_gen_id }} {
      font-size: 1.2rem;
    }
    .ai-content-media-block__description-{{ ai_gen_id }} {
      font-size: 0.8rem;
    }
  }
{% endstyle %}

<div class="ai-content-media-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-content-media-block__top-{{ ai_gen_id }}">
    <h1 class="ai-content-media-block__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h1>
    <div class="ai-content-media-block__paragraph-{{ ai_gen_id }}">{{ block.settings.paragraph }}</div>
  </div>

  <div class="ai-content-media-block__grid-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% assign image_key = 'image_' | append: i %}
      {% assign video_key = 'video_' | append: i %}
      {% assign title_key = 'title_' | append: i %}
      {% assign description_key = 'description_' | append: i %}
      {% assign text_position_key = 'text_position_' | append: i %}
      {% assign description_alignment_key = 'description_alignment_' | append: i %}
      {% assign hover_text_color_key = 'hover_text_color_' | append: i %}
      {% assign hover_text_shadow_key = 'hover_text_shadow_' | append: i %}
      {% assign blur_effect_key = 'blur_effect_' | append: i %}
      {% assign height_key = 'height_' | append: i %}
      
      {% assign image = block.settings[image_key] %}
      {% assign video = block.settings[video_key] %}
      {% assign title = block.settings[title_key] %}
      {% assign description = block.settings[description_key] %}
      {% assign text_position = block.settings[text_position_key] %}
      {% assign description_alignment = block.settings[description_alignment_key] %}
      {% assign hover_text_color = block.settings[hover_text_color_key] %}
      {% assign hover_text_shadow = block.settings[hover_text_shadow_key] %}
      {% assign blur_effect = block.settings[blur_effect_key] %}
      {% assign height = block.settings[height_key] %}
      
      {% case text_position %}
        {% when 'top-left' %}
          {% assign align_items = 'flex-start' %}
          {% assign justify_content = 'flex-start' %}
        {% when 'top-center' %}
          {% assign align_items = 'flex-start' %}
          {% assign justify_content = 'center' %}
        {% when 'top-right' %}
          {% assign align_items = 'flex-start' %}
          {% assign justify_content = 'flex-end' %}
        {% when 'center-left' %}
          {% assign align_items = 'center' %}
          {% assign justify_content = 'flex-start' %}
        {% when 'center' %}
          {% assign align_items = 'center' %}
          {% assign justify_content = 'center' %}
        {% when 'center-right' %}
          {% assign align_items = 'center' %}
          {% assign justify_content = 'flex-end' %}
        {% when 'bottom-left' %}
          {% assign align_items = 'flex-end' %}
          {% assign justify_content = 'flex-start' %}
        {% when 'bottom-center' %}
          {% assign align_items = 'flex-end' %}
          {% assign justify_content = 'center' %}
        {% when 'bottom-right' %}
          {% assign align_items = 'flex-end' %}
          {% assign justify_content = 'flex-end' %}
      {% endcase %}
      
      {% case block.settings.gradient_direction %}
        {% when 'top' %}
          {% assign gradient = 'linear-gradient(to bottom, ' | append: block.settings.gradient_start | append: ', ' | append: block.settings.gradient_end | append: ')' %}
        {% when 'bottom' %}
          {% assign gradient = 'linear-gradient(to top, ' | append: block.settings.gradient_start | append: ', ' | append: block.settings.gradient_end | append: ')' %}
        {% when 'left' %}
          {% assign gradient = 'linear-gradient(to right, ' | append: block.settings.gradient_start | append: ', ' | append: block.settings.gradient_end | append: ')' %}
        {% when 'right' %}
          {% assign gradient = 'linear-gradient(to left, ' | append: block.settings.gradient_start | append: ', ' | append: block.settings.gradient_end | append: ')' %}
        {% when 'diagonal' %}
          {% assign gradient = 'linear-gradient(to bottom right, ' | append: block.settings.gradient_start | append: ', ' | append: block.settings.gradient_end | append: ')' %}
      {% endcase %}
      
      {% style %}
        .ai-content-media-block__item-{{ ai_gen_id }}-{{ i }} {
          height: {{ height }}px;
        }
        
        .ai-content-media-block__item-{{ ai_gen_id }}-{{ i }} .ai-content-media-block__content-{{ ai_gen_id }} {
          align-items: {{ align_items }};
          justify-content: {{ justify_content }};
          color: {{ block.settings.text_color }};
        }
        
        .ai-content-media-block__item-{{ ai_gen_id }}-{{ i }} .ai-content-media-block__description-{{ ai_gen_id }} {
          text-align: {{ description_alignment }};
        }
        
        .ai-content-media-block__item-{{ ai_gen_id }}-{{ i }}:hover .ai-content-media-block__content-{{ ai_gen_id }} {
          color: {{ hover_text_color }};
          {% if hover_text_shadow %}
            text-shadow: 0 0 10px rgba(0, 0, 0, 0.5);
          {% endif %}
        }
        
        .ai-content-media-block__item-{{ ai_gen_id }}-{{ i }} .ai-content-media-block__gradient-{{ ai_gen_id }} {
          background: {{ gradient }};
          opacity: {{ block.settings.gradient_opacity | divided_by: 100.0 }};
        }
        
        {% if blur_effect %}
        .ai-content-media-block__item-{{ ai_gen_id }}-{{ i }}:hover .ai-content-media-block__bg-{{ ai_gen_id }},
        .ai-content-media-block__item-{{ ai_gen_id }}-{{ i }}:hover .ai-content-media-block__video-{{ ai_gen_id }} {
          filter: blur(5px);
        }
        {% endif %}
      {% endstyle %}
      
      <div class="ai-content-media-block__item-{{ ai_gen_id }} ai-content-media-block__item-{{ ai_gen_id }}-{{ i }}">
        {% if image %}
          <img 
            src="{{ image | image_url: width: 800 }}"
            loading="lazy"
            alt="{{ image.alt | escape }}"
            width="{{ image.width }}"
            height="{{ image.height }}"
            class="ai-content-media-block__bg-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-content-media-block__bg-placeholder-{{ ai_gen_id }}">
            {{'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
        
        {% if video != blank %}
          {% if video.sources %}
            <video 
              class="ai-content-media-block__video-{{ ai_gen_id }}" 
              autoplay 
              muted 
              loop 
              playsinline
            >
              {% for source in video.sources %}
                <source src="{{ source.url }}" type="{{ source.mime_type }}">
              {% endfor %}
            </video>
          {% endif %}
        {% endif %}
        
        {% if block.settings.gradient_enable %}
          <div class="ai-content-media-block__gradient-{{ ai_gen_id }}"></div>
        {% endif %}
        
        <div class="ai-content-media-block__content-{{ ai_gen_id }}">
          <h3 class="ai-content-media-block__title-{{ ai_gen_id }}">{{ title }}</h3>
          {% if description != blank %}
            <p class="ai-content-media-block__description-{{ ai_gen_id }}">{{ description }}</p>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>

<script>
  (function() {
    document.querySelectorAll('.ai-content-media-block__item-{{ ai_gen_id }}').forEach(item => {
      const video = item.querySelector('video');
      
      if (video) {
        item.addEventListener('mouseenter', () => {
          video.play();
        });
        
        item.addEventListener('mouseleave', () => {
          setTimeout(() => {
            if (!item.matches(':hover')) {
              video.pause();
              video.currentTime = 0;
            }
          }, 300);
        });
      }
    });
  })();
</script>

