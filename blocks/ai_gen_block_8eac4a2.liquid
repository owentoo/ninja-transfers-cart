{% doc %}
  @prompt
    i need a section with horizonla space options from 10 - 200
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-horizontal-spacer-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.spacing }}px;
  }
{% endstyle %}

<div
  class="ai-horizontal-spacer-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
></div>

{% schema %}
{
  "name": "Horizontal spacer",
  "settings": [
    {
      "type": "range",
      "id": "spacing",
      "min": 10,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Spacing",
      "default": 50
    }
  ],
  "presets": [
    {
      "name": "Horizontal spacer"
    }
  ]
}
{% endschema %}
