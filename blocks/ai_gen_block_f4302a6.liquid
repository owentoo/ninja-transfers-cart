{% doc %}
  @prompt
    i need a cta section with an h2 and text inside and div with bg image , section needs a max width with horzontal padding for desktop and mobile , i need button under the text. content needs alignment , horizontal padding needs to apply within max width , all text needs desktop and mobile ize options , cta doesn't need Border, need space between content for desktop and mobile , need padding options within div for content from edge for desktop and mobile  , need Minimum height for desktop and mobile 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-cta-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-cta-wrapper-{{ ai_gen_id }} {
    max-width: {{ block.settings.section_max_width }}px;
    margin: 0 auto;
    width: 100%;
    padding: 0 {{ block.settings.section_padding_desktop }}px;
  }

  .ai-cta-container-{{ ai_gen_id }} {
    position: relative;
    background-image: url('{{ block.settings.background_image | image_url: width: 2000 }}');
    background-size: cover;
    background-position: {{ block.settings.image_position }};
    background-repeat: no-repeat;
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.container_padding_top_desktop }}px {{ block.settings.container_padding_horizontal_desktop }}px {{ block.settings.container_padding_bottom_desktop }}px;
    min-height: {{ block.settings.min_height_desktop }}px;
    display: flex;
    flex-direction: column;
    justify-content: {{ block.settings.content_alignment_vertical }};
    align-items: {{ block.settings.content_alignment_horizontal }};
    overflow: hidden;
  }

  .ai-cta-container-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 1;
  }

  .ai-cta-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    max-width: {{ block.settings.content_max_width }}px;
    text-align: {{ block.settings.text_alignment }};
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_gap_desktop }}px;
  }

  .ai-cta-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size_desktop }}px;
    margin: 0;
    line-height: 1.2;
  }

  .ai-cta-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size_desktop }}px;
    line-height: 1.5;
    margin: 0;
  }

  .ai-cta-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size_desktop }}px;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    {% if block.settings.text_alignment == 'center' %}
      align-self: center;
    {% elsif block.settings.text_alignment == 'right' %}
      align-self: flex-end;
    {% else %}
      align-self: flex-start;
    {% endif %}
  }

  .ai-cta-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_background_hover }};
    color: {{ block.settings.button_text_color_hover }};
  }

  .ai-cta-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    min-height: {{ block.settings.min_height_desktop }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.border_radius }}px;
    position: relative;
  }

  .ai-cta-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-cta-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {

  .ai-cta-container-{{ ai_gen_id }} {
    {% if block.settings.background_image_mobile %}
      background-image: url('{{ block.settings.background_image_mobile | image_url: width: 1000 }}');
    {% endif %}
  }
 


    .ai-cta-wrapper-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.section_padding_mobile }}px;
    }

    .ai-cta-container-{{ ai_gen_id }} {
      padding: {{ block.settings.container_padding_top_mobile }}px {{ block.settings.container_padding_horizontal_mobile }}px {{ block.settings.container_padding_bottom_mobile }}px;
      min-height: {{ block.settings.min_height_mobile }}px;
    }

    .ai-cta-content-{{ ai_gen_id }} {
      gap: {{ block.settings.content_gap_mobile }}px;
    }

    .ai-cta-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-cta-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
    }

    .ai-cta-button-{{ ai_gen_id }} {
      padding: {{ block.settings.button_padding_vertical | times: 0.8 }}px {{ block.settings.button_padding_horizontal | times: 0.8 }}px;
      font-size: {{ block.settings.button_text_size_mobile }}px;
    }

    .ai-cta-placeholder-{{ ai_gen_id }} {
      min-height: {{ block.settings.min_height_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-cta-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-cta-wrapper-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <div class="ai-cta-container-{{ ai_gen_id }}">
        <div class="ai-cta-content-{{ ai_gen_id }}">
          {% if block.settings.heading != blank %}
            <h2 class="ai-cta-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
          {% endif %}
          {% if block.settings.text != blank %}
            <div class="ai-cta-text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
          {% endif %}
          {% if block.settings.button_text != blank %}
            <a href="{{ block.settings.button_link }}" class="ai-cta-button-{{ ai_gen_id }}">
              {{ block.settings.button_text }}
            </a>
          {% endif %}
        </div>
      </div>
    {% else %}
      <div class="ai-cta-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-cta-empty-state-{{ ai_gen_id }}">
          Next, add a background image
        </div>
      </div>
    {% endif %}
  </div>
</div>

