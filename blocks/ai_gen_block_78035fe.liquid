{% doc %}
  @prompt
    Build a new Shopify theme section: “DTF Hero Split (BG Image + Right Content)”.
    
    Layout / structure:
    - Full-width section with a background image that covers the entire section (center/cover, no repeat).
    - Inside the full-width background, create an inner container that uses the theme’s native max width (use the theme’s page-width / container class or equivalent).
    - Use a 2-column layout inside the max-width container:
      - Left column is empty (acts as spacing so content sits on the right).
      - Right column contains all text/buttons (content column width should be adjustable between 40%–60% on desktop).
    - On mobile: stack into a single column with content centered/left-aligned and full width, with comfortable padding.
    
    Content (right column):
    - Eyebrow/H1 (large, bold):
      “DTF Transfers Trusted by 225,000+ Side Hustlers”
      - Make “Side Hustlers” a different color (setting-controlled highlight color).
    - Supporting paragraph (medium size):
      “Print ANY Design on ANY Product, Material or Color with 100+ Wash Durability. Make More For Less.”
    - Feature bullets row (with check icons):
      “100% Satisfaction”
      “No Minimums or Art Fees”
      “Free & Fast Delivery”
    - Two CTA buttons in a row:
      Primary button: “Order Transfers by Size” (link setting)
      Secondary button: “Build a Gang Sheet” (link setting)
      - Buttons should be large, pill/rounded, and stack vertically on small screens.
    - Trust / proof row beneath CTAs (2 items):
      Left: “4.9 ★★★★★” and subtext “Based on 35,000+ Reviews”
      Right: “10 Seconds” and subtext “For ScreenPrint-Like Quality”
      - Use simple icons: star for rating, timer for 10 seconds.
    
    Styling / UX:
    - Add a dark overlay on top of the background image to ensure readability (overlay opacity adjustable via setting).
    - Text color defaults to white.
    - Spacing: generous top/bottom padding, with settings for padding.
    - Ensure everything stays within the theme’s native max width; only the background image should be full-bleed.
    
    Section settings (expose these in, Content needs left or right alignment option within section, should be full width on mobile, Trust proof should be two columns, in each column there should be an image below that large text with optional stars to the right of it and below that small text , trust item images need size options, stars need size option, trust items should be left aligned with space between  , all text needs weight option, give me an option to add my own feature check icon , change Content column width to a max width. on mobile trust items should be side by side. need horizontal padding options between content, add one more button that only shows on mobile all desktop buttons use the same styling only mobile button has different style , Primary  and secondary button should share the same style, colors, weight, so on 
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-dtf-hero-split-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    background-image: url('{{ block.settings.background_image | image_url: width: 2400 }}');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    display: block;
  }

  .ai-dtf-hero-split-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, {{ block.settings.overlay_opacity }});
    z-index: 1;
  }

  .ai-dtf-hero-split-container-{{ ai_gen_id }} {
    max-width: {{ settings.theme_max_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.horizontal_padding }}px;
    position: relative;
    z-index: 2;
  }

  .ai-dtf-hero-split-grid-{{ ai_gen_id }} {
    display: flex;
    {% if block.settings.content_alignment == 'left' %}
      justify-content: flex-start;
    {% else %}
      justify-content: flex-end;
    {% endif %}
  }

  .ai-dtf-hero-split-content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    max-width: {{ block.settings.content_max_width }}px;
    width: 100%;
  }

  .ai-dtf-hero-split-eyebrow-{{ ai_gen_id }} {
    font-family: {{ settings.headings_font_primary.family }}, {{ settings.headings_font_primary.fallback_families }};
    font-weight: {{ block.settings.heading_weight }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.1;
    margin: 0 0 20px;
  }

  .ai-dtf-hero-split-highlight-{{ ai_gen_id }} {
    color: {{ block.settings.highlight_color }};
  }

  .ai-dtf-hero-split-paragraph-{{ ai_gen_id }} {
    font-family: {{ settings.body_font_primary.family }}, {{ settings.body_font_primary.fallback_families }};
    font-weight: {{ block.settings.paragraph_weight }};
    font-size: {{ block.settings.paragraph_size }}px;
    line-height: 1.5;
    margin: 0 0 24px;
  }

  .ai-dtf-hero-split-features-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 32px;
  }

  .ai-dtf-hero-split-feature-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: {{ block.settings.feature_size }}px;
    font-weight: {{ block.settings.feature_weight }};
  }

  .ai-dtf-hero-split-feature-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .ai-dtf-hero-split-feature-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.feature_icon_color }};
  }

  .ai-dtf-hero-split-feature-icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-dtf-hero-split-buttons-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }

  .ai-dtf-hero-split-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 32px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: {{ block.settings.button_weight }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .ai-dtf-hero-split-button-primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.primary_button_bg }};
    color: {{ block.settings.primary_button_color }};
    border: 2px solid {{ block.settings.primary_button_border }};
  }

  .ai-dtf-hero-split-button-primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.primary_button_bg_hover }};
    color: {{ block.settings.primary_button_color_hover }};
    border-color: {{ block.settings.primary_button_border_hover }};
  }

  .ai-dtf-hero-split-button-secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.primary_button_bg }};
    color: {{ block.settings.primary_button_color }};
    border: 2px solid {{ block.settings.primary_button_border }};
  }

  .ai-dtf-hero-split-button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.primary_button_bg_hover }};
    color: {{ block.settings.primary_button_color_hover }};
    border-color: {{ block.settings.primary_button_border_hover }};
  }

  .ai-dtf-hero-split-button-mobile-{{ ai_gen_id }} {
    display: none;
    background-color: {{ block.settings.mobile_button_bg }};
    color: {{ block.settings.mobile_button_color }};
    border: 2px solid {{ block.settings.mobile_button_border }};
    font-size: {{ block.settings.mobile_button_text_size }}px;
    font-weight: {{ block.settings.mobile_button_weight }};
    border-radius: {{ block.settings.mobile_button_border_radius }}px;
  }

  .ai-dtf-hero-split-button-mobile-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.mobile_button_bg_hover }};
    color: {{ block.settings.mobile_button_color_hover }};
    border-color: {{ block.settings.mobile_button_border_hover }};
  }

  .ai-dtf-hero-split-trust-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.trust_gap }}px;
    align-items: flex-start;
  }

  .ai-dtf-hero-split-trust-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: flex-start;
  }

  .ai-dtf-hero-split-trust-image-{{ ai_gen_id }} {
    width: {{ block.settings.trust_image_size }}px;
    height: auto;
    flex-shrink: 0;
  }

  .ai-dtf-hero-split-trust-image-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-dtf-hero-split-trust-main-row-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-dtf-hero-split-trust-main-{{ ai_gen_id }} {
    font-size: {{ block.settings.trust_main_size }}px;
    font-weight: {{ block.settings.trust_main_weight }};
    line-height: 1.2;
  }

  .ai-dtf-hero-split-trust-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 2px;
    color: {{ block.settings.trust_star_color }};
    font-size: {{ block.settings.trust_star_size }}px;
    line-height: 1;
  }

  .ai-dtf-hero-split-trust-sub-{{ ai_gen_id }} {
    font-size: {{ block.settings.trust_sub_size }}px;
    font-weight: {{ block.settings.trust_sub_weight }};
    opacity: 0.9;
    line-height: 1.3;
  }

  @media screen and (max-width: 989px) {
    .ai-dtf-hero-split-grid-{{ ai_gen_id }} {
      justify-content: center;
    }

    .ai-dtf-hero-split-content-{{ ai_gen_id }} {
      max-width: 100%;
    }

    .ai-dtf-hero-split-eyebrow-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-dtf-hero-split-paragraph-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.paragraph_size }}px * 0.9);
    }

    .ai-dtf-hero-split-buttons-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-dtf-hero-split-button-{{ ai_gen_id }} {
      width: 100%;
      text-align: center;
    }

    .ai-dtf-hero-split-button-mobile-{{ ai_gen_id }} {
      display: inline-flex;
      width: 100%;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-dtf-hero-split-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.6 }}px 0 {{ block.settings.padding_bottom | times: 0.6 }}px;
    }

    .ai-dtf-hero-split-container-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.horizontal_padding | times: 0.5 }}px;
    }

    .ai-dtf-hero-split-trust-{{ ai_gen_id }} {
      gap: {{ block.settings.trust_gap | times: 0.5 }}px;
    }

    .ai-dtf-hero-split-trust-image-{{ ai_gen_id }} {
      width: {{ block.settings.trust_image_size | times: 0.8 }}px;
    }

    .ai-dtf-hero-split-trust-main-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.trust_main_size }}px * 0.85);
    }

    .ai-dtf-hero-split-trust-sub-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.trust_sub_size }}px * 0.9);
    }
  }
{% endstyle %}

<div class="ai-dtf-hero-split-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-dtf-hero-split-container-{{ ai_gen_id }}">
    <div class="ai-dtf-hero-split-grid-{{ ai_gen_id }}">
      <div class="ai-dtf-hero-split-content-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h1 class="ai-dtf-hero-split-eyebrow-{{ ai_gen_id }}">
            {{ block.settings.heading | replace: block.settings.highlight_text, '<span class="ai-dtf-hero-split-highlight-' | append: ai_gen_id | append: '">' | append: block.settings.highlight_text | append: '</span>' }}
          </h1>
        {% endif %}

        {% if block.settings.paragraph != blank %}
          <p class="ai-dtf-hero-split-paragraph-{{ ai_gen_id }}">
            {{ block.settings.paragraph }}
          </p>
        {% endif %}

        {% if block.settings.show_features %}
          <div class="ai-dtf-hero-split-features-{{ ai_gen_id }}">
            {% if block.settings.feature_1 != blank %}
              <div class="ai-dtf-hero-split-feature-{{ ai_gen_id }}">
                <span class="ai-dtf-hero-split-feature-icon-{{ ai_gen_id }}">
                  {% if block.settings.feature_icon %}
                    <img
                      src="{{ block.settings.feature_icon | image_url: width: 40 }}"
                      alt="Check icon"
                      loading="lazy"
                      width="20"
                      height="20"
                    >
                  {% else %}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                      <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                    </svg>
                  {% endif %}
                </span>
                <span>{{ block.settings.feature_1 }}</span>
              </div>
            {% endif %}

            {% if block.settings.feature_2 != blank %}
              <div class="ai-dtf-hero-split-feature-{{ ai_gen_id }}">
                <span class="ai-dtf-hero-split-feature-icon-{{ ai_gen_id }}">
                  {% if block.settings.feature_icon %}
                    <img
                      src="{{ block.settings.feature_icon | image_url: width: 40 }}"
                      alt="Check icon"
                      loading="lazy"
                      width="20"
                      height="20"
                    >
                  {% else %}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                      <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                    </svg>
                  {% endif %}
                </span>
                <span>{{ block.settings.feature_2 }}</span>
              </div>
            {% endif %}

            {% if block.settings.feature_3 != blank %}
              <div class="ai-dtf-hero-split-feature-{{ ai_gen_id }}">
                <span class="ai-dtf-hero-split-feature-icon-{{ ai_gen_id }}">
                  {% if block.settings.feature_icon %}
                    <img
                      src="{{ block.settings.feature_icon | image_url: width: 40 }}"
                      alt="Check icon"
                      loading="lazy"
                      width="20"
                      height="20"
                    >
                  {% else %}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                      <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                    </svg>
                  {% endif %}
                </span>
                <span>{{ block.settings.feature_3 }}</span>
              </div>
            {% endif %}
          </div>
        {% endif %}

        <div class="ai-dtf-hero-split-buttons-{{ ai_gen_id }}">
          {% if block.settings.primary_button_label != blank %}
            <a
              href="{{ block.settings.primary_button_link }}"
              class="ai-dtf-hero-split-button-{{ ai_gen_id }} ai-dtf-hero-split-button-primary-{{ ai_gen_id }}"
            >
              {{ block.settings.primary_button_label }}
            </a>
          {% endif %}

          {% if block.settings.secondary_button_label != blank %}
            <a
              href="{{ block.settings.secondary_button_link }}"
              class="ai-dtf-hero-split-button-{{ ai_gen_id }} ai-dtf-hero-split-button-secondary-{{ ai_gen_id }}"
            >
              {{ block.settings.secondary_button_label }}
            </a>
          {% endif %}

          {% if block.settings.mobile_button_label != blank %}
            <a
              href="{{ block.settings.mobile_button_link }}"
              class="ai-dtf-hero-split-button-{{ ai_gen_id }} ai-dtf-hero-split-button-mobile-{{ ai_gen_id }}"
            >
              {{ block.settings.mobile_button_label }}
            </a>
          {% endif %}
        </div>

        {% if block.settings.show_trust %}
          <div class="ai-dtf-hero-split-trust-{{ ai_gen_id }}">
            <div class="ai-dtf-hero-split-trust-item-{{ ai_gen_id }}">
              {% if block.settings.trust_1_image %}
                <div class="ai-dtf-hero-split-trust-image-{{ ai_gen_id }}">
                  <img
                    src="{{ block.settings.trust_1_image | image_url: width: 300 }}"
                    alt="{{ block.settings.trust_1_image.alt | escape }}"
                    loading="lazy"
                    width="{{ block.settings.trust_image_size }}"
                    height="auto"
                  >
                </div>
              {% endif %}
              <div class="ai-dtf-hero-split-trust-main-row-{{ ai_gen_id }}">
                <div class="ai-dtf-hero-split-trust-main-{{ ai_gen_id }}">{{ block.settings.trust_1_main }}</div>
                {% if block.settings.trust_1_show_stars %}
                  <div class="ai-dtf-hero-split-trust-stars-{{ ai_gen_id }}">★★★★★</div>
                {% endif %}
              </div>
              <div class="ai-dtf-hero-split-trust-sub-{{ ai_gen_id }}">{{ block.settings.trust_1_sub }}</div>
            </div>

            <div class="ai-dtf-hero-split-trust-item-{{ ai_gen_id }}">
              {% if block.settings.trust_2_image %}
                <div class="ai-dtf-hero-split-trust-image-{{ ai_gen_id }}">
                  <img
                    src="{{ block.settings.trust_2_image | image_url: width: 300 }}"
                    alt="{{ block.settings.trust_2_image.alt | escape }}"
                    loading="lazy"
                    width="{{ block.settings.trust_image_size }}"
                    height="auto"
                  >
                </div>
              {% endif %}
              <div class="ai-dtf-hero-split-trust-main-row-{{ ai_gen_id }}">
                <div class="ai-dtf-hero-split-trust-main-{{ ai_gen_id }}">{{ block.settings.trust_2_main }}</div>
                {% if block.settings.trust_2_show_stars %}
                  <div class="ai-dtf-hero-split-trust-stars-{{ ai_gen_id }}">★★★★★</div>
                {% endif %}
              </div>
              <div class="ai-dtf-hero-split-trust-sub-{{ ai_gen_id }}">{{ block.settings.trust_2_sub }}</div>
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "DTF Hero Split",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "Overlay opacity",
