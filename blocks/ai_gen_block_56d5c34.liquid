{% doc %}
  @prompt
    Create a customizable section with adjustable height and width that displays icon images with small subtext underneath. The section should support 1-9 icons in a row with center alignment as default. Include settings for section dimensions, number of icons per row, alignment options, icon size, text styling, and spacing controls. Make it responsive and flexible for various use cases like features, services, or benefits showcase., I want to be able to make the icons really close together or far apart as needed. default to 3 icons, i need separate settings for mobile view, desktop alignment isn't working

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-icon-section-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.section_width }}px;
    height: {{ block.settings.section_height }}px;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-icon-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.icons_per_row }}, 1fr);
    gap: {{ block.settings.icon_spacing }}px;
    width: 100%;
    max-width: 100%;
    justify-content: {{ block.settings.alignment }};
  }

  .ai-icon-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: {{ block.settings.text_spacing }}px;
    justify-self: {{ block.settings.alignment }};
  }

  .ai-icon-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.icon_background }};
    border-radius: {{ block.settings.icon_border_radius }}px;
    padding: {{ block.settings.icon_padding }}px;
  }

  .ai-icon-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-icon-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.5;
  }

  .ai-icon-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: {{ block.settings.text_weight }};
    line-height: 1.3;
    margin: 0;
  }

  {% if block.settings.alignment == 'flex-start' %}
    .ai-icon-grid-{{ ai_gen_id }} {
      justify-items: start;
    }
  {% elsif block.settings.alignment == 'flex-end' %}
    .ai-icon-grid-{{ ai_gen_id }} {
      justify-items: end;
    }
  {% else %}
    .ai-icon-grid-{{ ai_gen_id }} {
      justify-items: center;
    }
  {% endif %}

  @media screen and (max-width: 768px) {
    .ai-icon-section-{{ ai_gen_id }} {
      max-width: {{ block.settings.section_width_mobile }}px;
      height: {{ block.settings.section_height_mobile }}px;
      padding: {{ block.settings.section_padding_mobile }}px;
    }

    .ai-icon-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.icons_per_row_mobile }}, 1fr);
      gap: {{ block.settings.icon_spacing_mobile }}px;
    }

    .ai-icon-item-{{ ai_gen_id }} {
      gap: {{ block.settings.text_spacing_mobile }}px;
    }

    .ai-icon-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size_mobile }}px;
      height: {{ block.settings.icon_size_mobile }}px;
      background-color: {{ block.settings.icon_background_mobile }};
      border-radius: {{ block.settings.icon_border_radius_mobile }}px;
      padding: {{ block.settings.icon_padding_mobile }}px;
    }

    .ai-icon-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
      color: {{ block.settings.text_color_mobile }};
      font-weight: {{ block.settings.text_weight_mobile }};
    }

    {% if block.settings.alignment_mobile == 'flex-start' %}
      .ai-icon-grid-{{ ai_gen_id }} {
        justify-items: start;
      }
    {% elsif block.settings.alignment_mobile == 'flex-end' %}
      .ai-icon-grid-{{ ai_gen_id }} {
        justify-items: end;
      }
    {% else %}
      .ai-icon-grid-{{ ai_gen_id }} {
        justify-items: center;
      }
    {% endif %}
  }
{% endstyle %}

<div class="ai-icon-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-icon-grid-{{ ai_gen_id }}">
    {% for i in (1..9) %}
      {% assign icon_key = 'icon_' | append: i %}
      {% assign text_key = 'text_' | append: i %}
      {% assign icon = block.settings[icon_key] %}
      {% assign text = block.settings[text_key] %}
      {% if icon != blank or text != blank %}
        <div class="ai-icon-item-{{ ai_gen_id }}">
          <div class="ai-icon-wrapper-{{ ai_gen_id }}">
            {% if icon != blank %}
              <img
                src="{{ icon | image_url: width: 200 }}"
                alt="{{ text | escape }}"
                loading="lazy"
                width="{{ block.settings.icon_size }}"
                height="{{ block.settings.icon_size }}"
              >
            {% else %}
              <div class="ai-icon-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          {% if text != blank %}
            <p class="ai-icon-text-{{ ai_gen_id }}">{{ text }}</p>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

