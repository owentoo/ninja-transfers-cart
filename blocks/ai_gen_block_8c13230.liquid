{% doc %}
  @prompt
    Create a full-width homepage hero section for a DTF printing e-commerce brand with a dark, modern, high-contrast aesthetic.
    Layout
    Two-column layout on desktop
    Left column (text & CTAs)
    Right column (product visual)
    Vertically centered content
    Responsive: stack with image below text on mobile
    Background
    Dark charcoal to near-black gradient background
    Subtle vignette or soft glow behind the product image
    Clean, premium, high-trust look
    Headline (H1)
    Large, bold sans-serif typography
    White text with a bright green accent for emphasis
    Example structure:
    “DTF Transfers Trusted by
    225,000+ Side Hustlers”
    Subheadline
    Smaller, light-weight text below the headline
    Describes versatility, durability, and value
    Emphasize printing on any material/color and long-lasting quality
    Trust Bullets
    Horizontal row of short bullet points with checkmark icons
    Examples:
    100% Satisfaction
    No Minimums or Art Fees
    Free & Fast Delivery
    Primary CTAs
    Two rounded buttons side-by-side
    Primary button: bright blue
    Secondary button: outlined or lighter blue
    Button copy examples:
    “Order Transfers by Size”
    “Build a Gang Sheet”
    Social Proof
    Star rating (4.9 out of 5) with star icons
    “Based on 35,000+ reviews”
    Small circular customer avatars or icons next to rating
    Speed Badge
    Small callout below CTAs highlighting speed
    Example: “10 Seconds – For Screenprint-Like Quality”
    Right-Side Visual
    Photorealistic black t-shirt mockup angled slightly
    Vibrant, neon-style graphic printed on the shirt
    Semi-transparent DTF transfer film partially peeled back to reveal the print
    Soft colored glow (pink/blue/purple) behind the shirt
    Promotional Badge
    Bright green starburst or sticker overlapping the shirt
    Text: “New LOW Prices”
    Overall Style
    Premium, trustworthy, high-conversion ecommerce hero
    Clean spacing, strong hierarchy
    Designed to feel modern, fast, and creator-friendly, image needs to take up full height, get rid new low prices badge, and have image go under all text and buttons on mobile , Product visual needs to take up full height , Product visual need to take up sections full height 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-dtf-hero-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background: linear-gradient(135deg, {{ block.settings.bg_color_start }} 0%, {{ block.settings.bg_color_end }} 100%);
    position: relative;
    overflow: hidden;
    min-height: {{ block.settings.min_height }}px;
  }

  .ai-dtf-hero-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: stretch;
    min-height: {{ block.settings.min_height }}px;
  }

  .ai-dtf-hero-content-{{ ai_gen_id }} {
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .ai-dtf-hero-headline-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.1;
    color: {{ block.settings.heading_color }};
    margin: 0 0 20px;
  }

  .ai-dtf-hero-headline-{{ ai_gen_id }} .ai-dtf-hero-accent-{{ ai_gen_id }} {
    color: {{ block.settings.accent_color }};
    display: block;
  }

  .ai-dtf-hero-subheadline-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    line-height: 1.5;
    color: {{ block.settings.subheading_color }};
    margin: 0 0 30px;
    max-width: 540px;
  }

  .ai-dtf-hero-trust-bullets-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    margin: 0 0 32px;
    list-style: none;
    padding: 0;
  }

  .ai-dtf-hero-trust-bullet-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: {{ block.settings.bullet_size }}px;
    color: {{ block.settings.bullet_color }};
  }

  .ai-dtf-hero-trust-bullet-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    fill: {{ block.settings.accent_color }};
  }

  .ai-dtf-hero-cta-group-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }

  .ai-dtf-hero-btn-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 32px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    text-decoration: none;
    border-radius: {{ block.settings.button_radius }}px;
    transition: all 0.3s ease;
    border: 2px solid transparent;
    cursor: pointer;
  }

  .ai-dtf-hero-btn-primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.primary_button_bg }};
    color: {{ block.settings.primary_button_color }};
  }

  .ai-dtf-hero-btn-primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.primary_button_bg_hover }};
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(1, 154, 255, 0.3);
  }

  .ai-dtf-hero-btn-secondary-{{ ai_gen_id }} {
    background-color: transparent;
    color: {{ block.settings.secondary_button_color }};
    border-color: {{ block.settings.secondary_button_border }};
  }

  .ai-dtf-hero-btn-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.secondary_button_bg_hover }};
    border-color: {{ block.settings.secondary_button_border_hover }};
  }

  .ai-dtf-hero-social-proof-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .ai-dtf-hero-rating-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-dtf-hero-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 2px;
  }

  .ai-dtf-hero-stars-{{ ai_gen_id }} svg {
    width: 18px;
    height: 18px;
    fill: {{ block.settings.star_color }};
  }

  .ai-dtf-hero-rating-text-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.subheading_color }};
  }

  .ai-dtf-hero-avatars-{{ ai_gen_id }} {
    display: flex;
    margin-left: 8px;
  }

  .ai-dtf-hero-avatar-{{ ai_gen_id }} {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid {{ block.settings.bg_color_end }};
    margin-left: -8px;
    background-color: {{ block.settings.avatar_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 600;
    color: {{ block.settings.heading_color }};
  }

  .ai-dtf-hero-speed-badge-{{ ai_gen_id }} {
    display: inline-block;
    margin-top: 16px;
    padding: 8px 16px;
    background-color: {{ block.settings.speed_badge_bg }};
    color: {{ block.settings.speed_badge_color }};
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
  }

  .ai-dtf-hero-visual-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    height: 100%;
  }

  .ai-dtf-hero-glow-{{ ai_gen_id }} {
    position: absolute;
    width: 500px;
    height: 500px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: radial-gradient(circle, {{ block.settings.glow_color_1 }} 0%, {{ block.settings.glow_color_2 }} 30%, transparent 70%);
    opacity: {{ block.settings.glow_opacity }};
    filter: blur(60px);
    z-index: 0;
    pointer-events: none;
  }

  .ai-dtf-hero-product-image-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-dtf-hero-product-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .ai-dtf-hero-product-image-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  @media screen and (max-width: 989px) {
    .ai-dtf-hero-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 60px 24px;
    }

    .ai-dtf-hero-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.65 }}px;
    }

    .ai-dtf-hero-subheadline-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.9 }}px;
    }

    .ai-dtf-hero-trust-bullets-{{ ai_gen_id }} {
      gap: 16px;
    }

    .ai-dtf-hero-cta-group-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-dtf-hero-btn-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-dtf-hero-content-{{ ai_gen_id }} {
      order: 1;
    }

    .ai-dtf-hero-visual-{{ ai_gen_id }} {
      order: 2;
      min-height: 400px;
    }

    .ai-dtf-hero-glow-{{ ai_gen_id }} {
      width: 350px;
      height: 350px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-dtf-hero-container-{{ ai_gen_id }} {
      min-height: auto;
    }

    .ai-dtf-hero-social-proof-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }

    .ai-dtf-hero-visual-{{ ai_gen_id }} {
      min-height: 350px;
    }
  }
{% endstyle %}

<ai-dtf-hero-{{ ai_gen_id }} class="ai-dtf-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-dtf-hero-container-{{ ai_gen_id }}">
    <div class="ai-dtf-hero-content-{{ ai_gen_id }}">
      {% if block.settings.headline_line_1 != blank %}
        <h1 class="ai-dtf-hero-headline-{{ ai_gen_id }}">
          {{ block.settings.headline_line_1 }}
          <span class="ai-dtf-hero-accent-{{ ai_gen_id }}">{{ block.settings.headline_line_2 }}</span>
        </h1>
      {% endif %}

      {% if block.settings.subheadline != blank %}
        <p class="ai-dtf-hero-subheadline-{{ ai_gen_id }}">
          {{ block.settings.subheadline }}
        </p>
      {% endif %}

      <ul class="ai-dtf-hero-trust-bullets-{{ ai_gen_id }}">
        {% if block.settings.bullet_1 != blank %}
          <li class="ai-dtf-hero-trust-bullet-{{ ai_gen_id }}">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
            </svg>
            {{ block.settings.bullet_1 }}
          </li>
        {% endif %}
        {% if block.settings.bullet_2 != blank %}
          <li class="ai-dtf-hero-trust-bullet-{{ ai_gen_id }}">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
            </svg>
            {{ block.settings.bullet_2 }}
          </li>
        {% endif %}
        {% if block.settings.bullet_3 != blank %}
          <li class="ai-dtf-hero-trust-bullet-{{ ai_gen_id }}">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
            </svg>
            {{ block.settings.bullet_3 }}
          </li>
        {% endif %}
      </ul>

      <div class="ai-dtf-hero-cta-group-{{ ai_gen_id }}">
        {% if block.settings.primary_button_label != blank %}
          <a href="{{ block.settings.primary_button_link }}" class="ai-dtf-hero-btn-{{ ai_gen_id }} ai-dtf-hero-btn-primary-{{ ai_gen_id }}">
            {{ block.settings.primary_button_label }}
          </a>
        {% endif %}
        {% if block.settings.secondary_button_label != blank %}
          <a href="{{ block.settings.secondary_button_link }}" class="ai-dtf-hero-btn-{{ ai_gen_id }} ai-dtf-hero-btn-secondary-{{ ai_gen_id }}">
            {{ block.settings.secondary_button_label }}
          </a>
        {% endif %}
      </div>

      <div class="ai-dtf-hero-social-proof-{{ ai_gen_id }}">
        <div class="ai-dtf-hero-rating-{{ ai_gen_id }}">
          <div class="ai-dtf-hero-stars-{{ ai_gen_id }}">
            {% for i in (1..5) %}
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
              </svg>
            {% endfor %}
          </div>
          <span class="ai-dtf-hero-rating-text-{{ ai_gen_id }}">
            <strong>{{ block.settings.rating_score }}</strong> {{ block.settings.rating_text }}
          </span>
        </div>
        {% if block.settings.show_avatars %}
          <div class="ai-dtf-hero-avatars-{{ ai_gen_id }}">
            <div class="ai-dtf-hero-avatar-{{ ai_gen_id }}">👤</div>
            <div class="ai-dtf-hero-avatar-{{ ai_gen_id }}">👤</div>
            <div class="ai-dtf-hero-avatar-{{ ai_gen_id }}">👤</div>
          </div>
        {% endif %}
      </div>

      {% if block.settings.speed_badge_label != blank %}
        <div class="ai-dtf-hero-speed-badge-{{ ai_gen_id }}">
          {{ block.settings.speed_badge_label }}
        </div>
      {% endif %}
    </div>

    <div class="ai-dtf-hero-visual-{{ ai_gen_id }}">
      <div class="ai-dtf-hero-glow-{{ ai_gen_id }}"></div>
      
      {% if block.settings.product_image %}
        <div class="ai-dtf-hero-product-image-{{ ai_gen_id }}">
          <img
            src="{{ block.settings.product_image | image_url: width: 1200 }}"
            alt="{{ block.settings.product_image.alt | escape }}"
            loading="eager"
            width="{{ block.settings.product_image.width }}"
            height="{{ block.settings.product_image.height }}"
          >
        </div>
      {% else %}
        <div class="ai-dtf-hero-product-image-{{ ai_gen_id }}">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>
  </div>
</ai-dtf-hero-{{ ai_gen_id }}>

<script>
  (function() {
    class AiDtfHero{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.initParallax();
      }

      initParallax() {
        const glow = this.querySelector('.ai-dtf-hero-glow-{{ ai_gen_id }}');
        if (!glow) return;

        this.addEventListener('mousemove', (e) => {
          const rect = this.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          
          const moveX = (x - rect.width / 2) / 20;
          const moveY = (y - rect.height / 2) / 20;
          
          glow.style.transform = `translate(calc(-50% + ${moveX}px), calc(-50% + ${moveY}px))`;
        });
      }
    }

    customElements.define('ai-dtf-hero-{{ ai_gen_id }}', AiDtfHero{{ ai_gen_id }});
  })();
</script>

