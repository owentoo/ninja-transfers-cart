{% doc %}
  @prompt
    i want a group of scrollable link blocks with ratio options an image bg, two lines of text with weight size and color options and a cta, need padding option on the left of the first block , all padding needs to be in increments of 2, content and overlay needs alignments options top middle and bottom, content alignments should apply to all cards. overlay should have height and opacity issue. i do not need rollover effects, and content should have a max width option , overlay needs to be gradiant , bg of entire section needs color and gradient options, not seeing Section background
    , get rid of section bg, need top and bottom padding to work, need up to 8 cards, content in cards need alignment options right, left, center. all content optional , add options for pill above text with weight, size, color, radius, and padding options, make cta optional and add an option for it to be a circle with opacity with an arrow inside of it , add option for arrow boldness
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-scrollable-links-{{ ai_gen_id }} {
    padding-top: {{ block.settings.section_padding_top }}px;
    padding-bottom: {{ block.settings.section_padding_bottom }}px;
    {% if block.settings.section_bg_type == 'solid' %}
      background-color: {{ block.settings.section_bg_color }};
    {% else %}
      background: linear-gradient({{ block.settings.gradient_angle }}deg, {{ block.settings.gradient_color_1 }} 0%, {{ block.settings.gradient_color_2 }} 100%);
    {% endif %}
  }

  .ai-scrollable-links-container-{{ ai_gen_id }} {
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .ai-scrollable-links-container-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-scrollable-links-wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    padding-left: {{ block.settings.first_card_padding }}px;
    padding-right: 20px;
  }

  .ai-scrollable-link-card-{{ ai_gen_id }} {
    position: relative;
    flex-shrink: 0;
    width: {{ block.settings.card_width }}px;
    height: {{ block.settings.card_height }}px;
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    display: flex;
    {% if block.settings.content_vertical_align == 'top' %}
      align-items: flex-start;
    {% elsif block.settings.content_vertical_align == 'middle' %}
      align-items: center;
    {% else %}
      align-items: flex-end;
    {% endif %}
    {% if block.settings.content_horizontal_align == 'left' %}
      justify-content: flex-start;
    {% elsif block.settings.content_horizontal_align == 'center' %}
      justify-content: center;
    {% else %}
      justify-content: flex-end;
    {% endif %}
  }

  .ai-scrollable-link-card-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: {{ block.settings.overlay_height }}%;
    background: linear-gradient(to top, {{ block.settings.overlay_color_1 }} 0%, {{ block.settings.overlay_color_2 }} 100%);
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 1;
    pointer-events: none;
  }

  .ai-scrollable-link-bg-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .ai-scrollable-link-bg-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 0;
  }

  .ai-scrollable-link-bg-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-scrollable-link-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    padding: 20px;
    width: 100%;
    max-width: {{ block.settings.content_max_width }}px;
    {% if block.settings.content_horizontal_align == 'left' %}
      text-align: left;
    {% elsif block.settings.content_horizontal_align == 'center' %}
      text-align: center;
    {% else %}
      text-align: right;
    {% endif %}
  }

  .ai-scrollable-link-pill-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.pill_padding_vertical }}px {{ block.settings.pill_padding_horizontal }}px;
    background-color: {{ block.settings.pill_bg_color }};
    color: {{ block.settings.pill_text_color }};
    font-size: {{ block.settings.pill_font_size }}px;
    font-weight: {{ block.settings.pill_font_weight }};
    border-radius: {{ block.settings.pill_border_radius }}px;
    margin-bottom: 12px;
    line-height: 1;
  }

  .ai-scrollable-link-text1-{{ ai_gen_id }} {
    font-size: {{ block.settings.text1_size }}px;
    font-weight: {{ block.settings.text1_weight }};
    color: {{ block.settings.text1_color }};
    margin: 0 0 8px 0;
    line-height: 1.2;
  }

  .ai-scrollable-link-text2-{{ ai_gen_id }} {
    font-size: {{ block.settings.text2_size }}px;
    font-weight: {{ block.settings.text2_weight }};
    color: {{ block.settings.text2_color }};
    margin: 0 0 16px 0;
    line-height: 1.3;
  }

  .ai-scrollable-link-cta-{{ ai_gen_id }} {
    display: inline-block;
    text-decoration: none;
    transition: background-color 0.3s ease, color 0.3s ease, opacity 0.3s ease;
  }

  .ai-scrollable-link-cta-{{ ai_gen_id }}.ai-cta-button-{{ ai_gen_id }} {
    padding: {{ block.settings.cta_padding_vertical }}px {{ block.settings.cta_padding_horizontal }}px;
    background-color: {{ block.settings.cta_bg_color }};
    color: {{ block.settings.cta_text_color }};
    border-radius: {{ block.settings.cta_border_radius }}px;
    font-size: {{ block.settings.cta_font_size }}px;
    font-weight: {{ block.settings.cta_font_weight }};
  }

  .ai-scrollable-link-cta-{{ ai_gen_id }}.ai-cta-circle-{{ ai_gen_id }} {
    width: {{ block.settings.cta_circle_size }}px;
    height: {{ block.settings.cta_circle_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.cta_circle_bg_color }};
    opacity: {{ block.settings.cta_circle_opacity }};
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  .ai-scrollable-link-cta-{{ ai_gen_id }}.ai-cta-circle-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-cta-arrow-{{ ai_gen_id }} {
    width: calc({{ block.settings.cta_circle_size }}px * 0.4);
    height: calc({{ block.settings.cta_circle_size }}px * 0.4);
    stroke: {{ block.settings.cta_circle_arrow_color }};
    stroke-width: {{ block.settings.cta_arrow_weight }};
  }

  .ai-scrollable-link-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
    z-index: 3;
  }
{% endstyle %}

<div class="ai-scrollable-links-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-scrollable-links-container-{{ ai_gen_id }}">
    <div class="ai-scrollable-links-wrapper-{{ ai_gen_id }}">
      {% for i in (1..8) %}
        {% liquid
          assign card_image_key = 'card_' | append: i | append: '_image'
          assign card_pill_key = 'card_' | append: i | append: '_pill'
          assign card_text1_key = 'card_' | append: i | append: '_text1'
          assign card_text2_key = 'card_' | append: i | append: '_text2'
          assign card_cta_text_key = 'card_' | append: i | append: '_cta_text'
          assign card_cta_link_key = 'card_' | append: i | append: '_cta_link'

          assign card_image = block.settings[card_image_key]
          assign card_pill = block.settings[card_pill_key]
          assign card_text1 = block.settings[card_text1_key]
          assign card_text2 = block.settings[card_text2_key]
          assign card_cta_text = block.settings[card_cta_text_key]
          assign card_cta_link = block.settings[card_cta_link_key]
        %}

        <div class="ai-scrollable-link-card-{{ ai_gen_id }}">
          {% if card_image %}
            <img
              src="{{ card_image | image_url: width: 800 }}"
              alt="{{ card_image.alt | escape }}"
              class="ai-scrollable-link-bg-{{ ai_gen_id }}"
              loading="lazy"
              width="{{ card_image.width }}"
              height="{{ card_image.height }}"
            >
          {% else %}
            <div class="ai-scrollable-link-bg-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
            {% if card_pill == blank and card_text1 == blank and card_text2 == blank and card_cta_text == blank %}
              <div class="ai-scrollable-link-empty-state-{{ ai_gen_id }}">
                Add image and content for card {{ i }}
              </div>
            {% endif %}
          {% endif %}

          <div class="ai-scrollable-link-content-{{ ai_gen_id }}">
            {% if card_pill != blank %}
              <div class="ai-scrollable-link-pill-{{ ai_gen_id }}">{{ card_pill }}</div>
            {% endif %}

            {% if card_text1 != blank %}
              <div class="ai-scrollable-link-text1-{{ ai_gen_id }}">{{ card_text1 }}</div>
            {% endif %}

            {% if card_text2 != blank %}
              <div class="ai-scrollable-link-text2-{{ ai_gen_id }}">{{ card_text2 }}</div>
            {% endif %}

            {% if card_cta_text != blank or block.settings.cta_style == 'circle' %}
              {% if card_cta_link != blank %}
                {% if block.settings.cta_style == 'button' %}
                  <a
                    href="{{ card_cta_link }}"
                    class="ai-scrollable-link-cta-{{ ai_gen_id }} ai-cta-button-{{ ai_gen_id }}"
                  >
                    {{ card_cta_text }}
                  </a>
                {% else %}
                  <a
                    href="{{ card_cta_link }}"
                    class="ai-scrollable-link-cta-{{ ai_gen_id }} ai-cta-circle-{{ ai_gen_id }}"
                    aria-label="View details"
                  >
                    <svg
                      class="ai-cta-arrow-{{ ai_gen_id }}"
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <line x1="5" y1="12" x2="19" y2="12"></line>
                      <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                  </a>
                {% endif %}
              {% endif %}
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

