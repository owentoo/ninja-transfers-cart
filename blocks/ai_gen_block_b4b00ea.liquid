{% doc %}
  @prompt
    i need a section with with a full width bi image and centered in the section an image with text to the right., text should always be horizontally aligned with image. needs desktop and mobile size options for text and image , only need Heading, no text , all settings need smaller options and image and text section needs to be center aligned , text needs to be right aligned to image, content box does not need color 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-bg-image-section-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: {{ block.settings.section_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .ai-bg-image-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-bg-image-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-bg-image-background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-bg-image-background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 600px;
    max-height: 600px;
  }

  .ai-bg-image-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 2;
  }

  .ai-bg-image-content-wrapper-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 20px;
  }

  .ai-bg-image-content-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: {{ block.settings.content_gap }}px;
    padding: {{ block.settings.content_padding }}px;
  }

  .ai-bg-image-image-container-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.image_width_desktop }}px;
  }

  .ai-bg-image-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: block;
  }

  .ai-bg-image-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    background-color: #e5e5e5;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-bg-image-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .ai-bg-image-text-container-{{ ai_gen_id }} {
    flex-grow: 1;
    text-align: left;
  }

  .ai-bg-image-heading-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.heading_size_desktop }}px;
    color: {{ block.settings.heading_color }};
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    line-height: 1.2;
  }

  .ai-bg-image-button-{{ ai_gen_id }} {
    display: inline-block;
    margin-top: {{ block.settings.button_spacing }}px;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  .ai-bg-image-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-bg-image-section-{{ ai_gen_id }} {
      min-height: {{ block.settings.section_height_mobile }}px;
    }

    .ai-bg-image-content-{{ ai_gen_id }} {
      {% if block.settings.mobile_layout == 'column' %}
        flex-direction: column;
      {% endif %}
    }

    .ai-bg-image-image-container-{{ ai_gen_id }} {
      width: {{ block.settings.image_width_mobile }}px;
      max-width: 100%;
    }

    .ai-bg-image-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    {% if block.settings.mobile_layout == 'column' %}
      .ai-bg-image-text-container-{{ ai_gen_id }} {
        text-align: center;
      }
    {% endif %}
  }
{% endstyle %}

<div class="ai-bg-image-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-bg-image-background-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2400 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-bg-image-background-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  {% if block.settings.overlay_opacity > 0 %}
    <div class="ai-bg-image-overlay-{{ ai_gen_id }}"></div>
  {% endif %}

  <div class="ai-bg-image-content-wrapper-{{ ai_gen_id }}">
    <div class="ai-bg-image-content-{{ ai_gen_id }}">
      <div class="ai-bg-image-image-container-{{ ai_gen_id }}">
        {% if block.settings.content_image %}
          <img
            src="{{ block.settings.content_image | image_url: width: 800 }}"
            alt="{{ block.settings.content_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.content_image.width }}"
            height="{{ block.settings.content_image.height }}"
            class="ai-bg-image-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-bg-image-image-placeholder-{{ ai_gen_id }}">
            {{ 'product-apparel-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      <div class="ai-bg-image-text-container-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-bg-image-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}

        {% if block.settings.button_text != blank and block.settings.button_link != blank %}
          <a href="{{ block.settings.button_link }}" class="ai-bg-image-button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image with text overlay",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Background image"
