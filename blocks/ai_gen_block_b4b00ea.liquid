    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.3
    },
    {
      "type": "header",
      "content": "Content box"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Maximum width",
      "min": 400,
      "max": 1400,
      "step": 50,
      "unit": "px",
      "default": 800
    },
    {
      "type": "range",
      "id": "content_padding",
