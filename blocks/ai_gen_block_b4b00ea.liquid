      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Vertical padding",
      "min": 10,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Content image"
    },
    {
      "type": "image_picker",
      "id": "content_image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "image_width_desktop",
      "label": "Desktop width",
      "min": 80,
      "max": 600,
      "step": 20,
      "unit": "px",
      "default": 200
