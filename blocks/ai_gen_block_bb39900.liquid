{% doc %}
  @prompt
    Create an FAQ section with accordion-style dropdowns. Each FAQ item should include a question (heading) and answer (paragraph text). Display questions as clickable headings that expand to reveal the answer below.
    
    Layout:
    
    Stack all accordion items vertically
    Only one item should expand at a time (optional toggle setting)
    Include icons to indicate open/closed state
    Add animation for smooth expand/collapse
    Content Elements:
    
    Question (Heading, editable text)
    Answer (Paragraph, editable text)
    Icon for expand/collapse (chevron or plus/minus)
    Customization Settings:
    
    Editable text for all questions and answers
    Option to add, remove, or reorder FAQ items
    Desktop and mobile font size and weight options for both question and answer
    Padding and margin controls (top, bottom, sides)
    Max width control for FAQ container
    Background color setting
    Text color setting
    Option to enable/disable "only one open at a time", i need a section width and alignment and width option for the faq within and add an h1 above, Layout & Structure
    Section heading: Frequently Asked Questions (editable h2)
    Stack of accordion items below the heading
    Each accordion item includes:
    A bold, editable question (e.g., This is a FAQ question for SEO)
    A hidden answer paragraph that expands with a toggle
    A down/up chevron icon aligned to the right of each question
    Only one accordion item can be open at a time (optional setting)
    Content Elements
    Section title (h2, editable)
    Accordion questions (editable)
    Accordion answers (editable rich text)
    Expand/collapse icon (chevron up/down toggle)
    Design & Style
    Max-width container aligned center (set to match theme container)
    Light grey background (#EEF7F7 or customizable)
    Black text for questions
    Soft animation for toggle (ease-in-out 200ms)
    Divider line between each FAQ item
    Mobile responsiveness: stack with same paddings
    Icon changes direction based on state (up/down arrow)
    Clean sans-serif font, consistent with theme, the bg color should be full width, add a container with width rules and then the existing container within that with alignment rules, add a smooth animation to open and close the accordians

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-faq-section-{{ ai_gen_id }} {
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
  }

  .ai-faq-outer-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.section_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-faq-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.container_background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-faq-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_font_size }}px;
    font-weight: {{ block.settings.heading_font_weight }};
    color: {{ block.settings.heading_color }};
    text-align: {{ block.settings.heading_alignment }};
    margin-top: 0;
    margin-bottom: {{ block.settings.heading_spacing }}px;
  }

  .ai-faq-list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ai-faq-item-{{ ai_gen_id }} {
    border-bottom: 1px solid {{ block.settings.divider_color }};
  }

  .ai-faq-item-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-faq-question-{{ ai_gen_id }} {
    width: 100%;
    background: none;
    border: none;
    text-align: left;
    padding: {{ block.settings.question_padding }}px 0;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: {{ block.settings.question_font_size }}px;
    font-weight: {{ block.settings.question_font_weight }};
    color: {{ block.settings.question_color }};
    transition: color 0.3s ease-in-out;
  }

  .ai-faq-question-{{ ai_gen_id }}:hover {
    color: {{ block.settings.question_hover_color }};
  }

  .ai-faq-question-text-{{ ai_gen_id }} {
    flex: 1;
    margin-right: 16px;
  }

  .ai-faq-icon-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    transition: transform 0.3s ease-in-out;
    flex-shrink: 0;
    color: {{ block.settings.icon_color }};
  }

  .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-icon-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  .ai-faq-answer-{{ ai_gen_id }} {
    height: 0;
    overflow: hidden;
    transition: height 0.3s ease-in-out;
    font-size: {{ block.settings.answer_font_size }}px;
    color: {{ block.settings.answer_color }};
    line-height: 1.5;
    opacity: 0;
  }

  .ai-faq-answer-inner-{{ ai_gen_id }} {
    padding: 0 0 {{ block.settings.answer_padding }}px 0;
  }

  .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-answer-{{ ai_gen_id }} {
    opacity: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-faq-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size_mobile }}px;
    }
    
    .ai-faq-question-{{ ai_gen_id }} {
      font-size: {{ block.settings.question_font_size_mobile }}px;
    }

    .ai-faq-answer-{{ ai_gen_id }} {
      font-size: {{ block.settings.answer_font_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-faq-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-faq-outer-container-{{ ai_gen_id }}">
    <div class="ai-faq-container-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-faq-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      
      <faq-accordion-{{ ai_gen_id }}
        class="ai-faq-wrapper-{{ ai_gen_id }}"
        data-single-open="{{ block.settings.single_open }}"
      >
        <ul class="ai-faq-list-{{ ai_gen_id }}">
          {% for i in (1..6) %}
            {% assign question_key = 'question_' | append: i %}
            {% assign answer_key = 'answer_' | append: i %}
            {% assign question = block.settings[question_key] %}
            {% assign answer = block.settings[answer_key] %}
            {% if question != blank and answer != blank %}
              <li class="ai-faq-item-{{ ai_gen_id }}" data-faq-item="{{ i }}">
                <button 
                  class="ai-faq-question-{{ ai_gen_id }}"
                  aria-expanded="false"
                  aria-controls="ai-faq-answer-{{ ai_gen_id }}-{{ i }}"
                >
                  <span class="ai-faq-question-text-{{ ai_gen_id }}">{{ question }}</span>
                  <svg class="ai-faq-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="6,9 12,15 18,9"></polyline>
                  </svg>
                </button>
                <div 
                  class="ai-faq-answer-{{ ai_gen_id }}"
                  id="ai-faq-answer-{{ ai_gen_id }}-{{ i }}"
                  aria-hidden="true"
                >
                  <div class="ai-faq-answer-inner-{{ ai_gen_id }}">{{ answer }}</div>
                </div>
              </li>
            {% endif %}
          {% endfor %}
        </ul>
      </faq-accordion-{{ ai_gen_id }}>
    </div>
  </div>
</div>

<script>
  (function() {
    class FaqAccordion{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.singleOpen = this.dataset.singleOpen === 'true';
        this.animationSpeed = 300; // Animation duration in ms
      }

      connectedCallback() {
        this.setupEventListeners();
      }

      setupEventListeners() {
        const questions = this.querySelectorAll('.ai-faq-question-{{ ai_gen_id }}');
        questions.forEach(question => {
          question.addEventListener('click', () => {
            const faqItem = question.closest('.ai-faq-item-{{ ai_gen_id }}');
            const answer = faqItem.querySelector('.ai-faq-answer-{{ ai_gen_id }}');
            const isActive = faqItem.classList.contains('active');
            
            if (this.singleOpen) {
              // Close all other items
              this.querySelectorAll('.ai-faq-item-{{ ai_gen_id }}.active').forEach(item => {
                if (item !== faqItem) {
                  this.closeItem(item);
                }
              });
            }
            
            if (isActive) {
              this.closeItem(faqItem);
            } else {
              this.openItem(faqItem);
            }
          });
        });
      }

      openItem(item) {
        const question = item.querySelector('.ai-faq-question-{{ ai_gen_id }}');
        const answer = item.querySelector('.ai-faq-answer-{{ ai_gen_id }}');
        const answerInner = answer.querySelector('.ai-faq-answer-inner-{{ ai_gen_id }}');
        
        // Set to active state
        item.classList.add('active');
        question.setAttribute('aria-expanded', 'true');
        answer.setAttribute('aria-hidden', 'false');
        
        // Get the height of the content
        const height = answerInner.offsetHeight;
        
        // Start animation
        answer.style.height = '0px';
        answer.style.opacity = '0';
        
        // Force a reflow to ensure the initial state is applied
        void answer.offsetWidth;
        
        // Apply transition
        answer.style.height = `${height}px`;
        answer.style.opacity = '1';
        
        // Clean up after animation completes
        setTimeout(() => {
          if (item.classList.contains('active')) {
            answer.style.height = 'auto';
          }
        }, this.animationSpeed);
      }

      closeItem(item) {
        const question = item.querySelector('.ai-faq-question-{{ ai_gen_id }}');
        const answer = item.querySelector('.ai-faq-answer-{{ ai_gen_id }}');
        const answerInner = answer.querySelector('.ai-faq-answer-inner-{{ ai_gen_id }}');
        
        // Get the current height
        const height = answer.offsetHeight;
        
        // Set fixed height to allow animation
        answer.style.height = `${height}px`;
        
        // Force a reflow to ensure the fixed height is applied
        void answer.offsetWidth;
        
        // Start animation
        answer.style.height = '0px';
        answer.style.opacity = '0';
        
        // Update ARIA attributes
        question.setAttribute('aria-expanded', 'false');
        answer.setAttribute('aria-hidden', 'true');
        
        // Remove active class after animation completes
        setTimeout(() => {
          item.classList.remove('active');
        }, this.animationSpeed);
      }
    }

    customElements.define('faq-accordion-{{ ai_gen_id }}', FaqAccordion{{ ai_gen_id }});
  })();
</script>

