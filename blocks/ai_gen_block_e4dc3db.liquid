{% doc %}
  @prompt
    make me a section that follows the themes horizontal max width padding and margin. inside i need the option to add 2,3, or 4 blocks, in each block i need an image below that a headline and below that para text., i need more image ratios, and all text should have size, color, and weight options for desktop and mobile, text need alignment options and padding for sides option. and space between options, Padding should be, horizontal and apply to all text. And weight option can match on desktop and mobile, i don't need the "Content alignment" and every block should have the option for a roll over image or video, add an option for video to be selected from the cms as well, and add an option small play icon when hover video is selected, need "Text horizontal padding" for desktop and mobile. add play "Play icon" option whenever a rollover image or video is there, "Media type" will always be an image, only another image or video on roll over. the icon should show whenever there is a "Hover effect type" other then none. and it should show before hover not after, add Play Icon Settings for position of centers or corners and padding from the edge, for desktop and mobile, and color options, give me the option to upload my own play icon. and add option for bg color or bg gradiant

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-feature-blocks-{{ ai_gen_id }} {
    max-width: {{ settings.theme_max_width }}px;
    margin: 0 auto;
    padding: 0 {{ settings.grid_gap }}px;
  }

  .ai-feature-blocks__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.space_between }}px;
  }

  .ai-feature-blocks__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-feature-blocks__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    margin-bottom: {{ block.settings.image_bottom_spacing }}px;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    position: relative;
  }

  .ai-feature-blocks__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-feature-blocks__hover-image-{{ ai_gen_id }},
  .ai-feature-blocks__hover-video-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .ai-feature-blocks__image-wrapper-{{ ai_gen_id }}:hover .ai-feature-blocks__hover-image-{{ ai_gen_id }},
  .ai-feature-blocks__image-wrapper-{{ ai_gen_id }}:hover .ai-feature-blocks__hover-video-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-feature-blocks__hover-video-{{ ai_gen_id }} {
    object-fit: cover;
  }

  .ai-feature-blocks__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-feature-blocks__image-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.5;
  }

  .ai-feature-blocks__content-{{ ai_gen_id }} {
    padding-left: {{ block.settings.text_padding_horizontal_desktop }}px;
    padding-right: {{ block.settings.text_padding_horizontal_desktop }}px;
  }

  .ai-feature-blocks__heading-{{ ai_gen_id }} {
    font-family: var(--font-heading-family);
    font-size: {{ block.settings.heading_size_desktop }}px;
    font-weight: {{ block.settings.heading_weight }};
    line-height: 1.2;
    margin: 0 0 {{ block.settings.heading_bottom_spacing }}px 0;
    color: {{ block.settings.heading_color }};
  }

  .ai-feature-blocks__text-{{ ai_gen_id }} {
    font-family: var(--font-body-family);
    font-size: {{ block.settings.text_size_desktop }}px;
    font-weight: {{ block.settings.text_weight }};
    line-height: 1.5;
    margin: 0;
    color: {{ block.settings.text_color }};
  }

  .ai-feature-blocks__play-icon-{{ ai_gen_id }} {
    position: absolute;
    width: {{ block.settings.play_icon_size }}px;
    height: {{ block.settings.play_icon_size }}px;
    {% if block.settings.play_icon_bg_type == 'color' %}
      background-color: {{ block.settings.play_icon_bg_color }};
    {% elsif block.settings.play_icon_bg_type == 'gradient' %}
      background: linear-gradient(to right, {{ block.settings.play_icon_bg_gradient_start }}, {{ block.settings.play_icon_bg_gradient_end }});
    {% else %}
      background-color: transparent;
    {% endif %}
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 1;
    transition: opacity 0.3s ease;
  }

  .ai-feature-blocks__play-icon-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    fill: {{ block.settings.play_icon_color }};
  }

  .ai-feature-blocks__play-icon-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  {% if block.settings.play_icon_position == 'center' %}
    .ai-feature-blocks__play-icon-{{ ai_gen_id }} {
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
    }
  {% elsif block.settings.play_icon_position == 'top-left' %}
    .ai-feature-blocks__play-icon-{{ ai_gen_id }} {
      top: {{ block.settings.play_icon_padding_desktop }}px;
      left: {{ block.settings.play_icon_padding_desktop }}px;
    }
  {% elsif block.settings.play_icon_position == 'top-right' %}
    .ai-feature-blocks__play-icon-{{ ai_gen_id }} {
      top: {{ block.settings.play_icon_padding_desktop }}px;
      right: {{ block.settings.play_icon_padding_desktop }}px;
    }
  {% elsif block.settings.play_icon_position == 'bottom-left' %}
    .ai-feature-blocks__play-icon-{{ ai_gen_id }} {
      bottom: {{ block.settings.play_icon_padding_desktop }}px;
      left: {{ block.settings.play_icon_padding_desktop }}px;
    }
  {% elsif block.settings.play_icon_position == 'bottom-right' %}
    .ai-feature-blocks__play-icon-{{ ai_gen_id }} {
      bottom: {{ block.settings.play_icon_padding_desktop }}px;
      right: {{ block.settings.play_icon_padding_desktop }}px;
    }
  {% endif %}

  @media screen and (max-width: 749px) {
    .ai-feature-blocks__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.space_between_mobile }}px;
    }
    
    .ai-feature-blocks__image-wrapper-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.image_bottom_spacing_mobile }}px;
    }
    
    .ai-feature-blocks__content-{{ ai_gen_id }} {
      padding-left: {{ block.settings.text_padding_horizontal_mobile }}px;
      padding-right: {{ block.settings.text_padding_horizontal_mobile }}px;
    }
    
    .ai-feature-blocks__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
      margin: 0 0 {{ block.settings.heading_bottom_spacing_mobile }}px 0;
    }
    
    .ai-feature-blocks__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
    }

    .ai-feature-blocks__play-icon-{{ ai_gen_id }} {
      width: {{ block.settings.play_icon_size_mobile }}px;
      height: {{ block.settings.play_icon_size_mobile }}px;
    }
    
    {% if block.settings.play_icon_position == 'top-left' %}
      .ai-feature-blocks__play-icon-{{ ai_gen_id }} {
        top: {{ block.settings.play_icon_padding_mobile }}px;
        left: {{ block.settings.play_icon_padding_mobile }}px;
      }
    {% elsif block.settings.play_icon_position == 'top-right' %}
      .ai-feature-blocks__play-icon-{{ ai_gen_id }} {
        top: {{ block.settings.play_icon_padding_mobile }}px;
        right: {{ block.settings.play_icon_padding_mobile }}px;
      }
    {% elsif block.settings.play_icon_position == 'bottom-left' %}
      .ai-feature-blocks__play-icon-{{ ai_gen_id }} {
        bottom: {{ block.settings.play_icon_padding_mobile }}px;
        left: {{ block.settings.play_icon_padding_mobile }}px;
      }
    {% elsif block.settings.play_icon_position == 'bottom-right' %}
      .ai-feature-blocks__play-icon-{{ ai_gen_id }} {
        bottom: {{ block.settings.play_icon_padding_mobile }}px;
        right: {{ block.settings.play_icon_padding_mobile }}px;
      }
    {% endif %}
  }
{% endstyle %}

<div class="ai-feature-blocks-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-feature-blocks__grid-{{ ai_gen_id }}">
    {% for i in (1..block.settings.number_of_blocks) %}
      {% liquid
        assign image_key = 'image_' | append: i
        assign hover_image_key = 'hover_image_' | append: i
        assign hover_video_key = 'hover_video_' | append: i
        assign hover_type_key = 'hover_type_' | append: i
        assign heading_key = 'heading_' | append: i
        assign text_key = 'text_' | append: i
        
        assign image = block.settings[image_key]
        assign hover_image = block.settings[hover_image_key]
        assign hover_video_url = block.settings[hover_video_key]
        assign hover_type = block.settings[hover_type_key]
        assign heading = block.settings[heading_key]
        assign text = block.settings[text_key]
      %}
      
      <div class="ai-feature-blocks__item-{{ ai_gen_id }}">
        <div class="ai-feature-blocks__image-wrapper-{{ ai_gen_id }}">
          {% if image != blank %}
            <img 
              src="{{ image | image_url: width: 500 }}" 
              alt="{{ image.alt | escape }}"
              width="{{ image.width }}"
              height="{{ image.height }}"
              loading="lazy"
              class="ai-feature-blocks__image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-feature-blocks__image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
          
          {% if hover_type == 'image' and hover_image != blank %}
            <img 
              src="{{ hover_image | image_url: width: 500 }}" 
              alt="{{ hover_image.alt | escape }}"
              width="{{ hover_image.width }}"
              height="{{ hover_image.height }}"
              loading="lazy"
              class="ai-feature-blocks__hover-image-{{ ai_gen_id }}"
            >
          {% elsif hover_type == 'video' and hover_video_url != blank %}
            <video 
              class="ai-feature-blocks__hover-video-{{ ai_gen_id }}" 
              autoplay 
              muted 
              loop 
              playsinline
            >
              <source src="{{ hover_video_url }}" type="video/mp4">
            </video>
          {% endif %}
          
          {% if hover_type != 'none' %}
            <div class="ai-feature-blocks__play-icon-{{ ai_gen_id }}">
              {% if block.settings.custom_play_icon != blank %}
                <img 
                  src="{{ block.settings.custom_play_icon | image_url: width: 100 }}" 
                  alt="Play"
                  loading="lazy"
                  class="ai-feature-blocks__play-icon-image-{{ ai_gen_id }}"
                >
              {% else %}
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <polygon points="5,3 19,12 5,21"/>
                </svg>
              {% endif %}
            </div>
          {% endif %}
        </div>
        
        <div class="ai-feature-blocks__content-{{ ai_gen_id }}">
          {% if heading != blank %}
            <h3 class="ai-feature-blocks__heading-{{ ai_gen_id }}">{{ heading }}</h3>
          {% endif %}
          
          {% if text != blank %}
            <div class="ai-feature-blocks__text-{{ ai_gen_id }}">{{ text }}</div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>

