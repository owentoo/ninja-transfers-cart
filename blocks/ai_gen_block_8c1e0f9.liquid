{% doc %}
  @prompt
    i need a row or cards, each card will be an image, with a partial gradient overlay, inside that a name under that starts, under that a quote. need utp eight , name text and starts should be ontop of the overlay, cards should not have a white section the quote should be under the stars and in the overlay section , need Gap between cards for desktop and mobile. all text needs size option for desktop and mobile. starts need space between option , need Overlay padding for desktop and mobile. content needs max width, hide overflow and show arrow when overflow exists , all cards have to be on the same line, section needs max width hide overflow allow scroll horzintally , section need horizontal padding for desktop and mobile, get rid of hover effects , add arrows to show overflow and make sure horizontal scroll bar is below elements , only show arrow when there is over flow on the right or left , need top and bottom padding options, and give me more aspect ratio options all tall , hide arrows on mobile , get rid of all top and bottom padding 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonial-cards-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: {{ block.settings.section_max_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.section_padding_horizontal_desktop }}px;
    position: relative;
  }

  .ai-testimonial-cards__wrapper-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-testimonial-cards__container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap_desktop }}px;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: {{ block.settings.scrollbar_color }} transparent;
    padding-bottom: 20px;
  }

  .ai-testimonial-cards__container-{{ ai_gen_id }}::-webkit-scrollbar {
    height: 8px;
  }

  .ai-testimonial-cards__container-{{ ai_gen_id }}::-webkit-scrollbar-track {
    background: transparent;
  }

  .ai-testimonial-cards__container-{{ ai_gen_id }}::-webkit-scrollbar-thumb {
    background-color: {{ block.settings.scrollbar_color }};
    border-radius: 4px;
  }

  .ai-testimonial-cards__arrow-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: {{ block.settings.arrow_size }}px;
    height: {{ block.settings.arrow_size }}px;
    background-color: {{ block.settings.arrow_background }};
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .ai-testimonial-cards__arrow-{{ ai_gen_id }}.visible {
    opacity: 1;
    visibility: visible;
  }

  .ai-testimonial-cards__arrow-{{ ai_gen_id }}--left {
    left: {{ block.settings.arrow_offset }}px;
  }

  .ai-testimonial-cards__arrow-{{ ai_gen_id }}--right {
    right: {{ block.settings.arrow_offset }}px;
  }

  .ai-testimonial-cards__arrow-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    fill: {{ block.settings.arrow_color }};
  }

  .ai-testimonial-card-{{ ai_gen_id }} {
    position: relative;
    flex: 0 0 {{ block.settings.card_width_desktop }}px;
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-testimonial-card__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    overflow: hidden;
  }

  .ai-testimonial-card__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-testimonial-card__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-testimonial-card__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-testimonial-card__gradient-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: {{ block.settings.gradient_height }}%;
    background: linear-gradient(
      to top,
      {{ block.settings.gradient_color }},
      transparent
    );
    pointer-events: none;
  }

  .ai-testimonial-card__overlay-content-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: {{ block.settings.overlay_padding_desktop }}px;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-testimonial-card__name-{{ ai_gen_id }} {
    font-family: {{ block.settings.name_font.family }}, {{ block.settings.name_font.fallback_families }};
    font-weight: {{ block.settings.name_font.weight }};
    font-size: {{ block.settings.name_font_size_desktop }}px;
    color: {{ block.settings.name_color }};
    margin: 0;
  }

  .ai-testimonial-card__stars-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.star_spacing }}px;
    align-items: center;
  }

  .ai-testimonial-card__star-{{ ai_gen_id }} {
    width: {{ block.settings.star_size_desktop }}px;
    height: {{ block.settings.star_size_desktop }}px;
    fill: {{ block.settings.star_color }};
  }

  .ai-testimonial-card__star-{{ ai_gen_id }}--empty {
    fill: {{ block.settings.star_empty_color }};
  }

  .ai-testimonial-card__quote-wrapper-{{ ai_gen_id }} {
    position: relative;
    max-width: {{ block.settings.content_max_width }}px;
  }

  .ai-testimonial-card__quote-{{ ai_gen_id }} {
    font-family: {{ block.settings.quote_font.family }}, {{ block.settings.quote_font.fallback_families }};
    font-weight: {{ block.settings.quote_font.weight }};
    font-size: {{ block.settings.quote_font_size_desktop }}px;
    line-height: 1.5;
    color: {{ block.settings.quote_color }};
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: {{ block.settings.quote_max_lines }};
    -webkit-box-orient: vertical;
  }

  .ai-testimonial-card__expand-btn-{{ ai_gen_id }} {
    display: none;
    background: none;
    border: none;
    color: {{ block.settings.quote_color }};
    cursor: pointer;
    padding: 4px 0;
    font-size: {{ block.settings.quote_font_size_desktop }}px;
    text-decoration: underline;
    margin-top: 4px;
  }

  .ai-testimonial-card__quote-wrapper-{{ ai_gen_id }}.has-overflow .ai-testimonial-card__expand-btn-{{ ai_gen_id }} {
    display: block;
  }

  .ai-testimonial-card__quote-wrapper-{{ ai_gen_id }}.expanded .ai-testimonial-card__quote-{{ ai_gen_id }} {
    -webkit-line-clamp: unset;
  }

  @media screen and (max-width: 749px) {
    .ai-testimonial-cards-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.section_padding_horizontal_mobile }}px;
    }

    .ai-testimonial-cards__container-{{ ai_gen_id }} {
      gap: {{ block.settings.card_gap_mobile }}px;
    }

    .ai-testimonial-card-{{ ai_gen_id }} {
      flex: 0 0 {{ block.settings.card_width_mobile }}px;
    }

    .ai-testimonial-card__overlay-content-{{ ai_gen_id }} {
      padding: {{ block.settings.overlay_padding_mobile }}px;
    }

    .ai-testimonial-card__name-{{ ai_gen_id }} {
      font-size: {{ block.settings.name_font_size_mobile }}px;
    }

    .ai-testimonial-card__star-{{ ai_gen_id }} {
      width: {{ block.settings.star_size_mobile }}px;
      height: {{ block.settings.star_size_mobile }}px;
    }

    .ai-testimonial-card__quote-{{ ai_gen_id }} {
      font-size: {{ block.settings.quote_font_size_mobile }}px;
    }

    .ai-testimonial-card__expand-btn-{{ ai_gen_id }} {
      font-size: {{ block.settings.quote_font_size_mobile }}px;
    }

    .ai-testimonial-cards__arrow-{{ ai_gen_id }} {
      display: none;
    }
  }
{% endstyle %}

<testimonial-cards-{{ ai_gen_id }}
  class="ai-testimonial-cards-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-testimonial-cards__wrapper-{{ ai_gen_id }}">
    <button
      class="ai-testimonial-cards__arrow-{{ ai_gen_id }} ai-testimonial-cards__arrow-{{ ai_gen_id }}--left"
      data-arrow-left
      aria-label="Scroll left"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
        <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
      </svg>
    </button>

    <button
      class="ai-testimonial-cards__arrow-{{ ai_gen_id }} ai-testimonial-cards__arrow-{{ ai_gen_id }}--right"
      data-arrow-right
      aria-label="Scroll right"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
        <path d="M8.59 16.59L10 18l6-6-6-6-1.41 1.41L13.17 12z"/>
      </svg>
    </button>

    <div class="ai-testimonial-cards__container-{{ ai_gen_id }}" data-container>
      {% for i in (1..8) %}
        {% liquid
          assign card_enabled_key = 'card_' | append: i | append: '_enabled'
          assign card_image_key = 'card_' | append: i | append: '_image'
          assign card_name_key = 'card_' | append: i | append: '_name'
          assign card_rating_key = 'card_' | append: i | append: '_rating'
          assign card_quote_key = 'card_' | append: i | append: '_quote'

          assign card_enabled = block.settings[card_enabled_key]
          assign card_image = block.settings[card_image_key]
          assign card_name = block.settings[card_name_key]
          assign card_rating = block.settings[card_rating_key]
          assign card_quote = block.settings[card_quote_key]
        %}

        {% if card_enabled %}
          <div class="ai-testimonial-card-{{ ai_gen_id }}">
            <div class="ai-testimonial-card__image-wrapper-{{ ai_gen_id }}">
              {% if card_image %}
                <img
                  src="{{ card_image | image_url: width: 600 }}"
                  alt="{{ card_name | escape }}"
                  loading="lazy"
                  width="600"
                  height="{{ 600 | divided_by: block.settings.image_aspect_ratio }}"
                  class="ai-testimonial-card__image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-testimonial-card__image-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
              <div class="ai-testimonial-card__gradient-{{ ai_gen_id }}"></div>
              
              <div class="ai-testimonial-card__overlay-content-{{ ai_gen_id }}">
                {% if card_name != blank %}
                  <h3 class="ai-testimonial-card__name-{{ ai_gen_id }}">{{ card_name }}</h3>
                {% endif %}

                <div class="ai-testimonial-card__stars-{{ ai_gen_id }}">
                  {% for star in (1..5) %}
                    <svg
                      class="ai-testimonial-card__star-{{ ai_gen_id }} {% if star > card_rating %}ai-testimonial-card__star-{{ ai_gen_id }}--empty{% endif %}"
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                    >
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                    </svg>
                  {% endfor %}
                </div>

                {% if card_quote != blank %}
                  <div class="ai-testimonial-card__quote-wrapper-{{ ai_gen_id }}" data-quote-wrapper>
                    <p class="ai-testimonial-card__quote-{{ ai_gen_id }}" data-quote>{{ card_quote }}</p>
                    <button class="ai-testimonial-card__expand-btn-{{ ai_gen_id }}" data-expand-btn aria-label="Show more">
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                        <path d="M8 12L3 7h10l-5 5z"/>
                      </svg>
                    </button>
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</testimonial-cards-{{ ai_gen_id }}>

<script>
  (function() {
    class TestimonialCards{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.container = this.querySelector('[data-container]');
        this.leftArrow = this.querySelector('[data-arrow-left]');
        this.rightArrow = this.querySelector('[data-arrow-right]');
        this.cards = this.querySelectorAll('.ai-testimonial-card-{{ ai_gen_id }}');
        
        this.setupAccessibility();
        this.checkOverflow();
        this.setupExpandButtons();
        this.setupArrows();
        this.updateArrowVisibility();

        window.addEventListener('resize', () => {
          this.updateArrowVisibility();
        });

        this.container.addEventListener('scroll', () => {
          this.updateArrowVisibility();
        });
      }

      setupAccessibility() {
        this.cards.forEach((card) => {
          card.setAttribute('role', 'article');
          card.setAttribute('aria-label', 'Customer testimonial');
        });
      }

      checkOverflow() {
        const quoteWrappers = this.querySelectorAll('[data-quote-wrapper]');
        
        quoteWrappers.forEach((wrapper) => {
          const quote = wrapper.querySelector('[data-quote]');
          if (quote.scrollHeight > quote.clientHeight) {
            wrapper.classList.add('has-overflow');
          }
        });
      }

      setupExpandButtons() {
        const expandButtons = this.querySelectorAll('[data-expand-btn]');
        
        expandButtons.forEach((button) => {
          button.addEventListener('click', (e) => {
            e.preventDefault();
            const wrapper = button.closest('[data-quote-wrapper]');
            const isExpanded = wrapper.classList.contains('expanded');
            
            if (isExpanded) {
              wrapper.classList.remove('expanded');
              button.setAttribute('aria-label', 'Show more');
              button.innerHTML = '<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M8 12L3 7h10l-5 5z"/></svg>';
            } else {
              wrapper.classList.add('expanded');
              button.setAttribute('aria-label', 'Show less');
              button.innerHTML = '<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M8 4L13 9H3l5-5z"/></svg>';
            }
          });
        });
      }

      setupArrows() {
        this.leftArrow.addEventListener('click', () => {
          const scrollAmount = this.container.offsetWidth * 0.8;
          this.container.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
        });

        this.rightArrow.addEventListener('click', () => {
          const scrollAmount = this.container.offsetWidth * 0.8;
          this.container.scrollBy({ left: scrollAmount, behavior: 'smooth' });
        });
      }

      updateArrowVisibility() {
        const hasOverflow = this.container.scrollWidth > this.container.clientWidth;
        
        if (!hasOverflow) {
          this.leftArrow.classList.remove('visible');
          this.rightArrow.classList.remove('visible');
          return;
        }

        const scrollLeft = this.container.scrollLeft;
        const maxScroll = this.container.scrollWidth - this.container.clientWidth;
        const isAtStart = scrollLeft <= 1;
        const isAtEnd = scrollLeft >= maxScroll - 1;

        if (isAtStart) {
          this.leftArrow.classList.remove('visible');
        } else {
          this.leftArrow.classList.add('visible');
        }

        if (isAtEnd) {
          this.rightArrow.classList.remove('visible');
        } else {
          this.rightArrow.classList.add('visible');
        }
      }
    }

    customElements.define('testimonial-cards-{{ ai_gen_id }}', TestimonialCards{{ ai_gen_id }});
  })();
</script>

