{% doc %}
  @prompt
    Create a Features Section with a heading, subheading, and a 4-card feature grid. Heading and subheading must have independent desktop/mobile controls for font size, color, font family (include Inter + Inter Extra Bold), and spacing. Add section padding controls for desktop and mobile.
    
    Feature Grid Requirements:
    
    4 cards across on desktop, 2 across on mobile.
    
    Adjustable gaps, card height, and card corner radius (desktop + mobile).
    
    Each card is a block with:
    
    Static image as the default background.
    
    Optional video for hover/tap state.
    
    Title text at the bottom-left with an optional subtitle.
    
    A bottom overlay (solid or gradient) to improve text readability. Controls: overlay color, opacity, and height.
    
    Hover / Active State:
    
    On desktop hover, smoothly fade the image into the video, move the text to the upper-left, and optionally scale the card slightly (toggle).
    
    Video autoplay, loop, and mute settings must be available per card.
    
    On mobile, tap triggers the video state; second tap returns to the image.
    
    Customization Controls:
    
    Section background color.
    
    Max-width or full-width layout option.
    
    Controls for card title/subtitle typography (desktop + mobile).
    
    Option to hide subtitles.
    
    Adjustable padding around card text in both default and hover states., Feature description is hidden until hover over, feature title is hidden once hover is in effect, On hover, feature subtitle replaces feature title in the same location on feature card, Feature subtitle should never get cut off at the bottom of card, ensure that when it replaces the feature title, it is placed high enough on card that all subtitle text is visible
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-features-section-{{ ai_gen_id }} {
    background-color: {{ block.settings.section_bg_color }};
    padding: {{ block.settings.section_padding_desktop }}px 0;
  }

  @media screen and (max-width: 749px) {
    .ai-features-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_mobile }}px 0;
    }
  }

  .ai-features-container-{{ ai_gen_id }} {
    {% if block.settings.layout_width == 'contained' %}
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 20px;
    {% else %}
      width: 100%;
      padding: 0 20px;
    {% endif %}
  }

  .ai-features-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing_desktop }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-features-header-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.header_spacing_mobile }}px;
    }
  }

  .ai-features-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size_desktop }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_subheading_gap }}px;
    line-height: 1.2;
  }

  @media screen and (max-width: 749px) {
    .ai-features-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }
  }

  .ai-features-subheading-{{ ai_gen_id }} {
    font-family: {{ block.settings.subheading_font.family }}, {{ block.settings.subheading_font.fallback_families }};
    font-weight: {{ block.settings.subheading_font.weight }};
    font-size: {{ block.settings.subheading_size_desktop }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-features-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size_mobile }}px;
    }
  }

  .ai-features-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.grid_gap_desktop }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-features-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: {{ block.settings.grid_gap_mobile }}px;
    }
  }

  .ai-features-card-{{ ai_gen_id }} {
    position: relative;
    height: {{ block.settings.card_height_desktop }}px;
    border-radius: {{ block.settings.card_radius_desktop }}px;
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.4s ease;
  }

  @media screen and (max-width: 749px) {
    .ai-features-card-{{ ai_gen_id }} {
      height: {{ block.settings.card_height_mobile }}px;
      border-radius: {{ block.settings.card_radius_mobile }}px;
    }
  }

  {% if block.settings.enable_card_scale %}
    .ai-features-card-{{ ai_gen_id }}:hover {
      transform: scale(1.05);
    }
  {% endif %}

  .ai-features-card-media-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .ai-features-card-image-{{ ai_gen_id }},
  .ai-features-card-video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.4s ease;
  }

  .ai-features-card-image-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-features-card-video-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
  }

  .ai-features-card-{{ ai_gen_id }}:hover .ai-features-card-image-{{ ai_gen_id }} {
    opacity: 0;
  }

  .ai-features-card-{{ ai_gen_id }}:hover .ai-features-card-video-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-features-card-{{ ai_gen_id }}.active .ai-features-card-image-{{ ai_gen_id }} {
    opacity: 0;
  }

  .ai-features-card-{{ ai_gen_id }}.active .ai-features-card-video-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-features-card-overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: {{ block.settings.overlay_height }}%;
    {% if block.settings.overlay_type == 'solid' %}
      background-color: {{ block.settings.overlay_color }};
      opacity: {{ block.settings.overlay_opacity }};
    {% else %}
      background: linear-gradient(to top, {{ block.settings.overlay_color }}, transparent);
      opacity: {{ block.settings.overlay_opacity }};
    {% endif %}
    pointer-events: none;
  }

  .ai-features-card-content-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: {{ block.settings.text_padding_default }}px;
    z-index: 2;
    display: flex;
    align-items: flex-end;
    min-height: 120px;
  }

  .ai-features-card-text-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-features-card-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.card_title_font.family }}, {{ block.settings.card_title_font.fallback_families }};
    font-weight: {{ block.settings.card_title_font.weight }};
    font-size: {{ block.settings.card_title_size_desktop }}px;
    color: {{ block.settings.card_title_color }};
    margin: 0;
    line-height: 1.3;
    opacity: 1;
    transition: opacity 0.4s ease;
  }

  @media screen and (max-width: 749px) {
    .ai-features-card-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.card_title_size_mobile }}px;
    }
  }

  .ai-features-card-{{ ai_gen_id }}:hover .ai-features-card-title-{{ ai_gen_id }} {
    opacity: 0;
  }

  .ai-features-card-{{ ai_gen_id }}.active .ai-features-card-title-{{ ai_gen_id }} {
    opacity: 0;
  }

  .ai-features-card-subtitle-{{ ai_gen_id }} {
    font-family: {{ block.settings.card_subtitle_font.family }}, {{ block.settings.card_subtitle_font.fallback_families }};
    font-weight: {{ block.settings.card_subtitle_font.weight }};
    font-size: {{ block.settings.card_subtitle_size_desktop }}px;
    color: {{ block.settings.card_subtitle_color }};
    margin: 0;
    line-height: 1.4;
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    opacity: 0;
    transition: opacity 0.4s ease;
    {% if block.settings.hide_subtitle %}
      display: none;
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-features-card-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.card_subtitle_size_mobile }}px;
    }
  }

  .ai-features-card-{{ ai_gen_id }}:hover .ai-features-card-subtitle-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-features-card-{{ ai_gen_id }}.active .ai-features-card-subtitle-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-features-card-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-features-card-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }
{% endstyle %}

<feature-cards-{{ ai_gen_id }} class="ai-features-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-features-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-features-header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-features-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-features-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-features-grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign image_key = 'card_' | append: i | append: '_image'
          assign video_key = 'card_' | append: i | append: '_video'
          assign title_key = 'card_' | append: i | append: '_title'
          assign subtitle_key = 'card_' | append: i | append: '_subtitle'
          assign autoplay_key = 'card_' | append: i | append: '_video_autoplay'
          assign loop_key = 'card_' | append: i | append: '_video_loop'
          assign mute_key = 'card_' | append: i | append: '_video_mute'

          assign card_image = block.settings[image_key]
          assign card_video = block.settings[video_key]
          assign card_title = block.settings[title_key]
          assign card_subtitle = block.settings[subtitle_key]
          assign video_autoplay = block.settings[autoplay_key]
          assign video_loop = block.settings[loop_key]
          assign video_mute = block.settings[mute_key]
        %}

        <div class="ai-features-card-{{ ai_gen_id }}" data-card-id="{{ i }}">
          <div class="ai-features-card-media-{{ ai_gen_id }}">
            {% if card_image %}
              <img
                src="{{ card_image | image_url: width: 800 }}"
                alt="{{ card_image.alt | escape }}"
                class="ai-features-card-image-{{ ai_gen_id }}"
                loading="lazy"
                width="800"
                height="600"
              >
            {% else %}
              <div class="ai-features-card-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}

            {% if card_video != blank %}
              <video
                class="ai-features-card-video-{{ ai_gen_id }}"
                {% if video_autoplay %}autoplay{% endif %}
                {% if video_loop %}loop{% endif %}
                {% if video_mute %}muted{% endif %}
                playsinline
                preload="metadata"
              >
                <source src="{{ card_video }}" type="video/mp4">
              </video>
            {% endif %}
          </div>

          <div class="ai-features-card-overlay-{{ ai_gen_id }}"></div>

          <div class="ai-features-card-content-{{ ai_gen_id }}">
            <div class="ai-features-card-text-wrapper-{{ ai_gen_id }}">
              {% if card_title != blank %}
                <h3 class="ai-features-card-title-{{ ai_gen_id }}">{{ card_title }}</h3>
              {% endif %}
              {% if card_subtitle != blank %}
                <p class="ai-features-card-subtitle-{{ ai_gen_id }}">{{ card_subtitle }}</p>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</feature-cards-{{ ai_gen_id }}>

<script>
  (function() {
    class FeatureCards{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.isMobile = window.matchMedia('(max-width: 749px)').matches;
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-features-card-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.cards.forEach((card) => {
          const video = card.querySelector('.ai-features-card-video-{{ ai_gen_id }}');
          
          if (this.isMobile) {
            card.addEventListener('click', () => {
              const isActive = card.classList.contains('active');
              
              this.cards.forEach((c) => {
                c.classList.remove('active');
                const v = c.querySelector('.ai-features-card-video-{{ ai_gen_id }}');
                if (v) {
                  v.pause();
                  v.currentTime = 0;
                }
              });

              if (!isActive) {
                card.classList.add('active');
                if (video) {
                  video.play();
                }
              }
            });
          } else {
            card.addEventListener('mouseenter', () => {
              if (video) {
                video.play();
              }
            });

            card.addEventListener('mouseleave', () => {
              if (video) {
                video.pause();
                video.currentTime = 0;
              }
            });
          }
        });
      }
    }

    customElements.define('feature-cards-{{ ai_gen_id }}', FeatureCards{{ ai_gen_id }});
  })();
</script>

