{% doc %}
  @prompt
    i need a section with horizontal scrolling cards, each card needs an image with height and width options, inside the image a text pill, and below the image up to tree lines on text with size, weight, and color option. and under that a cta that can be a button or a text link , each card needs three individual lines of text, pill needs corner alignment options and text needs to go as small as 8px. each line of text needs color, weight, and size options , each line of text needs padding options above it , get rid of Content spacing. and just ipll radius and padding options , get rid of underline on text link, make vertical padding between each element an option default to 0 , cta needs padding above, section needs height and width padding and a bg color or grdient , need padding option under image, the whole card needs to act as a link, need up to ten cards, get rid of roll over effect and add padding to scroll bar 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-scroll-cards-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px;
    {% if block.settings.section_bg_type == 'color' %}
      background-color: {{ block.settings.section_bg_color }};
    {% else %}
      background: linear-gradient({{ block.settings.gradient_angle }}deg, {{ block.settings.gradient_color_1 }} 0%, {{ block.settings.gradient_color_2 }} 100%);
    {% endif %}
  }

  .ai-scroll-cards-container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    overflow-x: auto;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: {{ block.settings.scrollbar_color }} transparent;
    padding: 0 max(20px, calc((100vw - {{ block.settings.max_width }}px) / 2)) {{ block.settings.scrollbar_padding }}px;
  }

  .ai-scroll-cards-container-{{ ai_gen_id }}::-webkit-scrollbar {
    height: 8px;
  }

  .ai-scroll-cards-container-{{ ai_gen_id }}::-webkit-scrollbar-track {
    background: transparent;
  }

  .ai-scroll-cards-container-{{ ai_gen_id }}::-webkit-scrollbar-thumb {
    background-color: {{ block.settings.scrollbar_color }};
    border-radius: 4px;
  }

  .ai-scroll-card-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.card_width }}px;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .ai-scroll-card-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.image_height }}px;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    margin-bottom: {{ block.settings.image_padding_bottom }}px;
  }

  .ai-scroll-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-scroll-card-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-scroll-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-scroll-card-pill-{{ ai_gen_id }} {
    position: absolute;
    background-color: {{ block.settings.pill_bg_color }};
    color: {{ block.settings.pill_text_color }};
    padding: {{ block.settings.pill_padding_vertical }}px {{ block.settings.pill_padding_horizontal }}px;
    border-radius: {{ block.settings.pill_border_radius }}px;
    font-size: {{ block.settings.pill_font_size }}px;
    font-weight: {{ block.settings.pill_font_weight }};
  }

  .ai-scroll-card-pill-{{ ai_gen_id }}.top-left {
    top: {{ block.settings.pill_offset }}px;
    left: {{ block.settings.pill_offset }}px;
  }

  .ai-scroll-card-pill-{{ ai_gen_id }}.top-right {
    top: {{ block.settings.pill_offset }}px;
    right: {{ block.settings.pill_offset }}px;
  }

  .ai-scroll-card-pill-{{ ai_gen_id }}.bottom-left {
    bottom: {{ block.settings.pill_offset }}px;
    left: {{ block.settings.pill_offset }}px;
  }

  .ai-scroll-card-pill-{{ ai_gen_id }}.bottom-right {
    bottom: {{ block.settings.pill_offset }}px;
    right: {{ block.settings.pill_offset }}px;
  }

  .ai-scroll-card-text-container-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.spacing_text_to_cta }}px;
  }

  .ai-scroll-card-text-line1-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_line1_font_size }}px;
    font-weight: {{ block.settings.text_line1_font_weight }};
    color: {{ block.settings.text_line1_color }};
    line-height: 1.4;
    padding-top: {{ block.settings.text_line1_padding_top }}px;
  }

  .ai-scroll-card-text-line2-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_line2_font_size }}px;
    font-weight: {{ block.settings.text_line2_font_weight }};
    color: {{ block.settings.text_line2_color }};
    line-height: 1.4;
    padding-top: {{ block.settings.text_line2_padding_top }}px;
  }

  .ai-scroll-card-text-line3-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_line3_font_size }}px;
    font-weight: {{ block.settings.text_line3_font_weight }};
    color: {{ block.settings.text_line3_color }};
    line-height: 1.4;
    padding-top: {{ block.settings.text_line3_padding_top }}px;
  }

  .ai-scroll-card-cta-{{ ai_gen_id }} {
    margin-top: auto;
    padding-top: {{ block.settings.cta_padding_top }}px;
  }

  .ai-scroll-card-cta-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.cta_bg_color }};
    color: {{ block.settings.cta_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.cta_border_radius }}px;
    font-size: {{ block.settings.cta_font_size }}px;
    font-weight: {{ block.settings.cta_font_weight }};
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-scroll-card-{{ ai_gen_id }}:hover .ai-scroll-card-cta-button-{{ ai_gen_id }} {
    background-color: {{ block.settings.cta_bg_hover_color }};
    color: {{ block.settings.cta_text_hover_color }};
  }

  .ai-scroll-card-cta-link-{{ ai_gen_id }} {
    display: inline-block;
    color: {{ block.settings.cta_link_color }};
    text-decoration: none;
    font-size: {{ block.settings.cta_font_size }}px;
    font-weight: {{ block.settings.cta_font_weight }};
    transition: color 0.3s ease;
  }

  .ai-scroll-card-{{ ai_gen_id }}:hover .ai-scroll-card-cta-link-{{ ai_gen_id }} {
    color: {{ block.settings.cta_link_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-scroll-cards-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top_mobile }}px {{ block.settings.section_padding_horizontal_mobile }}px {{ block.settings.section_padding_bottom_mobile }}px;
    }

    .ai-scroll-card-{{ ai_gen_id }} {
      flex: 0 0 {{ block.settings.card_width_mobile }}px;
    }

    .ai-scroll-card-image-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.image_height_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-scroll-cards-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-scroll-cards-container-{{ ai_gen_id }}">
    {% for i in (1..10) %}
      {% liquid
       assign show_key = 'card_' | append: i | append: '_show'  
        if block.settings[show_key] != true  
          continue  
        endif  
        assign card_image_key = 'card_' | append: i | append: '_image'
        assign card_pill_key = 'card_' | append: i | append: '_pill_text'
        assign card_text_line1_key = 'card_' | append: i | append: '_text_line1'
        assign card_text_line2_key = 'card_' | append: i | append: '_text_line2'
        assign card_text_line3_key = 'card_' | append: i | append: '_text_line3'
        assign card_cta_text_key = 'card_' | append: i | append: '_cta_text'
        assign card_cta_url_key = 'card_' | append: i | append: '_cta_url'

        assign card_image = block.settings[card_image_key]
        assign card_pill = block.settings[card_pill_key]
        assign card_text_line1 = block.settings[card_text_line1_key]
        assign card_text_line2 = block.settings[card_text_line2_key]
        assign card_text_line3 = block.settings[card_text_line3_key]
        assign card_cta_text = block.settings[card_cta_text_key]
        assign card_cta_url = block.settings[card_cta_url_key]
      %}

      <a
        href="{{ card_cta_url | default: '#' }}"
        class="ai-scroll-card-{{ ai_gen_id }}"
      >
        <div class="ai-scroll-card-image-wrapper-{{ ai_gen_id }}">
          {% if card_image %}
            <img
              src="{{ card_image | image_url: width: 800 }}"
              alt="{{ card_image.alt | escape }}"
              loading="lazy"
              width="{{ card_image.width }}"
              height="{{ card_image.height }}"
              class="ai-scroll-card-image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-scroll-card-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}

          {% if card_pill != blank %}
            <div class="ai-scroll-card-pill-{{ ai_gen_id }} {{ block.settings.pill_position }}">
              {{ card_pill }}
            </div>
          {% endif %}
        </div>

        {% if card_text_line1 != blank or card_text_line2 != blank or card_text_line3 != blank %}
          <div class="ai-scroll-card-text-container-{{ ai_gen_id }}">
            {% if card_text_line1 != blank %}
              <div class="ai-scroll-card-text-line1-{{ ai_gen_id }}">
                {{ card_text_line1 }}
              </div>
            {% endif %}
            {% if card_text_line2 != blank %}
              <div class="ai-scroll-card-text-line2-{{ ai_gen_id }}">
                {{ card_text_line2 }}
              </div>
            {% endif %}
            {% if card_text_line3 != blank %}
              <div class="ai-scroll-card-text-line3-{{ ai_gen_id }}">
                {{ card_text_line3 }}
              </div>
            {% endif %}
          </div>
        {% endif %}

        {% if card_cta_text != blank %}
          <div class="ai-scroll-card-cta-{{ ai_gen_id }}">
            {% if block.settings.cta_style == 'button' %}
              <span class="ai-scroll-card-cta-button-{{ ai_gen_id }}">
                {{ card_cta_text }}
              </span>
            {% else %}
              <span class="ai-scroll-card-cta-link-{{ ai_gen_id }}">
                {{ card_cta_text }}
              </span>
            {% endif %}
          </div>
        {% endif %}
      </a>
    {% endfor %}
  </div>
</div>

