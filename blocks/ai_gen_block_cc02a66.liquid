{% doc %}
  @prompt
    i need a four column section with a background color option, and a photo with ratio options and heading text and papa test below each image. i need size and weight option for all text the should have left and right margin, photos should have a radius option, section should have a max width and text should have left and right margin options, section needs padding option and i need padding options below the image, all options should have desktop and mobile options,, give the bg a gardient option

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .four-column-block-{{ ai_gen_id }} {
    {% if block.settings.use_gradient %}
      background: linear-gradient({{ block.settings.gradient_direction }}deg, {{ block.settings.gradient_color_1 }}, {{ block.settings.gradient_color_2 }});
    {% else %}
      background-color: {{ block.settings.background_color }};
    {% endif %}
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .four-column-container-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    margin: 0 {{ block.settings.horizontal_margin }}px;
    max-width: {{ block.settings.max_width }}px;
    width: 100%;
  }

  .column-item-{{ ai_gen_id }} {
    width: calc(25% - 20px);
    margin-bottom: 30px;
  }

  .column-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    margin-bottom: {{ block.settings.image_bottom_spacing }}px;
    border-radius: {{ block.settings.image_radius }}px;
  }

  .column-image-wrapper-{{ ai_gen_id }}::before {
    content: "";
    display: block;
    padding-bottom: {{ block.settings.image_ratio }}%;
  }

  .column-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: {{ block.settings.image_radius }}px;
  }

  .column-image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_radius }}px;
  }

  .column-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .column-content-{{ ai_gen_id }} {
    margin-left: {{ block.settings.text_margin }}px;
    margin-right: {{ block.settings.text_margin }}px;
  }

  .column-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    margin-top: 0;
    margin-bottom: {{ block.settings.heading_bottom_spacing }}px;
  }

  .column-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    font-weight: {{ block.settings.text_weight }};
    line-height: 1.5;
  }

  @media screen and (max-width: 990px) {
    .column-item-{{ ai_gen_id }} {
      width: calc(50% - 15px);
    }
  }

  @media screen and (max-width: 749px) {
    .four-column-block-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px {{ block.settings.padding_horizontal_mobile }}px {{ block.settings.padding_bottom_mobile }}px;
    }
    
    .four-column-container-{{ ai_gen_id }} {
      margin: 0 {{ block.settings.horizontal_margin_mobile }}px;
    }
    
    .column-item-{{ ai_gen_id }} {
      width: 100%;
    }
    
    .column-image-wrapper-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.image_bottom_spacing_mobile }}px;
    }
    
    .column-content-{{ ai_gen_id }} {
      margin-left: {{ block.settings.text_margin_mobile }}px;
      margin-right: {{ block.settings.text_margin_mobile }}px;
    }
    
    .column-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
      margin-bottom: {{ block.settings.heading_bottom_spacing_mobile }}px;
    }
    
    .column-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="four-column-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="four-column-container-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% assign image_field = 'image_' | append: i %}
      {% assign heading_field = 'heading_' | append: i %}
      {% assign text_field = 'text_' | append: i %}
      
      <div class="column-item-{{ ai_gen_id }}">
        <div class="column-image-wrapper-{{ ai_gen_id }}">
          {% if block.settings[image_field] != blank %}
            <img 
              src="{{ block.settings[image_field] | img_url: '500x' }}" 
              alt="{{ block.settings[heading_field] }}"
              loading="lazy"
              class="column-image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="column-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
        
        <div class="column-content-{{ ai_gen_id }}">
          {% if block.settings[heading_field] != blank %}
            <h3 class="column-heading-{{ ai_gen_id }}">{{ block.settings[heading_field] }}</h3>
          {% endif %}
          
          {% if block.settings[text_field] != blank %}
            <div class="column-text-{{ ai_gen_id }}">{{ block.settings[text_field] }}</div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>

