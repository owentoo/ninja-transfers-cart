{% doc %}
  @prompt
    Create a section to have an h1 and paragrapgh text with all padding and text options for desktop and mobile also give it max width a bg color options, i need a max width for the section and the text container, Content need alignment options right center left, content alignment needs to fis within max section, bg color needs to go full width and add a gradiant option for bg, Make all h1's into h2's

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .text-block-wrapper-{{ ai_gen_id }} {
    width: 100%;
    {% if block.settings.use_gradient %}
      background: linear-gradient(to {{ block.settings.gradient_direction }}, {{ block.settings.gradient_color_1 }}, {{ block.settings.gradient_color_2 }});
    {% else %}
      background-color: {{ block.settings.background_color }};
    {% endif %}
  }

  .text-block-section-{{ ai_gen_id }} {
    max-width: {{ block.settings.section_max_width }}px;
    margin-left: auto;
    margin-right: auto;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_right }}px {{ block.settings.padding_bottom }}px {{ block.settings.padding_left }}px;
    display: flex;
    justify-content: {% if block.settings.content_alignment == 'left' %}flex-start{% elsif block.settings.content_alignment == 'right' %}flex-end{% else %}center{% endif %};
  }

  .text-block-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    width: 100%;
    text-align: {{ block.settings.text_alignment }};
  }

  .text-block-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin-top: 0;
    margin-bottom: {{ block.settings.space_between }}px;
    font-weight: {{ block.settings.heading_weight }};
    line-height: {{ block.settings.heading_line_height }};
    text-align: {{ block.settings.text_alignment }};
  }

  .text-block-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: {{ block.settings.text_line_height }};
    margin: 0;
    text-align: {{ block.settings.text_alignment }};
  }

  @media screen and (max-width: 749px) {
    .text-block-section-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px {{ block.settings.padding_right_mobile }}px {{ block.settings.padding_bottom_mobile }}px {{ block.settings.padding_left_mobile }}px;
    }

    .text-block-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
      margin-bottom: {{ block.settings.space_between_mobile }}px;
      line-height: {{ block.settings.heading_line_height_mobile }};
    }

    .text-block-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
      line-height: {{ block.settings.text_line_height_mobile }};
    }
  }
{% endstyle %}

<div class="text-block-wrapper-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="text-block-section-{{ ai_gen_id }}">
    <div class="text-block-container-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="text-block-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      
      {% if block.settings.text != blank %}
        <div class="text-block-text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
      {% endif %}
    </div>
  </div>
</div>

