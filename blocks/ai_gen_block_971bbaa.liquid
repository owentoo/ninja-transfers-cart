{% doc %}
  @prompt
    i need a section that follows themes max width and all horizontal padding options for desktop and mobile. the section needs a bg color, a radius, and three lines of text , section needs max width, section contents needs max width in px , Background color needs a gradient option. text size options for desktop and mobile, each line of text needs size options for desktop and mobile , background needs gradiant option , every line of text needs weight and color option , all text needs to go from 36-10 in increments of 1
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-text-section-container-{{ ai_gen_id }} {
    max-width: {{ settings.theme_max_width }}px;
    margin: 0 auto;
    padding-left: {{ block.settings.padding_horizontal_desktop }}px;
    padding-right: {{ block.settings.padding_horizontal_desktop }}px;
    padding-top: {{ block.settings.padding_vertical_desktop }}px;
    padding-bottom: {{ block.settings.padding_vertical_desktop }}px;
  }

  .ai-text-section-content-{{ ai_gen_id }} {
    {% if block.settings.use_gradient %}
      background: linear-gradient({{ block.settings.gradient_angle }}deg, {{ block.settings.gradient_color_1 }}, {{ block.settings.gradient_color_2 }});
    {% else %}
      background-color: {{ block.settings.background_color }};
    {% endif %}
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.content_padding_desktop }}px;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.text_spacing }}px;
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
  }

  .ai-text-section-line-{{ ai_gen_id }} {
    margin: 0;
  }

  .ai-text-section-line-1-{{ ai_gen_id }} {
    font-size: {{ block.settings.line_1_size_desktop }}px;
    font-weight: {{ block.settings.line_1_weight }};
    color: {{ block.settings.line_1_color }};
  }

  .ai-text-section-line-2-{{ ai_gen_id }} {
    font-size: {{ block.settings.line_2_size_desktop }}px;
    font-weight: {{ block.settings.line_2_weight }};
    color: {{ block.settings.line_2_color }};
  }

  .ai-text-section-line-3-{{ ai_gen_id }} {
    font-size: {{ block.settings.line_3_size_desktop }}px;
    font-weight: {{ block.settings.line_3_weight }};
    color: {{ block.settings.line_3_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-text-section-container-{{ ai_gen_id }} {
      padding-left: {{ block.settings.padding_horizontal_mobile }}px;
      padding-right: {{ block.settings.padding_horizontal_mobile }}px;
      padding-top: {{ block.settings.padding_vertical_mobile }}px;
      padding-bottom: {{ block.settings.padding_vertical_mobile }}px;
    }

    .ai-text-section-content-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding_mobile }}px;
    }

    .ai-text-section-line-1-{{ ai_gen_id }} {
      font-size: {{ block.settings.line_1_size_mobile }}px;
    }

    .ai-text-section-line-2-{{ ai_gen_id }} {
      font-size: {{ block.settings.line_2_size_mobile }}px;
    }

    .ai-text-section-line-3-{{ ai_gen_id }} {
      font-size: {{ block.settings.line_3_size_mobile }}px;
    }
  }
{% endstyle %}

<text-section-{{ ai_gen_id }} class="ai-text-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-section-container-{{ ai_gen_id }}">
    <div class="ai-text-section-content-{{ ai_gen_id }}">
      {% if block.settings.line_1 != blank %}
        <p class="ai-text-section-line-{{ ai_gen_id }} ai-text-section-line-1-{{ ai_gen_id }}">
          {{ block.settings.line_1 }}
        </p>
      {% endif %}

      {% if block.settings.line_2 != blank %}
        <p class="ai-text-section-line-{{ ai_gen_id }} ai-text-section-line-2-{{ ai_gen_id }}">
          {{ block.settings.line_2 }}
        </p>
      {% endif %}

      {% if block.settings.line_3 != blank %}
        <p class="ai-text-section-line-{{ ai_gen_id }} ai-text-section-line-3-{{ ai_gen_id }}">
          {{ block.settings.line_3 }}
        </p>
      {% endif %}
    </div>
  </div>
</text-section-{{ ai_gen_id }}>

<script>
  (function() {
    class TextSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    customElements.define('text-section-{{ ai_gen_id }}', TextSection{{ ai_gen_id }});
  })();
</script>

