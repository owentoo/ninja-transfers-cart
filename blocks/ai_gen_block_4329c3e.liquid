{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-text-section-{{ ai_gen_id }} {
    width: 100%;
    padding-top: {{ block.settings.vertical_padding_desktop }}px;
    padding-bottom: {{ block.settings.vertical_padding_desktop }}px;
    margin-top: {{ block.settings.vertical_margin_desktop }}px;
    margin-bottom: {{ block.settings.vertical_margin_desktop }}px;
  }

  .ai-video-text-container-{{ ai_gen_id }} {
    max-width: min({{ block.settings.max_width }}px, {{ settings.theme_max_width }}px);
    margin-left: auto;
    margin-right: auto;
    padding-left: {{ block.settings.horizontal_padding_desktop }}px;
    padding-right: {{ block.settings.horizontal_padding_desktop }}px;
    display: grid;
    {% if block.settings.desktop_layout == 'video_right' %}
      grid-template-columns: 1fr {{ block.settings.video_width_desktop }}%;
    {% else %}
      grid-template-columns: {{ block.settings.video_width_desktop }}% 1fr;
    {% endif %}
    gap: {{ block.settings.content_gap_desktop }}px;
    align-items: center;
  }

  .ai-video-text-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap:16px;
    margin-left: {{ block.settings.content_horizontal_margin_desktop }}px;
    margin-right: {{ block.settings.content_horizontal_margin_desktop }}px;
    {% if block.settings.desktop_layout == 'video_right' %}
      order: 1;
    {% else %}
      order: 2;
    {% endif %}
  }

  .ai-video-text-video-container-{{ ai_gen_id }} {
    {% if block.settings.desktop_layout == 'video_right' %}
      order: 2;
    {% else %}
      order: 1;
    {% endif %}}

  .ai-video-text-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size_desktop }}px;
    font-weight: {{ block.settings.heading_weight }};
    color: {{ block.settings.heading_color }};
    text-align: {{ block.settings.text_alignment_desktop }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-video-text-paragraph-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size_desktop }}px;
    font-weight: {{ block.settings.text_weight }};
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_alignment_desktop }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-video-text-cta-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.cta_padding_vertical }}px {{ block.settings.cta_padding_horizontal }}px;
    background-color: {{ block.settings.cta_background_color }};
    color: {{ block.settings.cta_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.cta_border_radius }}px;
    font-size: {{ block.settings.cta_font_size }}px;
    font-weight: {{ block.settings.cta_font_weight }};
    border: {{ block.settings.cta_border_width }}px solid {{ block.settings.cta_border_color }};
    transition: all 0.3s ease;
    cursor: pointer;
    {% if block.settings.text_alignment_desktop == 'center' %}
      align-self: center;
    {% elsif block.settings.text_alignment_desktop == 'right' %}
      align-self: flex-end;
    {% else %}
      align-self: flex-start;
    {% endif %}
  }

  .ai-video-text-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_hover_background_color }};
    color: {{ block.settings.cta_hover_text_color }};
    border-color: {{ block.settings.cta_hover_border_color }};
    transform: translateY(-2px);
  }

  .ai-video-text-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 0;
    padding-bottom: 56.25%;
    border-radius: {{ settings.widgets_border_radius }}px;
    overflow: hidden;
  }

  .ai-video-text-video-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .ai-video-text-play-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: opacity 0.3s ease;z-index: 1;
  }

  .ai-video-text-play-overlay-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-video-text-play-icon-{{ ai_gen_id }} {
    width: {{ block.settings.play_icon_size }}px;
    height: {{ block.settings.play_icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
  }

  .ai-video-text-play-overlay-{{ ai_gen_id }}:hover .ai-video-text-play-icon-{{ ai_gen_id }} {
    transform: scale(1.1);
  }

  .ai-video-text-play-icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-video-text-play-icon-default-{{ ai_gen_id }} {
    background: {{ block.settings.play_icon_color }};
    border-radius: 50%;
  }

  .ai-video-text-play-icon-default-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.play_icon_size }}px * 0.4);
    height: calc({{ block.settings.play_icon_size }}px * 0.4);fill: {{ block.settings.play_icon_arrow_color }};margin-left: 4px;
  }

  .ai-video-text-video-hidden-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-video-text-section-{{ ai_gen_id }} {
      padding-top: {{ block.settings.vertical_padding_mobile }}px;
      padding-bottom: {{ block.settings.vertical_padding_mobile }}px;
      margin-top: {{ block.settings.vertical_margin_mobile }}px;
      margin-bottom: {{ block.settings.vertical_margin_mobile }}px;
    }

    .ai-video-text-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.content_gap_mobile }}px;
      padding-left: {{ block.settings.horizontal_padding_mobile }}px;
      padding-right: {{ block.settings.horizontal_padding_mobile }}px;
    }

    .ai-video-text-content-{{ ai_gen_id }} {
      margin-left: {{ block.settings.content_horizontal_margin_mobile }}px;
      margin-right: {{ block.settings.content_horizontal_margin_mobile }}px;{% if block.settings.mobile_layout == 'content_top' %}
        order: 1;
      {% else %}
        order: 2;
      {% endif %}
    }

    .ai-video-text-video-container-{{ ai_gen_id }} {
      width: {{ block.settings.video_width_mobile }}%;
      margin-left: auto;
      margin-right: auto;
      {% if block.settings.mobile_layout == 'content_top' %}
        order: 2;
      {% else %}
        order: 1;
      {% endif %}
    }

    .ai-video-text-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
      text-align: {{ block.settings.text_alignment_mobile }};
    }

    .ai-video-text-paragraph-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
      text-align: {{ block.settings.text_alignment_mobile }};
    }

    .ai-video-text-cta-{{ ai_gen_id }} {
      font-size: {{ block.settings.cta_font_size_mobile }}px;
      padding: {{ block.settings.cta_padding_vertical_mobile }}px {{ block.settings.cta_padding_horizontal_mobile }}px;
      {% if block.settings.text_alignment_mobile == 'center' %}
        align-self: center;
      {% elsif block.settings.text_alignment_mobile == 'right' %}
        align-self: flex-end;
      {% else %}
        align-self: flex-start;
      {% endif %}
    }

    .ai-video-text-play-icon-{{ ai_gen_id }} {
      width: {{ block.settings.play_icon_size | times: 0.75 }}px;
      height: {{ block.settings.play_icon_size | times: 0.75 }}px;}

    .ai-video-text-play-icon-default-{{ ai_gen_id }} svg {
      width: calc({{ block.settings.play_icon_size | times: 0.75 }}px * 0.4);
      height: calc({{ block.settings.play_icon_size | times: 0.75 }}px * 0.4);
    }
  }
{% endstyle %}

<video-text-section-{{ ai_gen_id }} class="ai-video-text-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-video-text-container-{{ ai_gen_id }}">
    <div class="ai-video-text-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-video-text-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.text != blank %}
        <div class="ai-video-text-paragraph-{{ ai_gen_id }}">{{ block.settings.text }}</div>
      {% endif %}
      {% if block.settings.show_cta and block.settings.cta_text != blank %}
        <a 
          href="{{ block.settings.cta_link }}" 
          class="ai-video-text-cta-{{ ai_gen_id }}"
          {% if block.settings.cta_link == blank %}onclick="return false;"{% endif %}
        >
          {{ block.settings.cta_text }}
        </a>
      {% endif %}
    </div><div class="ai-video-text-video-container-{{ ai_gen_id }}"><div class="ai-video-text-video-wrapper-{{ ai_gen_id }}">
        {% if block.settings.show_play_icon %}
          <div class="ai-video-text-play-overlay-{{ ai_gen_id }}" data-video-overlay>
            <div class="ai-video-text-play-icon-{{ ai_gen_id }} {% unless block.settings.custom_play_icon %}ai-video-text-play-icon-default-{{ ai_gen_id }}{% endunless %}">
              {% if block.settings.custom_play_icon %}
                <img
                  src="{{ block.settings.custom_play_icon | image_url: width: 200}}"
                  alt="Play video"
                  width="{{ block.settings.play_icon_size }}"
                  height="{{ block.settings.play_icon_size }}"
                  loading="lazy"
                >
              {% else %}
                <svg viewBox="0 0 24 24">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              {% endif %}
            </div>
          </div>
        {% endif %}

        {% if block.settings.youtube_url != blank %}
          <iframe
            class="ai-video-text-video-{{ ai_gen_id }} {% if block.settings.show_play_icon %}ai-video-text-video-hidden-{{ ai_gen_id }}{% endif %}"
            data-video-iframe
            {% unless block.settings.show_play_icon %}src="{{ block.settings.youtube_url }}"{% endunless %}
            title="YouTube video player"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        {% else %}
          <div class="ai-video-text-video-{{ ai_gen_id }}" style="background: #f4f4f4; display: flex; align-items: center; justify-content: center; color: #666;">
            <span>YouTube video will appear here</span>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</video-text-section-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoTextSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.overlay = this.querySelector('[data-video-overlay]');
        this.iframe = this.querySelector('[data-video-iframe]');
        
        if (this.overlay && this.iframe) {
          this.setupVideoPlayback();
        }
      }

      setupVideoPlayback() {
        this.overlay.addEventListener('click', () => {
          const youtubeUrl = '{{ block.settings.youtube_url }}';
          if (youtubeUrl) {
            this.iframe.src = youtubeUrl + '&autoplay=1';
            this.iframe.classList.remove('ai-video-text-video-hidden-{{ ai_gen_id }}');
            this.overlay.style.display = 'none';
          }
        });
      }
    }

    customElements.define('video-text-section-{{ ai_gen_id }}', VideoTextSection{{ ai_gen_id }});
  })();
</script>

