{% doc %}
  @prompt
    need to create a full width link block with text on the left and an arrow on the right with an optinal top a botton line , need horizontal padding option in increments of 2, horizontal padding should apply to boarders, can i have options for types of arrows
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-link-block-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    text-decoration: none;
    position: relative;
  }

  .ai-link-block-wrapper-{{ ai_gen_id }} {
    padding: 0 {{ block.settings.padding_horizontal }}px;
  }

  .ai-link-block-container-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: {{ block.settings.padding_vertical }}px 0;
    background-color: {{ block.settings.background_color }};
    transition: background-color 0.3s ease;
    {% if block.settings.show_top_border %}
      border-top: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    {% endif %}
    {% if block.settings.show_bottom_border %}
      border-bottom: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    {% endif %}
  }

  .ai-link-block-{{ ai_gen_id }}:hover .ai-link-block-container-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_hover_color }};
  }

  .ai-link-block-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    margin: 0;
    transition: color 0.3s ease;
  }

  .ai-link-block-{{ ai_gen_id }}:hover .ai-link-block-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_hover_color }};
  }

  .ai-link-block-arrow-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-left: 16px;
    transition: transform 0.3s ease, color 0.3s ease;
    color: {{ block.settings.arrow_color }};
  }

  .ai-link-block-{{ ai_gen_id }}:hover .ai-link-block-arrow-{{ ai_gen_id }} {
    transform: translateX(4px);
    color: {{ block.settings.arrow_hover_color }};
  }

  .ai-link-block-arrow-{{ ai_gen_id }} svg {
    width: {{ block.settings.arrow_size }}px;
    height: {{ block.settings.arrow_size }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-link-block-wrapper-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.padding_horizontal | times: 0.75 }}px;
    }

    .ai-link-block-container-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_vertical | times: 0.75 }}px 0;
    }

    .ai-link-block-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
    }

    .ai-link-block-arrow-{{ ai_gen_id }} svg {
      width: {{ block.settings.arrow_size | times: 0.85 }}px;
      height: {{ block.settings.arrow_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<a
  href="{{ block.settings.link_url }}"
  class="ai-link-block-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
  {% if block.settings.link_url == blank %}aria-disabled="true"{% endif %}
>
  <div class="ai-link-block-wrapper-{{ ai_gen_id }}">
    <div class="ai-link-block-container-{{ ai_gen_id }}">
      <div class="ai-link-block-text-{{ ai_gen_id }}">
        {{ block.settings.link_text }}
      </div>
      <div class="ai-link-block-arrow-{{ ai_gen_id }}">
        {% if block.settings.arrow_style == 'arrow_right' %}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        {% elsif block.settings.arrow_style == 'chevron_right' %}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        {% elsif block.settings.arrow_style == 'angle_right' %}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="10 17 15 12 10 7"></polyline>
          </svg>
        {% elsif block.settings.arrow_style == 'caret_right' %}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path d="M9 5l7 7-7 7V5z"></path>
          </svg>
        {% elsif block.settings.arrow_style == 'plus' %}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
        {% endif %}
      </div>
    </div>
  </div>
</a>

{% schema %}
{
  "name": "Full width link",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link text",
      "default": "View all products"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "header",
      "content": "Text style"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 16
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "500"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_hover_color",
      "label": "Text hover color",
      "default": "#019aff"
    },
    {
      "type": "header",
      "content": "Arrow"
    },
    {
      "type": "select",
      "id": "arrow_style",
      "label": "Arrow style",
      "options": [
        {
          "value": "arrow_right",
          "label": "Arrow right"
        },
        {
          "value": "chevron_right",
          "label": "Chevron right"
        },
        {
          "value": "angle_right",
          "label": "Angle right"
        },
        {
          "value": "caret_right",
          "label": "Caret right"
        },
        {
          "value": "plus",
          "label": "Plus"
        }
      ],
      "default": "arrow_right"
    },
    {
      "type": "range",
      "id": "arrow_size",
      "min": 16,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Arrow size",
      "default": 20
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Arrow color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "arrow_hover_color",
      "label": "Arrow hover color",
      "default": "#019aff"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "background_hover_color",
      "label": "Background hover color",
      "default": "#f2f2f2"
    },
    {
      "type": "header",
      "content": "Borders"
    },
    {
      "type": "checkbox",
      "id": "show_top_border",
      "label": "Show top border",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_bottom_border",
      "label": "Show bottom border",
      "default": true
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 1,
      "max": 5,
      "step": 1,
      "unit": "px",
      "label": "Border width",
      "default": 1
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e5e5e5"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Vertical padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Full width link"
    }
  ]
}
{% endschema %}
