                </div>
              {% endif %}

              {% if card_2_show_button and card_2_button_text != blank %}
                <span class="ai-card-button-{{ ai_gen_id }}">
                  {{ card_2_button_text }}
                </span>
              {% endif %}
            </div>
          </div>
        </a>
      {% endif %}

      {% assign card_3_title = block.settings.card_3_title %}
      {% assign card_3_subtext = block.settings.card_3_subtext %}
      {% assign card_3_description = block.settings.card_3_description %}
      {% assign card_3_button_text = block.settings.card_3_button_text %}
      {% assign card_3_link = block.settings.card_3_link %}
      {% assign card_3_image = block.settings.card_3_image %}
      {% assign card_3_badge = block.settings.card_3_badge %}
      {% assign card_3_show_badge = block.settings.card_3_show_badge %}
      {% assign card_3_show_subtext = block.settings.card_3_show_subtext %}
      {% assign card_3_show_description = block.settings.card_3_show_description %}
      {% assign card_3_show_button = block.settings.card_3_show_button %}
      {% assign card_3_hide_desktop = block.settings.card_3_hide_desktop %}
      {% assign card_3_hide_tablet = block.settings.card_3_hide_tablet %}
      {% assign card_3_hide_mobile = block.settings.card_3_hide_mobile %}
      {% assign card_3_custom_class = block.settings.card_3_custom_class %}

      {% if card_3_title != blank or card_3_image %}
        <a
          href="{% if card_3_link != blank %}{{ card_3_link }}{% else %}#{% endif %}"
          class="ai-card-item-{{ ai_gen_id }} {{ card_3_custom_class }}
            {% if card_3_hide_desktop %}ai-card-hide-desktop-{{ ai_gen_id }}{% endif %}
            {% if card_3_hide_tablet %}ai-card-hide-tablet-{{ ai_gen_id }}{% endif %}
            {% if card_3_hide_mobile %}ai-card-hide-mobile-{{ ai_gen_id }}{% endif %}"
        >
          <div class="ai-card-content-wrapper-{{ ai_gen_id }}">
            <div class="ai-card-image-wrapper-{{ ai_gen_id }}">
              {% if card_3_image %}
                <img
                  src="{{ card_3_image | image_url: width: 800 }}"
                  alt="{{ card_3_image.alt | escape }}"
                  loading="lazy"
                  width="{{ card_3_image.width }}"
                  height="{{ card_3_image.height }}"
                  class="ai-card-image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-card-image-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}

              {% if card_3_show_badge and card_3_badge != blank %}
                <div class="ai-card-badge-{{ ai_gen_id }}">
                  {{ card_3_badge }}
                </div>
              {% endif %}
            </div>

            <div class="ai-card-text-content-{{ ai_gen_id }}">
              {% if card_3_title != blank %}
                <h3 class="ai-card-title-{{ ai_gen_id }}">{{ card_3_title }}</h3>
              {% endif %}

              {% if card_3_show_subtext and card_3_subtext != blank %}
                <p class="ai-card-subtext-{{ ai_gen_id }}">{{ card_3_subtext }}</p>
              {% endif %}

              {% if card_3_show_description and card_3_description != blank %}
                <div class="ai-card-description-{{ ai_gen_id }}">
                  {{ card_3_description }}
                </div>
              {% endif %}

              {% if card_3_show_button and card_3_button_text != blank %}
                <span class="ai-card-button-{{ ai_gen_id }}">
                  {{ card_3_button_text }}
                </span>
              {% endif %}
            </div>
          </div>
        </a>
      {% endif %}
    </div>
  </div>
</product-card-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductCardGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.init();
      }

      init() {
      }
    }

    customElements.define('product-card-grid-{{ ai_gen_id }}', ProductCardGrid{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Product card grid",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "label": "Columns desktop",
      "default": 3
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "1"
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Gap",
      "default": 24
    },
    {
      "type": "checkbox",
      "id": "equal_height",
      "label": "Equal height cards",
      "default": true
    },
    {
      "type": "header",
      "content": "Section width"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        {
          "value": "full",
          "label": "Full width"
        },
        {
          "value": "wide",
          "label": "Wide"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ],
      "default": "wide"
    },
    {
      "type": "range",
      "id": "section_custom_width",
      "min": 800,
      "max": 2000,
      "step": 50,
      "unit": "px",
      "label": "Custom width",
      "default": 1200
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "section_padding_desktop",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Desktop",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_mobile",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Mobile",
      "default": 40
    },
    {
