{% doc %}
  @prompt
    i need a section with four steps, each step has an image with a number in a box inside the image and two lines of text below each image give me desktop and mobile optiopns. , section needs max width in px, with horizontal padding that falls within max width for desktop and mobile. , text needs alignment options.  , all text needs size options for desktop and mobile, Space below image, Space between steps both need desktop and mobile options, both lines of text nee color options. number box should have alignments to corners only and padding from edge option for desktop and mobile , number box Background color needs opacity option. and all padding should be it multiples of 2 and 5 , i don't see background color box
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  assign bg_color_rgb = block.settings.number_box_bg_color | color_extract: 'red' | append: ', ' | append: block.settings.number_box_bg_color | color_extract: 'green' | append: ', ' | append: block.settings.number_box_bg_color | color_extract: 'blue'
  assign bg_opacity = block.settings.number_box_bg_opacity | divided_by: 100.0
%}

{% style %}
  .ai-steps-container-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-steps-inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.desktop_horizontal_padding }}px;
  }

  .ai-steps-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.desktop_columns }}, 1fr);
    gap: {{ block.settings.desktop_grid_gap }}px;
  }

  .ai-step-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .ai-step-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    margin-bottom: {{ block.settings.desktop_image_text_spacing }}px;
  }

  .ai-step-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: block;
  }

  .ai-step-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-step-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-step-number-box-{{ ai_gen_id }} {
    position: absolute;
    background-color: rgba({{ bg_color_rgb }}, {{ bg_opacity }});
    color: {{ block.settings.number_box_text_color }};
    width: {{ block.settings.number_box_size }}px;
    height: {{ block.settings.number_box_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: {{ block.settings.desktop_number_font_size }}px;
    font-weight: 700;
    border-radius: {{ block.settings.number_box_border_radius }}px;
    font-family: {{ block.settings.number_font.family }}, {{ block.settings.number_font.fallback_families }};
  }

  {% if block.settings.number_box_position == 'top-left' %}
    .ai-step-number-box-{{ ai_gen_id }} {
      top: {{ block.settings.desktop_number_box_padding }}px;
      left: {{ block.settings.desktop_number_box_padding }}px;
    }
  {% elsif block.settings.number_box_position == 'top-right' %}
    .ai-step-number-box-{{ ai_gen_id }} {
      top: {{ block.settings.desktop_number_box_padding }}px;
      right: {{ block.settings.desktop_number_box_padding }}px;
    }
  {% elsif block.settings.number_box_position == 'bottom-left' %}
    .ai-step-number-box-{{ ai_gen_id }} {
      bottom: {{ block.settings.desktop_number_box_padding }}px;
      left: {{ block.settings.desktop_number_box_padding }}px;
    }
  {% elsif block.settings.number_box_position == 'bottom-right' %}
    .ai-step-number-box-{{ ai_gen_id }} {
      bottom: {{ block.settings.desktop_number_box_padding }}px;
      right: {{ block.settings.desktop_number_box_padding }}px;
    }
  {% endif %}

  .ai-step-text-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.text_line_spacing }}px;
    width: 100%;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-step-text-line-{{ ai_gen_id }} {
    margin: 0;
    font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
  }

  .ai-step-text-line-{{ ai_gen_id }}:first-child {
    font-size: {{ block.settings.desktop_text_line_1_size }}px;
    font-weight: {{ block.settings.text_line_1_weight }};
    color: {{ block.settings.text_line_1_color }};
  }

  .ai-step-text-line-{{ ai_gen_id }}:last-child {
    font-size: {{ block.settings.desktop_text_line_2_size }}px;
    font-weight: {{ block.settings.text_line_2_weight }};
    color: {{ block.settings.text_line_2_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-steps-inner-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.mobile_horizontal_padding }}px;
    }

    .ai-steps-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.mobile_columns }}, 1fr);
      gap: {{ block.settings.mobile_grid_gap }}px;
    }

    .ai-step-image-wrapper-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.mobile_image_text_spacing }}px;
    }

    .ai-step-number-box-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_number_box_size }}px;
      height: {{ block.settings.mobile_number_box_size }}px;
      font-size: {{ block.settings.mobile_number_font_size }}px;
    }

    {% if block.settings.number_box_position == 'top-left' %}
      .ai-step-number-box-{{ ai_gen_id }} {
        top: {{ block.settings.mobile_number_box_padding }}px;
        left: {{ block.settings.mobile_number_box_padding }}px;
      }
    {% elsif block.settings.number_box_position == 'top-right' %}
      .ai-step-number-box-{{ ai_gen_id }} {
        top: {{ block.settings.mobile_number_box_padding }}px;
        right: {{ block.settings.mobile_number_box_padding }}px;
      }
    {% elsif block.settings.number_box_position == 'bottom-left' %}
      .ai-step-number-box-{{ ai_gen_id }} {
        bottom: {{ block.settings.mobile_number_box_padding }}px;
        left: {{ block.settings.mobile_number_box_padding }}px;
      }
    {% elsif block.settings.number_box_position == 'bottom-right' %}
      .ai-step-number-box-{{ ai_gen_id }} {
        bottom: {{ block.settings.mobile_number_box_padding }}px;
        right: {{ block.settings.mobile_number_box_padding }}px;
      }
    {% endif %}

    .ai-step-text-line-{{ ai_gen_id }}:first-child {
      font-size: {{ block.settings.mobile_text_line_1_size }}px;
    }

    .ai-step-text-line-{{ ai_gen_id }}:last-child {
      font-size: {{ block.settings.mobile_text_line_2_size }}px;
    }

    .ai-step-text-wrapper-{{ ai_gen_id }} {
      text-align: {{ block.settings.mobile_text_alignment }};
    }
  }
{% endstyle %}

<div class="ai-steps-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-steps-inner-{{ ai_gen_id }}">
    <div class="ai-steps-grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign image_key = 'step_' | append: i | append: '_image'
          assign text_1_key = 'step_' | append: i | append: '_text_line_1'
          assign text_2_key = 'step_' | append: i | append: '_text_line_2'
          
          assign step_image = block.settings[image_key]
          assign step_text_1 = block.settings[text_1_key]
          assign step_text_2 = block.settings[text_2_key]
        %}
        
        <div class="ai-step-item-{{ ai_gen_id }}">
          <div class="ai-step-image-wrapper-{{ ai_gen_id }}">
            {% if step_image %}
              <img
                src="{{ step_image | image_url: width: 800 }}"
                alt="{{ step_image.alt | escape }}"
                loading="lazy"
                width="{{ step_image.width }}"
                height="{{ step_image.height }}"
                class="ai-step-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-step-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
            
            <div class="ai-step-number-box-{{ ai_gen_id }}">
              {{ i }}
            </div>
          </div>
          
          <div class="ai-step-text-wrapper-{{ ai_gen_id }}">
            {% if step_text_1 != blank %}
              <p class="ai-step-text-line-{{ ai_gen_id }}">{{ step_text_1 }}</p>
            {% endif %}
            {% if step_text_2 != blank %}
              <p class="ai-step-text-line-{{ ai_gen_id }}">{{ step_text_2 }}</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

