{% doc %}
  @prompt
    i need a section with 3 blocks, with an image large and small text under each. 3 accross on desktop, 1.25 with overflow on mobile, section needs max width option , each image needs large and small text under it , desktop and mobile needs horizontal padding section options, and text alaignment options , horizontal padding should effect the Maximum width , need fomts size option for desktop and mobile 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-image-grid__wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.desktop_horizontal_padding }}px;
  }

  .ai-image-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    width: 100%;
  }

  .ai-image-grid__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.text_spacing }}px;
  }

  .ai-image-grid__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.image_background }};
  }

  .ai-image-grid__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-image-grid__placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-image-grid__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-image-grid__text-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.text_gap }}px;
  }

  .ai-image-grid__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size_desktop }}px;
    line-height: 1.2;
    color: {{ block.settings.heading_color }};
    text-align: {{ block.settings.text_alignment }};
    margin: 0;
  }

  .ai-image-grid__text-{{ ai_gen_id }} {
    font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
    font-weight: {{ block.settings.text_font.weight }};
    font-size: {{ block.settings.text_size_desktop }}px;
    line-height: 1.4;
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  @media screen and (max-width: 749px) {
    .ai-image-grid__wrapper-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.mobile_horizontal_padding }}px;
    }

    .ai-image-grid__container-{{ ai_gen_id }} {
      display: flex;
      overflow-x: auto;
      gap: {{ block.settings.mobile_gap }}px;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    .ai-image-grid__container-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    .ai-image-grid__item-{{ ai_gen_id }} {
      flex: 0 0 80%;
      scroll-snap-align: start;
    }

    .ai-image-grid__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
      text-align: {{ block.settings.mobile_text_alignment }};
    }

    .ai-image-grid__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
      text-align: {{ block.settings.mobile_text_alignment }};
    }
  }
{% endstyle %}

<div class="ai-image-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-grid__wrapper-{{ ai_gen_id }}">
    <div class="ai-image-grid__container-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign heading_key = 'heading_' | append: i
          assign text_key = 'text_' | append: i
          assign image = block.settings[image_key]
          assign heading = block.settings[heading_key]
          assign text = block.settings[text_key]
        %}
        
        <div class="ai-image-grid__item-{{ ai_gen_id }}">
          <div class="ai-image-grid__image-wrapper-{{ ai_gen_id }}">
            {% if image %}
              <img
                src="{{ image | image_url: width: 800 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
                class="ai-image-grid__image-{{ ai_gen_id }}"
                style="aspect-ratio: {{ block.settings.image_aspect_ratio }}; object-fit: cover;"
              >
            {% else %}
              <div class="ai-image-grid__placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          
          <div class="ai-image-grid__text-content-{{ ai_gen_id }}">
            {% if heading != blank %}
              <h3 class="ai-image-grid__heading-{{ ai_gen_id }}">
                {{ heading }}
              </h3>
            {% endif %}
            
            {% if text != blank %}
              <div class="ai-image-grid__text-{{ ai_gen_id }}">
                {{ text }}
              </div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

