{% doc %}
  @prompt
    make a divider line with a color and horizaontal and vertical padding, make all setting move in increments of 2, make thinkness from 1 to 10 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-divider-{{ ai_gen_id }} {
    padding-top: {{ block.settings.vertical_padding }}px;
    padding-bottom: {{ block.settings.vertical_padding }}px;
    padding-left: {{ block.settings.horizontal_padding }}px;
    padding-right: {{ block.settings.horizontal_padding }}px;
  }

  .ai-divider-line-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.line_thickness }}px;
    background-color: {{ block.settings.line_color }};
    border: none;
    margin: 0;
  }
{% endstyle %}

<div class="ai-divider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <hr class="ai-divider-line-{{ ai_gen_id }}">
</div>

{% schema %}
{
  "name": "Divider line",
  "settings": [
    {
      "type": "header",
      "content": "Line style"
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "line_thickness",
      "label": "Thickness",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "vertical_padding",
      "label": "Vertical padding",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "horizontal_padding",
      "label": "Horizontal padding",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Divider line"
    }
  ]
}
{% endschema %}
