{% doc %}
  @prompt
    make me a section with scrollable pictures, each one needs a link. give ratio options, image width needs to be percentage based, needs doot to show how many slides there are, have options to have dots inside or below images, with padding options. and give me more landscape options, dots should always be there not disappear with slide, dots inside image is not working , get rid of heading, width should be one setting not desktop and mobile, add horizontal padding and let image go the to edge , get rid of caption, get rid of hover zoom. make sure they snap to image, image should always be 100% width, dots need to be centered, no Gap between images each slide should be 100 width of screen, each image is a screen that is full width with horizontal padding. schroll spas to next image, padding needs to be in increments of 2, Dot color needs an active and inactive color. add option for custom height of image
    
    mnake sure dots are visable on mobile, add option for dot size, add image radius option
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-scrollable-gallery-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-scrollable-gallery__wrapper-{{ ai_gen_id }} {
    display: flex;
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .ai-scrollable-gallery__wrapper-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-scrollable-gallery__slide-{{ ai_gen_id }} {
    flex: 0 0 100%;
    scroll-snap-align: start;
    padding: 0 {{ block.settings.horizontal_padding }}px;
    box-sizing: border-box;
  }

  .ai-scrollable-gallery__link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: 100%;
  }

  .ai-scrollable-gallery__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    {% if block.settings.use_custom_height %}
      height: {{ block.settings.custom_height }}px;
    {% else %}
      padding-bottom: {{ 100 | divided_by: block.settings.aspect_ratio }}%;
    {% endif %}
    overflow: hidden;
    border-radius: {{ block.settings.image_radius }}px;
  }

  .ai-scrollable-gallery__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-scrollable-gallery__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-scrollable-gallery__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-scrollable-gallery__dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    {% if block.settings.dots_position == 'inside' %}
      position: absolute;
      bottom: {{ block.settings.dots_padding }}px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 10;
    {% else %}
      margin-top: {{ block.settings.dots_padding }}px;
    {% endif %}
  }

  .ai-scrollable-gallery__dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color_inactive }};
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-scrollable-gallery__dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_color_active }};
  }
{% endstyle %}

<scrollable-gallery-{{ ai_gen_id }} class="ai-scrollable-gallery-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-scrollable-gallery__wrapper-{{ ai_gen_id }}">
    {% for i in (1..10) %}
      {% liquid
        assign image_key = 'image_' | append: i
        assign link_key = 'link_' | append: i
        assign image = block.settings[image_key]
        assign link = block.settings[link_key]
      %}
      
      {% if image != blank or link != blank %}
        <div class="ai-scrollable-gallery__slide-{{ ai_gen_id }}">
          {% if link != blank %}
            <a href="{{ link }}" class="ai-scrollable-gallery__link-{{ ai_gen_id }}">
          {% endif %}
            <div class="ai-scrollable-gallery__image-wrapper-{{ ai_gen_id }}">
              {% if image != blank %}
                <img
                  src="{{ image | image_url: width: 2000 }}"
                  alt="{{ image.alt | escape }}"
                  loading="lazy"
                  class="ai-scrollable-gallery__image-{{ ai_gen_id }}"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                >
              {% else %}
                <div class="ai-scrollable-gallery__placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
          {% if link != blank %}
            </a>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="ai-scrollable-gallery__dots-{{ ai_gen_id }}"></div>
</scrollable-gallery-{{ ai_gen_id }}>

<script>
  (function() {
    class ScrollableGallery{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.wrapper = this.querySelector('.ai-scrollable-gallery__wrapper-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('.ai-scrollable-gallery__dots-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-scrollable-gallery__slide-{{ ai_gen_id }}');
        this.currentIndex = 0;
      }

      connectedCallback() {
        this.createDots();
        this.setupEventListeners();
        this.updateActiveDot();
      }

      createDots() {
        this.slides.forEach((slide, index) => {
          const dot = document.createElement('button');
          dot.classList.add('ai-scrollable-gallery__dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', `Go to slide ${index + 1}`);
          dot.addEventListener('click', () => this.scrollToSlide(index));
          this.dotsContainer.appendChild(dot);
        });
        this.dots = this.querySelectorAll('.ai-scrollable-gallery__dot-{{ ai_gen_id }}');
      }

      setupEventListeners() {
        this.wrapper.addEventListener('scroll', () => {
          this.handleScroll();
        });
      }

      handleScroll() {
        const scrollLeft = this.wrapper.scrollLeft;
        const slideWidth = this.wrapper.offsetWidth;
        const newIndex = Math.round(scrollLeft / slideWidth);
        
        if (newIndex !== this.currentIndex) {
          this.currentIndex = newIndex;
          this.updateActiveDot();
        }
      }

      scrollToSlide(index) {
        const slideWidth = this.wrapper.offsetWidth;
        this.wrapper.scrollTo({
          left: slideWidth * index,
          behavior: 'smooth'
        });
      }

      updateActiveDot() {
        this.dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }
    }

    customElements.define('scrollable-gallery-{{ ai_gen_id }}', ScrollableGallery{{ ai_gen_id }});
  })();
</script>

