{% doc %}
  @prompt
    make me a section that follows the themes horizontal max width padding and margin. with a left aligned text link with font weight, color, and size options for desktop and mobile, no underline, and give me the ability to add a full width bg color. I also need top and bottom padding and margin options, add an option to add an icon to the right or left of the link with padding and size options for desktop and mobile

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-link-section-{{ ai_gen_id }} {
    width: 100%;
    background-color: {{ block.settings.background_color }};
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
  }

  .ai-text-link-container-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ settings.theme_max_width }}px;
    padding-left: {{ block.settings.horizontal_padding }}px;
    padding-right: {{ block.settings.horizontal_padding }}px;
    margin-left: auto;
    margin-right: auto;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
  }

  .ai-text-link-wrapper-{{ ai_gen_id }} {
    text-align: left;
  }

  .ai-text-link-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    font-weight: {{ block.settings.font_weight }};
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size_desktop }}px;
    text-decoration: none;
    transition: color 0.3s ease, opacity 0.3s ease;
  }

  .ai-text-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.text_hover_color }};
    opacity: 0.9;
  }

  .ai-text-link-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size_desktop }}px;
    height: {{ block.settings.icon_size_desktop }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    {% if block.settings.icon_position == 'left' %}
      margin-right: {{ block.settings.icon_padding_desktop }}px;
    {% else %}
      margin-left: {{ block.settings.icon_padding_desktop }}px;
    {% endif %}
  }

  .ai-text-link-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  @media screen and (max-width: 749px) {
    .ai-text-link-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size_mobile }}px;
    }
    
    .ai-text-link-container-{{ ai_gen_id }} {
      padding-left: {{ block.settings.horizontal_padding_mobile }}px;
      padding-right: {{ block.settings.horizontal_padding_mobile }}px;
      padding-top: {{ block.settings.padding_top_mobile }}px;
      padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-text-link-section-{{ ai_gen_id }} {
      margin-top: {{ block.settings.margin_top_mobile }}px;
      margin-bottom: {{ block.settings.margin_bottom_mobile }}px;
    }

    .ai-text-link-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size_mobile }}px;
      height: {{ block.settings.icon_size_mobile }}px;
      {% if block.settings.icon_position == 'left' %}
        margin-right: {{ block.settings.icon_padding_mobile }}px;
      {% else %}
        margin-left: {{ block.settings.icon_padding_mobile }}px;
      {% endif %}
    }
  }
{% endstyle %}

<div class="ai-text-link-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-link-container-{{ ai_gen_id }}">
    <div class="ai-text-link-wrapper-{{ ai_gen_id }}">
      <a href="{{ block.settings.link }}" class="ai-text-link-{{ ai_gen_id }}">
        {% if block.settings.show_icon and block.settings.icon_position == 'left' %}
          <span class="ai-text-link-icon-{{ ai_gen_id }}">
            {% case block.settings.icon_type %}
              {% when 'arrow-right' %}
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M13.025 1l-2.847 2.828 6.176 6.176h-16.354v3.992h16.354l-6.176 6.176 2.847 2.828 10.975-11z"/>
                </svg>
              {% when 'arrow-left' %}
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M10.975 23l2.847-2.828-6.176-6.176h16.354v-3.992h-16.354l6.176-6.176-2.847-2.828-10.975 11z"/>
                </svg>
              {% when 'plus' %}
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M24 10h-10v-10h-4v10h-10v4h10v10h4v-10h10z"/>
                </svg>
              {% when 'circle' %}
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="12" cy="12" r="12"/>
                </svg>
            {% endcase %}
          </span>
        {% endif %}
        
        {{ block.settings.text }}
        
        {% if block.settings.show_icon and block.settings.icon_position == 'right' %}
          <span class="ai-text-link-icon-{{ ai_gen_id }}">
            {% case block.settings.icon_type %}
              {% when 'arrow-right' %}
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M13.025 1l-2.847 2.828 6.176 6.176h-16.354v3.992h16.354l-6.176 6.176 2.847 2.828 10.975-11z"/>
                </svg>
              {% when 'arrow-left' %}
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M10.975 23l2.847-2.828-6.176-6.176h16.354v-3.992h-16.354l6.176-6.176-2.847-2.828-10.975 11z"/>
                </svg>
              {% when 'plus' %}
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M24 10h-10v-10h-4v10h-10v4h10v10h4v-10h10z"/>
                </svg>
              {% when 'circle' %}
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="12" cy="12" r="12"/>
                </svg>
            {% endcase %}
          </span>
        {% endif %}
      </a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Text Link",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Link text",
      "default": "View more"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link URL"
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show icon",
      "default": true
    },
    {
      "type": "select",
      "id": "icon_type",
      "label": "Icon type",
      "options": [
        {
          "value": "arrow-right",
          "label": "Arrow right"
        },
        {
          "value": "arrow-left",
          "label": "Arrow left"
        },
        {
          "value": "plus",
          "label": "Plus"
        },
        {
          "value": "circle",
          "label": "Circle"
        }
      ],
      "default": "arrow-right"
    },
    {
      "type": "select",
      "id": "icon_position",
      "label": "Icon position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "right"
    },
    {
      "type": "range",
      "id": "icon_size_desktop",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Icon size (desktop)",
      "default": 16
    },
    {
      "type": "range",
      "id": "icon_padding_desktop",
      "min": 4,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Icon padding (desktop)",
      "default": 8
    },
    {
      "type": "range",
      "id": "icon_size_mobile",
      "min": 8,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Icon size (mobile)",
      "default": 14
    },
    {
      "type": "range",
      "id": "icon_padding_mobile",
      "min": 4,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Icon padding (mobile)",
      "default": 6
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Regular"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semibold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "400"
    },
    {
      "type": "range",
      "id": "font_size_desktop",
      "min": 12,
      "max": 36,
      "step": 1,
      "unit": "px",
      "label": "Font size (desktop)",
      "default": 16
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font size (mobile)",
      "default": 14
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "rgba(0,0,0,0)"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_hover_color",
      "label": "Text hover color",
      "default": "#019aff"
    },
    {
      "type": "header",
      "content": "Padding (Desktop)"
    },
    {
      "type": "range",
      "id": "horizontal_padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 20
    },
    {
      "type": "header",
      "content": "Margin (Desktop)"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top margin",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom margin",
      "default": 0
    },
    {
      "type": "header",
      "content": "Padding (Mobile)"
    },
    {
      "type": "range",
      "id": "horizontal_padding_mobile",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 16
    },
    {
      "type": "header",
      "content": "Margin (Mobile)"
    },
    {
      "type": "range",
      "id": "margin_top_mobile",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Top margin",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Bottom margin",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Text Link"
    }
  ]
}
{% endschema %}