{% doc %}
  @prompt
    Create a customizable section with adjustable height and width that displays icon images with small subtext underneath. The section should support 1-9 icons in a row with center alignment as default. Include settings for section dimensions, number of icons per row, alignment options, icon size, text styling, and spacing controls. Make it responsive and flexible for various use cases like features, services, or benefits showcase. Have mobile view settings as well., background color needs to expand the entire section. icons need to default close together as if all 9 slots are used., the icons need to be grouped closely together regardless of number of icons used, Content alignment needs to be different for desktop and mobile, subtext should wrap, add section max width for desktop only. background color needs to not be limited to the section width, Content alignment (desktop) is not working

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-icon-grid-{{ ai_gen_id }} {
    width: 100%;
    min-height: {{ block.settings.section_height }}px;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
    display: flex;
    align-items: center;}

  .ai-icon-grid__wrapper-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.section_max_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.section_padding }}px;border-radius: {{ block.settings.border_radius }}px;
    display: flex;
    justify-content: {{ block.settings.alignment }};
  }

  .ai-icon-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.icons_per_row }}, minmax(0, max-content));
    gap: {{ block.settings.icon_spacing }}px;
    justify-content: center;
    width: auto;
    max-width: 100%;
  }

  .ai-icon-grid__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: {{ block.settings.text_spacing }}px;
    width: max-content;
  }

  .ai-icon-grid__icon-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.icon_background }};
    border-radius: {{ block.settings.icon_border_radius }}px;
    padding: {{ block.settings.icon_padding }}px;
    flex-shrink: 0;
  }

  .ai-icon-grid__icon-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-icon-grid__icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;}

  .ai-icon-grid__icon-placeholder-{{ ai_gen_id }} svg {
    width: 80%;
    height: 80%;
    opacity: 0.3;
  }

  .ai-icon-grid__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    font-weight: {{ block.settings.text_weight }};
    line-height: 1.4;
    margin: 0;white-space: normal;
    word-wrap: break-word;
    max-width: {{ block.settings.text_max_width }}px;
    hyphens: auto;
  }

  @media screen and (max-width: 749px) {
    .ai-icon-grid__wrapper-{{ ai_gen_id }} {
      max-width: none;
      justify-content: {{ block.settings.alignment_mobile }};
    }

    .ai-icon-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.icons_per_row_mobile }}, minmax(0, max-content));
      gap: {{ block.settings.icon_spacing_mobile }}px;
    }

    .ai-icon-grid__item-{{ ai_gen_id }} {
      gap: {{ block.settings.text_spacing_mobile }}px;
    }

    .ai-icon-grid__icon-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size_mobile }}px;
      height: {{ block.settings.icon_size_mobile }}px;
    }

    .ai-icon-grid__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
      max-width: {{ block.settings.text_max_width_mobile }}px;
    }
  }
{% endstyle %}<div class="ai-icon-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}><div class="ai-icon-grid__wrapper-{{ ai_gen_id }}">
    <div class="ai-icon-grid__container-{{ ai_gen_id }}">
      {% for i in (1..9) %}
        {% assign icon_key = 'icon_' | append: i %}
        {% assign text_key = 'text_' | append: i %}
        {% assign icon = block.settings[icon_key] %}
        {% assign text = block.settings[text_key] %}
        {% if icon != blank or text != blank %}
          <div class="ai-icon-grid__item-{{ ai_gen_id }}">
            <div class="ai-icon-grid__icon-wrapper-{{ ai_gen_id }}">
              {% if icon != blank %}
                <img
                  src="{{ icon | image_url: width: 200}}"
                  alt="{{ icon.alt | escape }}"
                  class="ai-icon-grid__icon-{{ ai_gen_id }}"
                  loading="lazy"width="200"
                  height="200"
                >
              {% else %}
                <div class="ai-icon-grid__icon-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            {% if text != blank %}
              <p class="ai-icon-grid__text-{{ ai_gen_id }}">{{ text }}</p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

