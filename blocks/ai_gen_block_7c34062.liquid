{% doc %}
  @prompt
    need a collection of link blocks up to 30 each with an image and text below, 2-3 per row. whole section needs horizontal padding and spacing options 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-link-collection-{{ ai_gen_id }} {
    padding: {{ block.settings.vertical_padding }}px {{ block.settings.horizontal_padding }}px;
  }

  .ai-link-collection-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    max-width: 100%;
  }

  .ai-link-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    transition: transform 0.3s ease;
  }

  .ai-link-item-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-link-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    background-color: {{ block.settings.image_background_color }};
  }

  .ai-link-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    object-fit: cover;
  }

  .ai-link-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.image_background_color }};
  }

  .ai-link-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-link-text-{{ ai_gen_id }} {
    margin-top: {{ block.settings.text_spacing }}px;
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_alignment }};
    font-weight: {{ block.settings.text_weight }};
  }

  @media screen and (max-width: 749px) {
    .ai-link-collection-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
  }
{% endstyle %}

<div class="ai-link-collection-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-link-collection-grid-{{ ai_gen_id }}">
    {% for i in (1..30) %}
      {% liquid
        assign link_key = 'link_' | append: i
        assign image_key = 'image_' | append: i
        assign text_key = 'text_' | append: i
        
        assign link_url = block.settings[link_key]
        assign link_image = block.settings[image_key]
        assign link_text = block.settings[text_key]
      %}

      {% if link_url != blank or link_image != blank or link_text != blank %}
        <a 
          href="{{ link_url | default: '#' }}" 
          class="ai-link-item-{{ ai_gen_id }}"
        >
          <div class="ai-link-image-wrapper-{{ ai_gen_id }}">
            {% if link_image %}
              <img
                src="{{ link_image | image_url: width: 800 }}"
                alt="{{ link_text | escape }}"
                loading="lazy"
                width="{{ link_image.width }}"
                height="{{ link_image.height }}"
                class="ai-link-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-link-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          
          {% if link_text != blank %}
            <div class="ai-link-text-{{ ai_gen_id }}">
              {{ link_text }}
            </div>
          {% endif %}
        </a>
      {% endif %}
    {% endfor %}
  </div>
</div>

