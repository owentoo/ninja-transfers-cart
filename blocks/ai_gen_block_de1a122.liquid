{% doc %}
  @prompt
    I need a section with two lines of h1, rich text below it, two stcked cta's. and a image to the right, image below on mobile, image should have no padding, section needs a bg color option, all text needs desktop and mobbile size options  , image should be full height of section on desktop and full width on mobile , ech heading needs its own color option, and give me an option to use any font , custom font not working , give space options between h1 rich text and buttons. on desktop give percentage of width image can take up , the Rich text needs to be able to be styled with html , chnage the Rich text into a text feild i can apply html to , image needs to go below on mobile, and give me the option to have a differnt mobile image , on mobile section should end at the bottom of the image , image on desktop should be left aligned all overflow should be right
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-section-{{ ai_gen_id }} {
    background-color: {{ block.settings.section_background_color }};
  }

  .ai-hero-container-{{ ai_gen_id }} {
    display: flex;
    align-items: stretch;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    width: 100%;
    min-height: {{ block.settings.section_min_height }}px;
  }

  .ai-hero-content-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: {{ block.settings.section_padding }}px 20px;
  }

  .ai-hero-headings-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.heading_gap }}px;
    margin-bottom: {{ block.settings.heading_to_text_spacing }}px;
  }

  .ai-hero-heading-{{ ai_gen_id }} {
    margin: 0;
    line-height: 1.1;
  }

  .ai-hero-heading-1-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size_desktop }}px;
    color: {{ block.settings.heading_1_color }};
    font-family: {{ block.settings.heading_1_font.family }}, {{ block.settings.heading_1_font.fallback_families }};
    font-weight: {{ block.settings.heading_1_font.weight }};
  }

  .ai-hero-heading-2-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size_desktop }}px;
    color: {{ block.settings.heading_2_color }};
    font-family: {{ block.settings.heading_2_font.family }}, {{ block.settings.heading_2_font.fallback_families }};
    font-weight: {{ block.settings.heading_2_font.weight }};
  }

  .ai-hero-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size_desktop }}px;
    line-height: 1.5;
    margin-bottom: {{ block.settings.text_to_buttons_spacing }}px;
  }

  .ai-hero-text-{{ ai_gen_id }} p {
    margin: 0 0 1em 0;
  }

  .ai-hero-text-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-hero-text-{{ ai_gen_id }} strong {
    font-weight: 700;
  }

  .ai-hero-text-{{ ai_gen_id }} em {
    font-style: italic;
  }

  .ai-hero-text-{{ ai_gen_id }} a {
    color: inherit;
    text-decoration: underline;
  }

  .ai-hero-text-{{ ai_gen_id }} ul,
  .ai-hero-text-{{ ai_gen_id }} ol {
    margin: 0 0 1em 0;
    padding-left: 1.5em;
  }

  .ai-hero-text-{{ ai_gen_id }} ul:last-child,
  .ai-hero-text-{{ ai_gen_id }} ol:last-child {
    margin-bottom: 0;
  }

  .ai-hero-text-{{ ai_gen_id }} li {
    margin-bottom: 0.5em;
  }

  .ai-hero-text-{{ ai_gen_id }} li:last-child {
    margin-bottom: 0;
  }

  .ai-hero-text-{{ ai_gen_id }} h1,
  .ai-hero-text-{{ ai_gen_id }} h2,
  .ai-hero-text-{{ ai_gen_id }} h3,
  .ai-hero-text-{{ ai_gen_id }} h4,
  .ai-hero-text-{{ ai_gen_id }} h5,
  .ai-hero-text-{{ ai_gen_id }} h6 {
    margin: 0 0 0.5em 0;
    font-weight: 700;
  }

  .ai-hero-buttons-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.button_gap }}px;
    align-items: flex-start;
  }

  .ai-hero-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size_desktop }}px;
    font-weight: 600;
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid;
    width: 100%;
    max-width: {{ block.settings.button_max_width }}px;
  }

  .ai-hero-button-primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_primary_bg }};
    color: {{ block.settings.button_primary_color }};
    border-color: {{ block.settings.button_primary_border }};
  }

  .ai-hero-button-primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_primary_bg_hover }};
    color: {{ block.settings.button_primary_color_hover }};
    border-color: {{ block.settings.button_primary_border_hover }};
  }

  .ai-hero-button-secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_secondary_bg }};
    color: {{ block.settings.button_secondary_color }};
    border-color: {{ block.settings.button_secondary_border }};
  }

  .ai-hero-button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_secondary_bg_hover }};
    color: {{ block.settings.button_secondary_color_hover }};
    border-color: {{ block.settings.button_secondary_border_hover }};
  }

  .ai-hero-image-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.image_width_desktop }}%;
    position: relative;
    overflow: hidden;
  }

  .ai-hero-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: left center;
    display: block;
  }

  .ai-hero-image-desktop-{{ ai_gen_id }} {
    display: block;
  }

  .ai-hero-image-mobile-{{ ai_gen_id }} {
    display: none;
  }

  .ai-hero-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    position: relative;
  }

  .ai-hero-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: left center;
  }

  .ai-hero-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-container-{{ ai_gen_id }} {
      flex-direction: column;
      min-height: auto;
    }

    .ai-hero-content-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_padding }}px 20px;
      order: 1;
    }

    .ai-hero-headings-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.heading_to_text_spacing_mobile }}px;
    }

    .ai-hero-heading-1-{{ ai_gen_id }},
    .ai-hero-heading-2-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-hero-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
      margin-bottom: {{ block.settings.text_to_buttons_spacing_mobile }}px;
    }

    .ai-hero-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size_mobile }}px;
    }

    .ai-hero-image-wrapper-{{ ai_gen_id }} {
      width: 100%;
      height: auto;
      min-height: auto;
      order: 2;
    }

    .ai-hero-image-{{ ai_gen_id }} {
      height: auto;
      object-position: center center;
    }

    .ai-hero-image-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-hero-image-mobile-{{ ai_gen_id }} {
      display: block;
    }

    .ai-hero-image-placeholder-{{ ai_gen_id }} {
      min-height: {{ block.settings.mobile_image_height }}px;
      justify-content: center;
    }

    .ai-hero-image-placeholder-{{ ai_gen_id }} svg {
      object-position: center center;
    }
  }
{% endstyle %}

<style>
  {{ block.settings.heading_1_font | font_face: font_display: 'swap' }}
  {{ block.settings.heading_2_font | font_face: font_display: 'swap' }}
</style>

<div class="ai-hero-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-container-{{ ai_gen_id }}">
    <div class="ai-hero-content-{{ ai_gen_id }}">
      <div class="ai-hero-headings-{{ ai_gen_id }}">
        {% if block.settings.heading_line_1 != blank %}
          <h1 class="ai-hero-heading-{{ ai_gen_id }} ai-hero-heading-1-{{ ai_gen_id }}">{{ block.settings.heading_line_1 }}</h1>
        {% endif %}
        {% if block.settings.heading_line_2 != blank %}
          <h1 class="ai-hero-heading-{{ ai_gen_id }} ai-hero-heading-2-{{ ai_gen_id }}">{{ block.settings.heading_line_2 }}</h1>
        {% endif %}
      </div>

      {% if block.settings.html_text != blank %}
        <div class="ai-hero-text-{{ ai_gen_id }}">
          {{ block.settings.html_text }}
        </div>
      {% endif %}

      <div class="ai-hero-buttons-{{ ai_gen_id }}">
        {% if block.settings.button_primary_label != blank %}
          <a
            href="{{ block.settings.button_primary_link }}"
            class="ai-hero-button-{{ ai_gen_id }} ai-hero-button-primary-{{ ai_gen_id }}"
          >
            {{ block.settings.button_primary_label }}
          </a>
        {% endif %}

        {% if block.settings.button_secondary_label != blank %}
          <a
            href="{{ block.settings.button_secondary_link }}"
            class="ai-hero-button-{{ ai_gen_id }} ai-hero-button-secondary-{{ ai_gen_id }}"
          >
            {{ block.settings.button_secondary_label }}
          </a>
        {% endif %}
      </div>
    </div>

    <div class="ai-hero-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 1200 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-hero-image-{{ ai_gen_id }} ai-hero-image-desktop-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-hero-image-placeholder-{{ ai_gen_id }} ai-hero-image-desktop-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-hero-empty-state-{{ ai_gen_id }}">
            Next, add a desktop image
          </div>
        </div>
      {% endif %}

      {% if block.settings.mobile_image %}
        <img
          src="{{ block.settings.mobile_image | image_url: width: 800 }}"
          alt="{{ block.settings.mobile_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.mobile_image.width }}"
          height="{{ block.settings.mobile_image.height }}"
          class="ai-hero-image-{{ ai_gen_id }} ai-hero-image-mobile-{{ ai_gen_id }}"
        >
      {% elsif block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 800 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-hero-image-{{ ai_gen_id }} ai-hero-image-mobile-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-hero-image-placeholder-{{ ai_gen_id }} ai-hero-image-mobile-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-hero-empty-state-{{ ai_gen_id }}">
            Next, add a mobile image
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

