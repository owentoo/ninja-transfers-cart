{% doc %}
  @prompt
    give me a section with 0-200 vertical padding
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-vertical-padding-{{ ai_gen_id }} {
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
  }
{% endstyle %}

<div class="ai-vertical-padding-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.content != blank %}
    <div>{{ block.settings.content }}</div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Vertical padding",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 50
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content"
    }
  ],
  "presets": [
    {
      "name": "Vertical padding"
    }
  ]
}
{% endschema %}
