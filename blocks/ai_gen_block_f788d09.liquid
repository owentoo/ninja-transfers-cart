{% doc %}
  @prompt
    i need a section with an h2 and text below it. text needs color and weight options. text size needs desktop and mobile option, need max width and horizontal padding for desktop and mobile. and top and bottom padding fro desktop and mobile  , horizontal padding should be inside of the max width , get rid of Mobile max width, add option for space between text on desktop and mobile and all text needs a amax width option. give whole section bg color option , need mobile alignment options, if text is not filled in make sure it doesn;t take up any space and ignore space between
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding-top: {{ block.settings.padding_top_desktop }}px;
    padding-bottom: {{ block.settings.padding_bottom_desktop }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-text-section__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width_desktop }}px;
    margin: 0 auto;
    padding-left: {{ block.settings.padding_horizontal_desktop }}px;
    padding-right: {{ block.settings.padding_horizontal_desktop }}px;
  }

  .ai-text-section__heading-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.heading_color }};
    font-weight: {{ block.settings.heading_weight }};
    font-size: {{ block.settings.heading_size_desktop }}px;
    line-height: 1.2;
    max-width: {{ block.settings.heading_max_width }}px;
  }

  .ai-text-section__heading-{{ ai_gen_id }}:not(:last-child) {
    margin-bottom: {{ block.settings.spacing_desktop }}px;
  }

  .ai-text-section__text-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.text_color }};
    font-weight: {{ block.settings.text_weight }};
    font-size: {{ block.settings.text_size_desktop }}px;
    line-height: 1.5;
    max-width: {{ block.settings.text_max_width }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-text-section-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top_mobile }}px;
      padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-text-section__container-{{ ai_gen_id }} {
      padding-left: {{ block.settings.padding_horizontal_mobile }}px;
      padding-right: {{ block.settings.padding_horizontal_mobile }}px;
      text-align: {{ block.settings.mobile_alignment }};
    }

    .ai-text-section__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
      {% if block.settings.mobile_alignment == 'center' %}
        margin-left: auto;
        margin-right: auto;
      {% elsif block.settings.mobile_alignment == 'right' %}
        margin-left: auto;
        margin-right: 0;
      {% endif %}
    }

    .ai-text-section__heading-{{ ai_gen_id }}:not(:last-child) {
      margin-bottom: {{ block.settings.spacing_mobile }}px;
    }

    .ai-text-section__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
      {% if block.settings.mobile_alignment == 'center' %}
        margin-left: auto;
        margin-right: auto;
      {% elsif block.settings.mobile_alignment == 'right' %}
        margin-left: auto;
        margin-right: 0;
      {% endif %}
    }
  }
{% endstyle %}

<div class="ai-text-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-section__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-text-section__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    {% if block.settings.text != blank %}
      <div class="ai-text-section__text-{{ ai_gen_id }}">
        {{ block.settings.text }}
      </div>
    {% endif %}
  </div>
</div>

