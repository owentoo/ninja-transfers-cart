{% doc %}
  @prompt
    make me a section that follows the themes horizontal max width padding and margin. I need a full width div in that div a need a container with a max width and alignment options. in the container i need a header, para, txt and a cta, the content meeds a max width option, and should be inside a full width imge or video container, background should only go as wide as the themes max width, background needs radius option and is still wider than the theme's max width. look at the themes horizontal padding margin and max width, Background should grow or shrink top and bottom based on padding, all setting need desktop and mobile options, text needs weight, and opacity options. and add horizontal padding option for inside the bg, make text weight options (regular, medium, semibold, and bold) button needs padding options, add button radius. and horizontal padding to the section in increments os 2 for desktop and mobile, the section needs horizontal padding options in multiples of 2

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-content-block-{{ ai_gen_id }} {
    width: 100%;
    padding: 0 {{ block.settings.section_horizontal_padding }}px;
    margin: 0 auto;
    max-width: {{ settings.theme_max_width }}px;
  }

  .ai-content-block-inner-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.background_border_radius }}px;
    width: 100%;
  }

  .ai-media-background-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
    z-index: -1;
  }

  .ai-media-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-media-background-{{ ai_gen_id }} .ai-media-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.background_color }};
  }

  .ai-media-background-{{ ai_gen_id }} .ai-media-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
    opacity: 0.1;
  }

  .ai-media-background-{{ ai_gen_id }} video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-media-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};}

  .ai-media-content-container-{{ ai_gen_id }} {
    position: relative;
    padding: 0 {{ block.settings.content_horizontal_padding }}px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: {{ block.settings.content_alignment }};
  }

  .ai-media-content-inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_width }}px;
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    text-align: {{ block.settings.text_alignment }};
    width: 100%;
  }

  .ai-media-content-heading-{{ ai_gen_id }} {
    margin-bottom: 16px;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    line-height: 1.2;
    {% if block.settings.heading_weight == 'regular' %}
      font-weight: 400;
    {% elsif block.settings.heading_weight == 'medium' %}
      font-weight: 500;
    {% elsif block.settings.heading_weight == 'semibold' %}
      font-weight: 600;
    {% elsif block.settings.heading_weight == 'bold' %}
      font-weight: 700;
    {% endif %}
  }

  .ai-media-content-text-{{ ai_gen_id }} {
    margin-bottom: 24px;
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.5;
    opacity: {{ block.settings.text_opacity | divided_by: 100.0 }};
    {% if block.settings.text_weight == 'regular' %}
      font-weight: 400;
    {% elsif block.settings.text_weight == 'medium' %}
      font-weight: 500;
    {% elsif block.settings.text_weight == 'semibold' %}
      font-weight: 600;
    {% elsif block.settings.text_weight == 'bold' %}
      font-weight: 700;
    {% endif %}
  }

  .ai-media-content-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    transition: background-color 0.3s ease;
    {% if block.settings.button_text_weight == 'regular' %}
      font-weight: 400;
    {% elsif block.settings.button_text_weight == 'medium' %}
      font-weight: 500;
    {% elsif block.settings.button_text_weight == 'semibold' %}
      font-weight: 600;
    {% elsif block.settings.button_text_weight == 'bold' %}
      font-weight: 700;
    {% endif %}
  }

  .ai-media-content-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-content-block-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.section_horizontal_padding_mobile }}px;
    }
    
    .ai-content-block-inner-{{ ai_gen_id }} {
      border-radius: {{ block.settings.background_border_radius_mobile }}px;
    }
    
    .ai-media-content-container-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.content_horizontal_padding_mobile }}px;
      justify-content: {{ block.settings.content_alignment_mobile }};
    }
    
    .ai-media-content-inner-{{ ai_gen_id }} {
      max-width: {{ block.settings.content_width_mobile }}px;
      padding: {{ block.settings.padding_top_mobile }}px 0 {{ block.settings.padding_bottom_mobile }}px;text-align: {{ block.settings.text_alignment_mobile }};
    }
    
    .ai-media-content-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }
    
    .ai-media-content-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
    }
    
    .ai-media-content-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_text_size_mobile }}px;
      border-radius: {{ block.settings.button_border_radius_mobile }}px;
      padding: {{ block.settings.button_padding_vertical_mobile }}px {{ block.settings.button_padding_horizontal_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-content-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-content-block-inner-{{ ai_gen_id }}">
    <div class="ai-media-background-{{ ai_gen_id }}">
      {% if block.settings.background_type == 'image' %}
        {% if block.settings.background_image %}
          <img 
            src="{{ block.settings.background_image | image_url: width: 2000 }}" 
            alt="{{ block.settings.background_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.background_image.width }}"
            height="{{ block.settings.background_image.height }}"
          >
        {% else %}
          <div class="ai-media-placeholder-{{ ai_gen_id }}">
            {{'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      {% elsif block.settings.background_type == 'video' %}
        {% if block.settings.background_video_url != blank %}
          <video autoplay muted loop playsinline>
            <source src="{{ block.settings.background_video_url }}" type="video/mp4">
            Your browser does not support the video tag.
          </video>
        {% else %}
          <div class="ai-media-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      {% else %}
        <div class="ai-media-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>
    <div class="ai-media-overlay-{{ ai_gen_id }}"></div>
    
    <div class="ai-media-content-container-{{ ai_gen_id }}">
      <div class="ai-media-content-inner-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-media-content-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        
        {% if block.settings.text != blank %}
          <div class="ai-media-content-text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
        {% endif %}
        
        {% if block.settings.button_text != blank and block.settings.button_link != blank %}
          <a href="{{ block.settings.button_link }}" class="ai-media-content-button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

