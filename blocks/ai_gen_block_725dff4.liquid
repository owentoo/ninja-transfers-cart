{% doc %}
  @prompt
    Create a background video block that plays a video as a full-width background with an editable text overlay on top. The video should autoplay, loop, and be muted. Include settings to upload the background video, customize the text overlay content, positioning, styling, and add optional background opacity or color overlay for better text readability. Make it responsive and ensure the video covers the entire section while maintaining aspect ratio.

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-background-video-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: {{ block.settings.section_height }}px;
    overflow: hidden;
    display: flex;
    align-items: {{ block.settings.content_vertical_alignment }};
    justify-content: {{ block.settings.content_horizontal_alignment }};
  }

  .ai-background-video__video-container-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-background-video__video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-background-video__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 2;
  }

  .ai-background-video__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    text-align: {{ block.settings.text_alignment }};
    padding: 40px 20px;
    max-width: {{ block.settings.content_max_width }}px;
    width: 100%;
  }

  .ai-background-video__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    margin: 0 0 {{ block.settings.text_spacing }}px 0;
    line-height: 1.2;
  }

  .ai-background-video__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.5;
    margin: 0 0 {{ block.settings.text_spacing }}px 0;
  }

  .ai-background-video__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 500;
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
  }

  .ai-background-video__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-background-video__fallback-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-background-video__fallback-{{ ai_gen_id }} svg {
    width: 100px;
    height: 100px;
    opacity: 0.3;
  }

  @media screen and (max-width: 768px) {
    .ai-background-video-{{ ai_gen_id }} {
      min-height: {{ block.settings.section_height_mobile }}px;
    }

    .ai-background-video__content-{{ ai_gen_id }} {
      padding: 30px 15px;
      max-width: 100%;
    }

    .ai-background-video__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-background-video__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
    }

    .ai-background-video__button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_text_size_mobile }}px;
    }
  }
{% endstyle %}

<background-video-{{ ai_gen_id }}
  class="ai-background-video-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.background_video %}
    <div class="ai-background-video__video-container-{{ ai_gen_id }}">
      <video
        class="ai-background-video__video-{{ ai_gen_id }}"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
      >
        <source src="{{ block.settings.background_video }}" type="video/mp4">
      </video>
    </div>
  {% else %}
    <div class="ai-background-video__fallback-{{ ai_gen_id }}">
      {{ 'hero-apparel-1' | placeholder_svg_tag }}
    </div>
  {% endif %}

  {% if block.settings.show_overlay %}
    <div class="ai-background-video__overlay-{{ ai_gen_id }}"></div>
  {% endif %}

  <div class="ai-background-video__content-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-background-video__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    {% if block.settings.text != blank %}
      <div class="ai-background-video__text-{{ ai_gen_id }}">
        {{ block.settings.text }}
      </div>
    {% endif %}

    {% if block.settings.button_text != blank and block.settings.button_link != blank %}
      <a
        href="{{ block.settings.button_link }}"
        class="ai-background-video__button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}</a>
    {% endif %}
  </div>
</background-video-{{ ai_gen_id }}>

<script>
  (function() {
    class BackgroundVideo{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.video = this.querySelector('.ai-background-video__video-{{ ai_gen_id }}');
        if (this.video) {
          this.setupVideo();
        }
      }

      setupVideo() {
        this.video.addEventListener('loadeddata', () => {
          this.video.play().catch(() => {
            console.log('Video autoplay was prevented');
          });
        });

        this.video.addEventListener('error', () => {
          console.log('Video failed to load');
        });

        const playPromise = this.video.play();
        if (playPromise !== undefined) {
          playPromise.catch(() => {
            console.log('Video autoplay was prevented');
          });
        }
      }
    }

    customElements.define('background-video-{{ ai_gen_id }}', BackgroundVideo{{ ai_gen_id }});
  })();
</script>

