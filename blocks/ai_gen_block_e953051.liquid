{% doc %}
  @prompt
    i need a section with a cta with alignment, text, roll over and text options for desktop and mobile, all i need is a cta button, i need a section bg color, follow themes horizontal max width, margin, and padding. give button horizontal and vertical padding options, i need font weight options, and button is extending past themes max width, get rid of right and left option get rid of boarder. and dont make button move on roll over

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-cta-section-{{ ai_gen_id }} {
    background-color: {{ block.settings.section_background_color }};
    margin: {{ block.settings.section_margin_top }}px 0 {{ block.settings.section_margin_bottom }}px;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
  }

  .ai-cta-container-{{ ai_gen_id }} {
    max-width: {{ settings.theme_max_width }}px;
    margin: 0 auto;
    padding: 0 {{ settings.grid_gap | divided_by: 2 }}px;
  }

  .ai-cta-button-wrapper-{{ ai_gen_id }} {
    text-align: {{ block.settings.alignment_desktop }};
  }

  .ai-cta-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size_desktop }}px;
    font-weight: {{ block.settings.button_font_weight }};
    transition: all 0.3s ease;
    max-width: 100%;
    box-sizing: border-box;
  }

  .ai-cta-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-cta-button-wrapper-{{ ai_gen_id }} {
      text-align: {{ block.settings.alignment_mobile }};
    }

    .ai-cta-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_text_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-cta-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-cta-container-{{ ai_gen_id }}">
    <div class="ai-cta-button-wrapper-{{ ai_gen_id }}">
      {% if block.settings.button_text != blank and block.settings.button_link != blank %}
        <a href="{{ block.settings.button_link }}" class="ai-cta-button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

