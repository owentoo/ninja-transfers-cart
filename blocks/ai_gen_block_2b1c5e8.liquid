{% doc %}
  @prompt
    Modify the existing split content & video section at the top of the page to add an autoplay toggle setting for the video component, i need max widths for the left and right section as well as a bg color option that does not effect the section width, i need a max width for the entire section, the right should have a width option and the video should take up the reaiming space with an option for space inbetween, all fonts need mobile and desktop options for size and color and all links need roll over color options, add line height options for all text and padding options between all text and buttons, add option to play with sound or play muted

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-split-content-video-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    width: 100%;
  }

  .ai-split-content-video__container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: {{ block.settings.gap }}px;
    padding: {{ block.settings.padding }}px;max-width: {{ block.settings.section_max_width }}px;margin: 0 auto;
  }

  @media screen and (max-width: 749px) {
    .ai-split-content-video__container-{{ ai_gen_id }} {
      flex-direction: {{ block.settings.stack_on_mobile | default: 'column' }};
      padding: {{ block.settings.padding | divided_by: 2 }}px;
    }
  }

  .ai-split-content-video__text-column-{{ ai_gen_id }} {
    padding: {{ block.settings.text_padding }}px;
    width: {{ block.settings.text_width }}%;flex-shrink: 0;
  }

  .ai-split-content-video__video-column-{{ ai_gen_id }} {
    flex-grow: 1;
    width: calc(100% - {{ block.settings.text_width }}% - {{ block.settings.gap }}px);
  }

  @media screen and (max-width: 749px) {
    .ai-split-content-video__text-column-{{ ai_gen_id }},
    .ai-split-content-video__video-column-{{ ai_gen_id }} {
      width: 100%;
    }
  }

  .ai-split-content-video__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    line-height: {{ block.settings.heading_line_height }};
    margin-top: 0;
    margin-bottom: {{ block.settings.heading_bottom_spacing }}px;
    color: {{ block.settings.heading_color }};
  }

  .ai-split-content-video__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: {{ block.settings.text_line_height }};
    color: {{ block.settings.text_color }};
    margin-bottom: {{ block.settings.text_bottom_spacing }}px;
  }

  .ai-split-content-video__text-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: none;
    transition: color 0.3s;
  }

  .ai-split-content-video__text-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-split-content-video__button-{{ ai_gen_id }} {
    display: inline-block;
    margin-top: {{ block.settings.button_top_spacing }}px;
    padding: 12px 24px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    line-height: {{ block.settings.button_line_height }};
    transition: background-color 0.3s, color 0.3s;
  }

  .ai-split-content-video__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    color: {{ block.settings.button_text_hover_color }};
  }

  .ai-split-content-video__video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;border-radius: {{ block.settings.video_border_radius }}px;
  }

  .ai-split-content-video__video-wrapper-{{ ai_gen_id }} iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .ai-split-content-video__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.video_border_radius }}px;
    position: absolute;
    top: 0;
    left: 0;
  }

  .ai-split-content-video__placeholder-{{ ai_gen_id }} svg {
    width:100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  @media screen and (max-width: 749px) {
    .ai-split-content-video__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
      line-height: {{ block.settings.heading_line_height_mobile }};
      color: {{ block.settings.heading_color_mobile }};
      margin-bottom: {{ block.settings.heading_bottom_spacing_mobile }}px;
    }

    .ai-split-content-video__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
      line-height: {{ block.settings.text_line_height_mobile }};
      color: {{ block.settings.text_color_mobile }};
      margin-bottom: {{ block.settings.text_bottom_spacing_mobile }}px;
    }

    .ai-split-content-video__button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_text_size_mobile }}px;
      line-height: {{ block.settings.button_line_height_mobile }};
      margin-top: {{ block.settings.button_top_spacing_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-split-content-video-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-split-content-video__container-{{ ai_gen_id }}">
    {% if block.settings.layout == 'text_first' %}
      <div class="ai-split-content-video__text-column-{{ ai_gen_id }}">
        <h2 class="ai-split-content-video__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        <div class="ai-split-content-video__text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
        {% if block.settings.button_text != blank and block.settings.button_link != blank %}
          <a href="{{ block.settings.button_link }}" class="ai-split-content-video__button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </a>
        {% endif %}
      </div><div class="ai-split-content-video__video-column-{{ ai_gen_id }}">
        <div class="ai-split-content-video__video-wrapper-{{ ai_gen_id }}">
          {% if block.settings.video_url.type == 'youtube' %}
            <iframe 
              src="https://www.youtube.com/embed/{{ block.settings.video_url.id }}?rel=0&showinfo=0{% if block.settings.autoplay %}&autoplay=1{% if block.settings.mute_video %}&mute=1{% endif %}{% endif %}" 
              frameborder="0" 
              allowfullscreen
            ></iframe>
          {% elsif block.settings.video_url.type == 'vimeo' %}
            <iframe 
              src="https://player.vimeo.com/video/{{ block.settings.video_url.id }}?byline=0&portrait=0{% if block.settings.autoplay %}&autoplay=1{% if block.settings.mute_video %}&muted=1{% endif %}{% endif %}" 
              frameborder="0" 
              allowfullscreen
            ></iframe>
          {% else %}
            <div class="ai-split-content-video__placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      </div>
    {% else %}
      <div class="ai-split-content-video__video-column-{{ ai_gen_id }}">
        <div class="ai-split-content-video__video-wrapper-{{ ai_gen_id }}">
          {% if block.settings.video_url.type == 'youtube' %}
            <iframe 
              src="https://www.youtube.com/embed/{{ block.settings.video_url.id }}?rel=0&showinfo=0{% if block.settings.autoplay %}&autoplay=1{% if block.settings.mute_video %}&mute=1{% endif %}{% endif %}" 
              frameborder="0" 
              allowfullscreen
            ></iframe>
          {% elsif block.settings.video_url.type == 'vimeo' %}
            <iframe 
              src="https://player.vimeo.com/video/{{ block.settings.video_url.id }}?byline=0&portrait=0{% if block.settings.autoplay %}&autoplay=1{% if block.settings.mute_video %}&muted=1{% endif %}{% endif %}" 
              frameborder="0" 
              allowfullscreen
            ></iframe>
          {% else %}
            <div class="ai-split-content-video__placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      </div><div class="ai-split-content-video__text-column-{{ ai_gen_id }}">
        <h2 class="ai-split-content-video__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        <div class="ai-split-content-video__text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
        {% if block.settings.button_text != blank and block.settings.button_link != blank %}
          <a href="{{ block.settings.button_link }}" class="ai-split-content-video__button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </a>
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Split Content & Video",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        {
          "value": "video_first",
          "label": "Video first"
        },
        {
          "value": "text_first",
          "label": "Text first"
        }
      ],
      "default": "video_first"
    },
    {
      "type": "select",
      "id": "stack_on_mobile",
      "label": "Mobile layout",
      "options": [
        {
          "value": "column",
          "label": "Stack vertically"
        },
        {
          "value": "column-reverse",
          "label": "Stack reversed"
        }
      ],
      "default": "column"
    },
    {
      "type": "range",
      "id": "section_max_width",
      "min": 800,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Section max width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "text_width",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "%",
      "label": "Text column width",
      "default": 40
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Gap between columns",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Section padding",
      "default": 40
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Split Content with Video"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Use this section to explain your product features, share your brand story, or describe your services. Pair compelling text with an engaging video to create a powerful impression.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "Video URL",
      "accept": ["youtube", "vimeo"],
      "default": "https://www.youtube.com/watch?v=_9VUPq3SxOc"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay video",
      "default": false,
      "info": "Most browsers require autoplay videos to be muted"
    },
    {
      "type": "checkbox",
      "id": "mute_video",
      "label": "Mute video",
      "default": true,
      "info": "Most browsers require autoplay videos to be muted"
    },
    {
      "type": "range",
      "id": "video_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Video border radius",
      "default": 8
    },
    {
      "type": "header",
      "content": "Desktop Text Styling"
    },
    {
      "type": "range",
      "id": "text_padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Text padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 16,
      "max": 60,
      "step": 1,
      "unit": "px",
      "label": "Heading size",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_line_height",
      "min": 0.8,
      "max": 2,
      "step": 0.1,
      "label": "Heading line height",
      "default": 1.2
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 16
    },
    {
      "type": "range",
      "id": "text_line_height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "label": "Text line height",
      "default": 1.5
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#000f9f"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link hover color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Desktop Spacing"
    },
    {
      "type": "range",
      "id": "heading_bottom_spacing",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading bottom spacing",
      "default": 20
    },
    {
      "type": "range",
      "id": "text_bottom_spacing",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Text bottom spacing",
      "default": 0
    },
    {
      "type": "range",
