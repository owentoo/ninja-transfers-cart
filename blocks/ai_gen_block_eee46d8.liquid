{% doc %}
  @prompt
    create a section with a max width and the option to have three or four blocks each with an image with ratio options and a heading and para text below them, texts needs weight and size options for desktop and mobile. Images need radius options, section needs the option for a bg color or gradiant that isn;t effected by max width and the text needs right and left margins within the block, section needs solid color bg option and padding and margin options, section bg color not working, add an option to have a video play in each image block on rollover, move the play button icon to the bottom left and make it 50% the size and make it optional

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-text-section-{{ ai_gen_id }} {
    {% if block.settings.background_type == 'color' %}
      background-color: {{ block.settings.background_color }};
    {% else %}
      background: {{ block.settings.background_gradient }};
    {% endif %}
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    margin: {{ block.settings.section_margin_top }}px 0 {{ block.settings.section_margin_bottom }}px;
  }

  .ai-image-text-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-image-text-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_count }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-image-text-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
  }

  .ai-image-text-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    margin-bottom: {{ block.settings.image_text_spacing }}px;
    overflow: hidden;
    border-radius: {{ block.settings.image_radius }}px;
  }

  .ai-image-text-image-wrapper-{{ ai_gen_id }}::before {
    content: "";
    display: block;
    padding-bottom: calc(100% / {{ block.settings.image_ratio }});
  }

  .ai-image-text-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: {% if block.settings.image_cover %}cover{% else %}contain{% endif %};
    object-position: center;
    transition: opacity 0.3s ease;
  }

  .ai-image-text-video-wrapper-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 1;
  }

  .ai-image-text-video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-image-text-item-{{ ai_gen_id }}:hover .ai-image-text-video-wrapper-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-image-text-item-{{ ai_gen_id }}:hover .ai-image-text-image-{{ ai_gen_id }} {
    opacity: 0;
  }

  .ai-image-text-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-image-text-placeholder-{{ ai_gen_id }} svg {
    width: 80%;
    height: 80%;
  }

  .ai-image-text-content-{{ ai_gen_id }} {
    padding: 0 {{ block.settings.text_margin }}px;
  }

  .ai-image-text-heading-{{ ai_gen_id }} {
    margin-top: 0;
    margin-bottom: {{ block.settings.heading_para_spacing }}px;
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    line-height: 1.2;
  }

  .ai-image-text-paragraph-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.paragraph_size }}px;
    font-weight: {{ block.settings.paragraph_weight }};
    line-height: 1.5;
  }

  .ai-image-text-play-icon-{{ ai_gen_id }} {
    position: absolute;
    bottom: 10px;
    left: 10px;
    width: 30px;
    height: 30px;
    background-color: rgba(0, 0, 0, 0.5);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    opacity: 0.8;
    transition: opacity 0.3s ease;
  }

  .ai-image-text-play-icon-{{ ai_gen_id }} svg {
    width: 12px;
    height: 12px;
    fill: white;
  }

  .ai-image-text-item-{{ ai_gen_id }}:hover .ai-image-text-play-icon-{{ ai_gen_id }} {
    opacity: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-image-text-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top_mobile }}px 0 {{ block.settings.section_padding_bottom_mobile }}px;
      margin: {{ block.settings.section_margin_top_mobile }}px 0 {{ block.settings.section_margin_bottom_mobile }}px;
    }
    
    .ai-image-text-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.grid_gap_mobile }}px;
    }

    .ai-image-text-content-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.text_margin_mobile }}px;
    }

    .ai-image-text-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-image-text-paragraph-{{ ai_gen_id }} {
      font-size: {{ block.settings.paragraph_size_mobile }}px;
    }
    
    .ai-image-text-play-icon-{{ ai_gen_id }} {
      width: 20px;
      height: 20px;
    }
    
    .ai-image-text-play-icon-{{ ai_gen_id }} svg {
      width: 8px;
      height: 8px;
    }
  }
{% endstyle %}

<div class="ai-image-text-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-text-container-{{ ai_gen_id }}">
    <div class="ai-image-text-grid-{{ ai_gen_id }}">
      {% for i in (1..block.settings.columns_count) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign video_key = 'video_' | append: i
          assign heading_key = 'heading_' | append: i
          assign paragraph_key = 'paragraph_' | append: i
          assign show_play_key = 'show_play_icon_' | append: i
          
          assign image = block.settings[image_key]
          assign video_url = block.settings[video_key]
          assign heading = block.settings[heading_key]
          assign paragraph = block.settings[paragraph_key]
          assign show_play_icon = block.settings[show_play_key]
        %}

        <div class="ai-image-text-item-{{ ai_gen_id }}">
          <div class="ai-image-text-image-wrapper-{{ ai_gen_id }}">
            {% if image != blank %}
              <img
                src="{{ image | image_url: width: 800 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
                class="ai-image-text-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-image-text-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
            
            {% if video_url != blank %}
              {% if show_play_icon %}
                <div class="ai-image-text-play-icon-{{ ai_gen_id }}">
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
              {% endif %}
              
              <div class="ai-image-text-video-wrapper-{{ ai_gen_id }}">
                <video 
                  class="ai-image-text-video-{{ ai_gen_id }}"
                  muted
                  loop
                  playsinline
                  data-autoplay="true"
                >
                  <source src="{{ video_url }}" type="video/mp4">
                </video>
              </div>
            {% endif %}
          </div>

          <div class="ai-image-text-content-{{ ai_gen_id }}">
            {% if heading != blank %}
              <h3 class="ai-image-text-heading-{{ ai_gen_id }}">{{ heading }}</h3>
            {% endif %}

            {% if paragraph != blank %}
              <p class="ai-image-text-paragraph-{{ ai_gen_id }}">{{ paragraph }}</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<script>
  (function() {
    const container = document.querySelector('.ai-image-text-section-{{ ai_gen_id }}');
    if (!container) return;
    
    const items = container.querySelectorAll('.ai-image-text-item-{{ ai_gen_id }}');
    
    items.forEach(item => {
      const video = item.querySelector('video');
      if (!video) return;
      
      item.addEventListener('mouseenter', () => {
        video.play();
      });
      
      item.addEventListener('mouseleave', () => {
        video.pause();
        video.currentTime = 0;
      });
    });
  })();
</script>

