{% doc %}
  @prompt
    Prompt:
    
    Create a full-width section with eight horizontally scrolling blocks using a flex layout. Each block contains a 140x140 square image (1:1 ratio) with text below it, and the entire block (image + text) is a single clickable link. On desktop, the layout stretches across the full width with the blocks laid out in a row. On mobile, the blocks should be scrollable horizontally (side-scroll) with touch/swipe support.
    
    Content Elements:
    
    8 image blocks (each 140x140)
    Text label under each image
    Each block is one unified clickable link (image + text)
    Layout:
    
    Desktop: Full-width horizontal flex row, evenly spaced
    Mobile: Horizontally scrollable row (side-scroll)
    Image stacked above text
    All items centered within their block
    Customization Settings:
    
    Editable image for each block (140x140, 1:1 aspect ratio)
    Editable text label below each image
    Editable link URL per block
    Option to change image and text sizes separately for desktop and mobile
    Option to adjust spacing between blocks
    Option to change text alignment (center/left/right)
    Option to control padding/margin of the section, i need to add a max width to the section, and for the roll over can it rollover text color option, the bg color should go full width the section width should only apply the items, add an option to have the element containing the blocks to be aligned left, right, or center, add options for top, bottom, and side options for section padding and margin, add three more blocks but make sure any blocks without information is hidden once published

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .horizontal-scroll-wrapper-{{ ai_gen_id }} {
    width: 100%;
    background-color: {{ block.settings.section_background }};
    padding-top: {{ block.settings.section_padding_top }}px;
    padding-bottom: {{ block.settings.section_padding_bottom }}px;
    padding-left: {{ block.settings.section_padding_sides }}px;
    padding-right: {{ block.settings.section_padding_sides }}px;
    margin-top: {{ block.settings.section_margin_top }}px;
    margin-bottom: {{ block.settings.section_margin_bottom }}px;
  }

  .horizontal-scroll-section-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.section_max_width }}px;
    margin: 0 auto;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    {% if block.settings.container_alignment == 'left' %}
      margin-left: 0;
      margin-right: auto;
    {% elsif block.settings.container_alignment == 'right' %}
      margin-left: auto;
      margin-right: 0;
    {% else %}
      margin-left: auto;
      margin-right: auto;
    {% endif %}
  }

  .horizontal-scroll-section-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .horizontal-scroll-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: row;
    gap: {{ block.settings.block_spacing }}px;
    padding: 0 {{ block.settings.container_padding }}px;
  }

  .scroll-block-{{ ai_gen_id }} {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.text_alignment }};
    text-decoration: none;
    color: {{ block.settings.text_color }};
    transition: transform 0.3s ease, color 0.3s ease;
  }

  .scroll-block-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
    color: {{ block.settings.text_hover_color }};
  }

  .scroll-block-image-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_image_size }}px;
    height: {{ block.settings.desktop_image_size }}px;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    margin-bottom: {{ block.settings.image_text_spacing }}px;
  }

  .scroll-block-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .scroll-block-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .scroll-block-image-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
  }

  .scroll-block-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.desktop_text_size }}px;
    font-weight: {{ block.settings.text_weight }};
    text-align: {{ block.settings.text_alignment }};
    margin-top: 10px;
    max-width: {{ block.settings.desktop_image_size }}px;
  }

  @media screen and (max-width: 749px) {
    .scroll-block-image-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_image_size }}px;
      height: {{ block.settings.mobile_image_size }}px;
    }

    .scroll-block-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_text_size }}px;
      max-width: {{ block.settings.mobile_image_size }}px;
    }
  }
{% endstyle %}

<div class="horizontal-scroll-wrapper-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="horizontal-scroll-section-{{ ai_gen_id }}">
    <div class="horizontal-scroll-container-{{ ai_gen_id }}">
      {% if block.settings.item1_image != blank or block.settings.item1_text != blank %}
        <a href="{{ block.settings.item1_link }}" class="scroll-block-{{ ai_gen_id }}">
          <div class="scroll-block-image-wrapper-{{ ai_gen_id }}">
            {% if block.settings.item1_image != blank %}
              <img 
                src="{{ block.settings.item1_image | img_url: 'master' }}" 
                alt="{{ block.settings.item1_text }}"
                loading="lazy"
                class="scroll-block-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="scroll-block-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          <div class="scroll-block-text-{{ ai_gen_id }}">{{ block.settings.item1_text }}</div>
