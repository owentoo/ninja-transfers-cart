      "unit": "px",
      "label": "Maximum content width",
      "default": 1400
    },
    {
      "type": "select",
      "id": "container_alignment",
      "label": "Container alignment",
      "options": [
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
