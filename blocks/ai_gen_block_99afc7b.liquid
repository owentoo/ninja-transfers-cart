{% doc %}
  @prompt
    i need a section with links, that left align and go past the screen and are horizontally scrollable. each link needs an image and text below it. image needs ratio option and max width and option for space ebtween , links need max width, image should take up 100% of that space, text needs weight, alignment and horizontal padding options. add placeholder image and text for first three links, need top and bottom Section padding, space between. both of these should work in increments of 2, section needs horizontal padding, links should left align, Horizontal padding should not affect overflow
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-scroll-links-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    padding-top: {{ block.settings.section_padding_top }}px;
    padding-bottom: {{ block.settings.section_padding_bottom }}px;
  }

  .ai-scroll-links-container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.item_spacing }}px;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-left: {{ block.settings.section_padding_horizontal }}px;
    padding-right: {{ block.settings.section_padding_horizontal }}px;
  }

  .ai-scroll-links-container-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-scroll-links-item-{{ ai_gen_id }} {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-decoration: none;
    width: {{ block.settings.item_max_width }}px;
  }

  .ai-scroll-links-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    margin-bottom: 12px;
  }

  .ai-scroll-links-image-wrapper-{{ ai_gen_id }}::before {
    content: '';
    display: block;
    padding-bottom: {% if block.settings.image_ratio == 'square' %}100%{% elsif block.settings.image_ratio == 'portrait' %}133.33%{% elsif block.settings.image_ratio == 'landscape' %}75%{% else %}66.67%{% endif %};
  }

  .ai-scroll-links-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-scroll-links-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-scroll-links-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-scroll-links-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_alignment }};
    line-height: 1.3;
    width: 100%;
    padding: 0 {{ block.settings.text_padding }}px;
    font-weight: {{ block.settings.text_weight }};
  }
{% endstyle %}

<div class="ai-scroll-links-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-scroll-links-container-{{ ai_gen_id }}">
    {% for i in (1..10) %}
      {% liquid
        assign link_key = 'link_' | append: i
        assign image_key = 'image_' | append: i
        assign text_key = 'text_' | append: i
        
        assign link_url = block.settings[link_key]
        assign link_image = block.settings[image_key]
        assign link_text = block.settings[text_key]
      %}
      
      {% if link_url != blank and link_text != blank %}
        <a href="{{ link_url }}" class="ai-scroll-links-item-{{ ai_gen_id }}">
          <div class="ai-scroll-links-image-wrapper-{{ ai_gen_id }}">
            {% if link_image %}
              <img
                src="{{ link_image | image_url: width: 400 }}"
                alt="{{ link_text | escape }}"
                class="ai-scroll-links-image-{{ ai_gen_id }}"
                loading="lazy"
                width="400"
                height="400"
              >
            {% else %}
              <div class="ai-scroll-links-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          <div class="ai-scroll-links-text-{{ ai_gen_id }}">
            {{ link_text }}
          </div>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</div>

