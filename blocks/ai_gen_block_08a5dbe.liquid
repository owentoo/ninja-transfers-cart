{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-link-row-wrapper-{{ ai_gen_id }} {
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding-top: {{ block.settings.padding_top_desktop }}px;
    padding-bottom: {{ block.settings.padding_bottom_desktop }}px;
    margin-top: {{ block.settings.margin_top_desktop }}px;
    margin-bottom: {{ block.settings.margin_bottom_desktop }}px;
  }

  .ai-link-row-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ settings.theme_max_width }}px;
    margin: 0 auto;
    padding-left: {{ block.settings.padding_horizontal_desktop }}px;
    padding-right: {{ block.settings.padding_horizontal_desktop }}px;
    overflow: hidden;
  }

  .ai-link-row__container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;}

  .ai-link-row__scroller-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap_desktop }}px;
    overflow-x: auto;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 20px 0;
  }

  .ai-link-row__scroller-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-link-row__item-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.desktop_item_width }}px;
    text-decoration: none;
    color: {{ block.settings.text_color }};
    text-align: center;
    transition: transform 0.3s ease;
  }

  .ai-link-row__item-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
  }

  .ai-link-row__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: calc(100% / {{ block.settings.image_aspect_ratio }});
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    margin-bottom: 12px;
  }

  .ai-link-row__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.image_fit }};
  }

  .ai-link-row__image-wrapper-{{ ai_gen_id }} svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    background-color: #f4f4f4;
  }

  .ai-link-row__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.desktop_text_size }}px;
    font-weight: {{ block.settings.text_weight }};
    margin-top: 10px;
    color: {{ block.settings.text_color }};
    transition: color 0.3s ease;
    padding-left: {{ block.settings.text_padding_horizontal_desktop }}px;
    padding-right: {{ block.settings.text_padding_horizontal_desktop }}px;
  }

  .ai-link-row__item-{{ ai_gen_id }}:hover .ai-link-row__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_hover_color }};
  }

  .ai-link-row__arrow-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: {{ block.settings.arrow_size }}px;
    height: {{ block.settings.arrow_size }}px;
    background-color: {{ block.settings.arrow_background_color }};
    color: {{ block.settings.arrow_color }};
    border-radius: {{ block.settings.arrow_style }};
    display: none;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10;
    border: none;
    opacity: 0.8;
    transition: opacity 0.3s ease, background-color 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  .ai-link-row__arrow-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_hover_background_color }};
    opacity: 1;
  }

  .ai-link-row__arrow--prev-{{ ai_gen_id }} {
    left: 10px;
  }

  .ai-link-row__arrow--next-{{ ai_gen_id }} {
    right: 10px;
  }

  .ai-link-row__arrow-icon-{{ ai_gen_id }} {
    width: calc({{ block.settings.arrow_size }}px * 0.5);
    height: calc({{ block.settings.arrow_size }}px * 0.5);
  }

  .ai-link-row__custom-arrow-{{ ai_gen_id }} {
    width: calc({{ block.settings.arrow_size }}px * 0.6);
    height: calc({{ block.settings.arrow_size }}px * 0.6);
    object-fit: contain;
  }

  @media screen and (max-width: 749px) {
    .ai-link-row-wrapper-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top_mobile }}px;
      padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
      margin-top: {{ block.settings.margin_top_mobile }}px;
      margin-bottom: {{ block.settings.margin_bottom_mobile }}px;
    }

    .ai-link-row-{{ ai_gen_id }} {
      padding-left: {{ block.settings.padding_horizontal_mobile }}px;
      padding-right: {{ block.settings.padding_horizontal_mobile }}px;
    }

    .ai-link-row__scroller-{{ ai_gen_id }} {
      gap: {{ block.settings.gap_mobile }}px;
    }

    .ai-link-row__item-{{ ai_gen_id }} {
      flex: 0 0 {{ block.settings.mobile_item_width }}px;
    }

    .ai-link-row__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_text_size }}px;
      padding-left: {{ block.settings.text_padding_horizontal_mobile }}px;
      padding-right: {{ block.settings.text_padding_horizontal_mobile }}px;
    }

    .ai-link-row__arrow-{{ ai_gen_id }} {
      width: calc({{ block.settings.arrow_size }}px * 0.8);
      height: calc({{ block.settings.arrow_size }}px * 0.8);
    }

    .ai-link-row__arrow-icon-{{ ai_gen_id }} {
      width: calc({{ block.settings.arrow_size }}px * 0.4);
      height: calc({{ block.settings.arrow_size }}px * 0.4);
    }

    .ai-link-row__custom-arrow-{{ ai_gen_id }} {
      width: calc({{ block.settings.arrow_size }}px * 0.5);
      height: calc({{ block.settings.arrow_size }}px * 0.5);
    }
  }
{% endstyle %}

<div class="ai-link-row-wrapper-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-link-row-{{ ai_gen_id }}">
    <link-row-{{ ai_gen_id }} class="ai-link-row__container-{{ ai_gen_id }}">
      <div class="ai-link-row__scroller-{{ ai_gen_id }}" id="scroller-{{ ai_gen_id }}">
        {% for i in (1..block.settings.items_to_show) %}
          {% liquid
            assign link_type_key = 'link_type_' | append: i
            assign link_type = block.settings[link_type_key]
            
            assign image_key = 'image_' | append: i
            assign custom_image = block.settings[image_key]
            
            assign text_key = 'text_' | append: i
            assign custom_text = block.settings[text_key]
            
            assign product_key = 'product_' | append: i
            assign product = block.settings[product_key]
            
            assign collection_key = 'collection_' | append: i
            assign collection = block.settings[collection_key]
            
            assign page_key = 'page_' | append: i
            assign page = block.settings[page_key]
            
            assign url_key = 'url_' | append: i
            assign url = block.settings[url_key]
            
            assign link_url = '#'
            assign link_text = ''
            assign link_image = ''
          %}
          
          {% case link_type %}
            {% when 'product' %}
              {% if product != blank %}
                {% assign link_url = product.url %}
                {% if custom_text != blank %}
                  {% assign link_text = custom_text %}
                {% else %}
                  {% assign link_text = product.title %}
                {% endif %}
                {% if custom_image != blank %}
                  {% assign link_image = custom_image %}
                {% else %}
                  {% assign link_image = product.featured_image %}
                {% endif %}
              {% endif %}
            {% when 'collection' %}
              {% if collection != blank %}
                {% assign link_url = collection.url %}
                {% if custom_text != blank %}
                  {% assign link_text = custom_text %}
                {% else %}
                  {% assign link_text = collection.title %}
                {% endif %}
                {% if custom_image != blank %}
                  {% assign link_image = custom_image %}
                {% else %}
                  {% assign link_image = collection.image %}
                {% endif %}
              {% endif %}
            {% when 'page' %}
              {% if page != blank %}
                {% assign link_url = page.url %}
                {% if custom_text != blank %}
                  {% assign link_text = custom_text %}
                {% else %}
                  {% assign link_text = page.title %}
                {% endif %}
                {% if custom_image != blank %}
                  {% assign link_image = custom_image %}
                {% endif %}
              {% endif %}
            {% when 'url' %}
              {% if url != blank %}
                {% assign link_url = url %}
              {% endif %}
              {% if custom_text != blank %}
                {% assign link_text = custom_text %}
              {% endif %}
              {% if custom_image != blank %}
                {% assign link_image = custom_image %}
              {% endif %}
          {% endcase %}<a href="{{ link_url }}" class="ai-link-row__item-{{ ai_gen_id }}">
            <div class="ai-link-row__image-wrapper-{{ ai_gen_id }}">
              {% if link_image != blank %}
                <img 
                  src="{{ link_image | img_url: '400x' }}"
                  alt="{{ link_text | escape }}"
                  loading="lazy"
                  class="ai-link-row__image-{{ ai_gen_id }}"
                >
              {% else %}
                {{ 'image' | placeholder_svg_tag }}
              {% endif %}
            </div>
            {% if link_text != blank %}
              <div class="ai-link-row__text-{{ ai_gen_id }}">{{ link_text }}</div>
            {% endif %}
          </a>
        {% endfor %}
      </div>
      <button class="ai-link-row__arrow-{{ ai_gen_id }} ai-link-row__arrow--prev-{{ ai_gen_id }}" id="prev-{{ ai_gen_id }}" aria-label="Previous items">
        {% if block.settings.custom_arrow_left %}
          <img 
            src="{{ block.settings.custom_arrow_left | img_url: '100x' }}"
            alt="Previous"
            class="ai-link-row__custom-arrow-{{ ai_gen_id }}"
          >
        {% else %}
          <svg class="ai-link-row__arrow-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        {% endif %}
      </button>
      <button class="ai-link-row__arrow-{{ ai_gen_id }} ai-link-row__arrow--next-{{ ai_gen_id }}" id="next-{{ ai_gen_id }}" aria-label="Next items">
        {% if block.settings.custom_arrow_right %}
          <img 
            src="{{ block.settings.custom_arrow_right | img_url: '100x' }}"
            alt="Next"
            class="ai-link-row__custom-arrow-{{ ai_gen_id }}"
          >
        {% else %}
          <svg class="ai-link-row__arrow-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M9 6L15 12L9 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        {% endif %}
      </button>
    </link-row-{{ ai_gen_id }}>
  </div>
</div>

<script>
  (function() {
    class LinkRow{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.scroller = this.querySelector('#scroller-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('#prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('#next-{{ ai_gen_id }}');
        this.itemWidth = {{ block.settings.desktop_item_width }};
        this.gap = {{ block.settings.gap_desktop }};
        this.mobileBreakpoint = 749;
      }

      connectedCallback() {
        this.setupEventListeners();
        setTimeout(() => {
          this.checkOverflow();
        }, 100);
      }

      setupEventListeners() {
        if (this.prevButton && this.nextButton && this.scroller) {
          this.prevButton.addEventListener('click', () => this.scroll(-1));
          this.nextButton.addEventListener('click', () => this.scroll(1));
          this.scroller.addEventListener('scroll', () => this.updateArrowStates());
          
          window.addEventListener('resize', () => {
            setTimeout(() => {
              this.checkOverflow();
              this.updateGapForScreenSize();
            }, 100);
          });
          
          this.updateGapForScreenSize();
        }
      }

      updateGapForScreenSize() {
        const isMobile = window.innerWidth <= this.mobileBreakpoint;
        this.gap = isMobile ? {{ block.settings.gap_mobile }} : {{ block.settings.gap_desktop }};
      }

      scroll(direction) {
        if (!this.scroller) return;
        
        const isMobile = window.innerWidth <= this.mobileBreakpoint;
        const width = isMobile ? {{ block.settings.mobile_item_width }} : this.itemWidth;
        const scrollAmount = (width + this.gap) * {{ block.settings.scroll_items }} * direction;
        
        this.scroller.scrollBy({
          left: scrollAmount,
          behavior: 'smooth'
        });
      }

      checkOverflow() {
        if (!this.scroller || !this.prevButton || !this.nextButton) return;
        
        const hasOverflow = this.scroller.scrollWidth > this.scroller.clientWidth;
        
        if (hasOverflow) {
          this.updateArrowStates();
        } else {
          this.prevButton.style.display = 'none';
          this.nextButton.style.display = 'none';
        }
      }

      updateArrowStates() {
        if (!this.scroller || !this.prevButton || !this.nextButton) return;
        
        const atStart = this.scroller.scrollLeft <= 10;
        const atEnd = this.scroller.scrollLeft >= this.scroller.scrollWidth - this.scroller.clientWidth - 10;
        const hasOverflow = this.scroller.scrollWidth > this.scroller.clientWidth;
        
        if (!hasOverflow) {
          this.prevButton.style.display = 'none';
          this.nextButton.style.display = 'none';
          return;
        }
        
        this.prevButton.style.display = atStart ? 'none' : 'flex';
        this.nextButton.style.display = atEnd ? 'none' : 'flex';
      }
    }

    customElements.define('link-row-{{ ai_gen_id }}', LinkRow{{ ai_gen_id }});
  })();
</script>

