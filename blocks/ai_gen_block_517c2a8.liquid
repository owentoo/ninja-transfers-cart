{% doc %}
  @prompt
    i need a full width section with. bg image and overlay and a place to put an image, ceneraligned in section horizontally and vertically , image needs size for desktop and mobile height should be based on vertical k=padding for desktop and mobile 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-section-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding: {{ block.settings.vertical_padding_desktop }}px 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .ai-hero-bg-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-hero-bg-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-bg-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
  }

  .ai-hero-bg-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 2;
  }

  .ai-hero-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: {{ block.settings.content_max_width }}px;
    padding: 0 20px;
  }

  .ai-hero-image-wrapper-{{ ai_gen_id }} {
    max-width: {{ block.settings.image_max_width_desktop }}px;
    width: 100%;
  }

  .ai-hero-image-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-hero-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    background-color: #e0e0e0;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-hero-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-hero-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 4px;
    font-size: 13px;
    color: #666;
    text-align: center;
    white-space: nowrap;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-section-{{ ai_gen_id }} {
      padding: {{ block.settings.vertical_padding_mobile }}px 0;
    }

    .ai-hero-content-{{ ai_gen_id }} {
      padding: 0 15px;
    }

    .ai-hero-image-wrapper-{{ ai_gen_id }} {
      max-width: {{ block.settings.image_max_width_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-hero-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-bg-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2400 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {% else %}
      <div class="ai-hero-bg-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="ai-hero-overlay-{{ ai_gen_id }}"></div>

  <div class="ai-hero-content-{{ ai_gen_id }}">
    <div class="ai-hero-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.center_image %}
        <div class="ai-hero-image-{{ ai_gen_id }}">
          <img
            src="{{ block.settings.center_image | image_url: width: 1200 }}"
            alt="{{ block.settings.center_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.center_image.width }}"
            height="{{ block.settings.center_image.height }}"
          >
        </div>
      {% else %}
        <div class="ai-hero-image-placeholder-{{ ai_gen_id }}">
          {{ 'product-apparel-1' | placeholder_svg_tag }}
          <div class="ai-hero-empty-state-{{ ai_gen_id }}">
            Add a center image
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Full width hero",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "Overlay opacity",
      "default": 0.3
    },
    {
      "type": "header",
      "content": "Center image"
    },
    {
      "type": "image_picker",
      "id": "center_image",
      "label": "Center image"
    },
    {
      "type": "range",
      "id": "image_max_width_desktop",
      "min": 200,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "label": "Image width (desktop)",
      "default": 500
    },
    {
      "type": "range",
      "id": "image_max_width_mobile",
      "min": 150,
      "max": 500,
      "step": 25,
      "unit": "px",
      "label": "Image width (mobile)",
      "default": 300
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Image border radius",
      "default": 14
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "vertical_padding_desktop",
      "min": 50,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Vertical padding (desktop)",
      "default": 120
    },
    {
      "type": "range",
      "id": "vertical_padding_mobile",
      "min": 30,
      "max": 150,
      "step": 10,
      "unit": "px",
      "label": "Vertical padding (mobile)",
      "default": 60
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 600,
      "max": 1400,
      "step": 50,
      "unit": "px",
      "label": "Content max width",
      "default": 1200
    }
  ],
  "presets": [
    {
      "name": "Full width hero"
    }
  ]
}
{% endschema %}
