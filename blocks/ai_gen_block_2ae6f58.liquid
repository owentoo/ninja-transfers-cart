{% doc %}
  @prompt
    create hero section with an h1, para, and two cta, on the other side 8 or so images to overlay and scroll on different planes with parallax, the images need to be scattered and move on scroll

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
.ai-hero-parallax-{{ ai_gen_id }} {
  position: relative;
  display: flex;
  flex-direction: row;
  min-height: {{ block.settings.section_height }}px;
  overflow: hidden;
  background-color: {{ block.settings.background_color }};
  padding: 60px 0;
}

.ai-hero-parallax__content-{{ ai_gen_id }} {
  width: 50%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 5%;
  position: relative;
  z-index: 5;
}

.ai-hero-parallax__heading-{{ ai_gen_id }} {
  font-size: {{ block.settings.heading_size }}px;
  color: {{ block.settings.heading_color }};
  margin-bottom: 20px;
  max-width: 600px;
}

.ai-hero-parallax__text-{{ ai_gen_id }} {
  font-size: {{ block.settings.text_size }}px;
  color: {{ block.settings.text_color }};
  margin-bottom: 30px;
  max-width: 500px;
}

.ai-hero-parallax__buttons-{{ ai_gen_id }} {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}

.ai-hero-parallax__button-{{ ai_gen_id }} {
  padding: 12px 24px;
  border-radius: {{ block.settings.button_border_radius }}px;
  font-size: 16px;
  text-decoration: none;
  transition: all 0.3s ease;
  display: inline-block;
}

.ai-hero-parallax__button-primary-{{ ai_gen_id }} {
  background-color: {{ block.settings.primary_button_color }};
  color: {{ block.settings.primary_button_text_color }};
}

.ai-hero-parallax__button-primary-{{ ai_gen_id }}:hover {
  background-color: {{ block.settings.primary_button_hover_color }};
}

.ai-hero-parallax__button-secondary-{{ ai_gen_id }} {
  background-color: {{ block.settings.secondary_button_color }};
  color: {{ block.settings.secondary_button_text_color }};
}

.ai-hero-parallax__button-secondary-{{ ai_gen_id }}:hover {
  background-color: {{ block.settings.secondary_button_hover_color }};
}

.ai-hero-parallax__images-{{ ai_gen_id }} {
  position: absolute;
  top: 0;
  right: 0;
  width: 60%;
  height: 100%;
  pointer-events: none;
}

.ai-hero-parallax__image-container-{{ ai_gen_id }} {
  position: absolute;
  border-radius: {{ block.settings.image_border_radius }}px;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
  overflow: hidden;
  transform: translateY(0);
  will-change: transform;
  z-index: 1;
}

.ai-hero-parallax__image-{{ ai_gen_id }} {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.ai-hero-parallax__image-placeholder-{{ ai_gen_id }} {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-hero-parallax__image-placeholder-{{ ai_gen_id }} svg {
  width: 100%;
  height: 100%;
  background-color: #f4f4f4;
}

@media screen and (max-width: 990px) {
  .ai-hero-parallax-{{ ai_gen_id }} {
    flex-direction: column;
    padding-bottom: 450px;
  }
  
  .ai-hero-parallax__content-{{ ai_gen_id }} {
    width: 100%;
    padding: 40px 5%;
  }
  
  .ai-hero-parallax__images-{{ ai_gen_id }} {
    width: 100%;
    height: 450px;
    position: absolute;
    bottom: 0;
    top: auto;
    right: 0;
  }
  
  .ai-hero-parallax__heading-{{ ai_gen_id }} {
    font-size: calc({{ block.settings.heading_size }}px * 0.7);
  }
}
{% endstyle %}

<parallax-hero-{{ ai_gen_id }} 
  class="ai-hero-parallax-{{ ai_gen_id }}" 
  {{ block.shopify_attributes }}
>
  <div class="ai-hero-parallax__content-{{ ai_gen_id }}">
    <h1 class="ai-hero-parallax__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h1>
    <div class="ai-hero-parallax__text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
    <div class="ai-hero-parallax__buttons-{{ ai_gen_id }}">
      {% if block.settings.primary_button_text != blank and block.settings.primary_button_link != blank %}
        <a href="{{ block.settings.primary_button_link }}" class="ai-hero-parallax__button-{{ ai_gen_id }} ai-hero-parallax__button-primary-{{ ai_gen_id }}">
          {{ block.settings.primary_button_text }}
        </a>
      {% endif %}
      
      {% if block.settings.secondary_button_text != blank and block.settings.secondary_button_link != blank %}
        <a href="{{ block.settings.secondary_button_link }}" class="ai-hero-parallax__button-{{ ai_gen_id }} ai-hero-parallax__button-secondary-{{ ai_gen_id }}">
          {{ block.settings.secondary_button_text }}
        </a>
      {% endif %}
    </div>
  </div>
  
  <div class="ai-hero-parallax__images-{{ ai_gen_id }}">
    {% for i in (1..8) %}
      {% assign image_key = 'image_' | append: i %}
      {% assign image = block.settings[image_key] %}<div class="ai-hero-parallax__image-container-{{ ai_gen_id }} ai-hero-parallax__image-container-{{ i }}-{{ ai_gen_id }}" data-index="{{ i }}">
        {% if image != blank %}
          <img 
            src="{{ image | image_url: width: 800 }}" 
            alt="{{ image.alt | escape }}"
            width="{{ image.width }}"
            height="{{ image.height }}"
            loading="lazy"
            class="ai-hero-parallax__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-hero-parallax__image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</parallax-hero-{{ ai_gen_id }}>

<script>
  (function() {
    class ParallaxHero{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.imageContainers = Array.from(this.querySelectorAll('.ai-hero-parallax__image-container-{{ ai_gen_id }}'));
        this.lastScrollY = window.scrollY;
        this.ticking = false;
        
        // Define scattered positions and depths for each image
        this.imagePositions = [
          { top: '15%', left: '5%', width: '25%', height: '30%', depth: 0.3, zIndex: 3 },
          { top: '10%', left: '35%', width: '20%', height: '25%', depth: 0.5, zIndex: 2 },
          { top: '5%', left: '60%', width: '30%', height: '35%', depth: 0.2, zIndex: 1 },
          { top: '40%', left: '10%', width: '22%', height: '28%', depth: 0.6, zIndex: 4 },
          { top: '35%', left: '40%', width: '28%', height: '32%', depth: 0.4, zIndex: 3 },
          { top: '45%', left: '70%', width: '25%', height: '30%', depth: 0.7, zIndex: 2 },
          { top: '65%', left: '15%', width: '30%', height: '25%', depth: 0.3, zIndex: 1 },
          { top: '60%', left: '50%', width: '35%', height: '30%', depth: 0.5, zIndex: 2 }
        ];
      }
      
      connectedCallback() {
        this.setupImages();
        this.bindEvents();
        
        // Initial position update
        this.updateParallax();
      }
      
      setupImages() {
        this.imageContainers.forEach((container, index) => {
          if (index < this.imagePositions.length) {
            const position = this.imagePositions[index];
            
            // Set initial position and style
            container.style.top = position.top;
            container.style.left = position.left;
            container.style.width = position.width;
            container.style.height = position.height;
            container.style.zIndex = position.zIndex;
            
            // Store depth for parallax calculation
            container.setAttribute('data-depth', position.depth);
          } else {
            // Hide extra containers if there are more than positions defined
            container.style.display = 'none';
          }
        });
      }
      
      bindEvents() {
        // Bind scroll event with passive option for better performance
        window.addEventListener('scroll', () => {
          this.lastScrollY = window.scrollY;
          this.requestParallaxUpdate();
        }, { passive: true });
        
        // Handle resize events
        window.addEventListener('resize', () => {
          this.requestParallaxUpdate();
        });
      }
      
      requestParallaxUpdate() {
        if (!this.ticking) {
          window.requestAnimationFrame(() => {
            this.updateParallax();
            this.ticking = false;
          });
          this.ticking = true;
        }
      }
      
      updateParallax() {
        const rect = this.getBoundingClientRect();
        const scrollPosition = window.scrollY;
        const viewportHeight = window.innerHeight;
        
        // Only apply parallax if element is visible
        if (rect.bottom > 0 && rect.top < viewportHeight) {
          // Calculate how much of the element is visible in the viewport
          const visiblePercentage = Math.min(
            (viewportHeight - Math.max(0, rect.top)) / viewportHeight,
            rect.bottom / viewportHeight
          );
          
          this.imageContainers.forEach(container => {
            const depth = parseFloat(container.getAttribute('data-depth')) || 0.5;
            const index = parseInt(container.getAttribute('data-index')) || 1;
            
            // Create different movement patterns based on index
            let translateY, translateX, rotate;
            
            // Vertical movement based on scroll and depth
            translateY = scrollPosition * depth * 0.15;
            
            // Add some horizontal movement for certain images
            if (index % 2 === 0) {
              translateX = scrollPosition * depth * 0.05;
            } else {
              translateX = scrollPosition * depth * -0.03;
            }
            
            // Add slight rotation for some images
            if (index % 3 === 0) {
              rotate = scrollPosition * depth * 0.01;
            } else {
              rotate = 0;
            }
            
            // Apply transforms
            container.style.transform = `translateY(${translateY}px) translateX(${translateX}px) rotate(${rotate}deg)`;
          });
        }
      }
      
      disconnectedCallback() {
        window.removeEventListener('scroll', this.requestParallaxUpdate);
        window.removeEventListener('resize', this.requestParallaxUpdate);
      }
    }
    
    customElements.define('parallax-hero-{{ ai_gen_id }}', ParallaxHero{{ ai_gen_id }});
  })();
</script>

