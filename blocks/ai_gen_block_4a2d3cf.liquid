{% doc %}
  @prompt
    i need a hero section with a an h1, text, cta, and video button. and a full height image on the other., image needs the be on right or left, image should never get cropped on grow and shink, image should always be bottom aligned, section needs max width in pixels, next to cta i need a link that popups a video , make this work with a youtube link and section height should be determined by image id padding around the text section, video link should trigger popup video with overlay behind it , make the video popup work , need options for alignment on mobile , turn Content background color into section background color, color should go full width. all text needs size option for desktop and mobile , under the cta i need a line of text that accpets html , need setting for aspoce from cta to sub text on desktop and mobile , Desktop spacing from CTA needs to go from 0-100, neeed option of space between h1, text, cta, link, and Subtext on desktop and mobile, when moble layout is center video link and Subtext needs to be centered as well
    
    , get rid of video link, text section should go to edge of page there should only be an option for space between image and text , all content needs to fall inside of max width also need to add desktop and mobile horizontal padding within max width , image on mobile should. be full width and need mobile image option. mobile need top padding option , all text needs weight options.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    background-color: {{ block.settings.section_bg_color }};
  }

  .ai-hero-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.padding_horizontal_desktop }}px;
    display: flex;
    align-items: stretch;
    gap: {{ block.settings.gap_desktop }}px;
    {% if block.settings.image_position == 'left' %}
      flex-direction: row-reverse;
    {% else %}
      flex-direction: row;
    {% endif %}
  }

  .ai-hero-content-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    {% if block.settings.content_alignment == 'left' %}
      align-items: flex-start;
      text-align: left;
    {% elsif block.settings.content_alignment == 'center' %}
      align-items: center;
      text-align: center;
    {% else %}
      align-items: flex-end;
      text-align: right;
    {% endif %}
  }

  .ai-hero-heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.spacing_h1_text_desktop }}px;
    font-size: {{ block.settings.heading_size_desktop }}px;
    font-weight: {{ block.settings.heading_weight }};
    color: {{ block.settings.heading_color }};
    line-height: 1.2;
  }

  .ai-hero-text-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.spacing_text_cta_desktop }}px;
    font-size: {{ block.settings.text_size_desktop }}px;
    font-weight: {{ block.settings.text_weight }};
    color: {{ block.settings.text_color }};
    line-height: 1.5;
  }

  .ai-hero-cta-wrapper-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.spacing_cta_subtext_desktop }}px;
  }

  .ai-hero-cta-{{ ai_gen_id }} {
    display: inline-block;
    padding: 15px 30px;
    background-color: {{ block.settings.cta_bg_color }};
    color: {{ block.settings.cta_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.cta_border_radius }}px;
    font-size: {{ block.settings.cta_size_desktop }}px;
    font-weight: {{ block.settings.cta_weight }};
    transition: all 0.3s ease;
  }

  .ai-hero-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_hover_bg_color }};
    color: {{ block.settings.cta_hover_text_color }};
  }

  .ai-hero-subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_size_desktop }}px;
    font-weight: {{ block.settings.subtext_weight }};
    color: {{ block.settings.subtext_color }};
    line-height: 1.4;
  }

  .ai-hero-image-wrapper-{{ ai_gen_id }} {
    flex: 1;
    position: relative;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .ai-hero-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
    object-position: bottom;
  }

  .ai-hero-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: 500px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-hero-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-hero-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-hero-image-mobile-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top_mobile }}px;
    }

    .ai-hero-container-{{ ai_gen_id }} {
      padding: 0;
      gap: {{ block.settings.gap_mobile }}px;
      {% if block.settings.mobile_layout == 'image-first' %}
        flex-direction: column;
      {% else %}
        flex-direction: column-reverse;
      {% endif %}
    }

    .ai-hero-content-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.padding_horizontal_mobile }}px;
      {% if block.settings.mobile_alignment == 'left' %}
        align-items: flex-start;
        text-align: left;
      {% elsif block.settings.mobile_alignment == 'center' %}
        align-items: center;
        text-align: center;
      {% else %}
        align-items: flex-end;
        text-align: right;
      {% endif %}
    }

    .ai-hero-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
      margin-bottom: {{ block.settings.spacing_h1_text_mobile }}px;
    }

    .ai-hero-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
      margin-bottom: {{ block.settings.spacing_text_cta_mobile }}px;
    }

    .ai-hero-cta-{{ ai_gen_id }} {
      font-size: {{ block.settings.cta_size_mobile }}px;
    }

    .ai-hero-cta-wrapper-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.spacing_cta_subtext_mobile }}px;
    }

    .ai-hero-subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_size_mobile }}px;
      {% if block.settings.mobile_alignment == 'center' %}
        text-align: center;
      {% endif %}
    }

    .ai-hero-image-wrapper-{{ ai_gen_id }} {
      width: 100%;
      padding: 0;
    }

    .ai-hero-image-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-hero-image-mobile-{{ ai_gen_id }} {
      display: block;
    }

    .ai-hero-image-placeholder-{{ ai_gen_id }} {
      min-height: 300px;
    }
  }
{% endstyle %}

<div class="ai-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-container-{{ ai_gen_id }}">
    <div class="ai-hero-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h1 class="ai-hero-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h1>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-hero-text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
      {% endif %}

      {% if block.settings.cta_text != blank %}
        <div class="ai-hero-cta-wrapper-{{ ai_gen_id }}">
          <a href="{{ block.settings.cta_link }}" class="ai-hero-cta-{{ ai_gen_id }}">
            {{ block.settings.cta_text }}
          </a>
        </div>
      {% endif %}

      {% if block.settings.subtext != blank %}
        <div class="ai-hero-subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</div>
      {% endif %}
    </div>

    <div class="ai-hero-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 2000 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-hero-image-{{ ai_gen_id }} ai-hero-image-desktop-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-hero-image-placeholder-{{ ai_gen_id }} ai-hero-image-desktop-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-hero-empty-state-{{ ai_gen_id }}">
            Next, add an image
          </div>
        </div>
      {% endif %}

      {% if block.settings.image_mobile %}
        <img
          src="{{ block.settings.image_mobile | image_url: width: 1500 }}"
          alt="{{ block.settings.image_mobile.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image_mobile.width }}"
          height="{{ block.settings.image_mobile.height }}"
          class="ai-hero-image-{{ ai_gen_id }} ai-hero-image-mobile-{{ ai_gen_id }}"
        >
      {% elsif block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 1500 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-hero-image-{{ ai_gen_id }} ai-hero-image-mobile-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-hero-image-placeholder-{{ ai_gen_id }} ai-hero-image-mobile-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-hero-empty-state-{{ ai_gen_id }}">
            Next, add an image
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

