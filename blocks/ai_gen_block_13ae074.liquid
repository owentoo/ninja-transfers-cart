{% doc %}
  @prompt
    i need a hero section width a max width container, inside that a wrapper that can be aligned with the container with a max width, in the container an h1 and para text , for Container max width i need desktop and mobile horizontal padding in multiples of 2, add a line of text above the h1, and add three sales points with icons under the h1, swap sales points and para text. and under that i need two buttons with the same rules side by side. on a line under that i need two blocks separated by a vertical line, each block contains bold text with small text under it , need the option to add my own Points icon. Don't need an of the show hide toggles.
    eyebrow text, h1, and text need to accept inline html , eye brow and h1 need to be able to take html, not rich text, all point icons can be the same , all text needs desktop and mobile size options, Stats style boxes need max width, and smaller text size option , Stats style content needs to align to top on desktop , on desktop stats divider should be as tall as stats, on mobile stack them and go full width. on mobile give me an option to cut down on padding between points , get rid of Letter spacing and Text transform in eyebrow. make buttons  1 and 2 use the same style. add optional third button that only shows on mobile with its own color rules , add the option for bg to be an image with an overlay gradient , have gradient width align to Content with padding , Overlay gradient isn't smooth it's banding on desktop. and on mobile it should be a solid overlay, get rid of Overlay padding, Overlay gradient (desktop) needs to apply to the bg and be full width, add option for a mobile bg image , all Bottom spacing needs desktop and mobile setting. get rid of all button Borders. add option for space between buttons on mobile 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    position: relative;
    {% if block.settings.background_image %}
      background-image: url('{{ block.settings.background_image | image_url: width: 2000 }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% endif %}
  }

  .ai-hero-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    background: {{ block.settings.overlay_gradient }};
    opacity: {{ block.settings.overlay_opacity }};
    pointer-events: none;
    image-rendering: -webkit-optimize-contrast;
    image-rendering: crisp-edges;
  }

  .ai-hero-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.container_padding_desktop }}px;
    position: relative;
    z-index: 1;
  }

  .ai-hero-wrapper-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
    text-align: {{ block.settings.text_alignment }};
    position: relative;
    {% if block.settings.wrapper_alignment == 'left' %}
      margin-left: 0;
      margin-right: auto;
    {% elsif block.settings.wrapper_alignment == 'right' %}
      margin-left: auto;
      margin-right: 0;
    {% endif %}
  }

  .ai-hero-eyebrow-{{ ai_gen_id }} {
    font-family: {{ block.settings.eyebrow_font.family }}, {{ block.settings.eyebrow_font.fallback_families }};
    font-weight: {{ block.settings.eyebrow_font.weight }};
    font-size: {{ block.settings.eyebrow_size_desktop }}px;
    line-height: 1.4;
    color: {{ block.settings.eyebrow_color }};
    margin: 0 0 {{ block.settings.eyebrow_spacing_desktop }}px;
  }

  .ai-hero-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size_desktop }}px;
    line-height: {{ block.settings.heading_line_height }};
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing_desktop }}px;
  }

  .ai-hero-points-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.points_gap }}px;
    margin-bottom: {{ block.settings.points_spacing_desktop }}px;
    {% if block.settings.text_alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.text_alignment == 'right' %}
      justify-content: flex-end;
    {% else %}
      justify-content: flex-start;
    {% endif %}
    flex-wrap: wrap;
  }

  .ai-hero-point-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.point_icon_gap }}px;
  }

  .ai-hero-point-icon-{{ ai_gen_id }} {
    width: {{ block.settings.point_icon_size }}px;
    height: {{ block.settings.point_icon_size }}px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-point-icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-hero-point-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    color: {{ block.settings.point_icon_color }};
  }

  .ai-hero-point-text-{{ ai_gen_id }} {
    font-family: {{ block.settings.point_font.family }}, {{ block.settings.point_font.fallback_families }};
    font-weight: {{ block.settings.point_font.weight }};
    font-size: {{ block.settings.point_size_desktop }}px;
    line-height: 1.4;
    color: {{ block.settings.point_color }};
  }

  .ai-hero-text-{{ ai_gen_id }} {
    font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
    font-weight: {{ block.settings.text_font.weight }};
    font-size: {{ block.settings.text_size_desktop }}px;
    line-height: {{ block.settings.text_line_height }};
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.text_spacing_desktop }}px;
  }

  .ai-hero-buttons-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.buttons_gap }}px;
    margin-bottom: {{ block.settings.buttons_spacing_desktop }}px;
    {% if block.settings.text_alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.text_alignment == 'right' %}
      justify-content: flex-end;
    {% else %}
      justify-content: flex-start;
    {% endif %}
    flex-wrap: wrap;
  }

  .ai-hero-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
    font-weight: {{ block.settings.button_font.weight }};
    font-size: {{ block.settings.button_size_desktop }}px;
    text-decoration: none;
    border-radius: {{ block.settings.button_radius }}px;
    transition: all 0.3s ease;
    cursor: pointer;
    background-color: {{ block.settings.button_bg }};
    color: {{ block.settings.button_text }};
    border: none;
  }

  .ai-hero-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_bg_hover }};
    color: {{ block.settings.button_text_hover }};
  }

  .ai-hero-button-mobile-{{ ai_gen_id }} {
    display: none;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
    font-weight: {{ block.settings.button_font.weight }};
    font-size: {{ block.settings.button_size_desktop }}px;
    text-decoration: none;
    border-radius: {{ block.settings.button_radius }}px;
    transition: all 0.3s ease;
    cursor: pointer;
    background-color: {{ block.settings.button_mobile_bg }};
    color: {{ block.settings.button_mobile_text }};
    border: none;
  }

  .ai-hero-button-mobile-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_mobile_bg_hover }};
    color: {{ block.settings.button_mobile_text_hover }};
  }

  .ai-hero-stats-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.stats_gap }}px;
    align-items: stretch;
    {% if block.settings.text_alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.text_alignment == 'right' %}
      justify-content: flex-end;
    {% else %}
      justify-content: flex-start;
    {% endif %}
  }

  .ai-hero-stat-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.stat_gap }}px;
    max-width: {{ block.settings.stat_max_width }}px;
    justify-content: flex-start;
  }

  .ai-hero-stat-divider-{{ ai_gen_id }} {
    width: {{ block.settings.divider_width }}px;
    background-color: {{ block.settings.divider_color }};
    flex-shrink: 0;
    align-self: stretch;
  }

  .ai-hero-stat-value-{{ ai_gen_id }} {
    font-family: {{ block.settings.stat_value_font.family }}, {{ block.settings.stat_value_font.fallback_families }};
    font-weight: {{ block.settings.stat_value_font.weight }};
    font-size: {{ block.settings.stat_value_size_desktop }}px;
    line-height: 1.2;
    color: {{ block.settings.stat_value_color }};
    margin: 0;
  }

  .ai-hero-stat-label-{{ ai_gen_id }} {
    font-family: {{ block.settings.stat_label_font.family }}, {{ block.settings.stat_label_font.fallback_families }};
    font-weight: {{ block.settings.stat_label_font.weight }};
    font-size: {{ block.settings.stat_label_size_desktop }}px;
    line-height: 1.4;
    color: {{ block.settings.stat_label_color }};
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.6 }}px 0 {{ block.settings.section_padding_bottom | times: 0.6 }}px;
      {% if block.settings.background_image_mobile %}
        background-image: url('{{ block.settings.background_image_mobile | image_url: width: 1000 }}');
      {% endif %}
    }

    .ai-hero-container-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.container_padding_mobile }}px;
    }

    .ai-hero-overlay-{{ ai_gen_id }} {
      background: {{ block.settings.overlay_mobile_color }};
    }

    .ai-hero-eyebrow-{{ ai_gen_id }} {
      font-size: {{ block.settings.eyebrow_size_mobile }}px;
      margin-bottom: {{ block.settings.eyebrow_spacing_mobile }}px;
    }

    .ai-hero-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
      margin-bottom: {{ block.settings.heading_spacing_mobile }}px;
    }

    .ai-hero-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
      margin-bottom: {{ block.settings.text_spacing_mobile }}px;
    }

    .ai-hero-points-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: {% if block.settings.text_alignment == 'center' %}center{% elsif block.settings.text_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
      gap: {{ block.settings.points_gap_mobile }}px;
      margin-bottom: {{ block.settings.points_spacing_mobile }}px;
    }

    .ai-hero-point-icon-{{ ai_gen_id }} {
      width: {{ block.settings.point_icon_size | times: 0.8 }}px;
      height: {{ block.settings.point_icon_size | times: 0.8 }}px;
    }

    .ai-hero-point-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.point_size_mobile }}px;
    }

    .ai-hero-buttons-{{ ai_gen_id }} {
      flex-direction: column;
      width: 100%;
      gap: {{ block.settings.buttons_gap_mobile }}px;
      margin-bottom: {{ block.settings.buttons_spacing_mobile }}px;
    }

    .ai-hero-button-{{ ai_gen_id }} {
      width: 100%;
      font-size: {{ block.settings.button_size_mobile }}px;
    }

    .ai-hero-button-mobile-{{ ai_gen_id }} {
      display: inline-flex;
      width: 100%;
      font-size: {{ block.settings.button_size_mobile }}px;
    }

    .ai-hero-stats-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.stats_gap_mobile }}px;
      width: 100%;
    }

    .ai-hero-stat-{{ ai_gen_id }} {
      max-width: 100%;
      width: 100%;
    }

    .ai-hero-stat-divider-{{ ai_gen_id }} {
      width: 100%;
      height: {{ block.settings.divider_width }}px;
    }

    .ai-hero-stat-value-{{ ai_gen_id }} {
      font-size: {{ block.settings.stat_value_size_mobile }}px;
    }

    .ai-hero-stat-label-{{ ai_gen_id }} {
      font-size: {{ block.settings.stat_label_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.background_image %}
    <div class="ai-hero-overlay-{{ ai_gen_id }}"></div>
  {% endif %}
  
  <div class="ai-hero-container-{{ ai_gen_id }}">
    <div class="ai-hero-wrapper-{{ ai_gen_id }}">
      {% if block.settings.eyebrow != blank %}
        <div class="ai-hero-eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow }}</div>
      {% endif %}
      
      {% if block.settings.heading != blank %}
        <h1 class="ai-hero-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h1>
      {% endif %}
      
      {% if block.settings.point_1_text != blank or block.settings.point_2_text != blank or block.settings.point_3_text != blank %}
        <div class="ai-hero-points-{{ ai_gen_id }}">
          {% if block.settings.point_1_text != blank %}
            <div class="ai-hero-point-{{ ai_gen_id }}">
              <div class="ai-hero-point-icon-{{ ai_gen_id }}">
                {% if block.settings.point_icon %}
                  <img src="{{ block.settings.point_icon | image_url: width: 100 }}" alt="" loading="lazy" width="100" height="100">
                {% else %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                {% endif %}
              </div>
              <span class="ai-hero-point-text-{{ ai_gen_id }}">{{ block.settings.point_1_text }}</span>
            </div>
          {% endif %}

          {% if block.settings.point_2_text != blank %}
            <div class="ai-hero-point-{{ ai_gen_id }}">
              <div class="ai-hero-point-icon-{{ ai_gen_id }}">
                {% if block.settings.point_icon %}
                  <img src="{{ block.settings.point_icon | image_url: width: 100 }}" alt="" loading="lazy" width="100" height="100">
                {% else %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                {% endif %}
              </div>
              <span class="ai-hero-point-text-{{ ai_gen_id }}">{{ block.settings.point_2_text }}</span>
            </div>
          {% endif %}

          {% if block.settings.point_3_text != blank %}
            <div class="ai-hero-point-{{ ai_gen_id }}">
              <div class="ai-hero-point-icon-{{ ai_gen_id }}">
                {% if block.settings.point_icon %}
                  <img src="{{ block.settings.point_icon | image_url: width: 100 }}" alt="" loading="lazy" width="100" height="100">
                {% else %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                {% endif %}
              </div>
              <span class="ai-hero-point-text-{{ ai_gen_id }}">{{ block.settings.point_3_text }}</span>
            </div>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-hero-text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
      {% endif %}

      {% if block.settings.button_1_text != blank or block.settings.button_2_text != blank or block.settings.button_3_text != blank %}
        <div class="ai-hero-buttons-{{ ai_gen_id }}">
          {% if block.settings.button_1_text != blank %}
            <a href="{{ block.settings.button_1_link }}" class="ai-hero-button-{{ ai_gen_id }}">
              {{ block.settings.button_1_text }}
            </a>
          {% endif %}

          {% if block.settings.button_2_text != blank %}
            <a href="{{ block.settings.button_2_link }}" class="ai-hero-button-{{ ai_gen_id }}">
              {{ block.settings.button_2_text }}
            </a>
          {% endif %}

          {% if block.settings.button_3_text != blank %}
            <a href="{{ block.settings.button_3_link }}" class="ai-hero-button-mobile-{{ ai_gen_id }}">
              {{ block.settings.button_3_text }}
            </a>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.stat_1_value != blank or block.settings.stat_2_value != blank %}
        <div class="ai-hero-stats-{{ ai_gen_id }}">
          {% if block.settings.stat_1_value != blank %}
            <div class="ai-hero-stat-{{ ai_gen_id }}">
              <div class="ai-hero-stat-value-{{ ai_gen_id }}">{{ block.settings.stat_1_value }}</div>
              {% if block.settings.stat_1_label != blank %}
                <div class="ai-hero-stat-label-{{ ai_gen_id }}">{{ block.settings.stat_1_label }}</div>
              {% endif %}
            </div>
          {% endif %}

          {% if block.settings.stat_1_value != blank and block.settings.stat_2_value != blank %}
            <div class="ai-hero-stat-divider-{{ ai_gen_id }}"></div>
          {% endif %}

          {% if block.settings.stat_2_value != blank %}
            <div class="ai-hero-stat-{{ ai_gen_id }}">
              <div class="ai-hero-stat-value-{{ ai_gen_id }}">{{ block.settings.stat_2_value }}</div>
              {% if block.settings.stat_2_label != blank %}
                <div class="ai-hero-stat-label-{{ ai_gen_id }}">{{ block.settings.stat_2_label }}</div>
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero section",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "html",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "html",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to our store"
    },
    {
      "type": "inline_richtext",
      "id": "text",
      "label": "Text",
      "default": "Discover our amazing products and exclusive offers"
    },
    {
      "type": "header",
      "content": "Points"
    },
    {
      "type": "image_picker",
      "id": "point_icon",
      "label": "Icon"
    },
    {
      "type": "text",
      "id": "point_1_text",
      "label": "Point 1",
      "default": "Free shipping over $50"
    },
    {
      "type": "text",
      "id": "point_2_text",
      "label": "Point 2",
      "default": "30-day returns"
    },
    {
      "type": "text",
      "id": "point_3_text",
      "label": "Point 3",
      "default": "Secure checkout"
    },
    {
      "type": "header",
      "content": "Button 1"
    },
    {
      "type": "text",
      "id": "button_1_text",
      "label": "Text",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Button 2"
    },
    {
      "type": "text",
      "id": "button_2_text",
      "label": "Text",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Button 3 (mobile only)"
    },
    {
      "type": "text",
      "id": "button_3_text",
      "label": "Text"
    },
    {
      "type": "url",
      "id": "button_3_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Stat 1"
    },
    {
      "type": "text",
      "id": "stat_1_value",
      "label": "Value",
      "default": "10,000+"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Label",
      "default": "Happy customers"
    },
    {
      "type": "header",
      "content": "Stat 2"
    },
    {
      "type": "text",
      "id": "stat_2_value",
      "label": "Value",
      "default": "5-star"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Label",
      "default": "Average rating"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "container_max_width",
      "label": "Container max width",
      "min": 800,
      "max": 2000,
      "step": 50,
      "unit": "px",
      "default": 1400
    },
    {
      "type": "range",
      "id": "container_padding_desktop",
      "label": "Horizontal padding desktop",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "container_padding_mobile",
      "label": "Horizontal padding mobile",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 400,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "default": 800
    },
    {
      "type": "select",
      "id": "wrapper_alignment",
      "label": "Content alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Eyebrow style"
    },
    {
      "type": "font_picker",
      "id": "eyebrow_font",
      "label": "Font",
      "default": "inter_n6"
    },
    {
      "type": "range",
      "id": "eyebrow_size_desktop",
      "label": "Size desktop",
