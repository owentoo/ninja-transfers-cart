{% doc %}
  @prompt
    i need a section with an h2 and text on the left and on the right 6 images 3 by 3 with text under them, these should be 2 over 2 on mobile , needs a max width that follow the themes include all hoizontal padding and margin rules , for the text section make it a percentage i can change for width and let the pictures take up the rest of the space , Caption needs size and weight options. all text should have desktop and mobile size options , Gap between text and images needs desktop and mobile options , add option for bg color and give me top and bottom padding for desktop and mobile , give me an option to indent pad caption
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-content-grid-outer-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
  }

  .ai-content-grid-container-{{ ai_gen_id }} {
    max-width: {{ settings.theme_max_width }}px;
    margin: 0 auto;
    padding: 0 {{ settings.grid_gap }}px;
  }

  .ai-content-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: {{ block.settings.text_width }}% 1fr;
    gap: {{ block.settings.section_gap }}px;
    max-width: 100%;
  }

  .ai-content-grid__text-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: {{ block.settings.text_gap }}px;
  }

  .ai-content-grid__heading-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    line-height: 1.2;
  }

  .ai-content-grid__description-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
  }

  .ai-content-grid__images-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.image_gap }}px;
  }

  .ai-content-grid__image-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.caption_gap }}px;
  }

  .ai-content-grid__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    background-color: {{ block.settings.image_background }};
  }

  .ai-content-grid__image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: {% if block.settings.image_fit %}contain{% else %}cover{% endif %};
  }

  .ai-content-grid__image-wrapper-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-content-grid__caption-{{ ai_gen_id }} {
    font-size: {{ block.settings.caption_size }}px;
    font-weight: {{ block.settings.caption_weight }};
    color: {{ block.settings.caption_color }};
    text-align: {{ block.settings.caption_alignment }};
    margin: 0;
    padding: 0 {{ block.settings.caption_padding }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-content-grid-outer-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top_mobile }}px;
      padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-content-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.section_gap_mobile }}px;
    }

    .ai-content-grid__images-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }

    .ai-content-grid__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-content-grid__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
    }

    .ai-content-grid__caption-{{ ai_gen_id }} {
      font-size: {{ block.settings.caption_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-content-grid-outer-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-content-grid-container-{{ ai_gen_id }}">
    <div class="ai-content-grid-{{ ai_gen_id }}">
      <div class="ai-content-grid__text-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-content-grid__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        
        {% if block.settings.description != blank %}
          <div class="ai-content-grid__description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
        {% endif %}
      </div>

      <div class="ai-content-grid__images-{{ ai_gen_id }}">
        {% for i in (1..6) %}
          {% liquid
            assign image_key = 'image_' | append: i
            assign caption_key = 'caption_' | append: i
            assign image = block.settings[image_key]
            assign caption = block.settings[caption_key]
          %}
          
          <div class="ai-content-grid__image-item-{{ ai_gen_id }}">
            <div class="ai-content-grid__image-wrapper-{{ ai_gen_id }}">
              {% if image %}
                <img
                  src="{{ image | image_url: width: 600 }}"
                  alt="{{ image.alt | escape }}"
                  loading="lazy"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                >
              {% else %}
                {{ 'image' | placeholder_svg_tag }}
              {% endif %}
            </div>
            
            {% if caption != blank %}
              <p class="ai-content-grid__caption-{{ ai_gen_id }}">{{ caption }}</p>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

