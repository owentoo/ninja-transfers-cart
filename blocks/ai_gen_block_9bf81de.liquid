<script>
  (function() {
    class CategorySlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.track = this.querySelector('.ai-category-slider-track-{{ ai_gen_id }}');
        this.autoScroll = this.dataset.autoScroll === 'true';
        this.autoScrollSpeed = parseInt(this.dataset.autoScrollSpeed) || 3000;
        this.loopEnabled = this.dataset.loop === 'true';
        this.autoScrollInterval = null;
        this.isUserInteracting = false;
        this.resumeTimeout = null;
      }

      connectedCallback() {
        if (this.autoScroll) {
          this.startAutoScroll();
          this.setupInteractionListeners();
        }
      }

      disconnectedCallback() {
        this.stopAutoScroll();
        if (this.resumeTimeout) {
          clearTimeout(this.resumeTimeout);
        }
      }

      startAutoScroll() {
        this.autoScrollInterval = setInterval(() => {
          if (!this.isUserInteracting) {
            this.scrollNext();
          }
        }, this.autoScrollSpeed);
      }

      stopAutoScroll() {
        if (this.autoScrollInterval) {
          clearInterval(this.autoScrollInterval);
          this.autoScrollInterval = null;
        }
      }

      scrollNext() {
        const cards = this.track.querySelectorAll('.ai-category-slider-card-{{ ai_gen_id }}');
        if (cards.length === 0) return;

        const cardWidth = cards[0].offsetWidth;
        const gap = {{ block.settings.card_gap }};
        const scrollAmount = cardWidth + gap;
        const maxScroll = this.track.scrollWidth - this.track.clientWidth;

        if (this.track.scrollLeft >= maxScroll - 10) {
          if (this.loopEnabled) {
            this.track.scrollLeft = 0;
          }
        } else {
          this.track.scrollLeft += scrollAmount;
        }
      }

      setupInteractionListeners() {
        this.track.addEventListener('touchstart', () => {
          this.handleUserInteraction();
        });

        this.track.addEventListener('mousedown', () => {
          this.handleUserInteraction();
        });

        this.track.addEventListener('scroll', () => {
          this.handleUserInteraction();
        }, { passive: true });
      }

      handleUserInteraction() {
        this.isUserInteracting = true;

        if (this.resumeTimeout) {
          clearTimeout(this.resumeTimeout);
        }

        this.resumeTimeout = setTimeout(() => {
          this.isUserInteracting = false;
        }, 2000);
      }
    }

    customElements.define('category-slider-{{ ai_gen_id }}', CategorySlider{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Category slider",
  "tag": null,
  "class": "mobile-category-slider",
  "settings": [
    {
      "type": "header",
      "content": "Section heading"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show heading",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 24
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "heading_padding_top",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Heading top padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "heading_padding_bottom",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
