{% doc %}
  @prompt
    i want a group of scrollable link blocks with ratio options an image bg, two lines of text with weight size and color options and a cta, need padding option on the left of the first block , all padding needs to be in increments of 2, content and overlay needs alignments options top middle and bottom, content alignments should apply to all cards. overlay should have height and opacity issue. i do not need rollover effects, and content should have a max width option , overlay needs to be gradiant , bg of entire section needs color and gradient options, not seeing Section background
    , get rid of section bg, need top and bottom padding to work, need up to 8 cards, content in cards need alignment options right, left, center. all content optional , add options for pill above text with weight, size, color, radius, and padding options, make cta optional and add an option for it to be a circle with opacity with an arrow inside of it , add option for arrow boldness, circle and arrow both need size options, Card layout should just be height and width for desktop and mobile. gradient should have the color option of none. pill font size should go as low as 8. add one more line of text below Text 2 style, mobile card height not working , all text should be align horizontally top and arrow/.button should be aliagned horiziontlly bottom, all content in the card should be contained in a top middle or bottom , all text needs padding option under , arrow needs opacity separate from circle , whole card needs to act as link
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-scrollable-cards-{{ ai_gen_id }} {
    padding-top: {{ block.settings.section_padding_top }}px;
    padding-bottom: {{ block.settings.section_padding_bottom }}px;
    {% if block.settings.section_bg_type == 'solid' %}
      background-color: {{ block.settings.section_bg_color }};
    {% elsif block.settings.section_bg_type == 'gradient' %}
      background: linear-gradient({{ block.settings.gradient_angle }}deg, {{ block.settings.gradient_color_1 }} 0%, {{ block.settings.gradient_color_2 }} 100%);
    {% endif %}
  }

  .ai-scrollable-cards__container-{{ ai_gen_id }} {
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .ai-scrollable-cards__container-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-scrollable-cards__wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    padding-left: {{ block.settings.first_card_padding }}px;
    padding-right: 20px;
  }

  .ai-scrollable-cards__card-{{ ai_gen_id }} {
    position: relative;
    flex: 0 0 auto;
    width: {{ block.settings.card_width_desktop }}px;
    height: {{ block.settings.card_height_desktop }}px;
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    display: block;
    text-decoration: none;
  }

  .ai-scrollable-cards__bg-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-scrollable-cards__overlay-{{ ai_gen_id }} {
    position: absolute;
    left: 0;
    right: 0;
    {% if block.settings.overlay_position == 'top' %}
      top: 0;
    {% elsif block.settings.overlay_position == 'middle' %}
      top: 50%;
      transform: translateY(-50%);
    {% elsif block.settings.overlay_position == 'bottom' %}
      bottom: 0;
    {% endif %}
    height: {{ block.settings.overlay_height }}%;
    {% if block.settings.overlay_gradient_start != 'none' and block.settings.overlay_gradient_end != 'none' %}
      background: linear-gradient(180deg, {{ block.settings.overlay_gradient_start }} 0%, {{ block.settings.overlay_gradient_end }} 100%);
    {% elsif block.settings.overlay_gradient_start != 'none' %}
      background: {{ block.settings.overlay_gradient_start }};
    {% elsif block.settings.overlay_gradient_end != 'none' %}
      background: {{ block.settings.overlay_gradient_end }};
    {% endif %}
    opacity: {{ block.settings.overlay_opacity }};
  }

  .ai-scrollable-cards__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    padding: {{ block.settings.content_padding }}px;
    {% if block.settings.content_vertical_align == 'top' %}
      justify-content: flex-start;
    {% elsif block.settings.content_vertical_align == 'middle' %}
      justify-content: center;
    {% elsif block.settings.content_vertical_align == 'bottom' %}
      justify-content: flex-end;
    {% endif %}
    {% if block.settings.content_horizontal_align == 'left' %}
      align-items: flex-start;
      text-align: left;
    {% elsif block.settings.content_horizontal_align == 'center' %}
      align-items: center;
      text-align: center;
    {% elsif block.settings.content_horizontal_align == 'right' %}
      align-items: flex-end;
      text-align: right;
    {% endif %}
  }

  .ai-scrollable-cards__content-inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    width: 100%;
    display: flex;
    flex-direction: column;
    {% if block.settings.content_horizontal_align == 'left' %}
      align-items: flex-start;
    {% elsif block.settings.content_horizontal_align == 'center' %}
      align-items: center;
    {% elsif block.settings.content_horizontal_align == 'right' %}
      align-items: flex-end;
    {% endif %}
  }

  .ai-scrollable-cards__pill-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.pill_padding_vertical }}px {{ block.settings.pill_padding_horizontal }}px;
    background-color: {{ block.settings.pill_bg_color }};
    color: {{ block.settings.pill_text_color }};
    font-size: {{ block.settings.pill_font_size }}px;
    font-weight: {{ block.settings.pill_font_weight }};
    border-radius: {{ block.settings.pill_border_radius }}px;
    margin-bottom: {{ block.settings.pill_padding_bottom }}px;
  }

  .ai-scrollable-cards__text1-{{ ai_gen_id }} {
    color: {{ block.settings.text1_color }};
    font-size: {{ block.settings.text1_size }}px;
    font-weight: {{ block.settings.text1_weight }};
    margin: 0 0 {{ block.settings.text1_padding_bottom }}px 0;
  }

  .ai-scrollable-cards__text2-{{ ai_gen_id }} {
    color: {{ block.settings.text2_color }};
    font-size: {{ block.settings.text2_size }}px;
    font-weight: {{ block.settings.text2_weight }};
    margin: 0 0 {{ block.settings.text2_padding_bottom }}px 0;
  }

  .ai-scrollable-cards__text3-{{ ai_gen_id }} {
    color: {{ block.settings.text3_color }};
    font-size: {{ block.settings.text3_size }}px;
    font-weight: {{ block.settings.text3_weight }};
    margin: 0 0 {{ block.settings.text3_padding_bottom }}px 0;
  }

  .ai-scrollable-cards__cta-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    {% if block.settings.cta_style == 'button' %}
      padding: 12px 24px;
      background-color: {{ block.settings.cta_bg_color }};
      color: {{ block.settings.cta_text_color }};
      border-radius: {{ block.settings.cta_border_radius }}px;
      font-size: {{ block.settings.cta_font_size }}px;
      font-weight: {{ block.settings.cta_font_weight }};
    {% elsif block.settings.cta_style == 'circle' %}
      width: {{ block.settings.cta_circle_size }}px;
      height: {{ block.settings.cta_circle_size }}px;
      border-radius: 50%;
      background-color: {{ block.settings.cta_circle_bg }};
      opacity: {{ block.settings.cta_circle_opacity }};
    {% endif %}
  }

  .ai-scrollable-cards__arrow-{{ ai_gen_id }} {
    width: {{ block.settings.cta_arrow_size }}px;
    height: {{ block.settings.cta_arrow_size }}px;
    stroke: {{ block.settings.cta_circle_arrow_color }};
    stroke-width: {{ block.settings.cta_arrow_boldness }};
    opacity: {{ block.settings.cta_arrow_opacity }};
  }

  @media screen and (max-width: 749px) {
    .ai-scrollable-cards__card-{{ ai_gen_id }} {
      width: {{ block.settings.card_width_mobile }}px;
      height: {{ block.settings.card_height_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-scrollable-cards-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-scrollable-cards__container-{{ ai_gen_id }}">
    <div class="ai-scrollable-cards__wrapper-{{ ai_gen_id }}">
      {% for i in (1..8) %}
        {% liquid
          assign card_enabled_key = 'card_' | append: i | append: '_enabled'
          assign card_image_key = 'card_' | append: i | append: '_image'
          assign card_pill_key = 'card_' | append: i | append: '_pill'
          assign card_text1_key = 'card_' | append: i | append: '_text1'
          assign card_text2_key = 'card_' | append: i | append: '_text2'
          assign card_text3_key = 'card_' | append: i | append: '_text3'
          assign card_cta_text_key = 'card_' | append: i | append: '_cta_text'
          assign card_cta_link_key = 'card_' | append: i | append: '_cta_link'

          assign card_enabled = block.settings[card_enabled_key]
          assign card_image = block.settings[card_image_key]
          assign card_pill = block.settings[card_pill_key]
          assign card_text1 = block.settings[card_text1_key]
          assign card_text2 = block.settings[card_text2_key]
          assign card_text3 = block.settings[card_text3_key]
          assign card_cta_text = block.settings[card_cta_text_key]
          assign card_cta_link = block.settings[card_cta_link_key]
        %}

        {% if card_enabled %}
          <a href="{{ card_cta_link }}" class="ai-scrollable-cards__card-{{ ai_gen_id }}">
            {% if card_image %}
              <img
                src="{{ card_image | image_url: width: 800 }}"
                alt="{{ card_image.alt | escape }}"
                class="ai-scrollable-cards__bg-{{ ai_gen_id }}"
                loading="lazy"
                width="800"
                height="800"
              >
            {% else %}
              <div class="ai-scrollable-cards__bg-{{ ai_gen_id }}" style="background-color: #f4f4f4;"></div>
            {% endif %}

            <div class="ai-scrollable-cards__overlay-{{ ai_gen_id }}"></div>

            <div class="ai-scrollable-cards__content-{{ ai_gen_id }}">
              <div class="ai-scrollable-cards__content-inner-{{ ai_gen_id }}">
                {% if card_pill != blank %}
                  <div class="ai-scrollable-cards__pill-{{ ai_gen_id }}">{{ card_pill }}</div>
                {% endif %}

                {% if card_text1 != blank %}
                  <h3 class="ai-scrollable-cards__text1-{{ ai_gen_id }}">{{ card_text1 }}</h3>
                {% endif %}

                {% if card_text2 != blank %}
                  <p class="ai-scrollable-cards__text2-{{ ai_gen_id }}">{{ card_text2 }}</p>
                {% endif %}

                {% if card_text3 != blank %}
                  <p class="ai-scrollable-cards__text3-{{ ai_gen_id }}">{{ card_text3 }}</p>
                {% endif %}

                {% if block.settings.cta_enabled %}
                  <span class="ai-scrollable-cards__cta-{{ ai_gen_id }}">
                    {% if block.settings.cta_style == 'button' %}
                      {{ card_cta_text }}
                    {% elsif block.settings.cta_style == 'circle' %}
                      <svg class="ai-scrollable-cards__arrow-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    {% endif %}
                  </span>
                {% endif %}
              </div>
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

