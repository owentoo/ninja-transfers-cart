{% doc %}
  @prompt
    make me a section that follows the themes horizontal mad width padding and margin. i that i need a div i can align left right and center within the max width inside it i need an h1 and text, now give the section padding and margin option for top and bottom, mobile and desktop. and i need alignment rules for both the content and text on desktop and mobile, now give me options for the section to have a color, gradient, or photo with optional overlay background, that background option should cover the whole section, Text needs weight options, add Space between heading and text option to desktop, make Space between heading and text go by intervals of 2, give text opacity options, give the heading the option to be an h1 or h2

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-content-section-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
    overflow: hidden;
    {% case block.settings.background_type %}
      {% when 'color' %}
        background-color: {{ block.settings.background_color }};
      {% when 'gradient' %}
        background: linear-gradient({{ block.settings.gradient_angle }}deg, {{ block.settings.gradient_color_1 }} 0%, {{ block.settings.gradient_color_2 }} 100%);
      {% when 'image' %}
        {% if block.settings.background_image %}
          background-image: url('{{ block.settings.background_image | image_url: width: 2000 }}');
          background-size: {{ block.settings.background_size }};
          background-position: {{ block.settings.background_position }};
          background-repeat: no-repeat;
        {% else %}
          background-color: #f4f4f4;
        {% endif %}{% endcase %}
  }

  .ai-content-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    {% if block.settings.background_type == 'image' and block.settings.overlay_enabled %}
      background-color: {{ block.settings.overlay_color }};
      opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    {% endif %}
  }

  .ai-content-container-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ settings.theme_max_width }}px;
    margin-left: auto;
    margin-right: auto;
    padding-left: {{ block.settings.horizontal_padding }}px;
    padding-right: {{ block.settings.horizontal_padding }}px;
    position: relative;
    z-index: 2;
  }

  .ai-content-inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_width }}px;
    margin: 0;
    text-align: {{ block.settings.content_alignment }};
    {% if block.settings.content_alignment == 'center' %}
      margin-left: auto;
      margin-right: auto;
    {% elsif block.settings.content_alignment == 'right' %}
      margin-left: auto;
    {% endif %}
  }

  .ai-content-heading-{{ ai_gen_id }} {
    margin-top: 0;
    margin-bottom: {{ block.settings.space_between }}px;
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
    color: {{ block.settings.heading_color }};
    text-align: {{ block.settings.text_alignment }};
    font-weight: {{ block.settings.heading_weight }};
    opacity: {{ block.settings.heading_opacity | divided_by: 100.0 }};
  }

  .ai-content-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.5;
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_alignment }};
    font-weight: {{ block.settings.text_weight }};
    opacity: {{ block.settings.text_opacity | divided_by: 100.0 }};
  }

  @media screen and (max-width: 749px) {
    .ai-content-section-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top_mobile }}px;
      padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
      margin-top: {{ block.settings.margin_top_mobile }}px;
      margin-bottom: {{ block.settings.margin_bottom_mobile }}px;
    }

    .ai-content-container-{{ ai_gen_id }} {
      padding-left: {{ block.settings.horizontal_padding_mobile }}px;
      padding-right: {{ block.settings.horizontal_padding_mobile }}px;
    }

    .ai-content-inner-{{ ai_gen_id }} {
      text-align: {{ block.settings.content_alignment_mobile }};
      {% if block.settings.content_alignment_mobile == 'center' %}
        margin-left: auto;
        margin-right: auto;
      {% elsif block.settings.content_alignment_mobile == 'right' %}
        margin-left: auto;
        margin-right: 0;
      {% elsif block.settings.content_alignment_mobile == 'left' %}
        margin-left: 0;
        margin-right: auto;
      {% endif %}
    }

    .ai-content-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
      text-align: {{ block.settings.text_alignment_mobile }};
      margin-bottom: {{ block.settings.space_between_mobile }}px;
    }

    .ai-content-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
      text-align: {{ block.settings.text_alignment_mobile }};}
  }
{% endstyle %}

<div class="ai-content-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-content-overlay-{{ ai_gen_id }}"></div>
  <div class="ai-content-container-{{ ai_gen_id }}">
    <div class="ai-content-inner-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        {% if block.settings.heading_tag == 'h1' %}
          <h1 class="ai-content-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h1>
        {% else %}
          <h2 class="ai-content-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
      {% endif %}
      
      {% if block.settings.text != blank %}
        <div class="ai-content-text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
      {% endif %}
    </div>
  </div>
</div>

