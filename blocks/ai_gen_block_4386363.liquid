{% doc %}
  @prompt
    Create a 50/50 Video Hero section.
    
    Layout
    
    Desktop: two columns (content + video) with toggle to swap sides.
    
    Mobile: stack order control, alignment, spacing, and padding controls.
    
    Full-width or boxed toggle with max-width control.
    
    Content Column
    
    H1 supports logo image (image picker) with size controls (desktop + mobile).
    
    Second H1 line: editable text field under logo with full typography controls (desktop + mobile).
    
    Three selling points below headline:
    
    Each point has its own custom check icon (image picker) and text.
    
    Icon size, text style, and spacing controls (desktop + mobile).
    
    Optional CTA button(s) with full style controls (desktop + mobile).
    
    Video Column
    
    Video picker or URL.
    
    Controls: autoplay, loop, muted, poster image.
    
    Size, aspect ratio, border radius, and overlay controls (desktop + mobile).
    
    Global
    
    Background color/image, section padding, column gap.
    
    All elements must have separate desktop and mobile settings.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-hero-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    {% if block.settings.background_image %}
      background-image: url('{{ block.settings.background_image | image_url: width: 2000 }}');
      background-size: cover;
      background-position: center;
    {% endif %}
    padding: {{ block.settings.section_padding_mobile }}px 0;
  }

  @media screen and (min-width: 750px) {
    .ai-video-hero-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_desktop }}px 0;
    }
  }

  .ai-video-hero-container-{{ ai_gen_id }} {
    width: 100%;
    {% if block.settings.layout_width == 'boxed' %}
      max-width: {{ block.settings.max_width }}px;
      margin: 0 auto;
      padding: 0 20px;
    {% endif %}
  }

  .ai-video-hero-grid-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.column_gap_mobile }}px;
    align-items: {{ block.settings.mobile_alignment }};
    {% if block.settings.mobile_stack_order == 'video-first' %}
      flex-direction: column;
    {% else %}
      flex-direction: column-reverse;
    {% endif %}
  }

  @media screen and (min-width: 750px) {
    .ai-video-hero-grid-{{ ai_gen_id }} {
      flex-direction: row;
      gap: {{ block.settings.column_gap_desktop }}px;
      align-items: center;
      {% if block.settings.desktop_layout == 'content-left' %}
        flex-direction: row;
      {% else %}
        flex-direction: row-reverse;
      {% endif %}
    }
  }

  .ai-video-hero-content-{{ ai_gen_id }},
  .ai-video-hero-video-{{ ai_gen_id }} {
    flex: 1;
    width: 100%;
  }

  .ai-video-hero-content-inner-{{ ai_gen_id }} {
    padding: {{ block.settings.content_padding_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-video-hero-content-inner-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding_desktop }}px;
    }
  }

  .ai-video-hero-logo-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.logo_spacing_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-video-hero-logo-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.logo_spacing_desktop }}px;
    }
  }

  .ai-video-hero-logo-{{ ai_gen_id }} img {
    width: {{ block.settings.logo_size_mobile }}px;
    height: auto;
    display: block;
  }

  @media screen and (min-width: 750px) {
    .ai-video-hero-logo-{{ ai_gen_id }} img {
      width: {{ block.settings.logo_size_desktop }}px;
    }
  }

  .ai-video-hero-headline-{{ ai_gen_id }} {
    font-family: {{ block.settings.headline_font.family }}, {{ block.settings.headline_font.fallback_families }};
    font-weight: {{ block.settings.headline_font.weight }};
    font-size: {{ block.settings.headline_size_mobile }}px;
    line-height: {{ block.settings.headline_line_height_mobile }};
    color: {{ block.settings.headline_color }};
    margin: 0 0 {{ block.settings.headline_spacing_mobile }}px 0;
  }

  @media screen and (min-width: 750px) {
    .ai-video-hero-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size_desktop }}px;
      line-height: {{ block.settings.headline_line_height_desktop }};
      margin-bottom: {{ block.settings.headline_spacing_desktop }}px;
    }
  }

  .ai-video-hero-points-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0 0 {{ block.settings.points_spacing_mobile }}px 0;
  }

  @media screen and (min-width: 750px) {
    .ai-video-hero-points-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.points_spacing_desktop }}px;
    }
  }

  .ai-video-hero-point-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.point_icon_gap_mobile }}px;
    margin-bottom: {{ block.settings.point_gap_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-video-hero-point-{{ ai_gen_id }} {
      gap: {{ block.settings.point_icon_gap_desktop }}px;
      margin-bottom: {{ block.settings.point_gap_desktop }}px;
    }
  }

  .ai-video-hero-point-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-video-hero-point-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.point_icon_size_mobile }}px;
    height: {{ block.settings.point_icon_size_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-video-hero-point-icon-{{ ai_gen_id }} {
      width: {{ block.settings.point_icon_size_desktop }}px;
      height: {{ block.settings.point_icon_size_desktop }}px;
    }
  }

  .ai-video-hero-point-icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-video-hero-point-text-{{ ai_gen_id }} {
    font-family: {{ block.settings.point_font.family }}, {{ block.settings.point_font.fallback_families }};
    font-weight: {{ block.settings.point_font.weight }};
    font-size: {{ block.settings.point_text_size_mobile }}px;
    line-height: {{ block.settings.point_line_height_mobile }};
    color: {{ block.settings.point_text_color }};
  }

  @media screen and (min-width: 750px) {
    .ai-video-hero-point-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.point_text_size_desktop }}px;
      line-height: {{ block.settings.point_line_height_desktop }};
    }
  }

  .ai-video-hero-cta-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_mobile }}px {{ block.settings.button_padding_mobile | times: 2 }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
    font-weight: {{ block.settings.button_font.weight }};
    font-size: {{ block.settings.button_text_size_mobile }}px;
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
  }

  @media screen and (min-width: 750px) {
    .ai-video-hero-cta-{{ ai_gen_id }} {
      padding: {{ block.settings.button_padding_desktop }}px {{ block.settings.button_padding_desktop | times: 2 }}px;
      font-size: {{ block.settings.button_text_size_desktop }}px;
    }
  }

  .ai-video-hero-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_bg_hover_color }};
    color: {{ block.settings.button_text_hover_color }};
    border-color: {{ block.settings.button_border_hover_color }};
  }

  .ai-video-hero-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.video_border_radius_mobile }}px;
    {% if block.settings.video_aspect_ratio == 'custom' %}
      padding-bottom: {{ block.settings.video_custom_aspect | times: 100 }}%;
    {% elsif block.settings.video_aspect_ratio == '16-9' %}
      padding-bottom: 56.25%;
    {% elsif block.settings.video_aspect_ratio == '4-3' %}
      padding-bottom: 75%;
    {% elsif block.settings.video_aspect_ratio == '1-1' %}
      padding-bottom: 100%;
    {% elsif block.settings.video_aspect_ratio == '9-16' %}
      padding-bottom: 177.78%;
    {% endif %}
  }

  @media screen and (min-width: 750px) {
    .ai-video-hero-video-wrapper-{{ ai_gen_id }} {
      border-radius: {{ block.settings.video_border_radius_desktop }}px;
    }
  }

  .ai-video-hero-video-wrapper-{{ ai_gen_id }} video,
  .ai-video-hero-video-wrapper-{{ ai_gen_id }} iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-video-hero-video-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.video_overlay_color }};
    opacity: {{ block.settings.video_overlay_opacity }};
    pointer-events: none;
  }
{% endstyle %}

<div class="ai-video-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-video-hero-container-{{ ai_gen_id }}">
    <div class="ai-video-hero-grid-{{ ai_gen_id }}">
      <div class="ai-video-hero-content-{{ ai_gen_id }}">
        <div class="ai-video-hero-content-inner-{{ ai_gen_id }}">
          {% if block.settings.logo_image %}
            <div class="ai-video-hero-logo-{{ ai_gen_id }}">
              <img
                src="{{ block.settings.logo_image | image_url: width: 800 }}"
                alt="{{ block.settings.logo_image.alt | escape }}"
                width="{{ block.settings.logo_size_desktop }}"
                height="auto"
                loading="lazy"
              >
            </div>
          {% endif %}

          {% if block.settings.headline_text != blank %}
            <h1 class="ai-video-hero-headline-{{ ai_gen_id }}">
              {{ block.settings.headline_text }}
            </h1>
          {% endif %}

          <ul class="ai-video-hero-points-{{ ai_gen_id }}">
            {% if block.settings.point_1_text != blank %}
              <li class="ai-video-hero-point-{{ ai_gen_id }}">
                {% if block.settings.point_1_icon %}
                  <div class="ai-video-hero-point-icon-{{ ai_gen_id }}">
                    <img
                      src="{{ block.settings.point_1_icon | image_url: width: 100 }}"
                      alt=""
                      width="100"
                      height="100"
                      loading="lazy"
                    >
                  </div>
                {% endif %}
                <span class="ai-video-hero-point-text-{{ ai_gen_id }}">{{ block.settings.point_1_text }}</span>
              </li>
            {% endif %}

            {% if block.settings.point_2_text != blank %}
              <li class="ai-video-hero-point-{{ ai_gen_id }}">
                {% if block.settings.point_2_icon %}
                  <div class="ai-video-hero-point-icon-{{ ai_gen_id }}">
                    <img
                      src="{{ block.settings.point_2_icon | image_url: width: 100 }}"
                      alt=""
                      width="100"
                      height="100"
                      loading="lazy"
                    >
                  </div>
                {% endif %}
                <span class="ai-video-hero-point-text-{{ ai_gen_id }}">{{ block.settings.point_2_text }}</span>
              </li>
            {% endif %}

            {% if block.settings.point_3_text != blank %}
              <li class="ai-video-hero-point-{{ ai_gen_id }}">
                {% if block.settings.point_3_icon %}
                  <div class="ai-video-hero-point-icon-{{ ai_gen_id }}">
                    <img
                      src="{{ block.settings.point_3_icon | image_url: width: 100 }}"
                      alt=""
                      width="100"
                      height="100"
                      loading="lazy"
                    >
                  </div>
                {% endif %}
                <span class="ai-video-hero-point-text-{{ ai_gen_id }}">{{ block.settings.point_3_text }}</span>
              </li>
            {% endif %}
          </ul>

          {% if block.settings.cta_text != blank %}
            <a
              href="{{ block.settings.cta_link }}"
              class="ai-video-hero-cta-{{ ai_gen_id }}"
            >
              {{ block.settings.cta_text }}
            </a>
          {% endif %}
        </div>
      </div>

      <div class="ai-video-hero-video-{{ ai_gen_id }}">
        <div class="ai-video-hero-video-wrapper-{{ ai_gen_id }}">
          {% if block.settings.video_url != blank %}
            {% if block.settings.video_url contains 'youtube.com' or block.settings.video_url contains 'youtu.be' %}
              {% assign video_id = block.settings.video_url | split: 'v=' | last | split: '/' | last | split: '&' | first %}
              <iframe
                src="https://www.youtube.com/embed/{{ video_id }}?autoplay={{ block.settings.video_autoplay }}&loop={{ block.settings.video_loop }}&mute={{ block.settings.video_muted }}&controls=1&rel=0"
                frameborder="0"
                allow="autoplay; encrypted-media"
                allowfullscreen
              ></iframe>
            {% elsif block.settings.video_url contains 'vimeo.com' %}
              {% assign video_id = block.settings.video_url | split: '/' | last %}
              <iframe
                src="https://player.vimeo.com/video/{{ video_id }}?autoplay={{ block.settings.video_autoplay }}&loop={{ block.settings.video_loop }}&muted={{ block.settings.video_muted }}"
                frameborder="0"
                allow="autoplay; fullscreen"
                allowfullscreen
              ></iframe>
            {% else %}
              <video
                {% if block.settings.video_autoplay %}autoplay{% endif %}
                {% if block.settings.video_loop %}loop{% endif %}
                {% if block.settings.video_muted %}muted{% endif %}
                {% if block.settings.video_poster %}poster="{{ block.settings.video_poster | image_url: width: 1500 }}"{% endif %}
                playsinline
              >
                <source src="{{ block.settings.video_url }}" type="video/mp4">
              </video>
            {% endif %}
          {% elsif block.settings.video_shopify %}
            {{
              block.settings.video_shopify
              | video_tag:
                autoplay: block.settings.video_autoplay,
                loop: block.settings.video_loop,
                muted: block.settings.video_muted,
                controls: true
            }}
          {% else %}
            <div class="ai-video-hero-video-placeholder-{{ ai_gen_id }}">
              {{ 'hero-apparel-1' | placeholder_svg_tag }}
            </div>
          {% endif %}

          {% if block.settings.video_overlay_opacity > 0 %}
            <div class="ai-video-hero-video-overlay-{{ ai_gen_id }}"></div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
