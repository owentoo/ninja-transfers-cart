{% doc %}
  @prompt
    Create a fully customizable Shopify section that displays a grid of product cards.
    Layout: 5 columns on desktop, 2–3 on tablet (editable), 1 on mobile, with full control over spacing, padding, and max-width.
    
    Card Structure (top → bottom):
    
    Image (upload per card; adjustable ratio)
    
    Title (editable text)
    
    Optional 1-line benefit (toggle on/off per card)
    
    Price + Delivery row:
    
    Field 1: starting price
    
    Field 2: delivery time
    
    Option for single-line or stacked layout
    
    CTA Button
    
    Editable text + link
    
    Editable style
    
    Button width must be uniform across all cards
    
    Hide/show toggle
    
    Entire card must also be clickable (separate from CTA).
    
    Section Controls:
    
    Edit heading + optional subheading
    
    Adjust column count per breakpoint
    
    Adjust card padding, radius, background, border, shadow, hover state
    
    Control text alignment
    
    Control row/column gaps + section padding
    
    Edit CTA button style and global CTA width
    
    Set section max-width or card max-width
    
    Card Controls:
    
    Upload image
    
    Edit title
    
    Edit benefit text
    
    Edit starting price
    
    Edit delivery time
    
    Edit CTA text + link
    
    Toggle visibility for benefit, price, delivery, CTA
    
    Behavior Requirements:
    
    Fully responsive
    
    Image always on top
    
    Cards must remain simple, clean, and scannable
    
    All CTAs must display at a consistent width regardless of text length
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-grid-{{ ai_gen_id }} {
    max-width: {{ block.settings.section_max_width }}px;
    margin: 0 auto;
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-product-grid-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-product-grid-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.subheading_spacing }}px;
    color: {{ block.settings.heading_color }};
  }

  .ai-product-grid-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    margin: 0;
    color: {{ block.settings.subheading_color }};
  }

  .ai-product-grid-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.row_gap }}px {{ block.settings.column_gap }}px;
  }

  .ai-product-card-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    flex-direction: column;
    background-color: {{ block.settings.card_background }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    text-align: {{ block.settings.text_alignment }};
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    color: inherit;
    {% if block.settings.card_shadow %}
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    {% endif %}
  }

  .ai-product-card-{{ ai_gen_id }}:hover {
    {% if block.settings.card_hover_shadow %}
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
    {% endif %}
    {% if block.settings.card_hover_transform %}
      transform: translateY(-4px);
    {% endif %}
  }

  .ai-product-card-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio | times: 100 }}%;
    margin-bottom: {{ block.settings.image_spacing }}px;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-product-card-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-card-image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-product-card-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .ai-product-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    margin: 0 0 {{ block.settings.title_spacing }}px;
    color: {{ block.settings.title_color }};
  }

  .ai-product-card-benefit-{{ ai_gen_id }} {
    font-size: {{ block.settings.benefit_size }}px;
    margin: 0 0 {{ block.settings.benefit_spacing }}px;
    color: {{ block.settings.benefit_color }};
    line-height: 1.4;
  }

  .ai-product-card-price-delivery-{{ ai_gen_id }} {
    {% if block.settings.price_delivery_layout == 'row' %}
      display: flex;
      align-items: center;
      justify-content: {{ block.settings.text_alignment }};
      gap: {{ block.settings.price_delivery_gap }}px;
    {% else %}
      display: flex;
      flex-direction: column;
      gap: {{ block.settings.price_delivery_gap }}px;
    {% endif %}
    margin-bottom: {{ block.settings.price_delivery_spacing }}px;
  }

  .ai-product-card-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    font-weight: 600;
    color: {{ block.settings.price_color }};
  }

  .ai-product-card-delivery-{{ ai_gen_id }} {
    font-size: {{ block.settings.delivery_size }}px;
    color: {{ block.settings.delivery_color }};
  }

  .ai-product-card-cta-wrapper-{{ ai_gen_id }} {
    margin-top: auto;
  }

  .ai-product-card-cta-{{ ai_gen_id }} {
    display: inline-block;
    width: {{ block.settings.cta_width }}%;
    padding: {{ block.settings.cta_padding_vertical }}px {{ block.settings.cta_padding_horizontal }}px;
    background-color: {{ block.settings.cta_background }};
    color: {{ block.settings.cta_text_color }};
    border: {{ block.settings.cta_border_width }}px solid {{ block.settings.cta_border_color }};
    border-radius: {{ block.settings.cta_border_radius }}px;
    font-size: {{ block.settings.cta_font_size }}px;
    font-weight: 600;
    text-decoration: none;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-product-card-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_hover_background }};
    color: {{ block.settings.cta_hover_text_color }};
    border-color: {{ block.settings.cta_hover_border_color }};
  }

  @media screen and (max-width: 989px) and (min-width: 750px) {
    .ai-product-grid-container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-product-grid-container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-product-grid-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.7 }}px {{ block.settings.section_padding_horizontal | times: 0.7 }}px {{ block.settings.section_padding_bottom | times: 0.7 }}px;
    }

    .ai-product-grid-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-product-card-cta-{{ ai_gen_id }} {
      width: 100%;
    }

    {% if block.settings.hero_first_mobile %}
      .ai-product-card-{{ ai_gen_id }}:first-child {
        grid-column: 1 / -1;
      }
      .ai-product-card-{{ ai_gen_id }}:first-child .ai-product-card-image-wrapper-{{ ai_gen_id }} {
        padding-bottom: 56.25%;
      }
      .ai-product-card-{{ ai_gen_id }}:first-child .ai-product-card-content-{{ ai_gen_id }} {
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }
      .ai-product-card-{{ ai_gen_id }}:first-child .ai-product-card-title-{{ ai_gen_id }} {
        margin-bottom: 0;
        flex: 1;
        font-size: 18px;
      }
      .ai-product-card-{{ ai_gen_id }}:first-child .ai-product-card-cta-wrapper-{{ ai_gen_id }} {
        flex-shrink: 0;
      }
      .ai-product-card-{{ ai_gen_id }}:first-child .ai-product-card-cta-{{ ai_gen_id }} {
        width: auto;
        white-space: nowrap;
        padding: 12px 16px;
      }
    {% endif %}
  }
{% endstyle %}

<div class="ai-product-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank or block.settings.subheading != blank %}
    <div class="ai-product-grid-header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-product-grid-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subheading != blank %}
        <p class="ai-product-grid-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="ai-product-grid-container-{{ ai_gen_id }}">
    {% for i in (1..12) %}
      {% liquid
        assign card_enabled_key = 'card_' | append: i | append: '_enabled'
        assign card_image_key = 'card_' | append: i | append: '_image'
        assign card_title_key = 'card_' | append: i | append: '_title'
        assign card_benefit_key = 'card_' | append: i | append: '_benefit'
        assign card_benefit_show_key = 'card_' | append: i | append: '_show_benefit'
        assign card_price_key = 'card_' | append: i | append: '_price'
        assign card_delivery_key = 'card_' | append: i | append: '_delivery'
        assign card_show_price_key = 'card_' | append: i | append: '_show_price'
        assign card_cta_text_key = 'card_' | append: i | append: '_cta_text'
        assign card_cta_link_key = 'card_' | append: i | append: '_cta_link'
        assign card_show_cta_key = 'card_' | append: i | append: '_show_cta'
        assign card_link_key = 'card_' | append: i | append: '_card_link'

        assign card_enabled = block.settings[card_enabled_key]
        assign card_image = block.settings[card_image_key]
        assign card_title = block.settings[card_title_key]
        assign card_benefit = block.settings[card_benefit_key]
        assign card_benefit_show = block.settings[card_benefit_show_key]
        assign card_price = block.settings[card_price_key]
        assign card_delivery = block.settings[card_delivery_key]
        assign card_show_price = block.settings[card_show_price_key]
        assign card_cta_text = block.settings[card_cta_text_key]
        assign card_cta_link = block.settings[card_cta_link_key]
        assign card_show_cta = block.settings[card_show_cta_key]
        assign card_link = block.settings[card_link_key]
      %}

      {% if card_enabled %}
        <a
          href="{{ card_link }}"
          class="ai-product-card-{{ ai_gen_id }}"
        >
          <div class="ai-product-card-image-wrapper-{{ ai_gen_id }}">
            {% if card_image %}
              <img
                src="{{ card_image | image_url: width: 800 }}"
                alt="{{ card_title | escape }}"
                class="ai-product-card-image-{{ ai_gen_id }}"
                loading="lazy"
                width="800"
                height="{{ 800 | times: block.settings.image_aspect_ratio }}"
              >
            {% else %}
              <div class="ai-product-card-image-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <div class="ai-product-card-content-{{ ai_gen_id }}">
            {% if card_title != blank %}
              <h3 class="ai-product-card-title-{{ ai_gen_id }}">{{ card_title }}</h3>
            {% endif %}

            {% if card_benefit_show and card_benefit != blank %}
              <p class="ai-product-card-benefit-{{ ai_gen_id }}">{{ card_benefit }}</p>
            {% endif %}

            {% if card_show_price and card_price != blank or card_delivery != blank %}
              <div class="ai-product-card-price-delivery-{{ ai_gen_id }}">
                {% if card_price != blank %}
                  <div class="ai-product-card-price-{{ ai_gen_id }}">{{ card_price }}</div>
                {% endif %}
                {% if card_delivery != blank %}
                  <div class="ai-product-card-delivery-{{ ai_gen_id }}">{{ card_delivery }}</div>
                {% endif %}
              </div>
            {% endif %}

            {% if card_show_cta and card_cta_text != blank %}
              <div class="ai-product-card-cta-wrapper-{{ ai_gen_id }}">
                <span class="ai-product-card-cta-{{ ai_gen_id }}">
                  {{ card_cta_text }}
                </span>
              </div>
            {% endif %}
          </div>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Product grid",
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 16,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 32
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Subheading size",
      "default": 16
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "subheading_spacing",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Subheading spacing",
      "default": 8
    },
    {
      "type": "range",
      "id": "header_spacing",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Header bottom spacing",
      "default": 40
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "label": "Columns on desktop",
      "default": 5
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Columns on tablet",
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Columns on mobile",
      "default": 1
    },
    {
      "type": "checkbox",
      "id": "hero_first_mobile",
      "label": "Hero first card on mobile",
      "default": false
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "section_max_width",
      "min": 1000,
      "max": 2000,
      "step": 50,
      "unit": "px",
      "label": "Section max width",
      "default": 1400
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
