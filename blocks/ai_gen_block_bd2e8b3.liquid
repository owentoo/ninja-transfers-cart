{% doc %}
  @prompt
    Create a homepage hero section with a background video and dynamic headline. Include a background video with fallback image, overlay options, and responsive padding. Add a main heading with highlighted words that can be customized, a subheading, feature badges, call-to-action buttons, and a stats display. Make everything responsive with text alignment and sizing controls for different devices. Add 6 total options for highlighted text, text color should change each time the highlighted text/word changes, timer for how quickly text should alternate, Add H1, last word of H1 should be the word that alternates
    , subheading text should align with H1
    , Add container width controls, where all of the text, buttons, and badges live. Badges should have no background, icons next to each badge should be circle that can be colored. Add size controls for stat labels
    , remake container width into text content width and then the text content should have alignment controls 
    , content width controls should be pixels
    , add text width container controls, should be controllable on a slider where i can go up to 1400 pixels
    , Video: Upload or URL, full width always, with autoplay, loop, mute, and mobile fallback image options.
    
    Text container: Left-aligned within the video, with adjustable max-width (range: 600px to 1500px).
    
    Text & Button alignment: Toggle to align content left or right within the text container.
    
    Text container padding: Adjustable top and bottom padding.
    
    Ensure: Video spans full width of screen, but text stays within the defined max-width container.
    , re-add the badges and the stat text, they fell off in this version
    , add controls for container position, it should be a slider of pixels, not just and align left, right, or cent tab
    , Add layout controls with the following settings:
    
    Content alignment toggle: Left, Center, or Right
    
    Container width: Adjustable in pixels (min: 600px, max: 1500px)
    
    Text content width: Adjustable in pixels (independent of container width)
    
    Vertical padding: Adjustable top and bottom padding in pixels
    
    Add options to align stat text
    

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .hero-section-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    color: {{ block.settings.text_color }};
  }

  .hero-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -2;
  }

  .hero-background-{{ ai_gen_id }} video {
    width: 100%;
    height: 100%;
    object-fit: cover;}

  .hero-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;}

  .hero-background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: -1;
  }

  .hero-container-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    justify-content: {{ block.settings.container_alignment }};}

  .hero-content-{{ ai_gen_id }} {
    max-width: {{ block.settings.text_content_width }}px;
    width: 100%;
    text-align: {{ block.settings.text_alignment }};
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    margin-left: {{ block.settings.container_position }}px;
  }

  .hero-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
    margin-bottom:{{block.settings.heading_bottom_space}}px;
    font-weight: 700;
  }

  .hero-highlight-{{ ai_gen_id }} {
    display: inline-block;
    transition: color 0.5s ease, opacity 0.3s ease;
  }

  .hero-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    line-height: 1.5;
    margin-bottom: {{ block.settings.subheading_bottom_space }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .hero-badges-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    margin-bottom: {{ block.settings.badge_bottom_spacing }}px;
    justify-content: {{ block.settings.text_alignment }};
  }

  .hero-badge-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 10px;}

  .hero-badge-icon-{{ ai_gen_id }} {
    width: {{ block.settings.badge_icon_size }}px;
    height: {{ block.settings.badge_icon_size }}px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-badge-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.badge_text_size }}px; font-weight:500;
  }

  .hero-buttons-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
    margin-bottom: {{ block.settings.button_spacing }}px; 
    justify-content: {{ block.settings.text_alignment }};
  }

  .hero-button-primary-{{ ai_gen_id }} {
    display: inline-block;
    padding: 15px 30px;
    background-color: {{ block.settings.primary_button_color }};
    color: {{ block.settings.primary_button_text_color }};
    text-decoration: none;
    border-radius: 5px;
    font-weight: 600;
    transition: background-color 0.3s;
  }

  .hero-button-primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.primary_button_hover_color }};
  }

  .hero-button-secondary-{{ ai_gen_id }} {
    display: inline-block;
    padding: 15px 30px;
    background-color: {{ block.settings.secondary_button_color }};
    color: {{ block.settings.secondary_button_text_color }};
    text-decoration: none;
    border-radius: 5px;
    font-weight: 600;
    transition: background-color 0.3s;
  }

  .hero-button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.secondary_button_hover_color }};
  }

  .hero-stats-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 30px;
    justify-content: {{ block.settings.stats_alignment }};
  }

  .hero-stat-{{ ai_gen_id }} {
    text-align: {{ block.settings.stats_text_alignment }};}

  .hero-stat-value-{{ ai_gen_id }} {
    font-size: {{ block.settings.stat_value_size }}px;
    font-weight: 700;
    margin-bottom: 5px;
  }
  .stat-value-block{display:inline-flex; gap:8px; align-items:center;}

  .hero-stat-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.stat_label_size }}px;
  }

  @media screen and (max-width: 768px) {
    .hero-content-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top_mobile }}px;
      padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
      margin-left: {{ block.settings.container_position_mobile }}px;
    }

    .hero-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .hero-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size_mobile }}px;
    }

    .hero-badge-icon-{{ ai_gen_id }} {
      width: {{ block.settings.badge_icon_size | times: 0.8 }}px;
      height: {{ block.settings.badge_icon_size | times: 0.8 }}px;
    }

    .hero-badge-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.badge_text_size | times: 0.8 }}px; font-weight:bold;
    }

    .hero-stat-value-{{ ai_gen_id }} {
      font-size: {{ block.settings.stat_value_size | times: 0.8 }}px;
    }

    .hero-stat-label-{{ ai_gen_id }} {
      font-size: {{ block.settings.stat_label_size | times: 0.8 }}px;
    }
    .hero-badges-{{ ai_gen_id }} {flex-flow: column; gap:8px;}
    .hero-buttons-{{ ai_gen_id }} {flex-flow: column; margin-bottom: {{ block.settings.badge_bottom_spacing_mobile }}px; }
    .hero-buttons-{{ ai_gen_id }} a{text-align:center;}

    .hero-heading-{{ ai_gen_id }} {margin-bottom:{{block.settings.heading_bottom_space_mobile}}px;}
    .hero-subheading-{{ ai_gen_id }} {margin-bottom: {{ block.settings.subheading_bottom_space_mobile }}px;}
    
    .hero-buttons-{{ ai_gen_id }} {margin-bottom: {{ block.settings.button_spacing_mobile }}px;}
  }
{% endstyle %}

<div class="hero-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="hero-background-{{ ai_gen_id }}">
    {% if block.settings.video_url != blank %}
      <video autoplay muted loop playsinline>
        <source src="{{ block.settings.video_url }}" type="video/mp4">
        {% if block.settings.mobile_fallback_image %}
          <img src="{{ block.settings.mobile_fallback_image | image_url: width: 2000 }}" alt="{{ block.settings.mobile_fallback_image.alt | escape }}">
        {% elsif block.settings.background_image %}
          <img src="{{ block.settings.background_image | image_url: width: 2000 }}" alt="{{ block.settings.background_image.alt | escape }}">
        {% else %}
          <div class="hero-background-placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </video>
    {% elsif block.settings.background_image %}
      <img src="{{ block.settings.background_image | image_url: width: 2000 }}" alt="{{ block.settings.background_image.alt | escape }}">
    {% else %}
      <div class="hero-background-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  <div class="hero-overlay-{{ ai_gen_id }}"></div>

  <div class="hero-container-{{ ai_gen_id }}">
    <div class="hero-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h1 class="hero-heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
          <span class="hero-highlight-{{ ai_gen_id }}" id="hero-highlight-{{ ai_gen_id }}">
            {{ block.settings.highlight_word_1 }}
          </span>
        </h1>
      {% endif %}

      {% if block.settings.subheading != blank %}
        <div class="hero-subheading-{{ ai_gen_id }}">
          {{ block.settings.subheading }}
        </div>
      {% endif %}

      {% if block.settings.show_badges %}
        <div class="hero-badges-{{ ai_gen_id }}">
          {% for i in (1..3) %}
            {% assign badge_text_key = 'badge_' | append: i | append: '_text' %}
            {% assign badge_icon_color_key = 'badge_' | append: i | append: '_icon_color' %}
            
            {% if block.settings[badge_text_key] != blank %}
              <div class="hero-badge-{{ ai_gen_id }}">
                <div class="hero-badge-icon-{{ ai_gen_id }}" style="background-color: {{ block.settings[badge_icon_color_key] }}">
                  <!--
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                  -->
                </div>
                <div class="hero-badge-text-{{ ai_gen_id }}">{{ block.settings[badge_text_key] }}</div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}<div class="hero-buttons-{{ ai_gen_id }}">
        {% if block.settings.primary_button_text != blank and block.settings.primary_button_url != blank %}
          <a href="{{ block.settings.primary_button_url }}" class="hero-button-primary-{{ ai_gen_id }}">
            {{ block.settings.primary_button_text }}
          </a>
        {% endif %}

        {% if block.settings.secondary_button_text != blank and block.settings.secondary_button_url != blank %}
          <a href="{{ block.settings.secondary_button_url }}" class="hero-button-secondary-{{ ai_gen_id }}">
            {{ block.settings.secondary_button_text }}
          </a>
        {% endif %}
      </div>

      {% if block.settings.show_stats %}
        <div class="hero-stats-{{ ai_gen_id }}">
          {% for i in (1..3) %}
            {% assign stat_value_key = 'stat_' | append: i | append: '_value' %}
            {% assign stat_label_key = 'stat_' | append: i | append: '_label' %}
            {% assign stat_img_key = 'stat_' | append: i | append: '_img' %}
            
            {% if block.settings[stat_value_key] != blank and block.settings[stat_label_key] != blank %}
              <div class="hero-stat-{{ ai_gen_id }}">
                <div class="hero-img">
                    <img src="{{ block.settings[stat_img_key] | image_url: width: 200 }}" alt="" height="26" class="reviewsImg" />
                </div>
                <div>
                <div class="hero-stat-value-{{ ai_gen_id }} stat-value-block">
                  <span>{{ block.settings[stat_value_key] }}</span>
                  {% if forloop.first %}
                  <img srcset="//ninja-transfers-cdn.imgix.net/Star_6b22c75e-a27a-4075-98c1-52288f8afca1.png?auto=format,compress&amp;v=1725908410&amp;w=100 100w, 
                      //ninja-transfers-cdn.imgix.net/Star_6b22c75e-a27a-4075-98c1-52288f8afca1.png?auto=format,compress&amp;v=1725908410&amp;w=200 200w, 
                      //ninja-transfers-cdn.imgix.net/Star_6b22c75e-a27a-4075-98c1-52288f8afca1.png?auto=format,compress&amp;v=1725908410&amp;w=400 400w" sizes="(max-width: 600px) 50vw, 
                      (max-width: 1200px) 25vw, 
                      10vw" src="//ninja-transfers-cdn.imgix.net/Star_6b22c75e-a27a-4075-98c1-52288f8afca1.png?auto=format,compress&amp;v=1725908410&amp;w=200" alt="" width="80" height="auto" class="ratingImg">
                  {% endif %}
                </div>
                <div class="hero-stat-label-{{ ai_gen_id }}">{{ block.settings[stat_label_key] }}</div>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

<script>
  (function() {
    const highlightElement = document.getElementById('hero-highlight-{{ ai_gen_id }}');
    if (!highlightElement) return;

    const words = [
      { text: '{{ block.settings.highlight_word_1 }}', color: '{{ block.settings.highlight_color_1 }}' },
      { text: '{{ block.settings.highlight_word_2 }}', color: '{{ block.settings.highlight_color_2 }}' },
      { text: '{{ block.settings.highlight_word_3 }}', color: '{{ block.settings.highlight_color_3 }}' },
      { text: '{{ block.settings.highlight_word_4 }}', color: '{{ block.settings.highlight_color_4 }}' },
      { text: '{{ block.settings.highlight_word_5 }}', color: '{{ block.settings.highlight_color_5 }}' },
      { text: '{{ block.settings.highlight_word_6 }}', color: '{{ block.settings.highlight_color_6 }}' },
      { text: '{{ block.settings.highlight_word_7 }}', color: '{{ block.settings.highlight_color_7 }}' },
      { text: '{{ block.settings.highlight_word_8 }}', color: '{{ block.settings.highlight_color_8 }}' },
      { text: '{{ block.settings.highlight_word_9 }}', color: '{{ block.settings.highlight_color_9 }}' }
    ].filter(word => word.text.trim() !== '');

    if (words.length <= 1) return;

    let currentIndex = 0;
    const changeInterval = {{ block.settings.highlight_change_speed }} * 1000;

    // Set initial color
    highlightElement.style.color = words[0].color;

    function changeHighlightWord() {
      currentIndex = (currentIndex + 1) % words.length;
      // Fade out
      highlightElement.style.opacity = '0';
      setTimeout(() => {
        // Change text and color
        highlightElement.textContent = words[currentIndex].text;
        highlightElement.style.color = words[currentIndex].color;
        
        // Fade in
        highlightElement.style.opacity = '1';
      }, 300);
    }

    setInterval(changeHighlightWord, changeInterval);
  })();
</script>

