{% doc %}
  @prompt
    Create a responsive section with two columns where the left column takes up 1/3 of the width and contains a text card with customizable title, description, and styling options, and the right column takes up 2/3 of the width and contains an embedded YouTube video player that accepts a YouTube URL input. The section should be mobile-responsive and stack vertically on smaller screens.

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-video-block-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.gap }}px;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }
.container--large {
max-width: {{ block.settings.max_width }}px;

  margin-left: auto;
  margin-right: auto;
  padding-left: 20px;
  padding-right: 20px;
}

  .ai-text-column-{{ ai_gen_id }} {
    flex: 1;
    min-width: 250px;
    padding: {{ block.settings.card_padding }}px;
    background-color: {{ block.settings.card_background_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    box-shadow: 0 {{ block.settings.card_shadow }}px {{ block.settings.card_shadow | times: 2 }}px rgba(0, 0, 0, 0.1);
  }

  .ai-video-column-{{ ai_gen_id }} {
    flex: 2;
    min-width: 300px;
  }

  .ai-text-title-{{ ai_gen_id }} {
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    margin-top: 0;
    margin-bottom: {{ block.settings.title_margin }}px;
  }

  .ai-text-description-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.5;
  }

  .ai-video-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 Aspect Ratio */
    height: 0;
    overflow: hidden;
    border-radius: {{ block.settings.video_border_radius }}px;
  }

  .ai-video-container-{{ ai_gen_id }} iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  @media screen and (max-width: 749px) {
    .ai-text-video-block-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-text-column-{{ ai_gen_id }},
    .ai-video-column-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-text-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-text-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-text-video-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-column-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="ai-text-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    {% endif %}
    
    {% if block.settings.description != blank %}
      <div class="ai-text-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
    {% endif %}
  </div>
  
  <div class="ai-video-column-{{ ai_gen_id }}">
    {% if block.settings.youtube_url != blank %}
      {% assign youtube_id = block.settings.youtube_url | split: "v=" | last | split: "&" | first %}
      <div class="ai-video-container-{{ ai_gen_id }}">
        <iframe 
          src="https://www.youtube.com/embed/{{ youtube_id }}?rel=0" 
          title="{{ block.settings.title | escape }}"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
          allowfullscreen
          loading="lazy">
        </iframe>
      </div>
    {% else %}
      <div class="ai-video-container-{{ ai_gen_id }}">
        <div style="display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; background-color: #f4f4f4; position: absolute;">
          <svg width="100" height="100" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M22.5 6.5C22.2 5.6 21.5 4.9 20.6 4.7C18.9 4.2 12 4.2 12 4.2C12 4.2 5.1 4.2 3.4 4.7C2.5 4.9 1.8 5.6 1.5 6.5C1 8.2 1 11.7 1 11.7C1 11.7 1 15.3 1.5 16.9C1.8 17.8 2.5 18.5 3.4 18.8C5.1 19.3 12 19.3 12 19.3C12 19.3 18.9 19.3 20.6 18.8C21.5 18.5 22.2 17.8 22.5 16.9C23 15.3 23 11.7 23 11.7C23 11.7 23 8.2 22.5 6.5Z" stroke="#888888" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M9.75 15.02L15.5 11.7L9.75 8.38V15.02Z" stroke="#888888" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Text and Video",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Featured Video"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Add a description for your video here. Explain what viewers will learn or see in this video content.</p>"
    },
    {
      "type": "url",
      "id": "youtube_url",
      "label": "YouTube URL"
    },
    {
      "type": "header",
      "content": "Layout"
    },
   {
  "type": "range",
  "id": "max_width",
  "label": "Max content width (px)",
  "min": 800,
  "max": 1800,
  "step": 100,
  "default": 1400
},

    {
      "type": "range",
      "id": "padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Section padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "gap",
      "min": 16,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Space between columns",
      "default": 32
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Section border radius",
      "default": 0
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Text Card"
    },
    {
      "type": "range",
      "id": "card_padding",
      "min": 16,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Card padding",
      "default": 24
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Card border radius",
      "default": 8
    },
    {
      "type": "range",
      "id": "card_shadow",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Card shadow",
      "default": 4
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card background",
      "default": "#f5f5f5"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 16,
      "max": 60,
      "step": 1,
      "unit": "px",
      "label": "Title size",
      "default": 28
    },
    {
      "type": "range",
      "id": "title_margin",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Title bottom margin",
      "default": 16
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 16
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "range",
      "id": "video_border_radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Video border radius",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Text and Video"
    }
  ],
  "tag": null
}
{% endschema %}