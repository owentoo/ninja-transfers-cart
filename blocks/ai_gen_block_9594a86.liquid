{% doc %}
  @prompt
    make me an faq section with an h2 on one side and 8 expand and collapse sections on the other side , give section a max width in px and horizontal padding for desktop and mobile that falls within max width. section need bg color option , faq's should just have a line under each not a fiull outlibe around them , all text needs desktop and mobile options , need option on bole for space betwen heading and faq items. and vertical section padding for desktop and mobile , give me an option to have plus or arrow icons with size and weight options 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-faq-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.section_background }};
    padding: {{ block.settings.section_padding_desktop }}px 0;
  }

  .ai-faq-wrapper-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.horizontal_padding_desktop }}px;
  }

  .ai-faq-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: {{ block.settings.column_gap }}px;
    align-items: start;
  }

  .ai-faq-heading-column-{{ ai_gen_id }} {
    position: sticky;
    top: 100px;
  }

  .ai-faq-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size_desktop }}px;
    line-height: 1.2;
    color: {{ block.settings.heading_color }};
    margin: 0;
    margin-bottom: {{ block.settings.heading_spacing }}px;
  }

  .ai-faq-items-column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
  }

  .ai-faq-item-{{ ai_gen_id }} {
    border-bottom: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    background-color: {{ block.settings.item_background }};
    transition: border-color 0.3s ease;
  }

  .ai-faq-item-{{ ai_gen_id }}:hover {
    border-bottom-color: {{ block.settings.border_hover_color }};
  }

  .ai-faq-question-button-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: {{ block.settings.question_padding }}px 0;
    background: none;
    border: none;
    text-align: left;
    cursor: pointer;
    font-family: {{ block.settings.question_font.family }}, {{ block.settings.question_font.fallback_families }};
    font-weight: {{ block.settings.question_font.weight }};
    font-size: {{ block.settings.question_size_desktop }}px;
    color: {{ block.settings.question_color }};
    transition: color 0.3s ease;
  }

  .ai-faq-question-button-{{ ai_gen_id }}:hover {
    color: {{ block.settings.question_hover_color }};
  }

  .ai-faq-question-text-{{ ai_gen_id }} {
    flex: 1;
    padding-right: 20px;
  }

  .ai-faq-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
  }

  .ai-faq-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: {{ block.settings.icon_color }};
    stroke-width: {{ block.settings.icon_weight }};
  }

  .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-icon-{{ ai_gen_id }} {
    {% if block.settings.icon_style == 'arrow' %}
      transform: rotate(180deg);
    {% endif %}
  }

  .ai-faq-answer-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
  }

  .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-answer-{{ ai_gen_id }} {
    max-height: 1000px;
    padding-bottom: {{ block.settings.question_padding }}px;
  }

  .ai-faq-answer-content-{{ ai_gen_id }} {
    font-family: {{ block.settings.answer_font.family }}, {{ block.settings.answer_font.fallback_families }};
    font-weight: {{ block.settings.answer_font.weight }};
    font-size: {{ block.settings.answer_size_desktop }}px;
    line-height: 1.6;
    color: {{ block.settings.answer_color }};
  }

  .ai-faq-answer-content-{{ ai_gen_id }} p {
    margin: 0 0 12px;
  }

  .ai-faq-answer-content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 768px) {
    .ai-faq-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_mobile }}px 0;
    }

    .ai-faq-wrapper-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.horizontal_padding_mobile }}px;
    }

    .ai-faq-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .ai-faq-heading-column-{{ ai_gen_id }} {
      position: static;
    }

    .ai-faq-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-faq-question-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.question_size_mobile }}px;
    }

    .ai-faq-answer-content-{{ ai_gen_id }} {
      font-size: {{ block.settings.answer_size_mobile }}px;
    }
  }
{% endstyle %}

<faq-accordion-{{ ai_gen_id }} class="ai-faq-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-faq-wrapper-{{ ai_gen_id }}">
    <div class="ai-faq-container-{{ ai_gen_id }}">
      <div class="ai-faq-heading-column-{{ ai_gen_id }}">
        <h2 class="ai-faq-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      </div>

      <div class="ai-faq-items-column-{{ ai_gen_id }}">
        {% for i in (1..8) %}
          {% liquid
            assign question_key = 'question_' | append: i
            assign answer_key = 'answer_' | append: i
            assign question = block.settings[question_key]
            assign answer = block.settings[answer_key]
          %}

          {% if question != blank %}
            <div class="ai-faq-item-{{ ai_gen_id }}" data-faq-item>
              <button
                class="ai-faq-question-button-{{ ai_gen_id }}"
                aria-expanded="false"
                aria-controls="ai-faq-answer-{{ ai_gen_id }}-{{ i }}"
              >
                <span class="ai-faq-question-text-{{ ai_gen_id }}">{{ question }}</span>
                <span class="ai-faq-icon-{{ ai_gen_id }}">
                  {% if block.settings.icon_style == 'arrow' %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="6 9 12 15 18 9"></polyline>
                    </svg>
                  {% else %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round" data-plus-icon>
                      <line x1="12" y1="5" x2="12" y2="19"></line>
                      <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                  {% endif %}
                </span>
              </button>
              <div
                class="ai-faq-answer-{{ ai_gen_id }}"
                id="ai-faq-answer-{{ ai_gen_id }}-{{ i }}"
              >
                <div class="ai-faq-answer-content-{{ ai_gen_id }}">
                  {{ answer }}
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</faq-accordion-{{ ai_gen_id }}>

<script>
  (function() {
    class FaqAccordion{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.iconStyle = '{{ block.settings.icon_style }}';
      }

      connectedCallback() {
        this.items = this.querySelectorAll('[data-faq-item]');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.items.forEach((item) => {
          const button = item.querySelector('.ai-faq-question-button-{{ ai_gen_id }}');
          const icon = item.querySelector('.ai-faq-icon-{{ ai_gen_id }} svg');
          
          button.addEventListener('click', () => {
            const isActive = item.classList.contains('active');
            
            if (isActive) {
              item.classList.remove('active');
              button.setAttribute('aria-expanded', 'false');
              
              if (this.iconStyle === 'plus' && icon.hasAttribute('data-plus-icon')) {
                icon.innerHTML = '<line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line>';
              }
            } else {
              item.classList.add('active');
              button.setAttribute('aria-expanded', 'true');
              
              if (this.iconStyle === 'plus' && icon.hasAttribute('data-plus-icon')) {
                icon.innerHTML = '<line x1="5" y1="12" x2="19" y2="12"></line>';
              }
            }
          });
        });
      }
    }

    customElements.define('faq-accordion-{{ ai_gen_id }}', FaqAccordion{{ ai_gen_id }});
  })();
</script>

