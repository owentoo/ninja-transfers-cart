{% doc %}
  @prompt
    create a carousel, full width, upto 4 slides, all using the same size rules, height option, and in each an h2, text, and cta, , all text, and cta need size, weight, and color options, and alignment , hide arrows, and give me padding options , padding should go in increments of two, make dots smaller and give color options, add option for text pill above h2, every slide needs the option for an image , give each slide the option to have an overlay , give the pill a radius option, and add padding below pill, h2, and text, add a setting to container all text and cta to have a max width of container in %, Content max width not applying to mobile , Content max width needs alignment options , add line space option for h2 and text
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-carousel-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-carousel-wrapper-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease-in-out;
  }

  .ai-carousel-slide-{{ ai_gen_id }} {
    min-width: 100%;
    height: {{ block.settings.slide_height }}px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    {% if block.settings.content_alignment == 'left' %}
      align-items: flex-start;
    {% elsif block.settings.content_alignment == 'right' %}
      align-items: flex-end;
    {% else %}
      align-items: center;
    {% endif %}
    text-align: {{ block.settings.text_alignment }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.slide_bg_color }};
    color: {{ block.settings.slide_text_color }};
    position: relative;
  }

  .ai-carousel-slide-bg-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .ai-carousel-slide-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-carousel-slide-content-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}%;
    width: 100%;
    position: relative;
    z-index: 2;
  }

  .ai-carousel-slide-pill-wrapper-{{ ai_gen_id }} {
    display: flex;
    margin-bottom: {{ block.settings.pill_spacing }}px;
    {% if block.settings.text_alignment == 'left' %}
      justify-content: flex-start;
    {% elsif block.settings.text_alignment == 'right' %}
      justify-content: flex-end;
    {% else %}
      justify-content: center;
    {% endif %}
  }

  .ai-carousel-slide-pill-{{ ai_gen_id }} {
    display: inline-block;
    padding: 8px 20px;
    background-color: {{ block.settings.pill_bg_color }};
    color: {{ block.settings.pill_text_color }};
    font-size: {{ block.settings.pill_text_size }}px;
    font-weight: {{ block.settings.pill_text_weight }};
    border-radius: {{ block.settings.pill_border_radius }}px;
  }

  .ai-carousel-slide-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    color: {{ block.settings.heading_color }};
    line-height: {{ block.settings.heading_line_height }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
  }

  .ai-carousel-slide-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    font-weight: {{ block.settings.text_weight }};
    color: {{ block.settings.text_color }};
    line-height: {{ block.settings.text_line_height }};
    margin: 0 0 {{ block.settings.text_spacing }}px;
  }

  .ai-carousel-slide-cta-wrapper-{{ ai_gen_id }} {
    display: flex;
    {% if block.settings.text_alignment == 'left' %}
      justify-content: flex-start;
    {% elsif block.settings.text_alignment == 'right' %}
      justify-content: flex-end;
    {% else %}
      justify-content: center;
    {% endif %}
  }

  .ai-carousel-slide-cta-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    background-color: {{ block.settings.cta_bg_color }};
    color: {{ block.settings.cta_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.cta_border_radius }}px;
    font-size: {{ block.settings.cta_text_size }}px;
    font-weight: {{ block.settings.cta_text_weight }};
    transition: all 0.3s ease;
  }

  .ai-carousel-slide-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_hover_bg_color }};
    color: {{ block.settings.cta_hover_text_color }};
  }

  .ai-carousel-dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 3;
  }

  .ai-carousel-dot-{{ ai_gen_id }} {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.5;
    cursor: pointer;
    border: none;
    padding: 0;
    transition: opacity 0.3s ease, background-color 0.3s ease;
  }

  .ai-carousel-dot-{{ ai_gen_id }}.active {
    opacity: 1;
    background-color: {{ block.settings.dot_active_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-carousel-slide-{{ ai_gen_id }} {
      height: {{ block.settings.slide_height | times: 0.7 }}px;
      padding: {{ block.settings.padding_top | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px {{ block.settings.padding_bottom | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px;
    }

    .ai-carousel-slide-pill-wrapper-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.pill_spacing | times: 0.7 }}px;
    }

    .ai-carousel-slide-pill-{{ ai_gen_id }} {
      font-size: {{ block.settings.pill_text_size | times: 0.9 }}px;
      padding: 6px 16px;
    }

    .ai-carousel-slide-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
      margin-bottom: {{ block.settings.heading_spacing | times: 0.7 }}px;
    }

    .ai-carousel-slide-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
      margin-bottom: {{ block.settings.text_spacing | times: 0.7 }}px;
    }
  }
{% endstyle %}

<carousel-slider-{{ ai_gen_id }} class="ai-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-carousel-wrapper-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% liquid
        assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
        assign slide_image_key = 'slide_' | append: i | append: '_image'
        assign slide_overlay_key = 'slide_' | append: i | append: '_overlay'
        assign slide_overlay_opacity_key = 'slide_' | append: i | append: '_overlay_opacity'
        assign slide_pill_key = 'slide_' | append: i | append: '_pill'
        assign slide_heading_key = 'slide_' | append: i | append: '_heading'
        assign slide_text_key = 'slide_' | append: i | append: '_text'
        assign slide_cta_text_key = 'slide_' | append: i | append: '_cta_text'
        assign slide_cta_link_key = 'slide_' | append: i | append: '_cta_link'

        assign slide_enabled = block.settings[slide_enabled_key]
        assign slide_image = block.settings[slide_image_key]
        assign slide_overlay = block.settings[slide_overlay_key]
        assign slide_overlay_opacity = block.settings[slide_overlay_opacity_key]
        assign slide_pill = block.settings[slide_pill_key]
        assign slide_heading = block.settings[slide_heading_key]
        assign slide_text = block.settings[slide_text_key]
        assign slide_cta_text = block.settings[slide_cta_text_key]
        assign slide_cta_link = block.settings[slide_cta_link_key]
      %}

      {% if slide_enabled %}
        <div class="ai-carousel-slide-{{ ai_gen_id }}" data-slide="{{ i }}">
          {% if slide_image %}
            <img
              src="{{ slide_image | image_url: width: 2000 }}"
              alt="{{ slide_image.alt | escape }}"
              loading="lazy"
              width="{{ slide_image.width }}"
              height="{{ slide_image.height }}"
              class="ai-carousel-slide-bg-image-{{ ai_gen_id }}"
            >
          {% endif %}

          {% if slide_overlay %}
            <div 
              class="ai-carousel-slide-overlay-{{ ai_gen_id }}"
              style="background-color: {{ slide_overlay }}; opacity: {{ slide_overlay_opacity }};"
            ></div>
          {% endif %}

          <div class="ai-carousel-slide-content-{{ ai_gen_id }}">
            {% if slide_pill != blank %}
              <div class="ai-carousel-slide-pill-wrapper-{{ ai_gen_id }}">
                <span class="ai-carousel-slide-pill-{{ ai_gen_id }}">{{ slide_pill }}</span>
              </div>
            {% endif %}

            {% if slide_heading != blank %}
              <h2 class="ai-carousel-slide-heading-{{ ai_gen_id }}">{{ slide_heading }}</h2>
            {% endif %}

            {% if slide_text != blank %}
              <div class="ai-carousel-slide-text-{{ ai_gen_id }}">{{ slide_text }}</div>
            {% endif %}

            {% if slide_cta_text != blank %}
              <div class="ai-carousel-slide-cta-wrapper-{{ ai_gen_id }}">
                <a
                  href="{{ slide_cta_link | default: '#' }}"
                  class="ai-carousel-slide-cta-{{ ai_gen_id }}"
                >
                  {{ slide_cta_text }}
                </a>
              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="ai-carousel-dots-{{ ai_gen_id }}"></div>
</carousel-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class CarouselSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.wrapper = this.querySelector('.ai-carousel-wrapper-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-carousel-slide-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('.ai-carousel-dots-{{ ai_gen_id }}');

        if (this.slides.length === 0) return;

        this.createDots();
        this.setupEventListeners();
        this.updateSlide();

        {% if block.settings.autoplay %}
          this.startAutoplay();
        {% endif %}
      }

      createDots() {
        this.slides.forEach((slide, index) => {
          const dot = document.createElement('button');
          dot.classList.add('ai-carousel-dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', `Go to slide ${index + 1}`);
          if (index === 0) dot.classList.add('active');
          dot.addEventListener('click', () => this.goToSlide(index));
          this.dotsContainer.appendChild(dot);
        });
        this.dots = this.querySelectorAll('.ai-carousel-dot-{{ ai_gen_id }}');
      }

      setupEventListeners() {
        {% if block.settings.autoplay %}
          this.addEventListener('mouseenter', () => this.stopAutoplay());
          this.addEventListener('mouseleave', () => this.startAutoplay());
        {% endif %}

        let touchStartX = 0;
        let touchEndX = 0;

        this.addEventListener('touchstart', (e) => {
          touchStartX = e.changedTouches[0].screenX;
        });

        this.addEventListener('touchend', (e) => {
          touchEndX = e.changedTouches[0].screenX;
          this.handleSwipe(touchStartX, touchEndX);
        });
      }

      handleSwipe(startX, endX) {
        const swipeThreshold = 50;
        if (startX - endX > swipeThreshold) {
          this.nextSlide();
        } else if (endX - startX > swipeThreshold) {
          this.prevSlide();
        }
      }

      updateSlide() {
        this.wrapper.style.transform = `translateX(-${this.currentSlide * 100}%)`;
        
        this.dots.forEach((dot, index) => {
          if (index === this.currentSlide) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      goToSlide(index) {
        this.currentSlide = index;
        this.updateSlide();
      }

      nextSlide() {
        this.currentSlide = (this.currentSlide + 1) % this.slides.length;
        this.updateSlide();
      }

      prevSlide() {
        this.currentSlide = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.updateSlide();
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, {{ block.settings.autoplay_speed | times: 1000 }});
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('carousel-slider-{{ ai_gen_id }}', CarouselSlider{{ ai_gen_id }});
  })();
</script>

