{% doc %}
  @prompt
    i need a section with four steps, each step has an image with a number in a box inside the image and two lines of text below each image give me desktop and mobile optiopns. , section needs max width in px, with horizontal padding that falls within max width for desktop and mobile. , text needs alignment options.  , all text needs size options for desktop and mobile, Space below image, Space between steps both need desktop and mobile options, both lines of text nee color options. number box should have alignments to corners only and padding from edge option for desktop and mobile , number box Background color needs opacity option. and all padding should be it multiples of 2 and 5 , i don't see background color box, space between steps needs to be in multiples of 2 and number background needs radius option, all spacing needs to be in multiples of 2 and 5 , on mobile add the option to have everything on one row with horizontal scroll , text needs horizontal padding option , number box needs size for desktop and mobile , need top and bottom padding for desktop and mobile and section bg color option 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-four-steps-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.section_bg_color }};
    padding-top: {{ block.settings.padding_top_desktop }}px;
    padding-bottom: {{ block.settings.padding_bottom_desktop }}px;
  }

  .ai-four-steps-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding-left: {{ block.settings.horizontal_padding_desktop }}px;
    padding-right: {{ block.settings.horizontal_padding_desktop }}px;
  }

  .ai-four-steps-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.space_between_steps_desktop }}px;
  }

  .ai-four-steps-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
  }

  .ai-four-steps-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    margin-bottom: {{ block.settings.space_below_image_desktop }}px;
  }

  .ai-four-steps-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-four-steps-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-four-steps-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-four-steps-number-box-{{ ai_gen_id }} {
    position: absolute;
    background-color: {{ block.settings.number_box_bg_color | color_modify: 'alpha', block.settings.number_box_opacity }};
    color: {{ block.settings.number_box_text_color }};
    width: {{ block.settings.number_box_size_desktop }}px;
    height: {{ block.settings.number_box_size_desktop }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: {{ block.settings.number_size_desktop }}px;
    border-radius: {{ block.settings.number_box_radius }}px;
  }

  .ai-four-steps-number-box-{{ ai_gen_id }}--top-left {
    top: {{ block.settings.number_box_padding_desktop }}px;
    left: {{ block.settings.number_box_padding_desktop }}px;
  }

  .ai-four-steps-number-box-{{ ai_gen_id }}--top-right {
    top: {{ block.settings.number_box_padding_desktop }}px;
    right: {{ block.settings.number_box_padding_desktop }}px;
  }

  .ai-four-steps-number-box-{{ ai_gen_id }}--bottom-left {
    bottom: {{ block.settings.number_box_padding_desktop }}px;
    left: {{ block.settings.number_box_padding_desktop }}px;
  }

  .ai-four-steps-number-box-{{ ai_gen_id }}--bottom-right {
    bottom: {{ block.settings.number_box_padding_desktop }}px;
    right: {{ block.settings.number_box_padding_desktop }}px;
  }

  .ai-four-steps-text-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    padding-left: {{ block.settings.text_horizontal_padding_desktop }}px;
    padding-right: {{ block.settings.text_horizontal_padding_desktop }}px;
  }

  .ai-four-steps-text-line1-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_line1_size_desktop }}px;
    color: {{ block.settings.text_line1_color }};
    margin: 0 0 {{ block.settings.text_line_spacing }}px 0;
    font-weight: 600;
  }

  .ai-four-steps-text-line2-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_line2_size_desktop }}px;
    color: {{ block.settings.text_line2_color }};
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-four-steps-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top_mobile }}px;
      padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-four-steps-container-{{ ai_gen_id }} {
      padding-left: {{ block.settings.horizontal_padding_mobile }}px;
      padding-right: {{ block.settings.horizontal_padding_mobile }}px;
    }

    {% if block.settings.mobile_layout == 'scroll' %}
      .ai-four-steps-grid-{{ ai_gen_id }} {
        display: flex;
        overflow-x: auto;
        gap: {{ block.settings.space_between_steps_mobile }}px;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
      }

      .ai-four-steps-grid-{{ ai_gen_id }}::-webkit-scrollbar {
        display: none;
      }

      .ai-four-steps-item-{{ ai_gen_id }} {
        flex: 0 0 {{ block.settings.mobile_item_width }}%;
        scroll-snap-align: start;
      }
    {% else %}
      .ai-four-steps-grid-{{ ai_gen_id }} {
        grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
        gap: {{ block.settings.space_between_steps_mobile }}px;
      }
    {% endif %}

    .ai-four-steps-image-wrapper-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.space_below_image_mobile }}px;
    }

    .ai-four-steps-number-box-{{ ai_gen_id }} {
      width: {{ block.settings.number_box_size_mobile }}px;
      height: {{ block.settings.number_box_size_mobile }}px;
      font-size: {{ block.settings.number_size_mobile }}px;
    }

    .ai-four-steps-number-box-{{ ai_gen_id }}--top-left {
      top: {{ block.settings.number_box_padding_mobile }}px;
      left: {{ block.settings.number_box_padding_mobile }}px;
    }

    .ai-four-steps-number-box-{{ ai_gen_id }}--top-right {
      top: {{ block.settings.number_box_padding_mobile }}px;
      right: {{ block.settings.number_box_padding_mobile }}px;
    }

    .ai-four-steps-number-box-{{ ai_gen_id }}--bottom-left {
      bottom: {{ block.settings.number_box_padding_mobile }}px;
      left: {{ block.settings.number_box_padding_mobile }}px;
    }

    .ai-four-steps-number-box-{{ ai_gen_id }}--bottom-right {
      bottom: {{ block.settings.number_box_padding_mobile }}px;
      right: {{ block.settings.number_box_padding_mobile }}px;
    }

    .ai-four-steps-text-{{ ai_gen_id }} {
      padding-left: {{ block.settings.text_horizontal_padding_mobile }}px;
      padding-right: {{ block.settings.text_horizontal_padding_mobile }}px;
    }

    .ai-four-steps-text-line1-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_line1_size_mobile }}px;
    }

    .ai-four-steps-text-line2-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_line2_size_mobile }}px;
    }
  }
{% endstyle %}

<four-steps-{{ ai_gen_id }} class="ai-four-steps-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-four-steps-container-{{ ai_gen_id }}">
    <div class="ai-four-steps-grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign image_key = 'step_' | append: i | append: '_image'
          assign text1_key = 'step_' | append: i | append: '_text_line1'
          assign text2_key = 'step_' | append: i | append: '_text_line2'
          
          assign step_image = block.settings[image_key]
          assign step_text1 = block.settings[text1_key]
          assign step_text2 = block.settings[text2_key]
        %}
        
        <div class="ai-four-steps-item-{{ ai_gen_id }}">
          <div class="ai-four-steps-image-wrapper-{{ ai_gen_id }}">
            {% if step_image %}
              <img
                src="{{ step_image | image_url: width: 800 }}"
                alt="{{ step_image.alt | escape }}"
                loading="lazy"
                width="{{ step_image.width }}"
                height="{{ step_image.height }}"
                class="ai-four-steps-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-four-steps-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
            
            <div class="ai-four-steps-number-box-{{ ai_gen_id }} ai-four-steps-number-box-{{ ai_gen_id }}--{{ block.settings.number_box_position }}">
              {{ i }}
            </div>
          </div>
          
          <div class="ai-four-steps-text-{{ ai_gen_id }}">
            {% if step_text1 != blank %}
              <p class="ai-four-steps-text-line1-{{ ai_gen_id }}">{{ step_text1 }}</p>
            {% endif %}
            {% if step_text2 != blank %}
              <p class="ai-four-steps-text-line2-{{ ai_gen_id }}">{{ step_text2 }}</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</four-steps-{{ ai_gen_id }}>

<script>
  (function() {
    class FourSteps{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('four-steps-{{ ai_gen_id }}', FourSteps{{ ai_gen_id }});
  })();
</script>

