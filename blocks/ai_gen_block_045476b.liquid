      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Partner With Us"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Join our influencer program and collaborate with our brand"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Submit Application"
    },
    {
      "type": "textarea",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you for your application! We'll review it and get back to you soon."
