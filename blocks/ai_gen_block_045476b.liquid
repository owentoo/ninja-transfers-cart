    {
      "type": "textarea",
      "id": "platform_options",
      "label": "Platform options",
      "info": "Separate each option with a comma",
      "default": "Instagram, TikTok, YouTube, Facebook, X (Twitter)"
    },
    {
      "type": "textarea",
      "id": "follower_ranges",
      "label": "Follower count ranges",
      "info": "Separate each range with a comma",
      "default": "2K-10K, 10K-50K, 50K-100K, 100K-500K, 500K-1M, 1M+"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
