{% doc %}
  @prompt
    Create a flexible media blocks section that follows the theme's horizontal max width, padding and margin. The section should support 2-6 blocks displayed on 1-2 rows with responsive options for desktop (1-6 blocks per row) and mobile (1-6 blocks per row). Each block contains an image with customizable text overlay positioning (any corner), heading and paragraph text below the image. Include rollover image/video functionality, optional stickers with image upload capability for each block, play icon with hover effects, comprehensive text styling options (color, weight, size, opacity 0-100%), layout options to display 1-6 blocks, play icon customization (size, position including center and corners with padding, arrow styling, custom icon support), image aspect ratios and fit options (contain/cover), spacing controls (top/bottom padding/margin, horizontal padding in 2px increments for mobile), full-width section background color, text alignment options, gap controls between blocks and image-to-text spacing, with option to hide play icon on mobile. Each block should have individual settings for sticker image upload, text overlay content and positioning, rollover media, and all styling options., video needs to be a url, add space to the top of the section., 6 blocks arent displaying when I change the Number of blocks to display to 6, Text Overlay need background color control and opacity control, add background color to text overlay, Text Overlay Global background color isn't working, Text Overlay Global background color and opacity is not functioning, I need overlay text option for each block that has a background color option so you can see it over the image., I want text to overlay on the image and i want a block of color behind the text for legibility

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-media-blocks-section-{{ ai_gen_id }} {
    background-color: {{ block.settings.section_bg_color }};
    padding-top: {{ block.settings.section_padding_top }}px;
    padding-bottom: {{ block.settings.section_padding_bottom }}px;
    margin-top: {{ block.settings.section_margin_top }}px;
    margin-bottom: {{ block.settings.section_margin_bottom }}px;
  }

  .ai-media-blocks-container-{{ ai_gen_id }} {
    max-width: {{ settings.theme_max_width }}px;
    margin: 0 auto;
    padding-left: {{ settings.grid_gap | divided_by: 2 }}px;
    padding-right: {{ settings.grid_gap | divided_by: 2 }}px;
  }

  .ai-media-blocks-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.desktop_columns }}, 1fr);
    gap: {{ block.settings.blocks_gap }}px;
  }

  .ai-media-block-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.image_text_spacing }}px;
  }

  .ai-media-block-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    overflow: hidden;
    border-radius: {{ settings.widgets_border_radius }}px;
  }

  .ai-media-block-image-{{ ai_gen_id }},
  .ai-media-block-rollover-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.image_fit }};
    transition: opacity 0.3s ease;
  }

  .ai-media-block-rollover-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;}

  .ai-media-block-image-wrapper-{{ ai_gen_id }}:hover .ai-media-block-rollover-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-media-block-image-wrapper-{{ ai_gen_id }}:hover .ai-media-block-image-{{ ai_gen_id }} {
    opacity: 0;
  }

  .ai-media-block-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-media-block-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-media-block-text-overlay-{{ ai_gen_id }} {
    position: absolute;
    z-index: 2;
    color: {{ block.settings.overlay_text_color }};
    font-size: {{ block.settings.overlay_text_size }}px;
    font-weight: {{ block.settings.overlay_text_weight }};
    opacity: {{ block.settings.overlay_text_opacity | divided_by: 100.0 }};
    padding: {{ block.settings.overlay_padding }}px;
    border-radius: {{ block.settings.overlay_border_radius }}px;
    background-color: {{ block.settings.overlay_bg_color | color_modify: 'alpha', block.settings.overlay_bg_opacity | divided_by: 100.0 }};
    max-width: 80%;
    word-wrap: break-word;
  }

  .ai-media-block-text-overlay-{{ ai_gen_id }}--top-left {
    top: {{ block.settings.overlay_margin }}px;
    left: {{ block.settings.overlay_margin }}px;
  }

  .ai-media-block-text-overlay-{{ ai_gen_id }}--top-right {
    top: {{ block.settings.overlay_margin }}px;
    right: {{ block.settings.overlay_margin }}px;
  }

  .ai-media-block-text-overlay-{{ ai_gen_id }}--bottom-left {
    bottom: {{ block.settings.overlay_margin }}px;
    left: {{ block.settings.overlay_margin }}px;
  }

  .ai-media-block-text-overlay-{{ ai_gen_id }}--bottom-right {
    bottom: {{ block.settings.overlay_margin }}px;
    right: {{ block.settings.overlay_margin }}px;
  }

  .ai-media-block-text-overlay-{{ ai_gen_id }}--center {
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  {% for i in (1..6) %}
    {% liquid
      assign block_overlay_bg_key = 'block_' | append: i | append: '_overlay_bg_color'
      assign block_overlay_bg_opacity_key = 'block_' | append: i | append: '_overlay_bg_opacity'
      assign block_overlay_text_key = 'block_' | append: i | append: '_overlay_text'
      assign block_overlay_bg_color = block.settings[block_overlay_bg_key]
      assign block_overlay_bg_opacity = block.settings[block_overlay_bg_opacity_key]
      assign block_overlay_text = block.settings[block_overlay_text_key]
    %}
    {% if block_overlay_text != blank %}
      .ai-media-block-text-overlay-{{ ai_gen_id }}-{{ i }} {
        {% if block_overlay_bg_color != blank %}
          background-color: {{ block_overlay_bg_color | color_modify: 'alpha', block_overlay_bg_opacity | divided_by: 100.0 }} !important;
        {% endif %}
      }
    {% endif %}
  {% endfor %}

  .ai-media-block-sticker-{{ ai_gen_id }} {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 40px;
    height: 40px;
    z-index: 3;
  }

  .ai-media-block-sticker-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-media-block-play-icon-{{ ai_gen_id }} {
    position: absolute;
    z-index: 4;
    width: {{ block.settings.play_icon_size }}px;
    height: {{ block.settings.play_icon_size }}px;
    background-color: rgba(0, 0, 0, 0.7);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    color: white;
  }

  .ai-media-block-play-icon-{{ ai_gen_id }}:hover {
    background-color: rgba(0, 0, 0, 0.9);
    transform: scale(1.1);
  }

  .ai-media-block-play-icon-{{ ai_gen_id }}--center {
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .ai-media-block-play-icon-{{ ai_gen_id }}--top-left {
    top: {{ block.settings.play_icon_padding }}px;
    left: {{ block.settings.play_icon_padding }}px;
  }

  .ai-media-block-play-icon-{{ ai_gen_id }}--top-right {
    top: {{ block.settings.play_icon_padding }}px;
    right: {{ block.settings.play_icon_padding }}px;
  }

  .ai-media-block-play-icon-{{ ai_gen_id }}--bottom-left {
    bottom: {{ block.settings.play_icon_padding }}px;
    left: {{ block.settings.play_icon_padding }}px;
  }

  .ai-media-block-play-icon-{{ ai_gen_id }}--bottom-right {
    bottom: {{ block.settings.play_icon_padding }}px;
    right: {{ block.settings.play_icon_padding }}px;
  }

  .ai-media-block-play-icon-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .ai-media-block-content-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-media-block-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    opacity: {{ block.settings.heading_opacity | divided_by: 100.0 }};
    margin: 0 0 8px 0;
  }

  .ai-media-block-paragraph-{{ ai_gen_id }} {
    color: {{ block.settings.paragraph_color }};
    font-size: {{ block.settings.paragraph_size }}px;
    font-weight: {{ block.settings.paragraph_weight }};
    opacity: {{ block.settings.paragraph_opacity | divided_by: 100.0 }};
    margin: 0;
    line-height: 1.4;
  }

  @media screen and (max-width: 749px) {
    .ai-media-blocks-container-{{ ai_gen_id }} {
      padding-left: {{ block.settings.mobile_horizontal_padding }}px;
      padding-right: {{ block.settings.mobile_horizontal_padding }}px;
    }

    .ai-media-blocks-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.mobile_columns }}, 1fr);
    }

    {% if block.settings.hide_play_icon_mobile %}
      .ai-media-block-play-icon-{{ ai_gen_id }} {
        display: none;
      }
    {% endif %}

    .ai-media-block-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.9 }}px;
    }

    .ai-media-block-paragraph-{{ ai_gen_id }} {
      font-size: {{ block.settings.paragraph_size | times: 0.9 }}px;
    }

    .ai-media-block-text-overlay-{{ ai_gen_id }} {
      font-size: {{ block.settings.overlay_text_size | times: 0.9 }}px;
      padding: {{ block.settings.overlay_padding | times: 0.8 }}px;
    }
  }
{% endstyle %}

<media-blocks-{{ ai_gen_id }} class="ai-media-blocks-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-media-blocks-container-{{ ai_gen_id }}">
    <div class="ai-media-blocks-grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign block_enabled_key = 'block_' | append: i | append: '_enabled'
          assign block_image_key = 'block_' | append: i | append: '_image'
          assign block_rollover_image_key = 'block_' | append: i | append: '_rollover_image'
          assign block_rollover_video_key = 'block_' | append: i | append: '_rollover_video'
          assign block_heading_key = 'block_' | append: i | append: '_heading'
          assign block_paragraph_key = 'block_' | append: i | append: '_paragraph'
          assign block_overlay_text_key = 'block_' | append: i | append: '_overlay_text'
          assign block_overlay_position_key = 'block_' | append: i | append: '_overlay_position'
          assign block_sticker_key = 'block_' | append: i | append: '_sticker'
          assign block_show_play_key = 'block_' | append: i | append: '_show_play'

          assign block_enabled = block.settings[block_enabled_key]
          assign block_image = block.settings[block_image_key]
          assign block_rollover_image = block.settings[block_rollover_image_key]
          assign block_rollover_video = block.settings[block_rollover_video_key]
          assign block_heading = block.settings[block_heading_key]
          assign block_paragraph = block.settings[block_paragraph_key]
          assign block_overlay_text = block.settings[block_overlay_text_key]
          assign block_overlay_position = block.settings[block_overlay_position_key]
          assign block_sticker = block.settings[block_sticker_key]
          assign block_show_play = block.settings[block_show_play_key]
        %}

        {% if i <= block.settings.blocks_count %}
          <div class="ai-media-block-item-{{ ai_gen_id }}">
            <div class="ai-media-block-image-wrapper-{{ ai_gen_id }}">
              {% if block_image %}
                <img
                  src="{{ block_image | image_url: width: 800 }}"
                  alt="{{ block_image.alt | escape }}"
                  class="ai-media-block-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="{{ block_image.width }}"
                  height="{{ block_image.height }}"
                >
              {% else %}
                <div class="ai-media-block-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}

              {% if block_rollover_video != blank %}
                <video
                  class="ai-media-block-rollover-{{ ai_gen_id }}"
                  muted
                  loop
                  playsinline
                  preload="metadata"
                >
                  <source src="{{ block_rollover_video }}" type="video/mp4">
                </video>
              {% elsif block_rollover_image %}
                <img
                  src="{{ block_rollover_image | image_url: width: 800 }}"
                  alt="{{ block_rollover_image.alt | escape }}"
                  class="ai-media-block-rollover-{{ ai_gen_id }}"
                  loading="lazy"
                >
              {% endif %}

              {% if block_overlay_text != blank %}
                <div class="ai-media-block-text-overlay-{{ ai_gen_id }} ai-media-block-text-overlay-{{ ai_gen_id }}--{{ block_overlay_position }} ai-media-block-text-overlay-{{ ai_gen_id }}-{{ i }}">
                  {{ block_overlay_text }}
                </div>
              {% endif %}

              {% if block_sticker %}
                <div class="ai-media-block-sticker-{{ ai_gen_id }}">
                  <img
                    src="{{ block_sticker | image_url: width: 80 }}"
                    alt="{{ block_sticker.alt | escape }}"
                    loading="lazy"
                  >
                </div>
              {% endif %}

              {% if block_show_play %}
                <div class="ai-media-block-play-icon-{{ ai_gen_id }} ai-media-block-play-icon-{{ ai_gen_id }}--{{ block.settings.play_icon_position }}" data-block="{{ i }}">
                  {% if block.settings.custom_play_icon %}
                    <img
                      src="{{ block.settings.custom_play_icon | image_url: width: 100 }}"
                      alt="Play"
                      style="width: 100%; height: 100%; object-fit: contain;"
                    >
                  {% else %}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M8 5v14l11-7z"/>
                    </svg>
                  {% endif %}
                </div>
              {% endif %}
            </div>

            <div class="ai-media-block-content-{{ ai_gen_id }}">
              {% if block_heading != blank %}
                <h3 class="ai-media-block-heading-{{ ai_gen_id }}">{{ block_heading }}</h3>
              {% endif %}
              {% if block_paragraph != blank %}
                <p class="ai-media-block-paragraph-{{ ai_gen_id }}">{{ block_paragraph }}</p>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</media-blocks-{{ ai_gen_id }}>

<script>
  (function() {
    class MediaBlocks{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupEventListeners();
      }

      setupEventListeners() {
        const playIcons = this.querySelectorAll('.ai-media-block-play-icon-{{ ai_gen_id }}');
        const videoElements = this.querySelectorAll('.ai-media-block-rollover-{{ ai_gen_id }}[src]');

        playIcons.forEach((icon) => {
          icon.addEventListener('click', () => {
            const blockId = icon.dataset.block;
            const wrapper = icon.closest('.ai-media-block-image-wrapper-{{ ai_gen_id }}');
            const video = wrapper.querySelector('.ai-media-block-rollover-{{ ai_gen_id }}');
            
            if (video && video.tagName === 'VIDEO') {
              if (video.paused) {
                video.play();
              } else {
                video.pause();
              }
            }
          });
        });

        const imageWrappers = this.querySelectorAll('.ai-media-block-image-wrapper-{{ ai_gen_id }}');
        imageWrappers.forEach((wrapper) => {
          const video = wrapper.querySelector('.ai-media-block-rollover-{{ ai_gen_id }}');
          
          if (video && video.tagName === 'VIDEO') {
            wrapper.addEventListener('mouseenter', () => {
              video.play();
            });
            wrapper.addEventListener('mouseleave', () => {
              video.pause();
              video.currentTime = 0;
            });
          }
        });
      }
    }

    customElements.define('media-blocks-{{ ai_gen_id }}', MediaBlocks{{ ai_gen_id }});
  })();
</script>

