{% doc %}
  @prompt
    This component is a two-option selector.
    The text on the left (“I want to Sell”) is a clickable text link.
    The black pill on the right (“I want to Make”) represents the currently selected state and is not a link.
    Only the plain text (not the black pill) should function as a link.
    If you want it even more explicit / technical for Shopify AI, use this version:
    This UI uses a toggle-style layout. Only the unselected text label (“I want to Sell”) is a hyperlink. The selected option (“I want to Make”) is displayed as a black pill and is not clickable., there need to be a section bg and another elements wrapping the pills with another color , text in pill and outside need the same horizontal padding , pills need to have no padding between them, section needs max width in px and horizontal padding options in 2px multiples, and top and bottom padding for desktop and mobile , bg color should go full width, past sections max width, need Horizontal padding for desktop and mobile, need Alignment for desktop and mobile, i need a line of text directly above the toggles with alignment options , alignment for heading should apply to where it aligns in relation to toggle, and need text size for desktop and mobile , need smaller text options, space between heading and toggle and active toggle need space around it , horizontal padding should fall within max width, and i need a radious option on toggles 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-toggle-selector-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-toggle-selector-outer-{{ ai_gen_id }} {
    background-color: {{ block.settings.section_bg_color }};
    width: 100%;
    padding-top: {{ block.settings.section_padding_top_desktop }}px;
    padding-bottom: {{ block.settings.section_padding_bottom_desktop }}px;
  }

  .ai-toggle-selector-inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.section_max_width }}px;
    margin: 0 auto;
    padding-left: {{ block.settings.section_padding_horizontal_desktop }}px;
    padding-right: {{ block.settings.section_padding_horizontal_desktop }}px;
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.heading_alignment_desktop }};
    gap: {{ block.settings.heading_spacing }}px;
  }

  .ai-toggle-selector-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_font_size_desktop }}px;
    font-family: {{ block.settings.heading_font_family.family }}, {{ block.settings.heading_font_family.fallback_families }};
    font-weight: {{ block.settings.heading_font_family.weight }};
    margin: 0;
  }

  .ai-toggle-selector-wrapper-{{ ai_gen_id }} {
    background-color: {{ block.settings.wrapper_bg_color }};
    display: inline-flex;
    border-radius: {{ block.settings.wrapper_border_radius }}px;
    padding: {{ block.settings.wrapper_padding }}px;
    gap: {{ block.settings.pill_gap }}px;
  }

  .ai-toggle-selector-option-{{ ai_gen_id }} {
    padding: {{ block.settings.pill_padding_vertical }}px {{ block.settings.pill_padding_horizontal }}px;
    font-size: {{ block.settings.font_size_desktop }}px;
    font-family: {{ block.settings.font_family.family }}, {{ block.settings.font_family.fallback_families }};
    font-weight: {{ block.settings.font_family.weight }};
    transition: all 0.3s ease;
    white-space: nowrap;
    border-radius: {{ block.settings.toggle_border_radius }}px;
  }

  .ai-toggle-selector-option-{{ ai_gen_id }}.ai-toggle-selector-link-{{ ai_gen_id }} {
    color: {{ block.settings.unselected_text_color }};
    text-decoration: none;
    cursor: pointer;
  }

  .ai-toggle-selector-option-{{ ai_gen_id }}.ai-toggle-selector-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.unselected_hover_text_color }};
  }

  .ai-toggle-selector-option-{{ ai_gen_id }}.ai-toggle-selector-selected-{{ ai_gen_id }} {
    background-color: {{ block.settings.selected_bg_color }};
    color: {{ block.settings.selected_text_color }};
    cursor: default;
  }

  @media screen and (max-width: 749px) {
    .ai-toggle-selector-outer-{{ ai_gen_id }} {
      padding-top: {{ block.settings.section_padding_top_mobile }}px;
      padding-bottom: {{ block.settings.section_padding_bottom_mobile }}px;
    }

    .ai-toggle-selector-inner-{{ ai_gen_id }} {
      padding-left: {{ block.settings.section_padding_horizontal_mobile }}px;
      padding-right: {{ block.settings.section_padding_horizontal_mobile }}px;
      align-items: {{ block.settings.heading_alignment_mobile }};
    }

    .ai-toggle-selector-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size_mobile }}px;
    }

    .ai-toggle-selector-option-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size_mobile }}px;
    }
  }
{% endstyle %}

<toggle-selector-{{ ai_gen_id }} class="ai-toggle-selector-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-toggle-selector-outer-{{ ai_gen_id }}">
    <div class="ai-toggle-selector-inner-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-toggle-selector-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      <div class="ai-toggle-selector-wrapper-{{ ai_gen_id }}">
        {% if block.settings.option_1_is_selected %}
          <span class="ai-toggle-selector-option-{{ ai_gen_id }} ai-toggle-selector-selected-{{ ai_gen_id }}">
            {{ block.settings.option_1_text }}
          </span>
        {% else %}
          <a 
            href="{{ block.settings.option_1_url }}" 
            class="ai-toggle-selector-option-{{ ai_gen_id }} ai-toggle-selector-link-{{ ai_gen_id }}"
          >
            {{ block.settings.option_1_text }}
          </a>
        {% endif %}

        {% if block.settings.option_2_is_selected %}
          <span class="ai-toggle-selector-option-{{ ai_gen_id }} ai-toggle-selector-selected-{{ ai_gen_id }}">
            {{ block.settings.option_2_text }}
          </span>
        {% else %}
          <a 
            href="{{ block.settings.option_2_url }}" 
            class="ai-toggle-selector-option-{{ ai_gen_id }} ai-toggle-selector-link-{{ ai_gen_id }}"
          >
            {{ block.settings.option_2_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</toggle-selector-{{ ai_gen_id }}>

<script>
  (function() {
    class ToggleSelector{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('toggle-selector-{{ ai_gen_id }}', ToggleSelector{{ ai_gen_id }});
  })();
</script>

