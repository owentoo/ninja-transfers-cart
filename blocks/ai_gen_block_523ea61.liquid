{% doc %}
  @prompt
    make me a section that follows the themes max width and all padding and margin rules. I need a div within in i need an assignable h1 or h2 with text  below that i need para text, all text needs weight, color and size options for desktop and mobile. Section needs the option to have a photo with optional overlay, color, or gradient background, the contect also needs an option to align it to the left right or center of the sections max width, give me top and bottom margin and padding options for the section

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-content-block-{{ ai_gen_id }} {
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
    position: relative;
    overflow: hidden;
  }

  .ai-content-block__wrapper-{{ ai_gen_id }} {
    max-width: {{ settings.theme_max_width }}px;
    margin: 0 auto;
    padding: 0 {{ settings.grid_gap }}px;
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: {{ block.settings.content_position }};
  }

  .ai-content-block__inner-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.text_alignment }};
    text-align: {{ block.settings.text_alignment }};
    max-width: {{ block.settings.content_width }}px;
  }

  .ai-content-block__heading-{{ ai_gen_id }} {
    margin-top: 0;
    margin-bottom: {{ block.settings.heading_spacing }}px;
    font-weight: {{ block.settings.heading_weight }};
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
  }

  .ai-content-block__text-{{ ai_gen_id }} {
    margin: 0;
    font-weight: {{ block.settings.text_weight }};
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.5;
  }

  .ai-content-block__background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-content-block__bg-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-content-block__bg-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    {% if block.settings.background_type == 'image_with_overlay' %}
      background-color: {{ block.settings.overlay_color | color_modify: 'alpha', block.settings.overlay_opacity }};
    {% elsif block.settings.background_type == 'gradient' %}
      background: linear-gradient(to bottom, {{ block.settings.gradient_color_1 }}, {{ block.settings.gradient_color_2 }});
    {% elsif block.settings.background_type == 'color' %}
      background-color: {{ block.settings.background_color }};
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-content-block-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px 0 {{ block.settings.padding_bottom_mobile }}px;
      margin-top: {{ block.settings.margin_top_mobile }}px;
      margin-bottom: {{ block.settings.margin_bottom_mobile }}px;
    }
    
    .ai-content-block__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
      margin-bottom: {{ block.settings.heading_spacing_mobile }}px;
    }

    .ai-content-block__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
    }

    .ai-content-block__wrapper-{{ ai_gen_id }} {
      padding: 0 20px;
    }
  }
{% endstyle %}

<div class="ai-content-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.background_type == 'image' or block.settings.background_type == 'image_with_overlay' %}
    <div class="ai-content-block__background-{{ ai_gen_id }}">
      {% if block.settings.background_image %}
        <img 
          src="{{ block.settings.background_image | image_url: width: 2000 }}"
          alt="{{ block.settings.background_image.alt | escape }}"
          width="{{ block.settings.background_image.width }}"
          height="{{ block.settings.background_image.height }}"
          loading="lazy"
          class="ai-content-block__bg-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-content-block__bg-image-{{ ai_gen_id }}">{{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}{% if block.settings.background_type == 'image_with_overlay' %}
        <div class="ai-content-block__bg-overlay-{{ ai_gen_id }}"></div>
      {% endif %}
    </div>
  {% else %}
    <div class="ai-content-block__bg-overlay-{{ ai_gen_id }}"></div>
  {% endif %}

  <div class="ai-content-block__wrapper-{{ ai_gen_id }}">
    <div class="ai-content-block__inner-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        {% if block.settings.heading_tag == 'h1' %}
          <h1 class="ai-content-block__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h1>
        {% else %}
          <h2 class="ai-content-block__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-content-block__text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
      {% endif %}
    </div>
  </div>
</div>

