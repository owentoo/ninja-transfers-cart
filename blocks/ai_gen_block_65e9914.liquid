{% doc %}
  @prompt
    make me a section with a height from 0-200 that cen be filled with a color or gradient

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-spacer-{{ ai_gen_id }} {
    height: {{ block.settings.height }}px;
    width: 100%;
    display: block;
    {% if block.settings.background_type == 'color' %}
      background-color: {{ block.settings.background_color }};
    {% elsif block.settings.background_type == 'gradient' %}
      background: linear-gradient(
        {{ block.settings.gradient_angle }}deg,
        {{ block.settings.gradient_color_1 }} 0%,
        {{ block.settings.gradient_color_2 }} 100%
      );
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-spacer-{{ ai_gen_id }} {
      height: {{ block.settings.height_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-spacer-{{ ai_gen_id }}" {{ block.shopify_attributes }}></div>

{% schema %}
{
  "name": "Spacer",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "height",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Height",
      "default": 50
    },
    {
      "type": "range",
      "id": "height_mobile",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Mobile height",
      "default": 30
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "select",
      "id": "background_type",
      "label": "Background type",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "color",
          "label": "Solid color"
        },
        {
          "value": "gradient",
          "label": "Gradient"
        }
      ],
      "default": "none"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f4f4f4"
    },
    {
      "type": "color",
      "id": "gradient_color_1",
      "label": "Gradient color 1",
      "default": "#f4f4f4"
    },
    {
      "type": "color",
      "id": "gradient_color_2",
      "label": "Gradient color 2",
      "default": "#e0e0e0"
    },
    {
      "type": "range",
      "id": "gradient_angle",
      "min": 0,
      "max": 360,
      "step": 10,
      "unit": "°",
      "label": "Gradient angle",
      "default": 90
    }
  ],
  "presets": [
    {
      "name": "Spacer"
    }
  ]
}
{% endschema %}