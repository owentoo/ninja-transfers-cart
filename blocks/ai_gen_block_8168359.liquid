{% doc %}
  @prompt
    2-5 link blocks a row with an image with ratio. three lines of text with color, weight and size options and a cta, give section a max width a horizontal padding and margin that matches the crrent themes , make cta have the option to be button or text , cta button should be left aligns and have horizontal padding options 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-link-grid-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding }}px {{ block.settings.horizontal_padding }}px;
    margin: 0 auto;
    max-width: {{ settings.theme_max_width }}px;
  }

  .ai-link-grid-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    max-width: 100%;
  }

  .ai-link-grid-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    transition: transform 0.3s ease;
  }

  .ai-link-grid-item-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-link-grid-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: calc(100% / {{ block.settings.image_ratio }});
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    background-color: #f4f4f4;
    margin-bottom: {{ block.settings.text_spacing }}px;
  }

  .ai-link-grid-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-link-grid-image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-link-grid-image-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-link-grid-text-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.text_gap }}px;
  }

  .ai-link-grid-line1-{{ ai_gen_id }} {
    font-size: {{ block.settings.line1_size }}px;
    font-weight: {{ block.settings.line1_weight }};
    color: {{ block.settings.line1_color }};
    margin: 0;
  }

  .ai-link-grid-line2-{{ ai_gen_id }} {
    font-size: {{ block.settings.line2_size }}px;
    font-weight: {{ block.settings.line2_weight }};
    color: {{ block.settings.line2_color }};
    margin: 0;
  }

  .ai-link-grid-line3-{{ ai_gen_id }} {
    font-size: {{ block.settings.line3_size }}px;
    font-weight: {{ block.settings.line3_weight }};
    color: {{ block.settings.line3_color }};
    margin: 0;
  }

  .ai-link-grid-cta-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: {{ block.settings.cta_spacing }}px;
    font-size: {{ block.settings.cta_size }}px;
    font-weight: {{ block.settings.cta_weight }};
    text-decoration: none;
    transition: all 0.3s ease;
    align-self: flex-start;
  }

  {% if block.settings.cta_style == 'text' %}
    .ai-link-grid-cta-{{ ai_gen_id }} {
      color: {{ block.settings.cta_color }};
    }

    .ai-link-grid-item-{{ ai_gen_id }}:hover .ai-link-grid-cta-{{ ai_gen_id }} {
      color: {{ block.settings.cta_hover_color }};
    }
  {% else %}
    .ai-link-grid-cta-{{ ai_gen_id }} {
      padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
      background-color: {{ block.settings.button_bg_color }};
      color: {{ block.settings.button_text_color }};
      border-radius: {{ block.settings.button_border_radius }}px;
      border: {{ settings.border_width_buttons }}px solid {{ block.settings.button_border_color }};
    }

    .ai-link-grid-item-{{ ai_gen_id }}:hover .ai-link-grid-cta-{{ ai_gen_id }} {
      background-color: {{ block.settings.button_bg_hover_color }};
      color: {{ block.settings.button_text_hover_color }};
      border-color: {{ block.settings.button_border_hover_color }};
    }
  {% endif %}

  .ai-link-grid-cta-arrow-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    transition: transform 0.3s ease;
  }

  .ai-link-grid-item-{{ ai_gen_id }}:hover .ai-link-grid-cta-arrow-{{ ai_gen_id }} {
    transform: translateX(4px);
  }

  @media screen and (max-width: 989px) {
    .ai-link-grid-container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-link-grid-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding }}px 20px;
    }

    .ai-link-grid-container-{{ ai_gen_id }} {
      {% if block.settings.columns_mobile == '1' %}
        grid-template-columns: 1fr;
      {% else %}
        grid-template-columns: repeat(2, 1fr);
      {% endif %}
    }

    .ai-link-grid-line1-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.line1_size }}px * 0.9);
    }

    .ai-link-grid-line2-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.line2_size }}px * 0.9);
    }

    .ai-link-grid-line3-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.line3_size }}px * 0.9);
    }

    .ai-link-grid-cta-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.cta_size }}px * 0.9);
    }
  }
{% endstyle %}

<div class="ai-link-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-link-grid-container-{{ ai_gen_id }}">
    {% for i in (1..5) %}
      {% liquid
        assign link_key = 'link_' | append: i
        assign image_key = 'image_' | append: i
        assign line1_key = 'line1_' | append: i
        assign line2_key = 'line2_' | append: i
        assign line3_key = 'line3_' | append: i
        assign cta_key = 'cta_' | append: i

        assign link = block.settings[link_key]
        assign image = block.settings[image_key]
        assign line1 = block.settings[line1_key]
        assign line2 = block.settings[line2_key]
        assign line3 = block.settings[line3_key]
        assign cta = block.settings[cta_key]
      %}

      {% if link != blank %}
        <a href="{{ link }}" class="ai-link-grid-item-{{ ai_gen_id }}">
          <div class="ai-link-grid-image-wrapper-{{ ai_gen_id }}">
            {% if image %}
              <img
                src="{{ image | image_url: width: 800 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
                class="ai-link-grid-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-link-grid-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <div class="ai-link-grid-text-{{ ai_gen_id }}">
            {% if line1 != blank %}
              <p class="ai-link-grid-line1-{{ ai_gen_id }}">{{ line1 }}</p>
            {% endif %}

            {% if line2 != blank %}
              <p class="ai-link-grid-line2-{{ ai_gen_id }}">{{ line2 }}</p>
            {% endif %}

            {% if line3 != blank %}
              <p class="ai-link-grid-line3-{{ ai_gen_id }}">{{ line3 }}</p>
            {% endif %}

            {% if cta != blank %}
              <span class="ai-link-grid-cta-{{ ai_gen_id }}">
                {{ cta }}
                {% if block.settings.show_arrow %}
                  <svg class="ai-link-grid-cta-arrow-{{ ai_gen_id }}" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                {% endif %}
              </span>
            {% endif %}
          </div>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</div>

