{% doc %}
  @prompt
    make me a section with a row of link blocks with an image, heading and two optional lines of text below it, have it go to 2 by 2 on mobile, i need 5 in a row on desktop, and give it a max width that matches the themes , give me size, color, weight, and padding below options for all text , make each line of text have its own rules, add option for font size on mobile , make sure max width and all horizontal padding and margin rules match the themes, i need up to 20 blocks 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-link-blocks-container-{{ ai_gen_id }} {
    max-width: {{ settings.theme_max_width }}px;
    margin: 0 auto;
    padding: 0 {{ settings.grid_gap | divided_by: 2 }}px;
  }

  .ai-link-blocks-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: {{ settings.grid_gap }}px;
    padding: 0;
  }

  .ai-link-block-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
    color: inherit;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ settings.widgets_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-link-block-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
    box-shadow: 0 {{ block.settings.hover_lift | times: 2 }}px {{ block.settings.hover_lift | times: 4 }}px rgba(0, 0, 0, 0.1);
  }

  .ai-link-block-image-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    overflow: hidden;
    position: relative;
  }

  .ai-link-block-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-link-block-{{ ai_gen_id }}:hover .ai-link-block-image-{{ ai_gen_id }} img {
    transform: scale(1.05);
  }

  .ai-link-block-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ settings.color_background_main_secondary }};
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ settings.color_text_main }};
    opacity: 0.6;
  }

  .ai-link-block-placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
  }

  .ai-link-block-content-{{ ai_gen_id }} {
    padding: {{ block.settings.content_padding }}px;
  }

  .ai-link-block-heading-{{ ai_gen_id }} {
    font-family: {{ settings.headings_font_primary.family }}, {{ settings.headings_font_primary.fallback_families }};
    font-weight: {{ block.settings.heading_weight }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px 0;
    padding: {{ block.settings.heading_padding_top }}px {{ block.settings.heading_padding_horizontal }}px {{ block.settings.heading_padding_bottom }}px {{ block.settings.heading_padding_horizontal }}px;
    color: {{ block.settings.heading_color }};
  }

  .ai-link-block-text-1-{{ ai_gen_id }} {
    font-family: {{ settings.body_font_primary.family }}, {{ settings.body_font_primary.fallback_families }};
    font-weight: {{ block.settings.text_1_weight }};
    font-size: {{ block.settings.text_1_size }}px;
    line-height: 1.4;
    color: {{ block.settings.text_1_color }};
    margin: 0 0 {{ block.settings.text_1_margin_bottom }}px 0;
    padding: {{ block.settings.text_1_padding_top }}px {{ block.settings.text_1_padding_horizontal }}px {{ block.settings.text_1_padding_bottom }}px {{ block.settings.text_1_padding_horizontal }}px;
  }

  .ai-link-block-text-2-{{ ai_gen_id }} {
    font-family: {{ settings.body_font_primary.family }}, {{ settings.body_font_primary.fallback_families }};
    font-weight: {{ block.settings.text_2_weight }};
    font-size: {{ block.settings.text_2_size }}px;
    line-height: 1.4;
    color: {{ block.settings.text_2_color }};
    margin: 0;
    padding: {{ block.settings.text_2_padding_top }}px {{ block.settings.text_2_padding_horizontal }}px {{ block.settings.text_2_padding_bottom }}px {{ block.settings.text_2_padding_horizontal }}px;
  }

  .ai-link-block-text-1-{{ ai_gen_id }}:empty,
  .ai-link-block-text-2-{{ ai_gen_id }}:empty {
    display: none;
  }

  @media screen and (max-width: 1024px) {
    .ai-link-blocks-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-link-blocks-container-{{ ai_gen_id }} {
      padding: 0 {{ settings.grid_gap | divided_by: 4 }}px;
    }

    .ai-link-blocks-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: {{ settings.grid_gap | divided_by: 2 }}px;
    }

    .ai-link-block-content-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding | times: 0.75 }}px;
    }

    .ai-link-block-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-link-block-text-1-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_1_size_mobile }}px;
    }

    .ai-link-block-text-2-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_2_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-link-blocks-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-link-blocks-{{ ai_gen_id }}">
    {% for i in (1..20) %}
      {% liquid
        assign link_key = 'link_' | append: i
        assign image_key = 'image_' | append: i
        assign heading_key = 'heading_' | append: i
        assign text_1_key = 'text_1_' | append: i
        assign text_2_key = 'text_2_' | append: i

        assign link_url = block.settings[link_key]
        assign image = block.settings[image_key]
        assign heading = block.settings[heading_key]
        assign text_1 = block.settings[text_1_key]
        assign text_2 = block.settings[text_2_key]
      %}

      {% if heading != blank or image != blank %}
        <a
          href="{{ link_url | default: '#' }}"
          class="ai-link-block-{{ ai_gen_id }}"
          {% if link_url == blank %}onclick="return false;"{% endif %}
        >
          <div class="ai-link-block-image-{{ ai_gen_id }}">
            {% if image %}
              <img
                src="{{ image | image_url: width: 600 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
              >
            {% else %}
              <div class="ai-link-block-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <div class="ai-link-block-content-{{ ai_gen_id }}">
            {% if heading != blank %}
              <h3 class="ai-link-block-heading-{{ ai_gen_id }}">{{ heading }}</h3>
            {% endif %}

            {% if text_1 != blank %}
              <p class="ai-link-block-text-1-{{ ai_gen_id }}">{{ text_1 }}</p>
            {% endif %}

            {% if text_2 != blank %}
              <p class="ai-link-block-text-2-{{ ai_gen_id }}">{{ text_2 }}</p>
            {% endif %}
          </div>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</div>

