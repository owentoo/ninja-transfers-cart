<script>
  (function() {
    const highlightElement_hero = document.getElementById('{{ section.id }}-hero-highlight-tags');
    if (!highlightElement_hero) return;

    const words = [
      { text: '{{ section.settings.highlight_word_1 }}', color: '{{ section.settings.highlight_color_1 }}' },
      { text: '{{ section.settings.highlight_word_2 }}', color: '{{ section.settings.highlight_color_2 }}' },
      { text: '{{ section.settings.highlight_word_3 }}', color: '{{ section.settings.highlight_color_3 }}' },
      { text: '{{ section.settings.highlight_word_4 }}', color: '{{ section.settings.highlight_color_4 }}' },
      { text: '{{ section.settings.highlight_word_5 }}', color: '{{ section.settings.highlight_color_5 }}' },
      { text: '{{ section.settings.highlight_word_6 }}', color: '{{ section.settings.highlight_color_6 }}' },
      { text: '{{ section.settings.highlight_word_7 }}', color: '{{ section.settings.highlight_color_7 }}' },
      { text: '{{ section.settings.highlight_word_8 }}', color: '{{ section.settings.highlight_color_8 }}' },
      { text: '{{ section.settings.highlight_word_9 }}', color: '{{ section.settings.highlight_color_9 }}' }
    ].filter(word => word.text.trim() !== '');

    if (words.length <= 1) return;

    let currentIndex = 0;
    const changeInterval = {{ section.settings.highlight_change_speed }} * 1000;

    // Set initial color
    highlightElement_hero.style.color = words[0].color;

    function changeHighlightWord_hero() {
      currentIndex = (currentIndex + 1) % words.length;
      // Fade out
      highlightElement_hero.style.opacity = '0';
      setTimeout(() => {
        // Change text and color
        highlightElement_hero.textContent = words[currentIndex].text;
        highlightElement_hero.style.color = words[currentIndex].color;
        
        // Fade in
        highlightElement_hero.style.opacity = '1';
      }, 300);
    }

    setInterval(changeHighlightWord_hero, changeInterval);
  })();
</script>