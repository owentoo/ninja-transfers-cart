{% if is_upload_box_enabled %}
<script>
document.addEventListener("DOMContentLoaded", function () {

  document.querySelectorAll(".hero-upload-wrapper").forEach(wrapper => {
    const input = wrapper.querySelector('input[type="file"]');
    const box = wrapper.querySelector(".hero-upload-box");

    if (!input || !box) return;

    /* ---------- FILE PICKER ---------- */
    input.addEventListener("change", function () {
      handleFiles(this.files, wrapper);
    });

    /* ---------- DRAG EVENTS ---------- */
    ["dragenter", "dragover"].forEach(event => {
      box.addEventListener(event, e => {
        e.preventDefault();
        e.stopPropagation();
        box.classList.add("is-dragging");
      });
    });

    ["dragleave", "dragend", "drop"].forEach(event => {
      box.addEventListener(event, e => {
        e.preventDefault();
        e.stopPropagation();
        box.classList.remove("is-dragging");
      });
    });

    /* ---------- DROP ---------- */
    box.addEventListener("drop", e => {
      const files = e.dataTransfer.files;
      if (files && files.length) {
        input.files = files;
        handleFiles(files, wrapper);
      }
    });
  });

  /* ---------- FILE HANDLER ---------- */
function handleFiles(files, wrapper) {
  if (!files || !files.length) return;

  const box = wrapper.querySelector(".hero-upload-box");
  if (box) box.classList.add("is-loading");

  const storedFiles = [];
  let processed = 0;

  Array.from(files).forEach(file => {
    const reader = new FileReader();

    reader.onload = function (e) {
      storedFiles.push({
        name: file.name,
        type: file.type,
        size: file.size,
        data: e.target.result
      });

      processed++;

      if (processed === files.length) {
        sessionStorage.setItem(
          "hero_uploaded_files",
          JSON.stringify(storedFiles)
        );

        setTimeout(() => {
          window.location.href =
            "https://ninjatransfers.com/products/dtf-transfers?upload=direct";
        }, 300);
      }
    };

    reader.readAsDataURL(file);
  });
}




});
</script>
