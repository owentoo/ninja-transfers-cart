{%-liquid
  assign ss = section.settings
  assign sb = section.blocks
-%}
 
{{ 'new-hero.css' | asset_url | stylesheet_tag }}
{%  assign is_upload_box_enabled = false %}
{% if sb.size > 0 %}
  {%- comment -%}
  <link rel="stylesheet" href="{{ 'slick.css' | asset_url }}">
  {%- endcomment -%}
  {%- assign tickSvg = '<svg width="16" height="16" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" style="width: 20px; height: 20px; position: relative; top: 3px;"><mask id="mask0_2001_17936" style="mask-type:luminance" maskUnits="userSpaceOnUse" x="0" y="1" width="30" height="31"><path d="M16 29C23.1797 29 29 23.1797 29 16C29 8.8203 23.1797 3 16 3C8.8203 3 3 8.8203 3 16C3 23.1797 8.8203 29 16 29Z" stroke="white" stroke-width="2" stroke-linejoin="round"></path><path d="M22 32L28.989 23.5L15.998 16L9.998 26.393L22 32Z" fill="url(#paint0_linear_2001_17936)"></path><path d="M0 12.9994L3.008 23.4994L15.998 15.9994L9.998 5.60742L0 12.9994Z" fill="url(#paint1_linear_2001_17936)"></path><path d="M15.998 1H27.998V16H15.998V1Z" fill="url(#paint2_linear_2001_17936)"></path></mask><g mask="url(#mask0_2001_17936)"><path d="M0 0H32V32H0V0Z" fill="#CDFE7D"></path></g><path d="M14 21.5L9 16.54L10.59 14.97L14 18.35L21.41 11L23 12.58L14 21.5Z" fill="white"></path><defs><linearGradient id="paint0_linear_2001_17936" x1="24.2437" y1="18.7552" x2="13.3017" y2="29.6972" gradientUnits="userSpaceOnUse"><stop offset="0.2"></stop><stop offset="0.8" stop-opacity="0"></stop></linearGradient><linearGradient id="paint1_linear_2001_17936" x1="9.91476" y1="21.6487" x2="5.91019" y2="6.70256" gradientUnits="userSpaceOnUse"><stop offset="0.2"></stop><stop offset="0.8" stop-opacity="0"></stop></linearGradient><linearGradient id="paint2_linear_2001_17936" x1="14.525" y1="6.498" x2="29.471" y2="10.502" gradientUnits="userSpaceOnUse"><stop offset="0.2"></stop><stop offset="0.8" stop-opacity="0"></stop></linearGradient></defs></svg>' -%}
  <div class="newHero">
    <div class="newHero__{{ section.id }}">
      {%- assign collectStyles = '' -%}
      {%- for block in sb -%}
        {%- assign b = block.settings -%}
        <div class="newHero__slide" bid="{{ block.id }}">
          {% if forloop.first %}
            {%- assign firstImgBID = '.newHero__slide[bid="' | append: block.id | append: '"] .newHero__slide__img' -%}
          {% endif %}

          <div class="newHero__containerWidth">
            <div class="newHero__slide__content">
              {% if b.subTitle != blank %}
                <h5 class="newHero__slide__subTitle">{{ b.subTitle }}</h5>
              {% endif %}
              {% if b.title != blank %}
                {% if forloop.first %}
                  <h1 class="newHero__slide__title {{ b.headingclass }}">{{ b.title }} <span id="{{ section.id }}-hero-highlight-tags" class="hero-highlight-tags-feature-tag"></span></h1>
                {% else %}
                  <h2 class="newHero__slide__title {{ b.headingclass }}">{{ b.title }} <span id="{{ section.id }}-hero-highlight-tags" class="hero-highlight-tags-feature-tag"></span></h2>
                {% endif %}
              {% endif %}
              {% if b.content != blank %}
                <p class="newHero__slide__text">
                  <span>
                    {{ b.content | newline_to_br }}
                  </span>
                  {% if b.bulletContent != blank %}
                    <span class="showDesktop">
                      {% if b.tickConvert == 'desktop' or b.tickConvert == 'all' %}
                        {{ b.bulletContent | replace: '✔', tickSvg }}
                      {% else %}
                        {{ b.bulletContent }}
                      {% endif %}
                    </span>
                    <span class="showMobile">
                      {% if b.tickConvert == 'mobile' or b.tickConvert == 'all' %}
                        {{ b.bulletContent | replace: '✔', tickSvg | newline_to_br }}
                      {% else %}
                        {{ b.bulletContent | newline_to_br }}
                      {% endif %}
                    </span>
                  {% endif %}
                </p>
              {% endif %}

              <div class="newHero__slide__atc">

                {% if b.enable_desktop_upload_box %}
                  {%  assign is_upload_box_enabled = true %}
                  <style>
                      @media (min-width:768px){
                        .newHero__{{ section.id }} .newHero__slide .newHero__containerWidth{
                           min-height:850px;
                           display: flex;
    
    align--items: end;
                        }
                       .newHero__{{ section.id }}  .newHero__slide__content{
                        
                        }
                      }
                    </style> 
                  <div class="hero-upload-wrapper desktop-only">
                    <input
                      type="file"
                      id="heroUploadInput-{{ block.id }}"
                      hidden
                      multiple
                    />

                    <div class="hero-upload-box"
                        onclick="document.getElementById('heroUploadInput-{{ block.id }}').click();">
                        <div class="upload-content">
                      <h3>Upload Your Artwork</h3>
                      <p>
                        Click the button below to add your file(s) or<br>
                        drag into this area
                      </p>
                      <button type="button" class="hero-upload-btn">
                        Get Started
                      </button>
                      </div>
                      <div class="upload-loader">
    <div class="spinner"></div>
    <p style="margin-bottom: 0;">Preparing your files…</p>
  </div>
                    </div>

                    {% if b.enable_desktop_gang_sheet and b.gang_sheet_url != blank %}
                      <div class="hero-gang-sheet">
                        <span class="or-text">or</span>
                        <a href="{{ b.gang_sheet_url }}"
                          class="hero-gang-btn">
                          {{ b.gang_sheet_label }}
                        </a>
                      </div>
                    {% endif %}
                  </div>
                {% endif %}


                {% if b.btnText_1 != blank and b.btnLink_1 != blank %}
                  <div class="{% if b.hide_btn_1_desktop %}hide-desktop{% endif %}">
                  <a href="{{ b.btnLink_1 }}" class="newHero__slide__btn newHomeBtn banner_button_1">
                    <span>
                      {{ b.btnText_1 }}
                    </span>
                    {% if b.showArrow_1 %}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M13.3333 5L20 12M20 12L13.3333 19M20 12L4 12" stroke="#171717" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    {% endif %}
                  </a>
                   </div> 
                {% endif %}

                {% if b.btnText_2_fullwidth %}<div class="stack-mobile-cta">{% endif %}
                {% if b.btnText_2 != blank and b.btnLink_2 != blank %}
                  <div class="{% if b.hide_btn_2_desktop %}hide-desktop{% endif %}">
                  <a href="{{ b.btnLink_2 }}" class="newHero__slide__btn newHomeBtn banner_button_2">
                    <span>
                      {{ b.btnText_2 }}
                    </span>
                    {% if b.showArrow_2 %}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M13.3333 5L20 12M20 12L13.3333 19M20 12L4 12" stroke="#171717" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    {% endif %}
                  </a>
                  </div>
                {% endif %}

                {% if b.btnText_3 != blank and b.btnLink_3 != blank %}
                  <a href="{{ b.btnLink_3 }}" class="newHero__slide__btn newHomeBtn blank_homebtn banner_button_3 {% if b.showArrow_mobile_3 == true %}blank_homebtnmobile{% endif %}">
                    <span>
                      {{ b.btnText_3 }}
                    </span>
                    {% if b.showArrow_3 %}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M13.3333 5L20 12M20 12L13.3333 19M20 12L4 12" stroke="#171717" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    {% endif %}
                  </a>
                {% endif %}
                {% if b.btnText_2_fullwidth %}</div>{% endif %}
              </div>

              {% if b.reviewsImg != blank or b.reviewsCount != blank or b.timeImg != blank or b.timeCount != blank %}
                <div class="newHero__slide__etc {% if b.mobile_image != blank %}newHero__slide__etc_mobile{% endif %}">
                  <div class="newHero__slide__etcItem">
                    {% if b.reviewsImg != blank %}
                    <img
                    srcset="{{ b.reviewsImg | image_url: width: 100 }} 100w, 
                    {{ b.reviewsImg | image_url: width: 200 }} 200w, 
                    {{ b.reviewsImg | image_url: width: 400 }} 400w"
                    sizes="(max-width: 600px) 50vw, 
                    (max-width: 1200px) 25vw, 
                    10vw"
                    src="{{ b.reviewsImg | image_url: width: 200 }}"
                    alt="{{ b.reviewsImg.alt | escape }}"
                    width="200" 
                    height="auto"
                    class="reviewsImg"
                    />
                    {% endif %}
                    <div class="newHero__slide__etcItemReviewCountAndImg">
                      <reviews-count>{{ b.reviewsCount }}</reviews-count>
                      {% if b.ratingImg != blank %}
                      <img
                      srcset="{{ b.ratingImg | image_url: width: 100 }} 100w, 
                      {{ b.ratingImg | image_url: width: 200 }} 200w, 
                      {{ b.ratingImg | image_url: width: 400 }} 400w"
                      sizes="(max-width: 600px) 50vw, 
                      (max-width: 1200px) 25vw, 
                      10vw"
                      src="{{ b.ratingImg | image_url: width: 200 }}"
                      alt="{{ b.ratingImg.alt | escape }}"
                      width="200" 
                      height="auto"
                      class="ratingImg"
                      />
                      {% endif %}
                    </div>
                    <gray-out>{{ b.reviewsText }}</gray-out>
                  </div>

                  <div class="newHero__slide__etcItem">
                    {% if b.timeImg != blank %}
                    <img
                    srcset="{{ b.timeImg | image_url: width: 100 }} 100w, 
                    {{ b.timeImg | image_url: width: 200 }} 200w, 
                    {{ b.timeImg | image_url: width: 400 }} 400w"
                    sizes="(max-width: 600px) 50vw, 
                    (max-width: 1200px) 25vw, 
                    10vw"
                    src="{{ b.timeImg | image_url: width: 200 }}"
                    alt="{{ b.timeImg.alt | escape }}"
                    width="200" 
                    height="auto"
                    class="timeImg"
                    />
                    {% endif %}
                    <div class="newHero__slide__etcItemReviewCountAndImg">
                      <reviews-count>{{ b.timeCount }}</reviews-count>
                    </div>
                    <gray-out>{{ b.timeText }}</gray-out>
                  </div>
                </div>
              {% endif %}
            </div>

            {% if b.mediaType == 'img' %}
              {% if b.image != blank %}
                <img
                  srcset="{{ b.image | image_url: width: 400 }} 400w,
                  {{ b.image | image_url: width: 800 }} 800w,
                  {{ b.image | image_url: width: 1200 }} 1200w"
                  sizes="(max-width: 600px) 100vw,
                  (max-width: 1200px) 50vw,
                  33vw"
                  src="{{ b.image | image_url: width: 800 }}"
                  alt="{{ b.title | escape }}"
                  width="800"
                  height="auto"
                  class="newHero__slide__img newHero__slide__img_desktop {% if forloop.index > 1 %}notLoad{% endif %} {{ b.imgPosition_desktop }}"
                  {% if forloop.first %}
                    fetchpriority="high"
                  {% else %}
                    loading="lazy"
                  {% endif %}
                >
              {% endif %}
              {% if b.mobile_image != blank %}
                <img
                  srcset="{{ b.mobile_image | image_url: width: 400 }} 400w,
                  {{ b.mobile_image | image_url: width: 800 }} 800w,
                  {{ b.mobile_image | image_url: width: 1200 }} 1200w"
                  sizes="(max-width: 600px) 100vw,
                  (max-width: 1200px) 50vw,
                  33vw"
                  src="{{ b.mobile_image | image_url: width: 800 }}"
                  alt="{{ b.title | escape }}"
                  width="500"
                  height="auto"
                  class="newHero__slide__img __test{{ forloop.index }} newHero__slide__img_mobile {% if forloop.index > 1 %}notLoad{% endif %} {{ b.imgPosition_desktop }}"
                  {% if forloop.first %}
                    fetchpriority="high"
                  {% else %}
                    loading="lazy"
                  {% endif %}
                >
              {% endif %}
            {% elsif b.mediaType == 'vid' and b.videoLayout != 'fullWidth' %}
              {% if b.video != blank %}
                {%- capture getVideo -%}
                  {% for vid in b.video.sources %}
                    {% if vid.format == 'mp4' %}
                      {{ vid.url }}
                    {% endif %}
                  {% endfor %}
                {%- endcapture -%}
                <div class="textVid__item vidBlock" bid="{{ block.id }}">
                  <video
                    width="100%"
                    loop="true"
                    autoplay="autoplay"
                    controls="true"
                    muted
                    playsinline
                    {% if b.videoPoster != blank %}
                      poster="{{ b.videoPoster | image_url: width: 700 }}"
                    {% endif %}
                  >
                    <source src="{{ getVideo }}" type="video/mp4">
                  </video>
                </div>
              {% endif %}
            {% endif %}
          </div>

          {% if b.mediaType == 'vid' and b.videoLayout == 'fullWidth' %}
            {% if b.video != blank %}
              {%- capture getVideo -%}
                {% for vid in b.video.sources %}
                  {% if vid.format == 'mp4' %}
                    {{ vid.url }}
                  {% endif %}
                {% endfor %}
              {%- endcapture -%}
              <div class="newHoro__vidBlock fullWidth" bid="{{ block.id }}">
                <video
                  width="100%"
                  loop="true"
                  autoplay="autoplay"
                  muted
                  playsinline
                  {% if b.videoPoster != blank %}
                    poster="{{ b.videoPoster | image_url: width: 700 }}"
                  {% endif %}
                >
                  <source src="{{ getVideo }}" type="video/mp4">
                </video>
              </div>
              <style>
                .newHero__slide[bid="{{ block.id }}"] .newHoro__vidBlock.fullWidth {
                  position: relative;
                }
                .newHero__slide[bid="{{ block.id }}"] .newHoro__vidBlock.fullWidth video {
                  position: relative;
                  height: {{ b.videoHeight_desktop | append: 'px' }};
                }
                .newHero__slide[bid="{{ block.id }}"] .newHoro__vidBlock.fullWidth::before {
                  content: '';
                  position: absolute;
                  top: 0;
                  left: 0;
                  width: 100%;
                  height: 100%;
                  z-index: 1;
                  background-color: {{ b.videoOverlayColor }};
                  opacity: {{ b.videoOverlayOpacity }};
                }
                @media (max-width: 1024px) {
                  .newHero__slide[bid="{{ block.id }}"] .newHoro__vidBlock.fullWidth video {
                    height: {{ b.videoHeight_tab | append: 'px' }};
                  }
                }
                @media (max-width: 768px) {
                  .newHero__containerWidth {
                    position: absolute;
                    /* width: 100%; */
                  }
                  .newHero__slide[bid="{{ block.id }}"] .newHoro__vidBlock.fullWidth video {
                    height: {{ b.videoHeight_mobile | append: 'px' }};
                  }
                }
              </style>
            {% endif %}
          {% endif %}

        </div>
        {%- capture collectStyles -%}
          {{ collectStyles }}
          @media (min-width: 1024px) {
            {{ firstImgBID }}.notLoad {
              position: relative; top: -100%; left: calc(100% - 800px);
            }
          }
          {% if b.bgImage != blank %}
            .newHero__slide[bid="{{ block.id }}"] {
              background-image: url( '{{ b.bgImage | image_url: width: 800 }}' );
              background-repeat: no-repeat;
              background-size: cover;
            }
          {% endif %}
          .newHero__slide[bid="{{ block.id }}"] .newHero__slide__content {
            max-width: {{ b.maxWidthContent_desktop | append: 'px' }};
          }
          .newHero__slide[bid="{{ block.id }}"] .newHero__slide__subTitle {
            color: {{ b.subTitle__textColor }};
            font-size: {{ b.subTitleFontSize_desktop | append: 'px' }};
            font-weight: {{ b.subTitleFontSize_desktop }};
          }
          .newHero__slide[bid="{{ block.id }}"] .newHero__slide__title {
            font-size: {{ b.titleFontSize_desktop | append: 'px' }};
            font-weight: {{ b.titleFontWeight_desktop }};
            color: {{ b.titleColor }};
          }
          .newHero__slide[bid="{{ block.id }}"] .newHero__slide__title > em{font-size: calc({{ b.titleFontSize_desktop | minus : 2 | append : 'px' }})}
          .newHero__slide[bid="{{ block.id }}"] .newHero__slide__text {
            font-size: {{ b.contentFontSize_desktop | append: 'px' }};
            color: {{ b.contentColor }};
          }
          .newHero__slide[bid="{{ block.id }}"] .newHero__slide__etcItem reviews-count {
            font-size: {{ b.reviewRatingFontSize_desktop | append: 'px' }};
            font-weight: {{ b.reviewRatingFontWeight_desktop }};
          }
          .newHero__slide[bid="{{ block.id }}"] .newHero__slide__etcItem .reviewsImg {
            max-width: {{ b.reviewsImg_desktop | append: 'px' }};
          }
          .newHero__slide[bid="{{ block.id }}"] .newHero__slide__etcItem .ratingImg {
            max-width: {{ b.ratingImg_desktop | append: 'px' }};
          }
          .newHero__slide[bid="{{ block.id }}"] .newHero__slide__etcItem .timeImg {
            max-width: {{ b.timeImg_desktop | append: 'px' }};
          }
          .newHero__slide[bid="{{ block.id }}"] .newHero__slide__etc {
            margin-top: {{ b.marginTopReviewRatingTime_desktop | append: 'px' }};
          }
          .newHero__slide[bid="{{ block.id }}"] .newHero__slide__img {
            max-height: {{ b.imgHeight_desktop | append: 'px' }};
          }
          .newHero__slide[bid="{{ block.id }}"] .newHero__slide__atc {
            margin-top: {{ b.actMarginTop_desktop | append: 'px' }};
          }
          @media (max-width: 1024px) {
            .newHero__slide[bid="{{ block.id }}"] .newHero__slide__subTitle {
              font-size: {{ b.subTitleFontSize_tab | append: 'px' }};
              font-weight: {{ b.subTitleFontSize_tab }};
            }
            .newHero__slide[bid="{{ block.id }}"] .newHero__slide__title {
              font-size: {{ b.titleFontSize_tab | append: 'px' }};
              font-weight: {{ b.titleFontWeight_tab }};
            }
            .newHero__slide[bid="{{ block.id }}"] .newHero__slide__title > em{font-size: calc({{ b.titleFontSize_tab | minus : 2 | append : 'px' }})}
          
            .newHero__slide[bid="{{ block.id }}"] .newHero__slide__text {
              font-size: {{ b.contentFontSize_tab | append: 'px' }};
            }
            .newHero__slide[bid="{{ block.id }}"] .newHero__slide__etcItem reviews-count {
              font-size: {{ b.reviewRatingFontSize_tab | append: 'px' }};
              font-weight: {{ b.reviewRatingFontWeight_tab }};
            }
            .newHero__slide[bid="{{ block.id }}"] .newHero__slide__etcItem .reviewsImg {
              max-width: {{ b.reviewsImg_tab | append: 'px' }};
            }
            .newHero__slide[bid="{{ block.id }}"] .newHero__slide__etcItem .ratingImg {
              max-width: {{ b.ratingImg_tab | append: 'px' }};
            }
            .newHero__slide[bid="{{ block.id }}"] .newHero__slide__etcItem .timeImg {
              max-width: {{ b.timeImg_tab | append: 'px' }};
            }
            .newHero__slide[bid="{{ block.id }}"] .newHero__slide__etc {
              margin-top: {{ b.marginTopReviewRatingTime_tab | append: 'px' }};
            }
            .newHero__slide[bid="{{ block.id }}"] .newHero__slide__img {
              max-height: {{ b.imgHeight_tab | append: 'px' }};
            }
            .newHero__slide[bid="{{ block.id }}"] .newHero__slide__content {
              max-width: {{ b.maxWidthContent_tab | append: 'px' }};
            }
            .newHero__slide[bid="{{ block.id }}"] .newHero__slide__atc {
              margin-top: {{ b.actMarginTop_tab | append: 'px' }};
            }
          }
          @media (max-width: 768px) {
            .newHero__slide[bid="{{ block.id }}"] .newHero__slide__subTitle {
              font-size: {{ b.subTitleFontSize_mobile | append: 'px' }};
              font-weight: {{ b.subTitleFontSize_mobile }};
            }
            .newHero__slide[bid="{{ block.id }}"] .newHero__slide__title {
              font-size: {{ b.titleFontSize_mobile | append: 'px' }};
              font-weight: {{ b.titleFontWeight_mobile }};
            }
            .newHero__slide[bid="{{ block.id }}"] .newHero__slide__title > em{font-size: calc({{ b.titleFontSize_mobile | minus : 2 | append : 'px' }})}
          
            .newHero__slide[bid="{{ block.id }}"] .newHero__slide__text {
              font-size: {{ b.contentFontSize_mobile | append: 'px' }};
            }
            .newHero__slide[bid="{{ block.id }}"] .newHero__slide__etcItem reviews-count {
              font-size: {{ b.reviewRatingFontSize_mobile | append: 'px' }};
              font-weight: {{ b.reviewRatingFontWeight_mobile }};
            }
            .newHero__slide[bid="{{ block.id }}"] .newHero__slide__etcItem .reviewsImg {
              max-width: {{ b.reviewsImg_mobile | append: 'px' }};
            }
            .newHero__slide[bid="{{ block.id }}"] .newHero__slide__etcItem .ratingImg {
              max-width: {{ b.ratingImg_mobile | append: 'px' }};
            }
            .newHero__slide[bid="{{ block.id }}"] .newHero__slide__etcItem .timeImg {
              max-width: {{ b.timeImg_mobile | append: 'px' }};
            }
            .newHero__slide[bid="{{ block.id }}"] .newHero__slide__etc {
              margin-top: {{ b.marginTopReviewRatingTime_mobile | append: 'px' }};
            }
            .newHero__slide[bid="{{ block.id }}"] .newHero__slide__img {
              max-height: {{ b.imgHeight_mobile | append: 'px' }};
            }
            .newHero__slide[bid="{{ block.id }}"] .newHero__slide__content {
              max-width: {{ b.maxWidthContent_mobile | append: 'px' }};
            }
            .newHero__slide[bid="{{ block.id }}"] .newHero__slide__atc {
              margin-top: {{ b.actMarginTop_mobile | append: 'px' }};
            }
            {% if b.imgPosition_mobile == 'topImg' %}
              .newHero__slide[bid="{{ block.id }}"] .newHero__containerWidth {
                display: grid;
              }
              .newHero__slide[bid="{{ block.id }}"] .newHero__slide__content {
                order: 2;
                padding-bottom: 20px;
                padding-top: 40px;
              }
              .newHero__slide[bid="{{ block.id }}"]::after {
                display: none;
              }
              .newHero__slide[bid="{{ block.id }}"] .newHero__slide__img {
                order: 1;
                position: relative;
                margin-right: auto;
                margin-left: auto;
              }
              .newHero__slide[bid="{{ block.id }}"] .newHero__slide__title {
                margin-top: 0;
              }
            {% endif %}
          }
          .newHero__slide[bid="{{ block.id }}"] {
            background-color: {{ b.bgColor }};
          }
        {%- endcapture -%}
      {%- endfor -%}
    </div>
    {% if collectStyles != blank %}
      <style>
        {{ collectStyles }}
      </style>
    {% endif %}
  </div>
  {%- comment -%}
  <script src="{{ 'slick.min.js' | asset_url }}"></script>
  {%- endcomment -%}
  <script>
    $(function() {
      $( `.newHero__{{ section.id }}` ).slick({
        dots: {{ ss.showDots | json}},
        arrows: true,
        prevArrow: '<button type="button" class="slick-prev pull-left"><span class="animate-icon"></span></button>',
        nextArrow: '<button type="button" class="slick-next pull-right"><span class="animate-icon"></span></button>',
        infinite: false,
        slidesToShow: 1,
        slidesToScroll: 1,
        adaptiveHeight:true,
        autoplay: {{ ss.autoPlay }},
        autoplaySpeed: {{ ss.autoPlayTimer | times: 1000 }}
      })
      .on("setPosition", function () {
        resizeSlider();
      });

      $(window).resize(function() {
        $(".sliderWrapper_wrapper__{{ section.id }}").show().find(`.sliderWrapper__{{ section.id }}` ).slick("resize");
      });

      $(window).on("resize", function (e) {
        resizeSlider();
      });

      var slickHeight = $(".sliderWrapper_wrapper__{{ section.id }} .slick-track").outerHeight();

      var slideHeight = $(".sliderWrapper_wrapper__{{ section.id }}.slick-track").find(".slick-slide").outerHeight();

      function resizeSlider() {
        $(".sliderWrapper_wrapper__{{ section.id }} .slick-track")
