{%- assign ss = section.settings -%}

<div id="articleBody-{{ section.id }}" class="articleBody {% if section.settings.is_fullwidth %} container--fullwidth {% else %} container--large {% endif %} {% unless section.settings.remove_margin %} container--vertical-space {% endunless %} remove-empty-space reduce-margin-if-first">
  {% if ss.showPageContent %}
    {{ page.content }}
  {% endif %}
</div>

{% schema %}
{
  "name": "Article Body",
  "class": "mount-css-slider mount-slideshow mount-video-background supports-absolute-header",
  "settings": [
    {
      "type": "richtext",
      "id": "articleContent",
      "label": "Rich Text"
    },
    {
      "type": "checkbox",
      "id": "showPageContent",
      "label": "Show Page Content",
      "default": true
    },
    {
      "type": "range",
      "id": "maxWidth",
      "label": "Max Width",
      "unit": "px",
      "min": 500,
      "max": 1400,
      "step": 10,
      "default": 1000
    },
    {
      "type": "range",
      "id": "marginTop",
      "label": "Margin Top",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "marginBottom",
      "label": "Margin Bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 0,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Article Body"
    }
  ],
  "disabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}
<style>
  #articleBody-{{ section.id }} {
    max-width: {{ ss.maxWidth | append: 'px' }};
    margin-left: auto;
    margin-right: auto;
    margin-top: {{ ss.marginTop | append: 'px' }} !important;
    margin-bottom: {{ ss.marginBottom | append: 'px' }};
  }
  #articleBody-{{ section.id }} img {
    max-width: 100%;
  }
  p a,
  ol a,
  ul a,
  .articleHero__breadCrumb a {
    color: #42a9de;
    font-weight: 600;
  }
  p a:hover,
  ol a:hover,
  ul a:hover,
  .articleHero__breadCrumb a:hover {
    color: #002349;
  }
</style>
