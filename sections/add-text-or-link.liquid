{%-liquid
  assign ss = section.settings
-%}

{% if ss.linkLabel != blank and ss.link != blank %}
  <div class="container--large">
    <a href="{{ ss.link }}">
      {% if ss.showArrow %}
        <svg
          width="26px"
          viewBox="0 0 32 32"
          xmlns="http://www.w3.org/2000/svg"
          style="position: relative;
            top: 7px;
        "
        ><defs><style>.cls-1{fill:none;stroke:#000;stroke-linecap:round;stroke-linejoin:round;stroke-width:2px;}</style></defs><title></title><g id="arrow-left"><line class="cls-1" x1="3" x2="29" y1="16" y2="16"></line><line class="cls-1" x1="3" x2="7" y1="16" y2="11"></line><line class="cls-1" x1="3" x2="7" y1="16" y2="21"></line></g></svg>
      {% endif %}
      {{ ss.linkLabel }}
    </a>
  </div>

  <style>
    #shopify-section-{{ section.id }} {
      margin-top: {{ ss.desktop_marginTop | append: 'px' }};
      margin-bottom: {{ ss.desktop_marginBottom | append: 'px' }};
    }
    @media (max-width: 600px) {
      #shopify-section-{{ section.id }} {
        margin-top: {{ ss.mobile_marginTop | append: 'px' }};
        margin-bottom: {{ ss.mobile_marginBottom | append: 'px' }};
      }
    }
  </style>
{% endif %}

{% schema %}
{
  "name": "Add Text or Link",
  "settings": [
    {
      "type": "text",
      "id": "linkLabel",
      "label": "Link Label"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "checkbox",
      "id": "showArrow",
      "label": "Show Arrow",
      "default": true
    },
    {
      "type": "header",
      "content": "Section Margins"
    },
    {
      "type": "range",
      "id": "desktop_marginTop",
      "label": "Margin Top Desktop",
      "unit": "px",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 0
    },
    {
      "type": "range",
      "id": "desktop_marginBottom",
      "label": "Margin Bottom Desktop",
      "unit": "px",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 0
    },
    {
      "type": "range",
      "id": "mobile_marginTop",
      "label": "Margin Top Mobile",
      "unit": "px",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 0
    },
    {
      "type": "range",
      "id": "mobile_marginBottom",
      "label": "Margin Bottom Mobile",
      "unit": "px",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Add Text or Link"
    }
  ],
  "disabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}
