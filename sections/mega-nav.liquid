{% comment %}
  ╔══════════════════════════════════════════════════════════════════════╗
  ║  Ninja Blanks — Mega Navigation (Desktop + Mobile)                  ║
  ║  File: sections/mega-nav.liquid                                     ║
  ╠══════════════════════════════════════════════════════════════════════╣
  ║                                                                      ║
  ║  STEP 1 — Add to layout/theme.liquid                                ║
  ║    {%- section 'mega-nav' -%}                                        ║
  ║    Place after your existing header section.                        ║
  ║    On mobile, this section renders a trigger bar + drawer that      ║
  ║    replaces your theme's default mobile nav. You may need to hide   ║
  ║    the theme's built-in mobile menu via CSS or theme settings.      ║
  ║                                                                      ║
  ║  STEP 2 — Create linklists in Admin > Online Store > Navigation     ║
  ║    One list per column, e.g.:                                        ║
  ║      ts-style      ts-material     ts-brand                         ║
  ║      sw-style      sw-weight       sw-brand                         ║
  ║    BADGE SYNTAX — append to any link title:                         ║
  ║      "Short Sleeve [hot]"    "Cropped Tees [new]"                   ║
  ║      "100% Cotton [popular]" "Gildan [top seller]"                  ║
  ║      "Sale / Clearance [sale]"                                      ║
  ║                                                                      ║
  ║  STEP 3 — Configure Mega Navigation in Theme Customizer             ║
  ║    Add one "Nav Item / Mega Panel" block per category.              ║
  ║                                                                      ║
  ╚══════════════════════════════════════════════════════════════════════╝
{% endcomment %}

{%- liquid
  assign _is_blanks_page = false
  if request.page_type == 'collection'
    if collection.metafields.custom.apparel_filters == true
      assign _is_blanks_page = true
    endif
  elsif request.page_type == 'product'
    for _c in product.collections
      if _c.metafields.custom.apparel_filters == true
        assign _is_blanks_page = true
        break
      endif
    endfor
  endif
  assign _nav_mode = section.settings.nav_mode | default: 'blanks'
  assign _show_this_nav = false
  if _nav_mode == 'blanks' and _is_blanks_page
    assign _show_this_nav = true
  elsif _nav_mode == 'transfers' and _is_blanks_page == false
    assign _show_this_nav = true
  elsif _nav_mode == 'always'
    assign _show_this_nav = true
  endif
-%}

{%- if _show_this_nav -%}

<style>
/* ════════════════════════════════════════════════
   SHARED — badges, swatches, mobile search
════════════════════════════════════════════════ */
.nb-bge{font-size:9px;font-weight:700;padding:2px 5px;border-radius:3px;letter-spacing:.04em;text-transform:uppercase;flex-shrink:0;}
.nb-bge.hot{background:#e63b1e;color:#fff;}
.nb-bge.nw{background:#0a8a5c;color:#fff;}
.nb-bge.pop{background:#FFD600;color:#111;}
.nb-bge.sale{background:#7B2FBE;color:#fff;}

/* ════════════════════════════════════════════════
   DESKTOP MEGA NAV
════════════════════════════════════════════════ */
.nb-nav{background:#fff;position:relative;z-index:200;box-shadow:0 8px 16px -8px rgba(0,0,0,.12);}
.nb-nav-inner{display:flex;align-items:center;padding:0 var(--gutter-container, 40px);max-width:var(--theme-max-width, 1400px);margin:0 auto;width:100%;}
.nb-nav-items{display:flex;align-items:center;}
.nb-nav-item{position:relative;}
.nb-nav-item>a{
  display:flex;align-items:center;gap:4px;padding:0 12px;height:44px;
  font-size:13px;font-weight:600;color:#555;text-decoration:none;
  border-bottom:3px solid transparent;margin-bottom:0;
  transition:color .15s,border-color .15s;white-space:nowrap;position:relative;z-index:2;
}
.nb-nav-item>a:hover,.nb-nav-item:hover>a{color:#000;border-bottom-color:var(--nb-tab-line,#FFD600);}
.nb-nav-item.current>a{border-bottom-color:var(--nb-tab-line,#FFD600);}
.nb-nav-item>a .nb-arr{font-size:9px;opacity:.4;transition:transform .2s;}
.nb-nav-item:hover>a .nb-arr{transform:rotate(180deg);}
.nb-nav-item::after{content:'';position:absolute;top:100%;left:-20px;right:-20px;height:12px;background:transparent;z-index:301;display:none;}
.nb-nav-item:hover::after{display:block;}
.nb-nav-cta{margin-left:0;}
.nb-nav .atomato-bell-wrap{display:flex;align-items:center;padding:0 4px;}
.nb-nav-cta a{display:flex;align-items:center;height:44px;padding:0 16px;font-size:12px;font-weight:800;text-decoration:none;background:none;}
.nb-nav-cta a:hover{opacity:.75;}

/* MEGA PANEL */
.nb-mega{display:none;position:fixed;background:#ffffff;border-radius:10px;box-shadow:0 8px 32px rgba(0,0,0,.10);border:1px solid #e8e8e8;z-index:300;min-width:560px;max-width:780px;overflow-x:hidden;overflow-y:auto;max-height:calc(100vh - 80px);opacity:0;pointer-events:none;transition:opacity .15s ease,transform .15s ease;transform:translateY(-6px);}
.nb-mega.wide{min-width:780px;max-width:1100px;}
.nb-mega.nb-narrow{min-width:0;width:auto;max-width:560px;}
.nb-mega.nb-2col-cards{min-width:600px;max-width:min(760px,calc(100vw - 32px));}
.nb-mega.nb-tabbed{width:min(960px,calc(100vw - 32px));}.nb-mega.nb-tabbed-4{width:min(1100px,calc(100vw - 32px));}.nb-mega.nb-tabbed-4 .nb-tab-cards-area{padding:16px 24px;}
/* Tab panel */
.nb-tab-bar{display:flex;justify-content:center;border-bottom:2px solid #f0f0f0;padding:0 16px;gap:0;}
.nb-tab-btn{padding:11px 14px;font-size:12px;font-weight:700;color:#888;border:none;background:none;cursor:pointer;border-bottom:3px solid transparent;margin-bottom:-2px;white-space:nowrap;transition:color .15s,border-color .15s;text-transform:uppercase;letter-spacing:.04em;}
.nb-tab-btn.nb-tab-active{color:#111;border-bottom-color:var(--nb-tab-line,#FFD600);}
.nb-tab-panel{display:none;flex-direction:column;}
.nb-tab-panel.nb-tab-active{display:flex;}
.nb-tab-cards-area{flex:1;padding:16px 20px;display:grid;grid-template-columns:repeat(2,1fr);gap:8px;align-content:start;}
.nb-tab-card{display:flex;flex-direction:row;align-items:center;gap:12px;text-decoration:none;color:#222;border-radius:8px;padding:9px 14px;transition:background .1s,color .1s;}
.nb-tab-card:hover{background:#f4f4f4;color:#111;}
.nb-tab-card-img{width:80px;height:80px;flex-shrink:0;border-radius:8px;background:#f5f5f5;overflow:hidden;}
.nb-tab-card-img img{width:100%;height:100%;object-fit:cover;display:block;}
.nb-tab-card-body{flex:1;min-width:0;}
.nb-tab-card-title{font-size:13px;font-weight:700;line-height:1.3;color:#111;}
.nb-tab-card-sub{font-size:12px;color:#888;margin-top:3px;line-height:1.3;}
.nb-tab-card-badge{display:inline-block;font-size:9px;font-weight:800;padding:2px 6px;border-radius:3px;margin-top:4px;text-transform:uppercase;letter-spacing:.04em;}
.nb-tab-card-label{display:inline-block;font-size:9px;font-weight:800;text-transform:uppercase;letter-spacing:.06em;line-height:1;margin-bottom:4px;padding:2px 6px;border-radius:3px;}

/* Mobile tab grid */
.nb-mob-img-list{list-style:none;margin:0;padding:0;}
.nb-mob-img-list li{border-bottom:1px solid #f0f0f0;}
.nb-mob-img-list li:last-child{border-bottom:none;}
.nb-mob-img-row{display:flex;align-items:center;gap:12px;padding:12px 16px;text-decoration:none;color:#111;}
.nb-mob-img-row-thumb{flex-shrink:0;width:68px;height:68px;border-radius:8px;overflow:hidden;background:#f4f4f4;}
.nb-mob-img-row-thumb img{width:100%;height:100%;object-fit:cover;display:block;}
.nb-mob-img-row-body{flex:1;display:flex;flex-direction:column;gap:5px;}
.nb-mob-img-row-title{font-size:14px;font-weight:600;color:#111;line-height:1.3;display:block;}
.nb-nav-item:hover .nb-mega,
.nb-nav-item.nb-open .nb-mega{display:block;opacity:1;pointer-events:auto;transform:translateY(0);}
.nb-mega-body{display:flex;}
.nb-cols{flex:1;display:flex;padding:12px 20px;gap:0;overflow:hidden;}
.nb-mega.nb-narrow .nb-cols{padding:10px 6px;}
.nb-col{flex:1;min-width:0;padding:0 14px;border-right:1px solid #ebebeb;}
.nb-col:first-child{padding-left:0;}
.nb-col:last-child{border-right:none;}
.nb-no-dividers .nb-col{border-right:none;}
.nb-col-hd{font-size:9px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--nb-col-hd-color,#c49a00);margin-bottom:10px;padding-bottom:7px;border-bottom:1px solid #ebebeb;}
.nb-col ul{list-style:none;}
.nb-col ul li a{display:flex;align-items:center;justify-content:space-between;padding:5px 6px;border-radius:5px;font-size:13px;color:#444;text-decoration:none;transition:background .1s,color .1s;gap:5px;}
.nb-col ul li a:hover{background:#f4f4f4;color:#111;}
.nb-shop-all-row{padding:0 20px 14px;display:flex;gap:10px;align-items:center;}
.nb-shop-all-btn{display:inline-flex;align-items:center;gap:5px;background:#FFD600;color:#111;font-size:12px;font-weight:800;padding:7px 14px;border-radius:6px;text-decoration:none;transition:background .15s;}
.nb-shop-all-btn:hover{background:#f0c800;}
.nb-feat{width:210px;flex-shrink:0;background:transparent;border-left:1px solid #e8e8e8;padding:0 14px 16px;display:flex;flex-direction:column;gap:10px;}
.nb-feat-box{background:#f4f4f4;border-radius:8px;padding:8px;display:flex;flex-direction:column;gap:8px;flex:1;}
.nb-feat-lbl{font-size:9px;font-weight:800;letter-spacing:.12em;text-transform:uppercase;color:var(--nb-col-hd-color,#c49a00);margin-bottom:6px;padding-bottom:7px;border-bottom:1px solid #e0e0e0;}
.nb-feat-card{background:#fff;border-radius:8px;overflow:hidden;display:block;text-decoration:none;border:1px solid #e8e8e8;box-shadow:0 2px 8px rgba(0,0,0,.06);transition:box-shadow .15s;}
.nb-feat-card:hover{box-shadow:0 4px 14px rgba(0,0,0,.10);}
.nb-feat-img{width:100%;height:150px;display:flex;align-items:center;justify-content:center;background:#f9f9f9;overflow:hidden;padding:8px;box-sizing:border-box;}
.nb-feat-img img{width:100%;height:100%;object-fit:contain;}
.nb-emoji-fallback{font-size:48px;}
.nb-feat-info{padding:8px 10px 10px;}
.nb-feat-brand{font-size:9px;color:#999;font-weight:700;text-transform:uppercase;letter-spacing:.06em;}
.nb-feat-name{font-size:12px;color:#1a1a1a;font-weight:600;margin:3px 0 5px;line-height:1.35;}
.nb-feat-price{font-size:12px;color:#1a7a3c;font-weight:700;}
.nb-swatch-row{display:flex;align-items:center;gap:4px;margin-top:5px;flex-wrap:wrap;}
.nb-swatch{width:13px;height:13px;border-radius:50%;border:1.5px solid rgba(0,0,0,.12);cursor:pointer;transition:transform .12s;flex-shrink:0;}
.nb-swatch:hover{transform:scale(1.35);}
.nb-swatch-more{font-size:10px;color:#999;margin-left:2px;}
.nb-feat-btn{display:block;text-align:center;background:#FFD600;color:#111;font-size:11px;font-weight:800;padding:9px;border-radius:6px;text-decoration:none;margin-top:auto;letter-spacing:.02em;}
.nb-feat-btn:hover{background:#f0c800;}
.nb-logo-row{display:flex;align-items:center;gap:10px;padding:14px 20px;flex-wrap:wrap;}
.nb-logo-item{display:block;width:160px;height:102px;border:1px solid #e8e8e8;border-radius:8px;flex-shrink:0;overflow:hidden;transition:transform .18s ease,box-shadow .18s ease;}
.nb-logo-item:hover{transform:translateY(-3px);box-shadow:0 6px 16px rgba(0,0,0,.11);}
.nb-logo-item img{width:100%;height:100%;object-fit:cover;display:block;opacity:.85;}
.nb-logo-item:hover img{opacity:1;}
.nb-usps{padding-top:9px;border-top:1px solid #ebebeb;}
.nb-usp{font-size:10px;color:#888;margin-bottom:3px;}
.nb-mega-foot{padding:10px 20px;display:flex;align-items:center;gap:10px;justify-content:space-between;}
.nb-foot-left{display:flex;align-items:center;gap:10px;}
.nb-foot-ship-icon{flex-shrink:0;display:flex;align-items:center;}
.nb-foot-ship-text{display:flex;flex-direction:row;align-items:baseline;gap:5px;}
.nb-foot-ship-title{font-size:11px;font-weight:800;letter-spacing:.04em;text-transform:uppercase;}
.nb-foot-ship-sub{font-size:10px;font-weight:500;}
.nb-foot-right{display:flex;align-items:center;gap:14px;margin-left:auto;}
.nb-foot-promo{display:flex;align-items:center;gap:7px;}
.nb-foot-cta{white-space:nowrap;}
.nb-foot-promo-icon{flex-shrink:0;display:flex;align-items:center;}
.nb-foot-promo-text{font-size:11px;font-weight:700;letter-spacing:.02em;}

/* desktop overlay */
#nb-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:100;pointer-events:none;}

/* ════════════════════════════════════════════════
   MOBILE TRIGGER BAR
════════════════════════════════════════════════ */
.nb-mob-trigger{
  display:none;background:#fff;border-bottom:3px solid var(--nb-tab-line,#FFD600);
  padding:0 16px;height:48px;align-items:center;justify-content:space-between;
  position:sticky;top:0;z-index:200;
}
.nb-mob-ham{
  width:36px;height:36px;border:1.5px solid #e0e0e0;border-radius:7px;
  background:#fafafa;display:flex;flex-direction:column;align-items:center;
  justify-content:center;gap:4px;cursor:pointer;padding:0;
}
.nb-mob-ham span{display:block;width:18px;height:2px;background:#333;border-radius:2px;transition:all .2s;}
.nb-mob-ham.open span:nth-child(1){transform:translateY(6px) rotate(45deg);}
.nb-mob-ham.open span:nth-child(2){opacity:0;}
.nb-mob-ham.open span:nth-child(3){transform:translateY(-6px) rotate(-45deg);}
.nb-mob-trigger-logo{display:flex;align-items:center;gap:8px;text-decoration:none;}
.nb-mob-trigger-logo-box{width:32px;height:32px;background:#111;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:15px;}
.nb-mob-trigger-words strong{display:block;font-size:12px;font-weight:800;color:#111;letter-spacing:-.02em;}
.nb-mob-trigger-words span{font-size:9px;color:#999;text-transform:uppercase;letter-spacing:.04em;}
.nb-mob-trigger-actions{display:flex;align-items:center;gap:8px;}
.nb-mob-search-btn{width:36px;height:36px;border:1.5px solid #e0e0e0;border-radius:7px;background:#fafafa;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:15px;border:none;}

/* ════════════════════════════════════════════════
   MOBILE SEARCH OVERLAY
════════════════════════════════════════════════ */
.nb-mob-search-overlay{
  display:none;position:fixed;inset:0;background:#fff;z-index:800;padding:16px;overflow-y:auto;
}
.nb-mob-search-overlay.open{display:block;}
.nb-mob-search-inner{display:flex;align-items:center;gap:10px;margin-bottom:12px;}
.nb-mob-search-inner input{flex:1;height:42px;border:1.5px solid #FFD600;border-radius:8px;padding:0 14px;font-size:14px;color:#333;outline:none;}
.nb-mob-search-close{font-size:22px;color:#999;cursor:pointer;background:none;border:none;line-height:1;padding:4px;}
.nb-mob-search-section{font-size:9px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#bbb;padding:8px 0 4px;}
.nb-mob-search-item{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid #f0f0f0;cursor:pointer;}
.nb-mob-search-item .s-icon{font-size:16px;width:22px;text-align:center;}
.nb-mob-search-item .s-text{font-size:14px;color:#333;}
.nb-mob-search-item .s-badge{margin-left:auto;font-size:9px;font-weight:700;padding:2px 6px;border-radius:3px;background:#FFD600;color:#111;}

/* ════════════════════════════════════════════════
   MOBILE DRAWER
════════════════════════════════════════════════ */
.nb-mob-drawer-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:9998;}
.nb-mob-drawer-overlay.open{display:block;}
.nb-mob-drawer{
  position:fixed;top:0;left:0;right:0;bottom:0;width:100%;
  background:#ffffff;z-index:9999;
  transform:translateX(-100%);transition:transform .28s cubic-bezier(.4,0,.2,1);
  display:flex;flex-direction:column;overflow:hidden;
}
.nb-mob-drawer.open{transform:translateX(0);}
.nb-mob-drawer-header{
  background:#f8f8f8;padding:0 16px;height:56px;
  display:flex;align-items:center;justify-content:space-between;
  border-bottom:1px solid #eeeeee;flex-shrink:0;
}
.nb-mob-drawer-header strong{font-size:13px;color:#1a1a1a;font-weight:700;letter-spacing:.05em;}
.nb-mob-close{font-size:26px;color:#666;cursor:pointer;background:none;border:none;padding:4px;line-height:1;font-weight:300;}
.nb-mob-close:hover{color:#111;}
.nb-mob-rewards-strip{
  display:flex;align-items:center;gap:10px;padding:10px 16px;
  background:#fffbe6;border-bottom:1px solid #f0e060;flex-shrink:0;
}
.nb-mob-rewards-strip .rw-emoji{font-size:20px;}
.nb-mob-rewards-strip .rw-text strong{display:block;font-size:10px;color:#7a5c00;font-weight:700;}
.nb-mob-rewards-strip .rw-text span{font-size:12px;color:#7a5c00;font-weight:700;}
.nb-mob-rewards-strip .rw-btn{margin-left:auto;background:#FFD600;color:#111;font-size:11px;font-weight:700;padding:5px 10px;border-radius:5px;text-decoration:none;}

/* Accordion nav */
.nb-mob-nav{flex:1;overflow-y:auto;}
.nb-mob-nav::-webkit-scrollbar{width:3px;}
.nb-mob-nav::-webkit-scrollbar-thumb{background:#ddd;border-radius:3px;}
.nb-mob-nav-item{border-bottom:1px solid #eeeeee;}
.nb-mob-nav-row{display:flex;align-items:center;justify-content:space-between;padding:0 16px;height:52px;cursor:pointer;transition:background .1s;}
.nb-mob-nav-row:hover,.nb-mob-nav-row:active{background:#f5f5f5;}
.nb-mob-nav-row.current-page{}
.nb-mob-nav-label{font-size:14px;font-weight:600;color:#1a1a1a;}
.nb-mob-nav-chevron{font-size:11px;color:#bbb;transition:transform .22s;}
.nb-mob-nav-item.nb-expanded .nb-mob-nav-chevron{transform:rotate(90deg);}
.nb-mob-accordion{display:none;background:#f8f8f8;border-top:1px solid #eeeeee;}
.nb-mob-nav-item.nb-expanded .nb-mob-accordion{display:block;}
.nb-mob-acc-section{padding:14px 16px 4px;}.nb-mob-acc-section.nb-no-hd{padding-top:0;margin-top:-10px;}.nb-mob-acc-section.nb-no-hd:first-child{padding-top:10px;margin-top:0;}
/* First section directly after back button gets proper breathing room */
.nb-mob-back-row + .nb-mob-acc-section{padding-top:14px;margin-top:0;}
.nb-mob-acc-hd{font-size:9px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#c49a00;margin-bottom:8px;}
.nb-mob-acc-links{list-style:none;margin-bottom:10px;}
.nb-mob-acc-links li a{
  display:flex;align-items:center;justify-content:space-between;
  padding:10px 8px;border-radius:6px;font-size:13px;color:#444;
  text-decoration:none;transition:background .1s;min-height:44px;
}
.nb-mob-acc-links li a:active{background:#eeeeee;color:#111;}

/* Mobile featured product card */
.nb-mob-feat{
  margin:12px 16px;background:#f4f4f4;border-radius:8px;
  display:flex;align-items:center;gap:12px;padding:12px;
  text-decoration:none;border:1px solid #e8e8e8;
}
.nb-mob-feat:active{background:#ebebeb;}
.nb-mob-feat-img{width:52px;height:52px;border-radius:6px;background:#e8e8e8;display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0;overflow:hidden;}
.nb-mob-feat-img img{width:100%;height:100%;object-fit:cover;}
.nb-mob-feat-info .mf-brand{font-size:9px;color:#999;font-weight:600;text-transform:uppercase;letter-spacing:.05em;}
.nb-mob-feat-info .mf-name{font-size:12px;color:#1a1a1a;font-weight:600;margin:2px 0;}
.nb-mob-feat-info .mf-price{font-size:12px;color:#111;font-weight:700;}

/* Mobile swatches */
.nb-mob-swatch-row{display:flex;align-items:center;gap:6px;padding:0 16px 10px;flex-wrap:wrap;}
.nb-mob-swatch{width:22px;height:22px;border-radius:50%;border:2px solid rgba(0,0,0,.12);cursor:pointer;flex-shrink:0;}
.nb-mob-swatch-more{font-size:11px;color:#999;margin-left:3px;}

/* Mobile trending rail */
.nb-mob-trending{padding:12px 16px;}
.nb-mob-trending-lbl{font-size:9px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#c49a00;margin-bottom:10px;}
.nb-mob-trending-scroll{display:flex;gap:8px;overflow-x:auto;padding-bottom:4px;}
.nb-mob-trending-scroll::-webkit-scrollbar{display:none;}
.nb-mob-trend-card{display:flex;align-items:center;gap:8px;background:#eeeeee;border-radius:6px;padding:8px 10px;flex-shrink:0;width:150px;text-decoration:none;border:1px solid #e4e4e4;}
.nb-mob-trend-card:active{background:#e4e4e4;}
.nb-mob-trend-img{width:30px;height:30px;border-radius:4px;background:#e0e0e0;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;overflow:hidden;}
.nb-mob-trend-img img{width:100%;height:100%;object-fit:cover;}
.nb-mob-t-name{font-size:11px;color:#222;font-weight:600;line-height:1.2;}
.nb-mob-t-price{font-size:10px;color:#888;font-weight:600;margin-top:1px;}

/* Mobile brand grid (2-column tile layout) */
.nb-mob-logo-grid{list-style:none;display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:16px 16px 20px;}
.nb-mob-logo-grid li a{display:block;width:100%;aspect-ratio:16/10;border-radius:8px;border:1px solid #e8e8e8;overflow:hidden;}
.nb-mob-logo-grid li a img{width:100%;height:100%;object-fit:cover;display:block;opacity:.85;}
.nb-mob-brand-grid{list-style:none;display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:8px 16px 16px;}
.nb-mob-logo-grid + .nb-mob-brand-grid{padding-top:8px;}
.nb-mob-brand-grid li a{
  display:flex;align-items:center;justify-content:center;
  padding:11px 8px;border-radius:8px;border:1px solid #e4e4e4;
  background:#fff;font-size:12px;font-weight:600;color:#333;
  text-decoration:none;text-align:center;min-height:44px;
  transition:background .1s,border-color .1s;line-height:1.2;
}
.nb-mob-brand-grid li a:active{background:#f4f4f4;border-color:#ccc;}

/* Mobile shop all button */
.nb-mob-shop-all{
  display:block;margin:10px 16px 14px;text-align:center;
  background:#FFD600;color:#111;font-size:13px;font-weight:800;
  padding:13px;border-radius:8px;text-decoration:none;
}
.nb-mob-shop-all:active{background:#f0c800;}

/* Drawer footer */
.nb-mob-drawer-footer{background:#f5f5f5;border-top:1px solid #eeeeee;padding:16px;flex-shrink:0;}
.nb-mob-footer-label{font-size:9px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#bbb;margin-bottom:10px;}
.nb-mob-brand-links{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:14px;}
.nb-mob-brand-link{font-size:10px;font-weight:700;color:#666;text-decoration:none;padding:5px 10px;border:1px solid #ddd;border-radius:4px;letter-spacing:.04em;text-transform:uppercase;transition:all .15s;}
.nb-mob-brand-link:hover{color:#111;border-color:#aaa;}
.nb-mob-footer-utils{display:flex;gap:12px;align-items:center;}
.nb-mob-footer-link{font-size:12px;color:#777;text-decoration:none;}
.nb-mob-footer-link:hover{color:#111;}
.nb-mob-phone{font-size:12px;color:var(--nb-cta-color,#019AFF);font-weight:600;}

/* ════════════════════════════════════════════════
   RESPONSIVE — show/hide desktop vs mobile
════════════════════════════════════════════════ */
@media (max-width:767px) {
  .nb-nav { display: none !important; }
  #nb-overlay { display: none !important; }
  .nb-mob-trigger { display: none !important; }
  .nb-mob-feat { display: none !important; }
  .nb-blanks-ham { display: none !important; }
}
.nb-header-ham {
  background: none;
  border: none;
  padding: 6px;
  cursor: pointer;
  display: none;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: inherit;
}
@media (max-width:767px) {
  .nb-header-ham { display: flex !important; }
}
@media (min-width:768px) {
  .nb-mob-trigger { display: none !important; }
  .nb-mob-drawer { display: none !important; }
  .nb-mob-drawer-overlay { display: none !important; }
  .nb-mob-search-overlay { display: none !important; }
}

/* ── Suppress existing site nav on blanks pages — mega-nav replaces it ── */
.site-nav.style--classic { display: none !important; }
.blank-transfer-menu { display: none !important; }
.nav-transfer-cta { display: none !important; }
#site-menu-sidebar { display: none !important; }

/* ════════════════════════════════════════════════
   SLIDING PANEL MOBILE NAV (3-LEVEL)
════════════════════════════════════════════════ */
.nb-mob-nav-stage{flex:1;overflow:hidden;display:flex;flex-direction:column;min-height:0;}
.nb-mob-panel-wrap{
  display:flex;height:100%;width:300%;
  transition:transform .3s cubic-bezier(.4,0,.2,1);
}
.nb-mob-panel-wrap.nb-at-2{transform:translateX(-33.333%);}
.nb-mob-panel-wrap.nb-at-3{transform:translateX(-66.667%);}
.nb-mob-panel{width:33.333%;overflow-y:auto;-webkit-overflow-scrolling:touch;}
.nb-mob-panel::-webkit-scrollbar{width:3px;}
.nb-mob-panel::-webkit-scrollbar-thumb{background:#ddd;border-radius:3px;}

/* Level 1 rows */
.nb-mob-lvl1-item{
  display:flex;align-items:center;justify-content:space-between;
  padding:0 16px;height:52px;border-bottom:1px solid #eeeeee;
  cursor:pointer;transition:background .1s;text-decoration:none;color:inherit;
}
.nb-mob-lvl1-item:active{background:#f5f5f5;}
.nb-mob-lvl1-label{font-size:14px;font-weight:600;color:#1a1a1a;}
.nb-mob-lvl1-chevron{font-size:18px;color:#bbb;line-height:1;}

/* Panes inside panels 2 & 3 */
.nb-mob-p2-pane,.nb-mob-p3-pane{display:none;}
.nb-mob-p2-pane.nb-pane-active,.nb-mob-p3-pane.nb-pane-active{display:block;}

/* Back row — top of each sub-panel */
.nb-mob-back-row{
  display:flex;align-items:center;gap:8px;padding:0 16px;height:48px;
  width:100%;background:#f0f0f0;border:none;border-bottom:1px solid #e4e4e4;
  cursor:pointer;font-size:13px;font-weight:700;color:#444;text-align:left;
  transition:background .12s;box-sizing:border-box;
}
.nb-mob-back-row:active{background:#e0e0e0;}

/* Level 2 column header rows */
.nb-mob-lvl2-item{
  display:flex;align-items:center;justify-content:space-between;
  padding:0 16px;height:52px;border-bottom:1px solid #eeeeee;cursor:pointer;transition:background .1s;
}
.nb-mob-lvl2-item:active{background:#f5f5f5;}
.nb-mob-lvl2-label{font-size:14px;font-weight:600;color:#1a1a1a;}
.nb-mob-lvl2-chevron{font-size:18px;color:#bbb;line-height:1;}

/* Shop All — row below back button in panel 2 */
.nb-mob-showall-top{
  display:flex;align-items:center;justify-content:space-between;
  padding:0 16px;height:40px;
  font-size:13px;font-weight:800;color:#c49a00;text-decoration:none;
  border-bottom:1px solid #e4e4e4;flex-shrink:0;background:#fff;
}
.nb-mob-showall-top:active{background:#fafafa;}

/* ════════════════════════════════════════════════
   Link cards — image + label + title + description
════════════════════════════════════════════════ */
.nb-card-zone{flex:0 0 auto;padding:16px 0;border-right:1px solid #ebebeb;min-width:200px;}
.nb-card-zone.nb-cz-solo{flex:1;border-right:none;max-width:420px;}
.nb-card-zone.nb-cz-2col{display:grid;grid-template-columns:1fr 1fr;align-items:start;}
.nb-card-zone.nb-cz-2col.nb-cz-solo{max-width:none;}
.nb-cz-2col .nb-card-zone-hd{grid-column:1/-1;}
.nb-cz-col{display:flex;flex-direction:column;}
.nb-cz-2col.nb-cz-divider .nb-cz-col:first-child{border-right:1px solid #ebebeb;}
.nb-card-zone-hd{font-size:9px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#aaa;margin-bottom:4px;padding:0 14px 6px;border-bottom:1px solid #ebebeb;}
/* Compact link-row with thumbnail — matches category list density */
.nb-dtf-card{
  display:flex;align-items:center;gap:12px;
  padding:9px 14px;text-decoration:none;
  border-radius:6px;transition:background .1s;
}
.nb-dtf-card:hover{background:#f4f4f4;}
.nb-dtf-card.nb-pop .nb-dtf-title{color:#c49a00;}
.nb-dtf-thumb{width:112px;height:112px;flex-shrink:0;border-radius:8px;background:#ebebeb;display:flex;align-items:center;justify-content:center;overflow:hidden;}
.nb-2col-cards .nb-dtf-thumb{width:80px;height:80px;}
.nb-dtf-thumb img{width:100%;height:100%;object-fit:cover;display:block;}
.nb-dtf-thumb-emoji{font-size:18px;}
.nb-dtf-body{flex:1;min-width:0;}
.nb-dtf-label{display:inline-block;font-size:9px;font-weight:800;text-transform:uppercase;letter-spacing:.06em;line-height:1;margin-bottom:6px;padding:3px 8px;border-radius:4px;color:#1a1a1a;}
.nb-dtf-title{display:block;font-size:13px;font-weight:700;color:#1a1a1a;line-height:1.3;}
.nb-dtf-desc{display:block;font-size:12px;color:#888;line-height:1.3;margin-top:2px;}
/* Mobile link card list */
.nb-mob-lc-list{list-style:none;padding:6px 0 4px;}
.nb-mob-lc-list li a{display:flex;flex-direction:row;align-items:center;gap:12px;padding:10px 16px;text-decoration:none;border-bottom:1px solid #f0f0f0;}
.nb-mob-lc-list li:last-child a{border-bottom:none;}
.nb-mob-lc-list li a:active{background:#f9f9f9;}
.nb-mob-lc-thumb{width:64px;height:64px;flex-shrink:0;border-radius:8px;background:#ebebeb;display:flex;align-items:center;justify-content:center;overflow:hidden;}
.nb-mob-lc-thumb img{width:100%;height:100%;object-fit:cover;display:block;}
.nb-mob-lc-thumb-emoji{font-size:22px;}
.nb-mob-lc-body{flex:1;min-width:0;}
.nb-mob-lc-title{display:block;font-size:13px;font-weight:600;color:#1a1a1a;line-height:1.3;}
.nb-mob-lc-desc{display:block;font-size:11px;color:#888;margin-top:2px;line-height:1.3;}
.nb-mob-lc-label{display:inline-block;font-size:9px;font-weight:800;text-transform:uppercase;letter-spacing:.06em;margin-bottom:5px;padding:3px 8px;border-radius:4px;color:#1a1a1a;}
</style>
<style>:root{--nb-col-hd-color:{{ section.settings.col_header_color | default: '#c49a00' }};--nb-tab-line:{{ section.settings.tab_underline_color | default: '#FFD600' }};--nb-cta-color:{{ section.settings.cta_color | default: '#019AFF' }};}</style>

{%- comment -%} ════ DESKTOP OVERLAY ════ {%- endcomment -%}
<div id="nb-overlay"></div>

{%- comment -%} ════ DESKTOP MEGA NAV ════ {%- endcomment -%}
<nav class="nb-nav" id="nb-navbar" role="navigation" aria-label="Main navigation">
  <div class="nb-nav-inner">
    <div class="nb-nav-items">

      {%- for block in section.blocks -%}
        {%- if block.type == 'mega_panel' -%}
          {%- assign is_current = false -%}
          {%- if block.settings.nav_url != blank and request.path contains block.settings.nav_url -%}
            {%- assign is_current = true -%}
          {%- endif -%}

          {%- assign nb_c1 = linklists[block.settings.col1_menu] -%}
          {%- assign nb_c2 = linklists[block.settings.col2_menu] -%}
          {%- assign nb_c3 = linklists[block.settings.col3_menu] -%}
          {%- assign nb_c4 = linklists[block.settings.col4_menu] -%}
          {%- assign nb_c5 = linklists[block.settings.col5_menu] -%}
          {%- assign nb_tlm = linklists[block.settings.top_level_menu] -%}
          {%- assign nb_use_tlm = false -%}
          {%- if block.settings.top_level_menu != blank and nb_tlm.links.size > 0 -%}
            {%- assign nb_use_tlm = true -%}
          {%- endif -%}
          {%- assign nb_has_cols = false -%}
          {%- assign nb_active_cols = 0 -%}
          {%- if nb_use_tlm -%}
            {%- assign nb_has_cols = true -%}
            {%- for tl_link in nb_tlm.links -%}
              {%- if tl_link.links.size > 0 -%}{%- assign nb_active_cols = nb_active_cols | plus: 1 -%}{%- endif -%}
            {%- endfor -%}
          {%- elsif nb_c1.links.size > 0 or nb_c2.links.size > 0 or nb_c3.links.size > 0 or nb_c4.links.size > 0 or nb_c5.links.size > 0 -%}
            {%- assign nb_has_cols = true -%}
            {%- if nb_c1.links.size > 0 -%}{%- assign nb_active_cols = nb_active_cols | plus: 1 -%}{%- endif -%}
            {%- if nb_c2.links.size > 0 -%}{%- assign nb_active_cols = nb_active_cols | plus: 1 -%}{%- endif -%}
            {%- if nb_c3.links.size > 0 -%}{%- assign nb_active_cols = nb_active_cols | plus: 1 -%}{%- endif -%}
            {%- if nb_c4.links.size > 0 -%}{%- assign nb_active_cols = nb_active_cols | plus: 1 -%}{%- endif -%}
            {%- if nb_c5.links.size > 0 -%}{%- assign nb_active_cols = nb_active_cols | plus: 1 -%}{%- endif -%}
          {%- endif -%}
          {%- assign nb_has_link_cards = false -%}
          {%- for _lci in (1..8) -%}
            {%- assign _lck = 'lc_' | append: _lci | append: '_title' -%}
            {%- if block.settings[_lck] != blank -%}{%- assign nb_has_link_cards = true -%}{%- break -%}{%- endif -%}
          {%- endfor -%}
          <div class="nb-nav-item{% if is_current %} current{% endif %}">
            <a href="{{ block.settings.nav_url | default: '#' }}">
              {{- block.settings.nav_label | default: 'Menu' -}}
              {%- if nb_has_cols or nb_has_link_cards or block.settings.featured_product != blank -%}<span class="nb-arr">▼</span>{%- endif -%}
            </a>

            {%- if nb_has_cols or nb_has_link_cards or block.settings.featured_product != blank -%}
            {%- assign nb_has_logos = false -%}
            {%- if block.settings.logo_1_img != blank or block.settings.logo_2_img != blank or block.settings.logo_3_img != blank or block.settings.logo_4_img != blank or block.settings.logo_5_img != blank or block.settings.logo_6_img != blank -%}
              {%- assign nb_has_logos = true -%}
            {%- endif -%}
            {%- assign nb_is_narrow = false -%}
            {%- if nb_active_cols == 1 and block.settings.featured_product == blank and nb_has_logos == false -%}{%- assign nb_is_narrow = true -%}{%- endif -%}
            {%- if nb_active_cols == 0 and nb_has_link_cards and block.settings.featured_product == blank and nb_has_logos == false and block.settings.lc_2col == false -%}{%- assign nb_is_narrow = true -%}{%- endif -%}
            <div class="nb-mega{% if nb_is_narrow %} nb-narrow{% elsif block.settings.wide %} wide{% endif %}{% if block.settings.lc_2col and nb_active_cols == 0 %} nb-2col-cards{% endif %}{% if block.settings.hide_col_dividers %} nb-no-dividers{% endif %}" {{ block.shopify_attributes }}>
              {%- if nb_has_logos -%}
              <div class="nb-logo-row">
                {%- if block.settings.logo_1_img != blank -%}<a href="{{ block.settings.logo_1_url | default: '#' }}" class="nb-logo-item">{{- block.settings.logo_1_img | image_url: width: 180 | image_tag: loading: 'lazy', alt: '' -}}</a>{%- endif -%}
                {%- if block.settings.logo_2_img != blank -%}<a href="{{ block.settings.logo_2_url | default: '#' }}" class="nb-logo-item">{{- block.settings.logo_2_img | image_url: width: 180 | image_tag: loading: 'lazy', alt: '' -}}</a>{%- endif -%}
                {%- if block.settings.logo_3_img != blank -%}<a href="{{ block.settings.logo_3_url | default: '#' }}" class="nb-logo-item">{{- block.settings.logo_3_img | image_url: width: 180 | image_tag: loading: 'lazy', alt: '' -}}</a>{%- endif -%}
                {%- if block.settings.logo_4_img != blank -%}<a href="{{ block.settings.logo_4_url | default: '#' }}" class="nb-logo-item">{{- block.settings.logo_4_img | image_url: width: 180 | image_tag: loading: 'lazy', alt: '' -}}</a>{%- endif -%}
                {%- if block.settings.logo_5_img != blank -%}<a href="{{ block.settings.logo_5_url | default: '#' }}" class="nb-logo-item">{{- block.settings.logo_5_img | image_url: width: 180 | image_tag: loading: 'lazy', alt: '' -}}</a>{%- endif -%}
                {%- if block.settings.logo_6_img != blank -%}<a href="{{ block.settings.logo_6_url | default: '#' }}" class="nb-logo-item">{{- block.settings.logo_6_img | image_url: width: 180 | image_tag: loading: 'lazy', alt: '' -}}</a>{%- endif -%}
              </div>
              {%- endif -%}
              <div class="nb-mega-body">
                <div class="nb-cols">

                  {%- comment -%} ── Link card zone (image + label + title + desc) ── {%- endcomment -%}
                  {%- if nb_has_link_cards -%}
                  {%- assign lc_use_2col = block.settings.lc_2col -%}
                  <div class="nb-card-zone{% unless nb_has_cols %} nb-cz-solo{% endunless %}{% if lc_use_2col %} nb-cz-2col{% if block.settings.lc_2col_divider %} nb-cz-divider{% endif %}{% endif %}">
                    {%- if block.settings.card_zone_heading != blank -%}
                      <div class="nb-card-zone-hd">{{ block.settings.card_zone_heading }}</div>
                    {%- endif -%}
                    {%- comment -%} Capture card HTML into a reusable snippet pattern via columns {%- endcomment -%}
                    {%- if lc_use_2col -%}
                      {%- comment -%} Left column: cards 1–4 {%- endcomment -%}
                      <div class="nb-cz-col">
                        {%- for lci in (1..4) -%}
                          {%- assign lc_tk = 'lc_' | append: lci | append: '_title' -%}
                          {%- assign lc_title = block.settings[lc_tk] -%}
                          {%- if lc_title != blank -%}
                            {%- assign lc_uk = 'lc_' | append: lci | append: '_url' -%}
                            {%- assign lc_dk = 'lc_' | append: lci | append: '_desc' -%}
                            {%- assign lc_ik = 'lc_' | append: lci | append: '_img' -%}
                            {%- assign lc_lk = 'lc_' | append: lci | append: '_label' -%}
                            {%- assign lc_lbck = 'lc_' | append: lci | append: '_label_bg' -%}
                            {%- assign lc_bk = '' -%}
                            {%- if lc_title contains ' [' -%}{%- assign lc_bp = lc_title | split: ' [' -%}{%- assign lc_title = lc_bp[0] -%}{%- assign lc_bk = lc_bp[1] | remove: ']' | downcase | strip -%}{%- endif -%}
                            {%- assign lc_bc = 'pop' -%}{%- assign lc_bt = lc_bk | capitalize -%}
                            {%- if lc_bk == 'hot' -%}{%- assign lc_bc = 'hot' -%}{%- assign lc_bt = 'Hot' -%}{%- endif -%}
                            {%- if lc_bk == 'new' -%}{%- assign lc_bc = 'nw' -%}{%- assign lc_bt = 'New' -%}{%- endif -%}
                            {%- if lc_bk == 'sale' -%}{%- assign lc_bc = 'sale' -%}{%- assign lc_bt = 'Sale' -%}{%- endif -%}
                            <a href="{{ block.settings[lc_uk] | default: '#' }}" class="nb-dtf-card">
                              <div class="nb-dtf-thumb">
                                {%- if block.settings[lc_ik] != blank -%}
                                  {{- block.settings[lc_ik] | image_url: width: 180 | image_tag: loading: 'lazy', alt: lc_title -}}
                                {%- else -%}
                                  <span class="nb-dtf-thumb-emoji">📦</span>
                                {%- endif -%}
                              </div>
                              <div class="nb-dtf-body">
                                {%- if block.settings[lc_lk] != blank -%}
                                  {%- assign lc_ltck = 'lc_' | append: lci | append: '_label_color' -%}
                                  <div class="nb-dtf-label" style="background:{{ block.settings[lc_lbck] | default: '#FFD600' }};color:{{ block.settings[lc_ltck] | default: '#1a1a1a' }}">{{ block.settings[lc_lk] }}</div>
                                {%- endif -%}
                                <span class="nb-dtf-title">{{- lc_title -}}{% if lc_bk != '' %}&nbsp;<span class="nb-bge {{ lc_bc }}">{{ lc_bt }}</span>{% endif %}</span>
                                {%- if block.settings[lc_dk] != blank -%}<div class="nb-dtf-desc">{{ block.settings[lc_dk] }}</div>{%- endif -%}
                              </div>
                            </a>
                          {%- endif -%}
                        {%- endfor -%}
                      </div>
                      {%- comment -%} Right column: cards 5–8 {%- endcomment -%}
                      <div class="nb-cz-col">
                        {%- for lci in (5..8) -%}
                          {%- assign lc_tk = 'lc_' | append: lci | append: '_title' -%}
                          {%- assign lc_title = block.settings[lc_tk] -%}
                          {%- if lc_title != blank -%}
                            {%- assign lc_uk = 'lc_' | append: lci | append: '_url' -%}
                            {%- assign lc_dk = 'lc_' | append: lci | append: '_desc' -%}
                            {%- assign lc_ik = 'lc_' | append: lci | append: '_img' -%}
                            {%- assign lc_lk = 'lc_' | append: lci | append: '_label' -%}
                            {%- assign lc_lbck = 'lc_' | append: lci | append: '_label_bg' -%}
                            {%- assign lc_bk = '' -%}
                            {%- if lc_title contains ' [' -%}{%- assign lc_bp = lc_title | split: ' [' -%}{%- assign lc_title = lc_bp[0] -%}{%- assign lc_bk = lc_bp[1] | remove: ']' | downcase | strip -%}{%- endif -%}
                            {%- assign lc_bc = 'pop' -%}{%- assign lc_bt = lc_bk | capitalize -%}
                            {%- if lc_bk == 'hot' -%}{%- assign lc_bc = 'hot' -%}{%- assign lc_bt = 'Hot' -%}{%- endif -%}
                            {%- if lc_bk == 'new' -%}{%- assign lc_bc = 'nw' -%}{%- assign lc_bt = 'New' -%}{%- endif -%}
                            {%- if lc_bk == 'sale' -%}{%- assign lc_bc = 'sale' -%}{%- assign lc_bt = 'Sale' -%}{%- endif -%}
                            <a href="{{ block.settings[lc_uk] | default: '#' }}" class="nb-dtf-card">
                              <div class="nb-dtf-thumb">
                                {%- if block.settings[lc_ik] != blank -%}
                                  {{- block.settings[lc_ik] | image_url: width: 180 | image_tag: loading: 'lazy', alt: lc_title -}}
                                {%- else -%}
                                  <span class="nb-dtf-thumb-emoji">📦</span>
                                {%- endif -%}
                              </div>
                              <div class="nb-dtf-body">
                                {%- if block.settings[lc_lk] != blank -%}
                                  {%- assign lc_ltck = 'lc_' | append: lci | append: '_label_color' -%}
                                  <div class="nb-dtf-label" style="background:{{ block.settings[lc_lbck] | default: '#FFD600' }};color:{{ block.settings[lc_ltck] | default: '#1a1a1a' }}">{{ block.settings[lc_lk] }}</div>
                                {%- endif -%}
                                <span class="nb-dtf-title">{{- lc_title -}}{% if lc_bk != '' %}&nbsp;<span class="nb-bge {{ lc_bc }}">{{ lc_bt }}</span>{% endif %}</span>
                                {%- if block.settings[lc_dk] != blank -%}<div class="nb-dtf-desc">{{ block.settings[lc_dk] }}</div>{%- endif -%}
                              </div>
                            </a>
                          {%- endif -%}
                        {%- endfor -%}
                      </div>
                    {%- else -%}
                      {%- comment -%} Single column (default) {%- endcomment -%}
                      {%- for lci in (1..8) -%}
                        {%- assign lc_tk = 'lc_' | append: lci | append: '_title' -%}
                        {%- assign lc_title = block.settings[lc_tk] -%}
                        {%- if lc_title != blank -%}
                          {%- assign lc_uk = 'lc_' | append: lci | append: '_url' -%}
                          {%- assign lc_dk = 'lc_' | append: lci | append: '_desc' -%}
                          {%- assign lc_ik = 'lc_' | append: lci | append: '_img' -%}
                          {%- assign lc_lk = 'lc_' | append: lci | append: '_label' -%}
                          {%- assign lc_lbck = 'lc_' | append: lci | append: '_label_bg' -%}
                          {%- assign lc_bk = '' -%}
                          {%- if lc_title contains ' [' -%}{%- assign lc_bp = lc_title | split: ' [' -%}{%- assign lc_title = lc_bp[0] -%}{%- assign lc_bk = lc_bp[1] | remove: ']' | downcase | strip -%}{%- endif -%}
                          {%- assign lc_bc = 'pop' -%}{%- assign lc_bt = lc_bk | capitalize -%}
                          {%- if lc_bk == 'hot' -%}{%- assign lc_bc = 'hot' -%}{%- assign lc_bt = 'Hot' -%}{%- endif -%}
                          {%- if lc_bk == 'new' -%}{%- assign lc_bc = 'nw' -%}{%- assign lc_bt = 'New' -%}{%- endif -%}
                          {%- if lc_bk == 'sale' -%}{%- assign lc_bc = 'sale' -%}{%- assign lc_bt = 'Sale' -%}{%- endif -%}
                          <a href="{{ block.settings[lc_uk] | default: '#' }}" class="nb-dtf-card">
                            <div class="nb-dtf-thumb">
                              {%- if block.settings[lc_ik] != blank -%}
                                {{- block.settings[lc_ik] | image_url: width: 180 | image_tag: loading: 'lazy', alt: lc_title -}}
                              {%- else -%}
                                <span class="nb-dtf-thumb-emoji">📦</span>
                              {%- endif -%}
                            </div>
                            <div class="nb-dtf-body">
                              {%- if block.settings[lc_lk] != blank -%}
                                {%- assign lc_ltck = 'lc_' | append: lci | append: '_label_color' -%}
                                <div class="nb-dtf-label" style="background:{{ block.settings[lc_lbck] | default: '#FFD600' }};color:{{ block.settings[lc_ltck] | default: '#1a1a1a' }}">{{ block.settings[lc_lk] }}</div>
                              {%- endif -%}
                              <span class="nb-dtf-title">{{- lc_title -}}{% if lc_bk != '' %}&nbsp;<span class="nb-bge {{ lc_bc }}">{{ lc_bt }}</span>{% endif %}</span>
                              {%- if block.settings[lc_dk] != blank -%}
                                <div class="nb-dtf-desc">{{ block.settings[lc_dk] }}</div>
                              {%- endif -%}
                            </div>
                          </a>
                        {%- endif -%}
                      {%- endfor -%}
                    {%- endif -%}{%- comment -%}/lc_use_2col{%- endcomment -%}
                  </div>
                  {%- endif -%}

                  {%- comment -%} ── Top-level menu mode: each top-level link = column header, children = items ── {%- endcomment -%}
                  {%- if nb_use_tlm -%}
                    {%- for tl_link in nb_tlm.links -%}
                      {%- if tl_link.links.size > 0 -%}
                      <div class="nb-col">
                        <div class="nb-col-hd"><a href="{{ tl_link.url }}" style="color:inherit;text-decoration:none;">{{ tl_link.title }}</a></div>
                        <ul>
                          {%- for link in tl_link.links -%}
                            {%- assign rt = link.title -%}{%- assign bk = '' -%}
                            {%- if rt contains ' [' -%}{%- assign bp = rt | split: ' [' -%}{%- assign rt = bp[0] -%}{%- assign bk = bp[1] | remove: ']' | downcase | strip -%}{%- endif -%}
                            <li><a href="{{ link.url }}">{{- rt -}}
                              {%- if bk != '' -%}{%- assign bc = 'pop' -%}{%- assign bt = bk | capitalize -%}
                                {%- if bk == 'hot' -%}{%- assign bc = 'hot' -%}{%- assign bt = 'Hot' -%}{%- endif -%}
                                {%- if bk == 'new' -%}{%- assign bc = 'nw' -%}{%- assign bt = 'New' -%}{%- endif -%}
                                {%- if bk == 'top seller' -%}{%- assign bc = 'pop' -%}{%- assign bt = 'Top Seller' -%}{%- endif -%}
                                {%- if bk == 'sale' -%}{%- assign bc = 'sale' -%}{%- assign bt = 'Sale' -%}{%- endif -%}
                                <span class="nb-bge {{ bc }}">{{ bt }}</span>{%- endif -%}
                            </a></li>
                          {%- endfor -%}
                        </ul>
                      </div>
                      {%- endif -%}
                    {%- endfor -%}
                  {%- else -%}

                  {%- if nb_c1.links.size > 0 -%}
                  <div class="nb-col">
                    {%- if block.settings.col1_heading != blank -%}<div class="nb-col-hd">{{ block.settings.col1_heading }}</div>{%- endif -%}
                    <ul>
                      {%- for link in nb_c1.links -%}
                        {%- assign rt = link.title -%}{%- assign bk = '' -%}
                        {%- if rt contains ' [' -%}{%- assign bp = rt | split: ' [' -%}{%- assign rt = bp[0] -%}{%- assign bk = bp[1] | remove: ']' | downcase | strip -%}{%- endif -%}
                        <li><a href="{{ link.url }}">{{- rt -}}
                          {%- if bk != '' -%}{%- assign bc = 'pop' -%}{%- assign bt = bk | capitalize -%}
                            {%- if bk == 'hot' -%}{%- assign bc = 'hot' -%}{%- assign bt = 'Hot' -%}{%- endif -%}
                            {%- if bk == 'new' -%}{%- assign bc = 'nw' -%}{%- assign bt = 'New' -%}{%- endif -%}
                            {%- if bk == 'top seller' -%}{%- assign bc = 'pop' -%}{%- assign bt = 'Top Seller' -%}{%- endif -%}
                            {%- if bk == 'sale' -%}{%- assign bc = 'sale' -%}{%- assign bt = 'Sale' -%}{%- endif -%}
                            <span class="nb-bge {{ bc }}">{{ bt }}</span>{%- endif -%}
                        </a></li>
                      {%- endfor -%}
                    </ul>
                  </div>
                  {%- endif -%}

                  {%- if nb_c2.links.size > 0 -%}
                  <div class="nb-col">
                    {%- if block.settings.col2_heading != blank -%}<div class="nb-col-hd">{{ block.settings.col2_heading }}</div>{%- endif -%}
                    <ul>
                      {%- for link in nb_c2.links -%}
                        {%- assign rt = link.title -%}{%- assign bk = '' -%}
                        {%- if rt contains ' [' -%}{%- assign bp = rt | split: ' [' -%}{%- assign rt = bp[0] -%}{%- assign bk = bp[1] | remove: ']' | downcase | strip -%}{%- endif -%}
                        <li><a href="{{ link.url }}">{{- rt -}}
                          {%- if bk != '' -%}{%- assign bc = 'pop' -%}{%- assign bt = bk | capitalize -%}
                            {%- if bk == 'hot' -%}{%- assign bc = 'hot' -%}{%- assign bt = 'Hot' -%}{%- endif -%}
                            {%- if bk == 'new' -%}{%- assign bc = 'nw' -%}{%- assign bt = 'New' -%}{%- endif -%}
                            {%- if bk == 'top seller' -%}{%- assign bc = 'pop' -%}{%- assign bt = 'Top Seller' -%}{%- endif -%}
                            {%- if bk == 'sale' -%}{%- assign bc = 'sale' -%}{%- assign bt = 'Sale' -%}{%- endif -%}
                            <span class="nb-bge {{ bc }}">{{ bt }}</span>{%- endif -%}
                        </a></li>
                      {%- endfor -%}
                    </ul>
                  </div>
                  {%- endif -%}

                  {%- if nb_c3.links.size > 0 -%}
                  <div class="nb-col">
                    {%- if block.settings.col3_heading != blank -%}<div class="nb-col-hd">{{ block.settings.col3_heading }}</div>{%- endif -%}
                    <ul>
                      {%- for link in nb_c3.links -%}
                        {%- assign rt = link.title -%}{%- assign bk = '' -%}
                        {%- if rt contains ' [' -%}{%- assign bp = rt | split: ' [' -%}{%- assign rt = bp[0] -%}{%- assign bk = bp[1] | remove: ']' | downcase | strip -%}{%- endif -%}
                        <li><a href="{{ link.url }}">{{- rt -}}
                          {%- if bk != '' -%}{%- assign bc = 'pop' -%}{%- assign bt = bk | capitalize -%}
                            {%- if bk == 'hot' -%}{%- assign bc = 'hot' -%}{%- assign bt = 'Hot' -%}{%- endif -%}
                            {%- if bk == 'new' -%}{%- assign bc = 'nw' -%}{%- assign bt = 'New' -%}{%- endif -%}
                            {%- if bk == 'top seller' -%}{%- assign bc = 'pop' -%}{%- assign bt = 'Top Seller' -%}{%- endif -%}
                            {%- if bk == 'sale' -%}{%- assign bc = 'sale' -%}{%- assign bt = 'Sale' -%}{%- endif -%}
                            <span class="nb-bge {{ bc }}">{{ bt }}</span>{%- endif -%}
                        </a></li>
                      {%- endfor -%}
                    </ul>
                  </div>
                  {%- endif -%}

                  {%- if nb_c4.links.size > 0 -%}
                  <div class="nb-col">
                    {%- if block.settings.col4_heading != blank -%}<div class="nb-col-hd">{{ block.settings.col4_heading }}</div>{%- endif -%}
                    <ul>
                      {%- for link in nb_c4.links -%}
                        {%- assign rt = link.title -%}{%- assign bk = '' -%}
                        {%- if rt contains ' [' -%}{%- assign bp = rt | split: ' [' -%}{%- assign rt = bp[0] -%}{%- assign bk = bp[1] | remove: ']' | downcase | strip -%}{%- endif -%}
                        <li><a href="{{ link.url }}">{{- rt -}}
                          {%- if bk != '' -%}{%- assign bc = 'pop' -%}{%- assign bt = bk | capitalize -%}
                            {%- if bk == 'hot' -%}{%- assign bc = 'hot' -%}{%- assign bt = 'Hot' -%}{%- endif -%}
                            {%- if bk == 'new' -%}{%- assign bc = 'nw' -%}{%- assign bt = 'New' -%}{%- endif -%}
                            {%- if bk == 'top seller' -%}{%- assign bc = 'pop' -%}{%- assign bt = 'Top Seller' -%}{%- endif -%}
                            {%- if bk == 'sale' -%}{%- assign bc = 'sale' -%}{%- assign bt = 'Sale' -%}{%- endif -%}
                            <span class="nb-bge {{ bc }}">{{ bt }}</span>{%- endif -%}
                        </a></li>
                      {%- endfor -%}
                    </ul>
                  </div>
                  {%- endif -%}

                  {%- if nb_c5.links.size > 0 -%}
                  <div class="nb-col">
                    {%- if block.settings.col5_heading != blank -%}<div class="nb-col-hd">{{ block.settings.col5_heading }}</div>{%- endif -%}
                    <ul>
                      {%- for link in nb_c5.links -%}
                        {%- assign rt = link.title -%}{%- assign bk = '' -%}
                        {%- if rt contains ' [' -%}{%- assign bp = rt | split: ' [' -%}{%- assign rt = bp[0] -%}{%- assign bk = bp[1] | remove: ']' | downcase | strip -%}{%- endif -%}
                        <li><a href="{{ link.url }}">{{- rt -}}
                          {%- if bk != '' -%}{%- assign bc = 'pop' -%}{%- assign bt = bk | capitalize -%}
                            {%- if bk == 'hot' -%}{%- assign bc = 'hot' -%}{%- assign bt = 'Hot' -%}{%- endif -%}
                            {%- if bk == 'new' -%}{%- assign bc = 'nw' -%}{%- assign bt = 'New' -%}{%- endif -%}
                            {%- if bk == 'top seller' -%}{%- assign bc = 'pop' -%}{%- assign bt = 'Top Seller' -%}{%- endif -%}
                            {%- if bk == 'sale' -%}{%- assign bc = 'sale' -%}{%- assign bt = 'Sale' -%}{%- endif -%}
                            <span class="nb-bge {{ bc }}">{{ bt }}</span>{%- endif -%}
                        </a></li>
                      {%- endfor -%}
                    </ul>
                  </div>
                  {%- endif -%}

                  {%- endif -%}{%- comment -%}/nb_use_tlm{%- endcomment -%}

                  {%- if block.settings.featured_product != blank -%}
                    {%- assign fp = all_products[block.settings.featured_product] -%}
                    <div class="nb-feat">
                      <div class="nb-feat-lbl">{{ block.settings.featured_label | default: 'Best Seller' }}</div>
                      <div class="nb-feat-box">
                        <a href="{{ fp.url }}" class="nb-feat-card">
                          <div class="nb-feat-img">
                            {%- if fp.featured_image -%}
                              <img src="{{ fp.featured_image | image_url: width: 300 }}" alt="{{ fp.featured_image.alt | escape }}" loading="lazy">
                            {%- else -%}
                              <span class="nb-emoji-fallback">{{ block.settings.featured_emoji | default: '👕' }}</span>
                            {%- endif -%}
                          </div>
                          <div class="nb-feat-info">
                            <div class="nb-feat-brand">{{ fp.vendor }}</div>
                            <div class="nb-feat-name">{{ block.settings.featured_display_title | default: fp.title }}</div>
                            <div class="nb-feat-price">From {{ fp.price_min | money }} / unit</div>
                          </div>
                        </a>
                        {%- if block.settings.usp1 != blank or block.settings.usp2 != blank or block.settings.usp3 != blank -%}
                          <div class="nb-usps">
                            {%- if block.settings.usp1 != blank -%}<div class="nb-usp">{{ block.settings.usp1 }}</div>{%- endif -%}
                            {%- if block.settings.usp2 != blank -%}<div class="nb-usp">{{ block.settings.usp2 }}</div>{%- endif -%}
                            {%- if block.settings.usp3 != blank -%}<div class="nb-usp">{{ block.settings.usp3 }}</div>{%- endif -%}
                          </div>
                        {%- endif -%}
                      </div>
                    </div>
                  {%- endif -%}

                </div><!-- /nb-cols -->
              </div><!-- /nb-mega-body -->

              {%- comment -%} Standalone shop all row — only shown when footer bar is off {%- endcomment -%}
              {%- if block.settings.show_shop_all != false and block.settings.show_footer_bar == false -%}
              <div class="nb-shop-all-row">
                <a href="{{ block.settings.nav_url | default: '#' }}" class="nb-shop-all-btn" style="background:{{ block.settings.shop_all_btn_color | default: '#FFD600' }};color:#fff;">{%- if block.settings.shop_all_text != blank -%}{{ block.settings.shop_all_text }}{%- else -%}Shop All {{ block.settings.nav_label }}{%- endif -%} →</a>
              </div>
              {%- endif -%}

              {%- if block.settings.show_footer_bar != false -%}
              <div class="nb-mega-foot" style="background:{{ section.settings.foot_bg_color | default: '#2a2a2a' }};">
                <div class="nb-foot-left">
                  <div class="nb-foot-ship-icon" style="color:{{ section.settings.foot_icon_color | default: '#ffffff' }};">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 3h13v13H1V3z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M14 8h4l3 4v4h-7V8z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><circle cx="5.5" cy="18.5" r="1.5" stroke="currentColor" stroke-width="1.8"/><circle cx="18.5" cy="18.5" r="1.5" stroke="currentColor" stroke-width="1.8"/></svg>
                  </div>
                  <div class="nb-foot-ship-text">
                    <span class="nb-foot-ship-title" style="color:{{ section.settings.foot_title_color | default: '#ffffff' }};">{{ section.settings.foot_ship_bold | default: 'Free Shipping' }}</span>
                    <span class="nb-foot-ship-sub" style="color:{{ section.settings.foot_sub_color | default: '#aaaaaa' }};">{{ section.settings.foot_ship_prefix }}{{ section.settings.foot_ship_suffix | default: 'on blank apparel orders $50+' }}</span>
                  </div>
                </div>
                {%- comment -%} Right side: promo text + optional shop all CTA {%- endcomment -%}
                {%- if block.settings.promo_text != blank or block.settings.show_shop_all != false -%}
                <div class="nb-foot-right">
                {%- if block.settings.promo_text != blank -%}
                {%- assign nb_promo_icon = block.settings.promo_icon | default: 'truck' -%}
                <div class="nb-foot-promo">
                  {%- unless nb_promo_icon == 'none' -%}
                  <div class="nb-foot-promo-icon" style="color:{{ section.settings.foot_icon_color | default: '#ffffff' }};">
                    {%- if nb_promo_icon == 'truck' -%}
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 3h13v13H1V3z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M14 8h4l3 4v4h-7V8z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><circle cx="5.5" cy="18.5" r="1.5" stroke="currentColor" stroke-width="1.8"/><circle cx="18.5" cy="18.5" r="1.5" stroke="currentColor" stroke-width="1.8"/></svg>
                    {%- elsif nb_promo_icon == 'tag' -%}
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12.586 2H7a2 2 0 00-2 2v5.586a1 1 0 00.293.707l9 9a1 1 0 001.414 0l5.586-5.586a1 1 0 000-1.414l-9-9A1 1 0 0012.586 2z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><circle cx="9" cy="9" r="1.5" fill="currentColor"/></svg>
                    {%- elsif nb_promo_icon == 'lightning' -%}
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M13 2L4.5 13.5H12L11 22L19.5 10.5H12L13 2z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
                    {%- elsif nb_promo_icon == 'box' -%}
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M3.27 6.96L12 12.01l8.73-5.05M12 22.08V12" stroke="currentColor" stroke-width="1.8"/></svg>
                    {%- elsif nb_promo_icon == 'check' -%}
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.8"/><path d="M8 12l3 3 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    {%- elsif nb_promo_icon == 'fire' -%}
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2c0 0-6 5-6 11a6 6 0 0012 0c0-6-6-11-6-11z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M12 12c0 0-2.5 2-2.5 4a2.5 2.5 0 005 0c0-2-2.5-4-2.5-4z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
                    {%- elsif nb_promo_icon == 'star' -%}
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
                    {%- elsif nb_promo_icon == 'target' -%}
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="12" r="6" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="12" r="2" fill="currentColor"/></svg>
                    {%- endif -%}
                  </div>
                  {%- endunless -%}
                  <span class="nb-foot-promo-text" style="color:{{ section.settings.foot_title_color | default: '#ffffff' }};">{{ block.settings.promo_text }}</span>
                </div>
                {%- endif -%}
                {%- if block.settings.show_shop_all != false -%}
                <a href="{{ block.settings.nav_url | default: '#' }}" class="nb-shop-all-btn nb-foot-cta" style="background:{{ block.settings.shop_all_btn_color | default: '#FFD600' }};color:#fff;">{%- if block.settings.shop_all_text != blank -%}{{ block.settings.shop_all_text }}{%- else -%}Shop All {{ block.settings.nav_label }}{%- endif -%} →</a>
                {%- endif -%}
                </div><!-- /nb-foot-right -->
                {%- endif -%}
              </div>
              {%- endif -%}

            </div><!-- /nb-mega -->
            {%- endif -%}
          </div><!-- /nb-nav-item -->

        {%- elsif block.type == 'tab_panel' -%}
          {%- assign tp_is_current = false -%}
          {%- if block.settings.nav_url != blank and request.path contains block.settings.nav_url -%}
            {%- assign tp_is_current = true -%}
          {%- endif -%}
          <div class="nb-nav-item{% if tp_is_current %} current{% endif %}">
            <a href="{{ block.settings.nav_url | default: '#' }}">
              {{- block.settings.nav_label | default: 'Menu' -}}
              <span class="nb-arr">▼</span>
            </a>
            <div class="nb-mega nb-tabbed" {{ block.shopify_attributes }}>
              <div class="nb-tab-bar">
                {%- assign tp_tab_first = true -%}
                {%- for tabi in (1..2) -%}
                  {%- assign tab_lk = 'tab_' | append: tabi | append: '_label' -%}
                  {%- assign tp_has_items = false -%}
                  {%- for _mi in (1..9) -%}
                    {%- assign _mtk = 'tab_' | append: tabi | append: '_title_' | append: _mi -%}
                    {%- if block.settings[_mtk] != blank -%}{%- assign tp_has_items = true -%}{%- break -%}{%- endif -%}
                  {%- endfor -%}
                  {%- if tp_has_items and block.settings[tab_lk] != blank -%}
                    <button class="nb-tab-btn{% if tp_tab_first %} nb-tab-active{% endif %}" data-tab="{{ block.id }}-tab{{ tabi }}">{{ block.settings[tab_lk] }}</button>
                    {%- assign tp_tab_first = false -%}
                  {%- endif -%}
                {%- endfor -%}
              </div>
              {%- assign tp_tab_first = true -%}
              {%- for tabi in (1..2) -%}
                {%- assign tab_has_items = false -%}
                {%- for _mi in (1..9) -%}
                  {%- assign _mtk = 'tab_' | append: tabi | append: '_title_' | append: _mi -%}
                  {%- if block.settings[_mtk] != blank -%}{%- assign tab_has_items = true -%}{%- break -%}{%- endif -%}
                {%- endfor -%}
                {%- if tab_has_items -%}
                <div class="nb-tab-panel{% if tp_tab_first %} nb-tab-active{% endif %}" data-tab="{{ block.id }}-tab{{ tabi }}">
                  {%- assign tp_tab_first = false -%}
                  <div class="nb-tab-cards-area">
                  {%- for mi in (1..9) -%}
                    {%- assign tab_title_k = 'tab_' | append: tabi | append: '_title_' | append: mi -%}
                    {%- assign tab_url_k   = 'tab_' | append: tabi | append: '_url_'   | append: mi -%}
                    {%- assign tab_item_img_k = 'tab_' | append: tabi | append: '_img_' | append: mi -%}
                    {%- assign tab_item_lbl_k = 'tab_' | append: tabi | append: '_lbl_' | append: mi -%}
                    {%- assign tab_lbg_k = 'tab_' | append: tabi | append: '_lbl_bg_' | append: mi -%}
                    {%- assign tab_ltc_k = 'tab_' | append: tabi | append: '_lbl_color_' | append: mi -%}
                    {%- if block.settings[tab_title_k] != blank -%}
                    <a href="{{ block.settings[tab_url_k] | default: '#' }}" class="nb-tab-card">
                      <div class="nb-tab-card-img">
                        {%- if block.settings[tab_item_img_k] != blank -%}
                          {{- block.settings[tab_item_img_k] | image_url: width: 200 | image_tag: loading: 'lazy', alt: block.settings[tab_title_k] -}}
                        {%- endif -%}
                      </div>
                      <div class="nb-tab-card-body">
                        {%- if block.settings[tab_item_lbl_k] != blank -%}
                          <div class="nb-tab-card-label" style="background:{{ block.settings[tab_lbg_k] | default: '#FFD600' }};color:{{ block.settings[tab_ltc_k] | default: '#1a1a1a' }}">{{ block.settings[tab_item_lbl_k] }}</div>
                        {%- endif -%}
                        <div class="nb-tab-card-title">{{ block.settings[tab_title_k] }}</div>
                        {%- assign tab_sub_k = 'tab_' | append: tabi | append: '_sub_' | append: mi -%}
                        {%- if block.settings[tab_sub_k] != blank -%}<div class="nb-tab-card-sub">{{ block.settings[tab_sub_k] }}</div>{%- endif -%}
                      </div>
                    </a>
                    {%- endif -%}
                  {%- endfor -%}
                  </div>
                  {%- comment -%} Promo bar footer {%- endcomment -%}
                  {%- assign tp_promo_k  = 'tab_' | append: tabi | append: '_promo_text' -%}
                  {%- assign tp_icon_k   = 'tab_' | append: tabi | append: '_promo_icon' -%}
                  {%- assign tp_sa_txt_k = 'tab_' | append: tabi | append: '_shop_all_text' -%}
                  {%- assign tp_sa_url_k = 'tab_' | append: tabi | append: '_shop_all_url' -%}
                  {%- if block.settings[tp_promo_k] != blank or block.settings[tp_sa_txt_k] != blank -%}
                  <div class="nb-mega-foot" style="background:{{ section.settings.foot_bg_color | default: '#2a2a2a' }};border-radius:0 0 10px 10px;">
                    {%- if block.settings[tp_promo_k] != blank -%}
                      {%- assign tp_icon = block.settings[tp_icon_k] | default: 'lightning' -%}
                      <div class="nb-foot-promo">
                        {%- unless tp_icon == 'none' -%}
                        <div class="nb-foot-promo-icon" style="color:{{ section.settings.foot_icon_color | default: '#ffffff' }};">
                          {%- if tp_icon == 'truck' -%}<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M1 3h13v13H1V3z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M14 8h4l3 4v4h-7V8z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><circle cx="5.5" cy="18.5" r="1.5" stroke="currentColor" stroke-width="1.8"/><circle cx="18.5" cy="18.5" r="1.5" stroke="currentColor" stroke-width="1.8"/></svg>
                          {%- elsif tp_icon == 'tag' -%}<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12.586 2H7a2 2 0 00-2 2v5.586a1 1 0 00.293.707l9 9a1 1 0 001.414 0l5.586-5.586a1 1 0 000-1.414l-9-9A1 1 0 0012.586 2z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><circle cx="9" cy="9" r="1.5" fill="currentColor"/></svg>
                          {%- elsif tp_icon == 'lightning' -%}<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M13 2L4.5 13.5H12L11 22L19.5 10.5H12L13 2z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
                          {%- elsif tp_icon == 'box' -%}<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M3.27 6.96L12 12.01l8.73-5.05M12 22.08V12" stroke="currentColor" stroke-width="1.8"/></svg>
                          {%- elsif tp_icon == 'check' -%}<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.8"/><path d="M8 12l3 3 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                          {%- elsif tp_icon == 'fire' -%}<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 2c0 0-6 5-6 11a6 6 0 0012 0c0-6-6-11-6-11z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M12 12c0 0-2.5 2-2.5 4a2.5 2.5 0 005 0c0-2-2.5-4-2.5-4z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
                          {%- elsif tp_icon == 'star' -%}<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
                          {%- elsif tp_icon == 'target' -%}<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="12" r="6" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="12" r="2" fill="currentColor"/></svg>
                          {%- endif -%}
                        </div>
                        {%- endunless -%}
                        <span class="nb-foot-promo-text" style="color:{{ section.settings.foot_title_color | default: '#ffffff' }};">{{ block.settings[tp_promo_k] }}</span>
                      </div>
                    {%- endif -%}
                    {%- if block.settings[tp_sa_txt_k] != blank -%}
                      <a href="{{ block.settings[tp_sa_url_k] | default: '#' }}" class="nb-shop-all-btn nb-foot-cta" style="background:{{ block.settings.shop_all_btn_color | default: '#FFD600' }};color:#fff;">{{ block.settings[tp_sa_txt_k] }} →</a>
                    {%- endif -%}
                  </div>
                  {%- endif -%}
                </div>
                {%- endif -%}
              {%- endfor -%}
            </div><!-- /nb-mega tab_panel -->
          </div><!-- /nb-nav-item tab_panel -->

        {%- elsif block.type == 'tab_panel_4' -%}
          {%- assign tp_is_current = false -%}
          {%- if block.settings.nav_url != blank and request.path contains block.settings.nav_url -%}
            {%- assign tp_is_current = true -%}
          {%- endif -%}
          <div class="nb-nav-item{% if tp_is_current %} current{% endif %}">
            <a href="{{ block.settings.nav_url | default: '#' }}">
              {{- block.settings.nav_label | default: 'Menu' -}}
              <span class="nb-arr">▼</span>
            </a>
            <div class="nb-mega nb-tabbed nb-tabbed-4" {{ block.shopify_attributes }}>
              <div class="nb-tab-bar">
                {%- assign tp_tab_first = true -%}
                {%- for tabi in (1..4) -%}
                  {%- assign tab_lk = 'tab_' | append: tabi | append: '_label' -%}
                  {%- assign tp_has_items = false -%}
                  {%- for _mi in (1..9) -%}
                    {%- assign _mtk = 'tab_' | append: tabi | append: '_title_' | append: _mi -%}
                    {%- if block.settings[_mtk] != blank -%}{%- assign tp_has_items = true -%}{%- break -%}{%- endif -%}
                  {%- endfor -%}
                  {%- if tp_has_items and block.settings[tab_lk] != blank -%}
                    <button class="nb-tab-btn{% if tp_tab_first %} nb-tab-active{% endif %}" data-tab="{{ block.id }}-tab{{ tabi }}">{{ block.settings[tab_lk] }}</button>
                    {%- assign tp_tab_first = false -%}
                  {%- endif -%}
                {%- endfor -%}
              </div>
              {%- assign tp_tab_first = true -%}
              {%- for tabi in (1..4) -%}
                {%- assign tab_has_items = false -%}
                {%- for _mi in (1..9) -%}
                  {%- assign _mtk = 'tab_' | append: tabi | append: '_title_' | append: _mi -%}
                  {%- if block.settings[_mtk] != blank -%}{%- assign tab_has_items = true -%}{%- break -%}{%- endif -%}
                {%- endfor -%}
                {%- if tab_has_items -%}
                <div class="nb-tab-panel{% if tp_tab_first %} nb-tab-active{% endif %}" data-tab="{{ block.id }}-tab{{ tabi }}">
                  {%- assign tp_tab_first = false -%}
                  <div class="nb-tab-cards-area">
                  {%- for mi in (1..9) -%}
                    {%- assign tab_title_k = 'tab_' | append: tabi | append: '_title_' | append: mi -%}
                    {%- assign tab_url_k   = 'tab_' | append: tabi | append: '_url_'   | append: mi -%}
                    {%- assign tab_item_img_k = 'tab_' | append: tabi | append: '_img_' | append: mi -%}
                    {%- assign tab_item_lbl_k = 'tab_' | append: tabi | append: '_lbl_' | append: mi -%}
                    {%- assign tab_lbg_k = 'tab_' | append: tabi | append: '_lbl_bg_' | append: mi -%}
                    {%- assign tab_ltc_k = 'tab_' | append: tabi | append: '_lbl_color_' | append: mi -%}
                    {%- if block.settings[tab_title_k] != blank -%}
                    <a href="{{ block.settings[tab_url_k] | default: '#' }}" class="nb-tab-card">
                      <div class="nb-tab-card-img">
                        {%- if block.settings[tab_item_img_k] != blank -%}
                          {{- block.settings[tab_item_img_k] | image_url: width: 200 | image_tag: loading: 'lazy', alt: block.settings[tab_title_k] -}}
                        {%- endif -%}
                      </div>
                      <div class="nb-tab-card-body">
                        {%- if block.settings[tab_item_lbl_k] != blank -%}
                          <div class="nb-tab-card-label" style="background:{{ block.settings[tab_lbg_k] | default: '#FFD600' }};color:{{ block.settings[tab_ltc_k] | default: '#1a1a1a' }}">{{ block.settings[tab_item_lbl_k] }}</div>
                        {%- endif -%}
                        <div class="nb-tab-card-title">{{ block.settings[tab_title_k] }}</div>
                        {%- assign tab_sub_k = 'tab_' | append: tabi | append: '_sub_' | append: mi -%}
                        {%- if block.settings[tab_sub_k] != blank -%}<div class="nb-tab-card-sub">{{ block.settings[tab_sub_k] }}</div>{%- endif -%}
                      </div>
                    </a>
                    {%- endif -%}
                  {%- endfor -%}
                  </div>
                  {%- comment -%} Promo bar footer {%- endcomment -%}
                  {%- assign tp_promo_k  = 'tab_' | append: tabi | append: '_promo_text' -%}
                  {%- assign tp_icon_k   = 'tab_' | append: tabi | append: '_promo_icon' -%}
                  {%- assign tp_sa_txt_k = 'tab_' | append: tabi | append: '_shop_all_text' -%}
                  {%- assign tp_sa_url_k = 'tab_' | append: tabi | append: '_shop_all_url' -%}
                  {%- if block.settings[tp_promo_k] != blank or block.settings[tp_sa_txt_k] != blank -%}
                  <div class="nb-mega-foot" style="background:{{ section.settings.foot_bg_color | default: '#2a2a2a' }};border-radius:0 0 10px 10px;">
                    {%- if block.settings[tp_promo_k] != blank -%}
                      {%- assign tp_icon = block.settings[tp_icon_k] | default: 'lightning' -%}
                      <div class="nb-foot-promo">
                        {%- unless tp_icon == 'none' -%}
                        <div class="nb-foot-promo-icon" style="color:{{ section.settings.foot_icon_color | default: '#ffffff' }};">
                          {%- if tp_icon == 'truck' -%}<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M1 3h13v13H1V3z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M14 8h4l3 4v4h-7V8z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><circle cx="5.5" cy="18.5" r="1.5" stroke="currentColor" stroke-width="1.8"/><circle cx="18.5" cy="18.5" r="1.5" stroke="currentColor" stroke-width="1.8"/></svg>
                          {%- elsif tp_icon == 'tag' -%}<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12.586 2H7a2 2 0 00-2 2v5.586a1 1 0 00.293.707l9 9a1 1 0 001.414 0l5.586-5.586a1 1 0 000-1.414l-9-9A1 1 0 0012.586 2z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><circle cx="9" cy="9" r="1.5" fill="currentColor"/></svg>
                          {%- elsif tp_icon == 'lightning' -%}<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M13 2L4.5 13.5H12L11 22L19.5 10.5H12L13 2z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
                          {%- elsif tp_icon == 'box' -%}<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M3.27 6.96L12 12.01l8.73-5.05M12 22.08V12" stroke="currentColor" stroke-width="1.8"/></svg>
                          {%- elsif tp_icon == 'check' -%}<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.8"/><path d="M8 12l3 3 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                          {%- elsif tp_icon == 'fire' -%}<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 2c0 0-6 5-6 11a6 6 0 0012 0c0-6-6-11-6-11z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M12 12c0 0-2.5 2-2.5 4a2.5 2.5 0 005 0c0-2-2.5-4-2.5-4z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
                          {%- elsif tp_icon == 'star' -%}<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
                          {%- elsif tp_icon == 'target' -%}<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="12" r="6" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="12" r="2" fill="currentColor"/></svg>
                          {%- endif -%}
                        </div>
                        {%- endunless -%}
                        <span class="nb-foot-promo-text" style="color:{{ section.settings.foot_title_color | default: '#ffffff' }};">{{ block.settings[tp_promo_k] }}</span>
                      </div>
                    {%- endif -%}
                    {%- if block.settings[tp_sa_txt_k] != blank -%}
                      <a href="{{ block.settings[tp_sa_url_k] | default: '#' }}" class="nb-shop-all-btn nb-foot-cta" style="background:{{ block.settings.shop_all_btn_color | default: '#FFD600' }};color:#fff;">{{ block.settings[tp_sa_txt_k] }} →</a>
                    {%- endif -%}
                  </div>
                  {%- endif -%}
                </div>
                {%- endif -%}
              {%- endfor -%}
            </div><!-- /nb-mega tab_panel_4 -->
          </div><!-- /nb-nav-item tab_panel_4 -->

        {%- endif -%}
      {%- endfor -%}

    </div>
    <div class="atomato-bell-wrap">
      <div class="atomato-bell-wrap--fake"></div>
    </div>
    {%- if section.settings.cta_text != blank -%}
      <div class="nb-nav-cta"><a href="{{ section.settings.cta_url | default: '#' }}" style="color:{{ section.settings.cta_color | default: '#111111' }};">{{ section.settings.cta_text }}</a></div>
    {%- endif -%}
  </div>
</nav>

{%- comment -%} ════ MOBILE TRIGGER BAR ════ {%- endcomment -%}
<div class="nb-mob-trigger" id="nb-mob-trigger">
  <div style="display:flex;align-items:center;gap:8px;">
    <button class="nb-mob-ham" id="nb-mob-ham" aria-label="Open menu" aria-expanded="false" aria-controls="nb-mob-drawer">
      <span></span><span></span><span></span>
    </button>
    {%- if section.settings.mob_show_logo -%}
      <a href="{{ routes.root_url }}" class="nb-mob-trigger-logo">
        <div class="nb-mob-trigger-logo-box">{{ section.settings.mob_logo_emoji | default: '🥷' }}</div>
        <div class="nb-mob-trigger-words">
          <strong>{{ section.settings.mob_logo_text | default: shop.name }}</strong>
          <span>{{ section.settings.mob_logo_subtext }}</span>
        </div>
      </a>
    {%- endif -%}
  </div>
  <div class="nb-mob-trigger-actions">
  </div>
</div>

{%- comment -%} ════ MOBILE SEARCH OVERLAY ════ {%- endcomment -%}
<div class="nb-mob-search-overlay" id="nb-mob-search-overlay" role="dialog" aria-label="Search">
  <div class="nb-mob-search-inner">
    <input type="text" placeholder="{{ section.settings.search_placeholder | default: 'Search products, brands, styles…' }}">
    <button class="nb-mob-search-close" id="nb-mob-search-close" aria-label="Close search">✕</button>
  </div>
  {%- if section.settings.search_suggestion_1 != blank -%}
    <div class="nb-mob-search-section">Trending searches</div>
    {%- for i in (1..6) -%}
      {%- assign skey = 'search_suggestion_' | append: i -%}
      {%- assign sikey = 'search_suggestion_icon_' | append: i -%}
      {%- assign sbkey = 'search_suggestion_badge_' | append: i -%}
      {%- if section.settings[skey] != blank -%}
        <div class="nb-mob-search-item">
          <span class="s-icon">{{ section.settings[sikey] | default: '🔍' }}</span>
          <span class="s-text">{{ section.settings[skey] }}</span>
          {%- if section.settings[sbkey] != blank -%}<span class="s-badge">{{ section.settings[sbkey] }}</span>{%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}
</div>

{%- comment -%} ════ MOBILE DRAWER ════ {%- endcomment -%}
<div class="nb-mob-drawer-overlay" id="nb-mob-overlay"></div>
<div class="nb-mob-drawer" id="nb-mob-drawer" role="dialog" aria-label="Navigation menu" aria-modal="true">

  <div class="nb-mob-drawer-header">
    <strong>MENU</strong>
    <button class="nb-mob-close" id="nb-mob-close" aria-label="Close menu">✕</button>
  </div>

  {%- if section.settings.rewards_text != blank -%}
    <div class="nb-mob-rewards-strip">
      <span class="rw-emoji">{{ section.settings.rewards_emoji | default: '🥷' }}</span>
      <div class="rw-text">
        <strong>{{ section.settings.rewards_label | default: 'Ninja Rewards' }}</strong>
        <span>{{ section.settings.rewards_text }}</span>
      </div>
      {%- if section.settings.rewards_btn_text != blank -%}
        <a href="{{ section.settings.rewards_btn_url | default: '#' }}" class="rw-btn">{{ section.settings.rewards_btn_text }}</a>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="nb-mob-nav-stage">
    <div class="nb-mob-panel-wrap" id="nb-panel-wrap">

      {%- comment -%} ── PANEL 1: top-level items ── {%- endcomment -%}
      <div class="nb-mob-panel" id="nb-panel-1">
        {%- for block in section.blocks -%}
          {%- if block.type == 'mega_panel' -%}
            {%- assign p1_c1 = linklists[block.settings.col1_menu] -%}
            {%- assign p1_c2 = linklists[block.settings.col2_menu] -%}
            {%- assign p1_c3 = linklists[block.settings.col3_menu] -%}
            {%- assign p1_c4 = linklists[block.settings.col4_menu] -%}
            {%- assign p1_c5 = linklists[block.settings.col5_menu] -%}
            {%- assign p1_has_sub = false -%}
            {%- if p1_c1.links.size > 0 or p1_c2.links.size > 0 or p1_c3.links.size > 0 or p1_c4.links.size > 0 or p1_c5.links.size > 0 -%}
              {%- assign p1_has_sub = true -%}
            {%- endif -%}
            {%- unless p1_has_sub -%}
              {%- for _lci in (1..8) -%}
                {%- assign _lck = 'lc_' | append: _lci | append: '_title' -%}
                {%- if block.settings[_lck] != blank -%}{%- assign p1_has_sub = true -%}{%- break -%}{%- endif -%}
              {%- endfor -%}
            {%- endunless -%}
            {%- if p1_has_sub -%}
              <div class="nb-mob-lvl1-item" role="button" tabindex="0" data-block="{{ block.id }}" data-label="{{ block.settings.nav_label | escape }}">
                <span class="nb-mob-lvl1-label">{{ block.settings.nav_label | default: 'Menu' }}</span>
                <span class="nb-mob-lvl1-chevron" aria-hidden="true">›</span>
              </div>
            {%- else -%}
              <a href="{{ block.settings.nav_url | default: '#' }}" class="nb-mob-lvl1-item">
                <span class="nb-mob-lvl1-label">{{ block.settings.nav_label | default: 'Menu' }}</span>
              </a>
            {%- endif -%}
          {%- elsif block.type == 'tab_panel' or block.type == 'tab_panel_4' -%}
            <div class="nb-mob-lvl1-item" role="button" tabindex="0" data-block="{{ block.id }}" data-label="{{ block.settings.nav_label | escape }}">
              <span class="nb-mob-lvl1-label">{{ block.settings.nav_label | default: 'Menu' }}</span>
              <span class="nb-mob-lvl1-chevron" aria-hidden="true">›</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
        {%- if section.settings.cta_text != blank -%}
          <div style="padding:14px 16px;">
            <a href="{{ section.settings.cta_url | default: '#' }}" style="display:block;text-align:center;background:{{ section.settings.cta_color | default: '#019AFF' }};color:#fff;font-size:13px;font-weight:800;padding:13px;border-radius:8px;text-decoration:none;">{{ section.settings.cta_text }}</a>
          </div>
        {%- endif -%}
      </div><!-- /nb-panel-1 -->

      {%- comment -%} ── PANEL 2: category level (column headers or flat links) ── {%- endcomment -%}
      <div class="nb-mob-panel" id="nb-panel-2">
        {%- for block in section.blocks -%}
          {%- if block.type == 'mega_panel' -%}
            {%- assign p2_c1 = linklists[block.settings.col1_menu] -%}
            {%- assign p2_c2 = linklists[block.settings.col2_menu] -%}
            {%- assign p2_c3 = linklists[block.settings.col3_menu] -%}
            {%- assign p2_c4 = linklists[block.settings.col4_menu] -%}
            {%- assign p2_c5 = linklists[block.settings.col5_menu] -%}
            {%- assign p2_has_sub = false -%}
            {%- if p2_c1.links.size > 0 or p2_c2.links.size > 0 or p2_c3.links.size > 0 or p2_c4.links.size > 0 or p2_c5.links.size > 0 -%}
              {%- assign p2_has_sub = true -%}
            {%- endif -%}
            {%- unless p2_has_sub -%}
              {%- for _lci in (1..8) -%}
                {%- assign _lck = 'lc_' | append: _lci | append: '_title' -%}
                {%- if block.settings[_lck] != blank -%}{%- assign p2_has_sub = true -%}{%- break -%}{%- endif -%}
              {%- endfor -%}
            {%- endunless -%}
            {%- if p2_has_sub -%}
            <div class="nb-mob-p2-pane" data-panel="{{ block.id }}">

              {%- comment -%} ← Back to Menu {%- endcomment -%}
              <button class="nb-mob-back-row" data-to="1">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M19 12H5M5 12l7 7M5 12l7-7" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Back
              </button>
              {%- if block.settings.nav_url != blank and block.settings.promo_text != blank -%}
              <a href="{{ block.settings.nav_url }}" class="nb-mob-showall-top">
                <span>{%- if block.settings.shop_all_text != blank -%}{{ block.settings.shop_all_text }}{%- else -%}Shop All {{ block.settings.nav_label }}{%- endif -%}</span>
                <span>→</span>
              </a>
              {%- endif -%}

              {%- comment -%} Columns: heading = tappable lvl2 row → panel 3; no heading = flat links {%- endcomment -%}
              {%- if block.settings.mob_grid -%}

                {%- comment -%} GRID MODE: logo tiles first, then all links in one unified grid {%- endcomment -%}
                {%- assign nb_mob_has_brands = false -%}
                {%- for bci in (1..16) -%}
                  {%- assign bck = 'brand_col_' | append: bci -%}
                  {%- if block.settings[bck] != blank -%}{%- assign nb_mob_has_brands = true -%}{%- break -%}{%- endif -%}
                {%- endfor -%}
                {%- if nb_mob_has_brands -%}
                <ul class="nb-mob-logo-grid">
                  {%- for bci in (1..16) -%}
                    {%- assign bck = 'brand_col_' | append: bci -%}
                    {%- assign bc = collections[block.settings[bck]] -%}
                    {%- if bc != blank and bc.featured_image != blank -%}
                    <li><a href="{{ bc.url }}">
                      {{- bc.featured_image | image_url: width: 300 | image_tag: loading: 'lazy', alt: bc.title -}}
                    </a></li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
                {%- endif -%}

                {%- unless nb_mob_has_brands -%}
                <ul class="nb-mob-brand-grid">
                  {%- for ci in (1..5) -%}
                    {%- assign ck = 'col' | append: ci | append: '_menu' -%}
                    {%- assign hk = 'col' | append: ci | append: '_heading' -%}
                    {%- assign p2_col = linklists[block.settings[ck]] -%}
                    {%- if p2_col.links.size > 0 and block.settings[hk] == blank -%}
                      {%- for link in p2_col.links -%}
                        <li><a href="{{ link.url }}">{{ link.title | split: ' [' | first }}</a></li>
                      {%- endfor -%}
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
                {%- endunless -%}

              {%- else -%}

                {%- comment -%} NORMAL MODE: per-column sections with headings / flat lists {%- endcomment -%}
                {%- if nb_use_tlm -%}
                  {%- comment -%} TLM mode: top-level links → tappable rows or flat links {%- endcomment -%}
                  {%- for tl_link in nb_tlm.links -%}
                    {%- if tl_link.links.size > 0 -%}
                      <div class="nb-mob-lvl2-item" role="button" tabindex="0" data-block="{{ block.id }}" data-col="tl{{ forloop.index }}" data-label="{{ tl_link.title | escape }}">
                        <span class="nb-mob-lvl2-label">{{ tl_link.title }}</span>
                        <span class="nb-mob-lvl2-chevron" aria-hidden="true">›</span>
                      </div>
                    {%- else -%}
                      <div class="nb-mob-acc-section nb-no-hd">
                        <ul class="nb-mob-acc-links">
                          <li><a href="{{ tl_link.url }}">{{ tl_link.title }}</a></li>
                        </ul>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                {%- else -%}
                {%- for ci in (1..5) -%}
                  {%- assign ck = 'col' | append: ci | append: '_menu' -%}
                  {%- assign hk = 'col' | append: ci | append: '_heading' -%}
                  {%- assign p2_col = linklists[block.settings[ck]] -%}
                  {%- assign p2_hd  = block.settings[hk] -%}
                  {%- if p2_col.links.size > 0 -%}
                    {%- if p2_hd != blank -%}
                      <div class="nb-mob-lvl2-item" role="button" tabindex="0" data-block="{{ block.id }}" data-col="{{ ci }}" data-label="{{ p2_hd | escape }}">
                        <span class="nb-mob-lvl2-label">{{ p2_hd }}</span>
                        <span class="nb-mob-lvl2-chevron" aria-hidden="true">›</span>
                      </div>
                    {%- else -%}
                      <div class="nb-mob-acc-section nb-no-hd">
                        <ul class="nb-mob-acc-links">
                          {%- for link in p2_col.links -%}
                            {%- assign mob_rt = link.title -%}{%- assign mob_bk = '' -%}
                            {%- if mob_rt contains ' [' -%}{%- assign mob_bp = mob_rt | split: ' [' -%}{%- assign mob_rt = mob_bp[0] -%}{%- assign mob_bk = mob_bp[1] | remove: ']' | downcase | strip -%}{%- endif -%}
                            <li><a href="{{ link.url }}">{{- mob_rt -}}
                              {%- if mob_bk != '' -%}{%- assign mob_bc = 'pop' -%}{%- assign mob_bt = mob_bk | capitalize -%}
                                {%- if mob_bk == 'hot' -%}{%- assign mob_bc = 'hot' -%}{%- assign mob_bt = 'Hot' -%}{%- endif -%}
                                {%- if mob_bk == 'new' -%}{%- assign mob_bc = 'nw' -%}{%- assign mob_bt = 'New' -%}{%- endif -%}
                                {%- if mob_bk == 'top seller' -%}{%- assign mob_bc = 'pop' -%}{%- assign mob_bt = 'Top Seller' -%}{%- endif -%}
                                {%- if mob_bk == 'sale' -%}{%- assign mob_bc = 'sale' -%}{%- assign mob_bt = 'Sale' -%}{%- endif -%}
                                <span class="nb-bge {{ mob_bc }}">{{ mob_bt }}</span>
                              {%- endif -%}
                            </a></li>
                          {%- endfor -%}
                        </ul>
                      </div>
                    {%- endif -%}
                  {%- endif -%}
                {%- endfor -%}
                {%- endif -%}{%- comment -%}/nb_use_tlm mobile p2{%- endcomment -%}

              {%- endif -%}

              {%- comment -%} Link cards — flat list on mobile {%- endcomment -%}
              {%- assign p2_has_lc = false -%}
              {%- for _lci in (1..8) -%}
                {%- assign _lck = 'lc_' | append: _lci | append: '_title' -%}
                {%- if block.settings[_lck] != blank -%}{%- assign p2_has_lc = true -%}{%- break -%}{%- endif -%}
              {%- endfor -%}
              {%- if p2_has_lc -%}
              <ul class="nb-mob-lc-list">
                {%- for lci in (1..8) -%}
                  {%- assign mob_tk = 'lc_' | append: lci | append: '_title' -%}
                  {%- assign mob_lc_title = block.settings[mob_tk] -%}
                  {%- if mob_lc_title != blank -%}
                    {%- assign mob_uk = 'lc_' | append: lci | append: '_url' -%}
                    {%- assign mob_dk = 'lc_' | append: lci | append: '_desc' -%}
                    {%- assign mob_lk = 'lc_' | append: lci | append: '_label' -%}
                    {%- assign mob_lbck = 'lc_' | append: lci | append: '_label_bg' -%}
                    {%- assign mob_ik = 'lc_' | append: lci | append: '_img' -%}
                    {%- if mob_lc_title contains ' [' -%}{%- assign mob_lc_tp = mob_lc_title | split: ' [' -%}{%- assign mob_lc_title = mob_lc_tp[0] -%}{%- endif -%}
                    <li>
                      <a href="{{ block.settings[mob_uk] | default: '#' }}">
                        <div class="nb-mob-lc-thumb">
                          {%- if block.settings[mob_ik] != blank -%}
                            {{- block.settings[mob_ik] | image_url: width: 200 | image_tag: loading: 'lazy', alt: mob_lc_title -}}
                          {%- else -%}
                            <span class="nb-mob-lc-thumb-emoji">📦</span>
                          {%- endif -%}
                        </div>
                        <div class="nb-mob-lc-body">
                          {%- if block.settings[mob_lk] != blank -%}
                            {%- assign mob_ltck = 'lc_' | append: lci | append: '_label_color' -%}
                            <span class="nb-mob-lc-label" style="background:{{ block.settings[mob_lbck] | default: '#FFD600' }};color:{{ block.settings[mob_ltck] | default: '#1a1a1a' }}">{{ block.settings[mob_lk] }}</span>
                          {%- endif -%}
                          <span class="nb-mob-lc-title">{{ mob_lc_title }}</span>
                          {%- if block.settings[mob_dk] != blank -%}<span class="nb-mob-lc-desc">{{ block.settings[mob_dk] }}</span>{%- endif -%}
                        </div>
                      </a>
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
              {%- endif -%}


            </div><!-- /nb-mob-p2-pane -->
            {%- endif -%}
          {%- elsif block.type == 'tab_panel' or block.type == 'tab_panel_4' -%}
            <div class="nb-mob-p2-pane" data-panel="{{ block.id }}">
              <button class="nb-mob-back-row" data-to="1">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M19 12H5M5 12l7 7M5 12l7-7" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Back
              </button>
              {%- assign tp4_max = 2 -%}{%- if block.type == 'tab_panel_4' -%}{%- assign tp4_max = 4 -%}{%- endif -%}
              {%- for tabi in (1..4) -%}{%- if tabi > tp4_max -%}{%- continue -%}{%- endif -%}
                {%- assign tab_lk = 'tab_' | append: tabi | append: '_label' -%}
                {%- assign mob_has_items = false -%}
                {%- for _mi in (1..9) -%}
                  {%- assign _mtk = 'tab_' | append: tabi | append: '_title_' | append: _mi -%}
                  {%- if block.settings[_mtk] != blank -%}{%- assign mob_has_items = true -%}{%- break -%}{%- endif -%}
                {%- endfor -%}
                {%- if mob_has_items and block.settings[tab_lk] != blank -%}
                  <div class="nb-mob-lvl2-item" role="button" tabindex="0" data-block="{{ block.id }}" data-col="tab{{ tabi }}" data-label="{{ block.settings[tab_lk] | escape }}">
                    <span class="nb-mob-lvl2-label">{{ block.settings[tab_lk] }}</span>
                    <span class="nb-mob-lvl2-chevron" aria-hidden="true">›</span>
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div><!-- /nb-mob-p2-pane tab_panel -->
          {%- endif -%}
        {%- endfor -%}
      </div><!-- /nb-panel-2 -->

      {%- comment -%} ── PANEL 3: link level (per column) ── {%- endcomment -%}
      <div class="nb-mob-panel" id="nb-panel-3">
        {%- for block in section.blocks -%}
          {%- if block.type == 'mega_panel' -%}
            {%- comment -%} Re-compute TLM flag for this separate block loop {%- endcomment -%}
            {%- assign p3_tlm = linklists[block.settings.top_level_menu] -%}
            {%- assign p3_use_tlm = false -%}
            {%- if block.settings.top_level_menu != blank and p3_tlm.links.size > 0 -%}
              {%- assign p3_use_tlm = true -%}
            {%- endif -%}

            {%- if p3_use_tlm -%}
              {%- comment -%} TLM panes: one per top-level link that has children {%- endcomment -%}
              {%- for tl_link in p3_tlm.links -%}
                {%- if tl_link.links.size > 0 -%}
                <div class="nb-mob-p3-pane" data-panel="{{ block.id }}-tl{{ forloop.index }}">
                  <button class="nb-mob-back-row" data-to="2" data-parent="{{ block.id }}">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M19 12H5M5 12l7 7M5 12l7-7" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    Back
                  </button>
                  <ul class="nb-mob-acc-links" style="padding:8px 16px 16px;">
                    {%- for link in tl_link.links -%}
                      {%- assign mob_rt = link.title -%}{%- assign mob_bk = '' -%}
                      {%- if mob_rt contains ' [' -%}{%- assign mob_bp = mob_rt | split: ' [' -%}{%- assign mob_rt = mob_bp[0] -%}{%- assign mob_bk = mob_bp[1] | remove: ']' | downcase | strip -%}{%- endif -%}
                      <li><a href="{{ link.url }}">{{- mob_rt -}}
                        {%- if mob_bk != '' -%}{%- assign mob_bc = 'pop' -%}{%- assign mob_bt = mob_bk | capitalize -%}
                          {%- if mob_bk == 'hot' -%}{%- assign mob_bc = 'hot' -%}{%- assign mob_bt = 'Hot' -%}{%- endif -%}
                          {%- if mob_bk == 'new' -%}{%- assign mob_bc = 'nw' -%}{%- assign mob_bt = 'New' -%}{%- endif -%}
                          {%- if mob_bk == 'top seller' -%}{%- assign mob_bc = 'pop' -%}{%- assign mob_bt = 'Top Seller' -%}{%- endif -%}
                          {%- if mob_bk == 'sale' -%}{%- assign mob_bc = 'sale' -%}{%- assign mob_bt = 'Sale' -%}{%- endif -%}
                          <span class="nb-bge {{ mob_bc }}">{{ mob_bt }}</span>
                        {%- endif -%}
                      </a></li>
                    {%- endfor -%}
                  </ul>
                </div><!-- /nb-mob-p3-pane tl -->
                {%- endif -%}
              {%- endfor -%}
            {%- else -%}
            {%- for ci in (1..5) -%}
              {%- assign ck = 'col' | append: ci | append: '_menu' -%}
              {%- assign hk = 'col' | append: ci | append: '_heading' -%}
              {%- assign p3_col = linklists[block.settings[ck]] -%}
              {%- assign p3_hd  = block.settings[hk] -%}
              {%- if p3_col.links.size > 0 and p3_hd != blank -%}
              <div class="nb-mob-p3-pane" data-panel="{{ block.id }}-{{ ci }}">

                {%- comment -%} ← Back to category {%- endcomment -%}
                <button class="nb-mob-back-row" data-to="2" data-parent="{{ block.id }}">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M19 12H5M5 12l7 7M5 12l7-7" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  Back
                </button>

                <ul class="nb-mob-acc-links" style="padding:8px 16px 16px;">
                  {%- for link in p3_col.links -%}
                    {%- assign mob_rt = link.title -%}{%- assign mob_bk = '' -%}
                    {%- if mob_rt contains ' [' -%}{%- assign mob_bp = mob_rt | split: ' [' -%}{%- assign mob_rt = mob_bp[0] -%}{%- assign mob_bk = mob_bp[1] | remove: ']' | downcase | strip -%}{%- endif -%}
                    <li><a href="{{ link.url }}">{{- mob_rt -}}
                      {%- if mob_bk != '' -%}{%- assign mob_bc = 'pop' -%}{%- assign mob_bt = mob_bk | capitalize -%}
                        {%- if mob_bk == 'hot' -%}{%- assign mob_bc = 'hot' -%}{%- assign mob_bt = 'Hot' -%}{%- endif -%}
                        {%- if mob_bk == 'new' -%}{%- assign mob_bc = 'nw' -%}{%- assign mob_bt = 'New' -%}{%- endif -%}
                        {%- if mob_bk == 'top seller' -%}{%- assign mob_bc = 'pop' -%}{%- assign mob_bt = 'Top Seller' -%}{%- endif -%}
                        {%- if mob_bk == 'sale' -%}{%- assign mob_bc = 'sale' -%}{%- assign mob_bt = 'Sale' -%}{%- endif -%}
                        <span class="nb-bge {{ mob_bc }}">{{ mob_bt }}</span>
                      {%- endif -%}
                    </a></li>
                  {%- endfor -%}
                </ul>

              </div><!-- /nb-mob-p3-pane -->
              {%- endif -%}
            {%- endfor -%}
            {%- endif -%}{%- comment -%}/p3_use_tlm{%- endcomment -%}


          {%- elsif block.type == 'tab_panel' or block.type == 'tab_panel_4' -%}
            {%- assign tp4_max = 2 -%}{%- if block.type == 'tab_panel_4' -%}{%- assign tp4_max = 4 -%}{%- endif -%}
            {%- for tabi in (1..4) -%}{%- if tabi > tp4_max -%}{%- continue -%}{%- endif -%}
              {%- assign p3_has_items = false -%}
              {%- for _mi in (1..9) -%}
                {%- assign _mtk = 'tab_' | append: tabi | append: '_title_' | append: _mi -%}
                {%- if block.settings[_mtk] != blank -%}{%- assign p3_has_items = true -%}{%- break -%}{%- endif -%}
              {%- endfor -%}
              {%- if p3_has_items -%}
              <div class="nb-mob-p3-pane" data-panel="{{ block.id }}-tab{{ tabi }}">
                <button class="nb-mob-back-row" data-to="2" data-parent="{{ block.id }}">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M19 12H5M5 12l7 7M5 12l7-7" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  Back
                </button>
                {%- assign tp_sa_txt_k = 'tab_' | append: tabi | append: '_shop_all_text' -%}
                {%- assign tp_sa_url_k = 'tab_' | append: tabi | append: '_shop_all_url' -%}
                {%- if block.settings[tp_sa_txt_k] != blank -%}
                <a href="{{ block.settings[tp_sa_url_k] | default: '#' }}" class="nb-mob-showall-top" style="color:{{ block.settings.shop_all_btn_color | default: '#FFD600' }};">
                  <span>{{ block.settings[tp_sa_txt_k] }}</span>
                  <span>→</span>
                </a>
                {%- endif -%}
                <ul class="nb-mob-img-list">
                  {%- for mi in (1..9) -%}
                    {%- assign p3_title_k = 'tab_' | append: tabi | append: '_title_' | append: mi -%}
                    {%- assign p3_url_k   = 'tab_' | append: tabi | append: '_url_'   | append: mi -%}
                    {%- assign p3_img_k   = 'tab_' | append: tabi | append: '_img_'   | append: mi -%}
                    {%- assign p3_lbl_k   = 'tab_' | append: tabi | append: '_lbl_'   | append: mi -%}
                    {%- assign p3_lbg_k   = 'tab_' | append: tabi | append: '_lbl_bg_' | append: mi -%}
                    {%- assign p3_ltc_k   = 'tab_' | append: tabi | append: '_lbl_color_' | append: mi -%}
                    {%- if block.settings[p3_title_k] != blank -%}
                    <li>
                      <a href="{{ block.settings[p3_url_k] | default: '#' }}" class="nb-mob-img-row">
                        {%- if block.settings[p3_img_k] != blank -%}
                          <div class="nb-mob-img-row-thumb">
                            {{- block.settings[p3_img_k] | image_url: width: 140 | image_tag: loading: 'lazy', alt: block.settings[p3_title_k] -}}
                          </div>
                        {%- endif -%}
                        <div class="nb-mob-img-row-body">
                          {%- if block.settings[p3_lbl_k] != blank -%}
                            <span class="nb-tab-card-label" style="background:{{ block.settings[p3_lbg_k] | default: '#FFD600' }};color:{{ block.settings[p3_ltc_k] | default: '#1a1a1a' }};align-self:flex-start;">{{ block.settings[p3_lbl_k] }}</span>
                          {%- endif -%}
                          <span class="nb-mob-img-row-title">{{ block.settings[p3_title_k] }}</span>
                        </div>
                      </a>
                    </li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              </div><!-- /nb-mob-p3-pane tab_panel -->
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        {%- endfor -%}
      </div><!-- /nb-panel-3 -->

    </div><!-- /nb-panel-wrap -->
  </div><!-- /nb-mob-nav-stage -->

  <div class="nb-mob-drawer-footer">
    {%- if section.settings.mob_brand_menu != blank -%}
      {%- assign mob_brands = linklists[section.settings.mob_brand_menu] -%}
      {%- if mob_brands.links.size > 0 -%}
        <div class="nb-mob-brand-links">
          {%- for link in mob_brands.links -%}
            <a href="{{ link.url }}" class="nb-mob-brand-link">{{ link.title }}</a>
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endif -%}
    <div class="nb-mob-footer-utils">
      {%- if section.settings.mob_phone != blank -%}
        <span class="nb-mob-phone">📞 {{ section.settings.mob_phone }}</span>
      {%- endif -%}
      {%- if customer -%}
        <a href="{{ routes.account_url }}" class="nb-mob-footer-link">My Account</a>
      {%- else -%}
        <a href="{{ routes.account_login_url }}" class="nb-mob-footer-link">Sign In</a>
      {%- endif -%}
      {%- if section.settings.foot_rewards_link != blank -%}
        <a href="{{ section.settings.foot_rewards_link }}" class="nb-mob-footer-link">Rewards</a>
      {%- endif -%}
    </div>
  </div>

</div><!-- /nb-mob-drawer -->

<script>
/* ── Slot mega nav into the theme's header__bottom container ── */
(function () {
  var hb  = document.querySelector('.header__bottom');
  var nav = document.getElementById('nb-navbar');
  if (hb && nav) {
    hb.parentNode.insertBefore(nav, hb);
    hb.style.display = 'none';
  }
}());

(function () {
  /* ── DESKTOP: position mega panels ── */
  var dOverlay = document.getElementById('nb-overlay');
  var dItems   = document.querySelectorAll('.nb-nav-item');
  var navbar   = document.getElementById('nb-navbar');

  var navInner = document.querySelector('.nb-nav-inner');

  function positionPanel(item) {
    if (!navbar) return;
    var panel = item.querySelector('.nb-mega');
    if (!panel) return;
    var top     = navbar.getBoundingClientRect().bottom + 6;
    var navRect = navInner ? navInner.getBoundingClientRect() : null;
    panel.style.visibility = 'hidden';
    panel.style.display    = 'block';
    panel.style.opacity    = '0';
    var pw    = panel.offsetWidth;
    var iRect = item.getBoundingClientRect();
    var left  = iRect.left + iRect.width / 2 - pw / 2;
    var minL  = navRect ? navRect.left  : 16;
    var maxR  = navRect ? navRect.right : document.documentElement.clientWidth - 16;
    if (left + pw > maxR) left = maxR - pw;
    if (left < minL)      left = minL;
    panel.style.top        = top + 'px';
    panel.style.left       = left + 'px';
    panel.style.right      = 'auto';
    panel.style.transform  = 'none';
    panel.style.display    = '';
    panel.style.visibility = '';
    panel.style.opacity    = '';
  }

  /* Recalculate on hover so position is always fresh (handles sticky headers) */
  dItems.forEach(function (item) {
    item.addEventListener('mouseenter', function () { positionPanel(item); });
  });

  /* Also recalculate on resize */
  window.addEventListener('resize', function () {
    dItems.forEach(function (item) { positionPanel(item); });
  });

  /* Hide dropdown immediately on scroll — force display:none so fixed panel can't linger */
  var nbScrollTimer;
  window.addEventListener('scroll', function () {
    dItems.forEach(function (item) {
      var panel = item.querySelector('.nb-mega');
      if (panel) panel.style.display = 'none';
      item.classList.remove('nb-open');
    });
    if (navbar) navbar.style.pointerEvents = 'none';
    clearTimeout(nbScrollTimer);
    nbScrollTimer = setTimeout(function () {
      dItems.forEach(function (item) {
        var panel = item.querySelector('.nb-mega');
        if (panel) panel.style.display = '';
      });
      if (navbar) navbar.style.pointerEvents = '';
    }, 300);
  }, { passive: true });

  /* ── MOBILE: drawer ── */
  var drawer     = document.getElementById('nb-mob-drawer');
  var mobOverlay = document.getElementById('nb-mob-overlay');
  var ham        = document.getElementById('nb-mob-ham');
  var closeBtn   = document.getElementById('nb-mob-close');

  function openDrawer() {
    if (!drawer) return;
    drawer.classList.add('open');
    if (mobOverlay) mobOverlay.classList.add('open');
    if (ham) { ham.classList.add('open'); ham.setAttribute('aria-expanded', 'true'); }
    document.body.style.overflow = 'hidden';
  }
  function closeDrawer() {
    if (!drawer) return;
    drawer.classList.remove('open');
    if (mobOverlay) mobOverlay.classList.remove('open');
    if (ham) { ham.classList.remove('open'); ham.setAttribute('aria-expanded', 'false'); }
    document.body.style.overflow = '';
    /* reset panels after drawer slides out */
    setTimeout(resetPanels, 300);
  }

  if (ham) ham.addEventListener('click', function() {
    if (drawer && drawer.classList.contains('open')) closeDrawer();
    else openDrawer();
  });
  if (closeBtn)  closeBtn.addEventListener('click', closeDrawer);
  if (mobOverlay) mobOverlay.addEventListener('click', closeDrawer);

  /* ── MOBILE: 3-level sliding panel navigation ── */
  var panelWrap = document.getElementById('nb-panel-wrap');

  function goToL1() {
    if (panelWrap) panelWrap.classList.remove('nb-at-2', 'nb-at-3');
  }
  function goToL2(blockId) {
    document.querySelectorAll('.nb-mob-p2-pane').forEach(function (p) { p.classList.remove('nb-pane-active'); });
    var pane = document.querySelector('.nb-mob-p2-pane[data-panel="' + blockId + '"]');
    if (pane) pane.classList.add('nb-pane-active');
    var p2 = document.getElementById('nb-panel-2');
    if (p2) p2.scrollTop = 0;
    if (panelWrap) { panelWrap.classList.remove('nb-at-3'); panelWrap.classList.add('nb-at-2'); }
  }
  function goToL3(blockId, colNum) {
    document.querySelectorAll('.nb-mob-p3-pane').forEach(function (p) { p.classList.remove('nb-pane-active'); });
    var pane = document.querySelector('.nb-mob-p3-pane[data-panel="' + blockId + '-' + colNum + '"]');
    if (pane) pane.classList.add('nb-pane-active');
    var p3 = document.getElementById('nb-panel-3');
    if (p3) p3.scrollTop = 0;
    if (panelWrap) panelWrap.classList.add('nb-at-3');
  }

  /* Level 1 → Level 2 */
  document.querySelectorAll('.nb-mob-lvl1-item[data-block]').forEach(function (row) {
    row.addEventListener('click', function () { goToL2(row.getAttribute('data-block')); });
    row.addEventListener('keydown', function (e) { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); row.click(); } });
  });

  /* Level 2 → Level 3 */
  document.querySelectorAll('.nb-mob-lvl2-item').forEach(function (row) {
    row.addEventListener('click', function () { goToL3(row.getAttribute('data-block'), row.getAttribute('data-col')); });
    row.addEventListener('keydown', function (e) { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); row.click(); } });
  });

  /* Back buttons (inside panels) */
  document.querySelectorAll('.nb-mob-back-row').forEach(function (btn) {
    btn.addEventListener('click', function () {
      if (btn.getAttribute('data-to') === '1') goToL1();
      else if (btn.getAttribute('data-to') === '2') { if (panelWrap) panelWrap.classList.remove('nb-at-3'); }
    });
  });

  /* Reset on drawer close */
  function resetPanels() {
    if (panelWrap) {
      panelWrap.style.transition = 'none';
      panelWrap.classList.remove('nb-at-2', 'nb-at-3');
      setTimeout(function () { if (panelWrap) panelWrap.style.transition = ''; }, 0);
    }
    document.querySelectorAll('.nb-mob-p2-pane, .nb-mob-p3-pane').forEach(function (p) { p.classList.remove('nb-pane-active'); });
  }

  /* ── MOBILE: search overlay ── */
  var searchOpen  = document.getElementById('nb-mob-search-open');
  var searchClose = document.getElementById('nb-mob-search-close');
  var searchOv    = document.getElementById('nb-mob-search-overlay');

  if (searchOpen) searchOpen.addEventListener('click', function () {
    if (searchOv) { searchOv.classList.add('open'); searchOv.querySelector('input').focus(); }
  });
  if (searchClose) searchClose.addEventListener('click', function () {
    if (searchOv) searchOv.classList.remove('open');
  });
  if (searchOv) searchOv.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') searchOv.classList.remove('open');
  });

  // Tab panel switching
  document.querySelectorAll('.nb-tab-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var mega = btn.closest('.nb-mega');
      var tabId = btn.dataset.tab;
      mega.querySelectorAll('.nb-tab-btn').forEach(function(b) { b.classList.remove('nb-tab-active'); });
      mega.querySelectorAll('.nb-tab-panel').forEach(function(p) { p.classList.remove('nb-tab-active'); });
      btn.classList.add('nb-tab-active');
      var panel = mega.querySelector('.nb-tab-panel[data-tab="' + tabId + '"]');
      if (panel) panel.classList.add('nb-tab-active');
    });
  });
}());

/* ── Atomato bell: clone visual into mega-nav, proxy clicks to original ── */
(function() {
  var navWrap = document.querySelector('.nb-nav .atomato-bell-wrap');
  if (!navWrap) return;

  function setupBell() {
    var headerWrap = document.querySelector('#header-top .atomato-bell-wrap');
    if (!headerWrap) return false;
    var originalBtn = headerWrap.querySelector('[data-notifeed-bell]');
    if (!originalBtn) return false;

    /* Visual clone — appearance only */
    var clone = originalBtn.cloneNode(true);
    navWrap.innerHTML = '';
    navWrap.appendChild(clone);

    /* Proxy clicks to the original so Atomato's listener fires,
       then reposition the panel to appear below our nav bell.
       Atomato renders its panel inside a Shadow DOM on [data-atomato-notifeeds-host].
       The panel right-aligns to a zero-size position:fixed anchor div inside that shadow root.
       Setting anchor.left = bell.right makes the 400px panel appear directly below the bell. */
    clone.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();

      var cloneRect = clone.getBoundingClientRect();

      function nudgeShadowPanel() {
        var host = document.querySelector('[data-atomato-notifeeds-host]');
        if (!host || !host.shadowRoot) return false;
        var divs = host.shadowRoot.querySelectorAll('div');
        for (var i = 0; i < divs.length; i++) {
          var cs = window.getComputedStyle(divs[i]);
          if (cs.position === 'fixed' && cs.display !== 'none') {
            /* Panel right-aligns to anchor: panel.left = anchor.left - panelWidth.
               To open rightward (panel left = bell left): anchor.left = bell.left + panelWidth */
            var inner = divs[i].querySelector('div');
            var panelWidth = inner ? inner.getBoundingClientRect().width : 400;
            var anchorLeft = cloneRect.left + panelWidth;
            /* Clamp so panel doesn't overflow right edge of viewport */
            anchorLeft = Math.min(anchorLeft, window.innerWidth - 8);
            divs[i].style.setProperty('left', anchorLeft + 'px', 'important');
            divs[i].style.setProperty('top',  (cloneRect.bottom + 8) + 'px', 'important');
            return true;
          }
        }
        return false;
      }

      originalBtn.click();

      /* Atomato positions synchronously on click; nudge on next frame */
      requestAnimationFrame(function() {
        if (!nudgeShadowPanel()) {
          setTimeout(nudgeShadowPanel, 100);
        }
      });
    });

    return true;
  }

  if (!setupBell()) {
    var target = document.querySelector('#header-top .atomato-bell-wrap');
    if (target) {
      var obs = new MutationObserver(function() {
        if (setupBell()) obs.disconnect();
      });
      obs.observe(target, { childList: true, subtree: true });
    }
  }
}());
</script>

