{{ 'section-footer.css' | asset_url | stylesheet_tag }}
<style>
  ._lbcactivelabel label{display:block; margin-bottom:0; color:#fff;}
  input.popupinput{position:absolute; top:0; left:0;display:none; z-index: -1;}
  .icon-pack-small{display:inline-flex; margin-right:8px; align-items:center;}
  ._grt-icon-widgets{padding-top:16px; padding-bottom:12px;}
  ._grt-icon-row{margin-bottom:8px}
  ._grt-icon-row a{display:flex; align-items:center; border-bottom:none;}
  .colorfff{color:#fff}
  .toggle__icon--plus,.toggle__icon--minus{display:none}
  @media(max-width:768px){
    .footer-item__content{margin-top:16px}
    input.popupinput:checked + ._lbcactivelabel .toggle__icon--plus,.toggle__icon--minus,._hideshowlbl{display:none;}
    input.popupinput + ._lbcactivelabel{position:relative; border-bottom:solid 1px #fff; padding-bottom:12px; margin-bottom:0;}
    input.popupinput + ._lbcactivelabel label{display:block; margin-bottom:0;}
    input.popupinput{position:absolute; top:0; left:0;display:none; z-index: -1;}
    input.popupinput:checked + ._lbcactivelabel{border-bottom-color:transparent;}
    .toggle__icon--plus,input.popupinput:checked + ._lbcactivelabel .toggle__icon--minus{display:inline-block;}
    input.popupinput:checked + ._lbcactivelabel + ._hideshowlbl{display:block; padding-bottom:24px;padding-left: 20px;}
  }
</style>
{%- if section.blocks.size > 0 -%}

  <div class="container--large gutter-top--xlarge footer-top apponlyelements-rel" data-js-inert>
    <div class="grid grid--layout grid--gap-xlarge apponlyelements-web-block {{ section.settings.layout }}">
      {%- for block in section.blocks -%}

        <div class="footer-item" id="footer-block-{{ block.id }}" {{ block.shopify_attributes }}>
          <div class="">
          {%- if block.settings.title and block.settings.image_heading == blank -%}
            
            {% if block.settings.show_accordia_mobile %}
              <input type="checkbox" class="popupinput" id="_grt-accord-{{ block.id }}" />
            {% endif %}
            
            <{{ section.settings.seo_h_tag }} class="_lbcactivelabel footer-item__title text-font--primary text-size--regular text-weight--bold">
              <label for="_grt-accord-{{ block.id }}">
                {% if block.settings.show_accordia_mobile %}
                  <span class="toggle__icon--plus">
                    {% render 'icon-plus' %}
                  </span>
                  <span class="toggle__icon--minus">
                    {% render 'icon-minus' %}
                  </span>
                {% endif %}
                <span>{{ block.settings.title | escape }}</span>
              </label>
            </{{ section.settings.seo_h_tag }}>
          {%- endif -%}

          {%- case block.type -%}

            {%- when 'text' -%}
              <div class="footer-item__content {% if block.settings.show_accordia_mobile %}_hideshowlbl{% endif %} rte">
                {%- unless block.settings.image_heading == blank -%}
                  <div class="footer-item__image-heading">
                    {% style %}
                      .footer-item__image-heading {
                        max-width: {{ block.settings.image_heading_size }}px;
                      }
                    {% endstyle %}

                    {%- liquid
                      assign image_size_x2 = block.settings.image_heading_size | times: 2
                      assign image_size_x3 = block.settings.image_heading_size | times: 3
                    -%}

                    <img 
                      src="{{ block.settings.image_heading | image_url: width: block.settings.image_heading_size }}"
                      srcset="
                        {{ block.settings.image_heading | image_url: width: block.settings.image_heading_size }} {{ block.settings.image_heading_size }}w,
                        {{ block.settings.image_heading | image_url: width: image_size_x2 }} {{ image_size_x2 }}w,
                        {{ block.settings.image_heading | image_url: width: image_size_x3 }} {{ image_size_x3 }}w
                      "
                      sizes="{{ block.settings.image_heading_size }}px"
                      class="image-heading" loading="lazy"
                      width="{{ block.settings.image_heading.width }}" height="{{ block.settings.image_heading.height }}"
                      alt="{{ block.settings.image_heading.alt }}"
                    />

                  </div>
                {%- endunless -%}
                {%- liquid
                  echo block.settings.content
                -%}

              {% if block.settings.contact_number != blank or email_info == blank %}
                <div class="_grt-icon-widgets">
                  {% unless block.settings.contact_number == blank %}
                    <div class="_grt-icon-row">
                      <a href="tel:{{ block.settings.contact_number }}">
                        {% if block.settings.show_contact_icons %}
                        <span class="icon-pack-small">
                          {% render 'icon-call' %}
                        </span>
                        {% endif %}
                        <span>{{ block.settings.contact_number }}</span>
                      </a>
                    </div>
                  {% endunless %}
                  {% unless block.settings.email_info == blank %}
                    <div class="_grt-icon-row">
                      <a href="mailtto:{{ block.settings.email_info }}">
                        {% if block.settings.show_email_icons %}
                        <span class="icon-pack-small">
                        {% render 'icon-email' %}
                        </span>
                          {% endif %}
                        <span>{{ block.settings.email_info }}</span>
                      </a>
                    </div>
                  {% endunless %}
            
                  </div>
                {% endif %}

                {% unless block.settings.address_block == blank %}
                  <div class="colorfff">{{ block.settings.address_block }}</div>
                {% endunless %}
              </div>
              
              {%- when 'menu' -%}
                <nav class="footer-item__menu {% if block.settings.show_accordia_mobile %}_hideshowlbl{% endif %} {% unless block.settings.menu_style %} footer-item__menu--unstyled {% endunless %} rte">
                  {%- for link in linklists[block.settings.menu].links -%}
                    <span>
                      <a href="{{ link.url }}" {%- if block.settings.menu_target -%} target="_blank" {%- endif -%}>{{ link.title | escape }}</a>
                    </span>
                  {%- endfor -%}
                </nav>


            {%- when 'image' -%}
              <div class="footer-item__image">
                {%- if block.settings.link -%} <a href="{{ block.settings.link }}" target="{{ block.settings.link_type }}"> {%- endif -%}
                  {%- if block.settings.image -%}
                    {%- if section.settings.layout contains 'grid-4' -%}
                      {%- capture sizes -%}
                        sizes="(max-width: 767px) 100vw, (max-width: 1023px) 50vw, (max-width: {{ settings.theme_max_width }}px) calc((100vw - 100px) / 4), {{ settings.theme_max_width | divided_by: 4 }}px"
                      {%- endcapture -%}
                    {%- else -%}
                      {%- capture sizes -%}
                        sizes="(max-width: 767px) 100vw, (max-width: {{ settings.theme_max_width }}px) calc((100vw - 100px) / 3), {{ settings.theme_max_width | divided_by: 3 }}px"
                      {%- endcapture -%}
                    {%- endif -%}
                    {%- render 'lazy-image', image: block.settings.image, sizes: sizes, class: 'lazy-image--no-transition' -%}
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag }}
                  {%- endif -%}
                {%- if block.settings.link -%} </a> {%- endif -%}
                {%- if block.settings.image_border_radius > 0 -%}
                  {% style %}
                    #footer-block-{{ block.id }} figure,
                    #footer-block-{{ block.id }} img {
                      border-radius: {{ block.settings.image_border_radius }}px;
                    }
                  {% endstyle %}
                {%- endif -%}
              </div>

              {%- when 'payment' -%}
                <div class="footer-item__icons">
                  {%- liquid 
                    for type in shop.enabled_payment_types
                      echo type | payment_type_svg_tag: class: 'payment-icon'
                    endfor
                  -%}
                </div>

                {%- when 'follow' -%}
                  <div class="footer-item__follow">
                    {%- echo shop | login_button: action: 'follow' -%}
                  </div>

              {%- when 'newsletter' -%} 
                <div class="footer-item__newsletter">
                  {%- assign form_id = 'newsletter-footer-block' -%}
                  {%- form 'customer', id: form_id, class: '' -%}
                    {%- if form.posted_successfully? -%}
                      <p>
                        {{ 'general.newsletter.confirmation' | t }}
                      </p>
                    {%- endif -%}
                    {%- unless form.posted_successfully? -%}
                      <fieldset>
                        <input type="hidden" name="contact[tags]" value="newsletter">
                        <div class="form-row" style="position:relative">
                          <input type="email" class="newsletter__input" value="{% if customer %}{{ customer.email }}{% endif %}" placeholder="{{ 'general.newsletter.email_label' | t }}" name="contact[email]" id="Email-{{ form_id }}" aria-label="{{ 'general.newsletter.email_label' | t }}" autocorrect="off" autocapitalize="off" required> 
                          <button type="submit" id="Subscribe-{{ form_id }}" aria-label="{{ 'general.newsletter.submit_label' | t }}">
                              <span class="visually-hidden">{{ 'general.newsletter.submit_label' | t }}</span>
                              <span aria-hidden="true" role="img">{%- render 'theme-symbols': icon: 'send' -%}</span>
                          </button>
                        </div>
                      </fieldset>
                    {%- endunless -%}
                  {%- endform -%}

                </div>

          {%- endcase -%}

        </div>
        </div>

      {%- endfor -%}
    </div>
  </div>

{%- endif -%}

{% schema %}
  {
    "name": "t:sections.footer.name",
    "class": "main-footer",
    "max_blocks": 18,
    "settings": [
      {
        "type": "select",
        "id": "layout",
        "label": "t:sections.local-extra-words.sections.columns.name",
        "info": "t:sections.local-extra-words.sections.columns.info",
        "options": [
          {
            "value": "grid-3 grid-lap-1",
            "label": "t:sections.local-extra-words.sections.columns.option__2"
          },
          {
            "value": "grid-4 grid-portable-2 grid-lap-1",
            "label": "t:sections.local-extra-words.sections.columns.option__3"
          }
        ],
        "default": "grid-4 grid-portable-2 grid-lap-1"
      },
      {
        "type": "header",
        "content": "t:sections.refactor_words.seo.name"
      },
      {
        "type": "select",
        "id": "seo_h_tag",
        "label": "t:sections.refactor_words.seo.label",
        "info": "t:sections.refactor_words.seo.info",
        "options": [
          {
            "value": "h1",
            "label": "H1"
          },
          {
            "value": "h2",
            "label": "H2"
          },
          {
            "value": "h3",
            "label": "H3"
          },
          {
            "value": "h4",
            "label": "H4"
          },
          {
            "value": "span",
            "label": "span"
          }
        ],
        "default": "h2"
      }
    ],
    "blocks": [
      {
        "type": "text",
        "name": "t:sections.local-extra-words.sections.main-footer.blocks.text.name",
        "settings": [
          {
            "type": "text",
            "id": "title",
            "label": "t:sections.footer.blocks.text.settings.title.label",
            "default": "Contact information"
          },
          {
            "type": "image_picker",
            "id": "image_heading",
            "label": "t:sections.bundle-extra-words.settings_schema.labels.image_heading"
          },
          {
            "type": "checkbox",
            "id": "show_accordia_mobile",
            "label": "Show accordian on mobile",
            "default": true
          },
          {
            "type": "range",
            "id": "image_heading_size",
            "label": "t:sections.bundle-extra-words.settings_schema.labels.image_heading_size",
            "min": 40,
            "max": 200,
            "step": 5,
            "default": 40,
            "unit": "px"
          },
          {
            "type": "richtext",
            "id": "content",
            "label": "t:sections.footer.blocks.text.settings.content.label",
            "default": "<p>Write a short statement about your brand.</p>"
          },
          {
            "type": "richtext",
            "id": "address_block",
            "label": "Enter your address",
            "default": "<p>709 N 2nd St<br>Suite 400<br>Philadelphia, PA 1912</p>"
          },
          {
            "type": "checkbox",
            "id": "show_contact_icons",
            "label": "Use icon for phone",
            "default": true
          },
          {
            "type": "text",
            "id": "contact_number",
            "label": "Enter Phone no. with country code",
            "default": "1-888-356-3665"
          },
          {
            "type": "checkbox",
            "id": "show_email_icons",
            "label": "Use icon for e-mail",
            "default": true
          },
          {
            "type": "text",
            "id": "email_info",
            "label": "Enter e-mail id",
            "default": "service@ninjatransfers.com"
          }
        ]
      },
      {
        "type": "menu",
        "name": "t:sections.split-extra-words.sections.footer.blocks.menu.name",
        "settings": [
          {
            "type": "text",
            "id": "title",
            "label": "t:sections.footer.blocks.text.settings.title.label",
            "default": "Quick links"
          },
          {
            "type": "checkbox",
            "id": "show_accordia_mobile",
            "label": "Show accordian on mobile",
            "default": true
          },
          {
            "type": "link_list",
            "id": "menu",
            "label": "t:sections.split-extra-words.sections.footer.blocks.menu.label",
            "default": "footer",
            "info": "t:sections.footer.blocks.menus.settings.menu_1.info"
          },
          {
            "type": "checkbox",
            "id": "menu_target",
            "label": "t:footer-menu-items.open_links_in_new_window",
            "default": false
          },
          {
            "type": "checkbox",
            "id": "menu_style",
            "label": "t:footer-menu-items.underline_links",
            "default": true
          }
        ]
      },
      {
        "type": "image",
        "name": "t:sections.footer.blocks.image.name",
        "settings": [
          {
            "type": "text",
            "id": "title",
            "label": "t:sections.footer.blocks.text.settings.title.label",
            "default": "Trust badge"
          },
          {
            "type": "image_picker",
            "id": "image",
            "label": "t:sections.footer.blocks.image.settings.image.label"
          },
          {
            "type": "range",
            "id": "image_border_radius",
            "label": "t:sections.bundle-extra-words.sections.info_tabs.settings.borders.radius",
            "min": 0,
            "max": 30,
            "step": 1,
            "unit": "px",
            "default": 0
          },
          {
            "type": "url",
            "id": "link",
            "label": "t:sections.image-with-text.blocks.image.settings.url.label"
          },
          {
            "type": "select",
            "id": "link_type",
            "label": "t:sections.local-extra-words.sections.header.blocks.info.link_type.label",
            "options": [
              {
                "value": "_blank",
                "label": "t:sections.local-extra-words.sections.header.blocks.info.link_type.option__3"
              },
              {
                "value": "_self",
                "label": "t:sections.local-extra-words.sections.header.blocks.info.link_type.option__2"
              }
            ],
            "default": "_self"
          }
        ]
      },
      {
        "type": "payment",
        "name": "t:sections.local-extra-words.sections.main-footer.blocks.payment.name",
        "limit": 1,
        "settings": [
          {
            "type": "text",
            "id": "title",
            "label": "t:sections.footer.blocks.text.settings.title.label",
            "default": "Supported payment methods"
          },
          {
            "type": "paragraph",
            "content": "t:sections.local-extra-words.sections.main-footer.blocks.payment.info"
          }
        ]
      },
      {
        "type": "follow",
        "name": "t:settings_schema.follow_on_shop.content",
        "limit": 1,
        "settings": [
          {
            "type": "text",
            "id": "title",
            "label": "t:sections.footer.blocks.text.settings.title.label",
            "default": "Follow us"
          },
          {
            "type": "paragraph",
            "content": "t:settings_schema.follow_on_shop.info"
          }
        ]
      },
      {
        "type": "newsletter",
        "name": "t:sections.newsletter.name",
        "limit": 1,
        "settings": [
          {
            "type": "text",
            "id": "title",
            "label": "t:sections.footer.blocks.text.settings.title.label",
            "default": "Newsletter"
          }
        ]
      }
    ],
    "enabled_on": {
      "groups": ["footer"]
    }
  }
{% endschema %}
<script>
  
$(function(){

  window.addEventListener("load", function() {
    const urlParams = new URLSearchParams(window.location.search);
    const aiFeature = urlParams.get('aifeature');
    
    if (aiFeature === 'true') {
      const $target = $(".generative-ai-area");

      if ($target.length) {
          $('html, body').animate({
            scrollTop: $target.offset().top - 100
          }, 800);
      }
    }
  });
  
})
</script>