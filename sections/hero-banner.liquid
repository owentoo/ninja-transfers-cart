
  <style>
    #swag-grid-{{ section.id }} {
      background: var(--bg);
      color: var(--text);
      padding: var(--pad-y) var(--pad-x);
      background: linear-gradient(
    to bottom,
    var(--bg) 0%,
    var(--bg) 60%,
    #fff 60%,
    #fff 100%
  );
    }

    #swag-grid-{{ section.id }} .swag-grid__outer {
     /* max-width: var(--max); */
      margin: 0 auto;
    }

    #swag-grid-{{ section.id }} .swag-grid__top {
      background: var(--top-bg);
      border-radius: calc(var(--radius) + 6px);
      padding: 0;
      display: flex;
      grid-template-columns: 1.2fr 1fr;
      gap: var(--gap);
      align-items: center;
      justify-content:space-between;
      margin-bottom: var(--top-mb, 24px);
    }
    #swag-grid-{{ section.id }} .swag-grid__subheading p{
      margin:0;
    }

    #swag-grid-{{ section.id }} .swag-grid__heading {
      font-size: clamp(28px, 3.2vw, 44px);
      line-height: 1.08;
      letter-spacing: -0.02em;
      margin: 0 0 10px 0;
      font-weight: 800;
    }

    #swag-grid-{{ section.id }} .swag-grid__subheading {
      color: var(--muted);
      font-size: 14px;
      line-height: 1.6; 
    }

    /* Slider */
    #swag-grid-{{ section.id }} .swag-grid__slider {
      position: relative;
      overflow: hidden;
      padding-bottom: 5px;
    }
@media (min-width:991px){
  #swag-grid-{{ section.id }} .swag-grid__intro{
  max-width: var(--intro-max, 620px);
}

#swag-grid-{{ section.id }} .swag-grid__testimonial{
  max-width: var(--testi-max, 520px);
  margin-left: auto; /* keeps it aligned right */
}
}

    #swag-grid-{{ section.id }} .swag-grid__track {
      display: flex;
      width: 100%;
      transition: transform .45s ease;
      will-change: transform;
    }

    #swag-grid-{{ section.id }} .swag-grid__slide {
      flex: 0 0 100%;
      display: flex; 
      gap: 14px;
      align-items: center;
    }

    #swag-grid-{{ section.id }} .swag-grid__testimonial-media img {
      width: 110px;
      height: 110px;
      object-fit: cover;
      border-radius: 12px;
      display: block; 
      user-select: none;
      -webkit-user-drag: none;
    }

    #swag-grid-{{ section.id }} .swag-grid__stars {
      color: #f5b301;
      font-size: 16px;
      letter-spacing: -2px;
      margin-bottom: 6px;
    }

    #swag-grid-{{ section.id }} .swag-grid__testimonial-text {
      color: var(--muted);
      font-size: 14px;
      line-height: 1.5;
      margin-bottom: 10px;
    }

    #swag-grid-{{ section.id }} .swag-grid__testimonial-author {
      font-weight: 700;
      font-size: 14px;
      margin-bottom: 10px;
    }

    /* Dots */
    #swag-grid-{{ section.id }} .swag-grid__dots {
      display: flex;
      gap: 7px;
      margin-top: 10px;
      position: static;
  margin-left: 125px;
    }
    #swag-grid-{{ section.id }} .swag-grid__dot {
      width: 7px;
      height: 7px;
      border-radius: 999px;
      border: 0;
      padding: 0;
      background: rgba(0,0,0,.22);
      cursor: pointer;
    }
    #swag-grid-{{ section.id }} .swag-grid__dot.is-active {
      background: rgba(0,0,0,.78);
      transform: scale(1.12);
    }

    /* Cards */
    #swag-grid-{{ section.id }} .swag-grid__cards {
      margin-top: 0;
      display: grid;
      grid-template-columns: 1.25fr .75fr;
      gap: var(--gap);
    }

    #swag-grid-{{ section.id }} .swag-card {
      background: var(--card-bg);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 16px;
      overflow: hidden;
      border:1px solid #E0E0E0;
      cursor:pointer;
    }

    #swag-grid-{{ section.id }} .swag-card__title {
      margin: 0 0 16px 0;
      font-size: 18px;
      font-weight: 800;
    }

    #swag-grid-{{ section.id }} .swag-card__image-wrap {
      position: relative;
      border-radius: calc(var(--radius) - 0px);
      overflow: hidden;
      background: rgba(0,0,0,.04);
    }

    #swag-grid-{{ section.id }} .swag-card__image-wrap img {
      width: 100%;
      height: auto;
      display: block;
      height: var(--img-h-desktop, 380px);
      object-fit: cover;
    }

    

    #swag-grid-{{ section.id }} .swag-card__badge {
      position: absolute;
      left: 14px;
      bottom: 14px;
      background: rgba(255,255,255,.92);
      color: var(--badge-text, rgba(0,0,0,.82));
      font-size: 12px;
      padding: 8px 12px;
      border-radius: 6px;
      box-shadow: 0 8px 22px rgba(0,0,0,.12);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      max-width: calc(100% - 28px);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      padding-left: 40px;
  background: var(--badge-icon-url) 7px center no-repeat var(--badge-bg, rgba(255,255,255,.92));
    background-size: auto;
  background-size: 28px;
    }

    #swag-grid-{{ section.id }} .swag-card__buttons {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      margin-top: 12px;
    }

    #swag-grid-{{ section.id }} .swag-card.is-small .swag-card__buttons {
      grid-template-columns: 1fr;
    }

    #swag-grid-{{ section.id }} .swag-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      width: 100%;
      min-height: 46px;
      padding: 12px 14px;
      border-radius: 10px;
      background: var(--btn-bg);
      color: var(--btn-text);
      text-decoration: none;
      font-weight: 600;
      font-size: 14px;
      transition: transform .18s ease, background .18s ease;
    }
    #swag-grid-{{ section.id }} .swag-btn:hover {
      background: var(--btn-bg-hover); 
    }

    @media (max-width: 990px) {

      #swag-grid-{{ section.id }} { 
