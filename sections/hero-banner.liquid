{% liquid
  assign s = section.settings
%}

<section
  id="swag-grid-{{ section.id }}"
  class="swag-grid"
  style="
    --bg: {{ s.bg_color }};
    --top-bg: {{ s.top_bg_color }};
    --card-bg: {{ s.card_bg_color }};
    --text: {{ s.text_color }};
    --muted: {{ s.muted_text_color }};
    --btn-bg: {{ s.button_bg }};
    --btn-text: {{ s.button_text }};
    --btn-bg-hover: {{ s.button_bg_hover }};
    --radius: {{ s.radius }}px;
    --shadow: {{ s.shadow }};
    --gap: {{ s.gap }}px;
    --max: {{ s.max_width }}px;
    --pad-y: {{ s.section_padding_y }}px;
    --pad-x: {{ s.section_padding_x }}px;
    --intro-max: {{ s.intro_max_width }}px;
--testi-max: {{ s.testimonial_max_width }}px;
--top-mb: {{ s.top_margin_bottom }}px;
  "
>
  <div class="swag-grid__outer container container--large">
    <div class="swag-grid__top">
      <div class="swag-grid__intro">
        {% if s.heading != blank %}
          <h2 class="swag-grid__heading">{{ s.heading | replace:"|","<br/>"}}</h2>
        {% endif %}
        {% if s.subheading != blank %}
          <div class="swag-grid__subheading">{{ s.subheading }}</div>
        {% endif %}
      </div>

      {% if s.show_testimonial %}
        <div class="swag-grid__testimonial">
          <div class="swag-grid__slider" data-swag-slider>
            <div class="swag-grid__track" data-swag-track>
              {% assign testimonial_count = 0 %}
              {% for block in section.blocks %}
                {% if block.type == 'testimonial' %}
                  {% assign testimonial_count = testimonial_count | plus: 1 %}
                  {% assign t = block.settings %}
                  <div class="swag-grid__slide" data-swag-slide {{ block.shopify_attributes }}>
                    {% if t.image != blank %}
                      <div class="swag-grid__testimonial-media">
                        <img
                          src="{{ t.image | image_url: width: 320 }}"
                          alt="{{ t.author | escape }}"
                          loading="lazy"
                          width="160"
                          height="160"
                        >
                      </div>
                    {% endif %}

                    <div class="swag-grid__testimonial-body">
                      {% if t.stars > 0 %}
                        <div class="swag-grid__stars" aria-label="{{ t.stars }} stars">
                          {% for i in (1..t.stars) %}
                            ★
                          {% endfor %}
                        </div>
                      {% endif %}

                      {% if t.text != blank %}
                        <div class="swag-grid__testimonial-text">{{ t.text }}</div>
                      {% endif %}

                      {% if t.author != blank %}
                        <div class="swag-grid__testimonial-author">{{ t.author }}</div>
                      {% endif %}
                    </div>
                  </div>
                {% endif %}
              {% endfor %}
            </div>

            {% if testimonial_count > 1 and s.show_dots %}
              <div class="swag-grid__dots" data-swag-dots aria-label="Testimonial slider navigation">
                {% for i in (1..testimonial_count) %}
                  <button type="button" class="swag-grid__dot" data-index="{{ forloop.index0 }}" aria-label="Go to slide {{ forloop.index }}"></button>
                {% endfor %}
              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}
    </div>

    <div class="swag-grid__cards">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'card' %}
            {% liquid
              assign b = block.settings
              assign btn1_label = b.btn1_label
              assign btn2_label = b.btn2_label
            %}

            <article
              class="swag-card {% if b.card_size == 'large' %}is-large{% else %}is-small{% endif %}"
              style="
                --img-h-desktop: {{ b.image_height_desktop }}px;
                --img-h-mobile: {{ b.image_height_mobile }}px;
            "
              {{ block.shopify_attributes }}
              onclick="location.href='{{ b.btn1_link }}'"
            >
              {% if b.title != blank %}
                <h3 class="swag-card__title">{{ b.title }}</h3>
              {% endif %}

              {% if b.image != blank %}
                <div class="swag-card__image-wrap">
                  <img
                    src="{{ b.image | image_url: width: 1600 }}"
                    alt="{{ b.title | escape }}"
                    loading="lazy"
                    width="1200"
                    height="700"
                  >
                  {% if b.badge_text != blank %}
                    <div class="swag-card__badge"
                    style="
      --badge-bg: {{ b.badge_bg_color }};
      --badge-text: {{ b.badge_text_color }}; 
      --badge-icon-url: {% if b.badge_icon != blank %}url({{ b.badge_icon | image_url: width: 80 }}){% else %}none{% endif %};
    "
                    >{{ b.badge_text | replace:"[DELIVERY DATE]","<div class='dynamic-delivery-date'></div>"}}</div>
                  {% endif %}
                </div>
              {% endif %}

              {% if btn1_label != blank or btn2_label != blank %}
                <div class="swag-card__buttons">
                  {% if btn1_label != blank %}
                    <a class="swag-btn" href="{{ b.btn1_link | default: '#' }}">
                      {{ btn1_label }}
                    </a>
                  {% endif %}

                  {% if btn2_label != blank %}
                    <a class="swag-btn" href="{{ b.btn2_link | default: '#' }}">
                      {{ btn2_label }}
                    </a>
                  {% endif %}
                </div>
              {% endif %}
            </article>
        {% endcase %}
      {% endfor %}
    </div>
  </div>

  <script>

    (() => {
            let html = $('.headerCountdown').html();
let onlyDelivery = html.match(/^(.*?<\/strong>)/)?.[1]?.trim() || '';

$(".dynamic-delivery-date").html(onlyDelivery);

      const root = document.getElementById('swag-grid-{{ section.id }}');
      if (!root) return;

      const slider = root.querySelector('[data-swag-slider]');
      const track = root.querySelector('[data-swag-track]');
      const slides = root.querySelectorAll('[data-swag-slide]');
      const dotsWrap = root.querySelector('[data-swag-dots]');
      if (!slider || !track || slides.length <= 1) return;

      const dots = dotsWrap ? Array.from(dotsWrap.querySelectorAll('.swag-grid__dot')) : [];
      let index = 0;

      const autoplay = {{ s.autoplay | json }};
      const autoplaySpeed = {{ s.autoplay_speed | times: 1000 | json }};
      let timer = null;

      function setActiveDot(i) {
        if (!dots.length) return;
        dots.forEach((d, idx) => d.classList.toggle('is-active', idx === i));
      }

      function goTo(i, smooth = true) {
        index = (i + slides.length) % slides.length;
        track.style.transition = smooth ? 'transform .45s ease' : 'none';
        track.style.transform = `translateX(-${index * 100}%)`;
        setActiveDot(index);
      }

      function startAutoplay() {
        if (!autoplay) return;
        stopAutoplay();
        timer = setInterval(() => goTo(index + 1), autoplaySpeed);
      }

      function stopAutoplay() {
        if (timer) clearInterval(timer);
        timer = null;
      }

      // Dots click
      if (dots.length) {
        dots.forEach((dot) => {
          dot.addEventListener('click', () => {
            const i = Number(dot.dataset.index || 0);
            goTo(i);
            startAutoplay();
          });
        });
      }

      // Swipe support
      let startX = 0;
      let currentX = 0;
      let dragging = false;

      function onStart(e) {
        dragging = true;
        stopAutoplay();
        track.style.transition = 'none';
        startX = (e.touches ? e.touches[0].clientX : e.clientX);
        currentX = startX;
      }

      function onMove(e) {
        if (!dragging) return;
        currentX = (e.touches ? e.touches[0].clientX : e.clientX);
        const dx = currentX - startX;
        const percent = (dx / slider.clientWidth) * 100;
        track.style.transform = `translateX(calc(-${index * 100}% + ${percent}%))`;
      }

      function onEnd() {
        if (!dragging) return;
        dragging = false;

        const dx = currentX - startX;
        const threshold = slider.clientWidth * 0.18;

        if (dx > threshold) goTo(index - 1);
        else if (dx < -threshold) goTo(index + 1);
        else goTo(index);

        startAutoplay();
      }

      slider.addEventListener('mouseenter', stopAutoplay);
      slider.addEventListener('mouseleave', startAutoplay);

      slider.addEventListener('touchstart', onStart, { passive: true });
      slider.addEventListener('touchmove', onMove, { passive: true });
      slider.addEventListener('touchend', onEnd);

      slider.addEventListener('mousedown', onStart);
      window.addEventListener('mousemove', onMove);
      window.addEventListener('mouseup', onEnd);

      // Init
      goTo(0, false);
      startAutoplay();

      // Theme editor support
      document.addEventListener('shopify:section:unload', (event) => {
        if (event.detail.sectionId === '{{ section.id }}') stopAutoplay();
      });
    })();
  </script>
</section>

