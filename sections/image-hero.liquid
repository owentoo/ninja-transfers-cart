<!-- ── Dynamic styles (scoped to this section instance) ── -->
<style>
  #shopify-section-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    overflow-x: hidden;
  }
  #shopify-section-{{ section.id }} .hero h1 {
    font-size: {{ section.settings.h1_size_desktop }}px;
    line-height: 1.1;
    color: {{ section.settings.heading_color }};
  }
  #shopify-section-{{ section.id }} .hero .subtitle {
    font-size: {{ section.settings.subtitle_size_desktop }}px;
    line-height: 1.6;
    color: {{ section.settings.subtitle_color }};
    opacity: {{ section.settings.subtitle_opacity | divided_by: 100.0 }};
  }
  #shopify-section-{{ section.id }} .hero .badge .badge-review-text {
    font-size: {{ section.settings.review_text_size_desktop }}px;
  }
  #shopify-section-{{ section.id }} .hero .feature {
    font-size: {{ section.settings.feature_size_desktop }}px;
    line-height: 1.4;
    color: {{ section.settings.feature_color }};
    opacity: {{ section.settings.feature_opacity | divided_by: 100.0 }};
  }
  #shopify-section-{{ section.id }} .hero .feature svg,
  #shopify-section-{{ section.id }} .hero .feature .feature-custom-icon {
    width: {{ section.settings.icon_size_desktop }}px;
    height: {{ section.settings.icon_size_desktop }}px;
  }
  #shopify-section-{{ section.id }} .hero-wrapper {
    padding-bottom: {{ section.settings.section_padding_bottom }}px;
  }
  #shopify-section-{{ section.id }} .hero {
    min-height: {{ section.settings.section_max_height }}px;
    max-height: {{ section.settings.section_max_height }}px;
  }
  #shopify-section-{{ section.id }} .hero-left {
    padding-left: {{ section.settings.text_padding_left }}px;
  }
  #shopify-section-{{ section.id }} .hero-image--mobile {
    display: none;
  }
  #shopify-section-{{ section.id }} .hero-image {
    max-width: {{ section.settings.image_max_width }}%;
  }
  #shopify-section-{{ section.id }} .badge strong {
    color: {{ section.settings.badge_rating_color }};
  }
  #shopify-section-{{ section.id }} .badge .badge-review-text {
    color: {{ section.settings.badge_text_color }};
  }

  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .hero {
      min-height: auto;
      max-height: none;
      overflow: hidden;
    }
    #shopify-section-{{ section.id }} .hero-right--image {
      display: flex;
    }
    #shopify-section-{{ section.id }} .hero h1 {
      font-size: {{ section.settings.h1_size_mobile }}px;
      line-height: 1.15;
    }
    #shopify-section-{{ section.id }} .hero .subtitle {
      font-size: {{ section.settings.subtitle_size_mobile }}px;
      line-height: 1.5;
    }
    #shopify-section-{{ section.id }} .hero .badge .badge-review-text {
      font-size: {{ section.settings.review_text_size_mobile }}px;
    }
    #shopify-section-{{ section.id }} .hero .feature {
      font-size: {{ section.settings.feature_size_mobile }}px;
      line-height: 1.4;
    }
    #shopify-section-{{ section.id }} .hero .feature svg,
    #shopify-section-{{ section.id }} .hero .feature .feature-custom-icon {
      width: {{ section.settings.icon_size_mobile }}px;
      height: {{ section.settings.icon_size_mobile }}px;
    }
    #shopify-section-{{ section.id }} .hero-left {
      padding-bottom: {{ section.settings.mobile_cta_image_gap }}px;
    }
    #shopify-section-{{ section.id }} .hero-image--desktop {
      display: none;
    }
    #shopify-section-{{ section.id }} .hero-image--mobile {
      display: block;
    }
  }
</style>

<!-- ── Hero markup ── -->
<div class="hero-wrapper">
  <div class="hero">
    <div class="hero-left">

    {%- if section.settings.badge_visible -%}
      <div class="badge">
        <span class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        <strong>{{ section.settings.badge_rating }}</strong> <span class="badge-review-text">{{ section.settings.badge_review_text }}</span>
      </div>
    {%- endif -%}

    <h1>
      {{ section.settings.heading_text }} <span class="count">{{ section.settings.customer_count }}</span>
    </h1>

    <p class="subtitle">{{ section.settings.subtitle_text }}</p>

    {%- assign has_features = false -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'feature' -%}
        {%- assign has_features = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
    {%- if has_features -%}
      <div class="features">
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature' -%}
            <div class="feature" {{ block.shopify_attributes }}>
              {%- if block.settings.custom_icon != blank -%}
                {%- assign icon_url = block.settings.custom_icon | image_url: width: 40 -%}
                <img class="feature-custom-icon" src="{{ icon_url }}" alt="" width="40" height="40" loading="lazy">
              {%- else -%}
                {%- case block.settings.icon -%}
                  {%- when 'checkmark' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
                    </svg>
                  {%- when 'star' -%}
                    <svg viewBox="0 0 24 24" fill="currentColor">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                    </svg>
                  {%- when 'shield' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                  {%- when 'truck' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                      <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
                    </svg>
                {%- endcase -%}
              {%- endif -%}
              {{ block.settings.feature_text }}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="buttons">
      {%- for block in section.blocks -%}
        {%- if block.type == 'button' -%}
          <a href="{{ block.settings.btn_url }}"
             class="btn btn-{{ block.settings.btn_style }}{% if block.settings.mobile_only %} btn-mobile-only{% endif %}"
             style="--btn-bg: {{ block.settings.btn_bg_color }}; --btn-text: {{ block.settings.btn_text_color }}; --btn-border: {{ block.settings.btn_border_color }};"
             {{ block.shopify_attributes }}>
            {{- block.settings.btn_text -}}
            <svg class="btn-arrow" width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 10h10"/><path d="M11 6l4 4-4 4"/></svg>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>

    <div class="hero-right hero-right--image">
      {%- if section.settings.hero_image != blank -%}
        {%- assign hero_img = section.settings.hero_image | image_url: width: 1200 -%}
        <img class="hero-image hero-image--desktop" src="{{ hero_img }}" alt="{{ section.settings.hero_image.alt | escape }}" width="{{ section.settings.hero_image.width }}" height="{{ section.settings.hero_image.height }}" loading="eager">
        {%- if section.settings.hero_image_mobile != blank -%}
          {%- assign mobile_img = section.settings.hero_image_mobile -%}
        {%- else -%}
          {%- assign mobile_img = section.settings.hero_image -%}
        {%- endif -%}
        {%- assign hero_img_mobile = mobile_img | image_url: width: 800 -%}
        <img class="hero-image hero-image--mobile" src="{{ hero_img_mobile }}" alt="{{ mobile_img.alt | escape }}" width="{{ mobile_img.width }}" height="{{ mobile_img.height }}" loading="eager">
      {%- else -%}
        <div class="hero-image-placeholder">
          <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          <span>Upload Hero Image</span>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

<!-- ── Static CSS ── -->
{% stylesheet %}
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

  /* Full-width section wrapper */
  .hero-section-root {
    overflow-x: hidden;
  }

  .hero-wrapper {
    max-width: 1400px;
    margin: 0 auto;
    font-family: 'Inter', sans-serif;
    color: #fff;
  }

  .hero {
    display: flex;
    overflow-y: clip;
    overflow-x: visible;
    position: relative;
    padding-left: 40px;
    font-family: 'Inter', sans-serif;
    color: #fff;
  }

  .hero-left {
    flex: 0 0 45%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 40px 0 0;
    z-index: 2;
  }

  /* Badge */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 0;
    font-size: 13px;
    color: #9ca3af;
    margin-top: 0;
    margin-bottom: 14px;
    width: fit-content;
  }

  .badge .stars {
    color: #fbbf24;
    font-size: 15px;
    letter-spacing: 2px;
  }

  .badge strong {
    color: #fff;
    font-weight: 700;
  }

  /* Heading */
  .hero h1 {
    font-weight: 800;
    line-height: 1.1;
    margin-top: 0;
    margin-bottom: 20px;
    letter-spacing: -1.5px;
  }

  .hero h1 .count {
    color: #fff;
  }

  /* Subtitle */
  .hero .subtitle {
    color: #9ca3af;
    line-height: 1.6;
    margin-bottom: 28px;
    max-width: 100%;
  }

  /* Features */
  .hero .features {
    display: flex;
    gap: 20px;
    margin-bottom: 36px;
    flex-wrap: nowrap;
    white-space: nowrap;
  }

  .hero .feature {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #d1d5db;
  }

  .hero .feature svg {
    width: 20px;
    height: 20px;
    color: #22c55e;
    flex-shrink: 0;
  }

  .hero .feature .feature-custom-icon {
    width: 20px;
    height: 20px;
    object-fit: contain;
    flex-shrink: 0;
  }

  /* Buttons */
  .hero .buttons {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .hero .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    border-radius: 12px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s;
    cursor: pointer;
    border: none;
    font-family: 'Inter', sans-serif;
    white-space: nowrap;
  }

  .hero .btn-primary {
    background: var(--btn-bg);
    color: var(--btn-text);
    box-shadow: 0 4px 20px color-mix(in srgb, var(--btn-bg) 40%, transparent);
  }

  .hero .btn-primary:hover {
    box-shadow: 0 6px 30px color-mix(in srgb, var(--btn-bg) 50%, transparent);
    transform: translateY(-2px);
  }

  .hero .btn-secondary {
    background: color-mix(in srgb, var(--btn-bg) 12%, transparent);
    color: var(--btn-text);
    border: 1px solid color-mix(in srgb, var(--btn-border) 15%, transparent);
  }

  .hero .btn-secondary:hover {
    background: color-mix(in srgb, var(--btn-bg) 20%, transparent);
    transform: translateY(-2px);
  }

  .hero .btn-outline {
    background: transparent;
    color: var(--btn-text);
    border: 2px solid color-mix(in srgb, var(--btn-border) 35%, transparent);
  }

  .hero .btn-outline:hover {
    border-color: color-mix(in srgb, var(--btn-border) 70%, transparent);
    transform: translateY(-2px);
  }

  .hero .btn-text {
    background: transparent;
    color: var(--btn-text);
    padding-left: 4px;
    padding-right: 4px;
  }

  .hero .btn-text:hover {
    opacity: 0.7;
  }

  .hero .btn-glass {
    background: color-mix(in srgb, var(--btn-bg) 8%, transparent);
    color: var(--btn-text);
    border: 1px solid color-mix(in srgb, var(--btn-border) 10%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .hero .btn-glass:hover {
    background: color-mix(in srgb, var(--btn-bg) 15%, transparent);
    transform: translateY(-2px);
  }

  .hero .btn-arrow {
    width: 18px !important;
    height: 18px !important;
    min-width: 18px;
    min-height: 18px;
    flex-shrink: 0;
    transition: transform 0.3s;
  }

  .hero .btn:hover .btn-arrow {
    transform: translateX(3px);
  }

  .hero .btn-mobile-only {
    display: none;
  }

  /* Right side — single image mode */
  .hero-right--image {
    flex: 0 0 55%;
    display: flex;
    align-items: flex-end;
    align-self: stretch;
  }

  .hero-right--image::before {
    display: none;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
    object-position: bottom right;
  }

  .hero-image--mobile {
    display: none;
  }

  .hero-image-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    width: 100%;
    height: 100%;
    background: #1a1a2e;
    color: #4a4a6a;
  }

  .hero-image-placeholder span {
    font-size: 14px;
    font-family: 'Inter', sans-serif;
  }

  /* Tablet breakpoint */
  @media (max-width: 1024px) {
    .hero-left {
      flex: 0 0 55%;
      padding-right: 20px;
    }

    .hero .features {
      flex-wrap: wrap;
      white-space: normal;
    }
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .hero .btn-mobile-only {
      display: inline-flex;
    }

    .hero {
      flex-direction: column;
      min-height: auto;
      max-height: none;
      padding-bottom: 0;
      padding-left: 20px;
      padding-right: 20px;
    }

    .hero-left {
      flex: none;
      padding: 0 0 30px;
    }

    .hero-right--image {
      display: flex;
      width: 100%;
      flex: none;
      padding: 0;
      order: 2;
    }

    .hero-image--desktop {
      display: none;
    }

    .hero-image--mobile {
      display: block;
    }

    .hero .features {
      flex-direction: column;
      white-space: normal;
      gap: 12px;
    }

    .hero .buttons {
      flex-direction: column;
    }

    .hero .btn {
      justify-content: center;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Image Hero",
  "tag": "section",
  "class": "hero-section-root",
  "max_blocks": 50,
  "settings": [
    {
      "type": "header",
      "content": "Hero Image"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "hero_image_mobile",
      "label": "Hero image (mobile)",
      "info": "Optional — falls back to desktop image if empty"
    },
    {
      "type": "range",
      "id": "image_max_width",
      "label": "Image max width",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Badge"
    },
    {
      "type": "checkbox",
      "id": "badge_visible",
      "label": "Show star badge",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_rating",
      "label": "Rating number",
      "default": "4.9"
    },
    {
      "type": "text",
      "id": "badge_review_text",
      "label": "Review label",
      "default": "Based on 35,000+ Reviews"
    },
    {
      "type": "color",
      "id": "badge_rating_color",
      "label": "Rating number color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Review text color",
      "default": "#9ca3af"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading_text",
      "label": "Heading text (before number)",
      "default": "DTF Transfers Trusted by"
    },
    {
      "type": "text",
      "id": "customer_count",
      "label": "Customer count",
      "default": "225,000+"
    },
    {
      "type": "header",
      "content": "Subtitle"
    },
    {
      "type": "textarea",
      "id": "subtitle_text",
      "label": "Subtitle",
      "default": "Print ANY Design on ANY Product, Material or Color with 100+ Wash Durability. Make More For Less."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "section_max_height",
      "label": "Desktop section height",
      "min": 400,
      "max": 900,
      "step": 25,
      "unit": "px",
      "default": 600
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Section padding bottom",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "text_padding_left",
      "label": "Text indent from left",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "mobile_cta_image_gap",
      "label": "Mobile: space between CTA & image",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Desktop text sizes"
    },
    {
      "type": "range",
      "id": "h1_size_desktop",
      "label": "Heading size (desktop)",
      "min": 28,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 52
    },
    {
      "type": "range",
      "id": "subtitle_size_desktop",
      "label": "Subtitle size (desktop)",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "review_text_size_desktop",
      "label": "Review text size (desktop)",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "feature_size_desktop",
      "label": "Feature text size (desktop)",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "icon_size_desktop",
      "label": "Icon size (desktop)",
      "min": 12,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Mobile text sizes"
    },
    {
      "type": "range",
      "id": "h1_size_mobile",
      "label": "Heading size (mobile)",
      "min": 20,
      "max": 52,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "subtitle_size_mobile",
      "label": "Subtitle size (mobile)",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "review_text_size_mobile",
      "label": "Review text size (mobile)",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "feature_size_mobile",
      "label": "Feature text size (mobile)",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "icon_size_mobile",
      "label": "Icon size (mobile)",
      "min": 12,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle color",
      "default": "#9ca3af"
    },
    {
      "type": "range",
      "id": "subtitle_opacity",
      "label": "Subtitle opacity",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "color",
      "id": "feature_color",
      "label": "Feature text color",
      "default": "#d1d5db"
    },
    {
      "type": "range",
      "id": "feature_opacity",
      "label": "Feature text opacity",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Item",
      "settings": [
        {
          "type": "text",
          "id": "feature_text",
          "label": "Feature text",
          "default": "100% Satisfaction"
        },
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "Custom icon image",
          "info": "Upload your own icon. Overrides the dropdown below."
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Built-in icon (fallback)",
          "default": "checkmark",
          "options": [
