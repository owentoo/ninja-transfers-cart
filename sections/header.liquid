            assign startTimeNew   =   section.settings.startTimeNew | times: 1
            assign endTimeNew     =   section.settings.endTimeNew | times: 1

            assign startTime_satSunNew  = section.settings.startTime_satSunNew | times: 1
            assign endTime_satSunNew    = section.settings.endTime_satSunNew | times: 1

            assign hours          =   "now" | date: "%R" | split: ':' | first | times: 1

            comment
            echo hours
            assign hours          =   hours | plus: 1
            echo ' after ' | append: hours
            endcomment
            assign showPhone      =   false
            if dayName == 'mon'
              if hours >= startTimeNew and hours < endTimeNew
                assign showPhone  =   true
              endif
            endif

            if dayName == 'tue'
              if hours > startTimeNew and hours < endTimeNew
                assign showPhone  =   true
              endif
            endif

            if dayName == 'wed'
              if hours >= startTimeNew and hours < endTimeNew
                assign showPhone  =   true
              endif
            endif

            if dayName == 'thu'
              if hours >= startTimeNew and hours < endTimeNew
                assign showPhone  =   true
              endif
            endif

            if dayName == 'fri'
              if hours >= startTimeNew and hours < endTimeNew
                assign showPhone  =   true
              endif
            endif

            if dayName == 'sat'
              if hours >= startTime_satSunNew and hours < endTime_satSunNew
                assign showPhone  =   true
              endif
            endif

            if dayName == 'sun'
              if hours >= startTime_satSunNew and hours < endTime_satSunNew
                assign showPhone  =   true
              endif
            endif
