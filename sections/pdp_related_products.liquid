{% style %}
  .underCTA .pdpRelatedProducts__pItem__pCode {
    font-size: {{ section.settings.pCode_fontSize | append: 'px' }};
    font-weight: {{ section.settings.pCode_fontWeight }};
  }

  .underCTA .pdpRelatedProducts__pItem__atc button {
    --shadow-color: {{ section.settings.button_bg }};
    border-radius: {{ section.settings.button_radius | append: 'px' }};
    color: {{ section.settings.button_color }};
    background: {{ section.settings.button_bg }};
    font-size: {{ section.settings.button_fontSize | append: 'px' }};
    font-weight: {{ section.settings.button_fontWeight }};
  }

  .underCTA .pdpRelatedProducts__pItem__atc button:hover {
    color: {{ section.settings.button_color_hover }};
    background: {{ section.settings.button_bg_hover }};
  }

  /* just for testing */
  .relatedPopup__content .colorOptionsLimited {
    max-height: 64px !important;
    max-height: unset !important;
    padding: 1px;
  }

  .relatedPopup__content__variants .colorOptions .colorOption .colorButton {
    margin: 3px;
  }

  .relatedPopup__content .addToCartSection .button {
    display: flex;
    align-items: center;
  }

  .relatedPopup__content .addToCartSection .button .button__text {
    line-height: 1;
  }
  .bottom__popUp .toast {
    position: absolute;
    top: 10px;
    right: 8px;
    transform: unset;
    z-index: 99999999999999;
    opacity: 0;
  }
  .bottom__popUp .toast.active {
    opacity: 1;
  }
{% endstyle %}

{%- liquid
  assign ss = section.settings
-%}
<link rel="stylesheet" href="{{ 'pdpRelatedProducts.css' | asset_url }}">
<div class="pdpRelatedProducts hidden">
  {% if ss.title != blank %}
    <div class="pdpRelatedProducts__titleWrap">
      <h3 class="pdpRelatedProducts__title">{{ ss.title }}</h3>

      <div class="pdpRelatedProducts__iconWrap">
        <div class="pdpRelatedProducts__iconItem">
          
          <svg id="Layer_2" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 23.33 23.33">
            <g id="Layer_1-2" data-name="Layer_1">
              <path d="M19.92,3.41C15.37-1.14,7.96-1.14,3.41,3.41-1.14,7.96-1.14,15.37,3.41,19.92c2.28,2.27,5.26,3.41,8.25,3.41s5.98-1.14,8.25-3.41c4.55-4.55,4.55-11.95,0-16.5ZM19.21,4.12c4.04,4.04,4.14,10.54.34,14.72L4.49,3.78C6.52,1.94,9.09,1,11.66,1c2.73,0,5.46,1.04,7.54,3.12ZM4.12,19.21C.08,15.17-.03,8.67,3.78,4.49l15.05,15.05c-4.18,3.81-10.68,3.71-14.72-.34Z"/>
            </g>
          </svg>
          
          <span>No Minimums</span>
        </div>

        <div class="pdpRelatedProducts__iconItem">
          <svg id="Layer_1" data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 130.62 130.62">
            <circle cx="104.43" cy="93.08" r="12.1" fill="none" stroke="#000" stroke-miterlimit="10" stroke-width="4"/><circle cx="38.76" cy="93.08" r="12.1" fill="none" stroke="#000" stroke-miterlimit="10" stroke-width="4"/><path d="M50.86,93.08h30.72V27.55c0-1.17-.94-2.11-2.11-2.11H7.96c-1.17,0-2.11.94-2.11,2.11v65.53h20.82" fill="none" stroke="#000" stroke-miterlimit="10" stroke-width="4"/><polyline points="81.58 34.79 109.43 34.79 124.77 66.13 124.77 93.08 116.52 93.08" fill="none" stroke="#000" stroke-miterlimit="10" stroke-width="4"/><line x1="5.85" y1="71.08" x2="81.58" y2="71.08" fill="none" stroke="#000" stroke-miterlimit="10" stroke-width="4"/><polyline points="124.77 66.13 92.58 66.13 92.58 43.87 114.32 43.87" fill="none" stroke="#000" stroke-miterlimit="10" stroke-width="4"/><line x1="81.58" y1="93.08" x2="92.33" y2="93.08" fill="none" stroke="#000" stroke-miterlimit="10" stroke-width="4"/>
          </svg>
          <span style="font-weight: normal;">
            Earliest Delivery<br>
            <span style="color: #47bf56; font-weight: 600;">Tomorrow</span>
          </span>
        </div>
      </div>
    </div>
  {% endif %}

  <div class="swiperMainProducts">
    <div class="pdpRelatedProducts__pList">
      {%- assign apparelProductChild__count = 1 -%}
      {% for ppp in ss.p_list %}
        {% if ppp.available %}
        <div class="pdpRelatedProducts__pItem" pid="{{ ppp.id }}" handle="{{ ppp.url }}">
          <div class="pdpRelatedProducts__pItem__img">
            <img src="{{ ppp.featured_image | image_url: width: 300 }}" alt="{{ ppp.title | escape }}" class="pdpRelatedProducts__pItem__triggerAction" loading="lazy" />
          </div>
          <div class="pdpRelatedProducts__pItem__content">
            <h4 class="pdpRelatedProducts__pItem__title">{{ ppp.title }}</h4>
            <span class="pdpRelatedProducts__pItem__startFrom">starting at</span>
            <div class="pdpRelatedProducts__pItem__price">
              {{ ppp.price_min | money_without_currency | prepend: '$' }}
            </div>
            <div class="pdpRelatedProducts__pItem__yotpo">
              <div
                class="yotpo-widget-instance"
                data-yotpo-instance-id="447610"
                data-yotpo-product-id="{{ ppp.id }}"
                data-yotpo-section-id="{{ section.id }}"
                data-yotpo-preloaded-data=""
              ></div>
            </div>

            <div class="pdpRelatedProducts__pItem__pCode">{{ ppp.metafields.blanks.second_title_for_blanks }}&nbsp;</div>
            {%- comment -%}
              <span class="pdpRelatedProducts__pItem__triggerAction">Add</span>
            {%- endcomment -%}
          </div>
          <div class="pdpRelatedProducts__pItem__atc">
            <button class="pdpRelatedProducts__pItem__triggerAction button">{{ section.settings.button_text }}</button>
          </div>

          <div class="pdpRelatedProducts__popUp hidden">
            <svg class="pdpRelatedProducts__popUp__close" viewBox="0 0 32 32" data-chk="attr" xmlns="http://www.w3.org/2000/svg">
              <defs><style>.cls-1{fill:none;stroke:#000;stroke-linecap:round;stroke-linejoin:round;stroke-width:2px;}</style></defs><title/><g id="cross"><line class="cls-1" x1="7" x2="25" y1="7" y2="25"/><line class="cls-1" x1="7" x2="25" y1="25" y2="7"/></g>
            </svg>
            {% if apparelProductChild__count == 1 %}
              {%- assign showData = true -%}
              {%- assign apparelProductChild__count = apparelProductChild__count | plus: 1 -%}
            {% else %}
              {%- assign showData = false -%}
              {%- assign apparelProductChild__count = apparelProductChild__count | plus: 1 -%}
            {% endif %}
            {% render 'related_product_info', prod_: ppp, section: section, showJSData: showData %}
          </div>
        </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  {% if ss.bottomLabel != blank and ss.bottomLink != blank %}
    <div class="pdpRelatedProducts__bottomLink">
      <a href="{{ ss.bottomLink }}">
        <span>{{ ss.bottomLabel }}</span>
        <span aria-hidden="true" class="button__icon">
          <svg width="21" height="9" viewBox="0 0 21 9" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M20.354 4.854a.5.5 0 0 0 0-.708L17.172.964a.5.5 0 1 0-.707.708L19.293 4.5l-2.828 2.828a.5.5 0 1 0 .707.708l3.182-3.182ZM0 5h20V4H0v1Z" fill="#27a6ff">
          </svg>
        </span>
      </a>
    </div>
  {% endif %}
</div>
{{ 'swiper-bundle-v12.min.css' | asset_url | stylesheet_tag }}
{%- comment -%}
  <link rel="stylesheet" href="{{ 'slick.css' | asset_url }}">
  <script src="{{ 'slick.min.js' | asset_url }}"></script>
