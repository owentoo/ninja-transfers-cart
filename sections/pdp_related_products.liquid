      });
    });

    // Buy Now function
    $popup.on('click', '.bottom__popUp .buy-now', function() {
      var variantId = $(this).attr('data-variantid');
      window.location.href = '/checkout?variant=' + variantId + '&quantity=1';
    });
  });
</script>