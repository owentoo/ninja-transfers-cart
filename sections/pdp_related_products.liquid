{{ 'swiper-bundle-v12.min.js' | asset_url | script_tag }}
{% if ss.makeSlider %}
  <link rel="stylesheet" href="{{ 'slick.css' | asset_url }}">
  <script src="{{ 'slick.min.js' | asset_url }}"></script>

  <style>
    .underCTA .pdpRelatedProducts__pList .slick-arrow {
      position: absolute;
      top: 50%;
      width: 30px;
      height: 30px;
      z-index: 10;
      background-color: #fff;
      border-radius: 999px;
      transform: translateY(-50%);
      cursor: pointer;
      display: grid;
      align-items: center;
      box-shadow: 0 0 3px #999;
    }
    .underCTA .pdpRelatedProducts__pList .slick-arrow.slick-disabled {
      cursor: default;
      opacity: 0;
    }
    .underCTA .pdpRelatedProducts__pList .slick-arrow svg {
      margin: auto;
    }
    .underCTA .pdpRelatedProducts__pList .slick-prev {
      left: 10px;
    }
    .underCTA .pdpRelatedProducts__pList .slick-next {
      right: 10px;
    }
    .pdpRelatedProducts__pItem {
      margin-right: 10px;
    }
  </style>
{% endif %}

<script>
  $(document)
    .ready(function() {
      loadRelatedProducts( 'ready' );
    })
    .on(`click`, `.pdpRelatedProducts__pItem__triggerAction`, async function (e) {
      try {
        e.stopImmediatePropagation();
        $(`body`).addClass(`setOverlay`);
        const currNode = $(this);
        const yotpoHTML = currNode.closest(`.pdpRelatedProducts__pItem`).find(`.pdpRelatedProducts__pItem__yotpo`).html();

        const getPopupHTML = currNode.closest(`.pdpRelatedProducts__pItem`).find(`.pdpRelatedProducts__popUp`).html();
        const currentPID = currNode.closest(`.pdpRelatedProducts__pItem`).find(`.pdpRelatedProducts__popUp .relatedPopup`).attr(`pid`);
        $(`body`).append(`<div class="bottom__popUp">${ getPopupHTML }</div>`);
        var _cv = $('.bottom__popUp .swiper-wrapper .variant-image').index();
        var _price_node = $('.bottom__popUp .pdp-product-price-t');
        //$('.bottom__popUp .pdp-product-price').remove();
        $('.bottom__popUp .price_node').append(_price_node);
        $('.bottom__popUp .ratting_yopto').append(yotpoHTML);
        
        
        _slickObj = $('.bottom__popUp .swiper-wrapper').slick({
          prevArrow : $('.bottom__popUp .main-slider').find(".swiper-button-prev"),
          nextArrow : $('.bottom__popUp .main-slider').find(".swiper-button-next")
        });
        _slickObj.slick('slickGoTo', _cv);

        // window[`swiperMain_${ currentPID }`], window[`swiperThumbs_${ currentPID }`];
      } catch (err) {
        console.log(`ERROR .pdpRelatedProducts__pItem__triggerAction`, err.message);
      }
    })
    .on(`click`, `.pdpRelatedProducts__popUp__close,.bottom__popUp .p_bck`, function (e) {
      try {
        e.stopImmediatePropagation();
        // $( this ).closest( `.pdpRelatedProducts__pItem` ).find( `.pdpRelatedProducts__popUp` ).addClass( `hidden` );
        console.log(_slickObj," :_slickObj");
        //_slickObj.unslick();
        $(`body .bottom__popUp`).remove();
        $(`body`).removeClass(`setOverlay`);
      } catch (err) {
        console.log(`ERROR .pdpRelatedProducts__popUp__close`, err.message);
      }
    })

    .on(`keyup`, `.pdpRelatedProducts__popUp:not(.hidden) input.itemQuantity`, function (e) {
      try {
        e.stopImmediatePropagation();
        lineItems = [];
        $('.pdpRelatedProducts__popUp:not(.hidden) input.itemQuantity').each(function () {
          const quantity = parseInt($(this).val());
          const vid = $(this).attr(`data-id`) * 1;
          const color = $(this)
            .closest(`.relatedPopup__content__variants`)
            .find(`.colorOptions .colorOption .colorButton.selected`)
            .attr(`title`);

          if (quantity > 0) {
            lineItems.push({
              id: vid,
              quantity: quantity,
              properties: {
                Color: `${color}`,
              },
            });
          }
        });

        if (lineItems.length > 0) {
          console.log('lineItems', lineItems);
        }
      } catch (err) {
        console.log(`ERROR `, err.message);
      }
    })
    .on(`click`, `.colorOptionsLimitedViewAll`, function (e) {
      try {
        e.stopImmediatePropagation();
        const isColorsHidden = $(this).prev(`.colorOptions`).hasClass(`colorOptionsLimited`);
        if (isColorsHidden) {
          $(this).prev(`.colorOptions`).removeClass(`colorOptionsLimited`);
          $(this).find(`text`).text(`Hide`).next(`span`).addClass(`hidden`);
        } else {
          $(this).prev(`.colorOptions`).addClass(`colorOptionsLimited`);
          $(this).find(`text`).text(`Show`).next(`span`).removeClass(`hidden`);
        }
      } catch (err) {
        console.log(`ERROR .colorOptionsLimitedViewAll`, err.message);
      }
    })

    .on(`click`, `.toast.active .close`, function( e ) {
      try {
        e.stopImmediatePropagation();
        $( this ).closest( `.toast` ).removeClass( `active` );
      } catch ( err ) {
        console.log( `ERROR .toast.active .close`, err.message );
      }
    })
    ;

  window.addEventListener('load',function () {
    loadRelatedProducts( 'afterLoad' );
  });

  async function addToCartPopup() {
    const items = [];
    $('.bottom__popUp input.itemQuantity').each(function () {
      const quantity = parseInt($(this).val());
      const vid = $(this).attr(`data-id`) * 1;
      const color = $(this)
        .closest(`.relatedPopup__content__variants`)
        .find(`.colorOptions .colorOption .colorButton.selected`)
        .attr(`title`);

      if (quantity > 0) {
        items.push({
          id: vid,
          quantity: quantity,
          properties: {
            Color: `${color}`,
          },
        });
      }
    });

    if (items.length > 0) {
      $(`.bottom__popUp .addToCartSection span.button`).addClass(`working`);
      $(`.bottom__popUp .errorMessages`).hide();
      console.log('lineItems +++', items);

      await fetch(window.Shopify.routes.root + 'cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ items }),
      })
        .then((response) => {
          return response.json();
        })
        .catch((error) => {
          console.error('Error:', error);
        });

      refreshCart( `notOpen` );

      setTimeout(() => {
        $(`.bottom__popUp .addToCartSection span.button`).removeClass(`working`);
        const isToast = $( `.bottom__popUp .toast` ).length;
        if ( isToast > 0 ) {
          $( `.bottom__popUp .toast` ).addClass( `active` );

          setTimeout(() => {
            $( `.bottom__popUp .toast` ).removeClass( `active` );
          }, 5000);
        } else {
          $( `.bottom__popUp` )
            .append( `
              <div class="toast">
                <div class="toast-content">
                  <svg  class="fas fa-solid fa-check check" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path d="M9 22l-10-10.598 2.798-2.859 7.149 7.473 13.144-14.016 2.909 2.806z"/></svg>
                    <div class="message">
                    <span class="text text-1">Added</span>
                    <span class="text text-2">Product successfully added to your cart</span>
                  </div>
                </div>
                <svg class="fa-solid fa-xmark close" width="24px" height="24px" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6 6L18 18" stroke="#000" stroke-linecap="round"></path><path d="M18 6L6.00001 18" stroke="#000" stroke-linecap="round"></path></svg>

                <!-- Remove 'active' class, this is just to show in Codepen thumbnail -->
                <div class="progress active"></div>
              </div>
              ` );

              setTimeout(() => {
                $( `.bottom__popUp .toast` ).addClass( `active` );
              }, 50);

          setTimeout(() => {
            $( `.bottom__popUp .toast` ).removeClass( `active` );
            setTimeout(() => {
              $( `.bottom__popUp .toast` ).remove();
            }, 100);
          }, 5000);
        }
      }, 300);
    } else {
      $(`.bottom__popUp .errorMessages`).show();
    }

    $( `.bottom__popUp input.itemQuantity` ).val( '' );
  }

  async function loadVariantsPopup(this_, color, productHandle) {
    try {
      const main = $(this_).closest(`.relatedPopup__content__variants`);
      const currentPID = $(this_).closest(`.relatedPopup`).attr(`pid`);

      const makeURL = `/pages/popup-blanks-pdp-helper?variant=${encodeURIComponent(color)}_0_${productHandle}`;
      console.log('makeURL', makeURL);

      const getData = await getRequest(`${makeURL}`);
      if (typeof getData !== 'undefined' && getData) {
        console.log('getData', getData);
        if (typeof getData.sizes !== 'undefined' && getData.sizes) {
          main.find(`.variantsData`).html(getData.sizes);
        }

        const makeVarforMainImg = window[`swiperMain_${currentPID}`];
        let swiperMain = makeVarforMainImg;

        swiperMain = new Swiper(`.bottom__popUp .main-slider[pid="${currentPID}"]`, {
          spaceBetween: 10,
          pagination: {
            clickable: true
          },
          navigation: {
            nextEl: '.swiper-button-next',
            prevEl: '.swiper-button-prev'
          }
        });

        if (typeof getData.mainImgs !== 'undefined' && getData.mainImgs) {
          const getAvailableLength = $(
            `.bottom__popUp .swiper-container.main-slider .swiper-wrapper .swiper-slide`
          ).length;
          for (let i = 0; i < getAvailableLength; i++) {
            swiperMain.removeSlide($(`.bottom__popUp .main-slider[pid="${currentPID}"]`).length - 1);
            // thumb.removeSlide($( `.bottom__popUp .swiper-container-thumbs[pid="${ currentPID }"]` ).length-1);
          }
          getData.mainImgs.forEach((o) => {
            swiperMain.appendSlide(o.slide);
          });
        }
      }

      const getBtnStyles = $(this_).find(`.colorButton`).attr(`style`);

      main.find(`.selectedColor .style-name`).text(color);
      main.find(`.selectedColor [type="button"]`).attr(`style`, getBtnStyles);

      main.find(`.colorOptions .colorOption .colorButton`).removeClass(`selected `);

      $(this_).find(`.colorButton`).addClass(`selected`);
    } catch (err) {
      console.log(`ERROR loadVariantsPopup( this_, color, productHandle )`, err.message);
    }
  }
  $(window).resize(function () {
    resizerWidthAdjustment();
  });

  function resizerWidthAdjustment() {
    try {
      let getPanelWidth = $( `product-page .product-text` ).width();
      const getBodyWidth = $( `body` ).width();
      const getExactFullWidth = $( `main-header .header__bottom.container--large .site-nav.style--classic` ).width();
      if ( getBodyWidth < 1400 ) {
        const getGalleryWidth = $( `product-page .product-gallery` ).width();
        const get40Percent = ( getBodyWidth / 100 ) * 40;
        // console.log ( 'getBodyWidth', getBodyWidth - get40Percent );
        $( `.underCTA` ).css( `max-width`, `${ getExactFullWidth - getGalleryWidth - 40 }px` );
      } else {
        $( `.underCTA` ).css( `max-width`, `${ getPanelWidth }px` );
      }
      if ( typeof readjustSelectedBar === 'function' ) {
        readjustSelectedBar();
      }
    } catch ( err ) {
      console.log( `ERROR resizerWidthAdjustment()`, err.message );
    }
  }

  async function loadRelatedProducts( loadType='' ) {
    let productRightPanel = $(`product-page .product-text`);
    if ( loadType == 'ready' ) {
      const getPanelWidth = $( `product-page .product-text` ).width();
      productRightPanel.append(`<div class="underCTA inactive hidden" style="max-width: ${ getPanelWidth }px;">&nbsp;</div>`);
    }

    setTimeout(() => {
      if ( loadType == 'ready' ) {
        const secHTML = $(`.pdpRelatedProducts`).html();
        $(`.underCTA`).html(`<div class="pdpRelatedProducts">${secHTML}</div>`);
      }
      if ( loadType == 'afterLoad' ) {
        $(`#shopify-section-{{ section.id }} .pdpRelatedProducts__pList .pdpRelatedProducts__pItem`).each(function () {
          const cardPID = $( this ).attr( `pid` );
          const ratingHTML = $( this ).find( `.pdpRelatedProducts__pItem__content .pdpRelatedProducts__pItem__yotpo` ).html();
          $( `.underCTA .pdpRelatedProducts__pItem[pid="${ cardPID }"] .pdpRelatedProducts__pItem__content .pdpRelatedProducts__pItem__yotpo` ).html( ratingHTML );
        });
        $(`.underCTA .pdpRelatedProducts__pList .pdpRelatedProducts__pItem`).each(function () {
          let getReviewText = $(this)
            .find(`.yotpo-sr-bottom-line-right-panel .yotpo-sr-bottom-line-text.yotpo-sr-bottom-line-text--right-panel`)
            .text()
            .trim();
          getReviewText = getReviewText.replace(`Reviews`, ``);
          getReviewText = getReviewText.replace(`Review`, ``);
          $(this)
            .find(`.yotpo-sr-bottom-line-right-panel .yotpo-sr-bottom-line-text.yotpo-sr-bottom-line-text--right-panel`)
            .text(`(${getReviewText})`);
        });
        // $(`.pdpRelatedProducts.hidden`).remove();
        resizerWidthAdjustment();
      }

      $(`.underCTA .pdpRelatedProducts__pList .pdpRelatedProducts__pItem`).each(function () {
        let getReviewText = $(this).find(`.yotpo-sr-bottom-line-right-panel .yotpo-sr-bottom-line-text.yotpo-sr-bottom-line-text--right-panel`).text().trim();
        getReviewText = getReviewText.replace(`Reviews`, ``);
        getReviewText = getReviewText.replace( `(`, `` )
        getReviewText = getReviewText.replace( `)`, `` )
        getReviewText = getReviewText.replace( ` `, `` )
        getReviewText = getReviewText.replace(`Review`, ``);
        // console.log ( 'getReviewText', getReviewText );
        $(this).find(`.yotpo-sr-bottom-line-right-panel .yotpo-sr-bottom-line-text.yotpo-sr-bottom-line-text--right-panel`).text(`(${ getReviewText })`);
      });
    }, 200);

    await addDelay(300);

    const relatedProductsArr = document.querySelectorAll( `.underCTA .pdpRelatedProducts__pList .pdpRelatedProducts__pItem` );

    // console.log('relatedProductsArr', relatedProductsArr.length);

    if ( loadType == 'afterLoad' ) {
      for await (const el of relatedProductsArr) {
      }
      productRightPanel.find(`.underCTA`).removeClass( `inactive` );
    }

    if ( typeof addClassToWidget !== 'undefined' && addClassToWidget ) {
      productRightPanel.find(`.underCTA`).removeClass( `inactive` );
    } else {
      productRightPanel.find(`.underCTA`).removeClass( `hidden inactive` );
    }

    {% if ss.makeSlider %}
      await addDelay( 100 );
      if ( typeof addClassToWidget === 'undefined' ) {
        addSlickSlider__();
      }
    {% endif %}
  }


  function addSlickSlider__() {
    try {
      $( `.underCTA .pdpRelatedProducts .pdpRelatedProducts__pList` ).slick({
          dots: false,
          arrows: true,
          prevArrow: '<button type="button" class="slick-prev pull-left"><svg width="7px" height="9px" viewBox="0 0 7 9" version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"><g id="Page-1" stroke="none" stroke-width="1" fill="none" fill-rule="evenodd"><polygon id="Triangle" fill="#000000" transform="translate(3.5, 4.5) rotate(-90) translate(-3.5, -4.5)" points="3.5 1 8 8 -1 8"></polygon></g></svg></button>',
          nextArrow: '<button type="button" class="slick-next pull-right"><svg width="7px" height="9px" viewBox="0 0 7 9" version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"><g id="Page-1" stroke="none" stroke-width="1" fill="none" fill-rule="evenodd"><polygon id="Triangle" fill="#000000" transform="translate(3.5, 4.5) rotate(90) translate(-3.5, -4.5)" points="3.5 1 8 8 -1 8"></polygon></g></svg></button>',
          infinite: false,
          slidesToShow: 4.5,
