      $(this).hide();
      pNode.find(".second").show();
      pNode.find(".product-description").removeClass("hidden");
    })
    $popup.on('click', '._tndesc', function(event) {
      var pNode = $(this).parents(".desc-wrapper");
      $(this).hide();
      pNode.find(".first").show();
      pNode.find(".product-description").addClass("hidden");
    })
    
    $popup.on('click', '.bottom__popUp .variant-pill', function(event) {
      event.preventDefault();
      var variantId = $(this).data('variantid');
      var price = $(this).data('price');
      var imageSrc = $(this).data('image');
      console.log(imageSrc,"imageSrc")
      // Update price and image
      $('.bottom__popUp .price-value').html(price);
      $('.bottom__popUp .variant-image img').attr('src', imageSrc);
      var _kv = $('.bottom__popUp .variant-image:not(.slick-cloned)').index() - 1;
      console.log(_kv,$(this))
      _slickObj.slick('slickGoTo', _kv);
      // Update buttons
      $('.bottom__popUp .add-to-cart, .buy-now').attr('data-variantid', variantId);

      // Update active class
      $('.bottom__popUp .variant-pill').removeClass('active');
      $(this).addClass('active');
      
    });

    
    $popup.on('click', '.related-pdp-box[pid] .qty-btn', function() {
      var __currentVal = 0;
      var $input = "";
      $input = $(this).parents(".quantity-selector").find(".quantity-input");
      __currentVal = parseInt($input.text());
      var q_ty = 0;
      if ($(this).hasClass('increase')) {
        q_ty = __currentVal + 1;
        $input.text(q_ty);
      } else if ($(this).hasClass('decrease') && __currentVal > 1) {
        q_ty = __currentVal - 1;
        $input.text(q_ty);
      }
    });
    
  $(document).ready(function() {
  const editableDiv = $('.bottom__popUp .quantity-input');

  // Focus styles and handling
  editableDiv.on('focus', function() {
    $(this).addClass('focused');
  });

  // Remove focus styles and log value on blur
  editableDiv.on('blur', function() {
    $(this).removeClass('focused');
  });

  // Prevent line breaks (act like an input box)
  editableDiv.on('keypress', function(event) {
    if (event.key === 'Enter') {
      event.preventDefault(); // Stop line break
    }
  });

  editableDiv.on('focus', function() {
    if ($(this).text() === 'Type here...') {
      $(this).text('');
    }
  });

  // Placeholder text if empty
  editableDiv.on('blur', function() {
    if ($(this).text().trim() === '') {
      $(this).text('Type here...');
    }
  });

  // Synchronize div content with a variable (or backend)
  editableDiv.on('input', function() {
    console.log('Current input:', $(this).text());
  });
});
    
