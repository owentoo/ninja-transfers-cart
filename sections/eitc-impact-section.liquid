{% comment %}
  Ninja Transfers - EITC Impact Section
  - Forcefully uses INTER font via Google Fonts
  - FULLY EDITABLE Typography: Size, Weight, and Transform for EVERY text block
  - Removed global formatting ties and hardcoded classes
  - Features editable Custom Icons for cards
  - Removed bottom Details CTA link
{% endcomment %}

<!-- Load Full Inter Font Family (Weights 100-900) -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">

<!-- Added defer to address Shopify 'ParserBlockingScript' warning -->
<script src="https://cdn.tailwindcss.com" defer></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

{% style %}
  /* GLOBAL FONT FORCE: INTER */
  #shopify-section-{{ section.id }} {
    font-family: 'Inter', sans-serif;
    color: #111111;
  }

  /* Force font family on all text elements */
  #shopify-section-{{ section.id }} h1,
  #shopify-section-{{ section.id }} h2,
  #shopify-section-{{ section.id }} h3,
  #shopify-section-{{ section.id }} h4,
  #shopify-section-{{ section.id }} h5,
  #shopify-section-{{ section.id }} h6,
  #shopify-section-{{ section.id }} p,
  #shopify-section-{{ section.id }} a,
  #shopify-section-{{ section.id }} span,
  #shopify-section-{{ section.id }} li,
  #shopify-section-{{ section.id }} button,
  #shopify-section-{{ section.id }} input,
  #shopify-section-{{ section.id }} label,
  #shopify-section-{{ section.id }} div {
    font-family: 'Inter', sans-serif !important;
  }

  /* FIX RICH TEXT FORMATTING (Allow bold/italic to work if set in Rich Text editor) */
  #shopify-section-{{ section.id }} strong,
  #shopify-section-{{ section.id }} b {
    font-weight: 700;
  }
  #shopify-section-{{ section.id }} em {
    font-style: italic;
  }
  /* Target i tags for italics but exclude all FontAwesome icon classes */
  #shopify-section-{{ section.id }} i:not(.fa):not(.fas):not(.far):not(.fab):not(.fa-solid):not(.fa-regular):not(.fa-brands) {
    font-style: italic;
  }

  /* --- DYNAMIC TYPOGRAPHY SETTINGS --- */

  /* Hero Title Part 1 */
  #shopify-section-{{ section.id }} .hero-title-1 {
    font-size: {{ section.settings.hero_title_1_size_mobile }}px;
    font-weight: {{ section.settings.hero_title_1_weight }};
    text-transform: {{ section.settings.hero_title_1_transform }};
    line-height: 1.1;
    display: block;
  }

  /* Hero Title Part 2 */
  #shopify-section-{{ section.id }} .hero-title-2 {
    font-size: {{ section.settings.hero_title_2_size_mobile }}px;
    font-weight: {{ section.settings.hero_title_2_weight }};
    text-transform: {{ section.settings.hero_title_2_transform }};
    line-height: 1.1;
    display: block;
  }

  /* Hero Description */
  #shopify-section-{{ section.id }} .hero-desc {
    font-size: {{ section.settings.hero_desc_size_mobile }}px;
    font-weight: {{ section.settings.hero_desc_weight }};
    text-transform: {{ section.settings.hero_desc_transform }};
    line-height: 1.5;
  }

  /* Primary Button */
  #shopify-section-{{ section.id }} .btn-primary {
    font-size: {{ section.settings.btn_size_mobile }}px;
    font-weight: {{ section.settings.btn_weight }};
    text-transform: {{ section.settings.btn_transform }};
  }

  /* Impact Value */
  #shopify-section-{{ section.id }} .impact-val {
    font-size: {{ section.settings.impact_val_size_mobile }}px;
    font-weight: {{ section.settings.impact_val_weight }};
    text-transform: {{ section.settings.impact_val_transform }};
    line-height: 1;
  }

  /* Impact Label */
  #shopify-section-{{ section.id }} .impact-label {
    font-size: {{ section.settings.impact_label_size_mobile }}px;
    font-weight: {{ section.settings.impact_label_weight }};
    text-transform: {{ section.settings.impact_label_transform }};
    line-height: 1.2;
  }

  /* Partner Heading */
  #shopify-section-{{ section.id }} .partner-heading {
    font-size: {{ section.settings.partner_title_size_mobile }}px;
    font-weight: {{ section.settings.partner_title_weight }};
    text-transform: {{ section.settings.partner_title_transform }};
  }

  /* Details Tagline */
  #shopify-section-{{ section.id }} .details-tagline {
    font-size: {{ section.settings.details_label_size_mobile }}px;
    font-weight: {{ section.settings.details_label_weight }};
    text-transform: {{ section.settings.details_label_transform }};
    display: block;
    margin-bottom: 1rem;
  }

  /* Details Heading */
  #shopify-section-{{ section.id }} .details-heading {
    font-size: {{ section.settings.details_title_size_mobile }}px;
    font-weight: {{ section.settings.details_title_weight }};
    text-transform: {{ section.settings.details_title_transform }};
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  /* Details Body */
  #shopify-section-{{ section.id }} .details-body {
    font-size: {{ section.settings.details_body_size_mobile }}px;
    font-weight: {{ section.settings.details_body_weight }};
    text-transform: {{ section.settings.details_body_transform }};
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  /* Card Title */
  #shopify-section-{{ section.id }} .card-title {
    font-size: {{ section.settings.card_title_size_mobile }}px;
    font-weight: {{ section.settings.card_title_weight }};
    text-transform: {{ section.settings.card_title_transform }};
    margin-bottom: 0.5rem;
  }

  /* Card Body */
  #shopify-section-{{ section.id }} .card-body {
    font-size: {{ section.settings.card_body_size_mobile }}px;
    font-weight: {{ section.settings.card_body_weight }};
    text-transform: {{ section.settings.card_body_transform }};
    line-height: 1.5;
  }

  /* DESKTOP MEDIA QUERY */
  @media (min-width: 1024px) {
    #shopify-section-{{ section.id }} .hero-title-1 { font-size: {{ section.settings.hero_title_1_size }}px; }
    #shopify-section-{{ section.id }} .hero-title-2 { font-size: {{ section.settings.hero_title_2_size }}px; }
    #shopify-section-{{ section.id }} .hero-desc { font-size: {{ section.settings.hero_desc_size }}px; }
    #shopify-section-{{ section.id }} .btn-primary { font-size: {{ section.settings.btn_size }}px; }
    #shopify-section-{{ section.id }} .impact-val { font-size: {{ section.settings.impact_val_size }}px; }
    #shopify-section-{{ section.id }} .impact-label { font-size: {{ section.settings.impact_label_size }}px; }
    #shopify-section-{{ section.id }} .partner-heading { font-size: {{ section.settings.partner_title_size }}px; }
    #shopify-section-{{ section.id }} .details-tagline { font-size: {{ section.settings.details_label_size }}px; }
    #shopify-section-{{ section.id }} .details-heading { font-size: {{ section.settings.details_title_size }}px; }
    #shopify-section-{{ section.id }} .details-body { font-size: {{ section.settings.details_body_size }}px; }
    #shopify-section-{{ section.id }} .card-title { font-size: {{ section.settings.card_title_size }}px; }
    #shopify-section-{{ section.id }} .card-body { font-size: {{ section.settings.card_body_size }}px; }
  }


  /* Branding Colors */
  #shopify-section-{{ section.id }} .ninja-dark-bg { background-color: {{ section.settings.dark_bg_color }}; }
  #shopify-section-{{ section.id }} .ninja-blue { background-color: {{ section.settings.accent_color }}; }
  #shopify-section-{{ section.id }} .ninja-blue-text { color: {{ section.settings.accent_color }}; }
  #shopify-section-{{ section.id }} .ninja-blue-hover:hover { filter: brightness(90%); }

  /* Marquee/Carousel */
  .marquee-wrapper {
    overflow: hidden;
    user-select: none;
    display: flex;
    gap: 4rem;
    position: relative;
    padding: 2rem 0;
  }
  .marquee-track {
    display: flex;
    flex-shrink: 0;
    gap: 6rem;
    align-items: center;
    justify-content: space-around;
    min-width: 100%;
    animation: scroll {{ section.settings.marquee_speed }}s linear infinite;
  }
  @keyframes scroll {
    from { transform: translateX(0); }
    to { transform: translateX(calc(-100% - 6rem)); }
  }
  .partner-logo-item {
    filter: grayscale(100%);
    opacity: 0.5;
    transition: all 0.3s ease;
    flex-shrink: 0;
    display: block;
  }
  .partner-logo-item img {
    height: 40px; 
    width: auto;
    object-contain: contain;
  }
  @media (min-width: 1024px) {
    .partner-logo-item img { height: 64px; }
  }
  .partner-logo-item:hover {
    filter: grayscale(0%);
    opacity: 1;
  }
  .btn-shadow { box-shadow: 0 4px 14px 0 rgba(0, 163, 255, 0.3); }
  .carousel-placeholder {
    border: 2px dashed #e2e8f0;
    padding: 3rem;
    text-align: center;
    border-radius: 1rem;
    color: #94a3b8;
    background: #f8fafc;
  }
  html { scroll-behavior: smooth; }

  /* Helper text colors */
  #shopify-section-{{ section.id }} .text-white { color: #ffffff; }
  #shopify-section-{{ section.id }} .text-gray-200 { color: #e5e7eb; }
  #shopify-section-{{ section.id }} .text-gray-400 { color: #9ca3af; }
  #shopify-section-{{ section.id }} .text-gray-500 { color: #6b7280; }
  #shopify-section-{{ section.id }} .text-gray-600 { color: #4b5563; }
  #shopify-section-{{ section.id }} .text-gray-900 { color: #111827; }
  
  /* Rich Text Spacing */
  #shopify-section-{{ section.id }} .rte p { margin-bottom: 1em; }
  #shopify-section-{{ section.id }} .rte p:last-child { margin-bottom: 0; }
{% endstyle %}

<main id="section-{{ section.id }}">
    <!-- Hero Section -->
    <section class="ninja-dark-bg text-white pt-20 pb-28 lg:pt-32 lg:pb-40 relative overflow-hidden">
        
        <!-- Hero Image Background -->
        {% if section.settings.hero_image != blank %}
          <div class="absolute inset-0 z-0">
            {{ section.settings.hero_image | image_url: width: 2500 | image_tag: class: 'w-full h-full object-cover', loading: 'eager' }}
            <div class="absolute inset-0" style="background-color: black; opacity: {{ section.settings.hero_overlay_opacity | divided_by: 100.0 }};"></div>
          </div>
        {% endif %}

        <!-- Graduation Cap Watermark -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 lg:left-auto lg:translate-x-0 lg:right-0 lg:text-right w-full lg:w-1/2 pointer-events-none z-1" 
             style="opacity: {{ section.settings.watermark_opacity | divided_by: 100.0 }};">
            <i class="fa-solid fa-graduation-cap text-[20rem] lg:text-[35rem] text-white rotate-12"></i>
        </div>

        <div class="container mx-auto px-6 relative z-10">
            <div class="flex flex-col lg:flex-row items-center">
                <div class="w-full lg:w-3/5">
                    <div class="mb-8">
                        <span class="hero-title-1">{{ section.settings.hero_title_main }}</span>
                        <span class="hero-title-2" style="color: {{ section.settings.hero_span_color }};">{{ section.settings.hero_title_sub }}</span>
                    </div>
                    <!-- Hero Description -->
                    <div class="hero-desc text-gray-200 mb-12 max-w-xl rte">
                        {{ section.settings.hero_description }}
                    </div>

                    <!-- CTA Button -->
                    <div class="flex flex-wrap gap-4 mb-16">
                        {% if section.settings.btn1_text != blank %}
                        <a href="#partners" class="btn-primary ninja-blue btn-shadow text-white px-10 py-5 rounded-full flex items-center gap-3 ninja-blue-hover transition transform hover:scale-105">
                            {{ section.settings.btn1_text }} <i class="fa-solid fa-arrow-down text-xs"></i>
                        </a>
                        {% endif %}
                    </div>

                    <!-- Impact Highlights -->
                    <div class="flex items-center gap-10">
                        <div class="flex flex-col">
                            <span class="impact-val ninja-blue-text mb-2">{{ section.settings.impact_val_1 }}</span>
                            <p class="impact-label text-gray-400">{{ section.settings.impact_label_1 }}</p>
                        </div>
                        <div class="h-12 w-[1px] bg-gray-700"></div>
                        <div class="flex flex-col">
                            <span class="impact-val text-white mb-2">{{ section.settings.impact_val_2 }}</span>
                            <p class="impact-label text-gray-400">{{ section.settings.impact_label_2 }}</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Partner Carousel -->
    <section id="partners" class="py-16 border-b border-gray-100 overflow-hidden bg-white">
        <div class="container mx-auto px-6">
            <h2 class="partner-heading text-center text-gray-900 mb-6 italic">{{ section.settings.partner_title }}</h2>
            
            {% if section.blocks.size > 0 %}
            <div class="marquee-wrapper">
                <div class="marquee-track">
                    {% for block in section.blocks %}
                        <a href="{{ block.settings.link | default: '#' }}" target="_blank" class="partner-logo-item" {{ block.shopify_attributes }}>
                            {% if block.settings.image != blank %}
                                {{ block.settings.image | image_url: width: 600 | image_tag: 
                                    loading: 'lazy', 
                                    alt: block.settings.title,
                                    class: 'object-contain'
                                }}
                            {% else %}
                                <span class="font-black text-xl text-gray-300 uppercase italic">{{ block.settings.title }}</span>
                            {% endif %}
                        </a>
                    {% endfor %}
                </div>
                <!-- Track duplication -->
                <div class="marquee-track" aria-hidden="true">
                    {% for block in section.blocks %}
                        <a href="{{ block.settings.link | default: '#' }}" target="_blank" class="partner-logo-item">
                            {% if block.settings.image != blank %}
                                {{ block.settings.image | image_url: width: 600 | image_tag: 
                                    loading: 'lazy', 
                                    alt: block.settings.title,
                                    class: 'object-contain'
                                }}
                            {% else %}
                                <span class="font-black text-xl text-gray-300 uppercase italic">{{ block.settings.title }}</span>
                            {% endif %}
                        </a>
                    {% endfor %}
                </div>
            </div>
            {% else %}
                <div class="carousel-placeholder">
                    <i class="fa-solid fa-images text-4xl mb-4 block"></i>
                    <p class="font-bold">Add Carousel Images in the sidebar</p>
                    <p class="text-sm">Upload your partner logos to see them scroll here.</p>
                </div>
            {% endif %}
        </div>
    </section>

    <!-- Details Section -->
    <section class="py-28 bg-gray-50">
        <div class="container mx-auto px-6">
            <div class="max-w-5xl mx-auto">
                <div class="grid lg:grid-cols-2 gap-20 items-center">
                    <div>
                        <span class="details-tagline ninja-blue-text">{{ section.settings.details_label }}</span>
                        <h2 class="details-heading">{{ section.settings.details_title }}</h2>
                        <div class="details-body text-gray-600 rte">
                            {{ section.settings.details_content }}
                        </div>
                    </div>
                    <div class="bg-white p-10 lg:p-14 rounded-[2.5rem] shadow-2xl shadow-gray-200 border border-gray-100">
                        <div class="space-y-10">
                            <div class="flex gap-6">
                                <div class="ninja-blue w-14 h-14 rounded-2xl flex-shrink-0 flex items-center justify-center text-white shadow-xl shadow-blue-500/30">
                                    {% if section.settings.card1_icon != blank %}
                                        {{ section.settings.card1_icon | image_url: width: 60 | image_tag: class: 'w-6 h-6 object-contain', loading: 'lazy' }}
                                    {% else %}
                                        <i class="fa-solid fa-circle-check text-xl"></i>
                                    {% endif %}
                                </div>
                                <div>
                                    <h4 class="card-title text-gray-900">{{ section.settings.card1_title }}</h4>
                                    <div class="card-body text-gray-500 rte">{{ section.settings.card1_text }}</div>
                                </div>
                            </div>
                            <div class="flex gap-6">
                                <div class="ninja-blue w-14 h-14 rounded-2xl flex-shrink-0 flex items-center justify-center text-white shadow-xl shadow-blue-500/30">
                                    {% if section.settings.card2_icon != blank %}
                                        {{ section.settings.card2_icon | image_url: width: 60 | image_tag: class: 'w-6 h-6 object-contain', loading: 'lazy' }}
                                    {% else %}
                                        <i class="fa-solid fa-bolt text-xl"></i>
                                    {% endif %}
                                </div>
                                <div>
                                    <h4 class="card-title text-gray-900">{{ section.settings.card2_title }}</h4>
                                    <div class="card-body text-gray-500 rte">{{ section.settings.card2_text }}</div>
                                </div>
                            </div>
                            <div class="flex gap-6">
                                <div class="ninja-blue w-14 h-14 rounded-2xl flex-shrink-0 flex items-center justify-center text-white shadow-xl shadow-blue-500/30">
                                    {% if section.settings.card3_icon != blank %}
                                        {{ section.settings.card3_icon | image_url: width: 60 | image_tag: class: 'w-6 h-6 object-contain', loading: 'lazy' }}
                                    {% else %}
                                        <i class="fa-solid fa-users text-xl"></i>
                                    {% endif %}
                                </div>
                                <div>
                                    <h4 class="card-title text-gray-900">{{ section.settings.card3_title }}</h4>
                                    <div class="card-body text-gray-500 rte">{{ section.settings.card3_text }}</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

{% schema %}
{
  "name": "EITC Impact Section",
  "settings": [
    {
      "type": "header",
      "content": "Appearance & Branding"
    },
    {
      "type": "color",
      "id": "dark_bg_color",
      "label": "Hero Background Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent (Blue)",
      "default": "#00a3ff"
    },
    {
      "type": "header",
      "content": "Hero Media"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Background Image"
    },
    {
      "type": "range",
      "id": "hero_overlay_opacity",
      "label": "Hero Image Tint Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "watermark_opacity",
      "label": "Graduation Cap Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 15,
      "unit": "%"
    },
    
    /* --- TYPOGRAPHY: HERO TITLE PART 1 --- */
    {
      "type": "header",
      "content": "Text: Hero Title Part 1"
    },
    {
      "type": "inline_richtext",
      "id": "hero_title_main",
      "label": "Text Content",
      "default": "Supporting PA Youth"
    },
    {
      "type": "range",
      "id": "hero_title_1_size",
      "label": "Desktop Size",
      "min": 20,
      "max": 150,
      "step": 2,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "hero_title_1_size_mobile",
      "label": "Mobile Size",
      "min": 10,
      "max": 100,
      "step": 2,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "hero_title_1_weight",
      "label": "Font Weight",
      "options": [
        {"value":"100","label":"Thin"},{"value":"300","label":"Light"},
        {"value":"400","label":"Normal"},{"value":"500","label":"Medium"},
        {"value":"700","label":"Bold"},{"value":"900","label":"Black"}
      ],
      "default": "900"
    },
    {
      "type": "select",
      "id": "hero_title_1_transform",
      "label": "Text Transform",
      "options": [{"value":"none","label":"None"},{"value":"uppercase","label":"Uppercase"},{"value":"capitalize","label":"Capitalize"}],
      "default": "none"
    },

    /* --- TYPOGRAPHY: HERO TITLE PART 2 --- */
    {
      "type": "header",
      "content": "Text: Hero Title Part 2"
    },
    {
      "type": "inline_richtext",
      "id": "hero_title_sub",
      "label": "Text Content",
      "default": "Education via EITC"
    },
    {
      "type": "color",
      "id": "hero_span_color",
      "label": "Text Color",
      "default": "#6b7280"
    },
    {
      "type": "range",
      "id": "hero_title_2_size",
      "label": "Desktop Size",
      "min": 20,
      "max": 150,
      "step": 2,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "hero_title_2_size_mobile",
      "label": "Mobile Size",
      "min": 10,
      "max": 100,
      "step": 2,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "hero_title_2_weight",
      "label": "Font Weight",
      "options": [
        {"value":"100","label":"Thin"},{"value":"300","label":"Light"},
        {"value":"400","label":"Normal"},{"value":"500","label":"Medium"},
        {"value":"700","label":"Bold"},{"value":"900","label":"Black"}
      ],
      "default": "900"
    },
    {
      "type": "select",
      "id": "hero_title_2_transform",
      "label": "Text Transform",
      "options": [{"value":"none","label":"None"},{"value":"uppercase","label":"Uppercase"},{"value":"capitalize","label":"Capitalize"}],
      "default": "none"
    },

    /* --- TYPOGRAPHY: HERO DESCRIPTION --- */
    {
      "type": "header",
      "content": "Text: Hero Description"
    },
    {
      "type": "richtext",
      "id": "hero_description",
      "label": "Text Content",
      "default": "<p>Ninja Transfers is proud to invest in the next generation...</p>"
    },
    {
      "type": "range",
      "id": "hero_desc_size",
      "label": "Desktop Size",
      "min": 12,
      "max": 40,
      "step": 1,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "hero_desc_size_mobile",
      "label": "Mobile Size",
      "min": 10,
      "max": 30,
      "step": 1,
      "default": 18,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "hero_desc_weight",
      "label": "Font Weight",
      "options": [
        {"value":"300","label":"Light"},{"value":"400","label":"Normal"},{"value":"500","label":"Medium"},{"value":"700","label":"Bold"}
      ],
      "default": "400"
    },
    {
      "type": "select",
      "id": "hero_desc_transform",
      "label": "Text Transform",
      "options": [{"value":"none","label":"None"},{"value":"uppercase","label":"Uppercase"},{"value":"capitalize","label":"Capitalize"}],
      "default": "none"
    },

    /* --- TYPOGRAPHY: PRIMARY BUTTON --- */
    {
      "type": "header",
      "content": "Button: Meet Our Partners"
    },
    {
      "type": "text",
      "id": "btn1_text",
      "label": "Label",
      "default": "Meet Our Partners"
    },
    {
      "type": "range",
      "id": "btn_size",
      "label": "Desktop Size",
      "min": 10,
      "max": 30,
      "step": 1,
      "default": 16,
      "unit": "px"
