          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Unmatched Quality"
        },
        {
          "type": "inline_richtext",
          "id": "content",
          "label": "Content",
          "default": "Get unmatched quality in every DTF transfer with premium materials and expert craftsmanship"
