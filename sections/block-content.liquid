{%-liquid
  assign ss = section.settings
  assign sb = section.blocks
-%}
{{ 'blockContent.css' | asset_url | stylesheet_tag }}
{% if sb.size > 0 %}
  <div class="container--large">
    <div class="blockContent">
      {% if ss.title != blank %}
        <div class="blockContent__title titleAlignDesktop__{{ ss.titleAlign_desktop }} titleAlignMobile__{{ ss.titleAlign_desktop }}">
          <{{ ss.titleTag }}>
            {{ ss.title }}
          </{{ ss.titleTag }}>
        </div>
      {% endif %}

      <div class="blockContent__wrap">
        {%- assign collectStyles = '' -%}
        {%- for block in sb -%}
          {%- assign b = block.settings -%}
          <div class="blockContent__item" bid="{{ block.id }}">
            <div class="blockContent__item__iconWrap">
              {% if b.image != blank %}
                <img src="{{ b.image | image_url: width: b.img_width }}">
              {% else %}
                &nbsp;
              {% endif %}
            </div>

            <div class="blockContent__item__content">
              {% if b.title != blank %}
                <div class="blockContent__item__title">
                  {{ b.title }}
                </div>
              {% endif %}
              {% if b.content != blank %}
                <div class="blockContent__item__text">
                  {{ b.content }}
                </div>
              {% endif %}
            </div>

          </div>
          {%- capture collectStyles -%}
            {{ collectStyles }}
          {%- endcapture -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  {%- capture getStyles -%}
    {{ collectStyles }}
    {% if ss.showDots == false %}
      .slick-dots {
        display: none;
      }
    {% endif %}
    #shopify-section-{{ section.id }} {
      margin-top: {{ ss.secMarginTop_desktop | append: 'px' }};
      margin-bottom: {{ ss.secMarginBottom_desktop | append: 'px' }};

      padding-top: {{ ss.secPaddingTop_desktop | append: 'px' }};
      padding-bottom: {{ ss.secPaddingBottom_desktop | append: 'px' }};
    }
    @media (max-width: 1024px) {
      #shopify-section-{{ section.id }} {
        margin-top: {{ ss.secMarginTop_tab | append: 'px' }};
        margin-bottom: {{ ss.secMarginBottom_tab | append: 'px' }};

        padding-top: {{ ss.secPaddingTop_tab | append: 'px' }};
        padding-bottom: {{ ss.secPaddingBottom_tab | append: 'px' }};
      }
    }
    @media (max-width: 600px) {
      #shopify-section-{{ section.id }} {
        margin-top: {{ ss.secMarginTop_mobile | append: 'px' }};
        margin-bottom: {{ ss.secMarginBottom_mobile | append: 'px' }};

        padding-top: {{ ss.secPaddingTop_mobile | append: 'px' }};
        padding-bottom: {{ ss.secPaddingBottom_mobile | append: 'px' }};
      }
    }
    #shopify-section-{{ section.id }} .blockContent__wrap .blockContent__item {
      width: calc( {{ '100' | divided_by: ss.perRow__desktop | append: '%' }} - 20px );
    }
    @media (max-width: 1024px) {
      #shopify-section-{{ section.id }} .blockContent__wrap .blockContent__item {
        width: calc( {{ '100' | divided_by: ss.perRow__tab | append: '%' }} - 20px );
      }
    }
    @media (max-width: 600px) {
      #shopify-section-{{ section.id }} .blockContent__wrap .blockContent__item {
        width: calc( {{ '100' | divided_by: ss.perRow__mobile | append: '%' }} - 20px );
      }
    }
  {%- endcapture -%}
  <style>
    {{ getStyles }}
  </style>
{% endif %}

{% schema %}
{
  "name": "Block Content",
  "class": "can-be-fullwidth merged-section supports-absolute-header",
  "max_blocks": 9,
  "settings": [
