                  </div>
                  <div style="display: flex; justify-content: space-between; margin-bottom: 16px; font-size: 0.875rem;">
                     <span style="color: #6b7280; display: flex; align-items: center; gap: 8px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg> Screen Printer</span>
                     <span style="text-decoration: line-through; color: #9ca3af;">$15,000</span>
                  </div>
                  <div style="border-top: 1px solid #f3f4f6; padding-top: 16px; display: flex; justify-content: space-between; align-items: center; background: #eff6ff; padding: 12px; border-radius: 8px;">
                     <span style="font-weight: 700; color: #1e3a8a; display: flex; align-items: center; gap: 8px;"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg> Your Setup</span>
                     <span style="font-weight: 800; color: #1e3a8a;">Under $300</span>
                  </div>
               </div>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </section>

  <!-- VIDEO -->
  <section class="ninja-section ninja-text-center" style="background-color: {{ section.settings.video_bg_color }}; {% if section.settings.video_bg_image != blank %}background-image: url('{{ section.settings.video_bg_image | image_url: width: 2000 }}');{% endif %} color: {{ section.settings.video_text_color }};">
    <div class="ninja-container">
      <p style="font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 16px; font-size: 0.875rem; opacity: 0.8;">{{ section.settings.video_eyebrow }}</p>
      <h2 class="ninja-h2">{{ section.settings.video_headline }}</h2>
      
      <div style="max-width: 800px; margin: 0 auto 24px auto; background: #111827; border-radius: 12px; overflow: hidden; aspect-ratio: 16/9; position: relative; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);">
        {% if section.settings.video_url != blank %}
          {% if section.settings.video_url.type == 'youtube' %}
            <iframe src="https://www.youtube.com/embed/{{ section.settings.video_url.id }}?rel=0&showinfo=0&modestbranding=1" frameborder="0" allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture" allowfullscreen style="position:absolute; top:0; left:0; width:100%; height:100%;"></iframe>
          {% elsif section.settings.video_url.type == 'vimeo' %}
            <iframe src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}?color=2563eb&title=0&byline=0&portrait=0" frameborder="0" allow="autoplay; fullscreen" allowfullscreen style="position:absolute; top:0; left:0; width:100%; height:100%;"></iframe>
          {% endif %}
        {% else %}
          <div style="position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; color: white;">
            <div style="width: 80px; height: 80px; background: rgba(255,255,255,0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 16px;">
               <div style="width: 60px; height: 60px; background: white; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                 <svg width="30" height="30" viewBox="0 0 24 24" fill="currentColor" style="color: #2563eb; margin-left: 4px;"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
               </div>
            </div>
            <p style="font-weight: 500; font-size: 1.125rem;">Video Placeholder</p>
          </div>
        {% endif %}
      </div>
      <p style="font-size: 0.875rem; font-weight: 500; opacity: 0.8;">{{ section.settings.video_caption }}</p>
    </div>
  </section>

  <!-- BARRIERS -->
  <section class="ninja-section" style="background-color: {{ section.settings.barrier_bg_color }}; {% if section.settings.barrier_bg_image != blank %}background-image: url('{{ section.settings.barrier_bg_image | image_url: width: 2000 }}');{% endif %} color: {{ section.settings.barrier_text_color }};">
    <div class="ninja-container">
      <h2 class="ninja-h2 ninja-text-center" style="margin-bottom: 48px;">{{ section.settings.barrier_headline }}</h2>
      <div class="ninja-grid-3">
        {% for block in section.blocks %}
          {% if block.type == 'barrier' %}
            <div class="ninja-card" style="background-color: {{ block.settings.card_bg_color }}; {% if block.settings.card_bg_image != blank %}background-image: url('{{ block.settings.card_bg_image | image_url: width: 600 }}');{% endif %} text-align: center;">
              <div class="ninja-icon-circle" style="margin: 0 auto 16px auto; background-color: {{ block.settings.icon_bg_color }}; color: #374151;">
                {% if block.settings.icon != blank %}
                  <img src="{{ block.settings.icon | image_url: width: 48 }}" width="24" height="24" style="object-fit: contain;">
                {% else %}
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                {% endif %}
              </div>
              <h3 class="ninja-h3">{{ block.settings.title }}</h3>
              <p class="ninja-text-lg" style="font-size: 1rem;">{{ block.settings.text }}</p>
            </div>
          {% endif %}
        {% endfor %}
      </div>
      <div class="ninja-text-center" style="margin-top: 48px;">
        <h3 style="font-size: 1.5rem; font-weight: 700; color: #1e3a8a;">{{ section.settings.barrier_footer_text }}</h3>
      </div>
    </div>
  </section>

  <!-- PROFIT MATH -->
  <section class="ninja-section" style="background-color: {{ section.settings.math_bg_color }}; {% if section.settings.math_bg_image != blank %}background-image: url('{{ section.settings.math_bg_image | image_url: width: 2000 }}');{% endif %} color: {{ section.settings.math_text_color }};">
    <div class="ninja-container">
      <div class="ninja-text-center" style="margin-bottom: 48px;">
        <h2 class="ninja-h2">{{ section.settings.math_headline }}</h2>
        <p class="ninja-text-lg">{{ section.settings.math_subtext }}</p>
      </div>
      
      <div style="max-width: 900px; margin: 0 auto; background: white; border-radius: 16px; padding: 48px; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1); color: #1f2937;">
        <div style="display: flex; flex-direction: column; gap: 32px;">
           <div style="display: flex; flex-direction: column; gap: 16px; width: 100%;">
              <div style="display: flex; justify-content: space-between; border-bottom: 1px dashed #e5e7eb; padding-bottom: 8px;">
                 <span style="font-weight: 500; color: #4b5563;">{{ section.settings.cost_1_label }}</span>
                 <span style="font-weight: 700;">{{ section.settings.cost_1_value }}</span>
              </div>
              <div style="display: flex; justify-content: space-between; border-bottom: 1px dashed #e5e7eb; padding-bottom: 8px;">
                 <span style="font-weight: 500; color: #4b5563;">{{ section.settings.cost_2_label }}</span>
                 <span style="font-weight: 700;">{{ section.settings.cost_2_value }}</span>
              </div>
              <div style="display: flex; justify-content: space-between; padding-top: 8px;">
                 <span style="font-weight: 800; text-transform: uppercase;">{{ section.settings.total_cost_label }}</span>
                 <span style="font-weight: 800; font-size: 1.25rem;">{{ section.settings.total_cost_value }}</span>
              </div>
           </div>
           
           <div style="text-align: center; color: #9ca3af;">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="transform: rotate(90deg);"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              <div style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase;">Sell For</div>
           </div>

           <div style="background: #eff6ff; padding: 24px; border-radius: 12px; text-align: center; border: 1px solid #dbeafe;">
              <div style="font-size: 0.875rem; font-weight: 700; color: #2563eb; text-transform: uppercase; margin-bottom: 8px;">{{ section.settings.retail_price_label }}</div>
              <div style="font-size: 2.5rem; font-weight: 800; color: #1e3a8a; margin-bottom: 16px;">{{ section.settings.retail_price_value }}</div>
              <div style="display: inline-flex; align-items: center; gap: 8px; background: #dcfce7; color: #166534; padding: 8px 16px; border-radius: 8px; font-weight: 700;">
                 <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>
                 {{ section.settings.profit_value }}
              </div>
           </div>
        </div>
      </div>
      <p class="ninja-text-center" style="margin-top: 24px; font-size: 0.875rem; opacity: 0.8;">{{ section.settings.math_footer }}</p>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="ninja-section" style="background-color: {{ section.settings.how_bg_color }}; {% if section.settings.how_bg_image != blank %}background-image: url('{{ section.settings.how_bg_image | image_url: width: 2000 }}');{% endif %} color: {{ section.settings.how_text_color }};">
    <div class="ninja-container">
      <div class="ninja-text-center" style="margin-bottom: 48px;">
        <div class="ninja-badge">{{ section.settings.how_badge }}</div>
        <h2 class="ninja-h2">{{ section.settings.how_headline }}</h2>
      </div>
      <div class="ninja-grid-3">
        {% for block in section.blocks %}
          {% if block.type == 'step' %}
            <div class="ninja-card" style="background-color: {{ block.settings.card_bg_color }}; {% if block.settings.card_bg_image != blank %}background-image: url('{{ block.settings.card_bg_image | image_url: width: 600 }}');{% endif %} text-align: center;">
              <div class="ninja-num-circle" style="background-color: {{ block.settings.circle_bg_color }}; color: {{ block.settings.circle_text_color }};">
                {{ block.settings.step_number }}
              </div>
              <h3 class="ninja-h3">{{ block.settings.title }}</h3>
              <p class="ninja-text-lg" style="font-size: 1rem;">{{ block.settings.text }}</p>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- SOCIAL PROOF -->
  <section class="ninja-section" style="background-color: {{ section.settings.proof_bg_color }}; {% if section.settings.proof_bg_image != blank %}background-image: url('{{ section.settings.proof_bg_image | image_url: width: 2000 }}');{% endif %} color: {{ section.settings.proof_text_color }};">
    <div class="ninja-container">
      <div class="ninja-text-center" style="margin-bottom: 48px;">
        <h2 class="ninja-h2">{{ section.settings.proof_headline }}</h2>
        <div style="color: #fbbf24; display: flex; justify-content: center; gap: 4px; margin-bottom: 16px;">
          <!-- 5 Stars -->
          <svg width="24" height="24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
          <svg width="24" height="24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
          <svg width="24" height="24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
          <svg width="24" height="24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
          <svg width="24" height="24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
        </div>
      </div>
      <div class="ninja-grid-2">
        {% for block in section.blocks %}
          {% if block.type == 'review' %}
            <div class="ninja-card" style="background-color: {{ block.settings.card_bg_color }}; {% if block.settings.card_bg_image != blank %}background-image: url('{{ block.settings.card_bg_image | image_url: width: 600 }}');{% endif %}">
              <div style="font-size: 3rem; opacity: 0.1; line-height: 1; font-family: serif; position: absolute; top: 16px; right: 24px;">"</div>
              <p style="font-style: italic; margin-bottom: 24px; font-size: 1.125rem; position: relative;">"{{ block.settings.text }}"</p>
              <div style="display: flex; align-items: center; gap: 16px; border-top: 1px solid #e5e7eb; padding-top: 16px;">
                <div style="width: 48px; height: 48px; background: #dbeafe; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; color: #1e40af;">
                  {{ block.settings.author | slice: 0 }}
                </div>
                <div>
                  <div style="font-weight: 700;">{{ block.settings.author }}</div>
                  <div style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; opacity: 0.8; color: #2563eb;">{{ block.settings.role }}</div>
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="ninja-section" style="background-color: {{ section.settings.faq_bg_color }}; color: {{ section.settings.faq_text_color }};">
    <div class="ninja-container" style="max-width: 800px;">
      <h2 class="ninja-h2 ninja-text-center" style="margin-bottom: 40px;">{{ section.settings.faq_headline }}</h2>
      <div style="display: flex; flex-direction: column; gap: 16px;">
        {% for block in section.blocks %}
          {% if block.type == 'faq' %}
            <details style="background: white; border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden;">
              <summary style="padding: 20px; font-weight: 700; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; color: #111827;">
                {{ block.settings.question }}
                <span style="font-size: 1.25rem; color: #9ca3af;">+</span>
              </summary>
              <div style="padding: 0 20px 20px 20px; color: #4b5563;">{{ block.settings.answer }}</div>
            </details>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- RISK REVERSAL -->
  <section class="ninja-section ninja-text-center" style="background-color: {{ section.settings.risk_bg_color }}; color: {{ section.settings.risk_text_color }};">
    <div class="ninja-container" style="max-width: 800px;">
      <div style="display: flex; justify-content: center; margin-bottom: 24px; color: #2563eb;">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="M9 12l2 2 4-4"></path></svg>
      </div>
      <h2 class="ninja-h2">{{ section.settings.risk_headline }}</h2>
      <p class="ninja-text-lg">{{ section.settings.risk_subtext }}</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="ninja-section ninja-text-center" style="background-color: {{ section.settings.cta_bg_color }}; {% if section.settings.cta_bg_image != blank %}background-image: url('{{ section.settings.cta_bg_image | image_url: width: 2000 }}');{% endif %} color: {{ section.settings.cta_text_color }};">
    <div class="ninja-container" style="max-width: 800px;">
      <h2 class="ninja-h2">{{ section.settings.cta_headline }}</h2>
      <p class="ninja-text-lg ninja-mb-12">
        {{ section.settings.cta_subtext }}
      </p>
      
      <div style="display: flex; justify-content: center; gap: 16px; flex-wrap: wrap; margin-top: 32px;">
        <a href="{{ section.settings.cta_btn_link }}" class="ninja-btn ninja-btn-white ninja-btn-xl">{{ section.settings.cta_btn_text }}</a>
        <a href="{{ section.settings.secondary_btn_link }}" class="ninja-btn ninja-btn-outline-white ninja-btn-xl">{{ section.settings.secondary_btn_text }}</a>
      </div>

      <div style="margin-top: 32px; display: flex; justify-content: center; gap: 24px; font-weight: 500; font-size: 0.875rem; opacity: 0.8;">
        <span style="display: flex; alignItems: center; gap: 6px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> No Monthly Fees</span>
        <span style="display: flex; alignItems: center; gap: 6px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> Free Shipping Over $75</span>
        <span style="display: flex; alignItems: center; gap: 6px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> 24/7 Support</span>
      </div>
    </div>
  </section>

</div>