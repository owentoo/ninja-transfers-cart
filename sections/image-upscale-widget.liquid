 {% render "custom-fileupload" %}
      <style>
        .drop-disabled-size,
.drop-disabled-type{
   background-color: #ddd !important;
  border: 2px dashed #888 !important;
  position:relative;
}
.drop-disabled-size:after,
.drop-disabled-type:after{
  content:"Please Your File Should be 5 GB or Less";
  display:block;
  position:absolute;
  top:10px;
  left:10px;
  right:10px; 
  background-color: #c44e47 !important;
  border-radius: 5px;
  color:#fff;
  text-align:center;
  padding: 10px;
  font-size: 12px;
  z-index: 99;
  pointer-events: none;
}
        .drop-disabled-type:after{
  content:"We accept the following file types: JPG, JPEG, SVG, PNG, TIFF, AI, and PDF.";
}
        h1 {
          font-weight:800;
        }
        .drop-zoon--Uploaded .process{
          display:block!important;
        }
        .drop-zoon--Uploaded .processhide{
          display:none !important;
        }
        .fileupload_custom > div{
          border-top:1px solid #ddd;
          border-bottom:1px solid #ddd;
          padding:10px 0;
          display:flex;
          align-items:center;
          justify-content:space-between;
        }
        #fileDetails{
          font-size:20px;
          font-weight:700;
        }
        .buttons{
          display:flex;
          flex-direction:column;
          gap:10px;
          width:350px;
           max-width:100%;
        }
        .fileupload_custom .img_container{
           width:350px;
           max-width:100%; 
               background: #f2f2f2 url(data:image/svg+xml;base64,) center center;

        }
        .img_info{
          max-width:500px;
        }
        #reupload{
          display:flex;
          align-items:center;
          gap:10px;
          text-align:center;
          justify-content:center;
          font-size:18px;
        }
         #reupload svg{
           height:28px;
         }
        #reupload svg path{
          fill:#10A9EA
        }
    
        @media (max-width:768px){
           .fileupload_custom > div{
              flex-direction:column;
           }
        }
         .file-upload-overlay-1-active   .lazy-image img{
          z-index: 1;
        }
        .file-upload-overlay-1-active announcement-bar,
         .file-upload-overlay-1-active .site-header{
          z-index:9 !important;
        }
      </style>                            
                    <!-- Upload Area -->
           <div class="container--large  container--vertical-space" id="upload_area">              
 
                  <div class="file-upload-overlay-1">              
                          <div id="uploadArea" class="upload-area" item-show-on="beforeUpload"> 
                         
                            <!-- Drop Zoon -->
                            <div id="dropZoon" class="upload-area__drop-zoon drop-zoon">
