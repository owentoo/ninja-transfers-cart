{%- assign ss = section.settings -%}
{%- assign sb = section.blocks -%}

{{ 'section-main-product.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="{{ 'transferBySize.css' | asset_url }}">

{% if product.metafields.specs.default_child_color %}
  <script>
    const urlParams = new URLSearchParams(window.location.search);
    const viewParam = urlParams.get('view');
    if (viewParam) {
      const targetUrl = window.location.href.substring(0,window.location.href.indexOf('?')) + '?variant=' + viewParam;
      document.location = targetUrl;
    }
  </script>
{% elsif product.metafields.specs.shirt_color %}
  <script>
    const currentUrl = window.location.href;
    let pos = currentUrl.indexOf("-child");
    if (pos >= 0) {
      const targetUrl = currentUrl.substring(0,pos);
      document.location = targetUrl;
    }
  </script>
{% endif %}

{%- render 'breadcrumb', container: 'large', vertical_space: 'vertical-space', style: 'breadcrumb-main--margin breadcrumb-main--scroll element--hide-on-portable-plus' -%}

{%- capture allVariants -%}
  {% for variant in product.variants %}
    {
      "id": {{ variant.id | json }},
      "title": {{ variant.title | json }},
      {% if variant.featured_image != blank %}
        "thumb": {{ variant.featured_image | image_url: width: 100 | json }},
        "large": {{ variant.featured_image | image_url: width: 1000 | json }},
      {% else %}
        "thumb": null,
        "large": null,
      {% endif %}
      "media_id": {{ variant.featured_media.id | json }},
      "price": {{ variant.price | money_without_currency | json }}
    }
    {%- unless forloop.last -%}
      ,
    {%- endunless -%}
  {% endfor %}
{%- endcapture -%}
<script>
  const allVariants = [{{ allVariants }}];
</script>

{%- liquid
  if section.settings.gallery_desktop_width contains 'one-half'
    if section.settings.gallery_layout contains 'one-col'
      assign gallery_class = 'grid-1'
      assign parent_class = 'grid-2 grid-lap-1'
    else
      assign parent_class = 'grid-4 grid-lap-1'
      assign child_class = 'grid-offset-2 grid-offset-lap-1'
      assign gallery_class = 'grid-2 grid-portable-1'
      assign text_class = 'grid-offset-2 grid-offset-lap-1'
    endif
  else
    assign parent_class = 'grid-3 grid-portable-5 grid-lap-1'
    assign child_class = 'grid-offset-2 grid-offset-portable-3 grid-offset-lap-1'
    assign text_class = 'grid-portable-2 grid-offset-portable-2 grid-offset-lap-1'
    if section.settings.gallery_layout contains 'one-col'
      assign gallery_class = 'grid-1'
    else
      assign gallery_class = 'grid-2 grid-portable-1'
    endif
  endif
-%}

{%- liquid
  unless product.has_only_default_variant
    assign default_to_first_variant = section.settings.default_to_first_variant
  else
    assign default_to_first_variant = true
  endunless
-%}

{%- liquid
  assign selectedProduct = product
  if product.metafields.specs.default_child_color != blank
    assign page_url = content_for_header | split:'"pageurl":"' | last | split:'"' | first | split: request.host | last | replace:'\/','/' | replace:'%20',' ' | replace:'\u0026','&'
    assign param_color = nil

    for i in (1..1)
      unless page_url contains "?"
        break
      endunless
      assign query_string = page_url | split:'?' | last
      assign qry_parts= query_string | split:'&'

      for part in qry_parts
        assign key_and_value = part | split:'='
        if key_and_value.size > 1
          if key_and_value[0] == 'view' or key_and_value[0] == 'variant'
            assign param_color = key_and_value[1] | upcase
          endif
        endif
      endfor
    endfor

    assign style_category = 'style-' | append: product.metafields.specs.shirt_style
    assign style_collection = product.collections | where: "handle", style_category | first

    paginate style_collection.products by 1000
    assign sortedColors = style_collection.products | sort: "url"
    endpaginate

    assign defaultProduct = blank
    assign selectedProduct = blank
    for style_product in sortedColors
      assign shirt_color = style_product.metafields.specs.shirt_color | upcase
      if style_product.metafields.specs.shirt_color == product.metafields.specs.default_child_color
        assign defaultProduct = style_product
      endif
      if param_color and shirt_color == param_color
        assign selectedProduct = style_product
      endif
    endfor

    if selectedProduct == blank
      assign selectedProduct = defaultProduct
    endif
  endif
-%}

<div class="product container container--large container--vertical-space-small {% unless settings.show_breadcrumb %} container--no-space-mobile {% endunless %}">

  <product-page
    id="product-{{ section.id }}"
    class="grid grid--layout grid--gap-xlarge {{ parent_class }} grid--no-stretch main-product"
    data-collection="{{ collection.handle }}" data-id="{{ product.id }}"
    data-availability="{{ product.available }}"
  >

    {%- assign current_variant = product.selected_or_first_available_variant -%}

    <div class="{{ child_class }} element--is-sticky">
      {% if ss.uploadLiftPosition == 'atLeft' %}
        <script src="{{ 'html2canvas.min.js' | asset_url }}"></script>
        <div class="customUploaderView">
          <div class="customUploaderView_detail">
            <div class="customUploaderView__info">
              <div class="customUploaderView__info_left">
                <div class="customUploaderView__info_fileName"></div>
                <div class="customUploaderView__info_fileSize"></div>
              </div>
              <div class="customUploaderView__info_right">
                <div class="customUploaderView__info_status"></div>
                <div class="customUploaderView__info_status2nd"></div>
              </div>
              <span class="customUploaderView__removeFile">
                <svg width="26" height="26" viewBox="0 0 26 26" xmlns="http://www.w3.org/2000/svg"><path d="M11.586 13l-2.293 2.293a1 1 0 0 0 1.414 1.414L13 14.414l2.293 2.293a1 1 0 0 0 1.414-1.414L14.414 13l2.293-2.293a1 1 0 0 0-1.414-1.414L13 11.586l-2.293-2.293a1 1 0 0 0-1.414 1.414L11.586 13z" fill="currentColor" fill-rule="nonzero"></path></svg>
              </span>
            </div>
            <div class="customUploaderView_preview"></div>
          </div>

          <div class="customUploaderView__inputFeild">
            <div class="customUploaderView__inputFeild_label">Notes for our designers</div>
            <textarea class="customUploaderView__inputFeild_textarea" placeholder="ex: Remove background and change the black text to white text. Crop out any unwanted blank space."></textarea>
          </div>
        </div>
        <!-- <span class="btn-Preview-Image">Preview</span> -->
        <style>
          .customUploaderView {
            display: flex;
            gap: 20px;
            visibility: hidden;
            position: absolute;
            margin-bottom: 10px;
          }
          .changeLayout .customUploaderView {
            visibility: visible;
            position: relative;
          }
          .customUploaderView_detail {
            width: 50%;
            background-color: #eeeeee;
            border-radius: 7px;
            padding: 10px;
            overflow: hidden;
          }
          .customUploaderView_detail.imgAvailable .customUploaderView__info {
            background-image: linear-gradient(#369763, #36976312);
            background-color: transparent;
          }
          .customUploaderView__info {
            display: grid;
            grid-template-columns: 50% calc(50% - 30px);
            position: absolute;
            background-color: #369763;
            color: #fff;
            padding: 10px;
            border-radius: 4px;
            z-index: 1;
            width: calc(50% - 30px);
          }
          .customUploaderView__info_right {
            text-align: right;
          }
          .customUploaderView__removeFile {
            position: absolute;
            z-index: 1;
            top: 7px;
            right: 7px;
            width: 26px;
            height: 26px;
            background-color: #1a4930;
            border-radius: 999px;
            cursor: pointer;
            border: 2px solid transparent;
            transition: 0.2s all ease-in-out;
          }
          .customUploaderView__removeFile:hover {
            border-color: #fff;
          }
          .customUploaderView__removeFile svg {
            position: relative;
            transform: translate(-50%, -50%);
            top: 50%;
            left: 50%;
          }
          .customUploaderView__info_fileName,
          .customUploaderView__info_status {
            text-overflow: ellipsis;
            white-space: nowrap;
            width: 100%;
            font-size: .75em;
            line-height: 1.2;
            overflow: hidden;
          }
          .customUploaderView__info_fileSize,
          .customUploaderView__info_status2nd {
            opacity: .5;
            white-space: nowrap;
            font-size: .625em;
            transition: opacity .25s ease-in-out;
          }
          .customUploaderView_preview {
            position: relative;
            border-radius: 4px;
            overflow: hidden;
          }
          .customUploaderView_preview canvas {
            width: 100%;
          }
          .customUploaderView__inputFeild {
            width: 50%;
          }
          .customUploaderView__inputFeild_label {
            font-weight: 700;
            color: #555;
          }
          .customUploaderView__inputFeild_textarea {
            width: 100%;
          }
        </style>
        <script>
          $(document)
          .on(`click`, `.customUploaderView__removeFile`, function( e ) {
            try {
              e.stopImmediatePropagation();
              $( `button.filepond--file-action-button.filepond--action-revert-item-processing` ).click();
              $( '.customUploaderView_preview' ).text( `` );
              $( `.changeLayout [data-upload-lift]` ).show();
              $( `.pdp__block.customDescription.hidden` ).removeClass( `hidden` );
              $( `.customUploaderView_detail` ).removeClass( `imgAvailable` );
            } catch ( err ) {
              console.log( `ERROR .customUploaderView__removeFile`, err.message );
            }
          })

          .on(`keyup blur paste`, `.customUploaderView__inputFeild_textarea`, function( e ) {
            try {
              e.stopImmediatePropagation();
              const getVal = $( this ).val();
              $( `[name="properties[Design Notes]"]` ).val( getVal );
            } catch ( err ) {
              console.log( `ERROR .customUploaderView__inputFeild_textarea`, err.message );
            }
          })
          ;

          function customUploaderView() {
            try {
              const infoWrapper = $( `.filepond--root.cl-upload--area.filepond--hopper .filepond--file-wrapper .filepond--file` );
              const getData = {
                fileName: `${ infoWrapper.find( `.filepond--file-info .filepond--file-info-main` ).text().trim() }`,
                fileSize: `${ infoWrapper.find( `.filepond--file-info .filepond--file-info-sub` ).text().trim() }`,
                fileStatus: `${ infoWrapper.find( `.filepond--file-status .filepond--file-status-main` ).text().trim() }`,
                fileStatus2nd: `${ infoWrapper.find( `.filepond--file-status .filepond--file-status-sub` ).text().trim() }`,
                designNoteLabel: $( `.cl-upload--input-field .cl-upload--label` ).text().trim(),
                designNote: $( `[name="properties[Design Notes]"]` ).val(),
                designPlaceholder: $( `[name="properties[Design Notes]"]` ).attr( `placeholder` ),
              }

              var element = $(".filepond--root.cl-upload--area.filepond--hopper .filepond--image-bitmap canvas");
              if ( element.length > 0 ) {
                console.log ( 'find',  );
                console.log ( 'element', element );
                html2canvas(element, {
                dpi: 144,
                onrendered: function (canvas) {
                    // getCanvas = canvas;
                    $( `.customUploaderView_detail` )
                      .addClass( `imgAvailable` )
                      .find( `.customUploaderView_preview` )
                      .html( canvas );
                  }
                });
              } else {
                const elementForVector = $( `.filepond--root.cl-upload--area.filepond--hopper .filepond--file-wrapper .filepond--file` );
                if ( elementForVector.length > 0 ) {
                }
              }

              $( `.customUploaderView__info_fileName` ).text( getData.fileName );
              $( `.customUploaderView__info_fileSize` ).text( getData.fileSize );
              $( `.customUploaderView__info_status` ).text( getData.fileStatus );
              $( `.customUploaderView__info_status2nd` ).text( getData.fileStatus2nd );
              $( `.customUploaderView__inputFeild_label` ).text( getData.designNoteLabel );
              $( `.customUploaderView__inputFeild_textarea` ).attr( `placeholder`, getData.designPlaceholder ).val( getData.designNote );
              setTimeout(() => {
                $( `.changeLayout [data-upload-lift]` ).hide();
              }, 100);
            } catch ( err ) {
              console.log( `ERROR `, err.message );
            }
          }
        </script>
      {% endif %}
      {% render "product-gallery", section:section, product: selectedProduct, gallery_class: gallery_class, hideVariantImages: ss.hideVariantImages %}
    </div>

    <div class="product-text {{ text_class }} element--is-sticky remove-empty-space">
      <div class="element--hide-on-portable">
        {%- render 'breadcrumb', container: '', vertical_space: '', style: 'breadcrumb-main--scroll breadcrumb-main--smaller' -%}
      </div>
      {%- assign product_form_id = 'product-form-' | append: section.id -%}

      {%- for block in section.blocks -%}
        {%- assign b = block.settings -%}

        {%- case block.type -%}
 {% when 'pdp-text-image-block' %}
              {% render 'pdp-image-with-text-block' , block: block %}
          {%- when '@app' -%}
            <div class="has-bg-style--{{ section.settings.style }}">
              {%- render block -%}
            </div>

          {%- when 'widthHeight' -%}
            <div class="widthHeight__block">
              <div class="widthHeight__option customOption selected">
                <div class="widthHeight__option-radio">&nbsp;</div>
                <div class="widthHeight__option-name">
                  {{ b.customOptionText | escape }}
                </div>
                <div class="widthHeight__option-detectedSize">
                  Detected size: 5.0" x 11.5"
                </div>
              </div>

              <div class="widthHeight__custom">
                <div class="widthHeight__item" by="width">
                  {{ b.widthText }}<br>
                  <div class="widthHeight__item__action" by="width">
                    <button class="widthHeight__item__action-minus">
                      <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false" class="icon icon-minus" fill="none" viewBox="0 0 10 2"><path fill-rule="evenodd" clip-rule="evenodd" d="M.5 1C.5.7.7.5 1 .5h8a.5.5 0 110 1H1A.5.5 0 01.5 1z" fill="currentColor"></path></svg>
                    </button>
                    <input type="number" name="width__value" class="widthHeight__value" value="4.5" min="0.5" max="{{ b.maxSize }}" step="0.5" last="4.5">
                    <button class="widthHeight__item__action-plus">
                      <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false" class="icon icon-plus" fill="none" viewBox="0 0 10 10"><path fill-rule="evenodd" clip-rule="evenodd" d="M1 4.51a.5.5 0 000 1h3.5l.01 3.5a.5.5 0 001-.01V5.5l3.5-.01a.5.5 0 00-.01-1H5.5L5.49.99a.5.5 0 00-1 .01v3.5l-3.5.01H1z" fill="currentColor"></path></svg>
                    </button>
                  </div>
                  <div class="widthHeight__item_err">
                    <svg width="16" height="16" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48"><path d="M0 0h48v48h-48z" fill="none"/><path d="M24 4c-11.05 0-20 8.95-20 20s8.95 20 20 20 20-8.95 20-20-8.95-20-20-20zm2 30h-4v-12h4v12zm0-16h-4v-4h4v4z"/></svg>
                    <span>{{ b.errorMsg | replace: '[maxSize]', b.maxSize }}</span>
                  </div>
                </div>

                <div class="widthHeight__item" by="height">
                  {{ b.heightText }}<br>
                  <div class="widthHeight__item__action" by="height">
                    <button class="widthHeight__item__action-minus">
                      <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false" class="icon icon-minus" fill="none" viewBox="0 0 10 2"><path fill-rule="evenodd" clip-rule="evenodd" d="M.5 1C.5.7.7.5 1 .5h8a.5.5 0 110 1H1A.5.5 0 01.5 1z" fill="currentColor"></path></svg>
                    </button>
                    <input type="number" name="height__value" class="widthHeight__value" value="3" min="0.5" max="{{ b.maxSize }}" step="0.5" last="3">
                    <button class="widthHeight__item__action-plus">
                      <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false" class="icon icon-plus" fill="none" viewBox="0 0 10 10"><path fill-rule="evenodd" clip-rule="evenodd" d="M1 4.51a.5.5 0 000 1h3.5l.01 3.5a.5.5 0 001-.01V5.5l3.5-.01a.5.5 0 00-.01-1H5.5L5.49.99a.5.5 0 00-1 .01v3.5l-3.5.01H1z" fill="currentColor"></path></svg>
                    </button>
                  </div>
                  <div class="widthHeight__item_err">
                    <svg width="16" height="16" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48"><path d="M0 0h48v48h-48z" fill="none"/><path d="M24 4c-11.05 0-20 8.95-20 20s8.95 20 20 20 20-8.95 20-20-8.95-20-20-20zm2 30h-4v-12h4v12zm0-16h-4v-4h4v4z"/></svg>
                    <span>{{ b.errorMsg | replace: '[maxSize]', b.maxSize }}</span>
                  </div>
                </div>

                <div class="widthHeight__autoChange {% if b.autoChangeWidthHeightShowHide %}hidden{% endif %}">
                  {% if b.autoChangeWidthHeight %}
                    <label for="autoChange">
                      <input type="checkbox" id="autoChange" class="autoChange" checked>
                      <svg class="locked" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px" viewBox="0 0 24 24" style="enable-background:new 0 0 24 24;" xml:space="preserve"><style type="text/css">.st0{fill:#FFFFFF;}</style><path d="M22.7,10.2h-1.4V6c0-3.3-2.7-6-6-6s-6,2.7-6,6v4.2H7.9c-0.6,0-1.1,0.5-1.1,1.1v11.6c0,0.6,0.5,1.1,1.1,1.1h14.8 c0.6,0,1.1-0.5,1.1-1.1V11.3C23.8,10.7,23.3,10.2,22.7,10.2z M12.2,6c0-1.7,1.4-3.1,3.1-3.1c1.7,0,3.1,1.4,3.1,3.1v4.2h-6.1V6z"/><circle class="st0" cx="15.3" cy="17.1" r="2"/></svg>
                      <svg class="unlock" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px" viewBox="0 0 24 24" style="enable-background:new 0 0 24 24;" xml:space="preserve"><style type="text/css">.st0{fill:#FFFFFF;}</style><path d="M22.7,10.2H12.2V6c0-3.3-2.7-6-6-6s-6,2.7-6,6v1.9c0,0.8,0.7,1.5,1.5,1.5s1.5-0.7,1.5-1.5V6c0-1.7,1.4-3.1,3.1-3.1 c1.7,0,3.1,1.4,3.1,3.1v4.2H7.9c-0.6,0-1.1,0.5-1.1,1.1v11.6c0,0.6,0.5,1.1,1.1,1.1h14.8c0.6,0,1.1-0.5,1.1-1.1V11.3 C23.8,10.7,23.3,10.2,22.7,10.2z"/><circle class="st0" cx="15.3" cy="17.1" r="2"/></svg>
                      <span content lock-statement="{{ b.autoChangeText | escape }}" unlock-statement="{{ b.autoChangeText_unlock | escape }}">{{ b.autoChangeText_unlock }}</span>
                    </label>
                    <span class="tooltip">
                      <svg width="16px" height="16px" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 0 48 48" enable-background="new 0 0 48 48" xml:space="preserve"><path fill="none" d="M0,0h48v48H0V0z"/><path fill="#061C2D" d="M24,4C12.95,4,4,12.95,4,24s8.95,20,20,20s20-8.95,20-20S35.05,4,24,4z M26,34h-4V22h4V34z M26,18h-4v-4h4  V18z"/></svg>
                      <span class="tooltiptext">{{ b.tooltipText }}</span>
                    </span>
                  {% endif %}
                </div>

              </div>

              <div class="widthHeight__option popularOption">
                <div class="widthHeight__option-radio">&nbsp;</div>
                <div class="widthHeight__option-name">
                  {{ b.popularOptionText | escape }}
                </div>
                {% if b.showTooltip %}
                  {% if b.tooltipContent != blank or b.tooltipImage != blank %}
                    <div class="widthHeight__option-toolTip">
                      <img src="//ninjatransfers.com/cdn/shop/files/info_da70c6e6-1e86-41d3-9035-2bf57d01d406_medium.svg?v=1678797665">
                      <div class="widthHeight__option-toolTip__content">
                        {% if b.tooltipImage != blank %}
                          <img src="{{ b.tooltipImage | image_url: width: 500 }}" class="widthHeight__option-toolTip__contentImg">
                        {% endif %}
                        {% if b.tooltipContent != blank %}
                          <div>
                            {{ b.tooltipContent }}
                          </div>
                        {% endif %}
                      </div>
                    </div>
                  {% endif %}
                {% endif %}
              </div>
              <div class="widthHeight__popular"></div>
            </div>

            {% if b.hideVariants %}
              <style>
                product-variants .product-variant__item.product-variant__item--radio,
                variant-radios .form__label,
                product-variants .product-variants .product-variant[option="2"],
                variant-selects {
                  display: none;
                }
                product-variants .product-variant__item.product-variant__item--radio[min=""] {
                  display: inline-block;
                }
              </style>
            {% endif %}

            <script>
              function roundUpToHalf(value) {
                // Round up to the nearest 0.5
                return Math.ceil(value * 2) / 2;
              }
              function roundDownToHalf(value) {
                // Round up to the nearest 0.5
                return Math.floor(value * 2) / 2;
              }
              const userDefinedMaxLength = {{ b.maxSize | json }};
              const allowedMaxInches = {{ b.maxSqInches | json }};
              $(document).ready(function() {
                {% if b.hideVariants %}
                  $( `product-variants .product-variants .product-variant[option="1"]` ).addClass( `disabled` );
                {% endif %}
                $( `.widthHeight__value, .customQtyFile__qty` ).keypress(function (event) {
                  return isNumber(event, this)
                });
              });

              function isNumber(evt, element) {
                var charCode = (evt.which) ? evt.which : event.keyCode
                if ( ( charCode != 45 || charCode != 48 || $(element).val().indexOf('-') != -1 ) && ( charCode != 46 || $( element ).val().indexOf('.') != -1 ) && ( charCode < 48 || charCode > 57 ) ) {
                  return false;
                }
                return true;
              }

              $( document )
              .on(`click`, `.disabled[option="1"] .product-variant__item.product-variant__item--radio[min=""][max=""]`, function( e ) {
                try {
                  e.stopImmediatePropagation();

                  $( `.widthHeight__custom .widthHeight__item` ).removeClass( `error` );
                  $( `product-variants .product-variant[option="1"] .product-variant__item.product-variant__item--radio` ).each(function() {
                    const isChecked   =   $( this ).find( ` > input[type="radio"]` ).is( `:checked` );
                    if ( isChecked ) {
                      customSelectedVariant_id  =   $( this ).find( `label` ).attr( `for` );

                      console.log ( 'customSelectedVariant_id', customSelectedVariant_id );
                    }
                  })

                  $( `.widthHeight__option` ).removeClass( `selected` );

                  $( `.widthHeight__item__action, .widthHeight__autoChange` ).addClass( `disabled` );
                  $( `.product-variant` ).removeClass( `disabled` );

                  $( `.widthHeight__option.popularOption` ).addClass( `selected` );

                  $( `.form__properties input[name="properties[width]"], .form__properties input[name="properties[height]"], .form__properties input[name="properties[Detected Size]"]` )
                    .prop( `disabled`, true );

                  let detectedSize  =   $( `.widthHeight__option-detectedSize span[d-size]` ).text();
                  detectedSize      =   detectedSize.replace( '"', '' ).replace( '"', '' ).replace( ' ', '' ).replace( ' ', '' );

                  // $( `.form__properties` )
                    // .append( `
                    //   <textarea style="display: none;" name="properties[_specialNote]">Detected Size: ${ typeof detectedSize !== 'undefined' && detectedSize ? detectedSize : null }</textarea>
                    // ` );

                  $( this ).find( `label` ).click();

                } catch ( err ) {
                  console.log( `ERROR .product-variant__item.product-variant__item--radio[min=""][max=""]`, err.message );
                }
              })

              .on(`click`, `.widthHeight__option:not(.selected)`,async function( e ) {
                try {
                  e.stopImmediatePropagation();
                  const isCustomBlock = $( this ).hasClass( `customOption` );
                  $( `.widthHeight__option` ).removeClass( `selected` );
                  $( this ).addClass( `selected` );

                  if ( isCustomBlock ) {

                    $( `.widthHeight__item__action, .widthHeight__autoChange` ).removeClass( `disabled` );
                    $( `product-variants .product-variant` ).addClass( `disabled` );

                    if ( typeof customSelectedVariant_id !== 'undefined' && customSelectedVariant_id ) {
                      $( `product-variants .product-variant .product-variant__item.product-variant__item--radio > label[for="${ customSelectedVariant_id }"]` ).click();
                    }

                    $( `.form__properties input[name="properties[width]"], .form__properties input[name="properties[height]"], .form__properties input[name="properties[Detected Size]"]` )
                      .prop( `disabled`, false );

                    $( `.form__properties [name="properties[_specialNote]"]` )
                      .prop( `disabled`, true );

                  } else {

                    $( `.widthHeight__item__action, .widthHeight__autoChange` ).addClass( `disabled` );
                    $( `product-variants .product-variant` ).removeClass( `disabled` );

                    $( `product-variants .product-variant[option="1"] .product-variant__container .product-variant__item.product-variant__item--radio` ).each(function() {
                      const isChecked   =   $( this ).find( ` > input[type="radio"]` ).is( `:checked` );
                      if ( isChecked ) {
                        customSelectedVariant_id  =   $( this ).find( `label` ).attr( `for` );

                        console.log ( 'customSelectedVariant_id', customSelectedVariant_id );
                      }
                    })
                    $( `product-variants .product-variant[option="1"] .product-variant__container .product-variant__item.product-variant__item--radio[min=""][max=""]` ).first().find( `> label` ).click();

                    $( `.form__properties input[name="properties[width]"], .form__properties input[name="properties[height]"], .form__properties input[name="properties[Detected Size]"]` )
                      .prop( `disabled`, true );

                    $( `.form__properties [name="properties[_specialNote]"]` )
                      .prop( `disabled`, false );

                  }
                } catch ( err ) {
                  console.log( `ERROR .widthHeight__option:not(.selected)`, err.message );
                }
              })

              .on(`click`, `.widthHeight__item__action-minus`, function( e ) {
                try {
                  e.stopImmediatePropagation();
                  const wrapper   =   $( this ).closest( `.widthHeight__item__action` );
                  const min       =   wrapper.find( `.widthHeight__value` ).attr( `min` ) * 1;
                  const max       =   wrapper.find( `.widthHeight__value` ).attr( `max` ) * 1;
                  const step      =   wrapper.find( `.widthHeight__value` ).attr( `step` ) * 1;
                  const getVal    =   wrapper.find( `.widthHeight__value` ).val() * 1;
                  var afterMinus = 0;
                  if ( getVal % step > 0 ) {
                    afterMinus = roundDownToHalf(getVal);
                  } else {
                    afterMinus  =   getVal - step;
                  }
                  // const afterMinus  =   getVal - step;
                  const byWidthHeight = wrapper.attr( `by` );

                  if ( afterMinus >= min ) {
                    const winScreen =   $( window ).width();
                    if ( winScreen > 549 ) {
                      wrapper.find( `.widthHeight__value` ).val( afterMinus.toFixed(2) ).focus();
                    } else {
                      wrapper.find( `.widthHeight__value` ).val( afterMinus.toFixed(2) );
                    }

                    setTimeout(()=>{
                      getRadioMaintain( byWidthHeight );
                    }, 50);

                    setTimeout(()=>{
                      reAdjustSizes();
                    }, 1000);
                  }

                } catch ( err ) {
                  console.log( `ERROR .widthHeight__item__action-plus`, err.message );
                }
              })
              .on(`click`, `.widthHeight__item__action-plus`, function( e ) {
                try {
                  e.stopImmediatePropagation();
                  const wrapper   =   $( this ).closest( `.widthHeight__item__action` );
                  const min       =   wrapper.find( `.widthHeight__value` ).attr( `min` ) * 1;
                  const max       =   wrapper.find( `.widthHeight__value` ).attr( `max` ) * 1;
                  const step      =   wrapper.find( `.widthHeight__value` ).attr( `step` ) * 1;
                  const getVal    =   wrapper.find( `.widthHeight__value` ).val() * 1;
                  var afterAdd = 0;
                  if ( getVal % step > 0 ) {
                    afterAdd = roundUpToHalf(getVal);
                  } else {
                    afterAdd  =   getVal + step;
                  }
                  const byWidthHeight = wrapper.attr( `by` );
                  console.log(getVal," :getVal === Step: ",step)

                  if ( afterAdd <= max ) {
                    const winScreen =   $( window ).width();
                    if ( winScreen > 549 ) {
                      wrapper.find( `.widthHeight__value` ).val( afterAdd.toFixed(2) ).focus();
                    } else {
                      wrapper.find( `.widthHeight__value` ).val( afterAdd.toFixed(2) );
                    }

                    setTimeout(()=>{
                      getRadioMaintain( byWidthHeight );
                    }, 50);
                    setTimeout(()=>{
                      reAdjustSizes();
                    }, 1000);
                  } else {
                    const winScreen =   $( window ).width();
                    if ( winScreen > 549 ) {
                      wrapper.find( `.widthHeight__value` ).val( userDefinedMaxLength.toFixed(2) ).focus();
                    } else {
                      wrapper.find( `.widthHeight__value` ).val( userDefinedMaxLength.toFixed(2) );
                    }

                    setTimeout(()=>{
                      getRadioMaintain( byWidthHeight );
                    }, 50);
                    setTimeout(()=>{
                      reAdjustSizes();
                    }, 1000);
                  }

                } catch ( err ) {
                  console.log( `ERROR .widthHeight__item__action-plus`, err.message );
                }
              })
              .on(`keyup`, `input[name="width__value"], input[name="height__value"]`, function( e ) {
                try {
                  e.stopImmediatePropagation();
                  const wrapper       =   $( this ).closest( `.widthHeight__item__action` );
                  const getWidth      =   $( `input[name="width__value"]` ).attr( `last` );
                  const getHeight     =   $( `input[name="height__value"]` ).attr( `last` );
                  const byWidthHeight =   wrapper.attr( `by` );
                  const getVal        =   $( this ).val() * 1;
                  const getMin        =   $( this ).attr( `min` ) * 1;

                  console.log ( 'getVal', getVal );

                  if ( getVal < getMin ) {
                    $( this ).val( getMin );
                  }
                  if ( getVal > userDefinedMaxLength ) {
                    $( this ).closest( `.widthHeight__item` ).addClass( `error` );
                    // const lastEntery = $( this ).attr( `last` );
                    // $( this ).val( userDefinedMaxLength );
                  }

                  setTimeout(()=>{
                    getRadioMaintain( byWidthHeight );
                  }, 50);
                  setTimeout(()=>{
                    reAdjustSizes();
                  }, 1000);

                  setTimeout(()=>{
                    const getWidth      =   $( `input[name="width__value"]` ).val() * 1;
                    const getHeight     =   $( `input[name="height__value"]` ).val() * 1;

                    if ( getWidth > userDefinedMaxLength || getHeight > userDefinedMaxLength ) {
                      if ( getWidth > getHeight ) {
                        $( `input[name="width__value"]` ).val( userDefinedMaxLength.toFixed(2) );
                        getRadioMaintain( 'width' );
                        reAdjustSizes();
                      } else if ( getHeight > getWidth ) {
                        $( `input[name="height__value"]` ).val( userDefinedMaxLength.toFixed(2) );
                        getRadioMaintain( 'height' );
                        reAdjustSizes();
                      }
                    }
                  }, 1050);
                } catch ( err ) {
                  console.log( `ERROR input[name="width__value"], input[name="height__value"]`, err.message );
                }
              })
              .on(`focus`, `input[name="width__value"], input[name="height__value"]`, function( e ) {
                try {
                  e.stopImmediatePropagation();
                  $(this).select();
                } catch ( err ) {
                  console.log( `ERROR input[name="width__value"], input[name="height__value"]`, err.message );
                }
              })
              {% if b.autoChangeWidthHeight %}
                .on(`change`, `.widthHeight__autoChange .autoChange`,async function( e ) {
                  try {
                    e.stopImmediatePropagation();
                    const lockStatement   = $( this ).closest( `.widthHeight__autoChange` ).find( `span[content]` ).attr( `lock-statement` );
                    const unlockStatement = $( this ).closest( `.widthHeight__autoChange` ).find( `span[content]` ).attr( `unlock-statement` );

                    const isChecked       = $( this ).is( `:checked` );

                    if ( isChecked ) {
                      $( this ).closest( `.widthHeight__autoChange` ).find( `span[content]` ).text( unlockStatement );
                    } else {
                      $( this ).closest( `.widthHeight__autoChange` ).find( `span[content]` ).text( lockStatement );
                    }

                    $( `.widthHeight__item__action` ).addClass( `active` );

                    await ApplyDelay( 1000 );

                    $( `.widthHeight__item__action` ).removeClass( `active` );

                  } catch ( err ) {
                    console.log( `ERROR .widthHeight__autoChange .autoChange`, err.message );
                  }
                })
              {% endif %}
              ;
            </script>

          {%- when 'steps' -%}
