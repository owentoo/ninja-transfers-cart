                  }
                  let makeTitle = `${ firstOption }`;
                  if ( typeof secondOption !== 'undefined' && secondOption ) {
                    makeTitle = `${ makeTitle } / ${ secondOption }`;
                  }
                  const getVariantData = findObjectByKey( allVariants, `title`, makeTitle );
                  if ( typeof getVariantData !== 'undefined' && getVariantData ) {
                    customTabelManagePopUp( getVariantData.id );
                  }
                  /**  Move **/
                  var _pricetable = $(".customTabelPopup__overlay").clone(true);
                  $(".customTabelPopup__overlay").remove();
                  $("body").append(_pricetable)
                  /**  ./Move **/
                }, 50);
