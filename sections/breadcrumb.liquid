{% comment %}
  Breadcrumb navigation section - supports Product, Collection, Blog, Article, Page, and dynamic collection blocks
{% endcomment %}
<div class="container container--large container--vertical-space-small" style="padding: {{ section.settings.padding }};">
  <div class="breadcrumb-wrapper">
    <nav class="breadcrumb main-card" role="navigation" aria-label="breadcrumbs">
      {% unless section.settings.disable_homepage %}
      <a href="{{ routes.root_url }}">Home</a>
        <span class="separator">{{ section.settings.separator }}</span>
      {% endunless %}

      {% for block in section.blocks %}
        {% if block.type == 'collection' and block.settings.collection_object %}
          {% assign coll = block.settings.collection_object %}
          <a href="{{ coll.url }}">
            {% assign colname = coll.title %}
            {% if block.settings.collection_name != "" %}
              {% assign colname = block.settings.collection_name %}
            {% endif %}
            {{ colname }}
          </a>
          <span class="separator">{{ section.settings.separator }}</span>
        {% endif %}
      {% endfor %}
  
      {% if product %}
        <span>{{ product.title }}</span>
      {% elsif article %}
        <a href="{{ blog.url }}">{{ blog.title }}</a>
        <span>{{ article.title }}</span>
      {% elsif current_tags %}
        <a href="{{ collection.url }}">{{ collection.title }}</a>
        <span>{{ current_tags | join: ", " }}</span>
      {% elsif page %}
        <span>{{ page.title }}</span>
      {% endif %}
    </nav>
  </div>
</div>

<style>
  .breadcrumb.main-card{opacity:1; font-size:{{ section.settings.font_size }}px; flex-flow:row wrap;}
  .breadcrumb a {
    text-decoration: none;
    color: {{ section.settings.link_color }};
  }
  .breadcrumb span.separator {
    margin: 0 6px;
    color: {{ section.settings.separator_color }};
  }
  .breadcrumb span {
    color: {{ section.settings.text_color }};
  }
  @media(max-width:768px){
    .breadcrumb.main-card{font-size:{{ section.settings.mobile_font_size }}px;}
  }
</style>

{% schema %}
{
  "name": "Breadcrumb",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "label": "Hide home",
      "id": "disable_homepage",
      "default": false
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "mobile_font_size",
      "label": "Mobile font size",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "text",
      "id": "separator",
      "label": "Breadcrumb separator",
      "default": "/"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#007ace"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "separator_color",
      "label": "Separator color",
      "default": "#999999"
    },
    {
      "type": "text",
      "id": "padding",
      "label": "Padding (e.g. 10px 0)",
      "default": "10px 0"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection_object",
          "label": "Select collection"
        },
        {
          "type": "text",
          "id": "collection_name",
          "label": "Collection text"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Breadcrumb",
      "blocks": []
    }
  ]
}
{% endschema %}