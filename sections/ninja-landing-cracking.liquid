<style>
  .ninja-crack-wrapper {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    line-height: 1.5;
    width: 100%;
    overflow-x: hidden;
  }
  .ninja-crack-wrapper * { box-sizing: border-box; }
  .ninja-container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .ninja-section { padding: 80px 0; background-size: cover; background-position: center; background-repeat: no-repeat; }
  .ninja-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
  .ninja-grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  .ninja-text-center { text-align: center; }
  
  /* Buttons */
  .ninja-btn { display: inline-flex; align-items: center; justify-content: center; padding: 16px 32px; font-weight: 700; border-radius: 8px; text-decoration: none; transition: all 0.2s; cursor: pointer; border: none; font-size: 1.125rem; }
  .ninja-btn-primary { background-color: #2563eb; color: white; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }
  .ninja-btn-primary:hover { background-color: #1d4ed8; transform: translateY(-1px); }
  .ninja-btn-secondary { background-color: transparent; border: 2px solid #2563eb; color: #2563eb; }
  .ninja-btn-secondary:hover { background-color: #eff6ff; }
  .ninja-btn-white { background-color: white; color: #0f172a; }
  .ninja-btn-white:hover { background-color: #f8fafc; }
  .ninja-btn-outline-white { background-color: transparent; border: 2px solid white; color: white; }
  .ninja-btn-outline-white:hover { background-color: rgba(255,255,255,0.1); }
  .ninja-btn-xl { padding: 20px 40px; font-size: 1.25rem; }

  /* Typography */
  .ninja-h1 { font-size: 3.5rem; font-weight: 800; line-height: 1.1; margin-bottom: 24px; color: inherit; }
  .ninja-h2 { font-size: 2.5rem; font-weight: 700; margin-bottom: 24px; color: inherit; }
  .ninja-h3 { font-size: 1.5rem; font-weight: 700; margin-bottom: 12px; color: inherit; }
  .ninja-text-lg { font-size: 1.125rem; opacity: 0.9; margin-bottom: 24px; color: inherit; }
  .ninja-badge { display: inline-flex; align-items: center; gap: 8px; background: #dbeafe; color: #1e40af; padding: 4px 12px; border-radius: 99px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; margin-bottom: 16px; letter-spacing: 0.05em; }

  /* Visuals */
  .ninja-card { padding: 32px; border-radius: 12px; transition: transform 0.2s; background-size: cover; background-position: center; background-repeat: no-repeat; border: 1px solid rgba(0,0,0,0.05); }
  .ninja-card:hover { transform: translateY(-4px); box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); }
  .ninja-icon-circle { width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 16px; }

  /* Timeline */
  .ninja-timeline-wrapper { position: relative; border-left: 4px solid #e2e8f0; margin-left: 20px; padding-left: 40px; display: flex; flex-direction: column; gap: 48px; }
  .ninja-timeline-item { position: relative; }
  .ninja-timeline-dot { position: absolute; left: -64px; top: 0; width: 40px; height: 40px; border-radius: 50%; border: 4px solid white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.875rem; z-index: 10; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }
  .ninja-timeline-content { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }

  /* Responsive */
  @media (max-width: 768px) {
    .ninja-h1 { font-size: 2.5rem; }
    .ninja-grid-2, .ninja-grid-3 { grid-template-columns: 1fr; gap: 40px; }
    .ninja-btn { width: 100%; }
    .ninja-section { padding: 60px 0; }
    .ninja-timeline-content { grid-template-columns: 1fr; gap: 8px; }
  }
</style>

<div class="ninja-crack-wrapper">

  <!-- HERO -->
  <section class="ninja-section" style="background-color: {{ section.settings.hero_bg_color }}; {% if section.settings.hero_bg_image != blank %}background-image: url('{{ section.settings.hero_bg_image | image_url: width: 2000 }}');{% endif %} color: {{ section.settings.hero_text_color }};">
    <div class="ninja-container">
      <div class="ninja-grid-2">
        <div>
          <div class="ninja-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
            {{ section.settings.hero_badge }}
          </div>
          <h1 class="ninja-h1">{{ section.settings.hero_headline }}</h1>
          <p class="ninja-text-lg">{{ section.settings.hero_subtext }}</p>
          <div style="display:flex; flex-wrap:wrap; gap:16px;">
            <a href="{{ section.settings.hero_btn_link }}" class="ninja-btn ninja-btn-primary ninja-btn-xl">{{ section.settings.hero_btn_text }}</a>
            <a href="{{ section.settings.hero_btn_secondary_link }}" class="ninja-btn ninja-btn-secondary ninja-btn-xl">{{ section.settings.hero_btn_secondary_text }}</a>
          </div>
        </div>
        
        <div>
           {% if section.settings.hero_image != blank %}
             {{ section.settings.hero_image | image_url: width: 800 | image_tag: style: 'width: 100%; height: auto; border-radius: 12px; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);', alt: 'Crack Comparison' }}
           {% else %}
             <!-- Split Visual -->
             <div style="border-radius: 12px; overflow: hidden; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1); border: 1px solid #e5e7eb; display: flex; aspect-ratio: 4/3;">
                <!-- Left -->
                <div style="width: 50%; background-color: {{ section.settings.hero_split_left_bg }}; {% if section.settings.hero_split_left_img != blank %}background-image: url('{{ section.settings.hero_split_left_img | image_url: width: 600 }}'); background-size: cover; background-position: center; background-repeat: no-repeat;{% endif %} display: flex; flex-direction: column; justify-content: center; padding: 24px; border-right: 1px solid #e2e8f0; position: relative;">
                    <div style="position: absolute; top:0; left:0; width:100%; height: 8px; background: #ef4444;"></div>
                    <div style="font-weight: 700; color: #0f172a; display: flex; align-items: center; gap: 8px; margin-bottom: 4px;">
                        {% if section.settings.hero_split_left_icon != blank %}
                          <img src="{{ section.settings.hero_split_left_icon | image_url: width: 40 }}" width="20" height="20" style="object-fit: contain;">
                        {% else %}
                          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                        {% endif %}
                        {{ section.settings.hero_split_left_title }}
                    </div>
                    <div style="font-size: 0.75rem; color: #64748b; margin-bottom: 24px;">{{ section.settings.hero_split_left_subtitle }}</div>
                    <!-- Cracked Graphic Placeholder -->
                    <div style="width: 100%; height: 100px; background: #cbd5e1; border-radius: 8px; margin-bottom: 16px; opacity: 0.5; display: flex; align-items: center; justify-content: center;">
                       <div style="width: 60%; height: 2px; background: white; transform: rotate(15deg);"></div>
                       <div style="width: 60%; height: 2px; background: white; transform: rotate(-10deg);"></div>
                    </div>
                    <div style="font-family: monospace; font-size: 0.7rem; color: #ef4444; background: #fef2f2; padding: 8px; border-radius: 4px;">
                        {{ section.settings.hero_split_left_status | newline_to_br }}
                    </div>
                </div>
                <!-- Right -->
                <div style="width: 50%; background-color: {{ section.settings.hero_split_right_bg }}; {% if section.settings.hero_split_right_img != blank %}background-image: url('{{ section.settings.hero_split_right_img | image_url: width: 600 }}'); background-size: cover; background-position: center; background-repeat: no-repeat;{% endif %} display: flex; flex-direction: column; justify-content: center; padding: 24px; position: relative;">
                    <div style="position: absolute; top:0; left:0; width:100%; height: 8px; background: #2563eb;"></div>
                    <div style="font-weight: 700; color: #0f172a; display: flex; align-items: center; gap: 8px; margin-bottom: 4px;">
                        {% if section.settings.hero_split_right_icon != blank %}
                          <img src="{{ section.settings.hero_split_right_icon | image_url: width: 40 }}" width="20" height="20" style="object-fit: contain;">
                        {% else %}
                          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
                        {% endif %}
                        {{ section.settings.hero_split_right_title }}
                    </div>
                    <div style="font-size: 0.75rem; color: #64748b; margin-bottom: 24px;">{{ section.settings.hero_split_right_subtitle }}</div>
                    <!-- Smooth Graphic Placeholder -->
                    <div style="width: 100%; height: 100px; background: #3b82f6; border-radius: 8px; margin-bottom: 16px; display: flex; align-items: center; justify-content: center;">
                         <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="M9 12l2 2 4-4"></path></svg>
                    </div>
                    <div style="font-family: monospace; font-size: 0.7rem; color: #1e40af; background: #eff6ff; padding: 8px; border-radius: 4px;">
                        {{ section.settings.hero_split_right_status | newline_to_br }}
                    </div>
                </div>
             </div>
           {% endif %}
        </div>
      </div>
    </div>
  </section>

  <!-- VIDEO -->
  <section class="ninja-section ninja-text-center" style="background-color: {{ section.settings.video_bg_color }}; {% if section.settings.video_bg_image != blank %}background-image: url('{{ section.settings.video_bg_image | image_url: width: 2000 }}');{% endif %} color: {{ section.settings.video_text_color }};">
    <div class="ninja-container">
      <div style="display: inline-flex; align-items: center; gap: 8px; color: #60a5fa; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 16px; font-size: 0.875rem;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
        {{ section.settings.video_eyebrow }}
      </div>
      <h2 class="ninja-h2">{{ section.settings.video_headline }}</h2>
      
      <div style="max-width: 800px; margin: 0 auto 24px auto; background: #000; border-radius: 12px; overflow: hidden; aspect-ratio: 16/9; position: relative; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.3); border-top: 1px solid #334155;">
        {% if section.settings.video_url != blank %}
          {% if section.settings.video_url.type == 'youtube' %}
            <iframe src="https://www.youtube.com/embed/{{ section.settings.video_url.id }}?rel=0&showinfo=0&modestbranding=1" frameborder="0" allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture" allowfullscreen style="position:absolute; top:0; left:0; width:100%; height:100%;"></iframe>
          {% elsif section.settings.video_url.type == 'vimeo' %}
            <iframe src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}?color=2563eb&title=0&byline=0&portrait=0" frameborder="0" allow="autoplay; fullscreen" allowfullscreen style="position:absolute; top:0; left:0; width:100%; height:100%;"></iframe>
          {% endif %}
        {% else %}
          <div style="position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; color: white; background: #1e293b;">
            <div style="width: 80px; height: 80px; background: rgba(37,99,235,0.9); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 16px; box-shadow: 0 0 20px rgba(37,99,235,0.5);">
               <div style="width: 0; height: 0; border-top: 10px solid transparent; border-bottom: 10px solid transparent; border-left: 16px solid white; margin-left: 4px;"></div>
            </div>
            <p style="font-weight: 500; font-size: 1.125rem; color: #94a3b8;">Watch Analysis (0:90)</p>
          </div>
        {% endif %}
        <div style="position: absolute; bottom: 16px; right: 16px; background: rgba(0,0,0,0.8); color: #60a5fa; padding: 4px 8px; border-radius: 4px; font-size: 0.75rem; font-family: monospace;">
          {{ section.settings.video_caption }}
        </div>
      </div>
    </div>
  </section>

  <!-- SCIENCE -->
  <section class="ninja-section" style="background-color: {{ section.settings.science_bg_color }}; {% if section.settings.science_bg_image != blank %}background-image: url('{{ section.settings.science_bg_image | image_url: width: 2000 }}');{% endif %} color: {{ section.settings.science_text_color }};">
    <div class="ninja-container">
      <div class="ninja-text-center" style="margin-bottom: 64px;">
        <h2 class="ninja-h2">{{ section.settings.science_headline }}</h2>
        <p class="ninja-text-lg">{{ section.settings.science_subtext }}</p>
      </div>

      <div class="ninja-grid-3">
        {% assign science_blocks = section.blocks | where: "type", "science_item" %}
        {% if science_blocks.size > 0 %}
          {% for block in science_blocks %}
            <div class="ninja-card" style="background-color: {{ block.settings.card_bg_color }}; {% if block.settings.card_bg_image != blank %}background-image: url('{{ block.settings.card_bg_image | image_url: width: 600 }}');{% endif %}">
              <div style="position: absolute; top: 16px; right: 16px; font-size: 2rem; font-weight: 800; color: #e2e8f0;">0{{ forloop.index }}</div>
              <div class="ninja-icon-circle" style="background-color: {{ block.settings.icon_bg_color }}; color: #334155; width: 56px; height: 56px;">
                {% if block.settings.icon != blank %}
                  <img src="{{ block.settings.icon | image_url: width: 64 }}" width="32" height="32" style="object-fit: contain;">
                {% else %}
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8h1a4 4 0 0 1 0 8h-1"></path><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"></path><line x1="6" y1="1" x2="6" y2="4"></line><line x1="10" y1="1" x2="10" y2="4"></line><line x1="14" y1="1" x2="14" y2="4"></line></svg>
                {% endif %}
              </div>
              <h3 class="ninja-h3">{{ block.settings.title }}</h3>
              <p class="ninja-text-lg" style="font-size: 1rem;">{{ block.settings.text }}</p>
            </div>
          {% endfor %}
        {% else %}
           <!-- Default Content -->
           <div class="ninja-card" style="background-color: #f8fafc;">
              <h3 class="ninja-h3">Thermal Shock</h3>
              <p class="ninja-text-lg">Washing machines hit 140°F. Cheap adhesive becomes brittle.</p>
           </div>
        {% endif %}
      </div>
    </div>
  </section>

  <!-- SOLUTION (Stack) -->
  <section class="ninja-section" style="background-color: {{ section.settings.solution_bg_color }}; {% if section.settings.solution_bg_image != blank %}background-image: url('{{ section.settings.solution_bg_image | image_url: width: 2000 }}');{% endif %} color: {{ section.settings.solution_text_color }};">
    <div class="ninja-container">
      <div class="ninja-grid-2">
        <div>
          <div class="ninja-badge">{{ section.settings.solution_badge }}</div>
          <h2 class="ninja-h2">{{ section.settings.solution_headline }}</h2>
          <p class="ninja-text-lg">{{ section.settings.solution_description }}</p>
          <ul style="list-style: none; padding: 0;">
             <li style="display: flex; gap: 12px; margin-bottom: 12px; font-weight: 500;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                Elastic Polymer Core: Stretches, never cracks.
             </li>
             <li style="display: flex; gap: 12px; margin-bottom: 12px; font-weight: 500;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                Hydrophobic Seal: Repels water/detergent.
             </li>
             <li style="display: flex; gap: 12px; font-weight: 500;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                High-Temp Cure: Heat strengthens the bond.
             </li>
          </ul>
        </div>
        <div>
           {% if section.settings.solution_chart_image != blank %}
             {{ section.settings.solution_chart_image | image_url: width: 800 | image_tag: style: 'width: 100%; border-radius: 12px; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);', alt: 'Layer Stack' }}
           {% else %}
             <!-- Default Layer Visual -->
             <div style="background: white; padding: 32px; border-radius: 16px; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1); border: 1px solid #eff6ff;">
                <div style="background: linear-gradient(to right, #3b82f6, #8b5cf6); color: white; padding: 16px; border-radius: 8px; font-weight: 700; margin-bottom: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">Automotive-Grade Pigment Ink</div>
                <div style="background: #f1f5f9; color: #64748b; padding: 12px; border-radius: 8px; font-weight: 700; margin-bottom: 8px; margin-left: 8px; margin-right: 8px;">Opaque White Underbase</div>
                <div style="background: #2563eb; color: white; padding: 16px; border-radius: 8px; font-weight: 700; margin-bottom: 8px; box-shadow: 0 4px 6px rgba(37,99,235,0.3); border: 2px solid #60a5fa;">Medical-Grade Adhesive (Ninja Peel)</div>
                <div style="background: #1e293b; color: #94a3b8; padding: 24px; border-radius: 8px; font-weight: 700; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.1em; text-align: center; margin-top: -12px; padding-top: 32px; z-index: -1;">Fabric Fibers</div>
             </div>
           {% endif %}
        </div>
      </div>
    </div>
  </section>

  <!-- TIMELINE -->
  <section class="ninja-section" style="background-color: {{ section.settings.timeline_bg_color }}; {% if section.settings.timeline_bg_image != blank %}background-image: url('{{ section.settings.timeline_bg_image | image_url: width: 2000 }}');{% endif %} color: {{ section.settings.timeline_text_color }};">
    <div class="ninja-container">
      <div class="ninja-text-center" style="margin-bottom: 48px;">
        <h2 class="ninja-h2">{{ section.settings.timeline_headline }}</h2>
      </div>

      <div class="ninja-timeline-wrapper">
        {% assign timeline_blocks = section.blocks | where: "type", "timeline_event" %}
        {% if timeline_blocks.size > 0 %}
            {% for block in timeline_blocks %}
                <div class="ninja-timeline-item">
                <div class="ninja-timeline-dot" style="background-color: {{ block.settings.dot_color }};">{{ block.settings.wash_count }}</div>
                <div class="ninja-timeline-content">
                    <div style="text-align: right;">
                        <h3 class="ninja-h3" style="font-size: 1.25rem;">{{ block.settings.title }}</h3>
                        <p style="font-size: 0.875rem; opacity: 0.8;">{{ block.settings.competitor_status }}</p>
                    </div>
                    <div>
                        <span style="display: inline-block; background: #eff6ff; color: #1e40af; padding: 4px 12px; border-radius: 4px; font-weight: 700; font-size: 0.875rem; border: 1px solid #dbeafe;">
                        {{ block.settings.ninja_status }}
                        </span>
                    </div>
                </div>
                </div>
            {% endfor %}
        {% else %}
            <!-- Default -->
            <div class="ninja-timeline-item">
                <div class="ninja-timeline-dot">10</div>
                <div class="ninja-timeline-content">
                    <div style="text-align: right;"><h3>10 Washes</h3></div>
                    <div><span>No Change</span></div>
                </div>
            </div>
        {% endif %}
      </div>
    </div>
  </section>

  <!-- PROOF -->
  <section class="ninja-section" style="background-color: {{ section.settings.proof_bg_color }}; {% if section.settings.proof_bg_image != blank %}background-image: url('{{ section.settings.proof_bg_image | image_url: width: 2000 }}');{% endif %} color: {{ section.settings.proof_text_color }};">
    <div class="ninja-container">
      <div class="ninja-text-center" style="margin-bottom: 48px;">
        <h2 class="ninja-h2">{{ section.settings.proof_headline }}</h2>
      </div>
      <div class="ninja-grid-2">
        {% assign review_blocks = section.blocks | where: "type", "review" %}
        {% if review_blocks.size > 0 %}
            {% for block in review_blocks %}
            <div class="ninja-card" style="background-color: {{ block.settings.card_bg_color }}; {% if block.settings.card_bg_image != blank %}background-image: url('{{ block.settings.card_bg_image | image_url: width: 600 }}');{% endif %} border-left: 4px solid #2563eb;">
                <p style="font-style: italic; margin-bottom: 24px;">"{{ block.settings.text }}"</p>
                <div style="font-weight: 700;">— {{ block.settings.author }}, <span style="font-weight: 400; color: #64748b;">{{ block.settings.role }}</span></div>
            </div>
            {% endfor %}
        {% endif %}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="ninja-section" style="background-color: {{ section.settings.faq_bg_color }}; color: {{ section.settings.faq_text_color }};">
    <div class="ninja-container" style="max-width: 800px;">
      <h2 class="ninja-h2 ninja-text-center" style="margin-bottom: 40px;">{{ section.settings.faq_headline }}</h2>
      <div style="display: flex; flex-direction: column; gap: 16px;">
        {% assign faq_blocks = section.blocks | where: "type", "faq" %}
        {% for block in faq_blocks %}
            <details style="background: white; border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden;">
              <summary style="padding: 20px; font-weight: 700; cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; color: #111827;">
                {{ block.settings.question }}
                <span style="font-size: 1.25rem; color: #9ca3af;">+</span>
              </summary>
              <div style="padding: 0 20px 20px 20px; color: #4b5563;">{{ block.settings.answer }}</div>
            </details>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- RISK -->
  <section class="ninja-section ninja-text-center" style="background-color: {{ section.settings.risk_bg_color }}; color: {{ section.settings.risk_text_color }};">
    <div class="ninja-container" style="max-width: 800px;">
      <div style="display: flex; justify-content: center; margin-bottom: 24px; color: #2563eb;">
         <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 2v7.31"></path><path d="M14 9.3V1.99"></path><path d="M8.5 2h7"></path><path d="M14 9.3a6.5 6.5 0 1 1-4 0"></path><path d="M5.52 16h12.96"></path></svg>
      </div>
      <h2 class="ninja-h2">{{ section.settings.risk_headline }}</h2>
      <p class="ninja-text-lg">{{ section.settings.risk_subtext }}</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="ninja-section ninja-text-center" style="background-color: {{ section.settings.cta_bg_color }}; {% if section.settings.cta_bg_image != blank %}background-image: url('{{ section.settings.cta_bg_image | image_url: width: 2000 }}');{% endif %} color: {{ section.settings.cta_text_color }};">
    <div class="ninja-container" style="max-width: 800px;">
      <h2 class="ninja-h2">{{ section.settings.cta_headline }}</h2>
      <p class="ninja-text-lg">{{ section.settings.cta_subtext }}</p>
      <div style="display: flex; justify-content: center; gap: 16px; margin-top: 32px;">
         <a href="{{ section.settings.cta_btn_link }}" class="ninja-btn ninja-btn-white ninja-btn-xl">{{ section.settings.cta_btn_text }}</a>
         <a href="{{ section.settings.secondary_btn_link }}" class="ninja-btn ninja-btn-outline-white ninja-btn-xl">{{ section.settings.secondary_btn_text }}</a>
      </div>
      <div style="margin-top: 32px; display: flex; justify-content: center; gap: 24px; font-weight: 500; font-size: 0.875rem; opacity: 0.8;">
        <span style="display: flex; alignItems: center; gap: 6px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> 100+ Wash Certified</span>
        <span style="display: flex; alignItems: center; gap: 6px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg> G7 Color Calibrated</span>
      </div>
    </div>
  </section>

</div>