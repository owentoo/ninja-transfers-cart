{% assign section_id = section.id | replace: '_', '' | downcase %}

<link rel="stylesheet" href="{{ '__blanksUploadHelper.css' | asset_url }}">
<link rel="stylesheet" href="{{ 'display_classes.css' | asset_url }}">

<style>
  .mau-wrap-{{ section_id }} {
    display: none;
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_h }}px {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg_color }};
  }
  @media (max-width: 767px) {
    .mau-wrap-{{ section_id }} { display: block; }
  }

  .mau-wrap-{{ section_id }} .uploadBox__layout {
    min-height: {{ section.settings.box_height }}px;
    border-radius: {{ section.settings.border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .mau-wrap-{{ section_id }} .uploadBox__layout::after {
    border-radius: calc({{ section.settings.border_radius }}px - 2px);
  }
  .mau-wrap-{{ section_id }} .uploadBox__content {
    position: relative;
    top: unset;
    transform: unset;
    max-width: 100%;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .mau-wrap-{{ section_id }} .uploadBox__icon img {
    width: {{ section.settings.icon_size }}px;
    height: auto;
    margin-bottom: 12px;
  }
  .mau-wrap-{{ section_id }} .uploadBox__contentTitle {
    font-size: {{ section.settings.title_size }}px;
    font-weight: 700;
    color: {{ section.settings.title_color }};
    margin-bottom: 6px;
  }
  .mau-wrap-{{ section_id }} .uploadBox__contentText {
    font-size: {{ section.settings.sub_size }}px;
    color: {{ section.settings.sub_color }};
    margin-bottom: 0;
  }
  .mau-wrap-{{ section_id }} .uploadBox__contentButton {
    margin-top: {{ section.settings.btn_margin_top }}px;
    border-radius: {{ section.settings.btn_radius }}px;
    background-color: {{ section.settings.btn_bg }};
    color: {{ section.settings.btn_text_color }};
    font-size: {{ section.settings.btn_font_size }}px;
    padding: 12px 32px;
    display: inline-block;
    cursor: pointer;
  }
  .mau-wrap-{{ section_id }} .uploadBox__contentButton:hover {
    background-color: {{ section.settings.btn_bg | color_darken: 8 }};
  }
  .mau-prevdesign-{{ section_id }} {
    margin-top: 12px;
    font-size: 13px;
    color: {{ section.settings.prev_link_color }};
    text-decoration: none;
    display: block;
    text-align: center;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    font-family: inherit;
  }
  .mau-prevdesign-{{ section_id }}:hover { text-decoration: underline; }

  .mau-spinner-{{ section_id }} {
    display: inline-block;
    width: 20px;
    height: 20px;
    border: 3px solid #cce8ff;
    border-top-color: {{ section.settings.btn_bg }};
    border-radius: 50%;
    animation: mau-spin-{{ section_id }} 0.8s linear infinite;
    vertical-align: middle;
    margin-right: 8px;
  }
  @keyframes mau-spin-{{ section_id }} { to { transform: rotate(360deg); } }

  .mau-error-{{ section_id }} {
    display: none;
    text-align: center;
    padding: 8px 16px;
    font-size: 13px;
    color: #c0392b;
    background: #fdecea;
    border-radius: 8px;
    margin-top: 8px;
  }

  /* ── "Your Designs" modal — full screen sheet ── */
  #mau-designs-modal-{{ section_id }} {
    position: fixed;
    inset: 0;
    z-index: 99999;
    background: rgba(0,0,0,0.55);
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }
  .mau-sheet-{{ section_id }} {
    position: relative;
    width: 100%;
    max-width: 100%;
    height: 96vh;
    background: #fff;
    border-radius: 20px 20px 0 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 -4px 32px rgba(0,0,0,0.18);
  }
  /* ── Header ── */
  .mau-sheet-head-{{ section_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 16px 0;
    flex-shrink: 0;
  }
  .mau-sheet-title-{{ section_id }} {
    font-size: 20px;
    font-weight: 700;
    margin: 0;
  }
  .mau-sheet-close-{{ section_id }} {
    cursor: pointer;
    line-height: 1;
    padding: 4px;
  }
  /* ── Tabs ── */
  .mau-tabs-{{ section_id }} {
    display: flex;
    gap: 0;
    border-bottom: 1px solid #ddd;
    padding: 12px 16px 0;
    flex-shrink: 0;
  }
  .mau-tab-{{ section_id }} {
    font-weight: 700;
    padding: 0 10px 10px 0;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    font-size: 15px;
    color: #111;
    background: none;
    border-top: none;
    border-left: none;
    border-right: none;
    font-family: inherit;
  }
  .mau-tab-{{ section_id }}.active {
    color: #03a3f7;
    border-bottom-color: #03a3f7;
  }
  /* ── Scrollable body ── */
  .mau-body-{{ section_id }} {
    flex: 1;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    padding: 0 12px;
  }
  /* ── Toolbar ── */
  .mau-toolbar-{{ section_id }} {
    display: flex;
    gap: 8px;
    padding: 14px 0 10px;
    align-items: center;
  }
  .mau-search-wrap-{{ section_id }} {
    flex: 1;
    display: flex;
    align-items: center;
    border: 1px solid #ddd;
    border-radius: 8px;
    padding: 0 10px;
    gap: 6px;
    min-width: 0;
    background: #fff;
  }
  .mau-search-wrap-{{ section_id }} svg { width: 18px; height: 18px; flex-shrink: 0; }
  .mau-search-input-{{ section_id }} {
    border: none;
    outline: none;
    font-size: 14px;
    width: 100%;
    padding: 8px 0;
    background: transparent;
  }
  .mau-sort-wrap-{{ section_id }} {
    display: flex;
    align-items: center;
    border: 1px solid #ddd;
    border-radius: 8px;
    padding: 0 10px;
    white-space: nowrap;
    font-size: 13px;
    flex-shrink: 0;
    background: #fff;
  }
  .mau-sort-wrap-{{ section_id }} select,
  .mau-sort-wrap-{{ section_id }} select:focus,
  .mau-sort-select-{{ section_id }} {
    border: none !important;
    outline: none !important;
    font-size: 13px !important;
    background: #ffffff !important;
    background-image: none !important;
    padding: 8px 0 8px 4px !important;
    -webkit-appearance: auto !important;
    appearance: auto !important;
  }
  /* ── Design grid ── */
  .mau-grid-{{ section_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
    padding-bottom: 8px;
    list-style: none;
    margin: 0;
    padding-left: 0;
  }
  @media (min-width: 480px) { .mau-grid-{{ section_id }} { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 700px) { .mau-grid-{{ section_id }} { grid-template-columns: repeat(4, 1fr); } }
  .mau-card-{{ section_id }} {
    border: 3px solid #fff;
    border-radius: 10px;
    word-break: break-word;
    position: relative;
    overflow: hidden;
    cursor: pointer;
    transition: border-color 0.15s;
  }
  .mau-card-{{ section_id }}.selected {
    border-color: #03a3f7;
    background: #e6f6ff;
  }
  /* checkbox top-right */
  .mau-card-check-{{ section_id }} {
    position: absolute;
    top: 8px;
    left: 8px;
    z-index: 9;
    width: 22px;
    height: 22px;
    border: 2px solid #bbb;
    border-radius: 4px;
    background: rgba(255,255,255,0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
  }
  .mau-card-{{ section_id }}.selected .mau-card-check-{{ section_id }} {
    background: #03a3f7;
    border-color: #03a3f7;
  }
  .mau-card-check-{{ section_id }}::after {
    content: '';
    display: none;
    width: 5px;
    height: 9px;
    border: 2px solid #fff;
    border-top: none;
    border-left: none;
    transform: rotate(45deg) translateY(-1px);
  }
  .mau-card-{{ section_id }}.selected .mau-card-check-{{ section_id }}::after { display: block; }
  /* image area — checkered bg */
  .mau-img-wrap-{{ section_id }} {
    height: 160px;
    background: #f2f2f2 url("data:image/svg+xml;base64,") center center;
    border-radius: 6px 6px 0 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-bottom: 1px solid #eee;
  }
  .mau-img-wrap-{{ section_id }} img {
    max-width: 90%;
    max-height: 90%;
    width: auto;
    height: auto;
    object-fit: contain;
  }
  /* card info */
  .mau-card-info-{{ section_id }} {
    padding: 8px;
  }
  .mau-card-name-{{ section_id }} {
    font-size: 13px;
    font-weight: 700;
    margin: 0 0 4px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .mau-card-meta-{{ section_id }} {
    font-size: 11px;
    color: #555;
    margin: 0;
    line-height: 1.4;
  }
  /* ── USE DESIGNS footer ── */
  .mau-footer-{{ section_id }} {
    padding: 10px 12px 12px;
    flex-shrink: 0;
    border-top: 1px solid #eee;
    background: #fff;
  }
  .mau-use-btn-{{ section_id }} {
    width: 100%;
    padding: 14px;
    font-size: 16px;
    font-weight: 700;
    background: #03a3f7;
    color: #fff;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    transition: background 0.2s;
  }
  .mau-use-btn-{{ section_id }}:disabled {
    background: #b0d9f5;
    cursor: not-allowed;
  }
  .mau-use-btn-{{ section_id }}:not(:disabled):hover { background: #0291dc; }
  /* ── Loading / empty ── */
  .mau-loader-{{ section_id }} { display: block; margin: 32px auto; }
  .mau-empty-{{ section_id }} { text-align: center; padding: 32px 0; color: #888; font-size: 14px; }
</style>

<div class="mau-wrap-{{ section_id }}" {{ section.shopify_attributes }}>

  <div class="uploadBox">
    <div
      class="uploadBox__layout"
      id="mau-dropzone-{{ section_id }}"
      role="button"
      tabindex="0"
      aria-label="Upload your design file"
    >
      <div class="uploadBox__content">

        <div class="uploadBox__icon">
          <img
            src="https://cdn.shopify.com/s/files/1/0558/0265/8899/files/image_9_89553aea-5c53-4c9d-be87-f468e46ee459.png?auto=format,compress&v=1757090125"
            alt="Upload"
            width="{{ section.settings.icon_size }}"
            loading="lazy"
          >
        </div>

        <h4 class="uploadBox__contentTitle">{{ section.settings.box_title }}</h4>
        <p class="uploadBox__contentText">{{ section.settings.box_subtitle }}</p>

        <label
          for="mau-fileinput-{{ section_id }}"
          class="uploadBox__contentButton"
        >
          <span class="mau-btn-text-{{ section_id }}">{{ section.settings.btn_label }}</span>
          <span class="mau-btn-loading-{{ section_id }}" style="display:none;">
            <span class="mau-spinner-{{ section_id }}"></span>{{ section.settings.uploading_text }}
          </span>
        </label>

        <div class="mau-error-{{ section_id }}" id="mau-error-{{ section_id }}"></div>

        {% if customer %}
          <button
            type="button"
            class="mau-prevdesign-{{ section_id }}"
            id="mau-prev-btn-{{ section_id }}"
          >
            {{ section.settings.prev_design_text }}
          </button>
        {% else %}
          <a
            href="/customer_authentication/login?return_to={{ shop.url }}/products/dtf-transfers"
            class="mau-prevdesign-{{ section_id }}"
          >
            {{ section.settings.login_text }}
          </a>
        {% endif %}

      </div>
    </div>
  </div>

  <input
    type="file"
    id="mau-fileinput-{{ section_id }}"
    accept="image/png,image/jpg,image/jpeg,application/pdf,image/tiff,image/svg+xml,application/postscript,.eps"
    style="position:absolute;width:1px;height:1px;opacity:0;overflow:hidden;pointer-events:none;"
    aria-hidden="true"
  >

</div>

{% if customer %}
<!-- ── Your Designs modal (fully scoped, no shared class conflicts) ── -->
<div id="mau-designs-modal-{{ section_id }}" style="display:none;">
  <div class="mau-sheet-{{ section_id }}">

    <!-- Header -->
    <div class="mau-sheet-head-{{ section_id }}">
      <h2 class="mau-sheet-title-{{ section_id }}">Your Designs</h2>
      <button type="button" class="mau-sheet-close-{{ section_id }}" id="mau-modal-close-{{ section_id }}" aria-label="Close">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M6 6L18 18" stroke="#000" stroke-width="2" stroke-linecap="round"/><path d="M18 6L6 18" stroke="#000" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
    </div>

    <!-- Tabs -->
    <div class="mau-tabs-{{ section_id }}">
      <button type="button" class="mau-tab-{{ section_id }} active" data-panel="mau-orders-{{ section_id }}">Orders</button>
      <button type="button" class="mau-tab-{{ section_id }}" data-panel="mau-uploads-{{ section_id }}">Uploads</button>
    </div>

    <!-- ── Orders panel ── -->
    <div id="mau-orders-{{ section_id }}" class="mau-body-{{ section_id }}">
      <div class="mau-toolbar-{{ section_id }}">
        <div class="mau-search-wrap-{{ section_id }}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="text" class="mau-search-input-{{ section_id }}" placeholder="Search upload name" data-panel="mau-orders-{{ section_id }}">
        </div>
        <div class="mau-sort-wrap-{{ section_id }}">
          Sort:
          <select class="mau-sort-select-{{ section_id }}" data-panel="mau-orders-{{ section_id }}">
            <option value="date_asc">Date added (newest first)</option>
            <option value="date_desc">Date added (oldest first)</option>
            <option value="file_name_asc">File name (A–Z)</option>
            <option value="file_name_desc">File name (Z–A)</option>
          </select>
        </div>
      </div>
      <img src="https://cdn.shopify.com/s/files/1/0558/0265/8899/files/loader-2.gif?v=1723724647" class="mau-loader-{{ section_id }}" id="mau-orders-loader-{{ section_id }}" width="40" alt="Loading">
      <ul class="mau-grid-{{ section_id }}" id="mau-orders-list-{{ section_id }}"></ul>
    </div>

    <!-- ── Uploads panel ── -->
    <div id="mau-uploads-{{ section_id }}" class="mau-body-{{ section_id }}" style="display:none;">
      <div class="mau-toolbar-{{ section_id }}">
        <div class="mau-search-wrap-{{ section_id }}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="text" class="mau-search-input-{{ section_id }}" placeholder="Search upload name" data-panel="mau-uploads-{{ section_id }}">
        </div>
        <div class="mau-sort-wrap-{{ section_id }}">
          Sort:
          <select class="mau-sort-select-{{ section_id }}" data-panel="mau-uploads-{{ section_id }}">
            <option value="date_asc">Date added (newest first)</option>
            <option value="date_desc">Date added (oldest first)</option>
            <option value="file_name_asc">File name (A–Z)</option>
            <option value="file_name_desc">File name (Z–A)</option>
          </select>
        </div>
      </div>
      <img src="https://cdn.shopify.com/s/files/1/0558/0265/8899/files/loader-2.gif?v=1723724647" class="mau-loader-{{ section_id }}" id="mau-uploads-loader-{{ section_id }}" width="40" alt="Loading">
      <ul class="mau-grid-{{ section_id }}" id="mau-uploads-list-{{ section_id }}"></ul>
    </div>

    <!-- Footer USE DESIGNS -->
    <div class="mau-footer-{{ section_id }}">
      <button type="button" disabled class="mau-use-btn-{{ section_id }}" id="mau-use-btn-{{ section_id }}">USE DESIGNS</button>
    </div>

  </div>
</div>
{% endif %}

<script>
(function() {
  var NINJA_API   = 'https://hpz51rjda5.execute-api.us-east-1.amazonaws.com/production';
  var IMGIX_HOST  = 'ninjauploads-production.imgix.net';
  var REDIRECT    = {{ section.settings.redirect_url | json }};
  var CUSTOMER_ID = {{ customer.id | default: 0 | json }};

  /* ────────────────────────────────
     Upload flow (Browse / drag-drop)
  ──────────────────────────────── */
  var wrap      = document.getElementById('mau-dropzone-{{ section_id }}');
  var fileInput = document.getElementById('mau-fileinput-{{ section_id }}');
  var btnText   = document.querySelectorAll('.mau-btn-text-{{ section_id }}');
  var btnLoad   = document.querySelectorAll('.mau-btn-loading-{{ section_id }}');
  var errBox    = document.getElementById('mau-error-{{ section_id }}');

  if (fileInput && wrap) {
    wrap.addEventListener('dragover', function(e) { e.preventDefault(); wrap.classList.add('drop-zone--over'); });
    ['dragleave','dragend'].forEach(function(ev) { wrap.addEventListener(ev, function() { wrap.classList.remove('drop-zone--over'); }); });
    wrap.addEventListener('drop', function(e) {
      e.preventDefault(); wrap.classList.remove('drop-zone--over');
      var f = e.dataTransfer && e.dataTransfer.files;
      if (f && f.length) handleFile(f[0]);
    });
    fileInput.addEventListener('change', function() { if (fileInput.files && fileInput.files[0]) handleFile(fileInput.files[0]); });
  }

  function showError(msg) {
    errBox.textContent = msg; errBox.style.display = 'block';
    btnText.forEach(function(el) { el.style.display = ''; });
    btnLoad.forEach(function(el) { el.style.display = 'none'; });
  }
  function setLoading(on) {
    btnText.forEach(function(el) { el.style.display = on ? 'none' : ''; });
    btnLoad.forEach(function(el) { el.style.display = on ? 'inline' : 'none'; });
    errBox.style.display = 'none';
  }

  async function handleFile(file) {
    setLoading(true);
    try {
      var ext  = (file.name.split('.').pop() || 'png').toLowerCase();
      var name = 'app-' + Date.now() + '-' + Math.random().toString(36).slice(2) + '.' + ext;
      var presignRes  = await fetch(NINJA_API + '/uploads/getPresignedUploadUrl?file_name=' + encodeURIComponent(name) + '&file_type=' + encodeURIComponent(file.type));
      if (!presignRes.ok) throw new Error('Could not prepare upload.');
      var presignData = await presignRes.json();
      if (!presignData || !presignData.url) throw new Error('No upload URL returned.');
      var putRes = await fetch(presignData.url, { method: 'PUT', headers: { 'Content-Type': file.type }, body: file });
      if (!putRes.ok) throw new Error('Upload failed. Please try again.');
      redirectWithFile('https://' + IMGIX_HOST + '/' + name + '?auto=format,compress');
    } catch(err) {
      showError(err.message || 'Something went wrong. Please try again.');
      fileInput.value = '';
    }
  }

  function redirectWithFile(url) {
    window.location.href = REDIRECT + (REDIRECT.indexOf('?') >= 0 ? '&' : '?') + 'file=' + encodeURIComponent(url);
  }

  /* ────────────────────────────────
     "Your Designs" modal
  ──────────────────────────────── */
  {% if customer %}
  var modal      = document.getElementById('mau-designs-modal-{{ section_id }}');
  var prevBtn    = document.getElementById('mau-prev-btn-{{ section_id }}');
  var closeBtn   = document.getElementById('mau-modal-close-{{ section_id }}');
  var useBtn     = document.getElementById('mau-use-btn-{{ section_id }}');
  var dataLoaded = false;
  var activePanel = 'mau-orders-{{ section_id }}';

  function openModal() {
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    if (!dataLoaded) { dataLoaded = true; loadDesigns(); }
  }
  function closeModal() {
    modal.style.display = 'none';
    document.body.style.overflow = '';
  }
  function getSelectedSrc() {
    var panel = document.getElementById(activePanel);
    if (!panel) return null;
    var cards = panel.querySelectorAll('.mau-card-{{ section_id }}.selected');
    return cards.length ? cards[0].dataset.src : null;
  }
  function updateUseBtn() {
    var panel = document.getElementById(activePanel);
    var count = panel ? panel.querySelectorAll('.mau-card-{{ section_id }}.selected').length : 0;
    useBtn.disabled = count === 0;
    useBtn.textContent = count > 1 ? 'USE ' + count + ' DESIGNS' : 'USE DESIGNS';
  }

  if (prevBtn)  prevBtn.addEventListener('click', function(e) { e.preventDefault(); openModal(); });
  if (closeBtn) closeBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', function(e) { if (e.target === modal) closeModal(); });

  /* ── Tab switching ── */
  document.querySelectorAll('.mau-tab-{{ section_id }}').forEach(function(tab) {
    tab.addEventListener('click', function() {
      document.querySelectorAll('.mau-tab-{{ section_id }}').forEach(function(t) { t.classList.remove('active'); });
      this.classList.add('active');
      var panelId = this.dataset.panel;
      activePanel = panelId;
      ['mau-orders-{{ section_id }}', 'mau-uploads-{{ section_id }}'].forEach(function(id) {
        var el = document.getElementById(id);
        if (el) el.style.display = id === panelId ? '' : 'none';
      });
      updateUseBtn();
    });
  });

  /* ── USE DESIGNS ── */
  useBtn.addEventListener('click', function() {
    var src = getSelectedSrc();
    if (src) { closeModal(); redirectWithFile(src); }
  });

  /* ── Card tap = select / deselect ── */
  document.addEventListener('click', function(e) {
    var card = e.target.closest('.mau-card-{{ section_id }}');
    if (!card) return;
    /* deselect all others in this panel, select this one */
    var panel = card.closest('.mau-body-{{ section_id }}');
    if (panel) panel.querySelectorAll('.mau-card-{{ section_id }}').forEach(function(c) { c.classList.remove('selected'); });
    card.classList.toggle('selected');
    updateUseBtn();
  });

  /* ── Fetch both tabs ── */
  function loadDesigns() {
    fetch(NINJA_API + '/uploads/orderDataNew?customer_id=' + CUSTOMER_ID + '&gangsheet=false')
      .then(function(r) { return r.json(); })
      .then(function(json) { renderList('mau-orders-list-{{ section_id }}', 'mau-orders-loader-{{ section_id }}', json.data || [], 'order'); })
      .catch(function() { renderError('mau-orders-list-{{ section_id }}', 'mau-orders-loader-{{ section_id }}'); });

    fetch(NINJA_API + '/uploads/fetchDataNew?customer_id=' + CUSTOMER_ID + '&gangsheet=false')
      .then(function(r) { return r.json(); })
      .then(function(data) { renderList('mau-uploads-list-{{ section_id }}', 'mau-uploads-loader-{{ section_id }}', data || [], 'upload'); })
      .catch(function() { renderError('mau-uploads-list-{{ section_id }}', 'mau-uploads-loader-{{ section_id }}'); });
  }

  function renderList(listId, loaderId, data, type) {
    var loader = document.getElementById(loaderId);
    var list   = document.getElementById(listId);
    if (loader) loader.style.display = 'none';
    if (!list) return;
    if (!data.length) { list.innerHTML = '<li class="mau-empty-{{ section_id }}">No designs found</li>'; return; }
    list.innerHTML = data.map(function(item) { return buildCard(item, type); }).join('');
  }
  function renderError(listId, loaderId) {
    var loader = document.getElementById(loaderId);
    var list   = document.getElementById(listId);
    if (loader) loader.style.display = 'none';
    if (list) list.innerHTML = '<li class="mau-empty-{{ section_id }}">Sorry! No data found</li>';
  }

  function getFileName(url) {
    if (!url) return '';
    var clean = url.split('?')[0];
    if (url.indexOf('imgix.net') > -1 || url.indexOf('ninja-services-production') > -1) return clean.replace('https://','').split('/')[1] || '';
    if (url.indexOf('amazonaws') > -1) return clean.replace('https://','').split('/')[2] || '';
    if (url.indexOf('upload.cloudlift.app') > -1) return (url.split('transferss/')[1] || clean.split('/').pop());
    return clean.split('/').pop();
  }
  function thumb(url) {
    if (!url) return '';
    return url + (url.indexOf('?') > -1 ? '&' : '?') + 'h=300&auto=compress&q=10&dpi=72';
  }
  function buildCard(item, type) {
    var fileUrl  = item.file || '';
    var fileName = getFileName(fileUrl);
    var thumbUrl = thumb(fileUrl);
    var size = type === 'order'
      ? (item.variant_title ? item.variant_title.split(' / ')[0].toLowerCase() : '')
      : (item.variant_title ? (function(v){ var p = v.split('x'); return Number(p[0]).toFixed(2) + ' × ' + Number(p[1]).toFixed(2); })(item.variant_title) : '');
    var when = (item.purchased_at || '');
    if (type === 'upload') when = when.replace('Purchased','Uploaded');
    return '<li class="mau-card-{{ section_id }}" data-src="' + fileUrl + '" data-name="' + fileName.toLowerCase() + '" data-date="' + (item.formatted_date||'') + '">' +
      '<div class="mau-card-check-{{ section_id }}"></div>' +
      '<div class="mau-img-wrap-{{ section_id }}">' +
        '<img src="' + thumbUrl + '" loading="lazy" alt="' + fileName + '">' +
      '</div>' +
      '<div class="mau-card-info-{{ section_id }}">' +
        '<p class="mau-card-name-{{ section_id }}">' + fileName + '</p>' +
        '<p class="mau-card-meta-{{ section_id }}">Size: <b>' + size + '</b><br>' + when + '</p>' +
      '</div>' +
    '</li>';
  }

  /* ── Search ── */
  document.querySelectorAll('.mau-search-input-{{ section_id }}').forEach(function(input) {
    input.addEventListener('input', function() {
      var val  = this.value.toLowerCase().trim();
      var list = document.querySelector('#' + this.dataset.panel + ' .mau-grid-{{ section_id }}');
      if (!list) return;
      list.querySelectorAll('li.mau-card-{{ section_id }}').forEach(function(li) {
        li.style.display = (li.dataset.name || '').indexOf(val) > -1 ? '' : 'none';
      });
    });
  });

  /* ── Sort ── */
  document.querySelectorAll('.mau-sort-select-{{ section_id }}').forEach(function(sel) {
    sel.addEventListener('change', function() {
      var list = document.querySelector('#' + this.dataset.panel + ' .mau-grid-{{ section_id }}');
      if (!list) return;
      var items = Array.from(list.querySelectorAll('li.mau-card-{{ section_id }}'));
      items.sort(function(a, b) {
        switch (sel.value) {
          case 'date_asc':      return (b.dataset.date||'').localeCompare(a.dataset.date||'');
          case 'date_desc':     return (a.dataset.date||'').localeCompare(b.dataset.date||'');
          case 'file_name_asc': return (a.dataset.name||'').localeCompare(b.dataset.name||'');
          case 'file_name_desc':return (b.dataset.name||'').localeCompare(a.dataset.name||'');
          default: return 0;
        }
      });
      items.forEach(function(li) { list.appendChild(li); });
    });
  });
  {% endif %}
})();
</script>

