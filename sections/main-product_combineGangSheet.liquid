            </div>

          {%- when 'custom_liquid' -%}
            <div style="margin-top:{{ block.settings.margin_top }}px; margin-bottom:{{ block.settings.margin_bottom }}px;" class="product-custom-liquid" {{ block.shopify_attributes }}>
              {{ block.settings.custom_liquid }}
            </div>

          {%- when 'icons' -%}

            {%- liquid
              assign show_block = true
