                  function get1stSelectedVariantID() {
                    try {
                      let makeTitle = '';
                      let op_1 = $( `.firstProductStart .product-variants .product-variant__container[option="1"] .product-variant__input:checked` );
                      let op_2 = $( `.firstProductStart .product-variants .product-variant__container[option="2"] .product-variant__input:checked` );
                      let op_3 = $( `.firstProductStart .product-variants .product-variant__container[option="3"] .product-variant__input:checked` );

                      if ( typeof op_1 !== 'undefined' ) {
                        op_1 = op_1.val();
                        makeTitle = op_1;
                      }
                      if ( typeof op_2 !== 'undefined' ) {
                        op_2 = op_2.val();
                        if ( typeof op_2 !== 'undefined' ) {
                          makeTitle = `${ makeTitle } / ${ op_2 }`;
                        }
                      }
                      if ( typeof op_3 !== 'undefined' ) {
                        op_3 = op_3.val();
                        if ( typeof op_3 !== 'undefined' ) {
                          makeTitle = `${ makeTitle } / ${ op_3 }`;
                        }
                      }
                      const firstVaraintSelected = findObjectByKey(allVariants, 'title', makeTitle);
                      // console.log ( 'firstVaraintSelected', firstVaraintSelected );
                      if ( typeof firstVaraintSelected !== 'undefined' && firstVaraintSelected ) {
                        $( `[name="id"]` ).val( firstVaraintSelected.id );
                        $( `.firstProductStart .qtyWithPrice__unitPrice .qtyWithPrice__price` ).text( `$${ firstVaraintSelected.price } ea` );
                        $( `.product-price .money` ).text( `$${ firstVaraintSelected.price }` );
                        $( `css-slider .firstProd, .product-gallery__thumbnails-holder .firstProd:not(.prodThumbMedia)` ).removeClass( `hidden` );
                        $( `css-slider .secondProd, .product-gallery__thumbnails-holder .secondProd:not(.prodThumbMedia)` ).addClass( `hidden` );
                        $( `.product-gallery__thumbnails-holder .thumbnail.firstProd` ).first().click();
                        $( `.firstProductStart [name="quantity"]` ).prop( `disabled`, false );
                        $( `.secondProductStart [name="quantity"]` ).prop( `disabled`, true );
                        const getQty = $( `.combineProductsGroup .combineProductsGroup__item[index="1"]` ).attr( `qty` );
                        $( `product-quantity [name="quantity"]` ).val( getQty );
                        return firstVaraintSelected;
                      } else {
                        const getQty = $( `.combineProductsGroup .combineProductsGroup__item[index="1"]` ).attr( `qty` );
                        $( `product-quantity [name="quantity"]` ).val( getQty );
                        return false;
                      }
                    } catch ( err ) {
                      console.log( `ERROR get1stSelectedVariantID()`, err.message );
                    }
                  }
                  function get2ndSelectedVariantID( isFirst='' ) {
                    try {
                      if ( isFirst == 'yes' ) {
                        $( `.secondProductStart` ).attr( `is-first`, `` );
                      }
                      let makeTitle = '';
                      let op_1 = $( `.secondProductStart .product-variants .product-variant__container[option="1"] .product-variant__input:checked` );
                      let op_2 = $( `.secondProductStart .product-variants .product-variant__container[option="2"] .product-variant__input:checked` );
                      let op_3 = $( `.secondProductStart .product-variants .product-variant__container[option="3"] .product-variant__input:checked` );

                      if ( typeof op_1 !== 'undefined' ) {
                        op_1 = op_1.val();
                        op_1 = op_1.replace( `___2nd`, '' );
                        makeTitle = op_1;
                      }
                      if ( typeof op_2 !== 'undefined' ) {
                        op_2 = op_2.val();
                        if ( typeof op_2 !== 'undefined' ) {
                          op_2 = op_2.replace( `___2nd`, '' );
                          makeTitle = `${ makeTitle } / ${ op_2 }`;
                        }
                      }
                      if ( typeof op_3 !== 'undefined' ) {
                        op_3 = op_3.val();
                        if ( typeof op_3 !== 'undefined' ) {
                          op_3 = op_3.replace( `___2nd`, '' );
                          makeTitle = `${ makeTitle } / ${ op_3 }`;
                        }
                      }
                      const secondVaraintSelected = findObjectByKey(allVariants__2nd, 'title', makeTitle);
                      // console.log ( 'secondVaraintSelected', secondVaraintSelected );
                      if ( typeof secondVaraintSelected !== 'undefined' && secondVaraintSelected ) {
                        $( `[name="id"]` ).val( secondVaraintSelected.id );
                        $( `.secondProductStart .qtyWithPrice__unitPrice .qtyWithPrice__price` ).text( `$${ secondVaraintSelected.price } ea` );
                        $( `.product-price .money` ).text( `$${ secondVaraintSelected.price }` );
                        $( `css-slider .secondProd, .product-gallery__thumbnails-holder .secondProd:not(.prodThumbMedia)` ).removeClass( `hidden` );
                        $( `css-slider .firstProd, .product-gallery__thumbnails-holder .firstProd:not(.prodThumbMedia)` ).addClass( `hidden` );
                        $( `.product-gallery__thumbnails-holder .thumbnail.secondProd` ).first().click();
                        $( `.firstProductStart [name="quantity"]` ).prop( `disabled`, true );
                        $( `.secondProductStart [name="quantity"]` ).prop( `disabled`, false );
                        const getQty = $( `.combineProductsGroup .combineProductsGroup__item[index="2"]` ).attr( `qty` );
                        $( `product-quantity [name="quantity"]` ).val( getQty );
                        return secondVaraintSelected;
                      } else {
                        const getQty = $( `.combineProductsGroup .combineProductsGroup__item[index="2"]` ).attr( `qty` );
                        $( `product-quantity [name="quantity"]` ).val( getQty );
                        return false;
                      }
                    } catch ( err ) {
                      console.log( `ERROR get2ndSelectedVariantID()`, err.message );
                    }
                  }

                  async function firstProdAdd2Cart() {
                    try {
                      let uploadedFile = $( `.firstProductStart [name="properties[Upload (Vector Files Preferred)]"]` ).val();
                      if ( typeof uploadedFile !== 'undefined' && uploadedFile ) {
                      } else {
                        uploadedFile = '';
                      }
                      let isChecked = false;
                      let isCheckBoxChecked = $( `.firstProductStart [name="properties[Artwork is print-ready]"]` ).length;
                      let checkboxVal = '';
                      if ( isCheckBoxChecked > 0 ) {
                        const checkingBox = $( `.firstProductStart [name="properties[Artwork is print-ready]"]` ).is( `:checked` );
                        if ( checkingBox ) {
                          isChecked = true;
                          checkboxVal = '✔';
                        }
                      } else {
                        isChecked = true;
                      }

                      const VID = $( `.firstProductStart .product-form [name="id"]` ).val() * 1;
                      const qty = $( `.firstProductStart .product-form [name="quantity"][type="number"]` ).val() * 1;

                      let item = {};

                      if ( typeof VID !== 'undefined' && VID && typeof qty !== 'undefined' && qty ) {
                        item.id = VID;
                        item.quantity = qty;
                      }

                      if ( typeof uploadedFile !== 'undefined' && uploadedFile ) {
                        if ( isChecked && typeof checkboxVal != '' ) {
                          item.properties = {
                            'Artwork is print-ready': '✔',
                            'Upload (Vector Files Preferred)': uploadedFile
                          }
                        } else if ( isChecked && typeof checkboxVal == '' ) {
                          item.properties = {
                            'Upload (Vector Files Preferred)': uploadedFile
                          }
                        } else {
                          return 'clickDefault';
                        }
                      } else {
                        return 'clickDefault';
                      }

                      console.log ( 'item', item );

                      let formData = {
                        'items': [item]
                      };

                      console.log ( 'formData', formData );
                      await fetch(window.Shopify.routes.root + 'cart/add.js', {
                        method: 'POST',
                        headers: {
                          'Content-Type': 'application/json'
                        },
                        body: JSON.stringify(formData)
                      })
                      .then(response => {
                        return response.json();
                      })
                      .catch((error) => {
                        console.error('Error:', error);
                      });
                    } catch ( err ) {
                      console.log( `ERROR `, err.message );
                    }
                  }
                </script>
