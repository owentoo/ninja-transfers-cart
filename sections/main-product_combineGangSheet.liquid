{% if ss.newStyleUpload %}
  <style>
    .filepond--drop-label {
      background-color: #e6f6ff;
      border: 2px dashed #46aae3;
      border-radius: 12px;
      margin-left: auto;
      margin-right: auto;
      font-family: var(--font-body-family);
      font-size: 18px !important;
      cursor: pointer;
      position: relative;
    }
    .filepond--drop-label:hover {
      box-shadow: 0 0 10px #46aae3;
    }
    .filepond--drop-label::before {
      display: none;
    }
    .filepond--drop-label::after {
      display: none;
    }
    .filepond--drop-label > label .label__d_n_d {
      display: block;
      text-align: center;
      width: 100%;
      margin-bottom: 18px;
      color: #000;
      font-weight: bold;
    }
    .filepond--drop-label > label .label__or {
      display: block;
      margin-bottom: 20px;
      font-size: 14px;
      text-align: center;
    }
    .filepond--drop-label > label .label__files {
      display: block;
      font-size: 12px;
      font-weight: normal;
      text-align: center;
      color: gray;
    }
    .filepond--drop-label > label b {
      border: 1px solid #46aae3;
      background-color: #46aae3;
      color: #fff;
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 14px 30px;
      border-radius: 16px;
      margin-bottom: 18px;
      margin-top: 30px;
      position: relative;
      cursor: pointer;
      font-weight: 600;
      z-index: 2;
    }
    .filepond--drop-label > label b:hover {
      background-color: #005192;
      color: #fff;
      box-shadow: 0 0 10px #46aae3;
    }
    .filepond--drop-label > label b:hover svg {
      stroke: #fff;
    }
    .customUploaderWrapper__content__svg {
      position: relative;
      width: 20px;
      height: 20px;
      stroke: #fff;
      display: inline-block;
      margin-top: 0;
    }

    .shopify-block.shopify-app-block [data-upload-field] .cl-upload--wrapper,
    .upload-container .cl-upload--wrapper {
      display: grid;
    }
    .shopify-block.shopify-app-block [data-upload-field] .cl-upload--label {
      display: none !important;
    }
    

    @media (max-width: 768px) {
      .product.changeLayout .cl-upload--wrapper {
        grid-template-columns: auto;
      }
      .filepond--drop-label > label .label__d_n_d {
        display: none;
      }
    }
    .product.changeLayout .cl-upload--wrapper .cl-upload--input-fields .cl-upload--input-field {
      display: block;
    }
  </style>
{% endif %}

