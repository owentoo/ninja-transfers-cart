{%- assign ss = section.settings -%}
{%- assign sb = section.blocks -%}
{% liquid
  assign _text = product.type | downcase | split : " " | join : "_"
%}
{% unless product == empty %}
  {% if product.metafields.antigro.designer %}
    <script>
      window.Designer = Object.assign(window.Designer || {}, {
        productParams: {{ product.metafields.antigro.designer }},
      });

      window.addEventListener('load', function () {
        window.KROWN.settings.locales.products_add_to_cart_button = {{ 'antigro.create_design' | t | json }};
      });
    </script>
  {% endif %}
{% endunless %}

{{ 'section-main-product.css' | asset_url | stylesheet_tag }}
{{ 'pdp.css' | asset_url | stylesheet_tag }}

{% if product.metafields.specs.default_child_color %}
  <script>
    const urlParams = new URLSearchParams(window.location.search);
    const viewParam = urlParams.get('view');
    if (viewParam) {
      const targetUrl = window.location.href.substring(0,window.location.href.indexOf('?')) + '?variant=' + viewParam;
      document.location = targetUrl;
    }
  </script>
{% elsif product.metafields.specs.shirt_color %}
  <script>
    const currentUrl = window.location.href;
    let pos = currentUrl.indexOf("-child");
    if (pos >= 0) {
      const urlParams = new URLSearchParams(window.location.search);
      const variantParam = urlParams.get('variant');
      const productStyle = "{{ product.metafields.specs.shirt_style | downcase }}";
      pos = currentUrl.toLowerCase().indexOf(productStyle);
      let targetUrl = currentUrl.substring(0,pos+productStyle.length)+"?variant={{ product.metafields.specs.shirt_color }}";
      if (variantParam) {
        targetUrl += "_" + variantParam;
      }
      document.location = targetUrl;
    }
  </script>
{% endif %}

{%- render 'breadcrumb', container: 'large', vertical_space: 'vertical-space', style: 'breadcrumb-main--margin breadcrumb-main--scroll element--hide-on-portable-plus' -%}
{%- capture allVariants -%}
  {% for variant in product.variants %}
    {
      "id": {{ variant.id | json }},
      "title": {{ variant.title | json }},
      "meta_sqinch": {{ variant.metafields.custom.price_buckets_sq_in_ | json }},
      {% if variant.featured_image != blank %}
        "thumb": {{ variant.featured_image | image_url: width: 100 | json }},
        "large": {{ variant.featured_image | image_url: width: 1000 | json }},
      {% else %}
        "thumb": null,
        "large": null,
      {% endif %}
      "media_id": {{ variant.featured_media.id | json }},
      "price": {{ variant.price | money_without_currency | json }}
    }
    {%- unless forloop.last -%}
      ,
    {%- endunless -%}
  {% endfor %}
{%- endcapture -%}
<script>
  const allVariants = [{{ allVariants }}];
</script>

{%- liquid
  if section.settings.gallery_desktop_width contains 'one-half'
    if section.settings.gallery_layout contains 'one-col'
      assign gallery_class = 'grid-1'
      assign parent_class = 'grid-2 grid-lap-1'
    else
      assign parent_class = 'grid-4 grid-lap-1'
      assign child_class = 'grid-offset-2 grid-offset-lap-1'
      assign gallery_class = 'grid-2 grid-portable-1'
      assign text_class = 'grid-offset-2 grid-offset-lap-1'
    endif
  else
    assign parent_class = 'grid-3 grid-portable-5 grid-lap-1'
    assign child_class = 'grid-offset-2 grid-offset-portable-3 grid-offset-lap-1'
    assign text_class = 'grid-portable-2 grid-offset-portable-2 grid-offset-lap-1'
    if section.settings.gallery_layout contains 'one-col'
      assign gallery_class = 'grid-1'
    else
      assign gallery_class = 'grid-2 grid-portable-1'
    endif
  endif
-%}

{%- liquid
  unless product.has_only_default_variant
    assign default_to_first_variant = section.settings.default_to_first_variant
  else
    assign default_to_first_variant = true
  endunless
-%}

{%- liquid
  assign selectedProduct = product
  if product.metafields.specs.default_child_color != blank
    assign page_url = content_for_header | split:'"pageurl":"' | last | split:'"' | first | split: request.host | last | replace:'\/','/' | replace:'%20',' ' | replace:'\u0026','&'
    assign param_color = nil

    for i in (1..1)
      unless page_url contains "?"
        break
      endunless
      assign query_string = page_url | split:'?' | last
      assign qry_parts= query_string | split:'&'

      for part in qry_parts
        assign key_and_value = part | split:'='
        if key_and_value.size > 1
          if key_and_value[0] == 'view' or key_and_value[0] == 'variant'
            assign param_arr = key_and_value[1] | split:'_'
            assign param_color = param_arr[0] | upcase | url_decode
          endif
        endif
      endfor
    endfor

    assign style_category = 'style-' | append: product.metafields.specs.shirt_style
    assign style_collection = product.collections | where: "handle", style_category | first

    paginate style_collection.products by 1000
      assign sortedColors = style_collection.products | sort: "url"
    endpaginate

    assign firstAvailableProduct = blank
    assign defaultProduct = blank
    assign selectedProduct = blank
    for style_product in sortedColors
      assign inventoryTotal=0
      for variant in style_product.variants
        assign inventoryTotal = inventoryTotal | plus:variant.inventory_quantity
      endfor

      assign shirt_color = style_product.metafields.specs.shirt_color | upcase
      if firstAvailableProduct == blank and inventoryTotal > 0
        assign firstAvailableProduct = style_product
      endif
      if style_product.metafields.specs.shirt_color == product.metafields.specs.default_child_color and inventoryTotal > 0
        assign defaultProduct = style_product
      endif
      if param_color and shirt_color == param_color
        assign selectedProduct = style_product
      endif
    endfor

    if defaultProduct == blank
      assign defaultProduct = firstAvailableProduct
    endif

    if selectedProduct == blank
      assign selectedProduct = defaultProduct
    endif
  endif
-%}

