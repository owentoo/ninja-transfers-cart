              function getTemplateLink() {
                try {
                  if ( typeof allVariantsForTemplates !== 'undefined' && allVariantsForTemplates ) {
                    let vid = $( `form[action="/cart/add"][data-type="add-to-cart-form"] [name="id"]` ).val();

                    if ( typeof vid !== 'undefined' && vid ) {
                      vid   = vid * 1;
                    } else {
                      return;
