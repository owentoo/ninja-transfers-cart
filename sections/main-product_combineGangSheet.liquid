                  $(".__prematched-text").find("a").attr({"href":"javascript:void(0)","data-vrntid":_vid});
                }

                $(".__prematched-text").find("a").click(function(){
                  var _data_vrntid = $(this).attr("data-vrntid");
                  let formData = {
                    'items': [{
                      'id': _data_vrntid,
                      'quantity': 1
                    }]
                  };

                  fetch(window.Shopify.routes.root + 'cart/add.js', {
                    method: 'POST',
                    headers: {
                      'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(formData)
                  })
                  .then(response => {
                    window.refreshCart()
                    return response.json();
                  })
                  .catch((error) => {
                    console.error('Error:', error);
                  });
                })
              })

