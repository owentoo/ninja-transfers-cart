{%- comment -%}── Count blocks & compute animation durations ──{%- endcomment -%}
{%- assign image_count = 0 -%}
{%- assign word_count = 0 -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'gallery_image' -%}
    {%- assign image_count = image_count | plus: 1 -%}
  {%- endif -%}
  {%- if block.type == 'rotating_word' -%}
    {%- assign word_count = word_count | plus: 1 -%}
  {%- endif -%}
{%- endfor -%}

{%- assign speed = section.settings.gallery_scroll_speed -%}
{%- assign dur_col0 = 400.0 | divided_by: speed -%}
{%- assign dur_col1 = 350.0 | divided_by: speed -%}
{%- assign dur_col2 = 450.0 | divided_by: speed -%}
{%- assign dur_row0 = 300.0 | divided_by: speed -%}
{%- assign dur_row1 = 350.0 | divided_by: speed -%}
{%- assign delay_row1 = dur_row1 | divided_by: 2.0 -%}

{%- assign per_col = image_count | plus: 2 | divided_by: 3 -%}

{%- comment -%}Rotating word timing{%- endcomment -%}
{%- assign word_speed = section.settings.word_rotation_speed -%}
{%- assign total_word_duration = word_speed | times: word_count -%}
{%- if word_count > 0 -%}
  {%- assign visible_pct = 100.0 | divided_by: word_count -%}
  {%- assign fade_in_end = visible_pct | times: 15 | divided_by: 100 -%}
  {%- assign fade_out_start = visible_pct | times: 85 | divided_by: 100 -%}
{%- endif -%}

<!-- ── Dynamic styles (scoped to this section instance) ── -->
<style>
  #shopify-section-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    overflow-x: hidden;
  }
  #shopify-section-{{ section.id }} .hero-right::before {
    background: linear-gradient(to bottom, {{ section.settings.bg_color }}, transparent);
  }
  #shopify-section-{{ section.id }} .hero h1 {
    font-size: {{ section.settings.h1_size_desktop }}px;
    line-height: 1.1;
    color: {{ section.settings.heading_color }};
  }
  #shopify-section-{{ section.id }} .hero .subtitle {
    font-size: {{ section.settings.subtitle_size_desktop }}px;
    line-height: 1.6;
    color: {{ section.settings.subtitle_color }};
    opacity: {{ section.settings.subtitle_opacity | divided_by: 100.0 }};
  }
  #shopify-section-{{ section.id }} .hero .feature {
    font-size: {{ section.settings.feature_size_desktop }}px;
    line-height: 1.4;
    color: {{ section.settings.feature_color }};
    opacity: {{ section.settings.feature_opacity | divided_by: 100.0 }};
  }
  #shopify-section-{{ section.id }} .hero .feature svg,
  #shopify-section-{{ section.id }} .hero .feature .feature-custom-icon {
    width: {{ section.settings.icon_size_desktop }}px;
    height: {{ section.settings.icon_size_desktop }}px;
  }
  #shopify-section-{{ section.id }} .hero {
    min-height: {{ section.settings.section_max_height }}px;
    max-height: {{ section.settings.section_max_height }}px;
  }

  /* Gallery column animation durations */
  #shopify-section-{{ section.id }} .gallery-col-0 {
    animation: scrollUp {{ dur_col0 }}s linear infinite;
  }
  #shopify-section-{{ section.id }} .gallery-col-1 {
    animation: scrollDown {{ dur_col1 }}s linear infinite;
  }
  #shopify-section-{{ section.id }} .gallery-col-2 {
    animation: scrollUp {{ dur_col2 }}s linear infinite;
  }

  /* Mobile row animation durations */
  #shopify-section-{{ section.id }} .mobile-row-0 {
    animation: scrollLeft {{ dur_row0 }}s linear infinite;
  }
  #shopify-section-{{ section.id }} .mobile-row-1 {
    animation: scrollRight {{ dur_row1 }}s linear infinite;
    animation-delay: -{{ delay_row1 }}s;
  }

  /* Rotating word keyframes */
  {%- if word_count > 1 -%}
    @keyframes rotateWord_{{ section.id }} {
      0% { opacity: 0; transform: translateY(10px); }
      {{ fade_in_end }}% { opacity: 1; transform: translateY(0); }
      {{ fade_out_start }}% { opacity: 1; transform: translateY(0); }
      {{ visible_pct }}% { opacity: 0; transform: translateY(10px); }
      100% { opacity: 0; transform: translateY(10px); }
    }
    {%- assign wi = 0 -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'rotating_word' -%}
        {%- assign word_delay = word_speed | times: wi -%}
        #shopify-section-{{ section.id }} .rotating-word-{{ wi }} {
          animation: rotateWord_{{ section.id }} {{ total_word_duration }}ms infinite;
          animation-delay: {{ word_delay }}ms;
        }
        {%- assign wi = wi | plus: 1 -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}

  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .hero {
      min-height: auto;
      max-height: none;
    }
    #shopify-section-{{ section.id }} .hero h1 {
      font-size: {{ section.settings.h1_size_mobile }}px;
      line-height: 1.15;
    }
    #shopify-section-{{ section.id }} .hero .subtitle {
      font-size: {{ section.settings.subtitle_size_mobile }}px;
      line-height: 1.5;
    }
    #shopify-section-{{ section.id }} .hero .feature {
      font-size: {{ section.settings.feature_size_mobile }}px;
      line-height: 1.4;
    }
    #shopify-section-{{ section.id }} .hero .feature svg,
    #shopify-section-{{ section.id }} .hero .feature .feature-custom-icon {
      width: {{ section.settings.icon_size_mobile }}px;
      height: {{ section.settings.icon_size_mobile }}px;
    }
  }
</style>

<!-- ── Hero markup ── -->
<div class="hero">
  <div class="hero-left">

    {%- if section.settings.badge_visible -%}
      <div class="badge">
        <span class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        <strong>{{ section.settings.badge_rating }}</strong> {{ section.settings.badge_review_text }}
      </div>
    {%- endif -%}

    <h1>
      {{ section.settings.heading_text }} <span class="count">{{ section.settings.customer_count }}</span> <span class="rotating-wrapper">
        {%- assign wi = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'rotating_word' -%}
            <span class="rotating-word rotating-word-{{ wi }}"
                  style="color: {{ block.settings.word_color }};{% if word_count == 1 %} opacity: 1; position: relative;{% endif %}"
                  {{ block.shopify_attributes }}>
              {{- block.settings.word_text -}}
            </span>
            {%- assign wi = wi | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </span>
    </h1>

    <p class="subtitle">{{ section.settings.subtitle_text }}</p>

    <div class="features">
      {%- for block in section.blocks -%}
        {%- if block.type == 'feature' -%}
          <div class="feature" {{ block.shopify_attributes }}>
            {%- if block.settings.custom_icon != blank -%}
              {%- assign icon_url = block.settings.custom_icon | image_url: width: 40 -%}
              <img class="feature-custom-icon" src="{{ icon_url }}" alt="" loading="lazy">
            {%- else -%}
              {%- case block.settings.icon -%}
                {%- when 'checkmark' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
                  </svg>
                {%- when 'star' -%}
                  <svg viewBox="0 0 24 24" fill="currentColor">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                  </svg>
                {%- when 'shield' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  </svg>
                {%- when 'truck' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                    <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
                  </svg>
              {%- endcase -%}
            {%- endif -%}
            {{ block.settings.feature_text }}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="buttons">
      {%- for block in section.blocks -%}
        {%- if block.type == 'button' -%}
          <a href="{{ block.settings.btn_url }}"
             class="btn btn-{{ block.settings.btn_style }}{% if block.settings.mobile_only %} btn-mobile-only{% endif %}"
             style="--btn-bg: {{ block.settings.btn_bg_color }}; --btn-text: {{ block.settings.btn_text_color }}; --btn-border: {{ block.settings.btn_border_color }};"
             {{ block.shopify_attributes }}>
            {{- block.settings.btn_text -}}
            <svg class="btn-arrow" width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 10h10"/><path d="M11 6l4 4-4 4"/></svg>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>

  <!-- Desktop vertical gallery (3 columns, CSS animated) -->
  <div class="hero-right">
    {%- if image_count > 0 -%}
      <div class="gallery-container">
        {%- for col in (0..2) -%}
          {%- assign col_start = col | times: per_col -%}
          {%- assign col_end = col_start | plus: per_col -%}
          <div class="gallery-col gallery-col-{{ col }}">
            {%- comment -%}Two passes for seamless infinite scroll{%- endcomment -%}
            {%- for pass in (0..1) -%}
              {%- assign img_idx = 0 -%}
              {%- for block in section.blocks -%}
                {%- if block.type == 'gallery_image' -%}
                  {%- if img_idx >= col_start and img_idx < col_end -%}
                    <div class="gallery-card">
                      {%- if block.settings.image != blank -%}
                        <img src="{{ block.settings.image | image_url: width: 400 }}"
                             alt="{{ block.settings.image.alt | escape }}"
                             loading="lazy"
                             width="400"
                             height="533">
                      {%- else -%}
                        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                  {%- assign img_idx = img_idx | plus: 1 -%}
                {%- endif -%}
              {%- endfor -%}
            {%- endfor -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<!-- Mobile horizontal gallery (2 rows, CSS animated, split half-and-half) -->
{%- if image_count > 0 -%}
  {%- assign half_count = image_count | plus: 1 | divided_by: 2 -%}
  <div class="mobile-gallery">
    <!-- Row 0: first half of images -->
    <div class="mobile-gallery-container">
      <div class="mobile-gallery-row mobile-row-0">
        {%- for pass in (0..1) -%}
          {%- assign img_i = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'gallery_image' -%}
              {%- if img_i < half_count -%}
                <div class="mobile-gallery-card">
                  {%- if block.settings.image != blank -%}
                    <img src="{{ block.settings.image | image_url: width: 320 }}"
                         alt="{{ block.settings.image.alt | escape }}"
                         loading="lazy"
                         width="160"
                         height="200">
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                </div>
              {%- endif -%}
              {%- assign img_i = img_i | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endfor -%}
      </div>
    </div>
    <!-- Row 1: second half of images -->
    <div class="mobile-gallery-container">
      <div class="mobile-gallery-row mobile-row-1">
        {%- for pass in (0..1) -%}
          {%- assign img_i = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'gallery_image' -%}
              {%- if img_i >= half_count -%}
                <div class="mobile-gallery-card">
                  {%- if block.settings.image != blank -%}
                    <img src="{{ block.settings.image | image_url: width: 320 }}"
                         alt="{{ block.settings.image.alt | escape }}"
                         loading="lazy"
                         width="160"
                         height="200">
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                </div>
              {%- endif -%}
              {%- assign img_i = img_i | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
{%- endif -%}

<!-- ── Static CSS ── -->
{% stylesheet %}
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

  /* Full-width section wrapper */
  .hero-section-root {
    overflow-x: hidden;
  }

  .hero {
    display: flex;
    overflow-y: clip;
    overflow-x: visible;
    position: relative;
    max-width: 1400px;
    margin: 0 auto;
    padding-left: 40px;
    font-family: 'Inter', sans-serif;
    color: #fff;
  }

  .hero-left {
    flex: 0 0 45%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 60px 40px 60px 0;
    z-index: 2;
  }

  /* Badge */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 0;
    font-size: 13px;
    color: #9ca3af;
    margin-bottom: 14px;
    width: fit-content;
  }

  .badge .stars {
    color: #fbbf24;
    font-size: 15px;
    letter-spacing: 2px;
  }

  .badge strong {
    color: #fff;
    font-weight: 700;
  }

  /* Heading */
  .hero h1 {
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 20px;
    letter-spacing: -1.5px;
  }

  .hero h1 .count {
    color: #fff;
  }

  .rotating-wrapper {
    display: inline-block;
    position: relative;
    width: 320px;
    height: 1.1em;
    vertical-align: bottom;
    text-align: left;
  }

  .hero h1 .rotating-word {
    position: absolute;
    left: 0;
    bottom: 0;
    display: inline-block;
    opacity: 0;
    white-space: nowrap;
  }

  /* Subtitle */
  .hero .subtitle {
    color: #9ca3af;
    line-height: 1.6;
    margin-bottom: 28px;
    max-width: 100%;
  }

  /* Features */
  .hero .features {
    display: flex;
    gap: 20px;
    margin-bottom: 36px;
    flex-wrap: nowrap;
    white-space: nowrap;
  }

  .hero .feature {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #d1d5db;
  }

  .hero .feature svg {
    width: 20px;
    height: 20px;
    color: #22c55e;
    flex-shrink: 0;
  }

  .hero .feature .feature-custom-icon {
    width: 20px;
    height: 20px;
    object-fit: contain;
    flex-shrink: 0;
  }

  /* Buttons */
  .hero .buttons {
    display: flex;
    gap: 14px;
  }

  .hero .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    border-radius: 12px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s;
    cursor: pointer;
    border: none;
    font-family: 'Inter', sans-serif;
    white-space: nowrap;
  }

  .hero .btn-primary {
    background: var(--btn-bg);
    color: var(--btn-text);
    box-shadow: 0 4px 20px color-mix(in srgb, var(--btn-bg) 40%, transparent);
  }

  .hero .btn-primary:hover {
    box-shadow: 0 6px 30px color-mix(in srgb, var(--btn-bg) 50%, transparent);
    transform: translateY(-2px);
  }

  .hero .btn-secondary {
    background: color-mix(in srgb, var(--btn-bg) 12%, transparent);
    color: var(--btn-text);
    border: 1px solid color-mix(in srgb, var(--btn-border) 15%, transparent);
  }

  .hero .btn-secondary:hover {
    background: color-mix(in srgb, var(--btn-bg) 20%, transparent);
    transform: translateY(-2px);
  }

  .hero .btn-outline {
    background: transparent;
    color: var(--btn-text);
    border: 2px solid color-mix(in srgb, var(--btn-border) 35%, transparent);
  }

  .hero .btn-outline:hover {
    border-color: color-mix(in srgb, var(--btn-border) 70%, transparent);
    transform: translateY(-2px);
  }

  .hero .btn-text {
    background: transparent;
    color: var(--btn-text);
    padding-left: 4px;
    padding-right: 4px;
  }

  .hero .btn-text:hover {
    opacity: 0.7;
  }

  .hero .btn-glass {
    background: color-mix(in srgb, var(--btn-bg) 8%, transparent);
    color: var(--btn-text);
    border: 1px solid color-mix(in srgb, var(--btn-border) 10%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .hero .btn-glass:hover {
    background: color-mix(in srgb, var(--btn-bg) 15%, transparent);
    transform: translateY(-2px);
  }

  .hero .btn-arrow {
    width: 18px !important;
    height: 18px !important;
    min-width: 18px;
    min-height: 18px;
    flex-shrink: 0;
    transition: transform 0.3s;
  }

  .hero .btn:hover .btn-arrow {
    transform: translateX(3px);
  }

  .hero .btn-mobile-only {
    display: none;
  }

  /* Desktop gallery */
  .hero-right {
    flex: 1;
    position: relative;
    overflow: hidden;
    min-width: 0;
  }

  .hero-right::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 150px;
    z-index: 2;
    pointer-events: none;
  }

  .gallery-container {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    height: 100%;
    padding: 0 20px;
    position: relative;
    overflow: hidden;
  }

  .gallery-col {
    flex: 1;
    min-width: 160px;
    display: flex;
    flex-direction: column;
    will-change: transform;
  }

  .gallery-card {
    border-radius: clamp(10px, 1.2vw, 16px);
    overflow: hidden;
    flex-shrink: 0;
    position: relative;
    background: #1a1a2e;
    aspect-ratio: 3/4;
    width: 100%;
    margin-bottom: 16px;
  }

  .gallery-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .gallery-card .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @keyframes scrollUp {
    0%   { transform: translateY(0); }
    100% { transform: translateY(-50%); }
  }

  @keyframes scrollDown {
    0%   { transform: translateY(-50%); }
    100% { transform: translateY(0); }
  }

  /* Mobile gallery */
  .mobile-gallery {
    display: none;
  }

  .mobile-gallery-container {
    overflow: hidden;
    width: 100%;
  }

  .mobile-gallery-row {
    display: flex;
    will-change: transform;
    padding: 6px 0;
  }

  .mobile-gallery-card {
    border-radius: 12px;
    overflow: hidden;
    flex-shrink: 0;
    background: #1a1a2e;
    width: 160px;
    height: 200px;
    margin-right: 12px;
  }

  .mobile-gallery-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .mobile-gallery-card .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @keyframes scrollLeft {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @keyframes scrollRight {
    0%   { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }

  /* Mobile responsive */
  /* Tablet breakpoint */
  @media (max-width: 1024px) {
    .hero-left {
      flex: 0 0 55%;
      padding-right: 20px;
    }

    .rotating-wrapper {
      width: auto;
    }

    .hero .features {
      flex-wrap: wrap;
      white-space: normal;
    }
  }

  @media (max-width: 768px) {
    .hero .btn-mobile-only {
      display: inline-flex;
    }

    .hero {
      flex-direction: column;
      min-height: auto;
      max-height: none;
      padding-bottom: 0;
      padding-left: 20px;
      padding-right: 20px;
    }

    .hero-left {
      flex: none;
      padding: 40px 0 30px;
    }

    .hero-right {
      display: none;
    }

    .mobile-gallery {
      display: block;
      overflow: hidden;
      margin-top: 10px;
      max-height: calc(140px * 2 + 12px - 18px);
    }

    .mobile-gallery-card {
      width: 112px;
      height: 140px;
    }

    .rotating-wrapper {
      width: auto;
    }

    .hero .features {
      flex-direction: column;
      white-space: normal;
      gap: 12px;
    }

    .hero .buttons {
      flex-direction: column;
    }

    .hero .btn {
      justify-content: center;
    }
  }

  /* Accessibility: respect reduced motion preference */
  @media (prefers-reduced-motion: reduce) {
    .gallery-col,
    .mobile-gallery-row {
      animation-play-state: paused !important;
    }
    .rotating-word {
      animation: none !important;
      opacity: 0 !important;
    }
    .rotating-word-0 {
      opacity: 1 !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "UGC Hero NJS",
  "tag": "section",
  "class": "hero-section-root",
  "max_blocks": 50,
  "settings": [
    {
      "type": "header",
      "content": "Badge"
    },
    {
      "type": "checkbox",
      "id": "badge_visible",
      "label": "Show star badge",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_rating",
      "label": "Rating number",
      "default": "4.9"
    },
    {
      "type": "text",
      "id": "badge_review_text",
      "label": "Review label",
      "default": "Based on 35,000+ Reviews"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading_text",
      "label": "Heading text (before number)",
      "default": "DTF Transfers Trusted by"
    },
    {
      "type": "text",
      "id": "customer_count",
      "label": "Customer count",
      "default": "225,000+"
    },
    {
      "type": "header",
      "content": "Subtitle"
    },
    {
      "type": "textarea",
      "id": "subtitle_text",
      "label": "Subtitle",
      "default": "Print ANY Design on ANY Product, Material or Color with 100+ Wash Durability. Make More For Less."
    },
    {
