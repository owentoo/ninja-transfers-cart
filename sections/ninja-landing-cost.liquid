<style>
  .ninja-cost-wrapper {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    line-height: 1.5;
    width: 100%;
    overflow-x: hidden;
  }
  .ninja-cost-wrapper * { box-sizing: border-box; }
  .ninja-container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .ninja-section { padding: 80px 0; background-size: cover; background-position: center; }
  .ninja-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
  .ninja-grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  .ninja-text-center { text-align: center; }
  
  /* Buttons */
  .ninja-btn { display: inline-flex; align-items: center; justify-content: center; padding: 16px 32px; font-weight: 700; border-radius: 8px; text-decoration: none; transition: all 0.2s; cursor: pointer; border: none; font-size: 1.125rem; }
  .ninja-btn-primary { background-color: #16a34a; color: white; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }
  .ninja-btn-primary:hover { background-color: #15803d; transform: translateY(-1px); }
  .ninja-btn-secondary { background-color: transparent; border: 2px solid #16a34a; color: #16a34a; }
  .ninja-btn-secondary:hover { background-color: #f0fdf4; }
  .ninja-btn-xl { padding: 20px 40px; font-size: 1.25rem; }

  /* Typography */
  .ninja-h1 { font-size: 3.5rem; font-weight: 800; line-height: 1.1; margin-bottom: 24px; color: inherit; }
  .ninja-h2 { font-size: 2.5rem; font-weight: 700; margin-bottom: 24px; color: inherit; }
  .ninja-h3 { font-size: 1.5rem; font-weight: 700; margin-bottom: 12px; color: inherit; }
  .ninja-text-lg { font-size: 1.125rem; opacity: 0.9; margin-bottom: 24px; color: inherit; }
  .ninja-badge { display: inline-block; background: #dcfce7; color: #166534; padding: 4px 12px; border-radius: 99px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; margin-bottom: 16px; letter-spacing: 0.05em; }

  /* Calculator Table */
  .ninja-table-card { background: white; border-radius: 16px; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1); overflow: hidden; border: 1px solid #e5e7eb; }
  .ninja-table-header { display: grid; grid-template-columns: 1fr 1fr 1fr; background: #111827; color: white; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; font-size: 0.875rem; }
  .ninja-table-header > div { padding: 20px; text-align: center; }
  .ninja-table-header > div:first-child { text-align: left; }
  .ninja-table-row { display: grid; grid-template-columns: 1fr 1fr 1fr; border-bottom: 1px solid #f3f4f6; align-items: center; }
  .ninja-table-row > div { padding: 20px; }
  .ninja-table-row:nth-child(even) { background-color: #f9fafb; }
  .ninja-val-old { text-align: center; font-size: 1.125rem; font-weight: 500; color: #6b7280; }
  .ninja-val-new { text-align: center; font-size: 1.25rem; font-weight: 700; color: #16a34a; background-color: #f0fdf4; }
  .ninja-table-total { display: grid; grid-template-columns: 1fr 1fr 1fr; background: #f9fafb; border-top: 2px solid #e5e7eb; }
  
  /* Cards */
  .ninja-card { padding: 32px; border-radius: 12px; border: 1px solid #e5e7eb; transition: transform 0.2s; background-size: cover; background-position: center; }
  .ninja-card:hover { transform: translateY(-4px); box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); }
  .ninja-icon-circle { width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 16px; background: #f3f4f6; }

  /* Responsive */
  @media (max-width: 768px) {
    .ninja-h1 { font-size: 2.5rem; }
    .ninja-grid-2, .ninja-grid-3 { grid-template-columns: 1fr; gap: 40px; }
    .ninja-btn { width: 100%; }
    .ninja-section { padding: 60px 0; }
    .ninja-table-header, .ninja-table-row, .ninja-table-total { font-size: 0.875rem; }
    .ninja-table-row > div { padding: 12px; }
  }
</style>

<div class="ninja-cost-wrapper">

  <!-- HERO -->
  <section class="ninja-section" style="background-color: {{ section.settings.hero_bg_color }}; {% if section.settings.hero_bg_image != blank %}background-image: url('{{ section.settings.hero_bg_image | image_url: width: 2000 }}');{% endif %} color: {{ section.settings.hero_text_color }};">
    <div class="ninja-container">
