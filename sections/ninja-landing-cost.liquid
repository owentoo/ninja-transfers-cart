          <h1 class="ninja-h1">{{ section.settings.hero_headline }}</h1>
          <p class="ninja-text-lg">{{ section.settings.hero_subtext }}</p>
          <div style="display:flex; flex-wrap:wrap; gap:16px; margin-bottom:24px;">
            <a href="{{ section.settings.hero_btn_link }}" class="ninja-btn ninja-btn-primary ninja-btn-xl">{{ section.settings.hero_btn_text }}</a>
          </div>
          <p style="display: flex; align-items: center; gap: 8px; font-size: 0.875rem; opacity: 0.8;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
            {{ section.settings.hero_sub_caption }}
          </p>
        </div>
        <div>
          {% if section.settings.hero_main_image != blank %}
            {{ section.settings.hero_main_image | image_url: width: 800 | image_tag: style: 'width: 100%; border-radius: 12px; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);', alt: 'Cost Breakdown' }}
          {% else %}
            <!-- Default Visual Placeholder -->
            <div style="background: white; border-radius: 12px; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1); border: 1px solid #e5e7eb; overflow: hidden; transform: rotate(1deg);">
                <div style="background: #111827; color: white; padding: 16px; text-align: center; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; font-size: 0.875rem;">Job Cost Breakdown (50 Shirts)</div>
