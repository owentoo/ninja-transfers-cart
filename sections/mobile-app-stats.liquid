<style>
  .mas-section {
    display: none;
    padding: {{ section.settings.padding_top }}px 16px {{ section.settings.padding_bottom }}px;
    background: #f5f7fb;
  }
  @media (max-width: 767px) {
    .mas-section { display: block; }
  }
  .mas-bar {
    background: #ffffff;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: space-around;
    padding: 14px 8px;
  }
  .mas-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    flex: 1;
    position: relative;
  }
  .mas-item + .mas-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 10%;
    height: 80%;
    width: 1px;
    background: #e2e8f0;
  }
  .mas-value {
    font-size: 13px;
    font-weight: 700;
    color: #111;
    white-space: nowrap;
  }
  .mas-value.green  { color: #22c55e; }
  .mas-value.stars  { color: #f59e0b; letter-spacing: 1px; }
  .mas-label {
    font-size: 10px;
    color: #64748b;
    text-align: center;
    white-space: nowrap;
  }
</style>

<div class="mas-section">
  <div class="mas-bar">
    {%- for block in section.blocks -%}
      {%- assign b = block.settings -%}
      <div class="mas-item" {{ block.shopify_attributes }}>
        <span class="mas-value {{ b.value_color }}">{{ b.value }}</span>
        <span class="mas-label">{{ b.label }}</span>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Stats Bar",
  "settings": [
    { "type": "range", "id": "padding_top",    "label": "Padding Top",    "min": 0, "max": 60, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding_bottom", "label": "Padding Bottom", "min": 0, "max": 60, "step": 4, "unit": "px", "default": 16 }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "value", "label": "Value", "default": "4.9 ★★★★★" },
        { "type": "text", "id": "label", "label": "Label", "default": "35k+ Reviews" },
        {
          "type": "select",
          "id": "value_color",
          "label": "Value Color",
          "options": [
            { "value": "",      "label": "Black" },
            { "value": "green", "label": "Green" },
            { "value": "stars", "label": "Gold"  }
          ],
          "default": ""
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Stats Bar",
      "blocks": [
        { "type": "stat", "settings": { "value": "★★★★★ 4.9", "label": "35k+ Reviews",  "value_color": "stars" } },
        { "type": "stat", "settings": { "value": "1-Day",      "label": "Fast Delivery", "value_color": "green" } },
        { "type": "stat", "settings": { "value": "$75+",       "label": "Free Shipping", "value_color": "" } },
        { "type": "stat", "settings": { "value": "125k+",      "label": "Customers",     "value_color": "" } }
      ]
    }
  ]
}
{% endschema %}
