{% if section.settings.filter_list != "" %}
  {% assign filtertype = section.settings.filter_list | truncate | downcase | split : "|" %}
  <style>
  {% for type in filtertype %}
   .custom-flilter-{{ section.id }} .facet-dyn-filter-{{ type | replace : " ","-" }}{display:none !important;}
  {% endfor %}
  </style>
{% endif %}

{% if collection.metafields.custom.tag_redirect != blank  %}
  {% assign urlParts = request.path | split: "/" %}
  {% assign urlPartsLastIndex = urlParts.size | minus: 1 %}
  {% assign targetCollectionName = urlParts[urlPartsLastIndex] %}
  {%- if urlParts.size == 4 %}
  <!--
  WORKING
  {{ urlParts.size }}
  {{ targetCollectionName }}
  {{ collection.metafields.custom.tag_redirect }}
  -->
  <script>
    (function () {
      try {
        const tagRedirects = {{ collection.metafields.custom.tag_redirect }};
        tagRedirects.forEach((a) => {
          const data = a.split('|');
          if (data[0].toLowerCase() == '{{ targetCollectionName }}') {
            document.location = data[1];
          }
        })
      }
      catch (e) {
        console.log("tag_redirect error: " + e);
      }
    })();
  </script>
  {%- endif %}
{%- endif %}

