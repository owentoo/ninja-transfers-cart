<!-- Craft page -->
{% if section.settings.new_design_format %}
  <style>
    .product-item .product-item__title .remove-line-height-space--small{margin-bottom:0;}
    .card__text-wrapper{display: flex; flex-flow: column wrap; gap: 2px; padding:24px;}
    .card__text-wrapper .collection-title{line-height:24px; margin:0;}
    .card__text-wrapper .product-item__title:not(.collection-title){line-height:26px; margin:0;}
    .product-item .product-item__image-no-slider img,.product-item .product-item__image-no-slider{border-radius:0; border:none;}
    #main-collection-product-grid{--grid-gap:24px}
    .product-variant__item .variant-img,.product-item__quick-buy{padding: 0px; border-radius: 0; line-height: 0; border-color: transparent;}
    #main-collection-product-grid .product-form{display:none;}
    .inline-offer-row{display:flex; flex-flow:row wrap; gap:8px;}
    .product-item__quick-buy{margin-top:0;}
    .product-item__quick-buy .product-variants{padding-top:12px;}
    .product-item__price{line-height:28px;}
    .product-item__quick-buy .variant-img{margin-right:6px;}
    .collection-facet a:hover{color:#00C4C4;}
    details.facets__disclosure summary.facets__summary-text{font-weight:bold;}
    @media(max-width:768px){
      .card__text-wrapper{padding:8px;}
      .inline-offer-row{flex-flow:coloum wrap;}
    }
  </style>
  <script>
    $(function(){
      
      $(".variant-img").hover(function(){
        var nwimg = $(this).attr('data-img');
        var pnode = $(this).parents(".product-item").find(".first-img-box")
        pnode.find(".img").attr({"src":nwimg,"srcset":nwimg});
        //console.log("data-img: ",$(this).attr('data-img'),pnode.find(".img"))
      },function(){
        var pnode = $(this).parents(".product-item").find(".second-image-box")
        var nwimg = pnode.attr('data-defimg');
        pnode.find(".first-img-box .img").attr({"src":nwimg,"srcset":nwimg});
        //console.log("data-defimg: ",$(".second-image-box").attr('data-defimg'),pnode.find(".first-img-box .img"))
      })
      
    })
  </script>
{% endif %}
<!-- ./Craft Page -->

<div class="ninja-collection-grid {{ section.settings.custom_class }} custom-flilter-{{ section.id }}"> 
  {% if section.settings.filters_position == "top" %}
    <div class="container--large" data-js-inert>
      {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
         {%- render 'facets-horizontal', results: collection, enable_filtering: section.settings.enable_filtering, enable_sorting: section.settings.enable_sorting -%}
      {%- endif -%}
    </div>
  {% endif %}
  
<div data-js-inert>
  
  {%- paginate collection.products by section.settings.products_number -%}
    
    <div class="container--large" id="{%- if isblankproduct -%} blank-collection-page {%- endif -%}">

      {%- if section.settings.filters_position == "sidebar" -%}

        <div class="grid grid-4 grid-portable-3 grid-lap-2 grid-tiny-1 grid--layout">

          {%- unless collection.products.size == 0 -%}
            <aside class="facets-sidebar element--is-sticky">
              {%- liquid
                if section.settings.enable_filtering or section.settings.enable_sorting
                  render 'facets-vertical', results: collection, enable_filtering: section.settings.enable_filtering, enable_sorting: section.settings.enable_sorting, location: 'desktop'
                endif
              -%}
            </aside>
          {%- endunless -%}

          <div id="CollectionProductGrid" class="grid grid--layout grid-{{ section.settings.products_inrow }} grid-portable-2 grid-tiny-1 grid-offset-3 grid-offset-portable-2 grid-offset-tiny-1">
            {%- unless collection.products.size == 0 -%}
              <div class="collection-heading-container grid grid--layout grid-1 grid-offset-{{ section.settings.products_inrow }} grid-offset-portable-2 grid-offset-tiny-1">{%- render 'facets-header',iscraft: section.settings.new_design_format, results: collection -%}</div>
            {%- endunless -%}
            <div id="main-collection-product-grid" data-id="{{ section.id }}" class="collection grid grid--layout grid-{{ section.settings.products_inrow }} grid-portable-2 grid-tiny-1 grid-offset-{{ section.settings.products_inrow }} grid-offset-portable-2 grid-offset-tiny-1">

      {%- else -%}

        <div id="CollectionProductGrid">
          <div id="main-collection-product-grid" data-id="{{ section.id }}" class="collection grid grid--layout grid-{{ section.settings.products_inrow }} grid-portable-3 grid-lap-2 grid-tiny-1">

      {%- endif -%}
          
            {% assign collection_node = collection %}
            {%- for product in collection.products -%}
              {%- liquid
                  if forloop.index < 3
                    assign preload = true
                  else 
                    assign preload = false
                  endif
                  render 'product-item',new_design_format: section.settings.new_design_format, collection_node:collection_node, isblankproduct:isblankproduct, product: product, section_blocks: section.blocks, index: forloop.index, layout: 'grid-4', preload: preload, show_badges: settings.show_badges, section_id: section.id, product_collection: collection
              -%}

            {%- else -%}

              {%- if collection.filters != empty -%}
                {%- liquid
                  assign sort_by = collection.sort_by | default: collection.default_sort_by
                  assign terms = collection.terms | escape
                  if collection.current_vendor
                    assign terms = collection.current_vendor | escape
                  endif
                  assign results_url = '?q=' | append: terms | append: '&options%5Bprefix%5D=last&sort_by=' | append: sort_by
                -%}
                  <p class="no-content-message rte">
                    {{ 'collections.empty' | t }}<br/>
                    {{ 'collections.use_fewer_filters_html' | t: link: results_url, class: 'button--text' }}
                  </p>
              {%- else %}
                <p class="no-content-message">
                  {{ 'products.grid.no_products_text' | t }}
                </p>
              {%- endif -%}
              
            {%- endfor -%}

        {%- if paginate.pages > 1 -%}
          <div class="grid-offset-3 grid-offset-portable-2 grid-offset-tiny-1">
            {%- render 'pagination', paginate: paginate %}
          </div>
        {%- endif -%}

          </div>
        </div>

      {%- if section.settings.filters_position == "sidebar" -%}
        </div>
      {%- endif -%}

    </div>

  {%- endpaginate -%}

</div>


{%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
  <sidebar-drawer id="site-filters-sidebar" class="sidebar sidebar--right" tabindex="-1" role="dialog" aria-modal="true" style="display:none">
    <div class="sidebar__header">
      <span class="sidebar__title">
        {{ 'collections.filter_and_sort' | t }}
      </span>
      <button class="sidebar__close" data-js-close>
        <span class="visually-hidden">{{ 'general.accessibility_labels.close_sidebar' | t }}</span>
        <span aria-hidden="true" aria-role="img">{%- render 'theme-symbols', icon: 'close' -%}</span>
      </button>
    </div>
    <div class="sidebar__body">
      {%- render 'facets-vertical', results: collection, enable_filtering: section.settings.enable_filtering, enable_sorting: section.settings.enable_sorting, location: 'mobile' -%}
    </div>
  </sidebar-drawer>
  <script src="{{ 'component-facets.js' | asset_url }}" defer></script>
{%- endif -%}

    </div>
