                          {% elsif customer and isEliteMember == false %}
                            {{ b.nonMember__fourthColTitle }}
                            <span class="toolTipWrap">
                              <svg class="toolTipIconIs" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px" width="18px" height="18px" viewBox="0 0 48 48" enable-background="new 0 0 48 48" xml:space="preserve">
                                <path fill="none" d="M0,0h48v48H0V0z"/>
                                <path fill="#abe2ff" d="M24,4C12.95,4,4,12.95,4,24s8.95,20,20,20s20-8.95,20-20S35.05,4,24,4z M26,34h-4V22h4V34z M26,18h-4v-4h4  V18z"/>
                              </svg>
                              <tooltip>{{ b.nonMember__tooltip }}</tooltip>
                            </span>
                            <br>
                            {% if b.nonMember__firstLinkLabel != blank and b.nonMember__firstLink != blank %}
                              <a
                                href="{{ b.nonMember__firstLink }}"
                                {% if b.nonMember__firstLink_NewTab %}
                                  target="_blank"
                                {% endif %}
                              >
                                {{ b.nonMember__firstLinkLabel }}
                              </a>
                            {% endif %}

                            {% if b.nonMember__secondLinkLabel != blank and b.nonMember__secondLink != blank %}
                              |
                              <a
                                href="{{ b.nonMember__secondLink }}"
                                {% if b.nonMember__secondLink_NewTab %}
                                  target="_blank"
                                {% endif %}
                              >
                                {{ b.nonMember__secondLinkLabel }}
                              </a>
                            {% endif %}
                          {% else %}
                            {{ b.notLoggedin__fourthColTitle }}
                            <span class="toolTipWrap">
                              <svg class="toolTipIconIs" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px" width="18px" height="18px" viewBox="0 0 48 48" enable-background="new 0 0 48 48" xml:space="preserve">
                                <path fill="none" d="M0,0h48v48H0V0z"/>
                                <path fill="#abe2ff" d="M24,4C12.95,4,4,12.95,4,24s8.95,20,20,20s20-8.95,20-20S35.05,4,24,4z M26,34h-4V22h4V34z M26,18h-4v-4h4  V18z"/>
                              </svg>
                              <tooltip>{{ b.notLoggedin__tooltip }}</tooltip>
                            </span>
                            <br>
                            {% if b.notLoggedin__firstLinkLabel != blank and b.notLoggedin__firstLink != blank %}
                              <a
                                href="{{ b.notLoggedin__firstLink }}"
                                {% if b.notLoggedin__firstLink_NewTab %}
                                  target="_blank"
                                {% endif %}
                              >
                                {{ b.notLoggedin__firstLinkLabel }}
                              </a>
                            {% endif %}

                            {% if b.notLoggedin__secondLinkLabel != blank and b.notLoggedin__secondLink != blank %}
                              |
                              <a
                                href="{{ b.notLoggedin__secondLink }}"
                                {% if b.notLoggedin__secondLink_NewTab %}
                                  target="_blank"
                                {% endif %}
                              >
                                {{ b.notLoggedin__secondLinkLabel }}
                              </a>
                            {% endif %}
                          {% endif %}
                        </div>
                      </div>
                    {% endif %}

                    {% for item in customTabelItems %}
                      {%- assign tItems = item.settings -%}
                      {%- capture minMax -%}
                        {%- if tItems.title contains '-' -%}
                          {%- assign min = tItems.title | split: '-' | first | strip -%}
                          {%- assign max = tItems.title | split: '-' | last | strip -%}
                        {%- elsif tItems.title contains '+' -%}
                          {%- assign min = tItems.title | split: '+' | first | strip -%}
                          {%- assign max = 1000000 -%}
                        {%- endif -%}
                      {%- endcapture -%}
                      {%- capture percentages -%}
                        {%- if tItems.title_2 contains '%' -%}
                          {%- assign offPercentage = tItems.title_2 | split: '%' | first | strip -%}
                        {%- endif -%}
                      {%- endcapture -%}
                      {% if forloop.first %}
                        {%- assign getUnitPrice_1st = tItems.title_3 | default: '&nbsp;' -%}
                      {% endif %}
                      {%-liquid
                        capture lastColOff
                          assign lastColOffPercentage = tItems.title_4 | split: '<elite-discount>' | last | split: '</elite-discount>' | first
                          echo lastColOffPercentage | strip
                        endcapture
                      -%}
                      {% if forloop.first %}
                        <div class="customTabelPlace__itemsWrap vAll">

                      {% endif %}
                      {%- capture collectJS -%}
                        {{ collectJS }}
                        let rowIndex__{{ forloop.index }} = `{{ max }}`;
                      {%- endcapture -%}
                        <div class="customTabelPlace__item" index="{{ forloop.index }}" min="{{ min }}" max="{{ max }}" off="{{ offPercentage }}" elite-discount="{{ lastColOff }}">
                          <div class="customTabelPlace__item_1">
                            {{ tItems.title | default: '&nbsp;' }}{% if forloop.first %} {{ b.firstRowText }}{% endif %}
                          </div>
                          <div class="customTabelPlace__item_2">
                            {% if forloop.first %}
                              &nbsp;
                            {% else %}
                              {{ tItems.title_2 | default: '&nbsp;' }}
                            {% endif %}
                          </div>
                          <div class="customTabelPlace__item_3">
                            <span>
                              {{ tItems.title_3 | default: '&nbsp;' }}
                            </span>
                          </div>
                          <div class="customTabelPlace__item_4">
                            {{ tItems.title_4 | default: '&nbsp;' }}
                          </div>
                        </div>
                      {% if forloop.last %}
                          <div class="customTabelPlace__item__selectedBar"></div>
                        </div>
                      {% endif %}
                    {% endfor %}
                  </div>
                </div>
                <style>
                  .customTabelPlace__heading_3 {
                    text-align: right;
                  }
                  .customTabelPlace__heading_3 > span {
                    text-align: left;
                    display: inline-block;
                    width: 100%;
                    max-width: 90px;
                  }
                  .customTabelPlace__item_3 {
                    text-align: right !important;
                  }
                  .customTabelPlace__item_3 > span {
                    text-align: left;
                    display: inline-block;
                    width: 100%;
                    max-width: 90px;
                  }

                  .customTabelPlace.rowList .customTabelPlace__item__selectedBar {
                    position: absolute;
                    left: 0;
                    top: 0;
                    width: 100%;
                    height: 40px;
                    transition: .3s ease-in-out;
                    border-radius: 8px;
                    background-color: #cfefff;
                    z-index: -1;
                  }
                  .customTabelPlace__heading_3 {
                    text-align: right;
                  }
                  .customTabelPlace__heading_3 > span {
                    text-align: left;
                    display: inline-block;
                    width: 100%;
                    max-width: 90px;
                  }
                  .customTabelPlace__item_3 {
                    text-align: right !important;
                  }
                  .customTabelPlace__item_3 > span {
                    text-align: left;
                    display: inline-block;
                    width: 100%;
                    max-width: 90px;
                  }
                </style>
                <script style="display: none;">
                  {{ collectJS }}
                  window.addEventListener('load', function() {
                    setTimeout(() => {
                      setSelectedRow();
                    }, 2000);
                  })
                  $( document )
                  .on(`click`, `.customTabelPlace__itemWrapViewAll`, function( e ) {
                    try {
                      e.stopImmediatePropagation();
                      const isViewAll = $( this ).closest( `.customTabelPlace__itemsWrap.vAll` ).length;
                      let qty = $( `.customQtyFile__qty` ).val() * 1;
                      if ( typeof alreadyCartItems !== 'undefined' && alreadyCartItems.length > 0 ) {
                        selectedCartItem = findObjectByKey( alreadyCartItems, 'pid', currentPID );
                        if ( typeof selectedCartItem !== 'undefined' && selectedCartItem ) {
                          qty = qty + selectedCartItem.qty;
                        }
                      }

                      if ( typeof rowIndex__1 !== 'undefined' && rowIndex__1 ) {
                        rowIndex__1 = rowIndex__1 * 1;
                      } else {
                        rowIndex__1 = 14;
                      }

                      if ( qty > rowIndex__1 ) {
                        $( this ).removeClass( `hidden` );
                        if ( isViewAll > 0 ) {
                          $( this ).closest( `.customTabelPlace__itemsWrap.vAll` ).removeClass( `vAll` );
                          $( `.customTabelPlace__itemWrapViewAll > span` ).text( `hide` );
                        } else {
                          $( this ).closest( `.customTabelPlace__itemsWrap` ).addClass( `vAll` );
                          $( `.customTabelPlace__itemWrapViewAll > span` ).text( `view all` );
                        }
                        const getHeight = $( `.customTabelPlace .customTabelPlace__item.selected` ).outerHeight();
                        let getTopPosition = $( `.customTabelPlace .customTabelPlace__item.selected` ).position().top;

                        $( `.customTabelPlace__item__selectedBar` ).css({
                          "top": `${ getTopPosition }px`,
                          "height": `${ getHeight }px`
                        });
                      } else {
                        $( this ).addClass( `hidden` );
                      }
                    } catch ( err ) {
                      console.log( `ERROR .customTabelPlace__itemWrapViewAll`, err.message );
                    }
                  })
                  $(document)
                  .ready(function () {
                    customTabelManage( {{ product.selected_or_first_available_variant.id | json }} );
                  })

                  .on(`click`, `product-variants .product-variant .product-variant__item.product-variant__item--radio`, function( e ) {
                    try {
                      e.stopImmediatePropagation();
                      setTimeout(()=>{
                        let vid = $( `[name="id"]` ).val() * 1;
                        let getVariantParam = getParam( `variant` );
                        getVariantParam = getVariantParam * 1;
                        //console.log ( 'vid', vid, getVariantParam );
                        if ( typeof customTabelManage === 'function' ) {
                          if ( getVariantParam != vid ) {
                            vid = getVariantParam;
                          }
                          customTabelManage( vid, 'applyImg' );
                        }
                      }, 300);
                    } catch ( err ) {
                      //console.log( `ERROR product-variants .product-variant .product-variant__item.product-variant__item--radio`, err.message );
                    }
                  })

                  {% if b.selectorQtyIncreaseType != 'disabled' and b.selectorQtyIncrease != blank %}
                    .on(`{{ b.selectorQtyIncreaseType }}`, `{{ b.selectorQtyIncrease }}`, function( e ) {
                      try {
                        e.stopImmediatePropagation();
                        setTimeout(()=>{
                          const vid = $( `[name="id"]` ).val() * 1;
                          if ( typeof customTabelManage === 'function' ) {
                            customTabelManage( vid );
                          }
                        }, 300);
                      } catch ( err ) {
                        //console.log( `ERROR b.selectorQtyIncrease`, err.message );
                      }
                    })
                  {% endif %}
                  {% if b.selectorQtyInputType != 'disabled' and b.selectorQtyInput != blank %}
                    .on(`{{ b.selectorQtyInputType }}`, `{{ b.selectorQtyInput }}`, function( e ) {
                      try {
                        e.stopImmediatePropagation();
                        setTimeout(()=>{
                          const vid = $( `[name="id"]` ).val() * 1;
                          if ( typeof customTabelManage === 'function' ) {
                            customTabelManage( vid );
                          }
                        }, 300);
                      } catch ( err ) {
                        //console.log( `ERROR b.selectorQtyInput`, err.message );
                      }
                    })
                  {% endif %}

                  {% if b.selectorQtyDecreaseType != 'disabled' and b.selectorQtyDecrease != blank %}
                    .on(`{{ b.selectorQtyDecreaseType }}`, `{{ b.selectorQtyDecrease }}`, function( e ) {
                      try {
                        e.stopImmediatePropagation();
                        setTimeout(()=>{
                          const vid = $( `[name="id"]` ).val() * 1;
                          if ( typeof customTabelManage === 'function' ) {
                            customTabelManage( vid );
                          }
                        }, 300);
                      } catch ( err ) {
                        //console.log( `ERROR b.selectorQtyDecrease`, err.message );
                      }
                    })
                  {% endif %}
                  ;
                  function customTabelManage( vid, changeImg = '' ) {
                    try {
                      //console.log ( 'chaaaaa' );
                      const currentVariant = findObjectByKey( allVariants, `id`, vid );
                      if ( typeof currentVariant !== 'undefined' && currentVariant ) {
                        //console.log ( 'currentVariant', currentVariant );

                        const vPrice      = currentVariant.price * 1;
                        const percent_100 = 100;
                        $( `.customTabelPlace .customTabelPlace__item` ).each(function() {
                          let getOff  = $( this ).attr( `off` ) * 1;
                          getOff      = ( percent_100 - getOff ) / 100;
                          $( this )
                            .find( `discount` )
                            .text( `${ ( vPrice * getOff ).toFixed(2) }` );
                        })
                      }
                      if ( changeImg == 'applyImg' ) {
                        $( `.product__mainImg` )
                          .attr( `src`, currentVariant.large )
                          .fadeIn();
                        $( `.product__mainImgWrap iframe` )
                          .fadeOut();
                        $( `media-gallery .product__thumbItem` )
                          .removeClass( `selected` );
                        $( `.product__thumbItem.currentVariant` )
                          .attr( `img`, currentVariant.large )
                          .addClass( `selected` )
                          .find( `img` )
                          .attr( `src`, currentVariant.thumb );

                        {% if ss.hideVariantImages %}
                          if ( typeof currentVariant.media_id !== 'undefined' && currentVariant.media_id ) {
                            const is_mainMediaAvailable = $( `[data-media-id="${ currentVariant.media_id }"]` ).length;
                            const is_thumbMediaAvailable = $( `[data-thumb-id="${ currentVariant.media_id }"]` ).length;

                            if ( is_mainMediaAvailable > 0 && is_thumbMediaAvailable > 0 ) {
                              $( `.prodMainMedia, .prodThumbMedia` ).addClass( `hidden` );
                              $( `.prodMainMedia[data-media-id="${ currentVariant.media_id }"], .prodThumbMedia[data-thumb-id="${ currentVariant.media_id }"]` ).removeClass( `hidden` );

                              $( `.css-slider-viewport` ).addClass( 'processing' );
                              $( `.prodThumbMedia[data-thumb-id="${ currentVariant.media_id }"]` ).click();
                              setTimeout(() => {
                                $( `.css-slider-viewport` ).removeClass( 'processing' );
                                $( `.thumbnail.hidden.prodThumbMedia.active` ).removeClass( `hidden` );
                              }, 700);
                            }
                          }
                        {% endif %}
                      }

                      if ( typeof manageQuantities === 'function' ) {
                        manageQuantities();
                      } else {
                        let qty         = $( `.customQtyFile__qty` ).val();
                        if ( typeof qty !== 'undefined' && qty ) {
                          qty = qty * 1;
                        } else {
                          const qty__ = $( `product-quantity .qty[name="quantity"]` ).val();
                          if ( typeof qty__ !== 'undefined' && qty__ ) {
                            qty = qty__ * 1;
                          }
                        }
                        let selectedIndex = 0;
                        $( `.customTabelPlace .customTabelPlace__item` ).each(function() {
                          const min     = $( this ).attr( `min` ) * 1;
                          const max     = $( this ).attr( `max` ) * 1;
                          const indexNo = $( this ).attr( `index` ) * 1;
                          if ( qty >= min && qty <= max ) {
                            selectedIndex = indexNo;
                            const percentage  = $( this ).find( `.customTabelPlace__item_2` ).text().trim();
                            const unitPrice   = $( this ).find( `.customTabelPlace__item_3` ).text().trim();
                            $( `.customQtyFile__selectedData.percentage` ).html( `${ percentage !== '' ? percentage : `&nbsp;` }` );
                            $( `.customQtyFile__selectedData.unitPrice > span` ).html( `${ unitPrice !== '' ? unitPrice : `&nbsp;` }` );
                          }
                        })
                      }
                    }
                    catch ( err ) {
                      //console.log( `ERROR customTabelManage()`, err.message );
                    }
                  }
                </script>
              {% endif %}
            {% endif %}

          {%- when 'customSeparator' -%}
            <hr style="display: block; margin-top: {{ b.marginTop | append: 'px' }}; margin-bottom: {{ b.marginBottom | append: 'px' }};">

          {%- when 'customBadgesPlace' -%}
            <style>
              .customBadgesPlace {
                margin-top: 0;
                display: flex;
                -moz-column-gap: 20px;
                    column-gap: 20px;
                row-gap: 4px;
                flex-wrap: wrap;
              }
              .customBadgesPlace__item {
                display: inline-flex;
                gap: 0.7rem;
                align-items: center;
                margin-right:16px;
              }
              .customBadgesPlace__item[popup=true] {
                cursor: pointer;
              }
              .customBadgesPlace__item__icon {
                max-width: 16px;
                width: 100%;
              }
              .customBadgesPlace__item a {
                display: flex;
                gap: 0.7rem;
                align-items: center;
                text-decoration: none;
                color: rgba(var(--color-foreground), 0.75);
              }
              .modalDialog {
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                z-index: 10000;
                display: none;
              }
              .modalDialog .modalDialog__centerCenter__close.modalDialog__overlay {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background-color: rgba(0, 0, 0, 0.659);
                z-index: -1;
                cursor: default;
              }
              .modalDialog__centerCenter {
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                border-radius: 14px;
                background-color: #fff;
                max-width: 450px;
                width: calc(100% - 30px);
                padding: 100px 40px 80px;
              }
              .modalDialog__centerCenter::before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 50px;
                background-color: rgb(var(--color-foreground));
                border-radius: 14px 14px 0 0;
              }
              .modalDialog__centerCenter__close {
                position: absolute;
                top: 10px;
                right: 15px;
                width: 30px;
                height: 30px;
                cursor: pointer;
                display: grid;
                align-items: center;
                justify-content: center;
              }
              .modalDialog__centerCenter__content {
                display: grid;
                gap: 0px;
                width: 100%;
              }
              .modalDialog__centerCenter__content--title {
                font-weight: bold;
                margin-bottom: 20px;
                font-size: 2rem;
                line-height: 120%;
              }
              .modalDialog__centerCenter__content--detail {
                margin-bottom: 20px;
                line-height: 150%;
              }
              .modalDialog__centerCenter__content--detail iframe {
                aspect-ratio: 6/4;
              }
              .modalDialog__centerCenter__content--list {
                padding-left: 0;
                list-style: none;
              }
              .modalDialog__centerCenter__content--list li {
                display: flex;
                justify-content: space-between;
              }
              .modalDialog__centerCenter__content--list li._head_ {
                font-weight: bold;
              }
            </style>
            <script>
              // MODAL EVENTS START
              $( document )
              .on(`click`, `.customBadgesPlace__item[popup="true"]`, function( e ) {
                try {
                  e.stopImmediatePropagation();
                  const getBlockID = $( this ).attr( `block` );
                  $( `.modalDialog[block="${ getBlockID }"]` ).fadeIn();
                  const isIframeAvailable = $( `.modalDialog[block="${ getBlockID }"] .modalDialog__centerCenter__content--detail iframe` ).length;
                  const isIframeOldSrcAvailable = $( `.modalDialog[block="${ getBlockID }"] .modalDialog__centerCenter__content--detail iframe[src-old]` ).length;
                  if ( isIframeAvailable > 0 && isIframeOldSrcAvailable > 0 ) {
                    const videoSrc = $( `.modalDialog[block="${ getBlockID }"] .modalDialog__centerCenter__content--detail iframe` ).attr( `src-old` );
                    $( `.modalDialog[block="${ getBlockID }"] .modalDialog__centerCenter__content--detail iframe` )
                      .removeAttr( `src-old` )
                      .attr( `src`, videoSrc );
                  }
                } catch ( err ) {
                  //console.log( `ERROR .customBadgesPlace__item[popup="true"]`, err.message );
                }
              })
              .on(`click`, `.modalDialog__centerCenter__close`, function( e ) {
                try {
                  e.stopImmediatePropagation();
                  $( this ).closest( `.modalDialog` ).fadeOut();
                  const isIframeAvailable = $( this ).closest( `.modalDialog` ).find( `.modalDialog__centerCenter__content--detail iframe` ).length;
                  if ( isIframeAvailable > 0 ) {
                    const videoSrc = $( this ).closest( `.modalDialog` ).find( `.modalDialog__centerCenter__content--detail iframe` ).attr( `src` );
                    $( this ).closest( `.modalDialog` ).find( `.modalDialog__centerCenter__content--detail iframe` )
                      .removeAttr( `src` )
                      .attr( `src-old`, videoSrc );
                  }
                } catch ( err ) {
                  //console.log( `ERROR .modalDialog__centerCenter__close`, err.message );
                }
              })
              ;
              // MODAL EVENTS END
            </script>
            {%- assign badgesItems = sb | where: 'type', 'customBadgesItem' -%}
            {% if badgesItems.size > 0 %}
              <div class="customBadgesPlace">
                {% for item in badgesItems %}
                  {%- assign item_b = item.settings -%}
                  {% if item_b.title != blank %}
                    {% if item_b.link != blank %}
                      <div class="customBadgesPlace__item {% if item_b.showStepOn != 'beforeUpload' %}hidden{% endif %}" item-show-on="{{ item_b.showStepOn }}" block="{{ block.id }}__{{ forloop.index }}">
                        <a href="{{ item_b.link }}">
                          {% if item_b.icon != blank %}
                            <img src="{{ item_b.icon | img_url: '100x' }}" alt="{{ item_b.title | escape }}" class="customBadgesPlace__item__icon">
                          {% endif %}

                          <div class="customBadgesPlace__item__title">
                            {{ item_b.title }}
                          </div>
                        </a>
                      </div>
                    {% else %}
                      <div class="customBadgesPlace__item {% if item_b.showStepOn != 'beforeUpload' %}hidden{% endif %}" item-show-on="{{ item_b.showStepOn }}" popup="{{ item_b.popupShow }}" block="{{ block.id }}__{{ forloop.index }}">
                        {% if item_b.icon != blank %}
                          <img src="{{ item_b.icon | img_url: '100x' }}" alt="{{ item_b.title | escape }}" class="customBadgesPlace__item__icon">
                        {% endif %}

                        <div class="customBadgesPlace__item__title">
                          {{ item_b.title }}
                        </div>
                      </div>
                    {% endif %}
                  {% endif %}
                  {% if item_b.popupShow %}
                    <div class="modalDialog" data-block="appendtobottom" block="{{ block.id }}__{{ forloop.index }}">
                      <div class="modalDialog__centerCenter" style="max-width: {{ item_b.popupWidth | append: 'px' }};">
                        <div class="modalDialog__centerCenter__close">
                          <svg width="24px" height="24px" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6 6L18 18" stroke="#000" stroke-linecap="round"/><path d="M18 6L6.00001 18" stroke="#000" stroke-linecap="round"/></svg>
                        </div>

                        <div class="modalDialog__centerCenter__content">
                          {% if item_b.modalTitle != blank %}
                            <div class="modalDialog__centerCenter__content--title">
                              {{ item_b.modalTitle | escape }}
                            </div>
                          {% endif %}
                          {% if item_b.modalDetail_1 != blank %}
                            {% if item_b.modalDetail_1 contains 'embed/' %}
                              {%- assign videoID = item_b.modalDetail_1 | split: 'embed/' | last -%}
                            {% elsif item_b.modalDetail_1 contains '/watch?v=' %}
                              {%- assign videoID = item_b.modalDetail_1 | split: '/watch?v=' | last -%}
                            {% endif %}
                            {% if videoID != blank %}
                              <div class="modalDialog__centerCenter__content--detail">
                                <iframe width="100%" height="100%" src="https://www.youtube.com/embed/{{ videoID }}" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
                              </div>
                            {% endif %}
                          {% elsif item_b.modalDetail != blank %}
                            {% if item_b.modalDetail contains 'iframe' %}
                              <div class="modalDialog__centerCenter__content--detail">
                                {{ item_b.modalDetail }}
                              </div>
                            {% else %}
                              <div class="modalDialog__centerCenter__content--detail">
                                {{ item_b.modalDetail | newline_to_br }}
                              </div>
                            {% endif %}
                          {% endif %}
                          {% if item_b.modalBullets != blank %}
                            {%- assign bulletsArr = item_b.modalBullets | newline_to_br | split: '<br />' -%}
                            {% if bulletsArr.size > 0 %}
                              <ul class="modalDialog__centerCenter__content--list">
                                {% for item in bulletsArr %}
                                  {%- assign getCol = item | split: '|||' -%}
                                  {% if forloop.first %}
                                    <li class="_head_">
                                      <div class="text">{{ getCol[0] }}</div>
                                      <div class="size">{{ getCol[1] }}</div>
                                    </li>
                                  {% else %}
                                    <li>
                                      <div class="text">{{ getCol[0] }}</div>
                                      <div class="size">{{ getCol[1] }}</div>
                                    </li>
                                  {% endif %}
                                {% endfor %}
                              </ul>
                            {% endif %}
                          {% endif %}
                        </div>
                      </div>
                      <div class="modalDialog__centerCenter__close modalDialog__overlay">&nbsp;</div>
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
            {% endif %}

          {%- when 'customQtyFile' -%}
