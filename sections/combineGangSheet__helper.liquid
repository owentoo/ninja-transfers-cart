{%- assign ss = section.settings -%}
{%- assign sb = section.blocks -%}
{% liquid
  assign _text = product.type | downcase | split : " " | join : "_"
%}
{% unless product == empty %}
  {% if product.metafields.antigro.designer %}
    <script>
      window.Designer = Object.assign(window.Designer || {}, {
        productParams: {{ product.metafields.antigro.designer }},
      });

      window.addEventListener('load', function () {
        window.KROWN.settings.locales.products_add_to_cart_button = {{ 'antigro.create_design' | t | json }};
      });
    </script>
  {% endif %}
{% endunless %}

{%- capture allVariants -%}
  {% for variant in product.variants %}
    {
      "id": {{ variant.id | json }},
      "title": {{ variant.title | json }},
      "meta_sqinch": {{ variant.metafields.custom.price_buckets_sq_in_ | json }},
      {% if variant.featured_image != blank %}
        "thumb": {{ variant.featured_image | image_url: width: 100 | json }},
        "large": {{ variant.featured_image | image_url: width: 1000 | json }},
      {% else %}
        "thumb": null,
        "large": null,
      {% endif %}
      "media_id": {{ variant.featured_media.id | json }},
      "price": {{ variant.price | money_without_currency | json }},
      {% if variant.option1 != blank %}
        "op_1": {{ variant.option1 | json }},
      {% endif %}

      {% if variant.option2 != blank %}
        "op_2": {{ variant.option2 | json }},
      {% endif %}

      {% if variant.option3 != blank %}
        "op_3": {{ variant.option3 | json }},
      {% endif %}

      "available": {{ variant.available }}
    }
    {%- unless forloop.last -%}
      ,
    {%- endunless -%}
  {% endfor %}
{%- endcapture -%}
<script>
  const allVariants__2nd = [{{ allVariants }}];
</script>

{%- liquid
  if section.settings.gallery_desktop_width contains 'one-half'
    if section.settings.gallery_layout contains 'one-col'
      assign gallery_class = 'grid-1'
      assign parent_class = 'grid-2 grid-lap-1'
    else
      assign parent_class = 'grid-4 grid-lap-1'
      assign child_class = 'grid-offset-2 grid-offset-lap-1'
      assign gallery_class = 'grid-2 grid-portable-1'
      assign text_class = 'grid-offset-2 grid-offset-lap-1'
    endif
  else
    assign parent_class = 'grid-3 grid-portable-5 grid-lap-1'
    assign child_class = 'grid-offset-2 grid-offset-portable-3 grid-offset-lap-1'
    assign text_class = 'grid-portable-2 grid-offset-portable-2 grid-offset-lap-1'
    if section.settings.gallery_layout contains 'one-col'
      assign gallery_class = 'grid-1'
    else
      assign gallery_class = 'grid-2 grid-portable-1'
    endif
  endif
-%}

{%- liquid
  unless product.has_only_default_variant
    assign default_to_first_variant = section.settings.default_to_first_variant
  else
    assign default_to_first_variant = true
  endunless
-%}

{%- liquid
  assign selectedProduct = product
  if product.metafields.specs.default_child_color != blank
    assign page_url = content_for_header | split:'"pageurl":"' | last | split:'"' | first | split: request.host | last | replace:'\/','/' | replace:'%20',' ' | replace:'\u0026','&'
    assign param_color = nil

    for i in (1..1)
      unless page_url contains "?"
        break
      endunless
      assign query_string = page_url | split:'?' | last
      assign qry_parts= query_string | split:'&'

      for part in qry_parts
        assign key_and_value = part | split:'='
        if key_and_value.size > 1
          if key_and_value[0] == 'view' or key_and_value[0] == 'variant'
            assign param_arr = key_and_value[1] | split:'_'
            assign param_color = param_arr[0] | upcase | url_decode
          endif
        endif
      endfor
    endfor

    assign style_category = 'style-' | append: product.metafields.specs.shirt_style
    assign style_collection = product.collections | where: "handle", style_category | first

    paginate style_collection.products by 1000
      assign sortedColors = style_collection.products | sort: "url"
    endpaginate

    assign firstAvailableProduct = blank
    assign defaultProduct = blank
    assign selectedProduct = blank
    for style_product in sortedColors
      assign inventoryTotal=0
      for variant in style_product.variants
        assign inventoryTotal = inventoryTotal | plus:variant.inventory_quantity
      endfor

      assign shirt_color = style_product.metafields.specs.shirt_color | upcase
      if firstAvailableProduct == blank and inventoryTotal > 0
        assign firstAvailableProduct = style_product
      endif
      if style_product.metafields.specs.shirt_color == product.metafields.specs.default_child_color and inventoryTotal > 0
        assign defaultProduct = style_product
      endif
      if param_color and shirt_color == param_color
        assign selectedProduct = style_product
      endif
    endfor

    if defaultProduct == blank
      assign defaultProduct = firstAvailableProduct
    endif

    if selectedProduct == blank
      assign selectedProduct = defaultProduct
    endif
  endif
-%}

{% assign metafield_data = product.metafields.custom.icons_and_label_section.value %}
{%- comment -%}
<div class="container container--large container--vertical-space-small {% unless settings.show_breadcrumb %} container--no-space-mobile {% endunless %}"
  style="
    {%- if product.metafields.specs.shirt_style -%}
      margin-top:24px;
    {%- endif -%}
  "
>
{%- endcomment -%}
  {%- comment -%}
  <product-page
    id="product-{{ section.id }}"
    class="grid grid--layout grid--gap-xlarge {{ parent_class }} grid--no-stretch main-product"
    data-collection="{{ collection.handle }}" data-id="{{ product.id }}"
    data-availability="{{ product.available }}"
  >
  {%- endcomment -%}

    {%- assign current_variant = product.selected_or_first_available_variant -%}
    <div class="product-text__ {{ text_class }} element--is-sticky remove-empty-space">
      {%- assign product_form_id = 'product-form-' | append: section.id -%}
      {%- assign selectcombineProd_Arr = section.blocks | where: 'type', 'selectcombineProd' %}

      {%- for block in section.blocks -%}
        {%- assign b = block.settings -%}

        {%- case block.type -%}

          {%- when '@app' -%}
            <div class="has-bg-style--{{ section.settings.style }}">
              {%- render block -%}
            </div>

          {%- when 'price' -%}

            <div {{ block.shopify_attributes }} data-js-product-price-compact>
              {%- liquid
                if default_to_first_variant
                  render 'product-price', ptype:_text, variant: current_variant, target: current_variant
                else
                  render 'product-price', ptype:_text, variant: current_variant, target: product, product_price_varies: product.price_varies
                endif
              -%}
            </div>

          {%- when 'tax_info' -%}

            {%- if cart.taxes_included or shop.shipping_policy.body != blank -%}
              <div class="product-policies text-size--small" data-product-policies {{ block.shopify_attributes }}>
                {% if cart.taxes_included %}
                  {{ 'products.page.include_taxes' | t }}
                {%- endif -%}
                {%- if shop.shipping_policy.body != blank -%}
                  {{ 'products.page.shipping_policy_html' | t: link: shop.shipping_policy.url }}
                {%- endif -%}
              </div>
            {%- endif -%}

          {%- when 'description' -%}

            {% assign use_metafield = false %}
            {% if block.settings.product_data_src == 'metafield' and metafield_data.Headline != blank %}
              {% assign use_metafield = true %}
            {% endif %}

            {% if use_metafield or product.description != blank %}
              {%- if block.settings.product_description_truncated != 'full' -%}
                <show-more class="show-more"
                  style="--height:{{ block.settings.product_description_truncated }}px"
                  data-height="{{ block.settings.product_description_truncated }}"
                >
                  <span class="js-show-more show-more_toggler text-decoration--underline">
                    {{ 'general.accessibility_labels.show_more' | t }}
                  </span>
                  <div class="show-more_panel">
              {%- endif -%}

                <div class="product__description rte remove-empty-space" {{ block.shopify_attributes }}>
                  {% if use_metafield %}
                    {{ metafield_data.Headline }}
                  {% else %}
                    {{ product.description }}
                  {% endif %}
                </div>

              {%- if block.settings.product_description_truncated != 'full' -%}
                  </div>
                </show-more>
                <script src="{{ 'component-show-more.js' | asset_url }}" defer></script>
              {%- endif -%}
            {% endif %}

          {%-  when 'drip_apps' -%}
            <style>
              .drip_apps-wrapper .drip_apps-section{display:inline-flex; align-items: center;}
              .drip_apps-section .img-block{flex-shrink:0; flex-grow:0; margin-right:8px; width:24px; height:24px;}
              .drip_apps-section .img-block img{max-width:100%; max-height:100%;}
            </style>
            <div class="drip_apps-wrapper">
              <div class="drip_apps-section">
                <span class="img-block">
                  <img src="https://cdn.shopify.com/s/files/1/0558/0265/8899/files/Drip_Apps_Icon_8d9be839-a070-4803-a5d6-e2cb71b8e85f.png?v=1715617070" alt="icon set" />
                </span>
                <div>{{ block.settings.drip_apps_msg }}</div>
              </div>
            </div>

          {%- when 'iconText' -%}
            {% assign use_metafield = false %}
            {% assign no_of_icons = metafield_data.IconswithLabels | size  %}
            {% if block.settings.product_data_src == 'metafield' and no_of_icons > 0 %}
              {% assign use_metafield = true %}
            {% endif %}

            {% if use_metafield %}
              {% style %}
                .iconTextBlock__iconWrap {
                  background-color: unset !important;
                }
              {% endstyle %}
              <div class="iconTextBlock" data-mf-size="{{ metafield_data.IconswithLabels | size }}">
                {% for item in metafield_data.IconswithLabels %}
                  <div class="iconTextBlock__item">
                    <div class="iconTextBlock__iconWrap">
                      <img src="{{ item.Icon | append: '&width=50' }}" alt="{{ item.Label }}">
                    </div>
                    <p class="iconTextBlock__iconText">
                      {{ item.Label }}
                    </p>
                  </div>
                {% endfor %}
              </div>
            {% else %}
              <div class="iconTextBlock">
                {% if b.icon_1 != blank and b.title_1 != blank %}
                  <div class="iconTextBlock__item">
                    <div class="iconTextBlock__iconWrap">
                      <img src="{{ b.icon_1 | image_url: width: 50 }}" alt="{{ b.title_1 }}">
                    </div>
                    <p class="iconTextBlock__iconText">
                      {{ b.title_1 }}
                    </p>
                  </div>
                {% endif %}

                {% if b.icon_2 != blank and b.title_2 != blank %}
                  <div class="iconTextBlock__item">
                    <div class="iconTextBlock__iconWrap">
                      <img src="{{ b.icon_2 | image_url: width: 50 }}" alt="{{ b.title_2 }}">
                    </div>
                    <p class="iconTextBlock__iconText">
                      {{ b.title_2 }}
                    </p>
                  </div>
                {% endif %}

                {% if b.icon_3 != blank and b.title_3 != blank %}
                  <div class="iconTextBlock__item">
                    <div class="iconTextBlock__iconWrap">
                      <img src="{{ b.icon_3 | image_url: width: 50 }}" alt="{{ b.title_3 }}">
                    </div>
                    <p class="iconTextBlock__iconText">
                      {{ b.title_3 }}
                    </p>
                  </div>
                {% endif %}

                {% if b.icon_4 != blank and b.title_4 != blank %}
                  <div class="iconTextBlock__item">
                    <div class="iconTextBlock__iconWrap">
                      <img src="{{ b.icon_4 | image_url: width: 50 }}" alt="{{ b.title_4 }}">
                    </div>
                    <p class="iconTextBlock__iconText">
                      {{ b.title_4 }}
                    </p>
                  </div>
                {% endif %}

                {% if b.icon_5 != blank and b.title_5 != blank %}
                  <div class="iconTextBlock__item">
                    <div class="iconTextBlock__iconWrap">
                      <img src="{{ b.icon_5 | image_url: width: 50 }}" alt="{{ b.title_5 }}">
                    </div>
                    <p class="iconTextBlock__iconText">
                      {{ b.title_5 }}
                    </p>
                  </div>
                {% endif %}

                {% if b.icon_6 != blank and b.title_6 != blank %}
                  <div class="iconTextBlock__item">
                    <div class="iconTextBlock__iconWrap">
                      <img src="{{ b.icon_6 | image_url: width: 50 }}" alt="{{ b.title_6 }}">
                    </div>
                    <p class="iconTextBlock__iconText">
                      {{ b.title_6 }}
                    </p>
                  </div>
                {% endif %}

                {% if b.icon_7 != blank and b.title_7 != blank %}
                  <div class="iconTextBlock__item">
                    <div class="iconTextBlock__iconWrap">
                      <img src="{{ b.icon_7 | image_url: width: 50 }}" alt="{{ b.title_7 }}">
                    </div>
                    <p class="iconTextBlock__iconText">
                      {{ b.title_7 }}
                    </p>
                  </div>
                {% endif %}

                {% if b.icon_8 != blank and b.title_8 != blank %}
                  <div class="iconTextBlock__item">
                    <div class="iconTextBlock__iconWrap">
                      <img src="{{ b.icon_8 | image_url: width: 50 }}" alt="{{ b.title_8 }}">
                    </div>
                    <p class="iconTextBlock__iconText">
                      {{ b.title_8 }}
                    </p>
                  </div>
                {% endif %}

                {% if b.icon_9 != blank and b.title_9 != blank %}
                  <div class="iconTextBlock__item">
                    <div class="iconTextBlock__iconWrap">
                      <img src="{{ b.icon_9 | image_url: width: 50 }}" alt="{{ b.title_9 }}">
                    </div>
                    <p class="iconTextBlock__iconText">
                      {{ b.title_9 }}
                    </p>
                  </div>
                {% endif %}

                {% if b.icon_10 != blank and b.title_10 != blank %}
                  <div class="iconTextBlock__item">
                    <div class="iconTextBlock__iconWrap">
                      <img src="{{ b.icon_10 | image_url: width: 50 }}" alt="{{ b.title_10 }}">
                    </div>
                    <p class="iconTextBlock__iconText">
                      {{ b.title_10 }}
                    </p>
                  </div>
                {% endif %}
              </div>
            {% endif %}
            <style>
              @media (min-width: 1400px) {
                .iconTextBlock {
                  max-width: 90%;
                }
              }
              .iconTextBlock {
                --icon-size: {{ block.settings.icon_size | append: 'px' }};
                --icon-padding: {{ block.settings.icon_padding | append: 'px' }};
                --icon-container-size: calc(var(--icon-size) + (var(--icon-padding) * 2));

                display: flex;
                align-items: center;
                column-gap: 20px;
                row-gap: 6px;
                flex-wrap: wrap;
              }
              .iconTextBlock__item {
                width: 100%;
                max-width: calc(50% - 10px);
                display: grid;
                grid-template-columns: var(--icon-container-size) auto;
                align-items: center;
                gap: 8px 14px;
                column-gap: {{ block.settings.iconGrid_col_gap | append: 'px' }};
              }
              .iconTextBlock__iconWrap {
                width: var(--icon-container-size);
                height: var(--icon-container-size);
                border-radius: 999px;
                display: grid;
                align-items: center;
                justify-content: center;
                background-color: {{ b.iconCircleColor }};
              }
              .iconTextBlock__iconWrap img {
                width: var(--icon-size);
                height: var(--icon-size);
              }
              .iconTextBlock__iconText {
                margin-bottom: 0;
                font-size: 14px;
                font-weight: 500;
                color: {{ b.textColor }};
              }
              @media (max-width: 450px) {
                .iconTextBlock__item {
                  max-width: 100%;
                }
              }
            </style>

          {%-  when 'sample_product_active' -%}
            <p class="__prematched-text">{{ block.settings.sample_msg }} -&nbsp;<a href="javascript:void(0)" title="Add to Cart" data-vrntid="{{ block.settings.variant_id }}"><strong>Add to Cart</strong></a></p>

            <style>
              .__prematched-text:not(.gads){display:none}
            </style>
            <script>
              function getQuerystringNameValue(name) {
                name = name.replace(/[\[]/,"\\\[").replace(/[\]]/,"\\\]");
                var regexS = "[\\?&]"+name+"=([^&#]*)";
                var regex = new RegExp( regexS );
                var results = regex.exec( window.location.href );
                if( results == null )
                  return "null";
                else
                  return decodeURIComponent(results[1].replace(/\+/g, " "));
              }

              var __smp = getQuerystringNameValue("smp");
              var __rtype = getQuerystringNameValue("rtype");
              $(function(){
                if(__rtype == "another"){
                  $(window).on("load",function(){
                    $( `html, body` ).animate({
                        scrollTop: $( `.product-variant__container[option="1"]` ).offset().top - 180
                    }, 500);
                  })
                }
                if(__smp == "true"){
                  var _variantID = '{{ block.settings.variant_id }}';
                  $(".__prematched-text").addClass("gads");
                  var _vid = _variantID.replace("id=","");
                  $(".__prematched-text").find("a").attr({"href":"javascript:void(0)","data-vrntid":_vid});
                }

                $(".__prematched-text").find("a").click(function(){
                  var _data_vrntid = $(this).attr("data-vrntid");
                  let formData = {
                    'items': [{
                      'id': _data_vrntid,
                      'quantity': 1
                    }]
                  };

                  fetch(window.Shopify.routes.root + 'cart/add.js', {
                    method: 'POST',
                    headers: {
                      'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(formData)
                  })
                  .then(response => {
                    window.refreshCart()
                    return response.json();
                  })
                  .catch((error) => {
                    console.error('Error:', error);
                  });
                })
              })

              function _changeURL(currentVariant){
                var _vid = currentVariant.id
                var __addCTAurl = "{{ routes.cart_url }}/add?id="+ _vid +"&quantity=1";
                $(".__prematched-text").find("a").attr({"href":"javascript:void(0)","data-vrntid":_vid});
                $("[data-js-product-price-compact]").show();
                if(__smp == "true"){
                }
              }
            </script>

          {%-  when 'styled_text_field' -%}
            <style>
              ._flex-box{font-size: calc(20px / 16 * 15 + 0px);}
              ._styledtext{font-size:0.9rem; line-height:normal;}
            </style>
            <div class="_flex-box">
              <strong class="_cost_value">{{ block.settings.cent_inch }}&nbsp;</strong><span class="_styledtext"><strong>-&nbsp;</strong>{{ block.settings.cost_style_text }}</span>
            </div>

          {%- when 'variant_picker' -%}

            {%- assign color_label = settings.color_swatches_labels | split: ',' -%}

            <div class="sidebar-widget sidebar-widget--{{ block.settings.style }}"
              {% if product.has_only_default_variant %} style="display:none" {% endif %}
              {% if product.available == false and block.settings.unavailable_variants == 'hide' %} style="display:none" {% endif %}
            >

              {%- unless block.settings.heading == blank -%}
                <span class="sidebar-widget__title">{{ block.settings.heading | escape }}</span>
              {%- endunless -%}

              <div class="sidebar-widget__content">

                <product-variants-2nd
                  data-main-product-variants
                  data-variants="{{ product.options_with_values.size }}"
                  data-hide-variants="{%- liquid
                    if block.settings.unavailable_variants == 'disable'
                      echo 'disable'
                    elsif block.settings.unavailable_variants == 'show'
                      echo 'true'
                    else
                      echo 'hide'
                    endif
                  -%}"
                  data-url="{{ product.url }}" data-id="{{ section.id }}"
                  data-style="{{ block.settings.variants_style }}"
                  {% if block.settings.unavailable_variants == 'hide' %} class="product-variants--hide-unavailable" {% endif %}
                  {% unless default_to_first_variant %} data-variant-required {% endunless %}
                  {% unless product.has_only_default_variant %} data-has-variants {% elsif product.available == false %} data-unavailable {% endunless %}
                  {{ block.shopify_attributes }}
                >
                  {% comment %} Custom code to manage visibility {% endcomment %}
                  {%- assign show_options = "" -%}
                  {%- for variant in product.variants -%}
                    {%- unless variant.metafields.custom.variant_hidden == true -%}
                      {%- for i in (1..3) -%}
                        {%- assign option_name = "option" | append: i -%}
                        {%- assign option_value = variant[option_name] -%}
                        {%- if option_value != blank -%}
                          {%- assign show_options = show_options | append: option_value | append: " " -%}
                        {%- endif -%}
                      {%- endfor -%}
                    {%- endunless -%}
                  {%- endfor -%}
                  {% comment %} Custom code to manage visibility {% endcomment %}

                  <div class="product-variants no-js-hidden"
                    {% if product.has_only_default_variant %} style="display:none" {% endif %}
                    {% if product.available == false and block.settings.unavailable_variants == 'hide' %} style="display:none" {% endif %}
                  >

                    {%- for option in product.options_with_values -%}

                      {%- assign option_downcased = option.name | downcase %}

                      <div class="product-variant" data-name="product-{{ option.name | escape | downcase | strip }}-{{ section.id }}" data-js-product-variant>

                        <span class="product-variant__name text-size--small">{{ 'products.grid.select_variant' | t: variant: option_downcased }}</span>

                        {%- if color_label contains option_downcased and block.settings.color_swatches -%}

                          <div class="product-variant__container product-variant__container--radio product-variant__container--radio--wrap" data-js-product-variant-container="radio" option="{{ option.position }}">
                            {%- for value in option.values -%}
                              {%- if show_options contains value -%}
                              <div class="product-variant__item product-variant__item--radio product-variant__item--color">
                                <input type="radio" name="product-{{ option.name | escape | downcase | strip }}-{{ section.id }}" id="{{ product.handle }}-option-{{ option.name | escape | downcase | strip }}-{{ forloop.index }}-{{ section.id }}" value="{{ value | escape }}" {% if default_to_first_variant and option.selected_value == value %}checked{% endif %} class="product-variant__input product-variant-value">
                                <label for="{{ product.handle }}-option-{{ option.name | escape | downcase | strip }}-{{ forloop.index }}-{{ section.id }}" class="product-variant__label">
                                  {%- liquid
                                    assign color_swatch_name = value | handle | append: '.png'
                                    assign color_swatch_image = images[color_swatch_name]
                                    assign color_swatch_background = value | downcase | escape | replace: ' ', ''
                                  -%}
                                  {%- if color_swatch_image != blank -%}
                                    <img class="product-variant__item-swatch product-variant__item-swatch--color"
                                      src="{{ color_swatch_image | image_url: width: 30, height: 30, crop: 'center' }}"
                                      srcset="
                                        {{ color_swatch_image | image_url: width: 30, height: 30, crop: 'center' }} 30w,
                                        {{ color_swatch_image | image_url: width: 60, height: 60, crop: 'center' }} 60w,
                                        {{ color_swatch_image | image_url: width: 90, height: 90, crop: 'center' }} 90w
                                      "
                                      sizes="30px" width="30" height="30"
                                      loading="lazy"
                                      alt="{{ color_swatch_image.alt | escape }}"
                                    />
                                  {%- else -%}
                                    <span class="product-variant__item-swatch product-variant__item-swatch--image" style="background-color:{{ color_swatch_background }}"></span>
                                  {%- endif -%}
                                  <span class="visually-hidden">{{ value | escape }}</span>
                                </label>
                              </div>
                              {% endif %}
                            {%- endfor -%}

                          </div>

                          <span class="product-variant__item-text-label text-size--small text-line-height--small text-color--opacity">
                            {%- liquid
                              unless default_to_first_variant
                                echo 'products.grid.color_variants_count' | t: count: option.values.size
                              else
                                echo option.selected_value
                              endunless
                            -%}
                          </span>

                        {%- elsif block.settings.variants_style == 'select' -%}

                          <select class="product-variant__container product-variant__container--select text-size--small" id="product-{{ option.name | escape | downcase | strip }}-{{ section.id }}" data-js-product-variant-container="select">
                            {%- unless default_to_first_variant -%}
                              <option class="product-variant-value" default selected disabled>{{ 'products.grid.select_variant' | t: variant: option_downcased }}</option>
                            {%- endunless -%}
                            {%- for value in option.values -%}
                              {%- if show_options contains value -%}
                              <option class="product-variant-value" value="{{ value | escape }}" {% if default_to_first_variant and option.selected_value == value %}selected{% endif %}>
                                {{ value | escape }}
                              </option>
                              {% endif %}
                            {%- endfor -%}
                          </select>

                        {%- else -%}

