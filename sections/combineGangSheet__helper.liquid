                        </div>
                        <div class="customTabelPlace__heading_4">
                          {% if customer and isEliteMember %}
                            {{ b.member__fourthColTitle }}
                            <span class="toolTipWrap">
                              <svg class="toolTipIconIs" width="18px" height="18px" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px" viewBox="0 0 24 24" style="enable-background:new 0 0 24 24;" xml:space="preserve"><style type="text/css">.st0{fill:#FFFFFF;}.st1{fill:#3F97D2;}</style><circle class="st0" cx="11.9" cy="10.8" r="8"/><path class="st1" d="M10.5,17.1L18,9.7l-2.1-2.1l-5.3,5.4L8,10.4l-2.1,2.1L10.5,17.1z M12,22.9c-1.5,0-2.9-0.3-4.2-0.9 c-1.3-0.6-2.5-1.3-3.4-2.3c-1-1-1.7-2.1-2.3-3.4c-0.6-1.3-0.9-2.7-0.9-4.2S1.4,9.1,2,7.8c0.6-1.3,1.3-2.5,2.3-3.4 c1-1,2.1-1.7,3.4-2.3c1.3-0.6,2.7-0.9,4.2-0.9s2.9,0.3,4.2,0.9c1.3,0.6,2.5,1.3,3.4,2.3c1,1,1.7,2.1,2.3,3.4 c0.6,1.3,0.9,2.7,0.9,4.2s-0.3,2.9-0.9,4.2c-0.6,1.3-1.3,2.5-2.3,3.4c-1,1-2.1,1.7-3.4,2.3C14.9,22.6,13.5,22.9,12,22.9z"/></svg>
                              <tooltip>{{ b.member__tooltip }}</tooltip>
                            </span>
