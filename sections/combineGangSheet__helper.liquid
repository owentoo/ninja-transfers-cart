                  </div>
                  <style>
                    .customQtyFile__wrapper {
                      width: 100%;
                      max-width: 33.3333%;
                    }
                  </style>
                {% endif %}

                {% if b.showUploadFiles and b.title != blank %}
                  <div class="customQtyFile__upload">
                    {% if b.title != blank %}{{ b.title }} <svg height="48" viewBox="0 0 48 48" width="48" xmlns="http://www.w3.org/2000/svg"><path d="M0 0h48v48h-48z" fill="none"/><path d="M24 8l-2.83 2.83 11.17 11.17h-24.34v4h24.34l-11.17 11.17 2.83 2.83 16-16z"/></svg>{% else %}Continue to Upload Your File <?xml version="1.0" ?><svg height="48" viewBox="0 0 48 48" width="48" xmlns="http://www.w3.org/2000/svg"><path d="M0 0h48v48h-48z" fill="none"/><path d="M24 8l-2.83 2.83 11.17 11.17h-24.34v4h24.34l-11.17 11.17 2.83 2.83 16-16z"/></svg>{% endif %}
                  </div>
                {% endif %}
              </div>
            {% endif %}

        {%- endcase -%}

      {%- endfor -%}

    </div>

  {%- comment -%}
  </product-page>
  {%- endcomment -%}


{%- comment -%}
</div>
