                          .secondDropZone__inner b {
                            border: 1px solid #46aae3;
                            background-color: #46aae3;
                            color: #fff;
                            display: flex;
                            align-items: center;
                            gap: 6px;
                            padding: 8px 24px;
                            border-radius: 16px;
                            margin-bottom: 18px;
                            margin-top: 30px;
                            position: relative;
                            cursor: pointer;
                            font-weight: 600;
                            z-index: 2;
                          }
                          .secondDropZone__inner b:hover {
                            background-color: #fff;
                            color: #46aae3;
                            box-shadow: 0 0 10px #46aae3;
                          }
                          .secondDropZone__inner b:hover .secondDropZone__inner_icon {
                            stroke: #46aae3;
                          }
                          .secondDropZone__text {
                            display: block;
                            text-align: center;
                            width: 100%;
                            margin-bottom: 18px;
                            color: #000;
                            font-weight: bold;
                          }
                          .secondDropZone.active {
                            box-shadow: 0 0 10px #46aae3;
                            z-index: 0;
                            position: relative;
                          }

                          .anotherTransfer {
                            display: none !important;
                          }

                          .add-to-cart[disabled] {
                            background-color: #8cb3d2 !important;
                          }

                          .loadingScreen__ {
                            position: fixed;
                            top: 0;
                            left: 0;
                            width: 100%;
                            height: 100%;
                            z-index: 999999999;
                            background-color: #fff;

                            img {
                              position: absolute;
                              top: 50%;
                              left: 50%;
                              transform: translate(-50%, -50%);
                              height: 64px;
                              opacity: 1;
                              animation: fade 2s linear;
                            }
                          }

                          @keyframes fade {
                            0%,100% { opacity: 0.1 }
                            50% { opacity: 1 }
                          }

                          .__errorcase{cursor:pointer;}
                          .cl-upload--input-fields .cl-upload--label{padding-left:24px;}
                          div.upload-container .cl-upload--input-fields{display:none; position:relative;}
                          .cl-upload--input-fields .cl-upload--input{visibility:hidden; position:absolute;}
                          .cl-upload--input-fields::after{content: ""; width: 16px; height: 16px; display: block; position: absolute; border: solid 2px #3eaeff; top: 4px; border-radius: 3px; pointer-events:none;}
                          .cl-upload--input-fields::before{width: 6px; height: 12px; display: block; position: absolute; border-right: solid 2px #3eaeff; border-bottom: solid 2px #3eaeff; top: 5px; border-radius: 1px; pointer-events: none; transform: rotate(45deg); left: 5px;}
                          .cl-upload--input-fields.error-icon::after{border-color:red;}
                          .cl-upload--input-fields.filler:not(.error-icon)::before{content:"";}
                          .__validate_upload button{pointer-events:none;}
                          .__errorcase button{width:100%;}
                          .error_color{color:red; margin-bottom:8px; display:flex; align-items:center;}
                          .error_color span{display:inline-block; margin-right:8px;}
                          .error-icon .cl-upload--input{border:none}
                        </style>
                      {% endif %}

                      {%- if b.show_quantity_selector -%}

                        {% if b.showQty == 'qtyWithPrice' %}
                          <div class="qtyWithPrice">
                            <div class="qtyWithPrice__title">Quantity</div>
                            <div class="qtyWithPrice__wrapper">
                              <product-quantity class="product-quantity quantity-selector-holder">
                                <button class="qty-button qty-minus no-js-hidden" aria-label="{{ 'general.accessibility_labels.decrease_quantity' | t }}" role="button" controls="qty-{{ section.id }}">
                                  {%- render 'theme-symbols', icon: 'minus' -%}
                                </button>
                                <label for="qty-{{ section.id }}" class="visually-hidden">{{ 'general.accessibility_labels.quantity' | t }}</label>
                                <input type="number" name="quantity" value="1" min="1" max="999" class="qty qty-selector product__quantity" id="qty-{{ section.id }}">
                                <button class="qty-button qty-plus no-js-hidden" aria-label="{{ 'general.accessibility_labels.increase_quantity' | t }}" role="button" controls="qty-{{ section.id }}">
                                  {%- render 'theme-symbols', icon: 'plus' -%}
                                </button>
                              </product-quantity>

                              <div class="qtyWithPrice__unitPrice">
                                <div class="qtyWithPrice__price"></div>
                                <div class="qtyWithPrice__setupText">{{ b.setupText }}</div>
                              </div>
                            </div>
                          </div>
                          
                          <script>
                            var allowAnotherTransfer = {{b.allowAnotherTransfer}};
                            $(document).ready(function () {
                            $(document).on("click",".__validate_upload",function(){
                              $(".__uploaderror").remove();
                              $(".cl-upload--input-fields").removeClass("error-icon");

                              if($(".filepond--data input").length == 0){
                                $(".cl-upload--area").after("<div class='error_color __uploaderror'><span><img src='https://cdn.shopify.com/s/files/1/0558/0265/8899/files/warning_icon_red.svg?v=1725642417' alt='error' /></span> Upload a gang sheet to continue</div>");
                                return;
                              }

                              if($(".cl-upload--input").is(":checked") == false){
                                var node = $(".product__cart-functions .cl-upload--input-fields");
                                node.addClass("error-icon");
                                node.append("<div class='error_color __uploaderror'><span><img src='https://cdn.shopify.com/s/files/1/0558/0265/8899/files/warning_icon_red.svg?v=1725642417' alt='error' /></span> Please check the box above to continue</div>");
                              }
                            })
                            {% if b.allowAnotherTransfer %}
                              $(window).on("load",function(){
                                /** move checkbox **/
                                var __inputfield = $(".product__cart-functions .cl-upload--input-fields").clone(true);
                                $(".product__cart-functions .cl-upload--input-fields").addClass("hiddenelement");
                                $(".__validate_upload").before(__inputfield.wrap("<div class='pos-moved'></div>"));
                                /** ./move checkbox **/
                              })
                            {% endif %}

                            if ( typeof loaderGif == 'undefined' ) {
                              loaderGif = `{{ 'loader.gif' | asset_url }}`;
                            }
                          });
                          window.addEventListener('upload:ready', function(e) {
                            field__ = e.detail;
                            //console.log( `field__`, field__ );
                            if ( typeof field__.config.fileMimeTypes !== 'undefined' && field__.config.fileMimeTypes ) {
                              const fileTypesAllow = field__.config.fileMimeTypes.join( `,` );
                              // field__.config.fileMimeTypes.forEach(fileType => {
                              //   fileTypesAllow.join( `,` );
                              // });
                              $( `#secondFile` ).attr( `accept`, fileTypesAllow );
                            }
                            fileStatus = false;
                            {%- if b.allowAnotherTransfer -%}
                              if($(".__validate_upload").length <= 0){
                                $( `.add-to-cart[data-main-product-add-to-cart]` ).wrap('<div class="__errorcase __validate_upload"></div>');
                              }
                            {%- endif -%}
                          });

                          $( document )
                          .on(`change`, `.product__cart-functions .cl-upload--input-field .cl-upload--input[type="checkbox"]`, function( e ) {
                            try {
                              e.stopImmediatePropagation();
                              const isCheckBoxChecked = $( this ).is( `:checked` );
                              if ( isCheckBoxChecked && fileStatus ) {
                                //$("._grt-anotherTransfer").show();
                                $( `.customDrop` ).removeClass( `hidden` );
                                $(".product__cart-functions .cl-upload--input-fields").show().addClass("filler").removeClass("error-icon");
                                $(".product__cart-functions .cl-upload--input-fields input.cl-upload--input").prop("checked",true);
                                $(".__validate_upload").removeClass("__validate_upload");
                                $(".__uploaderror").remove();
                              } else {
                                //$("._grt-anotherTransfer").hide();
                                $( `.customDrop` ).addClass( `hidden` );
                                $(".product__cart-functions .cl-upload--input-fields").show().removeClass("filler");
                                $(".product__cart-functions .cl-upload--input-fields input.cl-upload--input").prop("checked",false);
                                $(".__errorcase").addClass("__validate_upload");
                              }
                            } catch ( err ) {
                              //console.log( `ERROR `, err.message );
                            }
                          })

                          window.addEventListener('upload:added', function(e) {
                            fileStatus = true;
                            $(".product__cart-functions .cl-upload--input-fields").addClass("img_uploaded").removeClass("filler");
                            const isCheckBoxChecked = $( `.product__cart-functions .cl-upload--input-field .cl-upload--input[type="checkbox"]` ).is( `:checked` );
                            if ( isCheckBoxChecked ) {
                              /*$( `.customDrop` ).removeClass( `hidden` );
                              $( `.add-to-cart[data-main-product-add-to-cart]` ).prop( `disabled`, false );*/
                            } else {
                              $( `.customDrop` ).addClass( `hidden` );
                              //$( `.add-to-cart[data-main-product-add-to-cart]` ).prop( `disabled`, true );
                              $(".__uploaderror").remove();
                            }
                          });

                          window.addEventListener('upload:removed', function(e) {
                            fileStatus = false;
                            $( `.customDrop` ).addClass( `hidden` );
                            $(".__errorcase").addClass("__validate_upload");
                            $(".product__cart-functions .cl-upload--input-fields").hide().removeClass("filler");
                            //$( `.add-to-cart[data-main-product-add-to-cart]` ).prop( `disabled`, true );
                          });
                            $( document )
                            .ready(function() {
                              priceUpdater();
                            })
                            .on(`change`, `.product-variant__container .product-variant__input`, function( e ) {
                              try {
                                e.stopImmediatePropagation();
                                priceUpdater();
                              } catch ( err ) {
                                //console.log( `ERROR .product-variant__container .product-variant__input`, err.message );
                              }
                            })
                            .on(`click`, `.qtyWithPrice product-quantity .qty-button`, function( e ) {
                              try {
                                e.stopImmediatePropagation();
                                priceUpdater();
                              } catch ( err ) {
                                //console.log( `ERROR .qtyWithPrice product-quantity .qty-button`, err.message );
                              }
                            })
                            .on(`keyup`, `.qtyWithPrice product-quantity .qty.qty-selector`, function( e ) {
                              try {
                                e.stopImmediatePropagation();
                                priceUpdater();
                              } catch ( err ) {
                                //console.log( `ERROR .qtyWithPrice product-quantity .qty.qty-selector`, err.message );
                              }
                            })
                            ;
                            async function priceUpdater() {
                              try {
                                await addDelay( 100 );
                                const getPrice = $( `[data-js-product-price-compact] .product-price .product-price--original .money` ).text();
                                $( `.qtyWithPrice__price` ).text( getPrice );
                              } catch ( err ) {
                                //console.log( `ERROR priceUpdater()`, err.message );
                              }
                            }
                          </script>
                        {% else %}
                          <product-quantity class="product-quantity quantity-selector-holder
                            {%- comment -%}
                            {% if default_to_first_variant %} hide {% endif %}
                            {%- endcomment -%}
                            "
                          >
                            <button class="qty-button qty-minus no-js-hidden" aria-label="{{ 'general.accessibility_labels.decrease_quantity' | t }}" role="button" controls="qty-{{ section.id }}">
                              {%- render 'theme-symbols', icon: 'minus' -%}
                            </button>
                            <label for="qty-{{ section.id }}" class="visually-hidden">{{ 'general.accessibility_labels.quantity' | t }}</label>
                            <input type="number" name="quantity" value="1" min="1" max="999" class="qty qty-selector product__quantity" id="qty-{{ section.id }}">
                            <button class="qty-button qty-plus no-js-hidden" aria-label="{{ 'general.accessibility_labels.increase_quantity' | t }}" role="button" controls="qty-{{ section.id }}">
                              {%- render 'theme-symbols', icon: 'plus' -%}
                            </button>
                          </product-quantity>
                        {% endif %}

                      {%- endif -%}

                      {% if b.fullWidthButtons %}
                        <style>
                          product-quantity {
                            max-width: max-content;
                          }
                        </style>
                      {% endif %}

                      {% if b.allowAnotherTransfer and b.anotherTransferPosition == 'above' %}
                        <span
                          class="anotherTransfer _grt-anotherTransfer above{% if b.fillAnotherTransferBtn %} button button--solid button--product{% endif %}{% if b.fullWidthButtons %} btnFullWidth{% endif %}"
                        >
                          <span class="anotherTransfer__btnText">
                            {{ b.allowAnotherTransfer__label }}
                          </span>
                        </span>
                      {% endif %}

                      <button type="submit" name="add" class="
                        add-to-cart button button--solid button--product button--loader button--move
                        {% if b.fullWidthButtons %} btnFullWidth{% endif %}
                        {% unless current_variant.available %} disabled {% endunless %}
                        {% unless default_to_first_variant %} disabled {% endunless %} {{ section.settings.secondary_cta_class | escape }}"
                        data-js-product-add-to-cart
                        data-main-product-add-to-cart
                      >
                        <span class="button__text" data-js-product-add-to-cart-text>
                          {%- liquid
                            unless default_to_first_variant
                              if product.available
                                echo 'products.grid.choose_variant_first' | t
                              else
                                echo 'products.page.inventory.sold_out_variant' | t
                              endif
                            else
                              if b.buttonText != blank
                                echo b.buttonText
                              elsif current_variant.available
                                echo 'products.page.add_to_cart_button' | t
                              else
                                echo 'products.page.inventory.sold_out_variant' | t
                              endif
                            endunless
                          -%}
                        </span>
                        <span class="button__preloader">
                          <svg class="button__preloader-element" viewBox="25 25 50 50"><circle cx="50" cy="50" r="20" fill="none" stroke-width="4"/></svg>
                        </span>
                      </button>

                      {% if b.allowAnotherTransfer and b.anotherTransferPosition == 'below' %}
                        <span
                          class="anotherTransfer above{% if b.fillAnotherTransferBtn %} button button--solid button--product{% endif %}{% if b.fullWidthButtons %} btnFullWidth{% endif %}"
                        >
                          <span class="anotherTransfer__btnText">
                            {{ b.allowAnotherTransfer__label }}
                          </span>
                        </span>
                      {% endif %}

                      {%- liquid
                        if block.settings.show_dynamic_checkout and block.settings.show_gift_card_recipient == false
                          echo form | payment_button
                        endif
                      -%}

                    </div>
                  </div>

                  {% for item in customTabelItems %}
                    {%- assign tItems = item.settings -%}
                    {%- capture minMax -%}
                      {%- if tItems.title contains '-' -%}
                        {%- assign min = tItems.title | split: '-' | first | strip -%}
                        {%- assign max = tItems.title | split: '-' | last | strip -%}
                      {%- elsif tItems.title contains '+' -%}
                        {%- assign min = tItems.title | split: '+' | first | strip -%}
                        {%- assign max = 1000000 -%}
                      {%- endif -%}
                    {%- endcapture -%}
                    {%- capture percentages -%}
                      {%- if tItems.title_2 contains '%' -%}
                        {%- assign offPercentage = tItems.title_2 | split: '%' | first | strip -%}
                      {%- endif -%}
                    {%- endcapture -%}
                    {% if forloop.first %}
                      {%- assign getUnitPrice_1st = tItems.title_3 | default: '&nbsp;' -%}
                    {% endif %}
                    {% assign _dis = _dis | append :  "min_" %}
                    {% assign _dis = _dis | append :  min %}
                    {% assign _dis = _dis | append : "-off_" %}
                    {% assign _dis = _dis | append : offPercentage %}
                    {% assign _dis = _dis | append : "#" %}

                    {% assign _dis_title = _dis_title | append : offPercentage | append : "%25_off_for_buying_" | append : min | append : "_or_more#" %}
                    {% assign _dis_title = _dis_title | split : "+" | join : "" %}
                    {% if forloop.last %}
                      <input type="hidden" name="properties[_discount_input]" value="{{ _dis }}" />
                      <input type="hidden" name="properties[_discount_name]" value="{{ _dis_title }}" />
                    {% endif %}
                  {% endfor %}

                {%- endform -%}

              </product-form>

              {%- form 'product', product, id: 'product-form-installment' -%}
                <input type="hidden" name="id" value="{{ current_variant.id }}">
                {{ form | payment_terms }}
              {%- endform -%}

              <script>
                document
                  .querySelector('shopify-payment-terms')
                  .shadowRoot.querySelector('*')
                  .setAttribute('style', 'text-align: center;');
              </script>
              {% if block.settings.enable_payment_terms %}
                {% render 'custom-payment-terms' %}
              {% endif %}

            </div>

          {%- when 'onlyTerms' -%}
            {%- form 'product', product, id: 'product-form-installment' -%}
              {{ form | payment_terms }}
            {%- endform -%}
          {%- when 'payterms' -%}
            {% render 'custom-payment-terms' %}

          {%- when 'inventory' -%}

            <div class="product-variant__quantity-holder" {{ block.shopify_attributes }}>
              <span class="product-variant__quantity"
                data-js-variant-quantity
                data-type="{{ block.settings.show_quantities }}"
                data-low-stock="{{ block.settings.low_inventory_threshold }}"
                data-high-stock="{{ block.settings.low_inventory_threshold | times: 2 }}"
              ></span>
              {%- capture variant_inventory -%}
                [{%- for variant in product.variants -%}{
                  "id": {{ variant.id }}{%- if variant.inventory_management != null -%},
                  "quantity": {{ variant.inventory_quantity }},
                  "inventory": "{{ variant.inventory_policy }}"{%- endif -%}
                  {%- if variant.available == false -%},"unavailable": true{%- endif -%}
                  }{%- unless forloop.last -%},{%- endunless -%}
                {%- endfor -%}]
              {%- endcapture -%}
              {%- if block.settings.show_progress_bar -%}
                <span class="product-variant__quantity-progress">
                  <span class="product-variant__quantity-progress-bar" data-js-variant-quantity-progress></span>
                </span>
                <span data-js-variant-quantity-data data-inventory='{{ variant_inventory }}'></span>
              {%- endif -%}
            </div>

          {%- when 'collapsible_tab' -%}

            {%- liquid
              assign show_block = true
              if block.settings.hide_block_if == true
                if block.settings.page == blank and block.settings.image == blank and block.settings.content == blank
                  assign show_block = false
                endif
              endif
            -%}
            {%- if show_block -%}
              <toggle-tab class="toggle" {{ block.shopify_attributes }}>
                <span class="toggle__title" data-js-title tabindex="0" aria-expanded="false" role="button" aria-controls="toggle-{{ block.id }}">{{ block.settings.heading | escape }}</span>
                <div id="toggle--{{ block.id }}" data-js-content class="toggle__content rte remove-empty-space" role="region">
                  {%- liquid
                    echo block.settings.content
                    unless block.settings.page == blank
                      echo block.settings.page.content
                    endunless
                    unless block.settings.image == blank
                      assign sizes = 'sizes="(max-width: 948px) calc(100vw - 20px), (min-width: 949px) and (max-width: 1023px) calc(100vw - 200px), 25vw"'
                      render 'lazy-image', image: block.settings.image, type: 'image', alt: block.settings.title, sizes: sizes
                    endunless
                  -%}
                </div>
              </toggle-tab>
            {%- endif -%}

          {%- when 'pickup_availability' -%}
            <pickup-availability-extended
              class="pickup-availability-widget element--border-radius no-js-hidden"
