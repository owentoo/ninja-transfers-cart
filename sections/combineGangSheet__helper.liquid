<script>
  $(function(){
    $('[data-block="appendtobottom"]').each(function() {
      var _cpopup = $(this);
      $("body").append(_cpopup.clone(true))
      _cpopup.remove();
    })
  })
</script>
{% if product.template_suffix == "dtf-gang-sheet" or product.template_suffix == "uv-gang-sheet" %}
  <style>
    .upload-container{order:-1}
    @media(max-width:768px){
      ._grt-{{product.template_suffix}} .add-to-cart,._grt-{{product.template_suffix}} .product-quantity{flex:1}
      .product-form .flex-buttons>*.shopify-payment-button{width: 100%;}
    }
    @media(min-width:768px){
      .customDrop{order: 2;}
      .qtyWithPrice{order: 1;}
      .__errorcase{order: 3;}
      ._grt-{{product.template_suffix}} .product-quantity{flex:1}
      ._grt-{{product.template_suffix}} .add-to-cart,._grt-{{product.template_suffix}} .shopify-payment-button{flex:2 !important}
    }
  </style>
{% endif %}
{% if _text == "custom_transfers_gang" or _text == "uv_dtf_gang" or _text == "ready_to_press" %}
  <script>
    function _update_q_inch(variant_obj){
      ////console.log(allVariants," ==allVariants")
      var _nodeid = "[data-sq="+ variant_obj.id +"]"
      for ( var _i = 0; _i < allVariants.length; _i++ ) {
        if ( variant_obj.id == allVariants[_i].id ) {
          var _vtTxt = $.trim(allVariants[_i].meta_sqinch);
          var __sqtext = "";
          if ( _vtTxt == "" ) {
            __sqtext = "with No Setup or Art Fees"
          } else {
            __sqtext = "<strong>- $"+allVariants[_i].meta_sqinch + " cents per sq inch</strong> with No Setup or Art Fees";
          }

          var _sqmsg = "<span class='_sqprice'>"+ __sqtext +"</span>"
          if ( $("[data-js-product-price-compact] .product-price" ).find("._sqprice").length ) {
            $("[data-js-product-price-compact] .product-price").find("._sqprice").html(__sqtext);
          } else {
            $("[data-js-product-price-compact] .product-price").append(_sqmsg);
          }
          break;
        }
      }
      if(typeof getTemplateLink == "function"){
        getTemplateLink();
      }
      
    }
  </script>
  <style>
    .product-variant__item .metafield-rich_text_field{text-align:center;}
  </style>
{% endif %}

