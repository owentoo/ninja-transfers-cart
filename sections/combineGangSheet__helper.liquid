              endif
            -%}

            {%- if show_block -%}
              <div class="product-recommendation" {{ block.shopify_attributes }}>
                {%- assign recommendation_id = 'product-recommendation-' | append: block.id -%}
                {%- render 'product-cross-sell', heading: block.settings.heading, product: block.settings.product, id: recommendation_id, widget_style: block.settings.style, heading_position: 'inside' -%}
              </div>
            {%- endif -%}

          {%- when 'customTabelPlace' -%}
            {%-liquid
              if customer
                assign isEliteMember = false
                for tag in customer.tags
                  if tag contains 'Elite-Monthly' or tag contains 'Elite-Annually' or tag contains 'Ninja Elite'
                    assign isEliteMember = true
                  endif
