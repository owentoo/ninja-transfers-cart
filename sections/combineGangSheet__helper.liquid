                  "meta_templateFiles": {{ templateFilesJson | json }}
                }
                {%- unless forloop.last -%}
                  ,
                {%- endunless -%}
              {% endfor %}
            {%- endcapture -%}

          {%- when 'buy_buttons' -%}
            {% if block.settings.reward_msg %}
              {% render 'reward-point-info' , product:product, reward_msg:block.settings.reward_msg ,reward_title: block.settings.reward_popup_title, reward_text:block.settings.reward_popup_msg, classneed : "__product-page", type : 'product', price : product.first_available_variant.price %}
            {% endif %}

            <div class="product-actions" {{ block.shopify_attributes }}>

              {%- if block.settings.show_price -%}

                <div class="sidebar-widget sidebar-widget--{{ block.settings.style }} {% unless default_to_first_variant %} hide {% endunless %}"
                  data-js-product-price-extended
                >
                  {%- if block.settings.style == 'outline' -%}
                    <span class="sidebar-widget__title">{{ 'products.page.price' | t }}</span>
                  {%- endif -%}
                  <div class="sidebar-widget__content">
                    <div>
                      {%- render 'product-price', variant: current_variant, target: current_variant, show_saving: true -%}
                    </div>
                  </div>
                </div>

              {%- endif -%}

              <product-form
                id="add-to-cart-{{ section.id }}" class="product-form" {% if settings.cart_action == 'overlay' %} data-ajax-cart data-js-product-form {% endif %}
              >

                {%- form 'product', product, id: product_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}

                  <template>
                    <input type="hidden" name="id" value="{{ current_variant.id }}">
                  </template>

                  <div class="form__properties"></div>

                  {%- liquid
                    if product.gift_card? and block.settings.show_gift_card_recipient
                      render 'gift-card-recipent-form', product: product
                    endif
                  -%}

                  <div class="product__cart-functions">
                    <div class="flex-buttons _grt-{{ product.template_suffix }}">

                      {% if b.allow2ndFiletoDrop %}
                        <div class="customDrop hidden">
                          <h3>
                            More files to upload?
                          </h3>

                          <input type="file" id="secondFile">
                          <label class="secondDropZone" for="secondFile">
                            <div class="secondDropZone__inner">
                              <b>Choose file <svg class="secondDropZone__inner_icon" fill="none" height="24" stroke="#46aae3" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="24" xmlns="http://www.w3.org/2000/svg"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" x2="12" y1="3" y2="15"></line></svg></b>
                              <div class="secondDropZone__text">
                                or drop file here
                              </div>
                            </div>
                          </label>
                        </div>
                        <style>
                          .customDrop {
                            width: 100%;
                            text-align: center;
                            position: relative;
                          }
                          .customDrop h3 {
                            font-size: large;
                            margin-bottom: 12px;
                          }
                          .customDrop #secondFile {
                            position: absolute;
                            bottom: 0;
                            left: 0;
                            z-index: 1;
                            width: 100%;
                            height: calc(100% - 30px);
                            opacity: 0;
                          }

                          .secondDropZone {
                            background-color: #e6f6ff;
                            border: 2px dashed #46aae3;
                            padding: 22px 20px;
                            border-radius: 8px;
                            text-align: center;
                            display: grid;
                            align-items: center;
                          }
                          .secondDropZone:hover {
                            box-shadow: 0 0 10px #46aae3;
                          }

                          .customDrop #secondFile:hover + .secondDropZone {
                            box-shadow: 0 0 10px #46aae3;
                          }

                          .secondDropZone__inner {
                            max-width: 216px;
                            margin: auto;
                          }
