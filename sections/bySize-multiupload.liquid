                          {% endif %}
                          $( `.widthHeight__value, .customQtyFile__qty` ).keypress(function (event) {
                            return isNumber(event, this)
                          });
                        });

                        function isNumber(evt, element) {
                          var charCode = (evt.which) ? evt.which : event.keyCode
                          if ( ( charCode != 45 || charCode != 48 || $(element).val().indexOf('-') != -1 ) && ( charCode != 46 || $( element ).val().indexOf('.') != -1 ) && ( charCode < 48 || charCode > 57 ) ) {
                            return false;
                          }
                          return true;
                        }

                        $( document )
                        .on(`click`, `.disabled[option="1"] .product-variant__item.product-variant__item--radio[min=""][max=""]`, function( e ) {
                           console.log(`disabled[option="1"] .product-variant__item.product-variant__item--radio[min=""][max=""]`);
                          try {
                            e.stopImmediatePropagation();
                            let parentContainer = $(this).parents("li[id^='upload-']").attr("id")??".master-upload";
                            if(parentContainer != ".master-upload"){
                               parentContainer = "#"+parentContainer;
                            }
                            console.log("parentContainer=>",parentContainer);
                            $( parentContainer+` .widthHeight__custom .widthHeight__item` ).removeClass( `error` );
                            $( parentContainer+` product-variants .product-variant[option="1"] .product-variant__item.product-variant__item--radio` ).each(function() {
                              const isChecked   =   $( this ).find( ` > input[type="radio"]` ).is( `:checked` );
                              if ( isChecked ) {
                                customSelectedVariant_id  =   $( this ).find( `label` ).attr( `for` );

                                console.log ( 'customSelectedVariant_id', customSelectedVariant_id );
                              }
                            })

                            $( parentContainer+` .widthHeight__option` ).removeClass( `selected` );

                            $( parentContainer+` .widthHeight__item__action, ${parentContainer} .widthHeight__autoChange` ).addClass( `disabled` );
                            $( parentContainer+` .product-variant` ).removeClass( `disabled` );

                            $( parentContainer+` .widthHeight__option.popularOption` ).addClass( `selected` );

                            $( `${parentContainer} .form__properties input[name="properties[width]"],${parentContainer} .form__properties input[name="properties[height]"],${parentContainer} .form__properties input[name="properties[Detected Size]"]` )
                              .prop( `disabled`, true );

                            let detectedSize  =   $( parentContainer+` .widthHeight__option-detectedSize span[d-size]` ).text();
                            detectedSize      =   detectedSize.replace( '"', '' ).replace( '"', '' ).replace( ' ', '' ).replace( ' ', '' );

                            $( this ).find( `label` ).click();

                          } catch ( err ) {
                            console.log( `ERROR .product-variant__item.product-variant__item--radio[min=""][max=""]`, err.message );
                          }
                        })

                        .on(`click`, `.widthHeight__option:not(.selected)`,async function( e ) {
                            console.log("widthHeight__option:not(.selected)");
                          try {
                            let parentContainer = $(this).parents("li[id^='upload-']").attr("id")??".master-upload";
                            if(parentContainer != ".master-upload"){
                               parentContainer = "#"+parentContainer;
