                  async function setQtyAndPricesForTable( currentVariant ) {
                    getCartTotal = {% if cart.item_count > 0 %}{{ cart.original_total_price | divided_by: 100 | json }}{% else %}0{% endif %};

                    const getCurrentQty = $( `.customQtyFile__wrapper .customQtyFile__qty` ).val() * 1;
                    const newPriceIs      = getCartTotal + ( currentVariant.price * 1 );
                    const productUnitPrice = currentVariant.price * 1;

                    if ( getCartTotal > 0 ) {
                      let getCalculatedQty = getCartTotal / productUnitPrice;
                      getCalculatedQty__ = Math.floor( getCalculatedQty );
                      // console.log ( 'getCalculatedQty__', getCalculatedQty__ );
                    }
                    // console.log ( 'newPriceIs', newPriceIs );
                    let lastMin = 0, lastMax = 0;
                    totalRow = $( `.customTabelPlace .customTabelPlace__item` ).length;
                    $( `.customTabelPlace .customTabelPlace__item` ).each(function(i) {
                      let discountedAmount = $( this ).find( `price-show` ).text();
                      discountedAmount = discountedAmount.replace( '$', '' ).replace( ',', '' ) * 1;

                      if ( discountedAmount === 0 ) {
                        lastMin = 1;
                        let getNextRowAmount = $( this ).next().find( `price-show` ).text();
                        getNextRowAmount = getNextRowAmount.replace( '$', '' ).replace( ',', '' ) * 1;
                        lastMax = getNextRowAmount / productUnitPrice;
                        lastMax = Math.floor( lastMax );
                        $( this ).attr({
                            min: lastMin,
                            max: lastMax
                          }).find( `.customTabelPlace__item_1 dynamic-qty` ).text( `${ lastMin }-${ lastMax } pcs` );
                        rowIndex__1 = lastMax;
                      } else {
                        isLastMinumum = lastMax;
                        lastMin = lastMax + 1;
                        if ( totalRow-1 == i ) {
                          let getRowAmount = $( this ).next().find( `price-show` ).text();
                          getRowAmount = getRowAmount.replace( '$', '' ).replace( ',', '' ) * 1;
                          lastMax = getRowAmount / productUnitPrice;
                          lastMax = 10000;
                          $( this ).attr({
                            min: lastMin,
                            max: lastMax
                          }).find( `.customTabelPlace__item_1 dynamic-qty` ).text( `${ lastMin }-${ lastMax }` );
                          // console.log ( 'isLastMinumum', isLastMinumum );
                        } else {
                          let getRowAmount = $( this ).next().find( `price-show` ).text();
                          getRowAmount = getRowAmount.replace( '$', '' ).replace( ',', '' ) * 1;
                          lastMax = getRowAmount / productUnitPrice;
                          lastMax = Math.floor( lastMax );
                          $( this ).attr({
                            min: lastMin,
                            max: lastMax
                          }).find( `.customTabelPlace__item_1 dynamic-qty` ).text( `${ lastMin }-${ lastMax }` );
                        }
                        const newIndex = i + 1;
                        // console.log ( 'newIndex', newIndex );
                        if ( newIndex == 1 ) {
                          rowIndex__1 = lastMax;
                        } else if ( newIndex == 2 ) {
                          rowIndex__2 = lastMax;
                        } else if ( newIndex == 3 ) {
                          rowIndex__3 = lastMax;
                        } else if ( newIndex == 4 ) {
                          rowIndex__4 = lastMax;
                        } else if ( newIndex == 5 ) {
                          rowIndex__5 = lastMax;
                        } else if ( newIndex == 6 ) {
                          rowIndex__6 = lastMax;
                        } else if ( newIndex == 7 ) {
                          rowIndex__7 = lastMax;
                        } else if ( newIndex == 8 ) {
                          rowIndex__8 = lastMax;
                        } else if ( newIndex == 9 ) {
                          rowIndex__9 = lastMax;
                        } else if ( newIndex == 10 ) {
                          rowIndex__10 = lastMax;
                        } else if ( newIndex == 11 ) {
                          rowIndex__11 = lastMax;
                        } else if ( newIndex == 12 ) {
                          rowIndex__12 = lastMax;
                        } else if ( newIndex == 13 ) {
                          rowIndex__13 = lastMax;
                        } else if ( newIndex == 14 ) {
                          rowIndex__14 = lastMax;
                        }
                        // rowIndex__1 = lastMax;
                      }



                      // console.log ( 'discountedAmount', discountedAmount );
                    });
                    // console.log ( 'setQtyAndPricesForTable ------function',  );
                  }

                  async function customTabelManage( vid, changeImg = '', eType, parentContainer = ".master-upload" ) {
                    try {
                      let currentVariant = findObjectByKey( allVariants, `id`, vid );
                      if(parentContainer != ".master-upload"){
                         let sizeVariantOptionText = $( parentContainer +` product-variants .product-variant[option="1"] input:checked`).val();  
                          let preCutOptionText = '';
                        const isPreCutActivated = $( `#precutselected__` ).is( `:checked` );
                          if ( isPreCutActivated ) {
                            preCutOptionText = $( parentContainer +` product-variants .product-variant[option="2"] .product-variant__item` ).last().find( `.product-variant__input` ).val();
                          } else {
                            preCutOptionText = $( parentContainer +` product-variants .product-variant[option="2"] .product-variant__item` ).first().find( `.product-variant__input` ).val();
                          }
                        const makeTitle = `${ sizeVariantOptionText } / ${ preCutOptionText }`;
                       // alert("makeTitle 1=" + makeTitle);
                       //  currentVariant = findObjectByKey( allVariants, `title`, makeTitle );
                      }
                      console.log("currentVariant",currentVariant);
                      if ( typeof currentVariant !== 'undefined' && currentVariant ) {
                        if ( typeof tableDiscountType !== 'undefined' && tableDiscountType == 'cartTotal' ) {
                          await setQtyAndPricesForTable( currentVariant );
                        }
                        console.log ( 'currentVariant__', currentVariant );
                        const vPrice      = currentVariant.price * 1;
                        const getCurrentQty = $( `.customQtyFile__wrapper .customQtyFile__qty` ).val() * 1;
                        console.log ( 'getCurrentQty', getCurrentQty );
                        const percent_100 = 100;
                        $( `.customTabelPlace .customTabelPlace__item` ).each(function(i) {
                          let getOff  = $( this ).attr( `off` ) * 1;
                          getOff      = ( percent_100 - getOff ) / 100;

                          let eliteDiscount = $( this ).attr( `elite-discount` ) * 1;
                          eliteDiscount = ( percent_100 - eliteDiscount ) / 100;

                          $( this )
                            .find( `discount` )
                            .text( `${ ( vPrice * getOff ).toFixed(2) }` );

                          $( this )
                            .find( `elite-discount` )
                            .text( `${ (( vPrice * getOff ) * eliteDiscount ).toFixed(2) }` );
                        })
                      }
                      if ( changeImg == 'applyImg' ) {
                        $( `.product__mainImg` )
                          .attr( `src`, currentVariant.large )
                          .fadeIn();
                        $( `.product__mainImgWrap iframe` )
                          .fadeOut();
                        $( `media-gallery .product__thumbItem` )
                          .removeClass( `selected` );
                        $( `.product__thumbItem.currentVariant` )
                          .attr( `img`, currentVariant.large )
                          .addClass( `selected` )
                          .find( `img` )
                          .attr( `src`, currentVariant.thumb );

                        {% if ss.hideVariantImages %}
                          if ( typeof currentVariant.media_id !== 'undefined' && currentVariant.media_id ) {
                            const is_mainMediaAvailable = $( `[data-media-id="${ currentVariant.media_id }"]` ).length;
                            const is_thumbMediaAvailable = $( `[data-thumb-id="${ currentVariant.media_id }"]` ).length;

                            if ( is_mainMediaAvailable > 0 && is_thumbMediaAvailable > 0 ) {
                              $( `.prodMainMedia, .prodThumbMedia` ).addClass( `hidden` );
                              if ( eType != 'onload' ) {
