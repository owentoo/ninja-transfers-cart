                <script>
                  $( document )
                  .on(`click`, `.openTextBasedPopup`, function( e ) {
                    try {
                      e.stopImmediatePropagation();
                      const popupHTML = `{{ popupHTML }}`;
                      $( `body` ).append( popupHTML );
                    } catch ( err ) {
                      console.log( `ERROR .openTextBasedPopup`, err.message );
                    }
                  })
                  .on(`click`, `popup-textbased .closePopup`, function( e ) {
                    try {
                      e.stopImmediatePropagation();
                      $( this ).closest( `popup-textbased` ).remove();
                    } catch ( err ) {
                      console.log( `ERROR popup-textbased .closePopup`, err.message );
                    }
                  })
                  ;
