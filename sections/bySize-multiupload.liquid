                </div>

                {% if layoutTypeIs == 'previous' %}
                  <div class="tab_header previousDesign" style="display: block;">
                    <div
                      class="prevItem"
                      type="popular"
                      onclick="$('.widthHeight__option.popularOption .widthHeight__option-radio').click(),$('.custom-variant-selector').prop('selectedIndex',0),$(`.prevItem[type='custom']`).removeClass('active'),$(this).addClass('active'),$(`#popular_size`).addClass('active')"
                    >
                      <div class="prevItem__circle">&nbsp;</div>
                      <div class="prevItem__title">
                        Popular Sizes
                        <div>Choose a size your design will fit within (WxH in inches)</div>
                      </div>
                    </div>
                  </div>
                {% endif %}

                <div data-id="popular_size" {% if layoutTypeIs == 'previous' %}style="display: block;"{% endif %}>
                  {% for block in section.blocks %}
                    {%- if block.type == 'variant_picker' -%}
                      {%- assign color_label = settings.color_swatches_labels | split: ',' -%}

                      <div class="sidebar-widget sidebar-widget--{{ block.settings.style }}"
                        {% if product.has_only_default_variant %} style="display:none" {% endif %}
                        {% if product.available == false and block.settings.unavailable_variants == 'hide' %} style="display:none" {% endif %}
                      >

                        {%- unless block.settings.heading == blank -%}
                          <span class="sidebar-widget__title">{{ block.settings.heading | escape }}</span>
                        {%- endunless -%}

                        <div class="sidebar-widget__content">

                          <product-variants
                            data-main-product-variants
                            data-variants="{{ product.options_with_values.size }}"
                            data-hide-variants="{%- liquid
                              if block.settings.unavailable_variants == 'disable'
                                echo 'disable'
                              elsif block.settings.unavailable_variants == 'show'
                                echo 'true'
                              else
                                echo 'hide'
                              endif
                            -%}"
                            data-url="{{ product.url }}" data-id="{{ section.id }}"
                            data-style="{{ block.settings.variants_style }}"
                            {% if block.settings.unavailable_variants == 'hide' %} class="product-variants--hide-unavailable" {% endif %}
                            {% unless default_to_first_variant %} data-variant-required {% endunless %}
                            {% unless product.has_only_default_variant %} data-has-variants {% elsif product.available == false %} data-unavailable {% endunless %}
                            {{ block.shopify_attributes }}
                          >

                            <div class="product-variants no-js-hidden"
                              {% if product.has_only_default_variant %} style="display:none" {% endif %}
                              {% if product.available == false and block.settings.unavailable_variants == 'hide' %} style="display:none" {% endif %}
                            >

                              {%- for option in product.options_with_values -%}

                                {%- assign option_downcased = option.name | downcase %}

                                <div class="product-variant" data-name="product-{{ option.name | escape | downcase | strip }}-{{ section.id }}" option="{{ option.position}}" data-js-product-variant>
                                  {% if layoutTypeIs == 'tab' or layoutTypeIs == 'tab_pills' %}
                                    <span class="product-variant__name text-size--small appendToolTip">
                                      {% if  option_downcased contains "size"  %}
                                        {% if layoutTypeIs == 'tab_pills' %}
                                          {%- comment -%}
                                          <strong>Popular Size</strong><br>
                                          {%- endcomment -%}
                                          <span style="font-weight: 400;">Choose a size your design will fit within (WxH in inches)</span>
                                        {% else %}
                                          Choose a popular size:&nbsp;
                                        {% endif %}
                                      {% else %}
                                        {{ 'products.grid.select_variant' | t: variant: option_downcased }}:&nbsp;
                                      {% endif %}
                                      {% if option_downcased contains "size" and block.settings.showTooltip %}
                                        <div class="widthHeight__option-toolTip" style="display:inline-block;margin-left:10px;">
                                          <img src="//ninjatransfers.com/cdn/shop/files/info_da70c6e6-1e86-41d3-9035-2bf57d01d406_medium.svg?v=1678797665">
                                          <div class="widthHeight__option-toolTip__content">
                                            {% if block.settings.tooltipImage != blank %}
                                              <img src="{{ block.settings.tooltipImage | image_url: width: 500 }}" class="widthHeight__option-toolTip__contentImg">
                                            {% endif %}
                                            {% if block.settings.tooltipContent != blank %}
                                              <div>
                                                {{ block.settings.tooltipContent }}
                                              </div>
                                            {% endif %}
                                          </div>
                                        </div>
                                      {% endif %}
                                    </span>
                                  {% endif %}
                                  {%- liquid
                                    unless default_to_first_variant
                                      assign _firstColorVal = 'products.grid.color_variants_count' | t: count: option.values.size
                                    else
                                      assign _firstColorVal = option.selected_value
                                    endunless
                                  -%}
                                  <strong style="display: none;" data-val="{{ _firstColorVal }}" class="product-variant__item-text-label text-size--small text-line-height--small text-color--opacity __variant-{{ option_downcased | split : " " | join : "_" }}">
                                    {{ _firstColorVal }}
                                  </strong>

                                  {%- if color_label contains option_downcased and block.settings.color_swatches -%}
                                    <div class="product-variant__container product-variant__container--radio product-variant__container--radio--wrap" data-js-product-variant-container="radio">
                                      {%- for value in option.values -%}
                                        <div
                                          class="product-variant__item product-variant__item--radio product-variant__item--color  __color-option"
                                        >
                                          <input type="radio" name="product-{{ option.name | escape | downcase | strip }}-{{ section.id }}" id="{{ product.handle }}-option-{{ option.name | escape | downcase | strip }}-{{ forloop.index }}-{{ section.id }}" value="{{ value | escape }}" {% if default_to_first_variant and option.selected_value == value %}checked{% endif %} class="product-variant__input product-variant-value">
                                          <label for="{{ product.handle }}-option-{{ option.name | escape | downcase | strip }}-{{ forloop.index }}-{{ section.id }}" class="tooltip product-variant__label" title="{{ option.name }}">
                                            {%- liquid
                                              assign color_swatch_name = value | handle | append: '.png'
                                              assign color_swatch_image = images[color_swatch_name]
                                              assign color_swatch_background = value | downcase | escape | replace: ' ', ''
                                            -%}
                                            <span class="tooltiptext">
                                              {{ color_swatch_background }}
                                            </span>
                                            {%- if color_swatch_image != blank -%}
                                              <img class="product-variant__item-swatch product-variant__item-swatch--color"
                                                src="{{ color_swatch_image | image_url: width: 30, height: 30, crop: 'center' }}"
                                                srcset="
                                                  {{ color_swatch_image | image_url: width: 30, height: 30, crop: 'center' }} 30w,
                                                  {{ color_swatch_image | image_url: width: 60, height: 60, crop: 'center' }} 60w,
                                                  {{ color_swatch_image | image_url: width: 90, height: 90, crop: 'center' }} 90w
                                                "
                                                sizes="30px" width="30" height="30"
                                                loading="lazy"
                                                alt="{{ color_swatch_image.alt | escape }}"
                                              />
                                            {%- else -%}
                                              {%-liquid
                                                case color_swatch_background
                                                  when 'mint'
                                                    assign __colorcode = "#caf7e5"
                                                  when 'denim'
                                                    assign __colorcode = "#5e87a3"
                                                  when 'glowinthedark'
                                                    assign __colorcode = "rgb(242, 253, 158)"
                                                  when 'glowinthedark'
                                                    assign __colorcode = "rgb(242, 253, 158)"
                                                  when 'green'
                                                    assign __colorcode = "#82d145"
                                                  when 'pink'
                                                    assign __colorcode = "#f77ff0"
                                                  when 'orange'
                                                    assign __colorcode = '#FF3900'
                                                  when 'gold'
                                                    assign __colorcode = '#ffc121'
                                                  when 'yellow'
                                                    assign __colorcode = '#ffe500'
                                                  when 'yellow'
                                                    assign __colorcode = '#ffe500'
                                                  when 'teal'
                                                    assign __colorcode = '#66c9c4'
                                                  when 'teal'
                                                    assign __colorcode = '#66c9c4'
                                                  when 'blue'
                                                    assign __colorcode = '#005bd3'
                                                  when 'purple'
                                                    assign __colorcode = '#a54dcf'
                                                  when 'lavender'
                                                    assign __colorcode = '#d9b7ea'
                                                  when 'tan'
                                                    assign __colorcode = '#e9b396'
                                                  when 'red'
                                                    assign __colorcode = '#c40000'
                                                  when 'skyblue'
                                                    assign __colorcode = '#88d4f7'
                                                  else
                                                    assign __colorcode = color_swatch_background
                                                endcase
                                              -%}
                                              <span class="product-variant__item-swatch product-variant__item-swatch--image" style="background-color:{{ __colorcode }}"></span>
                                            {%- endif -%}
                                            <span class="visually-hidden">{{ value | escape }}</span>
                                          </label>
                                        </div>
                                      {%- endfor -%}
                                    </div>

                                  {%- elsif block.settings.variants_style == 'select' -%}
                                    <select class="product-variant__container product-variant__container--select text-size--small" id="product-{{ option.name | escape | downcase | strip }}-{{ section.id }}" data-js-product-variant-container="select">
                                      {%- for value in option.values -%}
                                        {%-liquid
                                          assign minVal = ''
                                          assign maxVal = ''
                                          if value contains 'Style #'
                                            assign getVal = value | remove: '"' | remove: "'"
                                            assign getVal = getVal | split: '#' | last
                                            assign getVal = getVal | split: '-'
                                            assign minVal = getVal[0] | strip
                                            assign maxVal = getVal[1] | strip
                                          endif
                                        -%}
                                        <option  min="{{ minVal }}"
                                          max="{{ maxVal }}" class="product-variant-value" value="{{ value | escape }}" {% if default_to_first_variant and option.selected_value == value %}selected{% endif %}
                                        >
                                          {{ value | escape }}
                                        </option>
                                      {%- endfor -%}
                                    </select>
                                  {%- else -%}
                                    <div class="product-variant__container product-variant__container--radio product-variant__container--radio--wrap" data-js-product-variant-container="radio">
                                      {%- for value in option.values -%}
                                        {%-liquid
                                          assign minVal = ''
                                          assign maxVal = ''
                                          if value contains 'Style #'
                                            assign getVal = value | remove: '"' | remove: "'"
                                            assign getVal = getVal | split: '#' | last
                                            assign getVal = getVal | split: '-'
                                            assign minVal = getVal[0] | strip
                                            assign maxVal = getVal[1] | strip
                                          endif
                                        -%}
                                        <div
                                          {% if layoutTypeIs == 'tab' %}
                                            style="display:none;"
                                          {% endif %}
                                          class="product-variant__item product-variant__item--radio"
                                          min="{{ minVal }}"
                                          max="{{ maxVal }}"
                                        >
                                          <input type="radio" name="product-{{ option.name | escape | downcase | strip }}-{{ section.id }}" id="{{ product.handle }}-option-{{ option.name | escape | downcase | strip }}-{{ forloop.index }}-{{ section.id }}" value="{{ value | escape }}" {% if default_to_first_variant and option.selected_value == value %}checked{% endif %} class="product-variant__input product-variant-value">
                                          <label for="{{ product.handle }}-option-{{ option.name | escape | downcase | strip }}-{{ forloop.index }}-{{ section.id }}" class="product-variant__label text-size--small" val="{{ value | replace: '"', '^' }}">
                                            {{ value | escape }}
                                          </label>
                                        </div>
                                      {%- endfor -%}
                                      <select class="custom-variant-selector product-variant__container product-variant__container--select text-size--small {% if layoutTypeIs == 'previous' or layoutTypeIs == 'tab_pills' %}hidden{% endif %}">
                                        {%- for value in option.values -%}
                                          {%- unless value contains 'Style #' -%}
                                          <option  class="product-variant-value" value="{{ value | escape }}" {% if default_to_first_variant and option.selected_value == value %}selected{% endif %}>
                                            {{ value | escape }}
                                          </option>
                                          {% endunless %}
                                        {%- endfor -%}
                                      </select>
                                    </div>
                                  {%- endif -%}
                                </div>
                              {%- endfor -%}
                            </div>

                            <noscript>
                              <label for="Variants-{{ section.id }}" class="text-size--small" style="display:block;margin-bottom:.75rem">{{ 'products.page.variants' | t }}</label>
                              <select name="id" id="Variants-{{ section.id }}" class="productSelect"
                                {% if product.has_only_default_variant %} style="display:none!important" {% endif %}
                                form="{{ product_form_id }}"
                              >
                                {%- for variant in product.variants -%}
                                  <option
                                    {% if variant == current_variant %}selected="selected"{% endif %}
                                    {% if variant.available == false %}disabled{% endif %}
                                    value="{{ variant.id }}"
                                  >
                                    {{ variant.title }}
                                    {% if variant.available == false %} - {{ 'products.page.inventory.sold_out_variant' | t }}{% endif %}
                                    - {{ variant.price | money | strip_html }}
                                  </option>
                                {%- endfor -%}
                              </select>
                            </noscript>

                            <script type="application/json">
                              {{ product.variants | json }}
                            </script>
                          </product-variants>
                        </div>
                      </div>

                      {%- capture popularVariants -%}
                        {%- for variant in product.variants -%}
                          {%-liquid
                            capture options
                              for option in variant.options
                                if variant.metafields.custom.is_popular_size.value
                                  echo option | strip
                                  unless forloop.last
                                    echo '/'
                                  endunless
                                endif
                              endfor
                            endcapture
                          -%}

                          {%- if options != blank and options contains '/Yes' -%}
                            ,{
                              "vid": {{ variant.id | json }},
                              "title": {{ options | split: '/Yes' | first | strip | json }}
                            }
                          {%- endif -%}
                        {%- endfor -%}
                      {%- endcapture -%}

                      <script>
                        const popularVariants = [{{ popularVariants | remove_first: ',' }}];
                      </script>

                      {%- capture optionsHidden -%}
                        {%- if b.hideOption1 -%}
                          .product-variants .product-variant[option="1"] {
                            display: none;
                          }
                        {%- endif -%}
                        {%- if b.hideOption2 -%}
                          .product-variants .product-variant[option="2"] {
                            display: none;
                          }
                        {%- endif -%}
                        {%- if b.hideOption3 -%}
                          .product-variants .product-variant[option="3"] {
                            display: none;
                          }
                        {%- endif -%}
                      {%- endcapture -%}
                      <style>
                        {{ optionsHidden }}
                      </style>
                    {% endif %}
