<style>
  @media (max-width: 768px) {
    .fileupload_custom div.split_design .upload_image_info{order:-1}
    .size_selection  {
      display: grid;
    }
  }
  .activehover img{opacity:0 !important;}
</style>
<script>
  $(function(){
    $("[data-anim]").hover(function(){
      var imgurl = $(this).attr("data-anim");
      console.log(imgurl, " :imgurl")
      if(imgurl != ""){
        $(this).find("figure").addClass("activehover").css({"background":"url("+ imgurl +")","background-size":"cover"})
      }
    },function () {
      $(this).find("figure").removeClass("activehover").css({"background":'none'})
    })
  })
</script>