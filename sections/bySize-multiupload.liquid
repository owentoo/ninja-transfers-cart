{%-liquid
  assign ss = section.settings
  assign sb = section.blocks

  assign collectAllStyles = ''
  assign collectAllScripts = ''
-%}
{% render '__multipleSnippets' product: product, section: section, block: block, contentFor: 'interFont' %}
{% render 'bySize__js' product: product, section: section, contentIs: 'isCustomer' %}
{% render 'bySize__js' product: product, section: section, contentIs: 'isDTFTransfer' %}

{% render 'bySize__css' product: product, section: section, contentIs: 'fileUploadNote' %}

{% assign metafield_data = product.metafields.custom.icons_and_label_section.value %}

{{ 'section-main-product.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="{{ 'transferBySize.css' | asset_url }}">

{% render 'bySize__js' product: product, section: section, contentIs: 'metafieldsSpecs' %}

{% render 'bySize__js' product: product, section: section, contentIs: 'allVariants' %}

{%- render 'breadcrumb', container: 'large', vertical_space: 'vertical-space', style: 'breadcrumb-main--margin breadcrumb-main--scroll element--hide-on-portable-plus' -%}

{%- liquid
  if section.settings.gallery_desktop_width contains 'one-half'
    if section.settings.gallery_layout contains 'one-col'
      assign gallery_class = 'grid-1'
      assign parent_class = 'grid-2 grid-lap-1'
    else
      assign parent_class = 'grid-4 grid-lap-1'
      assign child_class = 'grid-offset-2 grid-offset-lap-1'
      assign gallery_class = 'grid-2 grid-portable-1'
      assign text_class = 'grid-offset-2 grid-offset-lap-1'
    endif
  else
    assign parent_class = 'grid-3 grid-portable-5 grid-lap-1'
    assign child_class = 'grid-offset-2 grid-offset-portable-3 grid-offset-lap-1'
    assign text_class = 'grid-portable-2 grid-offset-portable-2 grid-offset-lap-1'
    if section.settings.gallery_layout contains 'one-col'
      assign gallery_class = 'grid-1'
    else
      assign gallery_class = 'grid-2 grid-portable-1'
    endif
  endif
-%}

{%- liquid
  unless product.has_only_default_variant
    assign default_to_first_variant = section.settings.default_to_first_variant
  else
    assign default_to_first_variant = true
  endunless
-%}

{%- liquid
  assign selectedProduct = product
  if product.metafields.specs.default_child_color != blank
    assign page_url = content_for_header | split:'"pageurl":"' | last | split:'"' | first | split: request.host | last | replace:'\/','/' | replace:'%20',' ' | replace:'\u0026','&'
    assign param_color = nil

    for i in (1..1)
      unless page_url contains "?"
        break
      endunless
      assign query_string = page_url | split:'?' | last
      assign qry_parts= query_string | split:'&'

      for part in qry_parts
        assign key_and_value = part | split:'='
        if key_and_value.size > 1
          if key_and_value[0] == 'view' or key_and_value[0] == 'variant'
            assign param_color = key_and_value[1] | upcase
          endif
        endif
      endfor
    endfor

    assign style_category = 'style-' | append: product.metafields.specs.shirt_style
    assign style_collection = product.collections | where: "handle", style_category | first

    paginate style_collection.products by 1000
    assign sortedColors = style_collection.products | sort: "url"
    endpaginate

    assign defaultProduct = blank
    assign selectedProduct = blank
    for style_product in sortedColors
      assign shirt_color = style_product.metafields.specs.shirt_color | upcase
      if style_product.metafields.specs.shirt_color == product.metafields.specs.default_child_color
        assign defaultProduct = style_product
      endif
      if param_color and shirt_color == param_color
        assign selectedProduct = style_product
      endif
    endfor

    if selectedProduct == blank
      assign selectedProduct = defaultProduct
    endif
  endif
-%}

<div class="product container container--large container--vertical-space-small {% unless settings.show_breadcrumb %} container--no-space-mobile {% endunless %}">
  <product-page
    id="product-{{ section.id }}"
    class="grid grid--layout grid--gap-xlarge {{ parent_class }} grid--no-stretch main-product"
    data-collection="{{ collection.handle }}" data-id="{{ product.id }}"
    data-availability="{{ product.available }}"
  >
    <div class="{{ child_class }} element--is-sticky">
      {% if ss.uploadLiftPosition == 'atLeft' %}
        <script src="{{ 'html2canvas.min.js' | asset_url }}"></script>
        <div class="customUploaderView">
          <div class="customUploaderView_detail">
            <div class="customUploaderView__info">
              <div class="customUploaderView__info_left">
                <div class="customUploaderView__info_fileName"></div>
                <div class="customUploaderView__info_fileSize"></div>
              </div>
              <div class="customUploaderView__info_right">
                <div class="customUploaderView__info_status"></div>
                <div class="customUploaderView__info_status2nd"></div>
              </div>
              <span class="customUploaderView__removeFile">
                <svg width="26" height="26" viewBox="0 0 26 26" xmlns="http://www.w3.org/2000/svg"><path d="M11.586 13l-2.293 2.293a1 1 0 0 0 1.414 1.414L13 14.414l2.293 2.293a1 1 0 0 0 1.414-1.414L14.414 13l2.293-2.293a1 1 0 0 0-1.414-1.414L13 11.586l-2.293-2.293a1 1 0 0 0-1.414 1.414L11.586 13z" fill="currentColor" fill-rule="nonzero"></path></svg>
              </span>
            </div>
            <div class="customUploaderView_preview"></div>
          </div>

          <div class="customUploaderView__inputFeild">
            <div class="customUploaderView__inputFeild_label">Notes for our designers</div>
            <textarea class="customUploaderView__inputFeild_textarea" placeholder="ex: Remove background and change the black text to white text. Crop out any unwanted blank space."></textarea>
          </div>
        </div>
        <!-- <span class="btn-Preview-Image">Preview</span> -->
        {% render 'bySize__css' product: product, section: section, contentIs: 'customUploaderView' %}
        {% render 'bySize__js' product: product, section: section, contentIs: 'customUploaderView' %}
      {% endif %}
      {% render "product-gallery", section:section, product: selectedProduct, gallery_class: gallery_class, hideVariantImages: ss.hideVariantImages %}
    </div>

    <div class="product-text {{ text_class }} element--is-sticky remove-empty-space">
      <div class="element--hide-on-portable">
        {%- render 'breadcrumb', container: '', vertical_space: '', style: 'breadcrumb-main--scroll breadcrumb-main--smaller' -%}
      </div>

      {%- assign product_form_id = 'product-form-' | append: section.id -%}
      {%- for block in section.blocks -%}
        {%- assign b = block.settings -%}

        {%- case block.type -%}
          {%- when '@app' -%}
            <div class="has-bg-style--{{ section.settings.style }}">
              {%- render block -%}
            </div>

            {% render 'bySize__js' product: product, section: section, contentIs: 'isPuffTransfers' %}

          {%- when 'steps' -%}
            {% if b.stepElement == 'startingElement' %}
              {%-liquid
                capture stepsClass
                  if b.isStep_1
                    echo 'step__1'
                  endif

                  if b.isStep_2
                    echo ' step__2 hidden'
                  endif

                  if b.isStep_3
                    echo ' step__3 hidden'
                  endif
                endcapture
              -%}
              <div class="{{ stepsClass }}">
            {% else %}
              </div>
            {% endif %}

          {%- when 'vendor' -%}
            <div class="product__subtitle product__vendor rte" {{ block.shopify_attributes }}>
              {{ product.vendor | link_to_vendor }}
            </div>

          {%- when 'title' -%}
            <h1 class="product__title heading-size--page-title {{ section.settings.title_class | escape }}" {{ block.shopify_attributes }}>
              {{ product.title | escape }}{% if b.addBadge != blank %}{{ b.addBadge }}{% endif %}
            </h1>

          {%- when 'price' -%}
            <div {{ block.shopify_attributes }} data-js-product-price-compact>
              {%- liquid
                if default_to_first_variant
                  render 'product-price', variant: current_variant, target: current_variant
                else
                  render 'product-price', variant: current_variant, target: product, product_price_varies: product.price_varies
                endif
              -%}
            </div>

          {%- when 'description' -%}

            {% assign use_metafield = false %}
            {% if block.settings.product_data_src == 'metafield' and metafield_data.Headline != blank %}
              {% assign use_metafield = true %}
            {% endif %}

            {% if use_metafield or product.description != blank %}
              {%- if block.settings.product_description_truncated != 'full' -%}
                <show-more class="show-more"
                  style="--height:{{ block.settings.product_description_truncated }}px"
                  data-height="{{ block.settings.product_description_truncated }}"
                >
                  <span class="js-show-more show-more_toggler text-decoration--underline">
                    {{ 'general.accessibility_labels.show_more' | t }}
                  </span>
                  <div class="show-more_panel">
              {%- endif -%}

                <div class="product__description rte remove-empty-space" {{ block.shopify_attributes }}>
                  {% if use_metafield %}
                    {{ metafield_data.Headline }}
                  {% else %}
                    {{ product.description }}
                  {% endif %}
                </div>

              {%- if block.settings.product_description_truncated != 'full' -%}
                  </div>
                </show-more>
                <script src="{{ 'component-show-more.js' | asset_url }}" defer></script>
              {%- endif -%}
            {% endif %}

          {%- when 'customTabelPopup' -%}
            {%-liquid
              if customer
                assign isEliteMember = false
                for tag in customer.tags
                  if tag contains 'Elite-Monthly' or tag contains 'Elite-Annually' or tag contains 'Ninja Elite'
                    assign isEliteMember = true
                  endif
                endfor
              endif
            -%}

            <link rel="stylesheet" href="{{ 'customTabelPopup.css' | asset_url }}">

            <div class="customTabelPopup__overlay nj-popup pricing-table" style="display: none;">
              <div class="customTabelPopup">
                <span class="customTabelPopup__close">
                  <svg width="24px" height="24px" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M6 6L18 18" stroke="#000" stroke-linecap="round"></path><path d="M18 6L6.00001 18" stroke="#000" stroke-linecap="round"></path></svg>
                </span>
                <h2>Price Calculator</h2>

                <div class="customTabelPopup__sizes">
                  <div class="customTabelPopup__sizes__title">
                    Choose a size
                  </div>
                  <div class="customTabelPopup__sizes__popular">
                    <span class="_select">
                    <select class="customTabelPopup__sizes__popularSelect">
                      <option value="2x2">2" x 2"</option>
                      <option value="3x3">3" x 3"</option>
                    </select>
                    </span>

                    <div class="customTabelPopup__sizes__popularCheckboxWrap">
                      <label for="customTabelPopup__sizes__popularCheckboxWrap" {% if b.hideCustomSize %}style="opacity: 0;"{% endif %}>
                        <input type="checkbox" id="customTabelPopup__sizes__popularCheckboxWrap">
                        <span>Enter a Custom Size</span>
                      </label>
                    </div>
                  </div>

                  <div class="customTabelPopup__sizes__wrapper" style="display: none;">
                    <div class="customTabelPopup__sizes__wrapper_width">
                      Width (inches)<br>
                      <div class="widthHeight__item__action__" by="width_">
                        <button class="widthHeight__item__action__-minus__">
                          {% render 'transfer-icons' ,icon:'minus' %}
                        </button>
                        <input type="number" name="width__value" class="widthHeight__value__" value="2" min="0.5" max="22" step="0.5" data-parent=".master-upload">
                        <button class="widthHeight__item__action__-plus__">
                          {% render 'transfer-icons' ,icon:'plus' %}
                        </button>
                      </div>
                      <div class="widthHeight__item_err nodisplay hidden">
                        {% render 'transfer-icons' ,icon:'error' %}
                        <span>Max size is 22</span>
                      </div>
                    </div>

                    <div class="customTabelPopup__sizes__wrapper_height">
                      Height (inches)<br>
                      <div class="widthHeight__item__action__" by="height_">
                        <button class="widthHeight__item__action__-minus__">
                          {% render 'transfer-icons' ,icon:'minus' %}
                        </button>
                        <input type="number" name="height__value" class="widthHeight__value__" value="2" min="0.5" max="22" step="0.5"  data-parent=".master-upload">
                        <button class="widthHeight__item__action__-plus__">
                          {% render 'transfer-icons' ,icon:'plus' %}
                        </button>
                      </div>
                      <div class="widthHeight__item_err nodisplay hidden">
                        {% render 'transfer-icons' ,icon:'error' %}
                        <span>Max size is 22</span>
                      </div>
                    </div>

                  </div>
                </div>

                {% if b.title != blank %}
                  <div class="customTabelPopup__title">
                    {{ b.title }}
                  </div>
                {% endif %}

                {% if b.infoDetail != blank and b.toolTipContent != blank %}
                  {%- capture tooltip -%}
                    <picture class="tooltip">
                      <img src="//ninjatransfers.com/cdn/shop/files/info_da70c6e6-1e86-41d3-9035-2bf57d01d406_medium.svg?v=1678797665" class="infoIcon infoModal grt-infoicon">
                      <span class="tooltiptext" style="text-align: left; background-color: #000; color: #fff;">{{ b.toolTipContent }}</span>
                    </picture>
                  {%- endcapture -%}
                  {% assign infoDetailData = b.infoDetail | replace: '[ICON]', tooltip %}
                  <div class="customTabelPopup__detail">
                    {{ infoDetailData }}
                  </div>
                {% endif %}

                <div class="customTabelPopup__table popupView_{{ b.showCols }}">
                  {% assign _dis = "" %}
                  {% render 'popup_table_elite' b: b, isEliteMember: isEliteMember %}
                </div>

                {% if b.uploadBtnText != blank %}
                  <div>
                    <label for="fileInput" class="customTabelPopup__uploadArt d-block lblctrl">{{ b.uploadBtnText }}</label>
                  </div>

                  <script>
                    $( document )
                    .on(`click`, `.customTabelPopup__uploadArt`, function( e ) {
                      try {
                        e.stopImmediatePropagation();
                        $( `.filepond--drop-label label` ).click();
                        $( `.customTabelPopup__close` ).click();
                      } catch ( err ) {
                        console.log( `ERROR .customTabelPopup__uploadArt`, err.message );
                      }
                    })
                    ;
                  </script>
                {% endif %}
              </div>
            </div>

            <script>
              $(document).ready(function () {
                let optionsData = ``;
                let firstOption,secondOption;
                $( `product-variants .product-variant[option="1"] .product-variant__container .product-variant__item.product-variant__item--radio[min=""][max=""]` ).each(function(i) {
                  let getVal = $( this ).find( `.product-variant__input` ).val();
                  let quotesConvert = '';
                  if ( getVal.includes( `"` ) ) {
                    quotesConvert = getVal.replaceAll( `"`, `^` );
                    getVal = getVal.replaceAll( `"`, `\"` );
                  }
                  if ( i == 0 ) {
                    firstOption = $( this ).find( `.product-variant__input` ).val();
                  }
                  optionsData += `<option value="${ quotesConvert }" ${ i }>${ getVal }</option>`;
                })
                if ( optionsData != '' ) {
                  $( `.customTabelPopup__sizes__popularSelect` ).html( optionsData );
                }
                setTimeout(() => {
                  const is2ndOption = $( `product-variants .product-variant[option="2"] .product-variant__container .product-variant__item.product-variant__item--radio[min=""][max=""] .product-variant__input` ).length;
                  if ( is2ndOption > 0 ) {
                    secondOption = document.querySelector( `product-variants .product-variant[option="2"] .product-variant__container .product-variant__item.product-variant__item--radio[min=""][max=""] .product-variant__input` ).value;
                  }
                  let makeTitle = `${ firstOption }`;
                  if ( typeof secondOption !== 'undefined' && secondOption ) {
                    makeTitle = `${ makeTitle } / ${ secondOption }`;
                  }
                  const getVariantData = findObjectByKey( allVariants, `title`, makeTitle );
                  if ( typeof getVariantData !== 'undefined' && getVariantData ) {
                    customTabelManagePopUp( getVariantData.id );
                  }
                  /**  Move **/
                  var _pricetable = $(".customTabelPopup__overlay").clone(true);
                  $(".customTabelPopup__overlay").remove();
                  $("body").append(_pricetable)
                  /**  ./Move **/
                }, 50);
              })
              .on(`click`, `.customTabelPopup__close`, function( e ) {
                try {
                  e.stopImmediatePropagation();
                  $( `.customTabelPopup__overlay` ).fadeOut();
                  $( `.product.container.container--large` ).css( `z-index`, `unset` );
                  $( `body` ).removeAttr( `style` );
                } catch ( err ) {
                  console.log( `ERROR .customTabelPopup__close`, err.message );
                }
              })

              .on(`change`, `.customTabelPopup__sizes__popularSelect`, function( e ) {
                try {
                  e.stopImmediatePropagation();
                  let firstOption = $( this ).val();
                  if ( firstOption.includes( `^` ) ) {
                    firstOption = firstOption.replaceAll( `^`, `"` );
                  }
                  console.log ( 'firstOption', firstOption );
                  let makeTitle = `${ firstOption }`;
                  const is2ndOption = $( `product-variants .product-variant[option="2"] .product-variant__container .product-variant__item.product-variant__item--radio[min=""][max=""] .product-variant__input` ).length;
                  if ( is2ndOption > 0 ) {
                    secondOption = document.querySelector( `product-variants .product-variant[option="2"] .product-variant__container .product-variant__item.product-variant__item--radio[min=""][max=""] .product-variant__input` ).value;
                  }
                  if ( typeof secondOption !== 'undefined' && secondOption ) {
                    makeTitle = `${ makeTitle } / ${ secondOption }`;
                  }
                  const getVariantData = findObjectByKey( allVariants, `title`, makeTitle );
                  if ( typeof getVariantData !== 'undefined' && getVariantData ) {
                    customTabelManagePopUp( getVariantData.id );
                  }
                } catch ( err ) {
                  console.log( `ERROR .customTabelPopup__sizes__popularSelect`, err.message );
                }
              })


              .on(`change`, `#customTabelPopup__sizes__popularCheckboxWrap`, function( e ) {
                try {
                  e.stopImmediatePropagation();
                  const isChecked = $( this ).is( ':checked' );
                  if ( isChecked ) {
                    $( `.customTabelPopup__sizes__wrapper` ).show();
                    var _firstVal = "2^ x 2^";
                    $( `.customTabelPopup__sizes__popularSelect` ).val(_firstVal).trigger("change");
                    $( `.customTabelPopup__sizes__popularSelect` ).prop( `disabled`, true );
                  } else {
                    $( `.widthHeight__value__`).val(2).trigger("keyup");
                    $( `.customTabelPopup__sizes__wrapper` ).hide();
                    $( `.customTabelPopup__sizes__popularSelect` ).prop( `disabled`, false );
                  }
                  console.log ( 'isChecked', isChecked );
                } catch ( err ) {
                  console.log( `ERROR #customTabelPopup__sizes__popularCheckboxWrap`, err.message );
                }
              })

              .on(`click`, `.widthHeight__item__action__-minus__`, function( e ) {
                try {
                  e.stopImmediatePropagation();
                  const wrapper   =   $( this ).closest( `.widthHeight__item__action__` );
                  const min       =   wrapper.find( `.widthHeight__value__` ).attr( `min` ) * 1;
                  const max       =   wrapper.find( `.widthHeight__value__` ).attr( `max` ) * 1;
                  const step      =   wrapper.find( `.widthHeight__value__` ).attr( `step` ) * 1;
                  const getVal    =   wrapper.find( `.widthHeight__value__` ).val() * 1;
                  var afterMinus = 0;
                  if(getVal % step > 0){
                    afterMinus = roundDownToHalf(getVal);
                  }else{
                    afterMinus  =   getVal - step;
                  }

                  const byWidthHeight = wrapper.attr( `by` );

                  if ( afterMinus >= min ) {
                    const winScreen =   $( window ).width();
                    if ( winScreen > 549 ) {
                      wrapper.find( `.widthHeight__value__` ).val( afterMinus.toFixed(2) ).focus();
                    } else {
                      wrapper.find( `.widthHeight__value__` ).val( afterMinus.toFixed(2) );
                    }

                    setTimeout(()=>{
                      getRadioMaintain( byWidthHeight );
                    }, 50);

                    setTimeout(()=>{
                      reAdjustSizes();
                    }, 1000);
                  }
                  getSqInches();
                } catch ( err ) {
                  console.log( `ERROR .widthHeight__item__action__-minus__`, err.message );
                }
              })
              .on(`click`, `.widthHeight__item__action__-plus__`, function( e ) {
                try {
                  e.stopImmediatePropagation();
                  const wrapper   =   $( this ).closest( `.widthHeight__item__action__` );
                  const min       =   wrapper.find( `.widthHeight__value__` ).attr( `min` ) * 1;
                  const max       =   wrapper.find( `.widthHeight__value__` ).attr( `max` ) * 1;
                  const step      =   wrapper.find( `.widthHeight__value__` ).attr( `step` ) * 1;
                  const getVal    =   wrapper.find( `.widthHeight__value__` ).val() * 1;
                  var afterAdd = 0;
                  if(getVal % step > 0){
                    afterAdd = roundUpToHalf(getVal);
                  }else{
                    afterAdd  =   getVal + step;
                  }
                  const byWidthHeight = wrapper.attr( `by` );
                  console.log(getVal," :getVal === Step: ",step)

                  if ( afterAdd <= max ) {
                    const winScreen =   $( window ).width();
                    if ( winScreen > 549 ) {
                      wrapper.find( `.widthHeight__value__` ).val( afterAdd.toFixed(2) ).focus();
                    } else {
                      wrapper.find( `.widthHeight__value__` ).val( afterAdd.toFixed(2) );
                    }
                  } else {
                    const winScreen =   $( window ).width();
                    if ( winScreen > 549 ) {
                      wrapper.find( `.widthHeight__value__` ).val( userDefinedMaxLength.toFixed(2) ).focus();
                    } else {
                      wrapper.find( `.widthHeight__value__` ).val( userDefinedMaxLength.toFixed(2) );
                    }
                  }

                  getSqInches();

                } catch ( err ) {
                  console.log( `ERROR .widthHeight__item__action__-plus__`, err.message );
                }
              })
              .on(`keyup`, `input[name="width__value__"], input[name="height__value__"],.widthHeight__value__`, function( e ) {
                try {
                  e.stopImmediatePropagation();
                  const wrapper       =   $( this ).closest( `.widthHeight__item__action__` );
                  const getWidth      =   $( `input[name="width__value__"]` ).attr( `last` );
                  const getHeight     =   $( `input[name="height__value__"]` ).attr( `last` );
                  const byWidthHeight =   wrapper.attr( `by` );
                  const getVal        =   $( this ).val() * 1;
                  const getMin        =   $( this ).attr( `min` ) * 1;
                  const getMax        =   $( this ).attr( `max` ) * 1;
                  wrapper.removeClass( `error` )

                  if ( getVal < getMin ) {
                    $( this ).val( getMin );
                  }
                  if ( getVal > userDefinedMaxLength ) {
                    $( this ).closest( `.widthHeight__item__` ).addClass( `error` );
                    $( this ).closest( `.widthHeight__item__action__` ).addClass( `error` );
                    var _cnode = $( this );
                    setTimeout(function(){
                      _cnode.val( getMax ).trigger("change");
                      _cnode.closest( `.widthHeight__item__action__` ).removeClass( `error` );
                    })
                  }

                  setTimeout(()=>{
                    getRadioMaintain( byWidthHeight );
                  }, 50);
                  setTimeout(()=>{
                    reAdjustSizes();
                  }, 1000);

                  setTimeout(()=>{
                    const getWidth      =   $( `input[name="width__value__"]` ).val() * 1;
                    const getHeight     =   $( `input[name="height__value__"]` ).val() * 1;

                    if ( getWidth > userDefinedMaxLength || getHeight > userDefinedMaxLength ) {
                      if ( getWidth > getHeight ) {
                        $( `input[name="width__value__"]` ).val( userDefinedMaxLength.toFixed(2) );
                        getRadioMaintain( 'width' );
                        reAdjustSizes();
                      } else if ( getHeight > getWidth ) {
                        $( `input[name="height__value__"]` ).val( userDefinedMaxLength.toFixed(2) );
                        getRadioMaintain( 'height' );
                        reAdjustSizes();
                      }
                    }
                    getSqInches();
                  }, 1050);
                } catch ( err ) {
                  console.log( `ERROR input[name="width__value"], input[name="height__value"]`, err.message );
                }
              })

              ;

              function customTabelManagePopUp( vid, changeImg = '', eType ) {
                try {
                  const currentVariant = findObjectByKey( allVariants, `id`, vid );
                  if ( typeof currentVariant !== 'undefined' && currentVariant ) {
                    console.log ( 'currentVariant', currentVariant );
                    const vPrice      = currentVariant.price * 1;
                    const percent_100 = 100;
                    $( `.customTabelPopup__table .customTabelPopup__item` ).each(function() {
                      let getOff  = $( this ).attr( `off` ) * 1;
                      getOff      = ( percent_100 - getOff ) / 100;

                      let eliteDiscount = $( this ).attr( `elite-discount` ) * 1;
                      eliteDiscount = ( percent_100 - eliteDiscount ) / 100;

                      $( this )
                        .find( `discount` )
                        .text( `${ ( vPrice * getOff ).toFixed(2) }` );

                      $( this )
                        .find( `elite-discount` )
                        .text( `${ (( vPrice * getOff ) * eliteDiscount ).toFixed(2) }` );
                    })
                  }
                  // manageQuantities( `btnClicked` );
                }
                catch ( err ) {
                  console.log( `ERROR customTabelManage()`, err.message );
                }
              }

              function getSqInches() {
                try {
                  const getWidth    =   $( `.customTabelPopup__sizes .widthHeight__item__action__ .widthHeight__value__[name="width__value"]` ).val() * 1;
                  const getHeight   =   $( `.customTabelPopup__sizes .widthHeight__item__action__ .widthHeight__value__[name="height__value"]` ).val() * 1;
                  const getSquareIn =   Math.ceil( getWidth * getHeight );
                  console.log ( 'getSquareIn', getSquareIn );

                  let firstOption,secondOption;

                  $( `product-variants .product-variant[option="1"] .product-variant__item.product-variant__item--radio:not([min=""][max=""])` ).each(function() {
                    const min = $( this ).attr( `min` ) * 1;
                    const max = $( this ).attr( `max` ) * 1;
                    if ( getSquareIn >= min && getSquareIn <= max ) {
                      firstOption = $( this ).find( `.product-variant__input` ).val();
                      // $( this ).find( `label` ).click();
                    }
                  })
                  console.log ( 'firstOption chaaa', firstOption );

                  let makeTitle = `${ firstOption }`;
                  const is2ndOption = $( `product-variants .product-variant[option="2"] .product-variant__container .product-variant__item.product-variant__item--radio[min=""][max=""] .product-variant__input` ).length;

                  if ( is2ndOption > 0 ) {
                    secondOption = document.querySelector( `product-variants .product-variant[option="2"] .product-variant__container .product-variant__item.product-variant__item--radio[min=""][max=""] .product-variant__input` ).value;
                    makeTitle = `${ makeTitle } / ${ secondOption }`;
                  }

                  const getVariantData = findObjectByKey( allVariants, `title`, makeTitle );
                  if ( typeof getVariantData !== 'undefined' && getVariantData ) {
                    console.log ( 'getVariantData', getVariantData );
                    customTabelManagePopUp( getVariantData.id );
                  }

                } catch ( err ) {
                  console.log( `ERROR getSqInches()`, err.message );
                }
              }

            </script>

