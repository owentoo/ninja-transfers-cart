<script>
  
  function loadFallback(obj){
    $(obj).parents(".imgbox").removeClass("reorder_img");
    var _img = "https://cdn.shopify.com/s/files/1/0558/0265/8899/files/no_image-design-300424.svg?crop=center&height=120&v=1686517377&width=120";
    var _count = parseInt($(obj).attr("data-loadcount"));
    $(obj).attr("data-loadcount",++_count);
    if(_count < 3){
      var _src = $(obj).attr("data-src");
      $(obj).attr("src",_src);
      var _ctrlparent = $(obj).parents(".reorder_box_wrap");
      $(obj).parents(".order_img_box:not(._ptype_builder)").addClass("disable_addcart");
      _ctrlparent.addClass("parent_disable_addcart")
      if(_ctrlparent.find("._ptype_builder").length){
      }else{
        _ctrlparent.addClass("parent_disable_addcart")
      }
    }else{
      $(obj).attr("src",_img);
      $(obj).parents(".order_img_box").addClass("disable_addcart");
      
      var _ctrlparent = $(obj).parents(".reorder_box_wrap");
      _ctrlparent.addClass("parent_disable_addcart")
    }
  }
</script>
