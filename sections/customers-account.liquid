<script>
  
  
  (function($) {

    if($(".design_type.design_true").length){
      $(".design_order-tab").hide();
    }
  // stx reorder 
  this.reorder = new function(){
    var self = this;

    this.pushQueue = function(i, data, el){
      var __note_val = "";// "reorder of order #" + el.attr('data-corder-id');
      //LOW STOCK -- add as many as possible if stock is below requested ammount
      if(data[i].check_inventory){
        data[i].quantity = Math.min(parseInt(data[i].inventory), parseInt(data[i].quantity));
      }
      //console.log(data,"Ajax data")
      //return;
      $.ajax({
        url: '/cart/add.js',
        method: 'POST',
        data: {
          quantity: data[i].quantity,
          id: data[i].id,
          properties : data[i].properties
        },
        complete: function(res){
          if(i >= data.length - 1){
            //products from queue are now added to the cart -> stop loading signal and go to cart
            el.removeClass('loading');
            //window.location.href = '/cart';
            window.refreshCart()
            return;
          }else{
            // Calls are async as required by Shopify Docs
               self.pushQueue(i+1, data, el);
          }
        }
      });
    }

    this.listen = function(){
      var el = $(this);
      var pNode = el.parents(".reorder_box_wrap");
      
      var note = "of order #" + el.attr('data-corder-id');
      var ids = el.attr('data-variant-ids').split(',');
      var lineids = el.attr('data-lineitem-ids').split(',');
      var quantities = el.attr('data-variant-quantities').split(',');
      var inventories = el.attr('data-variant-inventories').split(',');
      var inventory_policies = el.attr('data-variant-inventory-policies').split(',');
      var inventory_trackers = el.attr('data-variant-inventory-trackers').split(',');
      
      
      ids.splice(-1, 1);
      quantities.splice(-1, 1);
      inventories.splice(-1, 1);
      inventory_policies.splice(-1, 1);
      inventory_trackers.splice(-1, 1);

      var data = [];
      var propitems = pNode.find(".propitems");
      for(var i=0; i<ids.length; i++){
        var order_properties =  $.trim($(propitems[i]).val());
        var _json_prop = {};
        if(order_properties != ""){
          _json_prop = JSON.parse(order_properties);
          $.each(_json_prop, function(key, value) {
              if(value.indexOf("https%3A%2F%2F") > -1){
                _json_prop[key] = decodeURIComponent(value);
              }else{
                _json_prop[key] = value.replaceAll("+", " ");
              }
          });
        }
        _json_prop["reorder"] = note  + " / " + lineids[i];
        data.push({
          id: ids[i],
          quantity: quantities[i],
          inventory: inventories[i],
          properties : _json_prop ,
          check_inventory: (inventory_policies[i] == "deny" && inventory_trackers[i] != "")
        });
      }
      
      el.addClass('loading');
      self.pushQueue(0, data, el);
    }

    
    this.addDesignCart = function(){
      var el = $(this);
      
      // var _index = parseInt(el.attr("data-line")) - 1;
      var pEL = el.parents(".order_img_box").find(".reorder-btn");
      var pNode = el.parents(".order_img_box");
      
      var note = "of order #" + pEL.attr('data-corder-id');
      var ids = pEL.attr('data-variant-ids').split(',');
      var lineids = pEL.attr('data-lineitem-ids').split(',');
      var quantities = pEL.attr('data-variant-quantities').split(',');
      var inventories = pEL.attr('data-variant-inventories').split(',');
      var inventory_policies = pEL.attr('data-variant-inventory-policies').split(',');
      var inventory_trackers = pEL.attr('data-variant-inventory-trackers').split(',');
      

      var data = [];
      var propitems = pNode.find(".propitems");
        for(var i=0; i<ids.length; i++){
          var order_properties =  $.trim($(propitems[i]).val());
          var _json_prop = {};
          if(order_properties != ""){
            _json_prop = JSON.parse(order_properties);
            $.each(_json_prop, function(key, value) {
                if(value.indexOf("https%3A%2F%2F") > -1){
                  _json_prop[key] = decodeURIComponent(value);
                }else{
                  _json_prop[key] = value.replaceAll("+", " ");
                }
            });
          }
          _json_prop["reorder"] = note  + " / " + lineids[i];
          data.push({
            id: ids[i],
            quantity: quantities[i],
            inventory: inventories[i],
            properties : _json_prop ,
            check_inventory: (inventory_policies[i] == "deny" && inventory_trackers[i] != "")
          });
      }
      
      pNode.addClass('loading');
      console.log(data,"data")
      self.pushQueue(0, data, el);
    }
    
    this.addDesign = function(){
      var el = $(this);
      
      var _index = parseInt(el.attr("data-line")) - 1;
      var pEL = el.parents(".reorder_box_wrap").find(".reorder-btn");
      var pNode = el.parents(".reorder_box_wrap");
      
      var note = "of order #" + pEL.attr('data-corder-id');
      var ids = pEL.attr('data-variant-ids').split(',');
      var lineids = pEL.attr('data-lineitem-ids').split(',');
      var quantities = pEL.attr('data-variant-quantities').split(',');
      var inventories = pEL.attr('data-variant-inventories').split(',');
      var inventory_policies = pEL.attr('data-variant-inventory-policies').split(',');
      var inventory_trackers = pEL.attr('data-variant-inventory-trackers').split(',');
      
      
      ids.splice(-1, 1);
      quantities.splice(-1, 1);
      inventories.splice(-1, 1);
      inventory_policies.splice(-1, 1);
      inventory_trackers.splice(-1, 1);

      var data = [];
      var propitems = pNode.find(".propitems");
      for(var i=0; i<ids.length; i++){
        if(i == _index){
          console.log(i," :Index: ",_index)
          var order_properties =  $.trim($(propitems[i]).val());
          var _json_prop = {};
          if(order_properties != ""){
            _json_prop = JSON.parse(order_properties);
            $.each(_json_prop, function(key, value) {
                if(value.indexOf("https%3A%2F%2F") > -1){
                  _json_prop[key] = decodeURIComponent(value);
                }else{
                  _json_prop[key] = value.replaceAll("+", " ");
                }
            });
          }
          _json_prop["reorder"] = note  + " / " + lineids[i];
          data.push({
            id: ids[i],
            quantity: quantities[i],
            inventory: inventories[i],
            properties : _json_prop ,
            check_inventory: (inventory_policies[i] == "deny" && inventory_trackers[i] != "")
          });
        }
      }
      
      pNode.addClass('loading');
      self.pushQueue(0, data, el);
    }
    
    this.init = function(){
      $('.reorder-btn').on('click', self.listen);
      $('.addtodesign').on('click', self.addDesign);
      $('.add_design').on('click', self.addDesignCart);
      
      $(".reorder_img").click(function(){
        var _href = $(this).attr("data-href");
        console.log("data",_href,$("#modal_image-container"));
        $("#modal_image-container").find("img").attr("src",_href);
        $("#modal_input").prop("checked",true);
      })
    }
  }

  $(reorder.init);
})(jQuery)
</script>
