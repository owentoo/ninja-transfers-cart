<!-- ── Dynamic styles (scoped to this section instance) ── -->
<style>
  #shopify-section-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    overflow-x: hidden;
  }
  {% if section.settings.right_side_display == 'gallery' %}
  #shopify-section-{{ section.id }} .hero-right::before {
    background: linear-gradient(to bottom, {{ section.settings.bg_color }}, transparent);
  }
  {% endif %}
  #shopify-section-{{ section.id }} .hero h1 {
    font-size: {{ section.settings.h1_size_desktop }}px;
    line-height: 1.1;
    color: {{ section.settings.heading_color }};
  }
  #shopify-section-{{ section.id }} .hero .subtitle {
    font-size: {{ section.settings.subtitle_size_desktop }}px;
    line-height: 1.6;
    color: {{ section.settings.subtitle_color }};
    opacity: {{ section.settings.subtitle_opacity | divided_by: 100.0 }};
  }
  #shopify-section-{{ section.id }} .hero .badge .badge-review-text {
    font-size: {{ section.settings.review_text_size_desktop }}px;
  }
  #shopify-section-{{ section.id }} .hero .feature {
    font-size: {{ section.settings.feature_size_desktop }}px;
    line-height: 1.4;
    color: {{ section.settings.feature_color }};
    opacity: {{ section.settings.feature_opacity | divided_by: 100.0 }};
  }
  #shopify-section-{{ section.id }} .hero .feature svg,
  #shopify-section-{{ section.id }} .hero .feature .feature-custom-icon {
    width: {{ section.settings.icon_size_desktop }}px;
    height: {{ section.settings.icon_size_desktop }}px;
  }
  #shopify-section-{{ section.id }} .hero-wrapper {
    padding-bottom: {{ section.settings.section_padding_bottom }}px;
  }
  #shopify-section-{{ section.id }} .hero {
    min-height: {{ section.settings.section_max_height }}px;
    max-height: {{ section.settings.section_max_height }}px;
  }
  #shopify-section-{{ section.id }} .hero-left {
    padding-left: {{ section.settings.text_padding_left }}px;
    padding-top: {{ section.settings.padding_above_toggles_desktop }}px;
    justify-content: flex-start;
  }
  #shopify-section-{{ section.id }} .hero-image--mobile {
    display: none;
  }
  #shopify-section-{{ section.id }} .nav-pills-bar {
    margin-bottom: {{ section.settings.space_below_toggles_desktop }}px;
    justify-content: {{ section.settings.pills_align_desktop }};
  }
  #shopify-section-{{ section.id }} .nav-pills-track {
    background: {{ section.settings.pill_wrapper_bg }};
    padding: {{ section.settings.pill_wrapper_padding }}px;
    border-radius: {{ section.settings.pill_wrapper_radius }}px;
    gap: {{ section.settings.pill_gap }}px;
    {%- if section.settings.pill_wrapper_shadow != blank %}box-shadow: {{ section.settings.pill_wrapper_shadow }};{%- endif %}
  }
  #shopify-section-{{ section.id }} .pill {
    font-size: {{ section.settings.pill_size_desktop }}px;
    padding: {{ section.settings.pill_vertical_padding }}px {{ section.settings.pill_horizontal_padding }}px;
    border-radius: {{ section.settings.pill_toggle_radius }}px;
  }
  #shopify-section-{{ section.id }} .pill-active {
    background: {{ section.settings.pill_selected_bg }};
    color: {{ section.settings.pill_selected_text }};
  }
  #shopify-section-{{ section.id }} .pill-inactive {
    color: {{ section.settings.pill_unselected_text }};
  }
  #shopify-section-{{ section.id }} .pill-inactive:hover {
    color: {{ section.settings.pill_hover_text }};
  }
  #shopify-section-{{ section.id }} .hero-image {
    max-width: {{ section.settings.image_max_width }}%;
  }
  #shopify-section-{{ section.id }} .badge strong {
    color: {{ section.settings.badge_rating_color }};
  }
  #shopify-section-{{ section.id }} .badge .badge-review-text {
    color: {{ section.settings.badge_text_color }};
  }
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .hero {
      min-height: auto;
      max-height: none;
      overflow: hidden;
    }
    #shopify-section-{{ section.id }} .hero-right {
      display: none;
    }
    #shopify-section-{{ section.id }} .hero-right--image {
      display: flex;
    }
    #shopify-section-{{ section.id }} .hero h1 {
      font-size: {{ section.settings.h1_size_mobile }}px;
      line-height: 1.15;
    }
    #shopify-section-{{ section.id }} .hero .subtitle {
      font-size: {{ section.settings.subtitle_size_mobile }}px;
      line-height: 1.5;
    }
    #shopify-section-{{ section.id }} .hero .badge .badge-review-text {
      font-size: {{ section.settings.review_text_size_mobile }}px;
    }
    #shopify-section-{{ section.id }} .hero .feature {
      font-size: {{ section.settings.feature_size_mobile }}px;
      line-height: 1.4;
    }
    #shopify-section-{{ section.id }} .hero .feature svg,
    #shopify-section-{{ section.id }} .hero .feature .feature-custom-icon {
      width: {{ section.settings.icon_size_mobile }}px;
      height: {{ section.settings.icon_size_mobile }}px;
    }
    #shopify-section-{{ section.id }} .pill {
      font-size: {{ section.settings.pill_size_mobile }}px;
    }
    #shopify-section-{{ section.id }} .hero-left {
      padding-top: {{ section.settings.padding_above_toggles_mobile }}px;
      padding-bottom: {{ section.settings.mobile_cta_image_gap }}px;
    }
    #shopify-section-{{ section.id }} .nav-pills-bar {
      margin-bottom: {{ section.settings.space_below_toggles_mobile }}px;
      justify-content: {{ section.settings.pills_align_mobile }};
    }
    #shopify-section-{{ section.id }} .hero-image--desktop {
      display: none;
    }
    #shopify-section-{{ section.id }} .hero-image--mobile {
      display: block;
    }
  }
</style>

<!-- ── Hero markup ── -->
<div class="hero-wrapper">
  <div class="hero">
    <div class="hero-left">

    {%- assign has_pills = false -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'nav_pill' -%}
        {%- assign has_pills = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
    {%- if has_pills -%}
      <div class="nav-pills-bar">
        <div class="nav-pills-track">
          {%- for block in section.blocks -%}
            {%- if block.type == 'nav_pill' -%}
              {%- if block.settings.is_active -%}
                <span class="pill pill-active" {{ block.shopify_attributes }}>{{ block.settings.label }}</span>
              {%- else -%}
                <a href="{{ block.settings.url }}" class="pill pill-inactive" {{ block.shopify_attributes }}>{{ block.settings.label }}</a>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- if section.settings.badge_visible -%}
      <div class="badge">
        <span class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        <strong>{{ section.settings.badge_rating }}</strong> <span class="badge-review-text">{{ section.settings.badge_review_text }}</span>
      </div>
    {%- endif -%}

    <h1>
      {{ section.settings.heading_text }}<br>
      <span class="count">{{ section.settings.customer_count }}</span>
      {%- assign has_rotating_words = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'rotating_word' -%}
          {%- assign has_rotating_words = true -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if has_rotating_words %} <span class="rotating-wrapper">
          <span id="rotating-word-{{ section.id }}" class="rotating-word">
            {%- for block in section.blocks -%}
              {%- if block.type == 'rotating_word' -%}
                {{- block.settings.word_text -}}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
          </span>
        </span>
      {%- endif -%}
    </h1>

    <p class="subtitle">{{ section.settings.subtitle_text }}</p>

    {%- assign has_features = false -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'feature' -%}
        {%- assign has_features = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
    {%- if has_features -%}
      <div class="features">
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature' -%}
            <div class="feature" {{ block.shopify_attributes }}>
              {%- if block.settings.custom_icon != blank -%}
                {%- assign icon_url = block.settings.custom_icon | image_url: width: 40 -%}
                <img class="feature-custom-icon" src="{{ icon_url }}" alt="" width="40" height="40" loading="lazy">
              {%- else -%}
                {%- case block.settings.icon -%}
                  {%- when 'checkmark' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
                    </svg>
                  {%- when 'star' -%}
                    <svg viewBox="0 0 24 24" fill="currentColor">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                    </svg>
                  {%- when 'shield' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                  {%- when 'truck' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                      <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
                    </svg>
                {%- endcase -%}
              {%- endif -%}
              {{ block.settings.feature_text }}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="buttons">
      {%- for block in section.blocks -%}
        {%- if block.type == 'button' -%}
          <a href="{{ block.settings.btn_url }}"
             class="btn btn-{{ block.settings.btn_style }}{% if block.settings.mobile_only %} btn-mobile-only{% endif %}"
             style="--btn-bg: {{ block.settings.btn_bg_color }}; --btn-text: {{ block.settings.btn_text_color }}; --btn-border: {{ block.settings.btn_border_color }};"
             {{ block.shopify_attributes }}>
            {{- block.settings.btn_text -}}
            <svg class="btn-arrow" width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 10h10"/><path d="M11 6l4 4-4 4"/></svg>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>

  {%- if section.settings.right_side_display == 'gallery' -%}
    <div class="hero-right">
      <div class="gallery-container" id="gallery-{{ section.id }}"></div>
    </div>
  {%- else -%}
    <div class="hero-right hero-right--image">
      {%- if section.settings.hero_image != blank -%}
        {%- assign hero_img = section.settings.hero_image | image_url: width: 1200 -%}
        <img class="hero-image hero-image--desktop" src="{{ hero_img }}" alt="{{ section.settings.hero_image.alt | escape }}" width="{{ section.settings.hero_image.width }}" height="{{ section.settings.hero_image.height }}" loading="eager">
        {%- if section.settings.hero_image_mobile != blank -%}
          {%- assign hero_img_mobile = section.settings.hero_image_mobile | image_url: width: 800 -%}
          <img class="hero-image hero-image--mobile" src="{{ hero_img_mobile }}" alt="{{ section.settings.hero_image_mobile.alt | escape }}" width="{{ section.settings.hero_image_mobile.width }}" height="{{ section.settings.hero_image_mobile.height }}" loading="eager">
        {%- endif -%}
      {%- else -%}
        <div class="hero-image-placeholder">
          <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          <span>Upload Hero Image</span>
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}
  </div>
</div>

{%- if section.settings.right_side_display == 'gallery' -%}
  <!-- Mobile horizontal gallery -->
  <div class="mobile-gallery" id="mobile-gallery-{{ section.id }}"></div>
{%- endif -%}

<!-- ── Data bridge: passes Liquid values to JS ── -->
<script type="application/json" id="hero-data-{{ section.id }}">
  {
    "sectionId": {{ section.id | json }},
    "displayMode": {{ section.settings.right_side_display | json }},
    "gallerySpeed": {{ section.settings.gallery_scroll_speed }},
    "wordSpeed": {{ section.settings.word_rotation_speed }},
    "images": [
      {%- assign img_comma = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'gallery_image' -%}
          {%- if img_comma -%},{%- endif -%}
          {%- assign img_comma = true -%}
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 400 | json }}
          {%- else -%}
            null
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    ],
    "words": [
      {%- assign word_comma = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'rotating_word' -%}
          {%- if word_comma -%},{%- endif -%}
          {%- assign word_comma = true -%}
          { "text": {{ block.settings.word_text | json }}, "color": {{ block.settings.word_color | json }} }
        {%- endif -%}
      {%- endfor -%}
    ]
  }
</script>

<!-- ── Static CSS ── -->
{% stylesheet %}
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

  /* Full-width section wrapper */
  .hero-section-root {
    overflow-x: hidden;
  }

  .hero-wrapper {
    max-width: 1400px;
    margin: 0 auto;
    font-family: 'Inter', sans-serif;
    color: #fff;
  }

  /* Nav pills — segmented toggle */
  .nav-pills-bar {
    display: flex;
  }

  .nav-pills-track {
    display: inline-flex;
  }

  .pill {
    display: inline-block;
    font-weight: 600;
    font-family: 'Inter', sans-serif;
    text-decoration: none;
    transition: color 0.25s;
    white-space: nowrap;
    cursor: pointer;
  }

  .pill-active {
    cursor: default;
  }

  .pill-inactive {
    background: transparent;
  }

  .hero {
    display: flex;
    overflow-y: clip;
    overflow-x: visible;
    position: relative;
    padding-left: 40px;
    font-family: 'Inter', sans-serif;
    color: #fff;
  }

  .hero-left {
    flex: 0 0 45%;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding: 0 40px 0 0;
    z-index: 2;
  }

  /* Badge */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 0;
    font-size: 13px;
    color: #9ca3af;
    margin-top: 0;
    margin-bottom: 14px;
    width: fit-content;
  }

  .badge .stars {
    color: #fbbf24;
    font-size: 15px;
    letter-spacing: 2px;
  }

  .badge strong {
    color: #fff;
    font-weight: 700;
  }

  /* Heading */
  .hero h1 {
    font-weight: 800;
    line-height: 1.1;
    margin-top: 0;
    margin-bottom: 20px;
    letter-spacing: -1.5px;
    white-space: nowrap;
  }

  .hero h1 .count {
    color: #fff;
  }

  .rotating-wrapper {
    display: inline-block;
    width: 320px;
    text-align: left;
  }

  .hero h1 .rotating-word {
    display: inline-block;
    transition: opacity 0.4s, transform 0.4s;
    white-space: nowrap;
  }

  .hero h1 .rotating-word.fade-out {
    opacity: 0;
    transform: translateY(10px);
  }

  .hero h1 .rotating-word.fade-in {
    opacity: 1;
    transform: translateY(0);
  }

  /* Subtitle */
  .hero .subtitle {
    color: #9ca3af;
    line-height: 1.6;
    margin-bottom: 28px;
    max-width: 480px;
  }

  /* Features */
  .hero .features {
    display: flex;
    gap: 20px;
    margin-bottom: 36px;
    flex-wrap: nowrap;
    white-space: nowrap;
  }

  .hero .feature {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #d1d5db;
  }

  .hero .feature svg {
    width: 20px;
    height: 20px;
    color: #22c55e;
    flex-shrink: 0;
  }

  .hero .feature .feature-custom-icon {
    width: 20px;
    height: 20px;
    object-fit: contain;
    flex-shrink: 0;
  }

  /* Buttons */
  .hero .buttons {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .hero .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    border-radius: 12px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s;
    cursor: pointer;
    border: none;
    font-family: 'Inter', sans-serif;
    white-space: nowrap;
  }

  .hero .btn-primary {
    background: var(--btn-bg);
    color: var(--btn-text);
    box-shadow: 0 4px 20px color-mix(in srgb, var(--btn-bg) 40%, transparent);
  }

  .hero .btn-primary:hover {
    box-shadow: 0 6px 30px color-mix(in srgb, var(--btn-bg) 50%, transparent);
    transform: translateY(-2px);
  }

  .hero .btn-secondary {
    background: color-mix(in srgb, var(--btn-bg) 12%, transparent);
    color: var(--btn-text);
    border: 1px solid color-mix(in srgb, var(--btn-border) 15%, transparent);
  }

  .hero .btn-secondary:hover {
    background: color-mix(in srgb, var(--btn-bg) 20%, transparent);
    transform: translateY(-2px);
  }

  .hero .btn-outline {
    background: transparent;
    color: var(--btn-text);
    border: 2px solid color-mix(in srgb, var(--btn-border) 35%, transparent);
  }

  .hero .btn-outline:hover {
    border-color: color-mix(in srgb, var(--btn-border) 70%, transparent);
    transform: translateY(-2px);
  }

  .hero .btn-text {
    background: transparent;
    color: var(--btn-text);
    padding-left: 4px;
    padding-right: 4px;
  }

  .hero .btn-text:hover {
    opacity: 0.7;
  }

  .hero .btn-glass {
    background: color-mix(in srgb, var(--btn-bg) 8%, transparent);
    color: var(--btn-text);
    border: 1px solid color-mix(in srgb, var(--btn-border) 10%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .hero .btn-glass:hover {
    background: color-mix(in srgb, var(--btn-bg) 15%, transparent);
    transform: translateY(-2px);
  }

  .hero .btn-arrow {
    width: 18px !important;
    height: 18px !important;
    min-width: 18px;
    min-height: 18px;
    flex-shrink: 0;
    transition: transform 0.3s;
  }

  .hero .btn:hover .btn-arrow {
    transform: translateX(3px);
  }

  .hero .btn-mobile-only {
    display: none;
  }

  /* Desktop gallery (right side — gallery mode) */
  .hero-right {
    flex: 0 0 55%;
    position: relative;
    overflow: hidden;
    min-width: 0;
    align-self: stretch;
  }

  .hero-right::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 150px;
    z-index: 2;
    pointer-events: none;
  }

  .gallery-container {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    height: 100%;
    padding: 0 20px;
    position: relative;
    overflow: hidden;
  }

  .gallery-col {
    flex: 1;
    min-width: 160px;
    display: flex;
    flex-direction: column;
    will-change: transform;
  }

  .gallery-card {
    border-radius: clamp(10px, 1.2vw, 16px);
    overflow: hidden;
    flex-shrink: 0;
    position: relative;
    background: #1a1a2e;
    aspect-ratio: 3/4;
    width: 100%;
    margin-bottom: 16px;
  }

  .gallery-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @keyframes scrollUp {
    0%   { transform: translateY(0); }
    100% { transform: translateY(-50%); }
  }

  @keyframes scrollDown {
    0%   { transform: translateY(-50%); }
    100% { transform: translateY(0); }
  }

  /* Right side — single image mode */
  .hero-right--image {
    flex: 0 0 55%;
    display: flex;
    align-items: flex-end;
    align-self: stretch;
  }

  .hero-right--image::before {
    display: none;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
    object-position: bottom right;
  }

  .hero-image--mobile {
    display: none;
  }

  .hero-image-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    width: 100%;
    height: 100%;
    background: #1a1a2e;
    color: #4a4a6a;
  }

  .hero-image-placeholder span {
    font-size: 14px;
    font-family: 'Inter', sans-serif;
  }

  /* Mobile gallery */
  .mobile-gallery {
    display: none;
  }

  .mobile-gallery-container {
    overflow: hidden;
    width: 100%;
  }

  .mobile-gallery-row {
    display: flex;
    will-change: transform;
    padding: 6px 0;
  }

  .mobile-gallery-card {
    border-radius: 12px;
    overflow: hidden;
    flex-shrink: 0;
    background: #1a1a2e;
    width: 160px;
    height: 200px;
    margin-right: 12px;
  }

  .mobile-gallery-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @keyframes scrollLeft {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @keyframes scrollRight {
    0%   { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .hero .btn-mobile-only {
      display: inline-flex;
    }

    .hero {
      flex-direction: column;
      min-height: auto;
      max-height: none;
      padding-bottom: 0;
      padding-left: 20px;
      padding-right: 20px;
    }

    .hero-left {
      flex: none;
      padding: 0 0 30px;
    }

    .hero-right {
      display: none;
    }

    .hero-right--image {
      display: flex;
      width: 100%;
      flex: none;
      padding: 0;
      order: 2;
    }

    .hero-image--desktop {
      display: none;
    }

    .hero-image--mobile {
      display: block;
    }

    .mobile-gallery {
      display: block;
      overflow: hidden;
      margin-top: 10px;
      max-height: calc(140px * 2 + 12px - 18px);
    }

    .mobile-gallery-card {
      width: 112px;
      height: 140px;
    }

    .hero h1 {
      white-space: normal;
    }

    .rotating-wrapper {
      width: auto;
    }

    .hero .features {
      flex-direction: column;
      white-space: normal;
      gap: 12px;
    }

    .hero .buttons {
      flex-direction: column;
    }

    .hero .btn {
      justify-content: center;
    }
  }
{% endstylesheet %}

<!-- ── JavaScript ── -->
{% javascript %}
  (function() {
    function initHeroBanner(sectionEl) {
      var sectionId = sectionEl.id.replace('shopify-section-', '');
      var dataEl = document.getElementById('hero-data-' + sectionId);
      if (!dataEl) return;

      var data = JSON.parse(dataEl.textContent);
      var images = data.images || [];
      var words = data.words || [];
      var gallerySpeed = data.gallerySpeed || 10;
      var wordSpeed = data.wordSpeed || 1500;
      var displayMode = data.displayMode || 'gallery';

      if (displayMode === 'gallery') {
        buildGallery(sectionId, images, gallerySpeed);
        buildMobileGallery(sectionId, images, gallerySpeed);
      }

      initWordRotation(sectionId, words, wordSpeed);
    }

    /* Split images evenly across columns */
    function computeColumnOrders(count, numCols) {
      var cols = [];
      var perCol = Math.ceil(count / numCols);
      for (var c = 0; c < numCols; c++) {
        var col = [];
        var start = c * perCol;
        var end = Math.min(start + perCol, count);
        for (var i = start; i < end; i++) {
          col.push(i);
        }
        cols.push(col);
      }
      return cols;
    }

    /* Placeholder SVG for empty image blocks */
    function placeholderSVG(index) {
      var hues = [210, 260, 320, 160, 40, 190];
      var h = hues[index % hues.length];
      var svg = '<svg xmlns="http://www.w3.org/2000/svg" width="300" height="400" viewBox="0 0 300 400">' +
        '<rect width="300" height="400" fill="hsl(' + h + ',40%,15%)"/>' +
        '<rect x="80" y="140" width="140" height="120" rx="12" fill="hsl(' + h + ',50%,25%)"/>' +
        '<text x="150" y="210" text-anchor="middle" fill="hsl(' + h + ',60%,50%)" font-size="14" font-family="sans-serif">Upload Image</text>' +
        '</svg>';
      return 'data:image/svg+xml,' + encodeURIComponent(svg);
    }

    /* Desktop vertical gallery */
    function buildGallery(sectionId, images, speedSetting) {
      var container = document.getElementById('gallery-' + sectionId);
      if (!container || !images.length) return;

      var BASE_SPEEDS = [40, 35, 45];
      var DIRECTIONS = ['scrollUp', 'scrollDown', 'scrollUp'];
      var NUM_COLS = 3;
      var colOrders = computeColumnOrders(images.length, NUM_COLS);

      for (var ci = 0; ci < NUM_COLS; ci++) {
        var colEl = document.createElement('div');
        colEl.className = 'gallery-col';
        var dur = (BASE_SPEEDS[ci] * 10 / speedSetting).toFixed(1) + 's';
        colEl.style.animation = DIRECTIONS[ci] + ' ' + dur + ' linear infinite';

        var order = colOrders[ci];
        for (var pass = 0; pass < 2; pass++) {
          for (var i = 0; i < order.length; i++) {
            var card = document.createElement('div');
            card.className = 'gallery-card';
            var img = document.createElement('img');
            var imgUrl = images[order[i]];
            img.src = imgUrl || placeholderSVG(order[i]);
            img.alt = 'Gallery image ' + (order[i] + 1);
            img.loading = 'lazy';
            card.appendChild(img);
            colEl.appendChild(card);
          }
        }
        container.appendChild(colEl);
      }
    }

    /* Mobile horizontal gallery */
    function buildMobileGallery(sectionId, images, speedSetting) {
      var container = document.getElementById('mobile-gallery-' + sectionId);
      if (!container || !images.length) return;

      var NUM_ROWS = 2;
      var BASE_SPEEDS = [30, 35];
      var DIRECTIONS = ['scrollLeft', 'scrollRight'];
      var halfCount = Math.floor(images.length / 2);

      for (var ri = 0; ri < NUM_ROWS; ri++) {
        var wrapper = document.createElement('div');
        wrapper.className = 'mobile-gallery-container';
        var rowEl = document.createElement('div');
        rowEl.className = 'mobile-gallery-row';
        var dur = (BASE_SPEEDS[ri] * 10 / speedSetting).toFixed(1) + 's';
        rowEl.style.animation = DIRECTIONS[ri] + ' ' + dur + ' linear infinite';

        for (var pass = 0; pass < 2; pass++) {
          for (var i = 0; i < images.length; i++) {
            var idx = (i + ri * halfCount) % images.length;
            var card = document.createElement('div');
            card.className = 'mobile-gallery-card';
            var img = document.createElement('img');
            var imgUrl = images[idx];
            img.src = imgUrl || placeholderSVG(idx);
            img.alt = 'Gallery image';
            img.loading = 'lazy';
            card.appendChild(img);
            rowEl.appendChild(card);
          }
        }
        wrapper.appendChild(rowEl);
        container.appendChild(wrapper);
      }
    }

    /* Rotating words */
    function initWordRotation(sectionId, words, intervalMs) {
      if (!words || words.length < 1) return;
      var el = document.getElementById('rotating-word-' + sectionId);
      if (!el) return;

      el.textContent = words[0].text;
      el.style.color = words[0].color;

      if (words.length < 2) return;

      var idx = 0;
      setInterval(function() {
        el.classList.add('fade-out');
        setTimeout(function() {
          idx = (idx + 1) % words.length;
          el.textContent = words[idx].text;
          el.style.color = words[idx].color;
          el.classList.remove('fade-out');
          el.classList.add('fade-in');
        }, 400);
      }, intervalMs);
    }

    /* Init on page load */
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.hero-section-root').forEach(initHeroBanner);
    });

    /* Theme Editor live reload */
    document.addEventListener('shopify:section:load', function(e) {
      initHeroBanner(e.target);
    });
  })();
{% endjavascript %}

