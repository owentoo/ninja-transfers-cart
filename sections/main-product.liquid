<script>
  var _isload = 0;
  var _ccalled = 0;
  function setVariantIMG() {
    setTimeout(function() {
      $(".product-variant__item input:checked").eq(0).trigger("click");
      if(_isload != 1) {
        console.log("_ccalled: ",_ccalled++);
        setVariantIMG();
      }
    },300)
  }

  $(function() {
    setTimeout(function() {
      /**  Move **/
      var _pricetable = $(".customTabelPopup__overlay").clone(true);
      $(".customTabelPopup__overlay").remove();
      $("body").append(_pricetable)
      /**  ./Move **/

      {% if section.settings.craft_product %}
        document.querySelectorAll('.lazy-image img').forEach(function(img) {
          if (img.parentNode.tagName.toLowerCase() === 'a') return;

          const galleryItem = img.closest('.product-gallery-item');
          if (!galleryItem) return;

          const mediaType = galleryItem.getAttribute('data-product-media-type');
          let a = document.createElement('a');

          if (mediaType === 'image') {
            const fullSrc = img.getAttribute('src').replace(/w=\d+/, 'w=1600');
            a.href = fullSrc;
            a.className = 'glightbox';
            a.setAttribute('data-gallery', 'product-gallery');
            if (img.getAttribute('alt')) {
              a.setAttribute('data-title', img.getAttribute('alt'));
            }
          } else if (mediaType === 'external_video' || mediaType === 'external_video-youtube') {
            const videoId = galleryItem.getAttribute('data-video-id');
            if (!videoId) return;

            // Use embed link so GLightbox handles it cleanly
            a.href = `https://www.youtube.com/embed/${videoId}?autoplay=1`;
            a.className = 'glightbox';
            a.setAttribute('data-gallery', 'product-gallery');
            a.setAttribute('data-type', 'video');
          } else {
            return; // skip unknown media types
          }

          img.parentNode.insertBefore(a, img);
          a.appendChild(img);
        });
      {% endif %}
    }, 50);

    {% if product.template_suffix contains "build-a-gang-sheet" %}
      if(location.search.indexOf("variant")) {
        setTimeout(function() {
          $(".product-variant__item input:checked").eq(0).trigger("click");
        },400)
        //setVariantIMG();
      }

      $(window).on("load",function() {
        _isload = 1;
        //setVariantIMG();
      })
    {% endif %}
  })
  .on(`click`, `.customTabelPopup__close`, function( e ) {
    try {
      e.stopImmediatePropagation();
      $( `.customTabelPopup__overlay` ).fadeOut();
      $( `.product.container.container--large` ).css( `z-index`, `unset` );
      $( `body` ).removeAttr( `style` );
    } catch ( err ) {
      console.log( `ERROR .customTabelPopup__close`, err.message );
    }
  })
</script>
