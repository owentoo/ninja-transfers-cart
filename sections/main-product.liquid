      $( `product-variants .product-variant__container[option]` ).addClass( `variantsLoaded` );
    })
    .on(`click`, `product-variants .product-variant__container .product-variant__item .product-variant__label, product-variants .product-variant__container .product-variant__item .product-variant__input`, function( e ) {
      try {
        filterAvailableVariantOptions();

      } catch ( err ) {
        console.log( `ERROR product-variants .product-variant__container .product-variant__item .product-variant__label`, err.message );
      }
    })
    ;

    function filterAvailableVariantOptions() {
      try {
        const selected = {
          size: $(`.product-variant__container[option="1"] .product-variant__input:checked`).val() || null,
          pack: $(`.product-variant__container[option="2"] .product-variant__input:checked`).val() || null,
          color: $(`.product-variant__container[option="3"] .product-variant__input:checked`).val() || null,
        };

        /* ===============================
          STEP 1: SIZE is the only base
        =============================== */
        let baseVariants = allVariants.filter(v =>
          v.available && (!selected.size || v.option1 === selected.size)
        );

        /* ===============================
          STEP 2: Allowed Packs & Colors
        =============================== */
        const allowed = {
          pack: new Set(),
          color: new Set(),
        };

        baseVariants.forEach(v => {
          if (v.option2) allowed.pack.add(v.option2);
          if (v.option3) allowed.color.add(v.option3);
        });

        /* ===============================
          STEP 3: Apply Pack visibility
        =============================== */
        const $packContainer = $(`.product-variant__container[option="2"]`);
        let validPackSelected = false;

        $packContainer.find('.product-variant__input').each(function () {
          const val = $(this).val();
          const $item = $(this).closest('.product-variant__item, label');

          if (!allowed.pack.has(val)) {
            $(this).prop('checked', false);
            $item.addClass('hidden');
          } else {
            $item.removeClass('hidden');
            if ($(this).is(':checked')) validPackSelected = true;
          }
        });

        if (!validPackSelected) {
          $packContainer
            .find('.product-variant__item:not(.hidden) .product-variant__input')
            .first()
            .prop('checked', true);
        }

        const activePack = $packContainer.find('.product-variant__input:checked').val();

        /* ===============================
          STEP 4: Filter colors by Size + Pack
        =============================== */
        let colorVariants = baseVariants;
        if (activePack) {
          colorVariants = colorVariants.filter(v => v.option2 === activePack);
        }

        const allowedColors = new Set();
        colorVariants.forEach(v => v.option3 && allowedColors.add(v.option3));

        /* ===============================
          STEP 5: Apply Color visibility
        =============================== */
        const $colorContainer = $(`.product-variant__container[option="3"]`);
        let validColorSelected = false;

        $colorContainer.find('.product-variant__input').each(function () {
          const val = $(this).val();
          const $item = $(this).closest('.product-variant__item, label');

          if (!allowedColors.has(val)) {
            $(this).prop('checked', false);
            $item.addClass('hidden');
          } else {
            $item.removeClass('hidden');
            if ($(this).is(':checked')) validColorSelected = true;
          }
        });

        if (!validColorSelected) {
          $colorContainer
            .find('.product-variant__item:not(.hidden) .product-variant__input')
            .first()
            .prop('checked', true);
        }
        if ( selected.color ) {
          $( `.product-variant__container[option="3"] + .product-variant__item-text-label` ).text( getCheckedValue(3) );
        }
      } catch ( err ) {
        console.log( `ERROR `, err.message );
      }
    }
    function getCheckedValue(index) {
      const $box = getOptionContainer(index);
      if (!$box) return null;
      return $box.find('input:checked').val() || null;
    }
    function getOptionContainer(index) {
      const $el = $(`.product-variant__container[option="${index}"]`);
      return $el.length ? $el : null;
    }
  </script>
  <style>
    .hidden {
      display: none;
    }
  </style>
{% endif %}

