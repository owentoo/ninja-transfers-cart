                                if ( field__.config.fileMimeTypes.includes( e.currentTarget.files[0].type ) ) {
                                  if ( $( `.loadingScreen__` ).length == 0 ) {
                                    $( `body` )
                                    .append( `
                                      <div class="loadingScreen__">
                                        <img src="${ loaderGif }">
