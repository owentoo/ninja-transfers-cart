                <script>
                  function updateSelectedVariantLabel() {
                    const labelContainer = document.querySelector('.selected-variant-label');
                    if (!labelContainer) return;
                
                    const checkedInput = document.querySelector('.product-variant__input:checked');
                    if (checkedInput) {
                      labelContainer.textContent = checkedInput.value;
                    }
                  }
                
                  // Initial update
                  updateSelectedVariantLabel();
                
                  // Update on change
                  document.addEventListener('change', function (e) {
                    if (e.target.matches('.product-variant__input')) {
                      updateSelectedVariantLabel();
                    }
                  });
