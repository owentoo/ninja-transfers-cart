            {% if block.settings.static_checkout %}
              <script>
                document.addEventListener('DOMContentLoaded', function () {
                  const checkoutBtn = document.querySelector('.custom-checkout-cta');
                
                  if (!checkoutBtn) return;
                
                  checkoutBtn.addEventListener('click', async function (e) {
                    e.preventDefault();
                    this.classList.add("working");
                    // Get selected variant ID
                    const variantInput = document.querySelector('[name="id"]');
                    const variantId = variantInput ? variantInput.value : null;
                
                    // Get quantity
                    const quantityInput = document.querySelector('input[name="quantity"]');
                    const quantity = quantityInput ? parseInt(quantityInput.value) || 1 : 1;
                
                    if (!variantId) {
                      alert('Please select a variant before checkout.');
                      return;
                    }
                
                    // Add to cart
                    try {
                      const properties = getLineItemProperties();
                      const payload = {
                        id: variantId,
                        quantity: quantity
                      };
                      if (Object.keys(properties).length > 0) {
                        payload.properties = properties;
                      }
                      {% comment %} await fetch('/cart/clear.js'); // Optional: clear existing cart {% endcomment %}
                      await fetch('/cart/add.js', {
                        method: 'POST',
                        headers: {
                          'Content-Type': 'application/json'
                        },
                        body: JSON.stringify(payload)
                      });
                
                      // Redirect to checkout
                      window.location.href = '/checkout';
                    } catch (err) {
                      console.error('Error adding to cart:', err);
                      alert('Something went wrong. Please try again.');
                    }
                  });
                });
                function getLineItemProperties() {
                  const properties = {};
                  document.querySelectorAll('#add-to-cart-{{ section.id }} [name^="properties["]').forEach(function (input) {
                    const nameMatch = input.name.match(/^properties\[(.+)\]$/);
                    if (nameMatch && input.value.trim() !== '') {
                      properties[nameMatch[1]] = input.value.trim();
                    }
                  });
                  return properties;
                }
