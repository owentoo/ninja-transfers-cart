                    "{{ option_key }}": {{ variant[option_key] | json | downcase }},
                  {%- endfor -%}
                  "meta_templateFiles": {{ templateFilesJson | json }},
                  "discount_p": {{ discount_p | json }},
                  "variant_hidden": {{ variant_hidden }}
                  {% if product.type == "crafts" %}
                  ,"craftfile": "{{ craftfile }}"
                  {% endif %}
                }
                {%- unless forloop.last -%}
                  ,
                {%- endunless -%}
              {% endfor %}
            {%- endcapture -%}
            <script>
              const allVariantsForTemplates = [{{ allVariantsForTemplates }}];
              
              function find_objectsByKeys(array, criteria, multiple = false) {
                try {
                  if (!Array.isArray(array)) {
                    throw new Error("First argument must be an array.");
                  }
                  if (typeof criteria !== "object" || criteria === null) {
                    throw new Error("Second argument must be an object with key-value pairs.");
                  }
                  // Filter the array based on multiple key-value criteria
                  const results = array.filter(item =>Object.entries(criteria).every(([key, value]) => item[key] === value));
                  // Return results based on the `multiple` flag
                  return multiple ? (results.length > 0 ? results : null) : results[0] || null;
                } catch (err) {
                  console.error(`ERROR find_objectsByKeys: ${err.message}`);
                  return null;
                }
              }

              function getVariantFromURL(c_vid) {
                const urlParams = new URLSearchParams(window.location.search);
                return urlParams.get('variant') || c_vid; // Returns the variant ID as a string or null
              }

              function v_showdiscount() {
                try {
                  let c_vid = "{{ product.selected_or_first_available_variant.id }}";
                  // Ensure allVariantsForTemplates is defined and not empty
                  if (typeof allVariantsForTemplates !== "undefined" && Array.isArray(allVariantsForTemplates)) {
                    // Fetch the selected variant ID from the form
                    c_vid = getVariantFromURL(c_vid);
                    if (c_vid) {
                      c_vid = parseInt(c_vid, 10); // Safely convert to a number
                    } else {
                      console.warn("No variant ID found.");
                      return;
                    }
                    $(".product-variant__item").removeClass("dtf-gang-sheet-discount");
                    const get_object = findObjectByKey(allVariantsForTemplates, "id", c_vid, false);
                    // Find the object by key
                    var optionList = find_objectsByKeys(allVariantsForTemplates, { option2: get_object.option2, variant_hidden: get_object.variant_hidden }, true);
                    var sel_list = $(document).find(`.product-variant__container[option="1"] input[type="radio"]`);
                    console.log(sel_list," :sel_list");
                    _select_gallery_img();
                    sel_list.each(function(i){
                      $(this).parents(".product-variant__item").addClass("dtf-gang-sheet-discount").find(".saving-info").text(optionList[i].discount_p);
                    })
                    if ( typeof get_object !== 'undefined' && get_object && typeof manageQuantities === 'function' && typeof customTabelManage === 'function' ) {
                      // manageQuantities( '', get_object );
                      customTabelManage( get_object.id );
                    }
                  } else {
                    console.warn("allVariantsForTemplates is undefined or not an array.");
                  }
                } catch (err) {
                  console.error(`ERROR _showdiscount: ${err.message}`);
                }
              }
              $(function(){
                getTemplateLink();
                v_showdiscount();
                $(document).on(`change click`, `.product-variant__container[option="1"] input[type="radio"]`,async function( e ) {
                  try {
                    e.stopImmediatePropagation();
                    await new Promise(resolve => setTimeout(resolve, 200));
                    getTemplateLink();
                    v_showdiscount();
                  } catch ( err ) {
                    //console.log( `ERROR product-variant__container[option="1"] input[type="radio"]`, err.message );
                  }
                })
              })

              function getTemplateLink() {
                try {
                  if ( typeof allVariantsForTemplates !== 'undefined' && allVariantsForTemplates ) {
                    let vid = $( `form[action="/cart/add"][data-type="add-to-cart-form"] [name="id"]` ).val();

                    if ( typeof vid !== 'undefined' && vid ) {
                      vid   = vid * 1;
                    } else {
                      return;
                    }
                    const getObject =   findObjectByKey( allVariantsForTemplates, 'id', vid );

                    if ( typeof getObject !== 'undefined' && getObject && typeof getObject.meta_templateFiles !== 'undefined' && getObject.meta_templateFiles ) {
                      const tempFilesEle  =   $( `.product-variant__item` ).length;
                      if ( tempFilesEle > 0 ) {
                        $( `.product-variant__item .product-form__input__wrapper-temp` ).remove();
                        $( `.product-variant__container[option="1"] .product-variant__item > input:checked+label` )
                          .after( `<div class="product-form__input__wrapper-temp">${ getObject.meta_templateFiles }</div>` );
                      }
                    }
                    if ( typeof getObject !== 'undefined' && getObject && typeof getObject.craftfile !== 'undefined' && getObject.craftfile ) {
                      console.log("getObject: ",getObject);
                      if($("#id_craftImage").length){
                        $("#id_craftImage").val(getObject.craftfile);
                      }
                    }
                  }
                } catch ( err ) {
                  //console.log( `ERROR getTemplateLink`, err.message );
                }
              }
            </script>

