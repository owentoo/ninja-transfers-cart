                                        {% elsif settings.matchingText_2 != blank and settings.matchingImg_2 != blank and settings.matchingText_2 == value %}
                                          <img src="{{ settings.matchingImg_2 | image_url: width: 60 }}">
                                        {% elsif settings.matchingText_3 != blank and settings.matchingImg_3 != blank and settings.matchingText_3 == value %}
                                          <img src="{{ settings.matchingImg_3 | image_url: width: 60 }}">
                                        {% elsif settings.matchingText_4 != blank and settings.matchingImg_4 != blank and settings.matchingText_4 == value %}
                                          <img src="{{ settings.matchingImg_4 | image_url: width: 60 }}">
                                        {% elsif settings.matchingText_5 != blank and settings.matchingImg_5 != blank and settings.matchingText_5 == value %}
                                          <img src="{{ settings.matchingImg_5 | image_url: width: 60 }}">
