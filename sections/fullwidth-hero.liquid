<!-- ── Dynamic styles (scoped to this section instance) ── -->
<style>
  #shopify-section-{{ section.id }} {
    overflow-x: hidden;
  }
  #shopify-section-{{ section.id }} .hero-fw {
    position: relative;
    min-height: {{ section.settings.section_max_height }}px;
    background: {{ section.settings.bg_color }};
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  /* Background image layer */
  #shopify-section-{{ section.id }} .hero-fw-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  #shopify-section-{{ section.id }} .hero-fw-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ section.settings.bg_image_position }};
    display: block;
  }
  /* Overlay for text legibility */
  #shopify-section-{{ section.id }} .hero-fw-overlay {
    position: absolute;
    inset: 0;
    background: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 1;
  }
  /* Content layer */
  #shopify-section-{{ section.id }} .hero-fw-content {
    position: relative;
    z-index: 2;
    max-width: {{ section.settings.content_max_width }}px;
    width: 100%;
    padding: {{ section.settings.padding_top_desktop }}px {{ section.settings.padding_right_desktop }}px {{ section.settings.padding_bottom_desktop }}px {{ section.settings.padding_left_desktop }}px;
  }
  #shopify-section-{{ section.id }} .hero-fw-inner {
    display: flex;
    align-items: center;
    justify-content: {{ section.settings.content_align_desktop }};
    min-height: {{ section.settings.section_max_height }}px;
  }
  #shopify-section-{{ section.id }} .hero-fw h1 {
    font-size: {{ section.settings.h1_size_desktop }}px;
    line-height: 1.1;
    color: {{ section.settings.heading_color }};
  }
  #shopify-section-{{ section.id }} .hero-fw .subtitle {
    font-size: {{ section.settings.subtitle_size_desktop }}px;
    line-height: 1.6;
    color: {{ section.settings.subtitle_color }};
    opacity: {{ section.settings.subtitle_opacity | divided_by: 100.0 }};
  }
  #shopify-section-{{ section.id }} .hero-fw .badge .badge-review-text {
    font-size: {{ section.settings.review_text_size_desktop }}px;
  }
  #shopify-section-{{ section.id }} .hero-fw .feature {
    font-size: {{ section.settings.feature_size_desktop }}px;
    line-height: 1.4;
    color: {{ section.settings.feature_color }};
    opacity: {{ section.settings.feature_opacity | divided_by: 100.0 }};
  }
  #shopify-section-{{ section.id }} .hero-fw .feature svg,
  #shopify-section-{{ section.id }} .hero-fw .feature .feature-custom-icon {
    width: {{ section.settings.icon_size_desktop }}px;
    height: {{ section.settings.icon_size_desktop }}px;
  }
  #shopify-section-{{ section.id }} .nav-pills-bar {
    margin-bottom: {{ section.settings.space_below_toggles_desktop }}px;
    justify-content: {{ section.settings.pills_align_desktop }};
  }
  #shopify-section-{{ section.id }} .nav-pills-track {
    background: {{ section.settings.pill_wrapper_bg }};
    padding: {{ section.settings.pill_wrapper_padding }}px;
    border-radius: {{ section.settings.pill_wrapper_radius }}px;
    gap: {{ section.settings.pill_gap }}px;
  }
  #shopify-section-{{ section.id }} .pill {
    font-size: {{ section.settings.pill_size_desktop }}px;
    padding: {{ section.settings.pill_vertical_padding }}px {{ section.settings.pill_horizontal_padding }}px;
    border-radius: {{ section.settings.pill_toggle_radius }}px;
  }
  #shopify-section-{{ section.id }} .pill-active {
    background: {{ section.settings.pill_selected_bg }};
    color: {{ section.settings.pill_selected_text }};
  }
  #shopify-section-{{ section.id }} .pill-inactive {
    color: {{ section.settings.pill_unselected_text }};
  }
  #shopify-section-{{ section.id }} .pill-inactive:hover {
    color: {{ section.settings.pill_hover_text }};
  }
  #shopify-section-{{ section.id }} .badge strong {
    color: {{ section.settings.badge_rating_color }};
  }
  #shopify-section-{{ section.id }} .badge .badge-review-text {
    color: {{ section.settings.badge_text_color }};
  }
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .hero-fw {
      min-height: {{ section.settings.section_height_mobile }}px;
    }
    #shopify-section-{{ section.id }} .hero-fw-inner {
      min-height: {{ section.settings.section_height_mobile }}px;
      justify-content: {{ section.settings.content_align_mobile }};
    }
    #shopify-section-{{ section.id }} .hero-fw-content {
      padding: {{ section.settings.padding_top_mobile }}px 20px {{ section.settings.padding_bottom_mobile }}px 20px;
    }
    #shopify-section-{{ section.id }} .hero-fw h1 {
      font-size: {{ section.settings.h1_size_mobile }}px;
      line-height: 1.15;
    }
    #shopify-section-{{ section.id }} .hero-fw .subtitle {
      font-size: {{ section.settings.subtitle_size_mobile }}px;
      line-height: 1.5;
    }
    #shopify-section-{{ section.id }} .hero-fw .badge .badge-review-text {
      font-size: {{ section.settings.review_text_size_mobile }}px;
    }
    #shopify-section-{{ section.id }} .hero-fw .feature {
      font-size: {{ section.settings.feature_size_mobile }}px;
      line-height: 1.4;
    }
    #shopify-section-{{ section.id }} .hero-fw .feature svg,
    #shopify-section-{{ section.id }} .hero-fw .feature .feature-custom-icon {
      width: {{ section.settings.icon_size_mobile }}px;
      height: {{ section.settings.icon_size_mobile }}px;
    }
    #shopify-section-{{ section.id }} .pill {
      font-size: {{ section.settings.pill_size_mobile }}px;
    }
    #shopify-section-{{ section.id }} .nav-pills-bar {
      margin-bottom: {{ section.settings.space_below_toggles_mobile }}px;
      justify-content: {{ section.settings.pills_align_mobile }};
    }
    #shopify-section-{{ section.id }} .hero-fw-bg .hero-fw-bg--desktop {
      display: none;
    }
    #shopify-section-{{ section.id }} .hero-fw-bg .hero-fw-bg--mobile {
      display: block;
    }
  }
  @media (min-width: 769px) {
    #shopify-section-{{ section.id }} .hero-fw-bg .hero-fw-bg--mobile {
      display: none;
    }
  }
</style>

<!-- ── Hero markup ── -->
<div class="hero-fw">
  <!-- Background image -->
  <div class="hero-fw-bg">
    {%- if section.settings.hero_image_url != blank -%}
      <img class="hero-fw-bg--desktop" src="{{ section.settings.hero_image_url }}" alt="Hero" loading="eager">
      <img class="hero-fw-bg--mobile" src="{{ section.settings.hero_image_url }}" alt="Hero" loading="eager">
    {%- elsif section.settings.hero_image != blank -%}
      {%- assign bg_img = section.settings.hero_image | image_url: width: 2000 -%}
      <img class="hero-fw-bg--desktop" src="{{ bg_img }}" alt="{{ section.settings.hero_image.alt | escape }}" loading="eager">
      {%- if section.settings.hero_image_mobile != blank -%}
        {%- assign bg_img_mobile = section.settings.hero_image_mobile | image_url: width: 800 -%}
        <img class="hero-fw-bg--mobile" src="{{ bg_img_mobile }}" alt="{{ section.settings.hero_image_mobile.alt | escape }}" loading="eager">
      {%- else -%}
        <img class="hero-fw-bg--mobile" src="{{ bg_img }}" alt="{{ section.settings.hero_image.alt | escape }}" loading="eager">
      {%- endif -%}
    {%- endif -%}
  </div>

  <!-- Overlay -->
  <div class="hero-fw-overlay"></div>

  <!-- Content -->
  <div class="hero-fw-inner">
    <div class="hero-fw-content">
      {%- assign has_pills = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'nav_pill' -%}
          {%- assign has_pills = true -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if has_pills -%}
        <div class="nav-pills-bar">
          <div class="nav-pills-track">
            {%- for block in section.blocks -%}
              {%- if block.type == 'nav_pill' -%}
                {%- if block.settings.is_active -%}
                  <span class="pill pill-active" {{ block.shopify_attributes }}>{{ block.settings.label }}</span>
                {%- else -%}
                  <a href="{{ block.settings.url }}" class="pill pill-inactive" {{ block.shopify_attributes }}>{{ block.settings.label }}</a>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}

      {%- if section.settings.badge_visible -%}
        <div class="badge">
          <span class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          <strong>{{ section.settings.badge_rating }}</strong> <span class="badge-review-text">{{ section.settings.badge_review_text }}</span>
        </div>
      {%- endif -%}

      <h1>
        {{ section.settings.heading_text }}<br>
        <span class="count">{{ section.settings.customer_count }}</span>
        {%- assign has_rotating_words = false -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'rotating_word' -%}
            {%- assign has_rotating_words = true -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}
        {%- if has_rotating_words %} <span class="rotating-wrapper">
            <span id="rotating-word-{{ section.id }}" class="rotating-word">
              {%- for block in section.blocks -%}
                {%- if block.type == 'rotating_word' -%}
                  {{- block.settings.word_text -}}
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}
            </span>
          </span>
        {%- endif -%}
      </h1>

      <p class="subtitle">{{ section.settings.subtitle_text }}</p>

      {%- assign has_features = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'feature' -%}
          {%- assign has_features = true -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if has_features -%}
        <div class="features">
          {%- for block in section.blocks -%}
            {%- if block.type == 'feature' -%}
              <div class="feature" {{ block.shopify_attributes }}>
                {%- if block.settings.custom_icon != blank -%}
                  {%- assign icon_url = block.settings.custom_icon | image_url: width: 40 -%}
                  <img class="feature-custom-icon" src="{{ icon_url }}" alt="" width="40" height="40" loading="lazy">
                {%- else -%}
                  {%- case block.settings.icon -%}
                    {%- when 'checkmark' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
                      </svg>
                    {%- when 'star' -%}
                      <svg viewBox="0 0 24 24" fill="currentColor">
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                      </svg>
                    {%- when 'shield' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                      </svg>
                    {%- when 'truck' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                        <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
                      </svg>
                  {%- endcase -%}
                {%- endif -%}
                {{ block.settings.feature_text }}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      <div class="buttons">
        {%- for block in section.blocks -%}
          {%- if block.type == 'button' -%}
            <a href="{{ block.settings.btn_url }}"
               class="btn btn-{{ block.settings.btn_style }}{% if block.settings.mobile_only %} btn-mobile-only{% endif %}"
               style="--btn-bg: {{ block.settings.btn_bg_color }}; --btn-text: {{ block.settings.btn_text_color }}; --btn-border: {{ block.settings.btn_border_color }};"
               {{ block.shopify_attributes }}>
              {{- block.settings.btn_text -}}
              <svg class="btn-arrow" width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 10h10"/><path d="M11 6l4 4-4 4"/></svg>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

<!-- ── Data bridge for rotating words ── -->
<script type="application/json" id="hero-data-{{ section.id }}">
  {
    "sectionId": {{ section.id | json }},
    "wordSpeed": {{ section.settings.word_rotation_speed }},
    "words": [
      {%- assign word_comma = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'rotating_word' -%}
          {%- if word_comma -%},{%- endif -%}
          {%- assign word_comma = true -%}
          { "text": {{ block.settings.word_text | json }}, "color": {{ block.settings.word_color | json }} }
        {%- endif -%}
      {%- endfor -%}
    ]
  }
</script>

<!-- ── Static CSS ── -->
{% stylesheet %}
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

  .hero-section-root {
    overflow-x: hidden;
  }

  .hero-fw {
    position: relative;
    font-family: 'Inter', sans-serif;
    color: #fff;
  }

  /* Background image — fills entire section */
  .hero-fw-bg {
    position: absolute;
    inset: 0;
  }

  .hero-fw-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-fw-overlay {
    position: absolute;
    inset: 0;
  }

  /* Content wrapper — centers the content block */
  .hero-fw-inner {
    position: relative;
    z-index: 2;
    display: flex;
    width: 100%;
  }

  .hero-fw-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /* Nav pills */
  .hero-fw .nav-pills-bar {
    display: flex;
  }

  .hero-fw .nav-pills-track {
    display: inline-flex;
  }

  .hero-fw .pill {
    display: inline-block;
    font-weight: 600;
    font-family: 'Inter', sans-serif;
    text-decoration: none;
    transition: color 0.25s;
    white-space: nowrap;
    cursor: pointer;
  }

  .hero-fw .pill-active {
    cursor: default;
  }

  .hero-fw .pill-inactive {
    background: transparent;
  }

  /* Badge */
  .hero-fw .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 0;
    font-size: 13px;
    color: #9ca3af;
    margin-bottom: 14px;
    width: fit-content;
  }

  .hero-fw .badge .stars {
    color: #fbbf24;
    font-size: 15px;
    letter-spacing: 2px;
  }

  .hero-fw .badge strong {
    font-weight: 700;
  }

  /* Heading */
  .hero-fw h1 {
    font-weight: 800;
    margin-top: 0;
    margin-bottom: 20px;
    letter-spacing: -1.5px;
  }

  .hero-fw h1 .count {
    color: inherit;
  }

  .hero-fw .rotating-wrapper {
    display: inline-block;
    width: 320px;
    text-align: left;
  }

  .hero-fw h1 .rotating-word {
    display: inline-block;
    transition: opacity 0.4s, transform 0.4s;
    white-space: nowrap;
  }

  .hero-fw h1 .rotating-word.fade-out {
    opacity: 0;
    transform: translateY(10px);
  }

  .hero-fw h1 .rotating-word.fade-in {
    opacity: 1;
    transform: translateY(0);
  }

  /* Subtitle */
  .hero-fw .subtitle {
    line-height: 1.6;
    margin-bottom: 28px;
    max-width: 560px;
  }

  /* Features */
  .hero-fw .features {
    display: flex;
    gap: 20px;
    margin-bottom: 36px;
    flex-wrap: nowrap;
    white-space: nowrap;
  }

  .hero-fw .feature {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .hero-fw .feature svg {
    width: 20px;
    height: 20px;
    color: #22c55e;
    flex-shrink: 0;
  }

  .hero-fw .feature .feature-custom-icon {
    width: 20px;
    height: 20px;
    object-fit: contain;
    flex-shrink: 0;
  }

  /* Buttons */
  .hero-fw .buttons {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .hero-fw .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    border-radius: 12px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s;
    cursor: pointer;
    border: none;
    font-family: 'Inter', sans-serif;
    white-space: nowrap;
  }

  .hero-fw .btn-primary {
    background: var(--btn-bg);
    color: var(--btn-text);
    box-shadow: 0 4px 20px color-mix(in srgb, var(--btn-bg) 40%, transparent);
  }

  .hero-fw .btn-primary:hover {
    box-shadow: 0 6px 30px color-mix(in srgb, var(--btn-bg) 50%, transparent);
    transform: translateY(-2px);
  }

  .hero-fw .btn-secondary {
    background: color-mix(in srgb, var(--btn-bg) 12%, transparent);
    color: var(--btn-text);
    border: 1px solid color-mix(in srgb, var(--btn-border) 15%, transparent);
  }

  .hero-fw .btn-secondary:hover {
    background: color-mix(in srgb, var(--btn-bg) 20%, transparent);
    transform: translateY(-2px);
  }

  .hero-fw .btn-outline {
    background: transparent;
    color: var(--btn-text);
    border: 2px solid color-mix(in srgb, var(--btn-border) 35%, transparent);
  }

  .hero-fw .btn-outline:hover {
    border-color: color-mix(in srgb, var(--btn-border) 70%, transparent);
    transform: translateY(-2px);
  }

  .hero-fw .btn-text {
    background: transparent;
    color: var(--btn-text);
    padding-left: 4px;
    padding-right: 4px;
  }

  .hero-fw .btn-text:hover {
    opacity: 0.7;
  }

  .hero-fw .btn-glass {
    background: color-mix(in srgb, var(--btn-bg) 8%, transparent);
    color: var(--btn-text);
    border: 1px solid color-mix(in srgb, var(--btn-border) 10%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .hero-fw .btn-glass:hover {
    background: color-mix(in srgb, var(--btn-bg) 15%, transparent);
    transform: translateY(-2px);
  }

  .hero-fw .btn-arrow {
    width: 18px !important;
    height: 18px !important;
    min-width: 18px;
    min-height: 18px;
    flex-shrink: 0;
    transition: transform 0.3s;
  }

  .hero-fw .btn:hover .btn-arrow {
    transform: translateX(3px);
  }

  .hero-fw .btn-mobile-only {
    display: none;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .hero-fw .btn-mobile-only {
      display: inline-flex;
    }

    .hero-fw h1 {
      white-space: normal;
    }

    .hero-fw .rotating-wrapper {
      width: auto;
    }

    .hero-fw .features {
      flex-direction: column;
      white-space: normal;
      gap: 12px;
    }

    .hero-fw .buttons {
      flex-direction: column;
    }

    .hero-fw .btn {
      justify-content: center;
    }
  }
{% endstylesheet %}

<!-- ── JavaScript ── -->
{% javascript %}
  (function() {
    function initHeroBanner(sectionEl) {
      var sectionId = sectionEl.id.replace('shopify-section-', '');
      var dataEl = document.getElementById('hero-data-' + sectionId);
      if (!dataEl) return;

      var data = JSON.parse(dataEl.textContent);
      var words = data.words || [];
      var wordSpeed = data.wordSpeed || 1500;

      if (!words || words.length < 1) return;
      var el = document.getElementById('rotating-word-' + sectionId);
      if (!el) return;

      el.textContent = words[0].text;
      el.style.color = words[0].color;

      if (words.length < 2) return;

      var idx = 0;
      setInterval(function() {
        el.classList.add('fade-out');
        setTimeout(function() {
          idx = (idx + 1) % words.length;
          el.textContent = words[idx].text;
          el.style.color = words[idx].color;
          el.classList.remove('fade-out');
          el.classList.add('fade-in');
        }, 400);
      }, wordSpeed);
    }

    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.hero-section-root').forEach(initHeroBanner);
    });

    document.addEventListener('shopify:section:load', function(e) {
      initHeroBanner(e.target);
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Fullwidth Image Hero",
  "tag": "section",
  "class": "hero-section-root",
  "max_blocks": 50,
  "settings": [
    {
      "type": "header",
      "content": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Background image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "hero_image_mobile",
      "label": "Background image (mobile)",
      "info": "Optional — falls back to desktop image"
    },
    {
      "type": "url",
      "id": "hero_image_url",
      "label": "Background image URL override",
      "info": "Direct URL to hero image — overrides the image picker above if set"
    },
    {
      "type": "select",
      "id": "bg_image_position",
      "label": "Image focal point",
      "default": "center center",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "center top", "label": "Top" },
        { "value": "center bottom", "label": "Bottom" },
        { "value": "left center", "label": "Left" },
        { "value": "right center", "label": "Right" },
        { "value": "left top", "label": "Top Left" },
        { "value": "right top", "label": "Top Right" },
        { "value": "left bottom", "label": "Bottom Left" },
        { "value": "right bottom", "label": "Bottom Right" }
      ]
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 40,
