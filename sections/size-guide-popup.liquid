          "type": "text",
          "id": "width_1",
          "label": "Suggested max width 1",
          "default": "8 inches"
        },
        {
          "type": "text",
          "id": "height_1",
          "label": "Suggested max height 1",
          "default": "8 inches"
        },
        {
          "type": "text",
          "id": "showAt_1",
          "label": "Shown At 1",
          "default": "8 x 8 inches"
        },
        {
          "type": "image_picker",
          "id": "img_1",
          "label": "Image 1",
          "info": "Upload Square Image"
        },
        {
          "type": "text",
          "id": "itemName_2",
          "label": "Item Name 2",
          "default": "Hat (Front)"
        },
        {
          "type": "text",
          "id": "width_2",
          "label": "Suggested max width 2",
          "default": "8 inches"
        },
        {
          "type": "text",
          "id": "height_2",
          "label": "Suggested max height 2",
          "default": "8 inches"
        },
        {
          "type": "text",
          "id": "showAt_2",
          "label": "Shown At 2",
          "default": "8 x 8 inches"
        },
        {
          "type": "image_picker",
          "id": "img_2",
          "label": "Image 2",
          "info": "Upload Square Image"
        },
        {
          "type": "text",
          "id": "itemName_3",
          "label": "Item Name 3",
          "default": "Hat (Front)"
        },
        {
          "type": "text",
          "id": "width_3",
          "label": "Suggested max width 3",
          "default": "8 inches"
        },
        {
          "type": "text",
          "id": "height_3",
          "label": "Suggested max height 3",
          "default": "8 inches"
        },
        {
          "type": "text",
          "id": "showAt_3",
          "label": "Shown At 3",
          "default": "8 x 8 inches"
        },
        {
          "type": "image_picker",
          "id": "img_3",
