    "custom_liquid_aib6bY": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "t:sections.refactor_words.custom_code.name",
      "settings": {
        "custom_liquid": "{% comment %}\n  ScrollText (Custom Liquid SAFE)\n  - Prevents skipping: 1 scroll step = 1 phrase\n  - Height: max(60vh, 800px)\n  Edit:\n  - left_text\n  - phrases_list (use | to separate)\n{% endcomment %}\n\n{% assign left_text = \"Trusted By\" %}\n{% assign phrases_list = \"Crafters|Hustlers|Makers|Brands\" %}\n{% assign phrases = phrases_list | split: \"|\" %}\n\n{% assign scrolltext_id = \"scrolltext-custom\" %}\n\n<style>\n  .{{ scrolltext_id }}{\n    /* Fallback */\n    min-height: 800px;\n    height: 800px;\n\n    /* Modern: 60vh but never shorter than 800px */\n    min-height: max(60vh, 800px);\n    height: max(60vh, 800px);\n\n    display:flex;\n    align-items:center;\n    gap:32px;\n    padding:112px 64px;\n  }\n\n  @media (max-width:1024px){\n    .{{ scrolltext_id }}{\n      flex-direction:column;\n      align-items:flex-start;\n      gap:24px;\n      padding:64px 32px;\n    }\n  }\n\n  .{{ scrolltext_id }}__left h1{\n    margin:0;\n    font-size:42px;     /* desktop */\n    font-weight:900;\n    line-height:1.1;    /* line height updated */\n    color:#111;\n    white-space:nowrap;\n  }\n\n  /* tablet */\n  @media (max-width:1024px){\n    .{{ scrolltext_id }}__left h1{\n      font-size:24px;\n      line-height:1.15;\n      white-space:normal;\n    }\n  }\n\n  /* mobile */\n  @media (max-width:640px){\n    .{{ scrolltext_id }}__left h1{\n      font-size:18px;\n      line-height:1.2;\n    }\n  }\n\n  .{{ scrolltext_id }}__right{\n    flex:1;\n    position:relative;\n\n    /* Match section height */\n    min-height: 800px;\n    height: 800px;\n    min-height: max(60vh, 800px);\n    height: max(60vh, 800px);\n\n    overflow:hidden;\n  }\n\n  /* Optional mobile behavior: slightly shorter phrase window.\n     If you want STRICT max(60vh, 800px) always, delete this rule. */\n  @media (max-width:1024px){\n    .{{ scrolltext_id }}__right{\n      height:80vh;\n      min-height:520px;\n    }\n  }\n\n  .{{ scrolltext_id }}__phrase{\n    position:absolute;\n    left:0;\n    top:50%;\n    transform:translateY(-50%);\n    font-size:42px;     /* desktop */\n    font-weight:900;\n    line-height:1.1;    /* line height updated */\n    white-space:nowrap;\n    transition: transform 500ms ease-in-out, opacity 500ms ease-in-out, color 500ms ease-in-out;\n    will-change:transform;\n  }\n\n  .{{ scrolltext_id }}__phrase.is-active{\n    color:#111;\n    opacity:1;\n  }\n  .{{ scrolltext_id }}__phrase.is-inactive{\n    color:#C7CBD1;\n    opacity:.6;\n  }\n\n  /* tablet */\n  @media (max-width:1024px){\n    .{{ scrolltext_id }}__phrase{\n      font-size:24px;\n      line-height:1.15;\n    }\n  }\n\n  /* mobile */\n  @media (max-width:640px){\n    .{{ scrolltext_id }}__phrase{\n      font-size:18px;\n      line-height:1.2;\n    }\n  }\n\n  .{{ scrolltext_id }}__fadeTop,\n  .{{ scrolltext_id }}__fadeBottom{\n    position:absolute;\n    left:0; right:0;\n    pointer-events:none;\n    z-index:10;\n  }\n  .{{ scrolltext_id }}__fadeTop{\n    top:0;\n    height:160px;\n    background:linear-gradient(to bottom,#fff 0%,rgba(255,255,255,.8) 40%,rgba(255,255,255,0) 100%);\n  }\n  .{{ scrolltext_id }}__fadeBottom{\n    bottom:0;\n    height:160px;\n    background:linear-gradient(to top,#fff 0%,rgba(255,255,255,.8) 40%,rgba(255,255,255,0) 100%);\n  }\n\n  @media (max-width:1024px){\n    .{{ scrolltext_id }}__fadeTop,\n    .{{ scrolltext_id }}__fadeBottom{ height:128px; }\n  }\n</style>\n\n<div class=\"{{ scrolltext_id }}\" data-scrolltext-root>\n  <div class=\"{{ scrolltext_id }}__left\">\n    <h1>{{ left_text | escape }}</h1>\n  </div>\n\n  <div class=\"{{ scrolltext_id }}__right\" data-scrolltext-viewport>\n    {% for phrase in phrases %}\n      <div\n        class=\"{{ scrolltext_id }}__phrase {% if forloop.first %}is-active{% else %}is-inactive{% endif %}\"\n        data-scrolltext-phrase\n        data-index=\"{{ forloop.index0 }}\"\n      >\n        {{ phrase | strip | escape }}\n      </div>\n    {% endfor %}\n\n    <div class=\"{{ scrolltext_id }}__fadeTop\"></div>\n    <div class=\"{{ scrolltext_id }}__fadeBottom\"></div>\n  </div>\n</div>\n\n<script>\n(function(){\n  function init(){\n    var root = document.querySelector('[data-scrolltext-root].{{ scrolltext_id }}');\n    if(!root) return;\n\n    var phrases = Array.prototype.slice.call(root.querySelectorAll('[data-scrolltext-phrase]'));\n    if(!phrases.length) return;\n\n    var activeIndex = 0;\n    var substantiallyVisible = false;\n\n    // Prevent skipping: 1 scroll = 1 step\n    var isStepping = false;\n    var STEP_LOCK_MS = 300;      // matches 500ms transition\n    var lastStepAt = 0;\n    var MIN_STEP_GAP_MS = 100;   // helps trackpads not spam steps\n\n    function clamp(n,min,max){ return Math.max(min, Math.min(max, n)); }\n    function spacing(){ return (window.innerWidth < 1024) ? 60 : 80; }\n\n    function render(){\n      var sp = spacing();\n      phrases.forEach(function(el,i){\n        var offset = (i - activeIndex) * sp;\n        el.style.transform = 'translateY(calc(-50% + ' + offset + 'px))';\n\n        if(i === activeIndex){\n          el.classList.add('is-active'); el.classList.remove('is-inactive');\n        } else {\n          el.classList.add('is-inactive'); el.classList.remove('is-active');\n        }\n      });\n    }\n\n    render();\n    window.addEventListener('resize', render);\n\n    // 80% visibility threshold\n    var observer = new IntersectionObserver(function(entries){\n      entries.forEach(function(entry){\n        substantiallyVisible = entry.isIntersecting && entry.intersectionRatio >= 0.8;\n      });\n    }, { threshold: [0, 0.5, 0.8, 1] });\n    observer.observe(root);\n\n    function step(direction){\n      var now = Date.now();\n      if (isStepping) return \"locked\";\n      if (now - lastStepAt < MIN_STEP_GAP_MS) return \"cooldown\";\n\n      var maxIndex = phrases.length - 1;\n      var nextIndex = clamp(activeIndex + direction, 0, maxIndex);\n\n      // If at boundary, do not lock page scroll\n      if (nextIndex === activeIndex) return \"at-boundary\";\n\n      isStepping = true;\n      lastStepAt = now;\n\n      activeIndex = nextIndex;\n      render();\n\n      window.setTimeout(function(){\n        isStepping = false;\n      }, STEP_LOCK_MS);\n\n      return \"stepped\";\n    }\n\n    function onWheel(e){\n      if(!substantiallyVisible) return;\n\n      // Use direction only (ignore magnitude)\n      var dir = e.deltaY > 0 ? 1 : -1;\n\n      var result = step(dir);\n\n      // If we stepped OR we are locked mid-animation, prevent page scroll\n      if (result === \"stepped\" || result === \"locked\" || result === \"cooldown\") {\n        e.preventDefault();\n        return;\n      }\n\n      // At boundary: allow normal page scroll\n    }\n\n    window.addEventListener('wheel', onWheel, { passive:false });\n  }\n\n  if(document.readyState === 'loading'){\n    document.addEventListener('DOMContentLoaded', init);\n  } else {\n    init();\n  }\n})();\n</script>",
        "full_width": false,
        "remove_margin": false
      }
    },
