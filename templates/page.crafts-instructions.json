    "pressing_instruction_nhPGJw": {
      "type": "pressing-instruction",
      "blocks": {
        "item_UpeAe9": {
          "type": "item",
          "settings": {
            "title": "Transfer Not Adhering Properly",
            "title_font": "19",
            "title_color": "#000000",
            "subline": "If your transfer isn't sticking to the fabric properly:",
            "subline_font": "16",
            "subline_color": "#000000",
            "content": "<ul><li>Lay it back down and press again with added pressure and heat (+15°F).</li><li>If that doesn't work, increase temperature by increments of 15°F until it transfers correctly.</li></ul><p></p><p><strong>Remember:</strong> Repeated pressing won't damage the transfer.</p>",
            "content_font": "16",
            "content_color": "#000000"
          }
        },
        "item_hzEfxd": {
          "type": "item",
          "settings": {
            "title": "Design Cracking/Peeling After Washing",
            "title_font": "19",
            "title_color": "#000000",
            "subline": "If your design cracks or peels after washing:",
            "subline_font": "16",
            "subline_color": "#000000",
            "content": "<ul><li>Always turn garments inside-out before washing</li><li>Wash in cold water on gentle cycle</li><li>Avoid bleach and harsh detergents</li><li>Air dry or tumble dry on low heat</li></ul>",
            "content_font": "16",
            "content_color": "#000000"
          }
        },
        "item_zXqEk6": {
          "type": "item",
          "settings": {
            "title": "Transfer Shifting During Application",
            "title_font": "19",
            "title_color": "#000000",
            "subline": "If your transfer moves during application:",
            "subline_font": "16",
            "subline_color": "#000000",
            "content": "<ul><li>Use <a href=\"/products/thermal-heat-tape-1-roll\" title=\"Thermal Heat Tape\">Thermal Heat Tape</a> to secure the transfer</li><li>Close the press gently to avoid air movement</li><li>Pre-press the garment to create a flat surface</li><li>Ensure your work surface is stable</li><li>Consider using a placement guide or our <a href=\"/products/dtf-alignment-ruler-set\" title=\"DTF Alignment Ruler Set\">DTF Alignment Ruler Set</a></li></ul>",
            "content_font": "16",
            "content_color": "#000000"
          }
        }
      },
      "block_order": [
        "item_UpeAe9",
        "item_hzEfxd",
        "item_zXqEk6"
      ],
