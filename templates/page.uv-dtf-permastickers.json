    "bee277e8-e550-4a84-8c7c-d01760d8e205": {
      "type": "content-toggles",
      "blocks": {
        "template--15006313349203__bee277e8-e550-4a84-8c7c-d01760d8e205-text-1": {
          "type": "text",
          "settings": {
            "title": "Do I need any special equipment?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>No, while we do recommend using our squeegee any piece of rigid plastic such as a credit card will do.</p>"
          }
        },
        "2dc3f044-cfd6-483c-824f-3c528036c5bb": {
          "type": "text",
          "settings": {
            "title": "What can I apply my PermaSticker™ to?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>You can apply your PermaSticker™ to just about any smooth hard surface. Apply them to glass, plastics, metals, glass, wood, and more.</p>"
          }
        },
        "81b845f8-54fb-4c82-a286-9bce05b14dd6": {
          "type": "text",
          "settings": {
            "title": "What kind of finish does a PermaSticker™ have?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>Every PermaSticker™ has a durable layer of varnish added to every print to give it a permanent & waterproof glossy finish.</p>"
          }
        },
        "a100f3af-1452-4ace-8390-cbfb53d076b8": {
          "type": "text",
          "settings": {
            "title": "How long do UV DTF PermaStickers™ last?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>PermaStickers™<em> are extremely durable, color fast, chip & weather resistant stickers/decals, but they can still wear down or lose adhesion depending on the conditions & circumstances.For that reason, we can’t make any warranties or guarantees and should not be used for mission-critical applications or equipment.</em></p>"
          }
        },
        "41e0d777-0a85-496d-a6dc-ff1f72eabcfd": {
          "type": "text",
          "settings": {
            "title": "Whats the difference between \"By Size\" and \"Gang Sheet\"",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>\"By Size\" is a one single image on the transfer size you select, these can be individually cut or left in a roll. A \"Gang Sheet\" is the grouping of multiple images that are always left in a roll.</p>"
          }
        },
        "a41cc454-e585-4d15-a904-176affc46505": {
          "type": "text",
          "settings": {
            "title": "What file format should my artwork be?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>Vector art is always preferred, raster art should be at least 300 dpi. Preferred file types: .AI, .PDF, .EPS</p>"
          }
        },
        "38649e65-441b-4d92-9eac-2aeb9c15b1c0": {
          "type": "text",
          "settings": {
            "title": "What are your shipping times?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>All orders ship within 24 -48 hours. We offer expedited shipping options at checkout.</p>"
          }
        },
        "babe439f-b8b5-4f2f-958b-d847a06ae6a2": {
          "type": "text",
          "settings": {
            "title": "What is your refund policy?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>We stand behind our work so If you have any issues with your transfers at all <a href=\"https://ninjatransfers.com/pages/contact\" title=\"Contact Us | Ninja Transfers\">Contact Us </a>and we'll be sure to make sure we solve whatever issue you might have.</p>"
          }
        }
      },
