    "custom_liquid_tbjmkm": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "t:sections.refactor_words.custom_code.name",
      "settings": {
        "custom_liquid": "<div style=\"width:100%; text-align:center; margin:0 0 28px 0; max-width:900px; margin-left:auto; margin-right:auto;\">\n  \n  <h2 style=\"margin:0 0 12px 0; font-size:32px; line-height:1.2; font-weight:700; color:#111;\">\n    Why Most Print Shops Switch to the<br>Ninja Silicone Garment Protector\n  </h2>\n\n  <p style=\"margin:0; font-size:16px; line-height:1.6; color:#555;\">\n    DTF spray and pressing sheets work — but they slow down production and add unnecessary cost over time. The Ninja Silicone Cover stays attached to your press, improves transfer feel, and lasts for thousands of presses.\n  </p>\n\n</div>",
        "full_width": false,
        "remove_margin": false
      }
    },
    "custom_liquid_UfdY4i": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "t:sections.refactor_words.custom_code.name",
      "settings": {
        "custom_liquid": "<style>\n.nt-compare-section {\n  width: 100%;\n  margin: 40px 0;\n  font-family: inherit;\n}\n\n.nt-compare-table {\n  width: 100%;\n  border-collapse: collapse;\n  border-radius: 14px;\n  overflow: hidden;\n  box-shadow: 0 6px 20px rgba(0,0,0,0.06);\n}\n\n.nt-compare-table thead th {\n  background: #2d2d2d;\n  color: #fff;\n  padding: 22px 20px;\n  text-align: left;\n  font-size: 16px;\n  font-weight: 600;\n}\n\n.nt-compare-table td {\n  padding: 18px 20px;\n  border-bottom: 1px solid #ececec;\n  font-size: 15px;\n  vertical-align: top;\n}\n\n.nt-compare-table tr:last-child td {\n  border-bottom: none;\n}\n\n.nt-row {\n  display: flex;\n  align-items: flex-start;\n  gap: 10px;\n}\n\n.nt-icon {\n  width: 18px;\n  flex-shrink: 0;\n  font-weight: 700;\n}\n\n.nt-check {\n  color: #16a34a;\n}\n\n.nt-x {\n  color: #dc2626;\n}\n\n.nt-compare-table tbody tr:hover {\n  background: #fafafa;\n}\n\n@media (max-width: 768px) {\n  .nt-compare-scroll {\n    overflow-x: auto;\n    -webkit-overflow-scrolling: touch;\n  }\n\n  .nt-compare-table {\n    min-width: 640px;\n  }\n}\n</style>\n\n<div class=\"nt-compare-section\">\n<div class=\"nt-compare-scroll\">\n\n<table class=\"nt-compare-table\">\n\n<thead>\n<tr>\n<th>Silicone Press Cover</th>\n<th>DTF Chemical Spray</th>\n<th>DTF Pressing Sheet</th>\n</tr>\n</thead>\n\n<tbody>\n\n<tr>\n<td>\n<div class=\"nt-row\">\n<span class=\"nt-icon nt-check\">✔</span>\n<span>Lasts 10,000+ presses and stays mounted to your heat press</span>\n</div>\n</td>\n\n<td>\n<div class=\"nt-row\">\n<span class=\"nt-icon nt-x\">✕</span>\n<span>One bottle lasts about 125–175 presses</span>\n</div>\n</td>\n\n<td>\n<div class=\"nt-row\">\n<span class=\"nt-icon nt-x\">✕</span>\n<span>Wears out after roughly 350–500 presses</span>\n</div>\n</td>\n</tr>\n\n<tr>\n<td>\n<div class=\"nt-row\">\n<span class=\"nt-icon nt-check\">✔</span>\n<span>Magnet-mounted and always stays on your press</span>\n</div>\n</td>\n\n<td>\n<div class=\"nt-row\"