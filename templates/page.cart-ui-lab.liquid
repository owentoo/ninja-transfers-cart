    </div>
  </div>

  <div class="lab-divider"></div>

  {%- comment -%}═══════════════════════════════════════════
    SECTION 4: State Examples
  ═══════════════════════════════════════════{%- endcomment -%}

  <div class="lab-section">
    <div class="lab-section-title">States: Confirm Delete / Toast / Loading</div>

    <!-- Card with confirm delete panel visible -->
    <div class="design-card dc-card-enter">
      <div class="dc-card-header">
        <div class="dc-card-thumb">
          <img src="https://placehold.co/128x128/f1f5f9/64748b?text=Delete" alt="">
        </div>
        <div class="dc-card-info">
          <span class="dc-card-type">CUSTOM TRANSFERS</span>
          <span class="dc-card-title">delete-me-test.png</span>
          <span class="dc-card-badge">Standard / Vivid</span>
        </div>
        <div class="dc-price-block">
          <span class="dc-price-now">$5.19</span>
          <span class="dc-price-meta">1 size · 1 pcs</span>
        </div>
      </div>
      <!-- Confirm delete panel (visible for demo) -->
      <div class="dc-confirm-delete" style="display:flex;">
        <span>Remove this design and all sizes?</span>
        <div class="dc-confirm-btns">
          <button type="button" class="dc-card-btn default" data-action="hide-confirm-delete">Keep</button>
          <button type="button" class="dc-card-btn danger" data-action="remove-design">Remove</button>
        </div>
      </div>
    </div>

    <!-- Toast example -->
    <div style="position:relative; height:60px; margin-top:16px;">
      <div class="dc-toast" style="opacity:1; transform:translateY(0);">
        Design removed · <button type="button" style="background:none;border:none;color:#7c3aed;font-weight:600;cursor:pointer;text-decoration:underline;font-size:inherit;">Undo</button>
      </div>
    </div>
  </div>
</div>

<script>
document.querySelector('.cart-ui-lab')?.addEventListener('click', function(e) {
  const btn = e.target.closest('[data-action]');
  if (!btn) return;
  const action = btn.dataset.action;
  const card = btn.closest('.design-card');

  switch(action) {
    case 'toggle-add-size': {
      const form = card?.querySelector('.dc-add-form');
      const trigger = card?.querySelector('.dc-add-trigger');
      if (form) {
        const showing = form.style.display !== 'none';
        form.style.display = showing ? 'none' : 'block';
        if (trigger) trigger.style.display = showing ? 'block' : 'none';
        btn.textContent = showing ? '+ Add a size' : '− Add a size';
      }
      break;
    }
    case 'cancel-add-size': {
      const form = card?.querySelector('.dc-add-form');
      const trigger = card?.querySelector('.dc-add-trigger');
      if (form) form.style.display = 'none';
      if (trigger) trigger.style.display = 'block';
      break;
    }
    case 'toggle-edit-sizes': {
      const normalRows = card?.querySelector('[data-normal-rows]');
      const editRows = card?.querySelector('[data-edit-rows]');
      const editBar = card?.querySelector('[data-edit-bar]');
      const addWrap = card?.querySelector('.dc-add-trigger');
      if (normalRows && editRows) {
        const isEditing = normalRows.style.display === 'none';
        normalRows.style.display = isEditing ? '' : 'none';
        editRows.style.display = isEditing ? 'none' : '';
        if (editBar) editBar.style.display = isEditing ? 'none' : 'flex';
        if (addWrap) addWrap.style.display = isEditing ? '' : 'none';
        btn.textContent = isEditing ? 'Edit sizes' : 'Editing...';
        btn.classList.toggle('active', !isEditing);
      }
      break;
    }
    case 'cancel-edit':
    case 'save-edit': {
      const normalRows = card?.querySelector('[data-normal-rows]');
      const editRows = card?.querySelector('[data-edit-rows]');
      const editBar = card?.querySelector('[data-edit-bar]');
      const addWrap = card?.querySelector('.dc-add-trigger');
      const editBtn = card?.querySelector('[data-action="toggle-edit-sizes"]');
      if (normalRows) normalRows.style.display = '';
      if (editRows) editRows.style.display = 'none';
      if (editBar) editBar.style.display = 'none';
      if (addWrap) addWrap.style.display = '';
      if (editBtn) { editBtn.textContent = 'Edit sizes'; editBtn.classList.remove('active'); }
      if (action === 'save-edit') showToast('Changes saved');
      break;
    }
    case 'show-confirm-delete':
    case 'remove-btn': {
      const panel = card?.querySelector('.dc-confirm-delete');
      if (panel) panel.style.display = 'flex';
      break;
    }
    case 'hide-confirm-delete': {
      const panel = card?.querySelector('.dc-confirm-delete');
      if (panel) panel.style.display = 'none';
      break;
    }
    case 'remove-design': {
      card?.remove();
      showToast('Design removed');
      break;
    }
    case 'qty-minus': {
      const input = btn.closest('.dc-qty-wrap')?.querySelector('.dc-qty-num, .dc-qty-input');
      if (input) { const v = Math.max(1, (parseInt(input.value)||1) - 1); input.value = v; }
      break;
    }
    case 'qty-plus': {
      const input = btn.closest('.dc-qty-wrap')?.querySelector('.dc-qty-num, .dc-qty-input');
      if (input) { input.value = (parseInt(input.value)||1) + 1; }
      break;
    }
    case 'dim-minus':
    case 'dim-plus': {
      const stepper = btn.closest('.dc-dim-stepper');
      const inp = stepper?.querySelector('input');
      if (inp) {
        const step = parseFloat(inp.step) || 0.25;
        const val = parseFloat(inp.value) || 0;
        inp.value = action === 'dim-plus' ? (val + step).toFixed(2) : Math.max(parseFloat(inp.min)||0.5, val - step).toFixed(2);
      }
      break;
    }
    case 'toggle-popular-sizes': {
      const dropdown = card?.querySelector('.dc-pop-dropdown');
      if (dropdown) dropdown.style.display = dropdown.style.display === 'none' ? 'block' : 'none';
      break;
    }
    case 'confirm-add-size': {
      showToast('Size added');
      const form = card?.querySelector('.dc-add-form');
      const trigger = card?.querySelector('.dc-add-trigger');
      if (form) form.style.display = 'none';
      if (trigger) trigger.style.display = 'block';
      break;
    }
    case 'delete-row': {
      const row = btn.closest('.dc-size-row, .dc-edit-row');
      if (row) {
        row.style.transition = 'all 0.3s ease';
        row.style.opacity = '0';
        row.style.maxHeight = '0';
        row.style.overflow = 'hidden';
        setTimeout(() => row.remove(), 300);
      }
      break;
    }
  }
});

// Remove button clicks
document.querySelectorAll('.cart-ui-lab .dc-remove-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const card = btn.closest('.design-card');
    const panel = card?.querySelector('.dc-confirm-delete');
    if (panel) panel.style.display = 'flex';
  });
});

function showToast(msg) {
  const existing = document.querySelector('.cart-ui-lab .dc-toast-live');
  if (existing) existing.remove();
  const toast = document.createElement('div');
  toast.className = 'dc-toast-live';
  toast.style.cssText = 'position:fixed;bottom:30px;left:50%;transform:translateX(-50%);background:#1e293b;color:#fff;padding:12px 24px;border-radius:10px;font-size:13px;font-weight:500;z-index:9999;transition:opacity 0.3s;';
  toast.innerHTML = msg + ' \u00b7 <button onclick="this.parentElement.remove()" style="background:none;border:none;color:#a78bfa;font-weight:600;cursor:pointer;text-decoration:underline;font-size:inherit;">Dismiss</button>';
  document.body.appendChild(toast);
  setTimeout(() => { toast.style.opacity = '0'; setTimeout(() => toast.remove(), 300); }, 3000);
}
</script>
