<style>
  .cart-ui-lab { max-width: 900px; margin: 40px auto; padding: 0 20px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
  .lab-title { font-size: 28px; font-weight: 800; color: #1e293b; margin-bottom: 8px; }
  .lab-sub { font-size: 14px; color: #94a3b8; margin-bottom: 40px; }
  .lab-section { margin-bottom: 48px; }
  .lab-section-title { font-size: 11px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: #94a3b8; margin-bottom: 16px; padding-bottom: 8px; border-bottom: 1px solid #e2e8f0; }
  .lab-divider { height: 1px; background: #e2e8f0; margin: 48px 0; }

  /* Override theme globals that break grid layout */
  .cart-ui-lab * { box-sizing: border-box; }
  .cart-ui-lab .dc-card-header { display: grid !important; grid-template-columns: 80px 1fr auto !important; gap: 16px !important; align-items: start !important; padding: 20px !important; }
  .cart-ui-lab .dc-card-thumb { width: 80px !important; height: 80px !important; border-radius: 10px !important; overflow: hidden !important; background: #f1f5f9 !important; flex-shrink: 0 !important; display: block !important; }
  .cart-ui-lab .dc-card-thumb img { width: 100% !important; height: 100% !important; object-fit: cover !important; display: block !important; }
  .cart-ui-lab .dc-card-info { display: flex !important; flex-direction: column !important; gap: 4px !important; min-width: 0 !important; }
  .cart-ui-lab .dc-card-type { font-size: 11px !important; font-weight: 700 !important; letter-spacing: 0.5px !important; color: #7c3aed !important; text-transform: uppercase !important; }
  .cart-ui-lab .dc-card-title { font-size: 15px !important; font-weight: 700 !important; color: #1e293b !important; line-height: 1.3 !important; overflow: hidden !important; text-overflow: ellipsis !important; white-space: nowrap !important; }
  .cart-ui-lab .dc-card-badge { display: inline-block !important; font-size: 11px !important; font-weight: 600 !important; color: #16a34a !important; background: #f0fdf4 !important; border: 1px solid #bbf7d0 !important; border-radius: 6px !important; padding: 2px 8px !important; width: fit-content !important; }
  .cart-ui-lab .dc-card-actions { display: flex !important; gap: 8px !important; margin-top: 6px !important; }
  .cart-ui-lab .dc-card-btn { font-size: 12px !important; font-weight: 600 !important; padding: 6px 14px !important; border-radius: 8px !important; cursor: pointer !important; border: 1px solid #e2e8f0 !important; background: #fff !important; color: #334155 !important; }
  .cart-ui-lab .dc-price-block { text-align: right !important; display: flex !important; flex-direction: column !important; align-items: flex-end !important; gap: 2px !important; white-space: nowrap !important; }
  .cart-ui-lab .dc-price-now { font-size: 20px !important; font-weight: 800 !important; color: #1e293b !important; }
  .cart-ui-lab .dc-price-was { font-size: 12px !important; color: #94a3b8 !important; text-decoration: line-through !important; }
  .cart-ui-lab .dc-disc-pill { font-size: 11px !important; font-weight: 700 !important; color: #16a34a !important; background: #f0fdf4 !important; border-radius: 6px !important; padding: 2px 8px !important; }
  .cart-ui-lab .dc-price-meta { font-size: 11px !important; color: #94a3b8 !important; }
  .cart-ui-lab .dc-remove-btn { font-size: 12px !important; color: #94a3b8 !important; background: none !important; border: none !important; cursor: pointer !important; padding: 0 !important; }
  .cart-ui-lab .dc-remove-btn:hover { color: #ef4444 !important; }
  .cart-ui-lab .design-card { background: #fff !important; border: 1px solid rgba(226,232,240,0.6) !important; border-radius: 16px !important; margin-bottom: 16px !important; overflow: hidden !important; }
  .cart-ui-lab .dc-col-header { display: grid !important; grid-template-columns: minmax(0,1fr) 100px 100px 100px 60px 28px !important; padding: 0 20px !important; font-size: 11px !important; font-weight: 600 !important; color: #94a3b8 !important; border-top: 1px solid #f1f5f9 !important; padding-top: 12px !important; }
  .cart-ui-lab .dc-size-row { display: grid !important; grid-template-columns: minmax(0,1fr) 100px 100px 100px 60px 28px !important; align-items: center !important; padding: 12px 20px !important; border-top: 1px solid #f1f5f9 !important; }
  .cart-ui-lab .dc-size-dims { font-size: 14px !important; font-weight: 600 !important; color: #1e293b !important; }
  .cart-ui-lab .dc-qty-wrap { display: flex !important; align-items: center !important; border: 1px solid #e2e8f0 !important; border-radius: 8px !important; overflow: hidden !important; width: fit-content !important; }
  .cart-ui-lab .dc-qty-btn { width: 28px !important; height: 32px !important; border: none !important; background: none !important; font-size: 14px !important; cursor: pointer !important; color: #64748b !important; display: flex !important; align-items: center !important; justify-content: center !important; }
  .cart-ui-lab .dc-qty-num { width: 36px !important; text-align: center !important; border: none !important; font-size: 13px !important; font-weight: 600 !important; background: transparent !important; -moz-appearance: textfield !important; }
  .cart-ui-lab .dc-qty-num::-webkit-outer-spin-button,
  .cart-ui-lab .dc-qty-num::-webkit-inner-spin-button { -webkit-appearance: none !important; margin: 0 !important; }
  .cart-ui-lab .dc-price-ea { font-size: 13px !important; }
  .cart-ui-lab .dc-price-ea s { color: #94a3b8 !important; font-size: 11px !important; }
  .cart-ui-lab .disc-price { color: #16a34a !important; font-weight: 700 !important; }
  .cart-ui-lab .ea-suffix { color: #94a3b8 !important; font-weight: 400 !important; font-size: 11px !important; }
  .cart-ui-lab .dc-row-total { font-size: 14px !important; font-weight: 700 !important; color: #1e293b !important; }
  .cart-ui-lab .dc-disc-badge { font-size: 12px !important; font-weight: 600 !important; color: #16a34a !important; }
  .cart-ui-lab .dc-del-btn { background: none !important; border: none !important; cursor: pointer !important; padding: 4px !important; opacity: 0.4 !important; }
  .cart-ui-lab .dc-del-btn:hover { opacity: 1 !important; }
  .cart-ui-lab .dc-add-trigger { padding: 12px 20px !important; }
  .cart-ui-lab .dc-add-btn { font-size: 13px !important; font-weight: 600 !important; color: #16a34a !important; background: none !important; border: none !important; cursor: pointer !important; padding: 0 !important; }
  .cart-ui-lab .dc-section-label { display: flex !important; align-items: center !important; gap: 12px !important; margin-bottom: 16px !important; }
  .cart-ui-lab .dc-section-name { font-size: 13px !important; font-weight: 800 !important; letter-spacing: 1px !important; color: #334155 !important; white-space: nowrap !important; }
  .cart-ui-lab .dc-section-label::after { content: '' !important; flex: 1 !important; height: 1px !important; background: #e2e8f0 !important; }
  .cart-ui-lab .dc-section-meta { font-size: 12px !important; color: #94a3b8 !important; white-space: nowrap !important; }
  .cart-ui-lab .dc-disc-banner { display: flex !important; align-items: center !important; gap: 10px !important; padding: 12px 16px !important; border-radius: 12px !important; font-size: 13px !important; font-weight: 600 !important; margin-bottom: 16px !important; background: #f0fdf4 !important; color: #16a34a !important; border: 1px solid #bbf7d0 !important; }
  .cart-ui-lab .dc-confirm-delete { display: flex !important; align-items: center !important; justify-content: space-between !important; padding: 16px 20px !important; background: #fef2f2 !important; border-top: 1px solid #fecaca !important; font-size: 13px !important; color: #991b1b !important; }
  .cart-ui-lab .dc-confirm-btns { display: flex !important; gap: 8px !important; }
  .cart-ui-lab .dc-card-btn.danger { background: #ef4444 !important; color: #fff !important; border-color: #ef4444 !important; }
  .cart-ui-lab .dc-card-btn.primary { background: #38bdf8 !important; color: #fff !important; border-color: #38bdf8 !important; }
  .cart-ui-lab .dc-toast { position: absolute !important; left: 0 !important; right: 0 !important; text-align: center !important; background: #1e293b !important; color: #fff !important; padding: 12px 20px !important; border-radius: 10px !important; font-size: 13px !important; font-weight: 500 !important; }
  .cart-ui-lab .dc-has-promo { background: #f5f3ff !important; border-radius: 0 !important; margin: 0 !important; padding: 12px 20px !important; }
  .cart-ui-lab .dc-promo-tag { grid-column: 1 / -1 !important; display: flex !important; align-items: center !important; gap: 6px !important; font-size: 12px !important; font-weight: 600 !important; color: #7c3aed !important; padding: 4px 0 0 !important; }
  .cart-ui-lab .dc-promo-amount { font-weight: 400 !important; color: #a78bfa !important; }
  .cart-ui-lab .bc-color-row { display: flex !important; align-items: center !important; gap: 6px !important; margin-bottom: 6px !important; }
  .cart-ui-lab .bc-color-swatch { width: 14px !important; height: 14px !important; border-radius: 50% !important; flex-shrink: 0 !important; border: 1px solid rgba(0,0,0,0.1) !important; }
  .cart-ui-lab .bc-color-name { font-size: 12px !important; font-weight: 600 !important; color: #64748b !important; text-transform: capitalize !important; }
  .cart-ui-lab .dc-card-variant-label { font-size: 12px !important; color: #64748b !important; }

  /* Edit mode rows */
  .cart-ui-lab .dc-edit-row { display: grid !important; grid-template-columns: minmax(0,1fr) 100px 100px 100px 60px 28px !important; align-items: center !important; padding: 12px 20px !important; border-top: 1px solid #f1f5f9 !important; }
  .cart-ui-lab .dc-dim-edit-wrap { display: flex !important; align-items: center !important; gap: 6px !important; min-width: 0 !important; overflow: hidden !important; }
  .cart-ui-lab .dc-dim-stepper { display: flex !important; align-items: center !important; border: 1px solid #e2e8f0 !important; border-radius: 8px !important; overflow: hidden !important; }
  .cart-ui-lab .dc-dim-stepper-btn { width: 28px !important; height: 32px !important; border: none !important; background: none !important; font-size: 14px !important; cursor: pointer !important; color: #64748b !important; display: flex !important; align-items: center !important; justify-content: center !important; }
  .cart-ui-lab .dc-dim-stepper { flex-shrink: 1 !important; min-width: 0 !important; }
  .cart-ui-lab .dc-dim-stepper-input { width: 44px !important; text-align: center !important; border: none !important; border-left: 1px solid #e2e8f0 !important; border-right: 1px solid #e2e8f0 !important; font-size: 12px !important; font-weight: 600 !important; background: transparent !important; padding: 4px 1px !important; -moz-appearance: textfield !important; }
  .cart-ui-lab .dc-dim-stepper-input::-webkit-outer-spin-button,
  .cart-ui-lab .dc-dim-stepper-input::-webkit-inner-spin-button { -webkit-appearance: none !important; margin: 0 !important; }
  .cart-ui-lab .dc-dim-sep { font-size: 14px !important; font-weight: 600 !important; color: #94a3b8 !important; padding: 0 2px !important; }

  /* Add-size form */
  .cart-ui-lab .dc-add-form { padding: 0 !important; border-top: none !important; background: transparent !important; }
  .cart-ui-lab .dc-add-row { display: grid !important; grid-template-columns: minmax(0,1fr) 100px 100px 100px 60px 28px !important; align-items: center !important; padding: 12px 20px !important; border-top: 1px solid #e2e8f0 !important; background: #f8fafc !important; }
  .cart-ui-lab .dc-pop-trigger { padding: 8px 0 !important; }
  .cart-ui-lab .dc-pop-trigger a { font-size: 12px !important; color: #7c3aed !important; text-decoration: underline !important; cursor: pointer !important; }
  .cart-ui-lab .dc-pop-dropdown { background: #fff !important; border: 1px solid #e2e8f0 !important; border-radius: 10px !important; padding: 8px !important; margin-top: 4px !important; display: none !important; }
  .cart-ui-lab .dc-pop-dropdown button { display: block !important; width: 100% !important; text-align: left !important; padding: 8px 12px !important; border: none !important; background: none !important; font-size: 13px !important; color: #334155 !important; border-radius: 6px !important; cursor: pointer !important; }
  .cart-ui-lab .dc-pop-dropdown button:hover { background: #f1f5f9 !important; }
  .cart-ui-lab .dc-add-preview { padding: 8px 0 !important; font-size: 12px !important; color: #64748b !important; }
  .cart-ui-lab .dc-add-btns { display: flex !important; gap: 8px !important; padding: 12px 20px 16px !important; }
  .cart-ui-lab .dc-add-form .dc-pop-trigger { padding: 8px 20px 0 !important; display: block !important; }
  .cart-ui-lab .dc-add-form .dc-pop-trigger a { font-size: 13px !important; color: #7c3aed !important; font-weight: 600 !important; }
  .cart-ui-lab .dc-add-form .dc-pop-dropdown { padding: 8px 20px !important; }
  .cart-ui-lab .dc-add-preview { padding: 8px 20px !important; background: #f0fdf4 !important; margin: 0 !important; border-radius: 0 !important; font-size: 13px !important; color: #16a34a !important; font-weight: 600 !important; }
  .cart-ui-lab .dc-add-cancel { font-size: 12px !important; font-weight: 600 !important; padding: 6px 14px !important; border-radius: 8px !important; cursor: pointer !important; border: 1px solid #e2e8f0 !important; background: #fff !important; color: #334155 !important; }
  .cart-ui-lab .dc-add-confirm { font-size: 12px !important; font-weight: 600 !important; padding: 6px 14px !important; border-radius: 8px !important; cursor: pointer !important; border: 1px solid #38bdf8 !important; background: #38bdf8 !important; color: #fff !important; }

  /* Edit bar */
  .cart-ui-lab .dc-edit-bar { display: flex !important; align-items: center !important; justify-content: flex-end !important; gap: 8px !important; padding: 12px 20px !important; border-top: 1px solid #e2e8f0 !important; background: #f8fafc !important; }

  /* Disabled state */
  .cart-ui-lab .dc-disabled { opacity: 0.45 !important; pointer-events: none !important; }

  /* Active edit button state */
  .cart-ui-lab .dc-card-btn.active { background: #1e293b !important; color: #fff !important; border-color: #1e293b !important; }

  /* Dim group label */
  .cart-ui-lab .dc-dim-group { display: flex !important; flex-direction: column !important; gap: 4px !important; }
  .cart-ui-lab .dc-dim-label { font-size: 11px !important; font-weight: 600 !important; color: #94a3b8 !important; }
  .cart-ui-lab .dc-dim-x { font-size: 14px !important; font-weight: 600 !important; color: #94a3b8 !important; align-self: flex-end !important; margin-bottom: 6px !important; }
  .cart-ui-lab .dc-add-actions { display: flex !important; gap: 8px !important; padding-top: 12px !important; }
  .cart-ui-lab .dc-add-upsell { font-size: 12px !important; color: #7c3aed !important; font-weight: 500 !important; }
  .cart-ui-lab .dc-pop-link { font-size: 12px !important; color: #7c3aed !important; }
</style>

<div class="cart-ui-lab">
  <div class="lab-title">Cart Card UI Lab</div>
  <div class="lab-sub">Interactive prototypes for all card types. Click buttons to test state transitions.</div>

  {%- comment -%}═══════════════════════════════════════════
    SECTION 1: Design Cards (DTF / UV Transfers)
  ═══════════════════════════════════════════{%- endcomment -%}

  <div class="lab-section">
    <div class="lab-section-title">Section: DTF Transfers by Size</div>

    <!-- Section label bar -->
