    "content_toggles_iEGhim": {
      "type": "content-toggles",
      "blocks": {
        "text_K3MjQe": {
          "type": "text",
          "settings": {
            "title": "What’s included in your UV DTF Sticker Packs?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>By using our gang sheet builder, you can choose from 2,000+ pre-made designs in our design library to build your own custom sticker pack.</p>"
          }
        },
        "text_wqwRGB": {
          "type": "text",
          "settings": {
            "title": "How many stickers do I get in a sticker pack?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>As many as you'd like! You can fit hundreds of designs on our sticker packs by using our gang sheet builder.</p>"
          }
        },
        "text_9GAVqt": {
          "type": "text",
          "settings": {
            "title": "Do your UV DTF sticker packs come pre-cut?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>No, our UV DTF sticker packs do not come pre-cut. They'll be shipped to you in a sheet that you will then have to cut out and apply to your hard goods of choice.</p>"
          }
        },
        "text_nGPYqz": {
          "type": "text",
          "settings": {
            "title": "Can I upload a custom design?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>Yes, you can upload your own custom designs through our gang sheet builder. Simply hit the \"Upload Image\" button in the top-left corner and choose which designs you'd like to add to the sheet.</p>"
          }
        },
        "text_YtiUCj": {
          "type": "text",
          "settings": {
            "title": "Do you have pre-made designs?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>Yes, we have 2,000+ pre-made designs to choose from for your sticker pack. In the gang sheet builder, simply hit the \"From Gallery\" button in the top-left of your screen to choose which designs you'd like to use. </p>"
          }
        }
      },
