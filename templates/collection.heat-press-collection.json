        "item_gmqrTy": {
          "type": "item",
          "settings": {
            "question": "What heat press models are available through Ninja Transfers?",
            "answer": "<p>Ninja Transfers features the Heat Press Nation Signature Series, including:</p><ul><li>HPN Signature 15\" x 15\" Slide Out Drawer​</li><li>HPN Signature 15\" x 15\" Slide Out & Auto Open​</li><li>HPN Signature 16\" x 20\" Slide Out Drawer​</li><li>HPN Signature 16\" x 20\" Slide Out & Auto Open</li></ul>"
          }
        },
        "item_PwpAUV": {
          "type": "item",
          "settings": {
            "question": "What are the key features of the HPN Signature Series heat presses?",
            "answer": "<p>The HPN Signature Series heat presses offer:</p><ul><li><strong>Slide Out Drawer</strong>: Provides easy access to the workspace, enhancing safety and convenience.​</li><li><strong>Auto-Open Function:</strong> Automatically opens the press after the set time, preventing over-pressing and improving efficiency.​</li><li><strong>Digital Controls:</strong> Precise digital time and temperature controls for consistent results.</li><li><strong>Non-Stick Coated Heat Platen:</strong> Ensures even heat distribution and prevents materials from sticking.</li></ul>"
          }
        },
        "item_UMk6eN": {
          "type": "item",
          "settings": {
            "question": "What sizes are available for these heat presses?",
            "answer": "<p>The HPN Signature Series heat presses come in two primary platen sizes:</p><ul><li>15\" x 15\"​</li><li>16\" x 20\"</li></ul>"
          }
        },
        "item_YyBwCU": {
          "type": "item",
          "settings": {
            "question": "Are these heat presses suitable for DTF transfers?",
            "answer": "<p>Yes, the HPN Signature Series heat presses are designed to deliver professional results with <a href=\"/products/dtf-transfers\" title=\"DTF Transfers By Size\">DTF transfers</a>, providing the consistent heat and pressure required for high-quality applications.</p>"
          }
        },
        "item_43HQCN": {
          "type": "item",
          "settings": {
            "question": "Where can I purchase these heat presses?",
            "answer": "<p>You can explore and purchase the HPN Signature Series heat presses directly from Ninja Transfers' website!</p>"
          }
        }
      },
