    "custom_liquid_BnyXwQ": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<style>\n  /* =========================================================\n     Base table styling (desktop + mobile defaults)\n     ========================================================= */\n  .comparison-table {\n    width: 100%;\n    border-collapse: collapse;\n    margin-top: 10px;\n    table-layout: fixed; /* prevents columns from blowing out layout */\n  }\n\n  .comparison-table th,\n  .comparison-table td {\n    border: 1px solid #ddd;\n    padding: 12px;\n    text-align: left;\n    vertical-align: top;\n    overflow-wrap: anywhere; /* long strings won't break mobile */\n    word-break: normal;\n  }\n\n  .comparison-table th {\n    background-color: #f5f5f5;\n    font-weight: 700;\n  }\n\n  .comparison-table td:first-child {\n    font-weight: 700;\n    width: 18%;\n    white-space: nowrap;\n  }\n\n  .comparison-table ul {\n    margin: 0;\n    padding-left: 18px;\n  }\n\n  .comparison-table li {\n    margin-bottom: 6px;\n  }\n\n  /* =========================================================\n     Mobile-only rules (best practice for e-comm comparison tables)\n     - Keep table structure (so it stays “natural”)\n     - Make it horizontally scrollable with momentum scrolling\n     - Sticky first column so shoppers always see the row label\n     - Slightly tighter spacing for readability\n     ========================================================= */\n  @media (max-width: 768px) {\n    .comparison-table-wrap {\n      width: 100%;\n      overflow-x: auto;\n      -webkit-overflow-scrolling: touch;\n      overscroll-behavior-x: contain;\n      border: 1px solid #e6e6e6; /* gives the scroll container a clean edge */\n      border-radius: 10px;\n      background: #fff;\n    }\n\n    .comparison-table {\n      min-width: 760px; /* forces scroll instead of squishing columns */\n      margin-top: 0;\n    }\n\n    .comparison-table th,\n    .comparison-table td {\n      padding: 10px;\n      font-size: 14px;\n      line-height: 1.35;\n    }\n\n    /* Sticky “Feature” column */\n    .comparison-table th:first-child,\n    .comparison-table td:first-child {\n      position: sticky;\n      left: 0;\n      z-index: 2;\n      background: #fff; /* keeps it readable over other cells */\n      box-shadow: 8px 0 10px -10px rgba(0, 0, 0, 0.25);\n      white-space: normal; /* allow wrapping if a feature label is long */\n      width: 140px;       /* more usable on mobile than % widths */\n      min-width: 140px;\n    }\n\n    /* Keep header row above sticky first column cells */\n    .comparison-table thead th {\n      position: sticky;\n      top: 0;\n      z-index: 3;\n      background: #f5f5f5;\n    }\n\n    /* Ensure the top-left cell stays on top of both sticky layers */\n    .comparison-table thead th:first-child {\n      z-index: 4;\n      background: #f5f5f5;\n    }\n\n    /* Make columns readable without being huge */\n    .comparison-table th:not(:first-child),\n    .comparison-table td:not(:first-child) {\n      min-width: 160px;\n    }\n\n    /* Lists read cleaner on mobile */\n    .comparison-table ul {\n      padding-left: 16px;\n    }\n\n    .comparison-table li {\n      margin-bottom: 4px;\n    }\n  }\n</style>\n\n<div class=\"comparison-table-wrap\">\n  <table class=\"comparison-table\">\n    <thead>\n      <tr>\n        <th>Feature</th>\n        <th>HPN Signature Series</th>\n        <th>HPN Signature Series PRO</th>\n        <th>HPN TrueSpec Cap Press</th>\n        <th>HPN CraftPro</th>\n      </tr>\n    </thead>\n    <tbody>\n      <tr>\n        <td>Best For</td>\n        <td>General apparel pressing and multi-function setups</td>\n        <td>Higher-volume production with upgraded controls</td>\n        <td>Professional cap decoration and patch pressing</td>\n        <td>Crafters and small businesses</td>\n      </tr>\n\n      <tr>\n        <td>Heat Press Style</td>\n        <td>Clamshell, Multi-Function</td>\n        <td>Auto-Open, Clamshell, Drawer</td>\n        <td>Dual Heat Slide-Out Cap Press</td>\n        <td>Clamshell with Slide-Out Drawer</td>\n      </tr>\n\n      <tr>\n        <td>Platen / Heating Area</td>\n        <td>15&quot; x 15&quot;, 16&quot; x 20&quot;</td>\n        <td>15&quot; x 15&quot;, 16&quot; x 20&quot;</td>\n        <td>\n          Upper: 3.65&quot; x 7&quot;<br>\n          Lower: 3.35&quot; x 6&quot;\n        </td>\n        <td>14.91&quot; x 14.91&quot;</td>\n      </tr>\n\n      <tr>\n        <td>Weight</td>\n        <td>25 lbs – 140 lbs</td>\n        <td>75 lbs (100.7 lbs shipping)</td>\n        <td>48 lbs (67 lbs shipping)</td>\n        <td>59.5 lbs (77.2 lbs shipping)</td>\n      </tr>\n\n      <tr>\n        <td>Temperature Control</td>\n        <td>Digital</td>\n        <td>Digital (°F / °C)</td>\n        <td>Dual Temperature (Upper + Lower)</td>\n        <td>Digital (°F)</td>\n      </tr>\n\n      <tr>\n        <td>Timer</td>\n        <td>0–999 seconds</td>\n        <td>0–999 seconds</td>\n        <td>0–999 seconds (Dual Time)</td>\n        <td>0–999 seconds (Auto-start)</td>\n      </tr>\n\n      <tr>\n        <td>Max Temperature</td>\n        <td>400º F</td>\n        <td>400º F</td>\n        <td>\n          Upper: 400º F<br>\n          Lower: 320º F (280º F surface)\n        </td>\n        <td>400º F</td>\n      </tr>\n\n      <tr>\n        <td>Voltage / Power</td>\n        <td>110V / 1600W / 14A</td>\n        <td>110V / 1500W / 14A</td>\n        <td>120V / 1200W / 10A</td>\n        <td>120V / 1500W / 14A</td>\n      </tr>\n\n      <tr>\n        <td>Lower Platen</td>\n        <td>Stationary</td>\n        <td>Slide-Out Drawer</td>\n        <td>Slide-Out Drawer (Cap)</td>\n        <td>Slide-Out Drawer</td>\n      </tr>\n\n      <tr>\n        <td>Opening Mechanism</td>\n        <td>Auto-Open</td>\n        <td>Gas Shock Auto-Open</td>\n        <td>Gas Shock Auto-Open</td>\n        <td>Manual Clamshell</td>\n      </tr>\n\n      <tr>\n        <td>Key Features</td>\n        <td>\n          <ul>\n            <li>Embedded nonstick coating</li>\n            <li>Secondary handle (select models)</li>\n          </ul>\n        </td>\n        <td>\n          <ul>\n            <li>SurePressure™ pressure readout</li>\n            <li>Improved heating element</li>\n            <li>Slide-out drawer options</li>\n          </ul>\n        </td>\n        <td>\n          <ul>\n            <li>TrueSpec TransferGuard (no heat tape)</li>\n            <li>Slide-out drawer for safer loading</li>\n            <li>Limit plate prevents bill contact</li>\n            <li>All-around cap pressing</li>\n            <li>Updated platen curvature</li>\n            <li>3 programmable presets</li>\n          </ul>\n        </td>\n        <td>\n          <ul>\n            <li>Slide-out lower platen</li>\n            <li>Auto-start timer</li>\n            <li>Floating top platen</li>\n            <li>Compact, space-saving design</li>\n          </ul>\n        </td>\n      </tr>\n\n      <tr>\n        <td>Extended Warranty</td>\n        <td>\n          1 Year — Included<br>\n          2 Years — $49.99<br>\n          3 Years — $79.99<br>\n          4 Years — $99.99\n        </td>\n        <td>\n          1 Year — Included<br>\n          2 Years — $49.99<br>\n          3 Years — $79.99<br>\n          4 Years — $99.99\n        </td>\n        <td>\n          1 Year — Included<br>\n          2 Years — $49.99<br>\n          3 Years — $79.99<br>\n          4 Years — $99.99\n        </td>\n        <td>\n          1 Year — Included<br>\n          2 Years — $49.99<br>\n          3 Years — $79.99<br>\n          4 Years — $99.99\n        </td>\n      </tr>\n    </tbody>\n  </table>\n</div>",
