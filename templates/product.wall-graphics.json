    "ss_faq_5_Ea9nQa": {
      "type": "ss-faq-5",
      "blocks": {
        "item_bFwa3U": {
          "type": "item",
          "settings": {
            "question": "What materials are used for your custom vinyl stickers?",
            "answer": "<p>Our custom vinyl stickers are crafted from premium, weatherproof vinyl, ensuring vibrant, high-resolution designs that are durable for over two years, even in outdoor conditions.</p>"
          }
        },
        "item_fh4ypt": {
          "type": "item",
          "settings": {
            "question": "Are the stickers waterproof and suitable for outdoor use?",
            "answer": "<p>Yes, our stickers are both waterproof and weatherproof, making them ideal for outdoor applications. They are designed to withstand exposure to wind, rain, and sunlight without fading or peeling.</p>"
          }
        },
        "item_GczWKk": {
          "type": "item",
          "settings": {
            "question": "What sizes and shapes are available for custom stickers?",
            "answer": "<p>We offer stickers up to 22\" x 22\" in size. For shapes, we provide a variety of options, including standard circles and squares, as well as custom shapes designed to match your vision perfectly.</p>"
          }
        },
        "item_bxRzfp": {
          "type": "item",
          "settings": {
            "question": "How do I apply the stickers, and can they be removed without leaving residue?",
            "answer": "<p>Applying our stickers is straightforward: simply peel from the backing and place on a clean, smooth surface. They can be removed without leaving any sticky residue behind.</p>"
          }
        },
        "item_FbW8mT": {
          "type": "item",
          "settings": {
            "question": "What is the minimum order quantity for custom stickers?",
            "answer": "<p>The minimum order quantity for vinyl stickers is 100 pieces.</p>"
          }
        },
        "item_JfVmna": {
          "type": "item",
          "settings": {
            "question": "Can I see a proof of my design before final printing?",
            "answer": "<p>Currently, we do not offer proofs for custom stickers.</p>"
          }
        },
        "item_UxHwzz": {
          "type": "item",
          "settings": {
            "question": "How long does production and shipping take?",
            "answer": "<p>All sticker orders are processed and shipped within 2-3 business days.</p>"
          }
        },
        "item_4hNWJE": {
          "type": "item",
          "settings": {
            "question": "Are there discounts for bulk orders?",
            "answer": "<p>Yes, we offer tiered pricing with discounts increasing based on the order quantity. Save up 65% when ordering 2,000 or more stickers!</p>"
          }
        },
        "item_zMDBJj": {
          "type": "item",
          "settings": {
            "question": "Can I customize the finish of my stickers?",
            "answer": "<p>Absolutely, you can choose between a sleek matte or gloss finish to best suit your design preferences.</p>"
          }
        },
        "item_w7CD6G": {
          "type": "item",
          "settings": {
            "question": "Are your stickers safe for use on drinkware and other items that require washing?",
            "answer": "<p>Yes, our stickers are dishwasher safe when applied to <a href=\"/collections/drinkware\" title=\"Blank Drinkware\">drinkware</a>, ensuring they maintain their appearance even after repeated washes.</p>"
          }
        }
      },
