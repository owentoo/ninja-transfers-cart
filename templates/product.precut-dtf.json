        },
        "collapsible_row_hcCcy4": {
          "type": "collapsible_row",
          "disabled": true,
          "settings": {
            "heading": "Custom Numbers",
            "row_content": "<p>Elevate your apparel game with our Custom Numbers DTF Transfer Packs. Each pack includes ten high-quality numbers (0-9), available in two classic fonts: Collegiate and Interstate. Whether you're looking to personalize jerseys, shirts, jackets, or other garments, these versatile numbers are the perfect solution. Choose between left chest sizing (4 inches in height) or a full front design (8 inches in height) to achieve the perfect look.</p><p><a href=\"https://ninjatransfers.com/products/custom-number-pack\" target=\"_blank\" title=\"https://ninjatransfers.com/products/custom-number-pack\">Order Them Here</a></p>",
            "custom_liquid": ""
          }
        }
      },
