    "290dab8d-8b7e-47c1-bbcb-85e77a74e459": {
      "type": "rich-text",
      "blocks": {
        "13e24e27-2c5b-4a09-832c-a8a7bea82509": {
          "type": "title",
          "settings": {
            "title": "4. Final Press",
            "title_size": "heading-size--small",
            "seo_h_tag": "h2"
          }
        },
        "a0626fe1-bdd7-4192-8d95-0a7436eb5074": {
          "type": "text",
          "settings": {
            "text": "<p>Place the parchment paper included or a single layer of t-shirt material over the design and press again for 15 seconds to soften the design, increase durability, and remove shine.</p><p>If you want a shinier finish instead, you can use our Protective Guard Sheet for this result.</p>",
            "text_size": "regular"
          }
        }
      },
      "block_order": [
        "13e24e27-2c5b-4a09-832c-a8a7bea82509",
        "a0626fe1-bdd7-4192-8d95-0a7436eb5074"
