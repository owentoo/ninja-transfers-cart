    "b7ac54e8-2093-4261-960e-f80502300a2a": {
      "type": "rich-text",
      "blocks": {
        "template--14994963365971__b7ac54e8-2093-4261-960e-f80502300a2a-16897055922469b662-0": {
          "type": "title",
          "settings": {
            "title": "1. Position Your Design",
            "title_size": "heading-size--small",
            "seo_h_tag": "h2"
          }
        },
        "template--14994963365971__b7ac54e8-2093-4261-960e-f80502300a2a-16897055922469b662-1": {
          "type": "text",
          "settings": {
            "text": "<p>Take your time and line up your artwork in the desired print area. To ensure your transfer doesn't move while ironing it onto the garment, use our <a href=\"/products/thermal-heat-tape-1-roll\" title=\"Thermal Heat Tape\">Thermal Heat Tape</a> to secure it.</p>",
            "text_size": "regular"
          }
        }
      },
      "block_order": [
        "template--14994963365971__b7ac54e8-2093-4261-960e-f80502300a2a-16897055922469b662-0",
