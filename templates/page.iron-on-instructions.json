    },
    "cdaa6feb-d841-4fc3-a915-b7fb7b6c37e5": {
      "type": "rich-text",
      "blocks": {
        "594d259f-babe-4683-bb1d-44d88ad96f34": {
          "type": "title",
          "settings": {
            "title": "3. Peel Hot After a Few Seconds",
            "title_size": "heading-size--small",
            "seo_h_tag": "h2"
          }
        },
        "e7c2c918-9986-4016-9fab-ac17c4e87b3b": {
          "type": "text",
          "settings": {
            "text": "<p>With our proprietary Ninja Peel Technology, you can peel hot or cool. Wait a few seconds (or longer) and peel. If any part of the design lifts while peeling, lay the transfer back down and press again with firm pressure for another 10–15 seconds.</p>",
            "text_size": "regular"
          }
        }
      },
      "block_order": [
        "594d259f-babe-4683-bb1d-44d88ad96f34",
        "e7c2c918-9986-4016-9fab-ac17c4e87b3b"
      ],
