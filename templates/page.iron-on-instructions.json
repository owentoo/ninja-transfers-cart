    "262c38a8-de4f-4445-8199-948ed8698bd5": {
      "type": "rich-text",
      "blocks": {
        "024d2617-fc61-4c9d-bee3-443979aa07e9": {
          "type": "title",
          "settings": {
            "title": "2. Press",
            "title_size": "heading-size--small",
            "seo_h_tag": "h2"
          }
        },
        "71420bde-00ab-4a98-ac37-b5d3188960e9": {
          "type": "text",
          "settings": {
            "text": "<p>Set your iron to the highest temperature recommended for your garment. Place a piece of parchment paper over the transfer and apply firm pressure for about 20<strong> </strong>seconds. When using an iron, focus on one section of the design at a time, moving slowly across the entire graphic to ensure even heat and pressure. If any part of the transfer isn’t adhering, lay it back down and press again with additional pressure and time.</p>",
            "text_size": "regular"
          }
        }
      },
      "block_order": [
        "024d2617-fc61-4c9d-bee3-443979aa07e9",
        "71420bde-00ab-4a98-ac37-b5d3188960e9"
