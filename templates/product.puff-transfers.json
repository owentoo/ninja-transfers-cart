    "6ff89c20-9a60-4c71-b742-ac9fc9068e03": {
      "type": "collapsible-content",
      "blocks": {
        "template--15246164459603__6ff89c20-9a60-4c71-b742-ac9fc9068e03-collapsible_row-1": {
          "type": "collapsible_row",
          "settings": {
