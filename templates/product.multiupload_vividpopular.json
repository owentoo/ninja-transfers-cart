    "custom_liquid_L468k8": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "t:sections.refactor_words.custom_code.name",
      "settings": {
        "custom_liquid": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Promo Banner</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap\" rel=\"stylesheet\">\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body {\n      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;\n      background: #f5f5f5;\n      padding: 40px 20px;\n    }\n\n    .promo-banner {\n      max-width: 760px;\n      margin: 0 auto;\n      border-radius: 12px;\n      overflow: hidden;\n      background: #fff;\n      border: 1px solid #e0e0e0;\n    }\n\n    /* ── Header ── */\n    .promo-banner__header {\n      background: linear-gradient(135deg, #1a2e3b 0%, #1b4d5e 100%);\n      padding: 14px 24px;\n    }\n\n    .promo-banner__header h2 {\n      margin: 0;\n      font-size: 18px;\n      font-weight: 600;\n      color: #fff;\n      line-height: 1.4;\n    }\n\n    /* ── Body ── */\n    .promo-banner__body {\n      display: flex;\n      gap: 20px;\n      padding: 8px 8px 8px 24px;\n      align-items: center;\n    }\n\n    /* ── Text column ── */\n    .promo-banner__text {\n      flex: 1 1 0%;\n      min-width: 0;\n    }\n\n    .promo-banner__text h3 {\n      margin: 0 0 6px;\n      font-size: 15px;\n      font-weight: 700;\n      color: #1a1a1a;\n    }\n\n    .promo-banner__desc {\n      font-size: 13px;\n      line-height: 1.5;\n      color: #333;\n      margin: 0 0 14px;\n    }\n\n    .promo-banner__desc strong {\n      color: #329F00;\n      font-weight: 700;\n      display: block;\n    }\n\n    .promo-banner__features {\n      display: grid;\n      grid-template-columns: auto auto;\n      gap: 10px 20px;\n      margin-bottom: 14px;\n    }\n\n    .promo-banner__feature {\n      display: flex;\n      align-items: center;\n      gap: 6px;\n      font-size: 12px;\n      font-weight: 700;\n      color: #1a1a1a;\n    }\n\n    .promo-banner__check {\n      flex-shrink: 0;\n      width: 18px;\n      height: 18px;\n    }\n\n    .promo-banner__disclaimer {\n      font-size: 10px;\n      color: #888;\n      margin: 0;\n      line-height: 1.4;\n    }\n\n    /* ── Images column ── */\n    .promo-banner__images {\n      display: flex;\n      align-items: flex-start;\n      gap: 12px;\n      flex-shrink: 0;\n      position: relative;\n    }\n\n    .promo-banner__image-card {\n      position: relative;\n      width: 160px;\n    }\n\n    /* Pills — 10px font, 8px from image edges */\n    .promo-banner__label {\n      display: inline-flex;\n      position: absolute;\n      top: 8px;\n      left: 8px;\n      padding: 0 12px;\n      border-radius: 6px;\n      font-size: 10px;\n      font-weight: 700;\n      line-height: 24px;\n      letter-spacing: 0.009px;\n      text-align: center;\n      z-index: 2;\n      white-space: nowrap;\n    }\n\n    .promo-banner__label--blanks {\n      background: #1a2e3b;\n      color: #fff;\n    }\n\n    .promo-banner__label--transfers {\n      background: #329F00;\n      color: #fff;\n    }\n\n    .promo-banner__img {\n      width: 100%;\n      aspect-ratio: 11 / 13;\n      border-radius: 10px;\n      overflow: hidden;\n      background: #e4d6cc;\n    }\n\n    .promo-banner__img img {\n      width: 100%;\n      height: 100%;\n      object-fit: cover;\n      display: block;\n    }\n\n    /* Equals — overlays center of both images */\n    .promo-banner__equals {\n      position: absolute;\n      top: 50%;\n      left: 50%;\n      transform: translate(-50%, -50%);\n      z-index: 3;\n      width: 36px;\n      height: 36px;\n      background: #1a2e3b;\n      border-radius: 50%;\n      border: 2px solid #fff;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n    }\n\n    .promo-banner__equals svg {\n      width: 16px;\n      height: 16px;\n    }\n\n    /* ── Mobile ── */\n    @media (max-width: 768px) {\n      .promo-banner__header {\n        padding: 12px 18px;\n      }\n\n      .promo-banner__header h2 {\n        font-size: 15px;\n      }\n\n      .promo-banner__body {\n        flex-direction: column;\n        padding: 0;\n        gap: 0;\n      }\n\n      .promo-banner__text {\n        padding: 14px 8px 12px;\n      }\n\n      .promo-banner__images {\n        width: 100%;\n        padding: 0 8px 8px;\n      }\n\n      .promo-banner__image-card {\n        flex: 1;\n        width: auto;\n      }\n\n      .promo-banner__label {\n        font-size: 8px;\n        line-height: 22px;\n      }\n\n      .promo-banner__features {\n        gap: 8px 16px;\n      }\n    }\n  </style>\n</head>\n<body>\n\n<div class=\"promo-banner\">\n  <div class=\"promo-banner__header\">\n    <h2>Buy 5 Blanks, Get 5 Transfers FREE</h2>\n  </div>\n\n  <div class=\"promo-banner__body\">\n    <div class=\"promo-banner__text\">\n      <h3>How it works</h3>\n      <p class=\"promo-banner__desc\">Just add 5 or more blanks to your cart and get <strong>5 Transfers FREE!</strong></p>\n\n      <div class=\"promo-banner__features\">\n        <div class=\"promo-banner__feature\">\n          <svg class=\"promo-banner__check\" viewBox=\"0 0 24 24\" fill=\"none\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#329F00\"/><path d=\"M7 12.5l3 3 7-7\" stroke=\"#fff\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n          <span>Next Day Delivery</span>\n        </div>\n        <div class=\"promo-banner__feature\">\n          <svg class=\"promo-banner__check\" viewBox=\"0 0 24 24\" fill=\"none\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#329F00\"/><path d=\"M7 12.5l3 3 7-7\" stroke=\"#fff\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n          <span>Free Shipping $50+</span>\n        </div>\n        <div class=\"promo-banner__feature\">\n          <svg class=\"promo-banner__check\" viewBox=\"0 0 24 24\" fill=\"none\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#329F00\"/><path d=\"M7 12.5l3 3 7-7\" stroke=\"#fff\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n          <span>No Minimums</span>\n        </div>\n        <div class=\"promo-banner__feature\">\n          <svg class=\"promo-banner__check\" viewBox=\"0 0 24 24\" fill=\"none\"><circle cx=\"12\" cy=\"12\" r=\"12\" fill=\"#329F00\"/><path d=\"M7 12.5l3 3 7-7\" stroke=\"#fff\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n          <span>Bulk Discounts</span>\n        </div>\n      </div>\n\n      <p class=\"promo-banner__disclaimer\">Discount automatically applied. Valid on transfers up to 11\" × 11\".</p>\n    </div>\n\n    <div class=\"promo-banner__images\">\n      <div class=\"promo-banner__image-card\">\n        <span class=\"promo-banner__label promo-banner__label--blanks\">Buy 5 Blanks</span>\n        <div class=\"promo-banner__img\"><img src=\"https://cdn.shopify.com/s/files/1/0558/0265/8899/files/5_shirts.png?v=1773263745\" alt=\"Buy 5 Blanks\" loading=\"lazy\"></div>\n      </div>\n\n      <div class=\"promo-banner__equals\">\n        <svg viewBox=\"0 0 20 20\" fill=\"none\"><rect x=\"3\" y=\"6\" width=\"14\" height=\"2.5\" rx=\"1.25\" fill=\"#fff\"/><rect x=\"3\" y=\"11.5\" width=\"14\" height=\"2.5\" rx=\"1.25\" fill=\"#fff\"/></svg>\n      </div>\n\n      <div class=\"promo-banner__image-card\">\n        <span class=\"promo-banner__label promo-banner__label--transfers\">Get 5 FREE Transfers</span>\n        <div class=\"promo-banner__img\"><img src=\"https://cdn.shopify.com/s/files/1/0558/0265/8899/files/5_transfers.png?v=1773263744\" alt=\"Get 5 FREE Transfers\" loading=\"lazy\"></div>\n      </div>\n    </div>\n  </div>\n</div>\n\n</body>\n</html>",
        "full_width": false,
        "remove_margin": false
      }
    },
