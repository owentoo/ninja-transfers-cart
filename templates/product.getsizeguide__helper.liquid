{% layout none %}
{%-liquid
  assign maxWidth = product.metafields.custom.suggested_max_width | times: 1 | round: 0
  assign maxHeight = product.metafields.custom.suggested_max_height | times: 1 | round: 0
  assign shownAt = maxWidth | append: ' x ' | append: maxHeight | append: ' inches'
  assign getImg = product.metafields.custom.size_guide_image | image_url: width: 600
  assign getTitle = product.title
-%}
{
  "maxWidth": {{ maxWidth | json }},
  "maxHeight": {{ maxHeight | json }},
  "shownAt": {{ shownAt | json }},
  "getImg": {{ getImg | json }},
  "getTitle": {{ getTitle | json }}
}
