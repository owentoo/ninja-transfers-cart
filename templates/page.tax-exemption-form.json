          }
        },
        "text_FWXjFD": {
          "type": "text",
          "settings": {
            "text": "<p>Schools, government agencies, nonprofits, and other tax-exempt organizations can apply for sales tax exemption through their state. To shop tax-free with Ninja Transfers, simply upload your valid exemption certificate for quick review and approval.</p>",
            "text_custom": false,
            "text_font": "josefin_sans_n4",
            "text_size": 18,
            "text_size_mobile": 16,
            "text_height": 130,
            "text_mt": 20,
            "text_mt_mobile": 20,
            "text_align": "left",
            "text_align_mobile": "center",
            "text_color": "#000000"
          }
        },
        "item_yaRBLJ": {
          "type": "item",
          "settings": {
            "question": "Does Ninja Transfers charge sales tax?",
            "answer": "<p>Yes, applicable state and local sales tax will be added at checkout. If your order qualifies for exemption, no tax will be charged.</p>",
            "linkText": "",
            "link": ""
          }
        },
        "item_YRg9fD": {
          "type": "item",
          "settings": {
            "question": "My organization is tax exempt. How can sales tax be removed from my order?",
            "answer": "<p>Sales tax exemptions are determined by each state. Schools, nonprofits, and government entities must provide valid, state-issued exemption documentation. Upload your certificate through your Ninja Transfers account for review and approval before purchasing tax-free.</p>",
            "linkText": "",
            "link": ""
          }
        },
        "item_7pNgdQ": {
          "type": "item",
          "settings": {
            "question": "Where can I find or get a tax exemption certificate?",
            "answer": "<p>Approved organizations receive a state-issued certificate of exemption. Check with your finance team or request one directly from your state’s tax department.</p>",
            "linkText": "",
            "link": ""
          }
        },
        "item_nGGxFR": {
          "type": "item",
          "settings": {
            "question": "Where can I manage my tax exemptions?",
            "answer": "<p>You can manage and view the status of your tax exemption through your Ninja Transfers account portal under <a href=\"https://account.ninjatransfers.com/pages/882ee7ee-0fb5-4f14-b74f-c7a11852aa8b\" title=\"https://account.ninjatransfers.com/pages/882ee7ee-0fb5-4f14-b74f-c7a11852aa8b\"><strong>account settings</strong></a><strong>.</strong></p>",
            "linkText": "",
            "link": ""
          }
        },
        "item_tnHD9F": {
          "type": "item",
          "settings": {
            "question": "How long does approval take?",
            "answer": "<p>Processing time varies by state. Most approvals take 1–2 business days, while some may be verified within a few hours depending on the documentation provided.</p>",
            "linkText": "",
            "link": ""
          }
        }
