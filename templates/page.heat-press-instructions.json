    "custom_liquid_BNbni7": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<!DOCTYPE html>\n<html>\n<head>\n    <style>\n        .custom-heading {\n            font-size: 24px;\n            font-weight: 600;\n            margin-top: 40px;\n            text-align: center;\n        }\n\n        .custom-paragraph {\n            font-size: 16px;\n            font-weight: 400;\n            margin-top: 10px;\n            text-align: center;\n            color: #555;\n        }\n    </style>\n</head>\n<body>\n    <h2 class=\"custom-heading\">Troubleshooting Common Issues</h2>\n    <p class=\"custom-paragraph\">Even with perfect technique, issues can sometimes arise. Here's what to watch out for:</p>\n</body>\n</html>",
