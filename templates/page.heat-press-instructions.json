          "type": "heading",
          "settings": {
            "heading": "1. Pre-Press or Pre-Iron is not required",
            "heading_custom": false,
            "heading_font": "assistant_n4",
            "header_size": 20,
            "font_weight": "600",
            "heading_height": 130,
            "heading_mt": 20,
