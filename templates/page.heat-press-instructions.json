    "ss_video_with_text_cRe6qP": {
      "type": "ss-video-with-text",
      "blocks": {
        "heading_hNmQVT": {
          "type": "heading",
          "settings": {
            "heading": "3. Press & Peel After a Few Seconds",
            "heading_custom": false,
            "heading_font": "assistant_n4",
            "header_size": 20,
            "font_weight": "600",
            "heading_height": 130,
            "heading_mt": 20,
            "heading_color": "#000000"
          }
        },
        "text_byY699": {
          "type": "text",
          "settings": {
            "text": "<p>Press the transfer at <strong>310°F / 155°C with medium to high pressure for ~12 seconds</strong>. It’s recommended to test your settings using a spare garment. Use parchment paper provided to protect the transfer and garment from touching the iron directly. Let cool a few seconds, then peel!</p><p> </p><p><strong>Pro Tip:</strong> When ready to upgrade from parchment paper to streamline your process, order <a href=\"/products/ninjaflex-heat-press-garment-protector\" title=\"Ninja Silicone Garment Protector\">Ninja’s Silicone Garment Protector</a>. It allows you to press faster and more confidently by preventing burning/scorching.</p>",
            "text_custom": true,
            "text_font": "inter_n4",
            "text_size": 16,
            "text_height": 130,
            "text_mt": 20,
            "text_color": "#000000"
          }
        }
      },
