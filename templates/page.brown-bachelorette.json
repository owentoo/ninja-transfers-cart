    "ss_faq_9_aQnYe7": {
      "type": "ss-faq-9",
      "blocks": {
        "heading_yaLAnh": {
          "type": "heading",
          "settings": {
            "heading": "<h2>FAQ</h2>",
            "heading_custom": true,
            "heading_font": "inter_n7",
            "heading_size": 48,
            "heading_size_mobile": 30,
            "heading_height": 130,
            "heading_mt": 0,
