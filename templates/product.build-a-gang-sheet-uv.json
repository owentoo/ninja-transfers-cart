        "video_zhxcGM": {
          "type": "video",
          "settings": {
            "image": "shopify://shop_images/NinjaCycle_Pic.png",
            "video": "shopify://files/videos/UV product selling point (any surface).mp4",
            "video_url": "",
            "title": "Works on Any Hard Surface",
            "text": "<p><strong>UV DTF PermaStickers are built to stick where others fail — delivering flawless adhesion to hard surfaces like laptops, tumblers, glass, plastic, metal, and more.</strong></p>"
          }
        },
        "video_UpUxff": {
          "type": "video",
          "settings": {
            "image": "shopify://shop_images/suds.png",
            "video": "shopify://files/videos/UV product selling point (waterproof).mp4",
            "video_url": "",
            "title": "100% Waterproof",
            "text": "<p><strong>Designed to handle moisture and mess, UV DTF PermaStickers are fully waterproof. They won’t peel, bubble, or fade when exposed to water — perfect for bottles, coolers, boats, and outdoor gear.</strong></p>"
          }
        },
        "video_fDwFwC": {
          "type": "video",
          "settings": {
            "image": "shopify://shop_images/3d.png",
            "video": "shopify://files/videos/UV product selling points (3d epoxy).mp4",
            "video_url": "",
            "title": "Premium 3D Look",
            "text": "<p><strong>Built with a smooth, epoxy-like finish, these PermaStickers deliver a bold, raised texture you can see and feel.</strong></p>"
          }
        },
        "video_qe8pnf": {
          "type": "video",
          "settings": {
            "image": "shopify://shop_images/no_bg.png",
            "video": "shopify://files/videos/UV product selling point (no bg).mp4",
