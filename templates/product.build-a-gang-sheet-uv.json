        "text_QgkXXK": {
          "type": "text",
          "settings": {
            "text": "<p>UV DTF 3D PermaStickers™ deliver vivid UV printing, raised texture, and extreme durability that holds strong indoors and outdoors.</p>",
            "text_custom": false,
            "text_font": "josefin_sans_n4",
            "text_size": 15,
