    "custom_liquid_aKWgni": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<style>\n    /* ===== Base / Desktop ===== */\n    .table-wrap {\n        width: 100%;\n        overflow: hidden; /* prevent tiny scrollbars on desktop */\n    }\n    table {\n        width: 100%;\n        border-collapse: collapse;\n        border: 1px solid #ddd;\n        font-family: Arial, sans-serif;\n    }\n    th, td {\n        border: 1px solid #ddd;\n        padding: 12px;\n        text-align: left;\n        vertical-align: top;\n    }\n    th {\n        background-color: #f8f8f8;\n        font-weight: bold;\n    }\n    tr:nth-child(even) {\n        background-color: #f9f9f9;\n    }\n    td:first-child, th:first-child {\n        font-weight: bold;\n        white-space: nowrap;\n    }\n    ul {\n        padding: 0;\n        margin: 0;\n        list-style: none;\n    }\n    ul li {\n        white-space: nowrap; /* desktop: keep tidy columns */\n    }\n\n    /* ===== Mobile (stacked cards) ===== */\n    @media (max-width: 640px) {\n        /* Allow horizontal scroll as a graceful fallback if needed */\n        .table-wrap {\n            overflow-x: auto;\n            -webkit-overflow-scrolling: touch;\n        }\n\n        /* Turn the table into stacked “cards” */\n        table, thead, tbody, th, td, tr {\n            display: block;\n        }\n        thead {\n            /* Hide header row on mobile (labels appear via data-label) */\n            position: absolute;\n            height: 0;\n            width: 0;\n            overflow: hidden;\n            clip: rect(0 0 0 0);\n            white-space: nowrap;\n        }\n        tbody tr {\n            background: #fff;\n            border: 1px solid #e6e6e6;\n            border-radius: 10px;\n            margin: 12px 0;\n            padding: 8px 0;\n        }\n        tbody tr:nth-child(even) {\n            background: #fff; /* neutralize zebra striping inside cards */\n        }\n        td {\n            border: 0;\n            border-bottom: 1px solid #f0f0f0;\n            padding: 10px 12px;\n            display: flex;\n            gap: 10px;\n        }\n        td:last-child {\n            border-bottom: 0;\n        }\n        /* Show the column name before each cell’s value */\n        td::before {\n            content: attr(data-label);\n            flex: 0 0 42%;\n            min-width: 120px;\n            font-weight: 700;\n            color: #333;\n        }\n        /* Make content wrap nicely on small screens */\n        ul li, td, td * {\n            white-space: normal !important;\n        }\n        /* Tighten fonts slightly for mobile */\n        table {\n            font-size: 14px;\n        }\n    }\n</style>\n\n<div class=\"table-wrap\">\n<table>\n    <thead>\n        <tr>\n            <th>Sticker Type</th>\n            <th>Description</th>\n            <th>Sizes Available</th>\n            <th>Best Use Cases</th>\n            <th>Waterproof</th>\n        </tr>\n    </thead>\n    <tbody>\n        <tr>\n            <td data-label=\"Sticker Type\">Vinyl Stickers</td>\n            <td data-label=\"Description\">Durable, high-quality vinyl stickers available in custom shapes and sizes.</td>\n            <td data-label=\"Sizes Available\">\n                <ul>\n                    <li>Custom sizing up to 10 in. by 10 in.</li>\n                </ul>\n            </td>\n            <td data-label=\"Best Use Cases\">\n                <ul>\n                    <li>Branding</li>\n                    <li>Product Labeling</li>\n                    <li>Promotional Giveaways</li>\n                </ul>\n            </td>\n            <td data-label=\"Waterproof\">Yes</td>\n        </tr>\n\n        <!-- VINYL MAGNETS -->\n        <tr>\n            <td data-label=\"Sticker Type\">Vinyl Magnets</td>\n            <td data-label=\"Description\">Premium vinyl, high-resolution, full-color magnets built to last with 2+ years of outdoor durability. Weather- and fade-resistant for vibrant, durable designs.</td>\n            <td data-label=\"Sizes Available\">\n                <ul>\n                    <li>Custom sizing up to 7 in. by 7 in.</li>\n                </ul>\n            </td>\n            <td data-label=\"Best Use Cases\">\n                <ul>\n                    <li>Branding &amp; Decorating</li>\n                    <li>Personalization</li>\n                    <li>Promotional Handouts</li>\n                </ul>\n            </td>\n            <td data-label=\"Waterproof\">Yes</td>\n        </tr>\n\n        <tr>\n            <td data-label=\"Sticker Type\" style=\"white-space: nowrap;\">Bumper Stickers</td>\n            <td data-label=\"Description\">Designed for vehicle bumpers, these stickers are long-lasting and resistant to outdoor elements.</td>\n            <td data-label=\"Sizes Available\">\n                <ul>\n                    <li>3 in. by 6 in.</li>\n                    <li>3 in. by 9 in.</li>\n                    <li>3 in. by 12 in.</li>\n                </ul>\n            </td>\n            <td data-label=\"Best Use Cases\">\n                <ul>\n                    <li>Slogans</li>\n                    <li>Personal Messages on Vehicles</li>\n                    <li>Advertising &amp; Business Promotion</li>\n                </ul>\n            </td>\n            <td data-label=\"Waterproof\">Yes</td>\n        </tr>\n\n        <tr>\n            <td data-label=\"Sticker Type\">Truck Stickers</td>\n            <td data-label=\"Description\">Larger, heavy-duty stickers made for trucks, ideal for branding or personal expression.</td>\n            <td data-label=\"Sizes Available\">\n                <ul>\n                    <li>8.25 in. by 12.5 in.</li>\n                    <li>12.25 in. by 18.5 in.</li>\n                    <li>16.25 in. by 24.5 in.</li>\n                </ul>\n            </td>\n            <td data-label=\"Best Use Cases\">\n                <ul>\n                    <li>Company Logos</li>\n                    <li>Business Branding</li>\n                    <li>Decorative Truck Decals</li>\n                </ul>\n            </td>\n            <td data-label=\"Waterproof\">Yes</td>\n        </tr>\n    </tbody>\n</table>\n</div>",
