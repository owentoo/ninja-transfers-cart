            "link": ""
          }
        },
        "item_48GUpi": {
          "type": "item",
          "settings": {
            "question": "What materials are used for your custom magnets?",
            "answer": "<p>Our custom magnets are crafted from premium, weatherproof vinyl, ensuring vibrant, high-resolution designs that are durable for over two years, even in outdoor conditions.</p>",
            "linkText": "",
            "link": ""
          }
        },
        "item_YFnYxw": {
