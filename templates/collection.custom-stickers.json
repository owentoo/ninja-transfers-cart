          }
        },
        "item_z3VbB6": {
          "type": "item",
          "settings": {
            "question": "How is pricing determined for stickers and magnets?",
            "answer": "<p>Pricing for stickers and magnets are determined by size and quantity. We offer bulk discounts for each sticker type we offer. The more you buy, the more you save!</p>",
