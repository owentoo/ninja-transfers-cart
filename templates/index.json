    "testimonials_home_HbREFf": {
      "type": "testimonials-home",
      "blocks": {
        "review_RpgxxT": {
          "type": "review",
          "settings": {
            "image": "shopify://shop_images/Erika_Lehrmann_4328e689-119a-4dc5-a11c-28730d361086.png",
            "title": "Erika Lehrmann",
            "reviewerTitle": "",
            "review": "I have to say, Ninja went above and beyond with their customer service. I'm happy to say that they stand by their product and that's all a small business owner like me could ask for.",
            "reviewStars": "5stars",
            "image_b": "shopify://shop_images/Rob_5c1a3d8a-3297-4a5f-8ecf-f98936815673.png",
            "title_b": "Rob Campbell",
            "reviewerTitle_b": "",
            "review_b": "Well when they say they stand behind their product the do, had an issue and they resolved quickly and amicably.",
            "reviewStars_b": "5stars"
          }
        },
        "review_tYBJYw": {
          "type": "review",
          "settings": {
            "image": "shopify://shop_images/Peter_07ebee30-0f2f-4d4d-aeb9-6e8cebde8b14.png",
            "title": "Peter Leger",
            "reviewerTitle": "",
            "review": "First time buyer here. My transfers turned out amazing! My shirts look amazing with my new logo. I will defiantly be buying other products from this company later this week. Speedy service and great quality.",
            "reviewStars": "5stars",
            "image_b": "shopify://shop_images/Lucy_124a9e64-b7d7-485e-ac04-ab90c4bf1008.png",
            "title_b": "Lucy Suarez",
            "reviewerTitle_b": "",
            "review_b": "I've never used transfers before and it was a great experience. Easy. Clear instructions for iron on application and beautiful results. I will definitely reorder",
            "reviewStars_b": "5stars"
          }
        },
        "review_KKJL7x": {
          "type": "review",
          "settings": {
            "image": "shopify://shop_images/Terry_8483d6c6-8be1-4c69-a4d6-e91d767af803.png",
            "title": "Victoria Terry",
            "reviewerTitle": "CEO Sans Brothers",
            "review": "Five stars are not enough. I purchased a custom transfer for my son's team shirts. The ordering process was simple, quick, and very reasonably priced. The quality of the transfers is phenomenal, and I could not be happier.",
            "reviewStars": "5stars",
            "image_b": "shopify://shop_images/Marcie_d4d4c183-e1f2-4060-a95c-9fdf0e391ed8.png",
            "title_b": "Marcie Poole",
            "reviewerTitle_b": "",
            "review_b": "Thank you! I ordered from another vendor prior and the prints were not presentable for my customers. I ended up trying you with a rush order. It was perfect! You",
            "reviewStars_b": "5stars"
          }
        },
        "review_Akqe4X": {
          "type": "review",
          "settings": {
            "image": "shopify://shop_images/Edward_868dcb26-4066-4efb-88c0-55ad53d26954.png",
            "title": "Edward Garcia",
            "reviewerTitle": "",
            "review": "I have been loving the quality of the products and DTF’s I have been receiving. I ordering shirts and prints for our food pantry volunteers. They loved them.",
            "reviewStars": "5stars",
            "image_b": "shopify://shop_images/Caitlin_0a2c2370-d742-4ee4-9c07-98dd73778d94.png",
            "title_b": "Caitlin L",
            "reviewerTitle_b": "",
            "review_b": "Their friendliness and expertise made the whole experience enjoyable. I highly recommend Ninja Transfer, especially with Allie and Erin on the team!",
            "reviewStars_b": "5stars"
          }
        },
        "review_chrn9m": {
          "type": "review",
          "settings": {
            "image": "shopify://shop_images/Jill_c81fdd75-f4cc-4c8e-8e99-3449033a30ba.png",
            "title": "Jill Fragus",
            "reviewerTitle": "",
