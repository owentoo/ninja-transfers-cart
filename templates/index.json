    "faq_home_CzVrEU": {
      "type": "faq-home",
      "blocks": {
        "qa_39YHdB": {
          "type": "qa",
          "settings": {
            "title": "What is a DTF transfer?",
            "answer": "DTF stands for Direct-to-Film, a printing method where your design is printed onto a special film and then heat pressed onto a garment. DTF transfers work on a wide range of fabrics—including cotton, polyester, blends, and more—and can be applied in about 12-15 seconds with a heat press.",
            "isOpen": false
          }
        },
        "qa_BrRrWw": {
          "type": "qa",
          "settings": {
            "title": "What is the minimum I can order?",
            "answer": "No Minimums! Whether you need 1 or 100,000 we can do it!",
            "isOpen": false
          }
        },
        "qa_8ERyRm": {
          "type": "qa",
          "settings": {
            "title": "What kind of press do I need?",
            "answer": "You can use the iron you have lying around your house or an industrial level heat press or anything in between. Learn more on our <a href=\"https://ninjatransfers.com/pages/application-instructions-for-dtf-transfers-heat-sources\" title=\"Application Instructions for DTF Transfers | Heat Sources\">How to Press</a> page.",
            "isOpen": false
          }
        },
        "qa_w7ePqi": {
          "type": "qa",
          "settings": {
            "title": "What sizes are available?",
            "answer": "We have sizes from 2\" X 2\" to 24\" X 30 feet",
            "isOpen": false
          }
        },
        "qa_iEwBxk": {
          "type": "qa",
          "settings": {
            "title": "How do transfers hold up in the wash?",
            "answer": "Ninja Transfers have been rigorously tested and verified by third party to ensure long-lasting durability. After undergoing 100 machine wash cycles (80°F, normal cycle, line dry) on a 100% cotton shirt, the transfers were evaluated for color retention, peeling, cracking, and overall integrity. The results were overwhelmingly positive, with a \"Satisfactory\" grade across all criteria, including negligible hand-feel change and no significant signs of delamination or print detachment.",
            "isOpen": false
          }
        },
        "qa_gtcGFy": {
          "type": "qa",
          "settings": {
            "title": "How quickly can I get my order?",
            "answer": "Expedited orders ship within 24 -48 hours.",
            "isOpen": false
          }
        },
        "qa_qEe7yD": {
          "type": "qa",
          "settings": {
            "title": "What file format should my artwork be?",
            "answer": "Vector art is always preferred, raster art should be at least 300 dpi. Preferred file types: .AI, .PDF Accepted files types: .JPG, .PNG",
            "isOpen": false
          }
        },
        "qa_6BdMzf": {
          "type": "qa",
          "settings": {
            "title": "What is your refund policy?",
            "answer": "We stand behind our work so If you have any issues with your transfers at all <a href=\"https://ninjatransfers.com/pages/contact\" title=\"Contact Us | Ninja Transfers\">Contact Us </a>and we'll be sure to make sure we solve whatever issue you might have.",
            "isOpen": false
          }
        }
      },
