    "global_richtext_wBGzPL": {
      "type": "global_richtext",
      "custom_css": [
        ".container--large {max-width: 850px; margin: 0 auto; /* Centers the container horizontally */ width: 100%; /* Ensures it adapts to smaller screens */ text-align: center; /* Centers all text within the container */}",
        "p {font-size: 18px; font-weight: 400; /* Regular font weight */ color: #797e86; /* Text color set to red */ line-height: 32px; /* Line height set to 20px */}"
      ],
      "settings": {
        "sectionWidth": "container--large",
        "title": "",
        "titleTag": "h2",
        "details": "<p>Ninja Peel Technology is the latest innovation from Ninja Transfers, designed to revolutionize your apparel decorating experience. Ninja Peel is the evolution of Hot Peel Transfers—combining everything you've wanted from Hot Peel while maintaining everything you've grown to love about Cold Peel. </p><p>Now, you can peel your transfers 3-4 times faster, saving you time and boosting your productivity. With the ability to peel hot or cool, these transfers make the peeling process faster and more efficient. Whether you're a seasoned professional or just starting out, Ninja Peel Transfers make decorating apparel easier than ever.</p>",
        "paddingTop": 24,
        "paddingBottom": 60
      }
    },
