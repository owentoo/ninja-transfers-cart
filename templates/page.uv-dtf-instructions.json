    "ss_video_with_text_yyVnRC": {
      "type": "ss-video-with-text",
      "blocks": {
        "heading_hzX4CT": {
          "type": "heading",
          "settings": {
            "heading": "1. Prep Your Surface and Pre-Squeegee Your UV-DTF Permasticker",
            "heading_custom": true,
            "heading_font": "inter_n6",
            "header_size": 20,
            "font_weight": "600",
            "heading_height": 130,
            "heading_mt": 0,
            "heading_color": "#000000"
          }
        },
        "text_YYjaQm": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Prepping the Area</strong> - When necessary, clean the surface of your item before applying the PermaSticker using either soap & water or a mixture of rubbing alcohol and water (50/50 mix). The cleaner the surface, the longer it will endure natural elements, washing, and wear and tear. Although it will adhere without this, it is recommended.</p><p> </p><p><strong>Pre-Squeegee</strong> - After cutting your sticker/decal out, place the design face down with the carrier side facing up. Using the padded end of the included squeegee, run over the whole design with hard pressure, back and forth 2-4 times. Additional pressure and repetitions should be applied on thin and separated design elements, such as small text.</p>",
            "text_custom": true,
            "text_font": "inter_n4",
            "text_size": 16,
            "text_height": 130,
            "text_mt": 0,
            "text_color": "#000000"
          }
        }
      },
