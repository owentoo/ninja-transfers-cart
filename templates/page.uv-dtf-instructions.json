    "ss_video_with_text_qzWyC4": {
      "type": "ss-video-with-text",
      "blocks": {
        "heading_7Fa4FA": {
          "type": "heading",
          "settings": {
            "heading": "3. Placing Your UV-DTF PermaSticker Onto Your Item",
            "heading_custom": true,
            "heading_font": "inter_n6",
            "header_size": 20,
            "font_weight": "600",
            "heading_height": 130,
            "heading_mt": 0,
            "heading_color": "#000000"
          }
        },
        "text_YPMctB": {
          "type": "text",
          "settings": {
            "text": "<p>First, identify the placement area on your item.<br/><br/><strong>For smaller designs</strong> (4 inches & under), carefully place the design onto the placement area with two hands controlling the placement.<br/><br/><strong>For larger designs</strong> (6 inches & larger), you may find it easier to place the sticker starting from one side and ending at the other. This will help control your placement, reduce bubbles underneath the design, and avoid wrinkling of the carrier sheet which could cause design elements being offset and/or design overlapping.</p><p><strong> </strong></p><p></p><p><strong>Pro Tip:</strong> Leave a corner of the carrier sheet unpressed to the product for easy peeling.</p>",
            "text_custom": true,
            "text_font": "inter_n4",
            "text_size": 16,
            "text_height": 130,
            "text_mt": 0,
            "text_color": "#000000"
          }
        }
      },
