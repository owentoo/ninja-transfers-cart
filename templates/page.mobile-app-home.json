    "blocks_WL6xph": {
      "type": "_blocks",
      "blocks": {
        "ai_gen_block_a4f4bbe_qDAJ97": {
          "type": "ai_gen_block_a4f4bbe",
          "settings": {
            "heading": "Features of our DTF Transfers",
            "subheading": "No more second guessing your artwork, product style, or product color combination. Our high quality DTF transfers are brighter, more durable, stretchier, and higher detail than any other transfer company.",
            "header_alignment": "center",
            "heading_size": 32,
            "subheading_size": 16,
            "heading_bottom_margin": 15,
            "header_bottom_margin": 40,
            "heading_color": "#000000",
            "subheading_color": "#555555",
            "section_width": 1400,
            "section_width_tablet": 750,
            "section_width_mobile": 450,
            "section_padding": 0,
            "section_padding_tablet": 30,
            "section_padding_mobile": 20,
            "section_margin": 0,
            "columns_tablet": "2",
            "columns_mobile": "1",
            "card_gap": 20,
            "card_border_radius": 8,
            "card_shadow_h_offset": 0,
            "card_shadow_v_offset": 0,
            "card_shadow_blur": 0,
            "card_shadow_color": "#0000001a",
            "card_content_bg": "#fefefe",
            "card_title_size": 20,
            "card_subtitle_size": 14,
            "card_title_color": "#fafafa",
            "card_subtitle_color": "#333333",
            "placeholder_color": "#fafafa",
            "image_aspect_ratio": 100,
            "image_fit": "contain",
            "overlay_color": "#000000",
            "overlay_opacity": 50,
            "overlay_height": 30,
            "overlay_gradient": true,
            "hover_animation": "zoom",
            "card_1_image": "shopify://shop_images/space-girl-Edit.jpg",
            "card_1_title": "Incredible Image Quality and Fine Details",
            "card_1_subtitle": "Our specially formulated DTF inks enable us to print deeper colors and a wider color gamut on our custom DTF transfers. Our color registration is performed to G7 Color Standards certified on a weekly basis for near-perfect machine linearization.",
            "card_1_bg_color": "#fafafa",
            "card_2_image": "shopify://shop_images/White_0ec02fde-73ea-47f1-8f7b-e192dd1cdcc4.png",
            "card_2_title": "Crisp Bright Whites",
            "card_2_subtitle": "The DTF transfers industry's brightest white ink with incredible stretchability. In fact every design, regardless if there is white in it, is underbased with white to ensure that there is never any dye migration -- not even on nylon, polyester, or spandex.",
            "card_2_bg_color": "#fafafa",
            "card_3_image": "shopify://shop_images/mets-fan_5860c822-8ad8-4c0d-b735-28e3d8bcfb87.jpg",
            "card_3_title": "No Borders Necessary",
            "card_3_subtitle": "The DTF transfer above is a 4 inch wide print. Look at the incredible detail you can achieve with any design without any connecting background or border on your design. Use DTF transfers in place of vinyl, screen printing, sublimation, and more.",
            "card_3_bg_color": "#f0f0f0",
            "card_4_image": "shopify://shop_images/Photos_b5f1b4ff-b727-4fc6-9171-912f02d37272.jpg",
            "card_4_title": "Super Fine Details",
            "card_4_subtitle": "DTF transfers can handle down to 3 pixels of detail, which means that it can handle all design accents and small text, even if it's not connected to other parts of the design. The DTF transfer above shows you small text, separated elements, design accents, a registration mark...etc!",
            "card_4_bg_color": "#f0f0f0",
            "card_5_image": "shopify://shop_images/Fish-Tank.jpg",
            "card_5_title": "Beautiful Color Contrast",
            "card_5_subtitle": "Bright colors and color correctness is essential to our customers when ordering DTF transfers. The colors will show vividly on your garments across any color combination. It will surprise you time and time again how bright and beautiful your DTF transfer designs will be on your products.",
            "card_5_bg_color": "#f0f0f0",
            "card_6_image": "shopify://shop_images/Diff_Shirt_Same_Design.png",
            "card_6_title": "Any Design on Lights or Darks",
            "card_6_subtitle": "DTF transfers are easier, cleaner, brighter, more durable, and more flexible than any transfer you've worked with before.",
            "card_6_bg_color": "#f0f0f0",
            "card_7_image": "shopify://shop_images/Stretchable_soft_flexible_DTF_transfers.webp",
            "card_7_title": "Stretchability means Durability",
            "card_7_subtitle": "The stretch test demonstrates durability. You will not see cracking when you stretch our DTF transfers (within reason of course). We've also tested it for 100+ washes with very little degradation made possible by our combination of film, ink, powder, and pressing process.",
            "card_7_bg_color": "#f0f0f0",
            "card_8_image": "shopify://shop_images/Mushroom.jpg",
            "card_8_title": "Super Thin Lines",
            "card_8_subtitle": "Limitless capability in terms of what designs you can print with our DTF transfers. If you're not sure, just give it a try and you'll be more impressed with every transfer you press and every design you order.",
            "card_8_bg_color": "#f0f0f0"
          },
          "blocks": {}
        }
      },
